// DBML Schema for Business: Retail
// Version: 2
// Generated on: 2026-06-24 00:49:02

Project {
  database_type: 'Databricks Unity Catalog'
  Note: 'Lakehouse data model for Retail - Version 2'
}

Table inventory.stock_position {
  stock_position_id varchar [pk, note: 'Unique surrogate identifier for each stock position record representing a SKU-node combination at a point in time. Primary key for the stock_position data product in the Databricks Silver Layer.']
  inventory_node_id varchar [note: 'Reference to the inventory node (store, Distribution Center (DC), Micro-Fulfillment Center (MFC), or dark store) where this stock position is held. Supports omnichannel fulfillment visibility across all network nodes.']
  lot_id varchar [note: 'Foreign key linking to inventory.lot. Business justification: stock_position has a batch_number string attribute indicating lot-tracked inventory. Adding lot_id as a proper FK to the lot master record normalizes this relationship, enabling expiry date management']
  reorder_policy_id varchar [note: 'Foreign key linking to inventory.reorder_policy. Business justification: A stock position at a SKU-location level is governed by a reorder policy that defines replenishment parameters. Linking stock_position to reorder_policy enables direct comparison of current on-hand qu']
  sku_id varchar [note: 'Reference to the SKU (Stock Keeping Unit) for which this stock position is recorded. Links to the product master in the Product Information Management (PIM) system and Informatica MDM golden record.']
  sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: Retail inventory valuation (retail method of accounting) requires linking each stock position to its active selling price. Inventory planners and finance teams use this to compute on-hand retail value']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: stock_position.unit_of_measure is a denormalized text field. Linking to product.uom enforces valid UOM codes, supports UOM conversion for inventory valuation reports, and ensures consistency with the ']
  available_to_promise_qty decimal(18,4) [note: 'Quantity of the SKU available to commit to new customer orders or fulfillment requests. Calculated as on-hand minus reserved, damaged, and quarantine quantities. Authoritative ATP signal consumed by Salesforce Commerce Cloud for omnichannel order promising (BOPIS, ROPIS, Ship-from-Store).']
  avg_daily_sales_qty decimal(18,4) [note: 'Rolling average quantity of the SKU sold per day at this node, calculated from SAP Customer Activity Repository (CAR) POS transaction data. Used to compute Weeks of Supply (WOS), reorder point, and safety stock. Input to Blue Yonder Demand Planning forecasts.']
  batch_number varchar [note: 'Supplier or manufacturer batch/lot number for the current inventory of this SKU at this node. Required for batch-managed products (food, pharmaceuticals, cosmetics) to support FDA recall traceability, CPSC compliance, and Return to Vendor (RTV) processing.']
  created_timestamp timestamp [note: 'Timestamp when this stock position record was first created in the Databricks Silver Layer. Supports data lineage, audit trail, and GDPR/CCPA data lifecycle management requirements.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the unit cost and inventory valuation amounts (e.g., USD, GBP, EUR). Supports multi-currency operations across international retail markets.']
  damaged_qty decimal(18,4) [note: 'Quantity of the SKU identified as damaged, defective, or unsellable at the inventory node. Excluded from Available-to-Promise (ATP) calculations. Tracked for shrinkage reporting, Return to Vendor (RTV) processing, and COGS (Cost of Goods Sold) write-down.']
  expiry_date date [note: 'Expiration or best-before date of the current inventory batch for perishable or date-sensitive SKUs (grocery, pharmacy, cosmetics). Used for FEFO (First Expired First Out) rotation, FDA food safety compliance, and proactive markdown or disposal before expiry.']
  in_transit_qty decimal(18,4) [note: 'Quantity of the SKU currently in transit from a supplier, Distribution Center (DC), or another node and expected to arrive at this inventory node. Sourced from Blue Yonder Demand Planning and SAP S/4HANA WM transfer orders. Used for future ATP projection.']
  inventory_valuation_method varchar [note: 'Accounting method used to value this SKU\'s inventory for financial reporting. FIFO (First In First Out), LIFO (Last In First Out), WAC (Weighted Average Cost), standard_cost, or retail_method. Governed by FASB ASC 330 and reported in financial P&L statements.']
  is_dead_stock boolean [note: 'Flag indicating whether this SKU at this node is classified as dead stock — unsold, obsolete inventory with no recent sales velocity. True when sell-through rate is zero and weeks of supply exceeds the dead stock threshold. Triggers markdown or clearance actions.']
  is_rfid_tracked boolean [note: 'Indicates whether this SKU at this node is tracked using RFID (Radio Frequency Identification) technology for real-time inventory visibility. True enables automated cycle counts and reduces manual scanning overhead. Relevant for apparel and high-value electronics categories.']
  is_vmi boolean [note: 'Indicates whether this SKU-node stock position is managed under a Vendor Managed Inventory (VMI) agreement, where the supplier is responsible for maintaining stock levels. When true, replenishment is supplier-initiated via EDI (Electronic Data Interchange) rather than retailer-triggered.']
  last_adjustment_date date [note: 'Date of the most recent manual or system-generated inventory adjustment (positive or negative) for this SKU at this node. Adjustments include shrinkage write-offs, cycle count corrections, and damage write-downs posted in SAP S/4HANA MM.']
  last_cycle_count_date date [note: 'Date of the most recent physical cycle count or inventory audit performed for this SKU at this node. Used to assess on-hand quantity accuracy, identify shrinkage, and schedule next count. Supports OSHA and internal audit compliance for inventory accuracy.']
  last_goods_receipt_date date [note: 'Date of the most recent goods receipt (inbound delivery) that updated the on-hand quantity for this SKU at this node. Sourced from SAP S/4HANA MM goods receipt postings and Manhattan Associates WMS inbound transactions. Used for freshness and lead time analysis.']
  last_sale_date date [note: 'Date of the most recent Point of Sale (POS) or e-commerce sale transaction that depleted stock for this SKU at this node. Sourced from SAP Customer Activity Repository (CAR). Used for dead stock identification, velocity scoring, and markdown trigger analysis.']
  max_stock_qty decimal(18,4) [note: 'Maximum allowable on-hand quantity for this SKU at this node, used to prevent overstock and optimize shelf/storage capacity. Defined in Oracle Retail Merchandising System (ORMS) and used by replenishment planning to cap order quantities within Open-to-Buy (OTB) constraints.']
  on_hand_qty decimal(18,4) [note: 'Total physical quantity of the SKU currently present at the inventory node, including all stock categories (sellable, reserved, damaged). Sourced from Manhattan Associates WMS goods receipt and adjustment transactions. Core metric for inventory visibility.']
  on_order_qty decimal(18,4) [note: 'Quantity of the SKU on open purchase orders or replenishment orders placed with suppliers but not yet shipped. Sourced from Oracle Retail Merchandising System (ORMS) purchase order lines. Represents future supply commitment within the Open-to-Buy (OTB) budget.']
  position_status varchar [note: 'Current lifecycle status of the stock position record. Active: normal sellable stock; frozen: temporarily locked pending investigation; quarantine: damaged or suspect stock held for quality review; blocked: SAP-blocked stock not available for sale; closed: position deactivated (zero stock, node closed).']
  position_timestamp timestamp [note: 'The precise date and time at which this stock position snapshot was captured or last updated. Represents the real-world event time of the inventory state. Critical for real-time ATP (Available-to-Promise) accuracy and omnichannel fulfillment SLA compliance.']
  quarantine_qty decimal(18,4) [note: 'Quantity of the SKU placed in quarantine pending quality inspection, regulatory hold, or recall investigation. Separate from damaged stock. Relevant for FDA food safety holds, CPSC recall compliance, and supplier quality disputes.']
  reorder_point_qty decimal(18,4) [note: 'Minimum on-hand quantity threshold at which a replenishment order is automatically triggered for this SKU at this node. Calculated by Blue Yonder Demand Planning based on lead time, demand velocity, and safety stock parameters. Core input to replenishment trigger logic.']
  replenishment_status varchar [note: 'Current replenishment workflow status for this SKU-node combination. normal: no action needed; triggered: reorder point breached, order pending; in_progress: replenishment order placed and open; suspended: replenishment paused (e.g., seasonal end, discontinuation); vmi: under Vendor Managed Inventory (VMI) control.']
  reserved_qty decimal(18,4) [note: 'Quantity of the SKU reserved against confirmed customer orders, BOPIS (Buy Online Pick Up In Store), ROPIS (Reserve Online Pick Up In Store), or internal transfer orders. Not available for new ATP commitments until reservation is released or fulfilled.']
  safety_stock_qty decimal(18,4) [note: 'Buffer stock quantity maintained above the reorder point to protect against demand variability and supply lead time uncertainty. Set by Blue Yonder Demand Planning. Prevents stockouts during peak demand or supplier delays.']
  sell_through_rate decimal(7,4) [note: 'Percentage of received inventory that has been sold within a defined period, expressed as a decimal (e.g., 0.7500 = 75%). Key performance indicator for assortment efficiency, markdown timing, and dead stock identification. Calculated from SAP Customer Activity Repository (CAR) POS data.']
  shrinkage_qty decimal(18,4) [note: 'Cumulative quantity of inventory loss attributed to shrinkage (theft, administrative error, vendor fraud, or damage) since the last cycle count or physical inventory. Used for shrinkage monitoring, loss prevention analytics, and COGS adjustment reporting.']
  source_record_reference varchar [note: 'The native record identifier from the originating operational system (e.g., SAP material document number, Manhattan Associates WMS inventory record ID). Enables traceability back to the system of record for reconciliation, audit, and EDI dispute resolution.']
  source_system_code varchar [note: 'Code identifying the operational system of record that originated this stock position record. SAP_S4: SAP S/4HANA; ORMS: Oracle Retail Merchandising System; MAWMS: Manhattan Associates WMS; BYOND: Blue Yonder Demand Planning; SFCC: Salesforce Commerce Cloud; CAR: SAP Customer Activity Repository. Supports data lineage and Master Data Management (MDM) reconciliation.']
  storage_location_code varchar [note: 'Specific storage location, bin, aisle, or zone within the inventory node where this SKU is physically stored. Sourced from Manhattan Associates WMS. Used for pick/pack/ship operations, cycle counts, and planogram (POG) compliance in store operations.']
  unit_cost decimal(18,4) [note: 'Standard cost per unit of the SKU used for inventory valuation and Cost of Goods Sold (COGS) calculation. Sourced from SAP S/4HANA FI/CO module. Confidential as it reflects supplier pricing and margin strategy. Used for GMROI (Gross Margin Return on Investment) analysis.']
  upc varchar [note: 'Universal Product Code (UPC) or European Article Number (EAN) barcode identifier for the SKU. Used for Point of Sale (POS) scanning, RFID tracking, and GS1-compliant product identification across the supply chain.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to this stock position record in the Databricks Silver Layer. Used for incremental data processing, change data capture (CDC), and audit trail compliance.']
  velocity_band varchar [note: 'ABC/D velocity classification of the SKU at this node based on sales frequency and volume. A: fast-moving (top sellers); B: medium-moving; C: slow-moving; D: very slow or non-moving (dead stock candidate). Used for replenishment prioritization, planogram slotting, and markdown strategy.']
  weeks_of_supply decimal(10,2) [note: 'Number of weeks the current on-hand quantity is projected to last based on the current average weekly sales velocity. Key inventory health metric (WOS) used by merchants and planners to identify overstock, understock, and dead stock situations.']

  Note: 'Real-time on-hand stock position for every SKU at each inventory node (store, DC, MFC, dark store). Captures on-hand quantity, available-to-promise (ATP), reserved quantity, in-transit quantity, on-order quantity, damaged/quarantine quantity, and velocity indicators. Authoritative SSOT for current inventory levels consumed by omnichannel fulfillment (ATP/promising), replenishment triggers, and store operations. Updated by goods receipts, sales depletions, adjustments, transfers, and reservations.'
}

Table inventory.stock_ledger {
  stock_ledger_id varchar [pk, note: 'Unique surrogate identifier for each stock ledger transaction record. Primary key for the perpetual inventory ledger at the SKU-location-date level.']
  fulfillment_line_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_line. Business justification: Each fulfillment line pick generates a stock ledger entry. Line-level traceability between inventory movements and fulfillment lines is required for short-pick shrinkage detection, COGS allocation per']
  goods_receipt_id varchar [note: 'Foreign key linking to inventory.goods_receipt. Business justification: Goods receipts generate stock ledger entries recording the inventory increase at the receiving node. stock_ledger has reference_document_number and reference_document_type string fields that generical']
  inventory_node_id varchar [note: 'Foreign key linking to inventory.inventory_node. Business justification: Every stock movement transaction in the perpetual ledger occurs at an inventory node (store, DC, MFC). stock_ledger currently references inventory.location via location_id, but inventory_node is the autho']
  location_id varchar [note: 'Reference to the inventory node (store, Distribution Center (DC), Micro-Fulfillment Center (MFC), or dark store) where the stock movement occurred.']
  lot_id varchar [note: 'Foreign key linking to inventory.lot. Business justification: stock_ledger has a lot_number string attribute for lot-tracked movements. Replacing this with a proper FK lot_id to the lot master record normalizes lot tracking in the perpetual ledger, enabling full']
  markdown_id varchar [note: 'Foreign key linking to pricing.markdown. Business justification: Markdown events generate stock ledger entries recording retail value write-downs. Linking stock_ledger to markdown_id allows retail-method accounting systems to reconcile markdown transactions against']
  order_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_order. Business justification: Fulfillment orders trigger inventory movement postings (goods issue, pick, ship). Linking stock_ledger to fulfillment_order enables fulfillment-driven inventory movement reporting, COGS reconciliation']
  outbound_order_id varchar [note: 'Foreign key linking to supplychain.outbound_order. Business justification: DC outbound operations: when a DC ships to a store via an outbound_order, stock_ledger entries record the inventory deduction. Retail DC inventory controllers need to trace stock_ledger outbound movem']
  price_change_id varchar [note: 'Foreign key linking to pricing.price_change. Business justification: Under the retail inventory method, price change events generate stock ledger entries (retail value write-ups/write-downs). Linking stock_ledger to price_change enables retail accounting systems to tra']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Promotional lift analysis requires attributing inventory movements (sales, markdowns) to specific campaigns. Enables campaign-level sell-through reporting, promotional shrinkage tracking, and vendor c']
  receiving_event_id varchar [note: 'Foreign key linking to supplychain.receiving_event. Business justification: DC receiving operations: when goods are unloaded and received (receiving_event), stock_ledger entries are created to record the inventory movement. Retail DC inventory accountants need to trace every ']
  reversed_transaction_stock_ledger_id varchar [note: 'Self-referencing identifier pointing to the original stock_ledger_id that this record reverses. Populated only when reversal_flag = True. Enables bidirectional audit trail linking between original and reversal entries.']
  shipment_id varchar [note: 'Foreign key linking to fulfillment.shipment. Business justification: Shipment completion triggers goods-issue stock ledger postings. Linking stock_ledger to shipment enables shipment-level inventory cost reconciliation, carrier charge vs. inventory cost variance report']
  sku_id varchar [note: 'Reference to the SKU (Stock Keeping Unit) involved in this stock movement transaction. Links to the product master for item-level inventory tracking.']
  sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: Financial reconciliation requires linking inventory movements to pricing effective at transaction time. COGS calculations, margin analysis, and GL posting validation depend on capturing the price-at-t']
  stock_transfer_id varchar [note: 'Foreign key linking to inventory.stock_transfer. Business justification: Stock transfer movements generate stock ledger entries (debit at source node, credit at destination node). stock_ledger has reference_document_number and reference_document_type string fields that gen']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: stock_ledger.unit_of_measure is a denormalized text field. Stock ledger entries drive financial inventory valuation; linking to product.uom ensures UOM integrity for cost accounting, audit trails, and']
  vendor_id varchar [note: 'Reference to the supplier associated with this stock movement, applicable for receipt and Direct Store Delivery (DSD) transactions. Null for internal transfers and sales depletions.']
  channel varchar [note: 'The omnichannel fulfillment channel through which this stock movement was triggered. STORE = in-store POS sale; ECOMMERCE = online order depletion; BOPIS = Buy Online Pick Up In Store; SHIP_FROM_STORE = store-as-fulfillment-center; DC = Distribution Center; MFC = Micro-Fulfillment Center; DARK_STORE = fulfillment-only location. [ENUM-REF-CANDIDATE: STORE|ECOMMERCE|BOPIS|SHIP_FROM_STORE|DC|MFC|DARK_STORE — 7 candidates stripped; promote to reference product]']
  created_timestamp timestamp [note: 'The timestamp when this stock ledger record was first created in the data platform. Represents the system audit creation time, distinct from the business transaction_timestamp. Used for data lineage, audit trail, and Silver layer processing tracking.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code in which unit_cost, extended_cost, unit_retail_price, and extended_retail_value are denominated (e.g., USD, EUR, GBP). Supports multi-currency retail operations.']
  dead_stock_flag boolean [note: 'Indicates whether this stock movement is associated with dead stock (unsold, obsolete inventory being written off or liquidated). True = dead stock write-off or clearance movement. Supports inventory health reporting and markdown decision-making.']
  dsd_flag boolean [note: 'Indicates whether this receipt transaction was fulfilled via Direct Store Delivery (DSD), where the supplier delivers directly to the store bypassing the Distribution Center (DC). True = DSD transaction. Impacts supply chain routing and vendor compliance tracking.']
  expiry_date date [note: 'The expiration or best-before date of the inventory units involved in this transaction. Applicable for perishable grocery, pharmaceutical, and health/beauty products. Used for FEFO (First Expired First Out) rotation, dead stock identification, and FDA compliance.']
  extended_cost decimal(18,4) [note: 'Total cost value of this stock movement, calculated as movement_quantity multiplied by unit_cost. Represents the financial impact on inventory valuation and feeds the general ledger Cost of Goods Sold (COGS) account. Used for financial reconciliation.']
  extended_retail_value decimal(18,4) [note: 'Total retail value of this stock movement, calculated as movement_quantity multiplied by unit_retail_price. Used in the retail inventory method for inventory valuation and supports gross margin return on investment (GMROI) reporting.']
  fiscal_period varchar [note: 'The retail fiscal period (year and period number, e.g., 2024-P01) to which this stock movement is attributed for financial reporting and inventory reconciliation. Supports 4-4-5 and 4-5-4 retail calendar structures.']
  movement_quantity decimal(18,4) [note: 'The quantity of units moved in this transaction. Positive values indicate stock increases (receipts, returns, transfer-in); negative values indicate stock decreases (sales, write-offs, transfer-out). Expressed in the SKU\'s base unit of measure.']
  movement_reason_code varchar [note: 'Standardized reason code providing additional context for the stock movement (e.g., VENDOR_RETURN, DAMAGED_GOODS, CYCLE_COUNT_VARIANCE, THEFT_SHRINKAGE, EXPIRED_PRODUCT, PROMOTIONAL_WRITE_DOWN). Supports shrinkage analysis and loss prevention reporting. [ENUM-REF-CANDIDATE: VENDOR_RETURN|DAMAGED_GOODS|CYCLE_COUNT_VARIANCE|THEFT_SHRINKAGE|EXPIRED_PRODUCT|PROMOTIONAL_WRITE_DOWN|CUSTOMER_RETURN|INTER_DC_TRANSFER — promote to reference product]']
  notes varchar [note: 'Free-text field for additional context or commentary on this stock movement, entered by warehouse staff, store associates, or system processes (e.g., cycle count discrepancy explanation, damage description, special handling notes). Supports operational investigation and audit.']
  on_hand_quantity_after decimal(18,4) [note: 'The total on-hand inventory quantity for this SKU at this location immediately after this transaction was applied. Represents the running balance of the perpetual inventory ledger and is the authoritative stock position for omnichannel fulfillment visibility.']
  on_hand_quantity_before decimal(18,4) [note: 'The total on-hand inventory quantity for this SKU at this location immediately before this transaction was applied. Enables point-in-time inventory reconstruction and audit trail validation of the perpetual ledger.']
  posting_date date [note: 'The accounting date on which this stock movement is posted to the general ledger and inventory valuation records. May differ from transaction_timestamp due to cut-off processing, period-end adjustments, or delayed DSD confirmations.']
  reference_document_number varchar [note: 'The source document number from the originating business transaction that triggered this stock movement (e.g., Purchase Order number, Transfer Order number, POS receipt number, Return Merchandise Authorization (RMA) number). Enables end-to-end traceability.']
  reference_document_type varchar [note: 'The type of source document associated with this stock movement (e.g., PURCHASE_ORDER, TRANSFER_ORDER, POS_RECEIPT, RMA = Return Merchandise Authorization, CYCLE_COUNT, WRITE_OFF_ORDER). Enables document-level drill-through for audit and reconciliation.']
  reversal_flag boolean [note: 'Indicates whether this stock ledger entry is a reversal (counter-entry) of a previously posted transaction. True = this record reverses a prior movement. Used to identify corrective entries and maintain a clean audit trail for financial reconciliation.']
  rfid_tracked boolean [note: 'Indicates whether this stock movement was captured or validated using Radio Frequency Identification (RFID) technology. True = RFID-confirmed movement. Supports inventory accuracy benchmarking and RFID program performance reporting.']
  serial_number varchar [note: 'The unique serial number of the specific inventory unit involved in this transaction. Applicable for high-value electronics, appliances, and serialized items. Supports specific identification costing, warranty tracking, and CPSC recall management.']
  shrinkage_flag boolean [note: 'Indicates whether this stock movement represents inventory shrinkage (loss due to theft, damage, administrative error, or vendor fraud). True = shrinkage event. Used for shrinkage monitoring, loss prevention analytics, and CPSC/NRF compliance reporting.']
  source_system_code varchar [note: 'Identifies the operational system of record that originated this stock ledger transaction (e.g., SAP_S4 = SAP S/4HANA Retail, ORMS = Oracle Retail Merchandising System, MANHATTAN_WMS = Manhattan Associates WMS, SFCC = Salesforce Commerce Cloud, SAP_CAR = SAP Customer Activity Repository). Supports data lineage and reconciliation.']
  transaction_number varchar [note: 'Externally-known business identifier for this stock movement transaction, sourced from the originating system (e.g., SAP material document number, ORMS transaction reference). Used for cross-system reconciliation and audit tracing.']
  transaction_status varchar [note: 'Current lifecycle state of the stock ledger transaction. POSTED = confirmed and applied to on-hand balance; PENDING = awaiting confirmation; REVERSED = corrected by a counter-entry; VOIDED = cancelled before posting; ERROR = failed validation.']
  transaction_timestamp timestamp [note: 'The precise real-world date and time when the stock movement event occurred (e.g., POS scan time, receiving dock timestamp, cycle count completion time). This is the principal business event time, distinct from system audit timestamps.']
  transaction_type varchar [note: 'Classification of the stock movement event driving this ledger entry. RECEIPT = inbound from supplier or DC; SALE = Point of Sale (POS) depletion; TRANSFER_IN/OUT = inter-location movement; ADJUSTMENT = cycle count correction; RETURN = customer or Return to Vendor (RTV); WRITE_OFF = shrinkage or dead stock removal. [ENUM-REF-CANDIDATE: RECEIPT|SALE|TRANSFER_IN|TRANSFER_OUT|ADJUSTMENT|RETURN|WRITE_OFF|DSD_RECEIPT|MARKDOWN_WRITE_DOWN|CYCLE_COUNT — promote to reference product]']
  unit_cost decimal(18,4) [note: 'The per-unit cost (Cost of Goods Sold - COGS) applied to this stock movement at the time of the transaction. Used for inventory valuation under FIFO, Weighted Average Cost (WAC), or retail inventory method. Sourced from the active cost layer in SAP S/4HANA.']
  unit_retail_price decimal(18,4) [note: 'The retail selling price per unit at the time of the transaction. Used for inventory valuation under the retail inventory method and for calculating gross margin. Supports Average Unit Retail (AUR) analytics and sell-through rate calculations.']
  updated_timestamp timestamp [note: 'The timestamp when this stock ledger record was last modified in the data platform (e.g., due to a reversal posting, status correction, or revaluation). Used for change data capture, audit trail, and incremental processing in the Databricks Lakehouse Silver layer.']
  valuation_method varchar [note: 'The inventory costing method applied to this stock movement for financial valuation purposes. FIFO = First In First Out; WAC = Weighted Average Cost; RETAIL_METHOD = retail inventory method; LIFO = Last In First Out (where permitted); SPECIFIC_ID = specific identification for high-value items.']
  vmf_flag boolean [note: 'Indicates whether this stock movement is part of a Vendor Managed Inventory (VMI) arrangement, where the supplier is responsible for maintaining stock levels. True = VMI-managed transaction. Impacts replenishment ownership and supplier performance tracking.']

  Note: 'Perpetual inventory ledger capturing every stock movement transaction at the SKU-location-date level. Records receipts, sales depletions, transfers, adjustments, returns, and write-offs with quantity, unit cost (COGS), and extended value. Supports inventory valuation methods (FIFO, WAC, retail method), shrinkage tracking, and financial reconciliation with the general ledger. Authoritative SSOT for inventory value and movement history within the inventory domain.'
}

Table inventory.inventory_node {
  inventory_node_id varchar [pk, note: 'Unique surrogate identifier for every physical or logical inventory-holding location in the retail network (stores, DCs, MFCs, dark stores, vendor-managed locations, in-transit nodes). Primary key of this master record.']
  cost_zone_id varchar [note: 'Foreign key linking to pricing.cost_zone. Business justification: Inventory nodes are assigned to cost zones that determine landed cost, freight factors, and duty rates applicable to that node. This assignment drives cost_price calculations for replenishment and goo']
  dc_facility_id varchar [note: 'Add column dc_facility_id (BIGINT) to supplychain.inventory_node with FK to supplychain.dc_facility.dc_facility_id because inventory nodes at distribution centers should reference the DC facility. P15: connect_table: supplychain.inventory_node*']
  location_id varchar [note: 'Add column location_id (BIGINT) to store.inventory_node with FK to store.location.location_id because inventory nodes represent physical locations. P14: connect_table: store.inventory_node** - add column location_id (BIGINT) with FK']
  price_zone_id varchar [note: 'Foreign key linking to pricing.price_zone. Business justification: Every retail store/DC node belongs to a price zone that determines which sku_price records are active for that location. Price zone assignment to inventory nodes is fundamental to retail pricing execu']
  address_line1 varchar [note: 'Primary street address of the inventory node facility. Used for carrier routing, last-mile delivery coordination, and regulatory filings.']
  address_line2 varchar [note: 'Secondary address detail (suite, dock number, building identifier) for the inventory node facility.']
  city varchar [note: 'City in which the inventory node is located. Used for geographic reporting, tax jurisdiction assignment, and carrier zone mapping.']
  close_date date [note: 'Calendar date on which the inventory node was permanently closed or decommissioned. Null for active nodes. Used for historical inventory reporting and asset disposal tracking.']
  country_code varchar [note: 'Three-letter ISO 3166-1 alpha-3 country code for the node location. Governs applicable regulatory frameworks (FDA, CPSC, GDPR/CCPA), currency, and customs rules.']
  created_timestamp timestamp [note: 'Timestamp when this inventory node master record was first created in the system, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Supports MDM audit trails and data lineage in Informatica MDM.']
  cycle_count_frequency varchar [note: 'Scheduled frequency at which physical inventory cycle counts are conducted at this node. Drives WMS task scheduling and shrinkage monitoring cadence.']
  district_code varchar [note: 'Internal district code within a region, used for field management span-of-control, district-level KPI reporting, and workforce scheduling via Workday HCM.']
  dock_door_count varchar [note: 'Number of inbound/outbound dock doors at the node. Determines receiving throughput capacity, inbound appointment scheduling windows, and cross-docking feasibility in Manhattan Associates WMS.']
  format_code varchar [note: 'Retail format identifier assigned to the node (e.g., \'HYPERMARKET\', \'DISCOUNT\', \'DEPT_STORE\', \'ECOMM_FC\'). Drives assortment breadth/depth rules in ORMS and planogram (POG) assignments.']
  gln varchar [note: 'GS1-issued 13-digit Global Location Number uniquely identifying this node in the global supply chain. Used in EDI transactions (ASC X12 / EDIFACT), RFID-based receiving, and supplier communications.']
  is_bopis_enabled boolean [note: 'Indicates whether the node supports Buy Online Pick Up In Store (BOPIS) fulfillment. Drives order routing logic in the OMS and Salesforce Commerce Cloud checkout flow.']
  is_drop_ship_origin boolean [note: 'Indicates whether this node acts as a drop-ship origin point where a vendor ships directly to the end customer on behalf of the retailer, bypassing DC inventory.']
  is_rfid_enabled boolean [note: 'Indicates whether the node is equipped with RFID infrastructure for real-time inventory tracking, cycle count automation, and shrinkage reduction.']
  is_ropis_enabled boolean [note: 'Indicates whether the node supports Reserve Online Pick Up In Store (ROPIS), allowing customers to reserve items online and collect without pre-payment.']
  is_ship_from_store_enabled boolean [note: 'Indicates whether the node is configured as a Ship-from-Store (SFS) fulfillment center, allowing it to pick, pack, and ship e-commerce orders directly to customers.']
  is_vmi_enabled boolean [note: 'Indicates whether this node participates in a Vendor Managed Inventory (VMI) program where the supplier is responsible for maintaining stock levels.']
  last_cycle_count_date date [note: 'Date of the most recent physical inventory cycle count performed at this node. Used to assess inventory accuracy, schedule next count, and monitor shrinkage compliance.']
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent modification to this inventory node master record. Used for change data capture (CDC), MDM synchronization, and Silver Layer incremental processing in Databricks.']
  latitude decimal(9,6) [note: 'WGS-84 decimal latitude coordinate of the node. Enables geospatial proximity analysis for BOPIS radius calculations, last-mile routing optimization, and store clustering.']
  longitude decimal(9,6) [note: 'WGS-84 decimal longitude coordinate of the node. Used alongside latitude for geospatial routing, catchment area analysis, and omnichannel fulfillment optimization.']
  manager_name varchar [note: 'Name of the store manager, DC operations manager, or facility lead responsible for this inventory node. Used for escalation routing, audit accountability, and Workday HCM workforce reporting.']
  max_sku_capacity varchar [note: 'Maximum number of distinct SKUs (Stock Keeping Units) the node can actively stock based on shelf slots, bin locations, and planogram (POG) configuration. Used in assortment planning and OTB (Open to Buy) calculations.']
  node_code varchar [note: 'Externally-known alphanumeric business identifier for the node as maintained in SAP S/4HANA WM and Oracle Retail Merchandising System (ORMS). Used in EDI transactions, purchase orders, and replenishment plans to reference the location. Serves as the BUSINESS_IDENTIFIER (MASTER_RESOURCE canonical category).']
  node_name varchar [note: 'Human-readable display name of the inventory node (e.g., \'Chicago Midway DC\', \'Store #0421 – Oak Park\'). Used in operational reports, planograms, and WMS screens. Serves as the IDENTITY_LABEL (MASTER_RESOURCE canonical category).']
  node_type varchar [note: 'Categorical classification of the inventory-holding location. Drives fulfillment capability rules, replenishment logic, and reporting hierarchies. Valid values: store (retail selling floor), distribution_center (DC), micro_fulfillment_center (MFC), dark_store (fulfillment-only), vendor_managed (VMI location), in_transit (goods in movement). Serves as the CLASSIFICATION_OR_TYPE (MASTER_RESOURCE canonical category).']
  open_date date [note: 'Calendar date on which the inventory node became operationally active and began receiving or fulfilling inventory. Used for comp sales (SSS) eligibility determination and new-store ramp analysis.']
  operational_status varchar [note: 'Current lifecycle state of the inventory node. Controls whether the node is eligible to receive stock, fulfill orders, or appear in replenishment plans. Serves as the LIFECYCLE_STATUS (MASTER_RESOURCE canonical category).']
  ownership_type varchar [note: 'Legal ownership or operating arrangement for the node facility. Drives lease accounting under FASB ASC 842, asset capitalization rules, and P&L cost allocation.']
  phone_number varchar [note: 'Primary operational phone number for the inventory node facility. Used for carrier coordination, inbound appointment confirmation, and emergency contact.']
  postal_code varchar [note: 'Postal or ZIP code of the inventory node. Used for carrier zone determination, last-mile delivery routing, and geographic market analysis.']
  primary_dc_node_code varchar [note: 'Node code of the primary Distribution Center (DC) that replenishes this node. Used in replenishment routing, inbound appointment scheduling, and supply chain network optimization.']
  region_code varchar [note: 'Internal geographic region code grouping nodes for regional P&L reporting, district management, and comp sales (SSS) analysis (e.g., \'MIDWEST\', \'NORTHEAST\', \'WEST_COAST\').']
  replenishment_lead_time_days varchar [note: 'Standard number of days from replenishment order placement to stock receipt at this node. Used by Blue Yonder Demand Planning to calculate reorder points, weeks of supply (WOS), and safety stock levels.']
  safety_stock_days varchar [note: 'Minimum days of supply maintained as safety stock buffer at this node to protect against demand variability and supply disruptions. Feeds Blue Yonder replenishment planning and WOS calculations.']
  selling_area_sqft decimal(12,2) [note: 'Net selling floor area in square feet, excluding back-of-house, receiving docks, and storage. Used for sales-per-square-foot KPI, planogram space allocation, and GMROI analysis.']
  state_province varchar [note: 'ISO 3166-2 state or province code for the node location. Drives sales tax rules, labor law compliance, and regional reporting.']
  subtype varchar [note: 'Secondary classification providing finer granularity within node_type (e.g., hypermarket, department_store, discount_outlet, cross_dock_dc, ambient_dc, cold_chain_dc, ship_from_store_hub). [ENUM-REF-CANDIDATE: hypermarket|department_store|discount_outlet|cross_dock_dc|ambient_dc|cold_chain_dc|ship_from_store_hub|ecommerce_fc — promote to reference product]']
  temperature_zone varchar [note: 'Storage temperature classification for the node. Governs which SKU categories (grocery, frozen, pharma) can be stocked and drives cold-chain compliance requirements under FDA food safety regulations.']
  time_zone varchar [note: 'IANA time zone identifier for the node (e.g., \'America/Chicago\'). Critical for accurate timestamp normalization of POS transactions, cycle count scheduling, and SLA window calculations across multi-timezone networks.']
  total_storage_capacity_sqft decimal(12,2) [note: 'Total physical storage area of the node measured in square feet. Used for capacity planning, space utilization analysis, and GMROI calculations. Serves as the MEASUREMENT_OR_VALUE (MASTER_RESOURCE canonical category).']

  Note: '[SSOT Owner] Authoritative source for inventory-holding locations (stores, DCs, 3PL nodes). Defines physical attributes, capabilities, and capacity of each node in the inventory network.'
}

Table inventory.replenishment_order {
  replenishment_order_id varchar [pk, note: 'Unique surrogate identifier for the replenishment order record in the Silver Layer lakehouse. Primary key for this entity.']
  cost_price_id varchar [note: 'Foreign key linking to pricing.cost_price. Business justification: Purchase order costing and landed cost validation require linking replenishment orders to contracted vendor cost structures. Enables variance analysis between ordered cost and actual invoice cost, and']
  demand_forecast_id varchar [note: 'Reference to the demand forecast record that informed the replenishment quantity calculation. Links to the Blue Yonder Demand Planning forecast used to size this order.']
  destination_node_inventory_node_id varchar [note: 'Reference to the receiving fulfillment node (store, DC, or MFC) where replenished inventory will be delivered. Drives last-mile delivery routing and receiving dock scheduling.']
  inbound_shipment_id varchar [note: 'Foreign key linking to supplychain.inbound_shipment. Business justification: Replenishment order fulfillment tracking: when a vendor ships against a replenishment_order, an inbound_shipment is created. Retail replenishment managers track expected_delivery_date vs. actual_arriv']
  lead_time_agreement_id varchar [note: 'Foreign key linking to supplier.lead_time_agreement. Business justification: Replenishment orders must reference the governing lead time SLA to enable on-time delivery compliance reporting and exception alerting. Retail supply chain teams track whether each order was fulfilled']
  outbound_order_id varchar [note: 'Foreign key linking to supplychain.outbound_order. Business justification: Store replenishment from DC: a replenishment_order (store perspective) is fulfilled by an outbound_order (DC perspective). Retail store operations and DC operations teams need to reconcile these two r']
  primary_replenishment_inventory_node_id varchar [note: 'Reference to the originating fulfillment node (Distribution Center, Micro-Fulfillment Center, or supplier location) from which inventory will be shipped. Supports omnichannel inventory routing logic.']
  promo_campaign_id varchar [note: 'Reference to the promotion event that drove this replenishment order, when trigger_type is promotional. Links to the promotion master to support promotional inventory planning and post-event analysis. Nullable for non-promotional orders.']
  purchase_order_id varchar [note: 'Reference to the associated purchase order in SAP S/4HANA MM or Oracle Retail Merchandising System (ORMS) when the replenishment order results in a supplier PO. Nullable for internal DC-to-store transfers.']
  reorder_policy_id varchar [note: 'Reference to the reorder policy that triggered this replenishment order. Links to the replenishment plan thresholds (reorder point, safety stock, max stock) configured in Blue Yonder Demand Planning.']
  replenishment_plan_id varchar [note: 'Foreign key linking to supplychain.replenishment_plan. Business justification: Replenishment execution tracking: a replenishment_order is the execution artifact of a replenishment_plan. Retail buyers and planners need to compare planned vs. actual order quantities and timing. Th']
  sku_id varchar [note: 'Reference to the SKU (Stock Keeping Unit) being replenished. Links to the product master in Oracle Retail Merchandising System (ORMS) and Informatica MDM product golden record.']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: replenishment_order.unit_of_measure is a denormalized text field. Replenishment orders must reference the authoritative UOM for MOQ compliance, vendor ordering units, and purchase order generation — a']
  vendor_contract_id varchar [note: 'Foreign key linking to supplier.vendor_contract. Business justification: Replenishment orders must be placed under an active vendor contract to enforce pricing, MOQ, and payment terms. Retail procurement compliance requires each order to reference the governing contract fo']
  vendor_id varchar [note: 'Reference to the supplier (vendor) fulfilling this replenishment order. Represents the PARTY_REFERENCE for this transaction. Links to the supplier master managed in Informatica MDM and SAP S/4HANA MM vendor master.']
  vendor_item_id varchar [note: 'Foreign key linking to supplier.vendor_item. Business justification: When raising a replenishment order, buyers reference the vendor\'s catalog entry (vendor_item) to confirm pack size, MOQ, and unit cost. This link enables PO accuracy validation and cost capture at ord']
  actual_delivery_date date [note: 'The date the replenishment order was physically received and confirmed at the destination node. Compared against expected_delivery_date to measure supplier on-time delivery performance and SLA compliance.']
  approved_quantity decimal(18,4) [note: 'The quantity confirmed and approved for fulfillment after supplier acceptance, MOQ compliance checks, and buyer review. May differ from ordered_quantity due to supplier constraints or buyer adjustments.']
  approved_timestamp timestamp [note: 'The date and time the replenishment order was approved by the buyer or automatically confirmed by the system. Marks the transition from draft/submitted to approved status in the order lifecycle.']
  buyer_notes varchar [note: 'Free-text notes entered by the merchandise buyer or replenishment analyst providing context for manual overrides, special handling instructions, or supplier communication details for this replenishment order.']
  cancellation_reason varchar [note: 'The business reason for cancelling the replenishment order. Overstock = destination node already has sufficient inventory; supplier_oos = supplier cannot fulfill; price_discrepancy = cost mismatch; duplicate_order = order already exists; demand_change = forecast revision eliminated need. Nullable for non-cancelled orders.']
  cancelled_timestamp timestamp [note: 'The date and time the replenishment order was cancelled, if applicable. Nullable for active or completed orders. Used for supplier chargeback processing and demand planning feedback loops.']
  created_timestamp timestamp [note: 'Audit timestamp recording when this replenishment order record was first captured in the Silver Layer data platform. Used for data lineage and pipeline monitoring.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts on this replenishment order (unit_cost, total_order_cost). Supports multi-currency operations for international supplier transactions.']
  expected_delivery_date date [note: 'The anticipated date on which the replenishment order is expected to arrive at the destination node, calculated from order_date plus lead_time_days. Used for inventory availability planning and receiving dock scheduling.']
  fulfillment_channel varchar [note: 'The physical supply chain channel through which this replenishment order will be fulfilled. dc_to_store = Distribution Center to store; supplier_to_store = Direct Store Delivery (DSD); supplier_to_dc = inbound to DC; cross_dock = Cross-Docking without DC storage; dsd = Direct Store Delivery; drop_ship = vendor ships directly to end customer. [ENUM-REF-CANDIDATE: dc_to_store|supplier_to_store|supplier_to_dc|cross_dock|dsd|drop_ship — promote to reference product]']
  is_emergency boolean [note: 'Indicates whether this replenishment order was flagged as an emergency order due to an imminent or active out-of-stock situation. Emergency orders bypass standard lead time and approval workflows. True = emergency; False = standard.']
  is_vmi boolean [note: 'Indicates whether this replenishment order is managed under a Vendor Managed Inventory (VMI) agreement where the supplier is responsible for maintaining stock levels at the destination node. True = VMI order; False = retailer-managed replenishment.']
  lead_time_days varchar [note: 'The supplier Lead Time in calendar days from order submission to expected delivery at the destination node. Sourced from SAP S/4HANA MM purchasing info record or Blue Yonder Demand Planning supplier master. Used to calculate expected_delivery_date and Weeks of Supply (WOS).']
  moq decimal(18,4) [note: 'The Minimum Order Quantity (MOQ) stipulated by the supplier for this SKU at the time the replenishment order was created. Used to validate that ordered_quantity meets supplier contractual requirements. Sourced from SAP S/4HANA MM purchasing info record.']
  moq_compliant boolean [note: 'Indicates whether the ordered_quantity meets or exceeds the supplier\'s Minimum Order Quantity (MOQ) requirement. True = compliant; False = below MOQ threshold, requiring buyer review or override.']
  order_date timestamp [note: 'The principal business event timestamp — the date and time the replenishment order was created and submitted by the demand planning or replenishment system (Blue Yonder or SAP MM). Distinct from audit timestamps.']
  order_number varchar [note: 'Externally-known business identifier for the replenishment order, sourced from Blue Yonder Demand Planning or SAP S/4HANA MM module. Used for cross-system traceability and supplier communication via EDI.']
  order_status varchar [note: 'Current lifecycle state of the replenishment order. Tracks progression from draft creation through approval, shipment, receipt at destination node, and closure. Cancelled indicates the order was voided before fulfillment. [ENUM-REF-CANDIDATE: draft|submitted|approved|in_transit|received|partially_received|cancelled|closed — promote to reference product]']
  order_type varchar [note: 'Classification of how the replenishment order was triggered. Auto-replenishment is system-generated based on reorder policy thresholds; manual is buyer-initiated; VMI (Vendor Managed Inventory) is supplier-driven; emergency covers urgent out-of-stock situations; cross_dock bypasses DC storage; drop_ship routes directly from vendor to destination. [ENUM-REF-CANDIDATE: auto_replenishment|manual|vmi|emergency|cross_dock|drop_ship — promote to reference product]']
  ordered_quantity decimal(18,4) [note: 'The quantity of the SKU originally requested in the replenishment order, expressed in the SKU\'s base unit of measure (e.g., each, case, pallet). This is the raw demand signal before supplier approval or MOQ adjustment.']
  priority_level varchar [note: 'Business priority assigned to this replenishment order, used to sequence fulfillment and allocate DC resources. Critical = imminent out-of-stock risk; high = elevated demand or promotional support; standard = routine replenishment; low = opportunistic or pre-build.']
  received_quantity decimal(18,4) [note: 'The actual quantity of the SKU physically received and confirmed at the destination node. Used to calculate fill rate and identify short shipments. Populated upon goods receipt in Manhattan Associates WMS or SAP S/4HANA WM.']
  source_system_order_ref varchar [note: 'The native order identifier from the originating source system (e.g., SAP MM document number, Blue Yonder order ID, ORMS order number). Enables reverse lookup and reconciliation with the system of record.']
  total_order_cost decimal(18,4) [note: 'The total cost of the replenishment order calculated as approved_quantity multiplied by unit_cost. Represents the financial commitment for this replenishment event. Used for Open to Buy (OTB) budget tracking and P&L reporting.']
  trigger_type varchar [note: 'The mechanism that triggered this replenishment order. reorder_point = on-hand fell below reorder point threshold; min_max = inventory fell below minimum level; days_of_supply = Weeks of Supply (WOS) fell below threshold; manual_override = buyer-initiated; vmi_signal = Vendor Managed Inventory (VMI) supplier signal; promotional = triggered by upcoming promotion event. [ENUM-REF-CANDIDATE: reorder_point|min_max|days_of_supply|manual_override|vmi_signal|promotional — promote to reference product]']
  unit_cost decimal(18,4) [note: 'The Cost of Goods Sold (COGS) per unit for this SKU at the time of the replenishment order, sourced from the SAP S/4HANA MM purchasing info record or Oracle Retail Merchandising System (ORMS). Used for inventory valuation and GMROI analysis.']
  updated_timestamp timestamp [note: 'Audit timestamp recording when this replenishment order record was last modified in the Silver Layer data platform. Supports change detection and incremental processing.']

  Note: 'Replenishment order records generated by demand planning and replenishment systems to restock SKUs at stores or DCs. Captures order type (auto-replenishment, manual, VMI), source node, destination node, ordered quantity, approved quantity, expected delivery date, lead time, MOQ compliance, and fulfillment status. Tracks the full replenishment lifecycle from trigger (based on reorder_policy thresholds) through receipt at the destination node.'
}

Table inventory.cycle_count {
  cycle_count_id varchar [pk, note: 'Unique system-generated identifier for each cycle count event record at the SKU-location level.']
  adjustment_id varchar [note: 'Reference to the inventory adjustment record created as a result of this cycle count variance exceeding the tolerance threshold. Links the count event to its financial reconciliation record.']
  department_id varchar [note: 'Foreign key linking to store.department. Business justification: Cycle counts are scheduled, executed, and reported by department within a store (e.g., \'count Apparel dept Q2\'). Retail loss prevention and inventory accuracy reporting require department-level cycle ']
  inventory_node_id varchar [note: 'Foreign key linking to inventory.inventory_node. Business justification: Cycle counts are physical inventory events conducted at inventory nodes (stores, DCs, MFCs). cycle_count currently references inventory.location via location_id, but inventory_node is the authoritative SS']
  location_id varchar [note: 'Reference to the inventory node (store, Distribution Center (DC), or Micro-Fulfillment Center (MFC)) where the cycle count is being performed.']
  sku_id varchar [note: 'Reference to the specific SKU (Stock Keeping Unit) being counted in this cycle count event.']
  sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: Retail inventory method requires cycle count variance reporting at retail value, not just cost. Linking cycle_count to sku_price enables variance_cost calculation at retail price — a standard retail a']
  stock_position_id varchar [note: 'Foreign key linking to inventory.stock_position. Business justification: A cycle count is a physical verification of the stock position at a specific SKU-location. Linking cycle_count directly to stock_position enables immediate comparison of counted_quantity vs. system_qu']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: cycle_count.unit_of_measure is a denormalized text field. Cycle count variance calculations (variance_cost, variance_quantity) require a validated UOM reference to ensure counted quantities are expres']
  warehouse_zone_id varchar [note: 'Foreign key linking to supplychain.warehouse_zone. Business justification: DC cycle counting is organized by warehouse_zone — zone managers schedule and execute counts by zone. Linking cycle_count to warehouse_zone enables zone-level count frequency tracking, compliance repo']
  abc_classification varchar [note: 'ABC classification of the SKU at the time of the cycle count, indicating inventory value and velocity tier. A = high-value/high-velocity; B = medium; C = low-value/low-velocity; D = dead stock. Drives count frequency prioritization.']
  adjustment_generated boolean [note: 'Indicates whether an inventory_adjustment record has been generated from this cycle count variance. When True, the variance has been posted to the inventory ledger for reconciliation.']
  approval_timestamp timestamp [note: 'The date and time when the cycle count result was reviewed and approved by the designated supervisor or manager, completing the approval workflow.']
  count_device_code varchar [note: 'Identifier of the handheld scanner, mobile device, or RFID reader used to perform the physical count. Supports device-level audit trail and equipment calibration tracking.']
  count_end_timestamp timestamp [note: 'The precise date and time when the physical counting activity was completed and the count was submitted by the assigned counter.']
  count_frequency varchar [note: 'The scheduled counting frequency for this SKU-location combination, typically driven by ABC classification or velocity. High-velocity A-items are counted more frequently than slow-moving C-items.']
  count_notes varchar [note: 'Free-text field for the counter or supervisor to record observations, exceptions, or explanations related to the cycle count result (e.g., damaged packaging, items in transit, display stock not included).']
  count_number varchar [note: 'Externally-known business reference number assigned to the cycle count event, used for cross-system tracking and audit trail. Typically generated by the WMS (e.g., Manhattan Associates) or SAP WM module.']
  count_start_timestamp timestamp [note: 'The precise date and time when the physical counting activity was initiated by the assigned counter. Used for cycle time analysis and labor tracking.']
  count_status varchar [note: 'Current workflow state of the cycle count event. \'scheduled\' = count is planned but not started; \'in_progress\' = counting is underway; \'completed\' = physical count recorded; \'reconciled\' = variance reviewed and inventory adjustment posted; \'cancelled\' = count was voided.']
  count_type varchar [note: 'Classification of the cycle count method. \'scheduled\' = routine planned count; \'ad_hoc\' = unplanned triggered count; \'blind\' = counter does not see system quantity; \'directed\' = WMS-directed count task; \'rfid_assisted\' = count performed using Radio Frequency Identification (RFID) technology.']
  counted_quantity decimal(18,4) [note: 'The actual physical quantity of the SKU observed and recorded by the counter during the cycle count. This is the primary measured outcome of the count event.']
  created_timestamp timestamp [note: 'The date and time when this cycle count record was first created in the system, establishing the audit trail for SOX inventory controls.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the monetary values (variance_cost, unit_cost) recorded in this cycle count record (e.g., USD, GBP, EUR).']
  fiscal_period varchar [note: 'The retail fiscal period (year and period number, e.g., 2024-P06) during which the cycle count was performed. Used for period-end inventory accuracy reporting and financial close processes.']
  planogram_location varchar [note: 'The planogram (POG) shelf position or fixture reference for the SKU at the store location, used to direct the counter to the correct physical location during in-store cycle counts.']
  recount_number varchar [note: 'Sequential count of how many times this SKU-location has been recounted within the same cycle count event. First count = 1; first recount = 2; etc. Supports escalation workflows when repeated recounts still show variance.']
  recount_required boolean [note: 'Indicates whether a recount of this SKU-location is required because the variance exceeded the tolerance threshold or the count was flagged for discrepancy. When True, a follow-up count must be performed before reconciliation.']
  scheduled_date date [note: 'The calendar date on which the cycle count was planned to be performed, as set in the WMS count schedule.']
  shrinkage_category varchar [note: 'Classification of the root cause of inventory shrinkage identified through this cycle count. Populated during the reconciliation phase when a negative variance is confirmed. Supports shrinkage investigation and loss prevention analytics.']
  storage_bin varchar [note: 'The specific warehouse storage bin, shelf, or slot location within the inventory node where the SKU is physically stored and counted. Granular location identifier used by the WMS for directed counting.']
  system_quantity decimal(18,4) [note: 'The inventory quantity recorded in the Warehouse Management System (WMS) or ERP at the exact time the cycle count was initiated. This is the \'book\' quantity against which the physical count is compared.']
  trigger_reason varchar [note: 'Business reason that initiated this cycle count. Supports shrinkage investigation and root cause analysis. [ENUM-REF-CANDIDATE: routine|negative_inventory|shrinkage_alert|receiving_discrepancy|customer_complaint|audit_request|rfid_discrepancy — promote to reference product]']
  unit_cost decimal(18,4) [note: 'The Cost of Goods Sold (COGS) unit cost of the SKU at the time the cycle count was performed, used to calculate the financial impact of any inventory variance.']
  updated_timestamp timestamp [note: 'The date and time when this cycle count record was last modified, supporting audit trail and change tracking requirements.']
  variance_cost decimal(18,2) [note: 'The monetary value of the inventory variance, calculated as variance_quantity multiplied by the unit cost at time of count. Expressed in the local operating currency. Used for Cost of Goods Sold (COGS) impact assessment and financial reporting.']
  variance_percentage decimal(10,4) [note: 'The variance quantity expressed as a percentage of the system on-hand quantity, calculated as (variance_quantity / system_quantity) * 100. Used to assess inventory accuracy and trigger shrinkage investigations when thresholds are exceeded.']
  variance_quantity decimal(18,4) [note: 'The difference between the physically counted quantity and the system on-hand quantity (counted_quantity minus system_quantity). A negative value indicates shrinkage or loss; a positive value indicates an overcount or unrecorded receipt.']
  variance_tolerance_pct decimal(10,4) [note: 'The maximum acceptable variance percentage for this SKU-location before a recount or inventory adjustment is triggered. Variances exceeding this threshold generate inventory_adjustment records for reconciliation.']

  Note: 'Scheduled and ad-hoc physical inventory cycle count events at the SKU-location level. Captures count schedule, assigned counter, counted quantity, system quantity at time of count, variance quantity, variance percentage, count status (scheduled, in-progress, completed, reconciled), and approval workflow. Supports shrinkage investigation, inventory accuracy KPIs, and Sarbanes-Oxley inventory controls. Variances exceeding tolerance thresholds generate inventory_adjustment records for reconciliation.'
}

Table inventory.adjustment {
  adjustment_id varchar [pk, note: 'Unique system-generated identifier for each inventory adjustment record. Serves as the primary key for the adjustment data product and is referenced by the stock ledger and loss prevention systems.']
  cost_price_id varchar [note: 'Foreign key linking to pricing.cost_price. Business justification: Shrinkage and adjustment financial impact calculations require cost basis. GL posting, P&L impact analysis, and loss prevention reporting depend on linking adjustments to the cost structure for accura']
  fulfillment_line_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_line. Business justification: Fulfillment line exceptions (substitution, short-pick, damage at pick) directly trigger inventory adjustments. Line-level adjustment traceability is a standard WMS audit requirement enabling per-line ']
  inventory_node_id varchar [note: 'Foreign key linking to inventory.inventory_node. Business justification: Inventory adjustments (shrinkage, damage, recalls) occur at inventory nodes. adjustment currently references inventory.location via location_id, but inventory_node is the SSOT for inventory-holding locati']
  location_id varchar [note: 'Reference to the specific inventory node (store, Distribution Center (DC), Micro-Fulfillment Center (MFC), or dark store) where the adjustment is being recorded. Supports omnichannel inventory visibility.']
  lot_id varchar [note: 'Foreign key linking to inventory.lot. Business justification: adjustment has a batch_number string attribute for lot-tracked adjustments (e.g., shrinkage of a specific lot, recall-driven adjustments). Replacing this with a proper FK lot_id to the lot master reco']
  order_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_order. Business justification: Fulfillment exceptions (damaged goods, mis-picks, cancellations) trigger inventory adjustments. Linking adjustment to fulfillment_order enables fulfillment-driven shrinkage reporting, exception root-c']
  pos_transaction_id varchar [note: 'Foreign key linking to order.pos_transaction. Business justification: Inventory adjustments for shrinkage, damage, or discrepancies are often discovered during POS operations (cashier finds damaged item, customer returns defective product). Linking adjustment to origina']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Promotional markdown adjustments and vendor-funded write-downs must be attributed to campaigns for campaign cost accounting and vendor chargeback reconciliation. Retail finance teams require this link']
  reversal_of_adjustment_id varchar [note: 'Self-referencing identifier pointing to the original adjustment record that this record is reversing. Populated only for reversal entries to maintain a complete audit trail of corrections. Nullable for original (non-reversal) adjustments.']
  sku_id varchar [note: 'Reference to the specific SKU (Stock Keeping Unit) whose inventory quantity is being adjusted. Links to the product master to identify the item at the variant level (size, color, style).']
  stock_ledger_id varchar [note: 'Reference to the corresponding stock ledger entry created when this adjustment was posted. Establishes the audit trail between the adjustment record and the resulting stock position change. Nullable until the adjustment reaches \'posted\' status.']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: adjustment.unit_of_measure is a denormalized text field. Inventory adjustments feed shrinkage reporting and financial reconciliation; a validated FK to product.uom ensures adjusted quantities are in t']
  vendor_id varchar [note: 'Reference to the supplier associated with this adjustment, applicable for receiving variances, Return to Vendor (RTV) adjustments, vendor fraud shrinkage, or Direct Store Delivery (DSD) discrepancies. Nullable for non-supplier-related adjustments.']
  adjusted_quantity decimal(15,4) [note: 'The net quantity change applied to on-hand inventory for the SKU at the specified location. Negative values represent inventory reductions (shrinkage, damage, write-offs); positive values represent inventory additions (found stock, receiving corrections). Expressed in the SKU\'s unit of measure.']
  adjustment_number varchar [note: 'Externally visible, human-readable business identifier for the adjustment transaction. Used in audit trails, loss prevention case references, and cross-system reconciliation with SAP S/4HANA and ORMS. Format: ADJ- followed by 10 digits.']
  adjustment_status varchar [note: 'Current workflow lifecycle state of the adjustment record. Controls whether the adjustment has been applied to the stock ledger. \'posted\' indicates the adjustment has updated on-hand quantities; \'reversed\' indicates a correcting entry was made.']
  adjustment_timestamp timestamp [note: 'The principal real-world date and time when the inventory adjustment event occurred (e.g., when shrinkage was detected, when a cycle count discrepancy was identified, when damage was observed). Distinct from system audit timestamps. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  approval_status varchar [note: 'Indicates whether the adjustment has been reviewed and approved through the authorization workflow. \'auto_approved\' applies to system-generated adjustments below a defined threshold that bypass manual review. Distinct from adjustment_status which tracks the full posting lifecycle.']
  approval_timestamp timestamp [note: 'Date and time when the adjustment was approved or rejected by the authorizing user. Used for SLA (Service Level Agreement) compliance tracking on adjustment processing turnaround. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  cost_impact decimal(18,4) [note: 'Total financial impact of the inventory adjustment on Cost of Goods Sold (COGS), calculated as adjusted_quantity multiplied by unit_cost. Negative values represent write-downs (losses); positive values represent write-ups (gains). Posted to the general ledger via SAP FI/CO integration.']
  created_timestamp timestamp [note: 'System audit timestamp recording when the adjustment record was first created in the system. Used for data lineage, audit compliance, and SLA tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code in which the cost impact and unit cost are expressed (e.g., USD, GBP, EUR, CAD). Required for multi-currency retail operations and financial consolidation.']
  department_code varchar [note: 'The merchandise department code associated with the SKU being adjusted, sourced from the product hierarchy in Oracle Retail Merchandising System (ORMS). Enables shrinkage and adjustment reporting by department for category management and P&L analysis.']
  detection_method varchar [note: 'The method by which the inventory discrepancy or adjustment need was identified. Supports shrinkage root-cause analysis and RFID (Radio Frequency Identification) program effectiveness measurement. [ENUM-REF-CANDIDATE: cycle_count|physical_inventory|rfid_scan|pos_exception|receiving_audit|system_alert|manual_observation|loss_prevention_investigation — promote to reference product]']
  expiry_date date [note: 'The expiration or best-before date of the inventory being written off, applicable for perishable grocery, food, and pharmaceutical SKUs. Required for FDA food safety compliance and expiry write-off reporting. Nullable for non-perishable items. Format: yyyy-MM-dd.']
  fiscal_period varchar [note: 'The fiscal accounting period (year and period number) to which this adjustment is attributed for financial reporting and shrinkage rate analysis. Format: YYYY-P## (e.g., 2024-P01 through 2024-P13 for 4-4-5 retail calendar).']
  is_shrinkage boolean [note: 'Boolean flag indicating whether this adjustment represents a shrinkage event (inventory loss due to theft, damage, administrative error, or vendor fraud). Used to filter and aggregate shrinkage metrics for loss prevention reporting and GMROI (Gross Margin Return on Investment) analysis.']
  is_system_generated boolean [note: 'Boolean flag indicating whether the adjustment was automatically generated by a system process (e.g., Blue Yonder replenishment system, RFID reconciliation engine, WMS cycle count automation) rather than manually entered by a user.']
  location_type varchar [note: 'Classification of the inventory node type where the adjustment occurred. Distinguishes between store-level adjustments, Distribution Center (DC) adjustments, Micro-Fulfillment Center (MFC) adjustments, and dark store adjustments for segmented shrinkage and variance reporting.']
  lp_case_reference varchar [note: 'Reference number linking this inventory adjustment to an active or closed Loss Prevention (LP) investigation case (e.g., shoplifting incident, employee theft case). Nullable — only populated when the adjustment is associated with a formal LP case in Salesforce Service Cloud or a dedicated LP system.']
  notes varchar [note: 'Free-text field for additional context, observations, or explanations provided by the initiating or authorizing user regarding the inventory adjustment. Supports audit trail completeness and loss prevention investigation documentation.']
  posting_date date [note: 'The accounting date on which the inventory adjustment is posted to the stock ledger and general ledger. May differ from adjustment_timestamp when adjustments are batched or backdated for period-end closing. Format: yyyy-MM-dd.']
  quantity_after_adjustment decimal(15,4) [note: 'The on-hand inventory quantity for the SKU at the location immediately after this adjustment is applied. Derived at posting time and stored for audit trail and stock ledger reconciliation. Expressed in the SKU\'s unit of measure.']
  quantity_before_adjustment decimal(15,4) [note: 'The on-hand inventory quantity for the SKU at the location immediately prior to this adjustment being applied. Captured at the time of adjustment for audit trail completeness and variance analysis. Expressed in the SKU\'s unit of measure.']
  reason_category varchar [note: 'High-level classification of why the inventory adjustment is being made. Drives reporting buckets for shrinkage monitoring, COGS (Cost of Goods Sold) impact analysis, and loss prevention dashboards. [ENUM-REF-CANDIDATE: shrinkage|damage|cycle_count_correction|receiving_variance|expiry_write_off|rtv|admin_correction|found_stock — promote to reference product]']
  reason_sub_category varchar [note: 'Granular sub-classification within the reason category providing specific cause detail. Examples for shrinkage: shoplifting, employee theft, administrative error, vendor fraud. Examples for damage: in-transit damage, handling damage, shelf damage. Feeds loss prevention case analysis and shrinkage root-cause reporting. [ENUM-REF-CANDIDATE: shoplifting|employee_theft|admin_error|vendor_fraud|in_transit_damage|handling_damage|shelf_damage|expired|recalled|mis-ship — promote to reference product]']
  recall_flag boolean [note: 'Boolean flag indicating whether this inventory adjustment is associated with a product recall event initiated by the CPSC, FDA, or the retailer. Enables rapid identification and financial quantification of recall-related inventory write-offs.']
  rfid_tag_count varchar [note: 'Number of RFID (Radio Frequency Identification) tags scanned during the detection event that triggered this adjustment. Populated only for RFID-based detection methods. Supports RFID program accuracy measurement and tag read-rate analysis.']
  source_document_number varchar [note: 'The reference number of the originating source document (e.g., cycle count ID, RTV authorization number, receiving document number, damage report ID). Enables cross-system traceability and audit trail linkage.']
  source_document_type varchar [note: 'The type of source business document that triggered or supports this inventory adjustment. Provides traceability back to the originating business process (e.g., cycle count sheet, Return to Vendor (RTV) authorization, receiving document). [ENUM-REF-CANDIDATE: cycle_count|physical_inventory|rtv_authorization|receiving_document|damage_report|expiry_report|pos_exception_report — promote to reference product]']
  unit_cost decimal(18,4) [note: 'The Cost of Goods Sold (COGS) per unit at the time of adjustment, used to calculate the total cost impact of the inventory change. Sourced from the inventory valuation layer in SAP S/4HANA. Business-confidential as it reflects supplier pricing.']
  updated_timestamp timestamp [note: 'System audit timestamp recording when the adjustment record was most recently modified. Tracks approval workflow updates, status changes, and corrections. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']

  Note: 'Records all inventory quantity adjustments at the SKU-location level including shrinkage events, damage write-downs, cycle count corrections, receiving variances, expiry write-offs, and RTVs. Captures adjustment reason category, sub-reason (e.g., shoplifting, employee theft, admin error for shrinkage), adjusted quantity, cost impact, detection method, authorizing user, approval status, and loss prevention case reference where applicable. Feeds the stock_ledger and serves as the SSOT for all non-transactional inventory changes and shrinkage monitoring.'
}

Table inventory.stock_transfer {
  stock_transfer_id varchar [pk, note: 'Unique system-generated surrogate identifier for each inter-node stock transfer record in the inventory management system.']
  carrier_id varchar [note: 'Reference to the logistics carrier or 3PL (Third-Party Logistics) provider responsible for transporting the stock transfer between nodes. Used for carrier performance analytics and SLA compliance reporting.']
  cost_price_id varchar [note: 'Foreign key linking to pricing.cost_price. Business justification: Transfer accounting and intercompany pricing require cost data for inventory valuation during movement. Store-to-store transfers, DC-to-store shipments, and cross-dock operations need cost basis for f']
  destination_node_inventory_node_id varchar [note: 'Identifier of the receiving inventory node (store, DC, MFC, or vendor location) to which the stock transfer is directed. Used for inventory receipt confirmation and network replenishment tracking.']
  lot_id varchar [note: 'Foreign key linking to inventory.lot. Business justification: Inter-node stock transfers frequently move specific lots, particularly for perishable or lot-tracked items where FEFO sequencing and expiry management require lot-level transfer tracking. Adding lot_i']
  order_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_order. Business justification: Ship-from-store and store-to-store transfers are initiated to fulfill specific fulfillment orders (BOPIS, ROPIS, SFS). Linking stock_transfer to fulfillment_order enables end-to-end order fulfillment ']
  order_line_id varchar [note: 'Foreign key linking to order.order_line. Business justification: Ship-from-store fulfillment: when an online order line triggers a store-to-customer transfer, the stock_transfer must reference the originating order_line for customer service tracing, SLA compliance ']
  outbound_order_id varchar [note: 'Foreign key linking to supplychain.outbound_order. Business justification: DC-to-store transfer execution: a stock_transfer (inventory movement record) corresponds to an outbound_order (DC shipping execution record). Retail inventory and DC operations teams need this link fo']
  primary_stock_inventory_node_id varchar [note: 'Identifier of the originating inventory node (store, DC, MFC, or vendor location) from which the stock transfer is dispatched. Supports network balancing and omnichannel fulfillment analytics.']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Retailers execute targeted inter-store and DC-to-store transfers to concentrate promotional stock at high-traffic locations before campaign launch. Linking stock_transfer to promo_campaign enables pro']
  purchase_order_id varchar [note: 'Reference to the originating purchase order that triggered this stock transfer, applicable for DC-to-store replenishment flows sourced from supplier inbound receipts. Links transfer to procurement context.']
  replenishment_order_id varchar [note: 'Foreign key linking to inventory.replenishment_order. Business justification: A stock transfer is frequently initiated to fulfill a replenishment order — moving inventory from a DC to a store or between nodes as directed by the replenishment system. Linking stock_transfer to re']
  replenishment_plan_id varchar [note: 'Reference to the replenishment plan that generated this stock transfer, linking the physical movement to the demand-driven planning signal from Blue Yonder or Oracle Retail. Supports replenishment accuracy analytics.']
  shipment_id varchar [note: 'Foreign key linking to fulfillment.shipment. Business justification: Inter-node stock transfers that are physically shipped generate carrier shipments. Linking stock_transfer to shipment enables tracking number association, carrier cost allocation to transfer events, a']
  sku_id varchar [note: 'Reference to the specific SKU (Stock Keeping Unit) being transferred. The SKU is the atomic unit of inventory tracking, uniquely identifying a product variant (size, color, style) within the retail assortment.']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: stock_transfer.unit_of_measure is a denormalized text field. Inter-node transfers require validated UOM for transfer_cost calculations, receiving reconciliation, and variance_quantity reporting — all ']
  actual_receipt_date date [note: 'Calendar date on which the stock transfer was physically received and confirmed at the destination node. Compared against expected_receipt_date to measure carrier and DC performance against SLA targets.']
  created_timestamp timestamp [note: 'System audit timestamp recording when this stock transfer record was first persisted in the data platform. Used for data lineage, audit trails, and Silver layer ingestion tracking.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code in which the transfer cost is denominated (e.g., USD, GBP, EUR). Supports multi-currency retail operations across international markets.']
  destination_node_type varchar [note: 'Classification of the receiving inventory node. STORE: retail store; DC: distribution center; MFC: micro-fulfillment center; VENDOR: supplier location for RTV; DARK_STORE: fulfillment-only location.']
  expected_receipt_date date [note: 'Planned calendar date by which the stock transfer is expected to arrive at the destination node. Used for replenishment planning, weeks of supply (WOS) calculations, and SLA compliance monitoring.']
  initiated_timestamp timestamp [note: 'Date and time when the stock transfer record was first created in the system, representing the business event of transfer initiation. Serves as the principal business event timestamp for the transfer lifecycle.']
  inventory_cost_per_unit decimal(18,4) [note: 'Cost of Goods Sold (COGS) value per unit for the transferred SKU at time of transfer, used for inventory valuation, GMROI calculations, and financial reporting. Sourced from SAP S/4HANA FI/CO standard cost or moving average cost.']
  is_cross_dock boolean [note: 'Flag indicating whether this stock transfer is executed as a cross-docking (cross-dock) movement, where inventory is transferred directly from inbound to outbound at the DC without putaway storage. Supports DC throughput and flow-through analytics.']
  is_ship_from_store boolean [note: 'Flag indicating whether this stock transfer is part of a ship-from-store (SFS) omnichannel fulfillment flow, where a retail store acts as a fulfillment node dispatching inventory to satisfy an e-commerce or BOPIS order.']
  is_vendor_managed boolean [note: 'Flag indicating whether this stock transfer is part of a Vendor Managed Inventory (VMI) program, where the supplier initiates and manages the replenishment transfer rather than the retailer\'s internal planning team.']
  notes varchar [note: 'Free-text operational notes or comments associated with the stock transfer, capturing exception details, special handling instructions, or carrier communication relevant to the transfer execution.']
  priority_level varchar [note: 'Operational priority assigned to the stock transfer, influencing pick sequencing, carrier selection, and dispatch scheduling at the DC or store. URGENT transfers may be triggered by stockout alerts or product recalls.']
  received_quantity varchar [note: 'Actual number of units confirmed received at the destination node upon delivery. May differ from transfer_quantity due to transit damage, shrinkage, or carrier discrepancies. Drives inventory reconciliation and shrinkage monitoring.']
  rfid_enabled boolean [note: 'Flag indicating whether this stock transfer was tracked using RFID (Radio Frequency Identification) technology for real-time inventory visibility during transit. Supports RFID-based inventory accuracy programs.']
  shipment_date date [note: 'Calendar date on which the stock transfer was physically dispatched from the source node. Used for lead time calculation, carrier SLA tracking, and inventory in-transit reporting.']
  source_node_type varchar [note: 'Classification of the originating inventory node. STORE: retail store; DC: distribution center; MFC: micro-fulfillment center; VENDOR: supplier location for RTV or DSD; DARK_STORE: fulfillment-only location.']
  source_system_code varchar [note: 'Code identifying the operational system of record from which this stock transfer record originated. Supports data lineage, reconciliation, and Silver layer provenance tracking across the retail technology stack.']
  tracking_number varchar [note: 'Carrier-assigned shipment tracking number for the stock transfer, enabling real-time in-transit visibility and last-mile delivery monitoring. Used for exception management and carrier SLA validation.']
  transfer_cost decimal(18,4) [note: 'Total logistics cost incurred for executing this stock transfer, including carrier freight charges, handling fees, and any 3PL surcharges. Used for inventory valuation (COGS), P&L allocation, and supply chain cost optimization.']
  transfer_number varchar [note: 'Externally-known business reference number for the stock transfer, used for tracking and communication across supply chain partners, carriers, and store operations. Sourced from SAP S/4HANA MM transfer order numbering.']
  transfer_quantity varchar [note: 'Number of units of the SKU authorized and dispatched in this stock transfer. Represents the planned transfer quantity as recorded at time of transfer creation.']
  transfer_reason_code varchar [note: 'Business reason code explaining why the stock transfer was initiated. REPLENISHMENT: routine inventory restocking; NETWORK_BALANCE: lateral balancing to address overstock/understock; RTV: return to vendor; RECALL: product safety recall per CPSC; DAMAGE_RETURN: return of damaged goods; OMNICHANNEL: ship-from-store or BOPIS fulfillment support.']
  transfer_status varchar [note: 'Current lifecycle state of the stock transfer. DRAFT: initiated but not yet dispatched; IN_TRANSIT: shipment dispatched from source node; RECEIVED: confirmed receipt at destination node; CANCELLED: transfer voided before completion; EXCEPTION: discrepancy or damage reported during transit.']
  transfer_type varchar [note: 'Classification of the inter-node inventory movement. DC_TO_STORE: distribution center replenishment to store; STORE_TO_STORE: lateral balancing between stores; STORE_TO_DC: reverse logistics or consolidation; CROSS_DOCK: direct transfer without storage per cross-docking (DSD) model; RTV: Return to Vendor; MFC_TO_STORE: micro-fulfillment center to store for omnichannel fulfillment (ship-from-store).']
  upc varchar [note: '12-digit Universal Product Code (UPC) barcode identifier for the transferred SKU, used for scanning and verification during pick, pack, and receipt operations at DC and store nodes.']
  updated_timestamp timestamp [note: 'System audit timestamp recording the most recent modification to this stock transfer record, such as status updates, quantity adjustments, or receipt confirmations. Supports change data capture and audit compliance.']
  variance_quantity varchar [note: 'Difference between transfer_quantity and received_quantity, representing units lost, damaged, or unaccounted for during transit. Positive value indicates shortage; negative indicates overage. Drives shrinkage monitoring and carrier chargeback processes.']
  variance_reason_code varchar [note: 'Reason code explaining the cause of any quantity variance between dispatched and received units. Used for shrinkage root cause analysis, carrier chargeback (RMA) processing, and inventory reconciliation.']

  Note: 'Inter-node stock transfer records capturing movement of inventory between stores, DCs, MFCs, and vendor locations. Captures transfer type (store-to-store, DC-to-store, cross-dock, RTV), source node, destination node, SKU, transfer quantity, shipment date, expected receipt date, actual receipt date, carrier, and transfer status. Supports omnichannel fulfillment (ship-from-store) and network balancing.'
}

Table inventory.goods_receipt {
  goods_receipt_id varchar [pk, note: 'Unique system-generated surrogate identifier for each goods receipt record in the inventory domain. Primary key for the goods_receipt data product.']
  cost_price_id varchar [note: 'Foreign key linking to pricing.cost_price. Business justification: Receiving process validates invoice costs against contracted pricing and updates landed cost. Three-way match (PO-receipt-invoice) depends on linking goods receipt to cost structure for variance detec']
  inbound_shipment_id varchar [note: 'Foreign key linking to supplychain.inbound_shipment. Business justification: ASN-to-receipt matching: goods_receipt is the inventory confirmation of an inbound_shipment\'s arrival. Retail receiving teams match ASNs to receipts for discrepancy resolution. bill_of_lading_number a']
  inventory_node_id varchar [note: 'Reference to the physical location (DC, store, or MFC) where the merchandise was received. Supports inventory accuracy at point of induction and omnichannel fulfillment visibility.']
  po_line_id varchar [note: 'Reference to the specific purchase order line item being received. Enables line-level PO matching, partial receipt tracking, and SKU-level discrepancy analysis.']
  purchase_order_id varchar [note: 'Reference to the parent purchase order against which this goods receipt is posted. Enables PO-to-receipt matching, open order tracking, and three-way match (PO, receipt, invoice) for accounts payable.']
  receiving_event_id varchar [note: 'Foreign key linking to supplychain.receiving_event. Business justification: DC receiving process: receiving_event is the physical unloading/inspection event; goods_receipt is the inventory system record created from it. Retail DC managers need to link these for quality inspec']
  replenishment_order_id varchar [note: 'Foreign key linking to inventory.replenishment_order. Business justification: A goods receipt records the physical arrival of merchandise against a replenishment order (in addition to purchase orders). goods_receipt already has purchase_order_id for PO-based receipts, but lacks']
  sku_id varchar [note: 'Reference to the SKU (Stock Keeping Unit) being received. Links to the product master in Informatica MDM or Oracle Retail Merchandising System for item-level inventory induction.']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: goods_receipt.unit_of_measure is a denormalized text field. Goods receipt drives total_receipt_cost and discrepancy calculations; linking to product.uom ensures received quantities are validated again']
  vendor_id varchar [note: 'Reference to the supplier or vendor from whom the merchandise was received. Links to the supplier master record in Informatica MDM. Used for vendor compliance chargeback processing and fill rate analysis.']
  vendor_item_id varchar [note: 'Foreign key linking to supplier.vendor_item. Business justification: Receiving teams validate received goods against the vendor\'s item catalog (pack size, GTIN, unit cost). Linking goods_receipt to vendor_item enables discrepancy detection and chargeback eligibility as']
  vendor_promo_agreement_id varchar [note: 'Foreign key linking to promotion.vendor_promo_agreement. Business justification: Vendor promotional agreements specify promotional purchase quantities and delivery obligations. Linking goods receipts to vendor_promo_agreement enables performance obligation tracking, chargeback rec']
  accepted_qty decimal(18,4) [note: 'Quantity of units accepted into inventory after quality inspection. Excludes rejected, damaged, or wrong-SKU units. This is the quantity inducted into on-hand inventory and used for COGS valuation.']
  chargeback_eligible boolean [note: 'Indicates whether this goods receipt record has identified discrepancies that qualify for a vendor compliance chargeback. True = chargeback may be issued to supplier; False = no chargeback applicable. Drives the vendor compliance chargeback workflow.']
  created_timestamp timestamp [note: 'System audit timestamp recording when this goods receipt record was first created in the data platform. Used for data lineage, audit trails, and SLA monitoring.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the unit cost and total receipt cost (e.g., USD, EUR, GBP). Required for multi-currency retail operations and financial reporting.']
  discrepancy_resolution_status varchar [note: 'Current status of the discrepancy resolution workflow. \'pending\' = discrepancy logged, not yet actioned; \'under_review\' = being investigated with supplier; \'resolved\' = discrepancy closed; \'chargeback_issued\' = vendor compliance chargeback raised; \'waived\' = discrepancy accepted without penalty.']
  discrepancy_type varchar [note: 'Classification of the primary discrepancy identified during receiving. \'shortage\' = fewer units than expected; \'overage\' = more units than expected; \'wrong_sku\' = incorrect item received; \'damage\' = merchandise physically damaged; \'expired\' = past sell-by or use-by date; \'none\' = no discrepancy. Drives chargeback and resolution workflows.']
  expected_qty decimal(18,4) [note: 'Quantity of units expected at the receiving node based on the ASN or replenishment plan. May differ from ordered quantity due to partial shipments or split deliveries. Used for receiving dock planning and discrepancy detection.']
  inspection_date date [note: 'Date on which the quality inspection of received merchandise was completed. Used for compliance reporting, CPSC/FDA audit trails, and receiving cycle time analysis.']
  ordered_qty decimal(18,4) [note: 'Quantity of units originally ordered on the purchase order line. Used as the baseline for receipt variance calculation, fill rate measurement, and vendor compliance scoring.']
  overage_qty decimal(18,4) [note: 'Quantity of units received in excess of the ASN or PO expectation (received_qty minus expected_qty when positive). Overages require disposition decisions and may trigger vendor compliance chargebacks.']
  po_number varchar [note: 'Externally-known purchase order number as referenced on supplier documentation and EDI transactions. Retained for operational readability, vendor communication, and three-way match without requiring a join.']
  quality_inspection_status varchar [note: 'Status of the quality inspection performed on received merchandise. \'not_required\' = inspection waived per supplier agreement; \'pending\' = awaiting inspection; \'passed\' = all units meet quality standards; \'failed\' = units do not meet standards; \'partial_pass\' = some units accepted, some rejected. Drives accepted/rejected quantity split.']
  receipt_date date [note: 'Calendar date on which the physical goods receipt was posted. Used for inventory valuation, vendor compliance reporting, and lead time analysis. Aligns with SAP Posting Date (BUDAT) in the MM module.']
  receipt_method varchar [note: 'Method by which merchandise was physically received. \'dsd\' = Direct Store Delivery from supplier; \'dc_to_store\' = replenishment from Distribution Center; \'cross_dock\' = direct transfer without storage; \'drop_ship\' = vendor direct-to-customer; \'transfer_order\' = inter-node stock transfer. Drives receiving workflow and inventory valuation logic.']
  receipt_notes varchar [note: 'Free-text notes entered by the receiving associate documenting special conditions, discrepancy details, handling instructions, or other observations at the time of receipt. Supports discrepancy investigation and vendor communication.']
  receipt_number varchar [note: 'Externally-known business identifier for the goods receipt document, typically generated by the WMS or ERP upon physical receipt confirmation. Maps to SAP Material Document Number (MBLNR) or Manhattan WMS Receipt Number.']
  receipt_status varchar [note: 'Current lifecycle state of the goods receipt workflow. \'draft\' indicates initiated but not confirmed; \'open\' indicates awaiting physical receipt; \'in_progress\' indicates receiving underway; \'completed\' indicates fully processed and inventory inducted; \'cancelled\' indicates voided; \'on_hold\' indicates paused pending resolution. [ENUM-REF-CANDIDATE: draft|open|in_progress|completed|cancelled|on_hold — promote to reference product]']
  receipt_timestamp timestamp [note: 'The principal real-world event timestamp recording when the physical merchandise was received and confirmed at the receiving node (DC, store, or MFC). Distinct from system audit timestamps. Maps to SAP Posting Date/Time in MIGO.']
  received_qty decimal(18,4) [note: 'Total quantity of units physically counted and received at the dock, prior to quality inspection. Includes all units regardless of condition. Used as the gross receipt quantity for inventory induction and discrepancy calculation.']
  receiving_node_type varchar [note: 'Classification of the physical location type where goods were received. \'dc\' = Distribution Center; \'store\' = retail store; \'mfc\' = Micro-Fulfillment Center; \'dark_store\' = fulfillment-only location. Determines applicable receiving workflows and inventory induction rules.']
  rejected_qty decimal(18,4) [note: 'Quantity of units rejected during quality inspection and not inducted into inventory. Drives Return to Vendor (RTV) processing, vendor compliance chargebacks, and RMA initiation.']
  rfid_verified boolean [note: 'Indicates whether the received merchandise was verified using RFID (Radio Frequency Identification) scanning during the receiving process. True = RFID scan confirmed; False = manual or barcode-only verification. Supports inventory accuracy at point of induction.']
  rtv_initiated boolean [note: 'Indicates whether a Return to Vendor (RTV) process has been initiated for rejected units from this goods receipt. True = RTV in progress; False = no RTV initiated. Supports reverse logistics and vendor debit memo processing.']
  shortage_qty decimal(18,4) [note: 'Quantity of units short-shipped relative to the ASN or PO expectation (expected_qty minus received_qty when negative). Used for vendor compliance chargeback calculation and fill rate reporting.']
  total_receipt_cost decimal(18,4) [note: 'Total cost of accepted merchandise received (accepted_qty × unit_cost). Used for inventory valuation, COGS posting, and financial reconciliation. Classified as confidential due to commercial sensitivity.']
  unit_cost decimal(18,4) [note: 'Cost per unit of the received merchandise as per the purchase order or supplier invoice. Used for inventory valuation (COGS), gross margin calculation (GMROI), and financial posting to the general ledger. Classified as confidential due to commercial sensitivity.']
  upc varchar [note: '12-digit Universal Product Code (UPC) barcode identifier for the received item. Used for RFID/barcode scanning during receiving, inventory accuracy validation, and GS1 compliance.']
  updated_timestamp timestamp [note: 'System audit timestamp recording when this goods receipt record was last modified in the data platform. Supports change tracking, discrepancy resolution audits, and data quality monitoring.']

  Note: 'Records physical receipt of merchandise at DCs, stores, and MFCs against purchase orders, replenishment orders, or transfer orders. Captures receipt date, receiving node, supplier/source, PO/ASN reference, line-level received/accepted/rejected quantities with discrepancy details (shortage, overage, wrong SKU, damage), unit cost, receipt method (DSD, DC-to-store, cross-dock), quality inspection status, and discrepancy resolution status. Supports receiving workflows, vendor compliance chargebacks, and inventory accuracy at point of induction.'
}

Table inventory.reservation {
  reservation_id varchar [pk, note: 'Unique system-generated identifier for each inventory reservation or hold record. Primary key for the reservation data product.']
  bopis_appointment_id varchar [note: 'Foreign key linking to fulfillment.bopis_appointment. Business justification: BOPIS reservations must be linked to their pickup appointment for SLA tracking, inventory hold expiry management, and customer notification workflows. Retail omnichannel operations require knowing whi']
  cart_id varchar [note: 'Foreign key linking to ecommerce.cart. Business justification: Inventory reservations are created from cart items during checkout to hold stock. Tracks cart-to-reservation lifecycle for abandoned cart inventory release and reservation expiry management.']
  checkout_id varchar [note: 'Foreign key linking to ecommerce.checkout. Business justification: Reservations are created during checkout to hold inventory during payment authorization. Links reservation lifecycle to checkout session for payment-hold-release coordination and checkout abandonment ']
  corporate_account_id decimal(9,4) [note: 'Foreign key linking to customer.corporate_account. Business justification: B2B bulk inventory reservation process: corporate accounts reserve large quantities of inventory for business purchases (e.g., corporate gifting, bulk procurement events). This is a distinct operation']
  fulfillment_line_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_line. Business justification: Reservations are SKU-level allocations matching fulfillment line granularity. Retail WMS systems reserve specific SKU quantities for specific order lines during wave planning and pick task generation.']
  header_id varchar [note: 'Reference to the customer order (OMS order) that triggered this inventory reservation. Populated for BOPIS, ROPIS, ship-from-store, and e-commerce hold encumbrances. Null for non-order-driven holds (quality, legal, regulatory). Links reservation to the order fulfillment lifecycle.']
  inventory_node_id varchar [note: 'System identifier for the inventory node (store, DC, MFC, dark store) where the reserved stock physically resides. Central to ATP calculation and omnichannel fulfillment routing (BOPIS, SFS, ship-from-DC).']
  lot_id varchar [note: 'Foreign key linking to inventory.lot. Business justification: Inventory reservations for perishable or lot-tracked items (e.g., FEFO-based omnichannel fulfillment, recall holds) must reference the specific lot being reserved. Adding lot_id to reservation enables']
  order_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_order. Business justification: Inventory reservations are created during fulfillment order allocation in retail operations. When an online order or BOPIS order enters fulfillment, the WMS reserves specific inventory for that fulfil']
  profile_id varchar [note: 'Foreign key linking to customer.profile. Business justification: Retail omnichannel fulfillment (BOPIS, ship-from-store, curbside pickup) requires tracking which customer profile created each inventory reservation. Essential for customer service, order fulfillment,']
  sku_id varchar [note: 'System identifier for the SKU (Stock Keeping Unit) whose inventory is being reserved or held. Links to the product master for item-level ATP (Available to Promise) calculation and omnichannel fulfillment routing.']
  stock_position_id varchar [note: 'Reference to the stock_position record at the SKU-node level that this reservation encumbers. Enables direct linkage between the reservation and the ATP calculation on the stock_position product, ensuring accurate real-time inventory visibility.']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: reservation.unit_of_measure is a denormalized text field. Inventory reservations for BOPIS/ROPIS/fulfillment require validated UOM to correctly decrement available_to_promise quantities and prevent ov']
  authorizing_department varchar [note: 'Name or code of the business department that authorized the hold (e.g., Quality Assurance, Legal, Compliance, Store Operations, E-Commerce Fulfillment). Supports departmental accountability reporting and hold resolution workflows.']
  case_reference_number varchar [note: 'Reference to the service case, quality investigation, legal matter, or regulatory recall case that authorized a hard hold. Populated for quality_hold, legal_hold, regulatory_recall, and damage_hold encumbrance types. Links to Salesforce Service Cloud case management.']
  created_timestamp timestamp [note: 'System-generated timestamp when the reservation record was first written to the data platform (Silver layer ingestion time). Distinct from reservation_timestamp which captures the business event time. Used for data lineage and audit trail.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the inventory_cost_per_unit value (e.g., USD, CAD, GBP). Supports multi-currency inventory valuation for international retail operations.']
  encumbrance_type varchar [note: 'Classifies the nature of the inventory encumbrance. Soft allocations (e.g., BOPIS reservation, ship-from-store allocation, e-commerce hold) are temporary and customer-driven; hard holds (quality hold, regulatory recall, legal hold, damage hold, price investigation) restrict stock from sale pending resolution. [ENUM-REF-CANDIDATE: soft_allocation|hard_hold|quality_hold|regulatory_recall|legal_hold|damage_hold|price_investigation — promote to reference product]']
  expiry_timestamp timestamp [note: 'Date and time at which the reservation automatically expires if not fulfilled or manually extended. Critical for BOPIS and e-commerce holds where stock must be released back to general availability after a defined window (e.g., 24–48 hours). Null for indefinite holds such as legal or regulatory holds.']
  fiscal_period varchar [note: 'Retail fiscal period (year and period number, e.g., 2024-P07) during which the reservation was created. Supports financial reporting of encumbered inventory valuation, OTB (Open to Buy) impact analysis, and period-end inventory reconciliation per FASB ASC 330.']
  fulfillment_channel varchar [note: 'The omnichannel fulfillment method associated with this reservation. BOPIS (Buy Online Pick Up In Store), ROPIS (Reserve Online Pick Up In Store), ship_from_store (SFS), ecommerce (ship from DC), drop_ship (vendor direct), in_store (POS hold). Null for non-order-driven hard holds.']
  hold_reason_code varchar [note: 'Standardized code identifying the specific business reason for the reservation or hold (e.g., BOPIS_ALLOC, SFS_ALLOC, ECOM_HOLD, QA_FAIL, RECALL_CPSC, LEGAL_HOLD, DMG_INBOUND, PRICE_INVEST). Enables operational reporting and root-cause analysis of inventory encumbrances.']
  hold_reason_description varchar [note: 'Free-text narrative describing the specific reason for the inventory hold or reservation, providing operational context beyond the structured hold_reason_code. Required for legal holds and regulatory recalls per compliance documentation standards.']
  inventory_cost_per_unit decimal(18,4) [note: 'Cost of Goods Sold (COGS) per unit for the reserved SKU at the time of reservation creation. Used for financial valuation of encumbered inventory, shrinkage reporting, and GMROI (Gross Margin Return on Investment) analysis. Sourced from SAP S/4HANA Retail FI/CO module.']
  is_recalled boolean [note: 'Indicates whether this reservation was created in response to a regulatory product recall (CPSC, FDA, or other governing body). When true, the hold cannot be released without explicit compliance authorization. Supports mandatory recall reporting and quarantine workflows.']
  is_vendor_managed boolean [note: 'Indicates whether the reserved inventory is managed under a Vendor Managed Inventory (VMI) agreement, where the supplier retains ownership and replenishment responsibility. Affects financial liability and hold authorization workflows.']
  priority_level varchar [note: 'Business priority assigned to the reservation, governing queue position in fulfillment workflows and hold resolution SLAs. \'critical\' applies to regulatory recalls and legal holds; \'high\' to same-day BOPIS; \'standard\' to regular e-commerce holds; \'low\' to pre-emptive soft allocations.']
  release_notes varchar [note: 'Free-text field capturing resolution details, disposition instructions, or compliance notes recorded at the time of hold release. Required for regulatory recalls and legal holds to document the resolution rationale for audit purposes.']
  release_status varchar [note: 'Approval workflow status for releasing a hard hold. \'pending\' — release request submitted awaiting authorization; \'approved\' — release authorized by responsible department; \'rejected\' — release denied, hold remains active; \'auto_released\' — system-triggered release upon expiry or order fulfillment; \'escalated\' — requires senior authorization.']
  release_timestamp timestamp [note: 'Actual date and time when the reservation was released, cancelled, or converted. Null while the reservation is active. Used for hold duration analysis, SLA compliance reporting, and ATP recalculation upon release.']
  reservation_number varchar [note: 'Externally-visible, human-readable business identifier for the reservation, used in operational communications, order management, and customer-facing references (e.g., BOPIS confirmation codes). Sourced from OMS or WMS upon creation.']
  reservation_status varchar [note: 'Current lifecycle state of the inventory reservation. \'active\' — stock is currently encumbered; \'expired\' — reservation lapsed past expiry without fulfillment; \'released\' — hold manually or systematically lifted; \'cancelled\' — reservation voided before fulfillment; \'pending_release\' — awaiting authorization to release; \'converted\' — soft allocation fulfilled and converted to a shipment.']
  reservation_timestamp timestamp [note: 'The precise date and time (with timezone offset) when the inventory encumbrance was created — the principal business event timestamp. For BOPIS/e-commerce holds, this is when the customer completed checkout. For quality/legal holds, this is when the hold was authorized.']
  reserved_quantity decimal(18,4) [note: 'Number of units of the SKU encumbered by this reservation. Subtracted from on-hand quantity to derive ATP (Available to Promise) on the stock_position product. Must be positive and not exceed available on-hand at time of reservation creation.']
  source_system_code varchar [note: 'Code identifying the operational system of record that originated this reservation record (e.g., WMS = Manhattan Associates WMS, OMS = Order Management System, ECOM = Salesforce Commerce Cloud, ERP = SAP S/4HANA, MANUAL = manually entered hold). Supports data lineage and reconciliation in the Databricks Lakehouse Silver layer. [ENUM-REF-CANDIDATE: WMS|OMS|ECOM|ERP|ORMS|CAR|SFCC|MANUAL — 8 candidates stripped; promote to reference product]']
  storage_bin varchar [note: 'Specific bin, shelf, or slot location within the node where the reserved inventory is physically stored. Enables warehouse associates to locate and pick reserved stock efficiently. Sourced from Manhattan Associates WMS bin management.']
  upc varchar [note: '12-digit Universal Product Code (UPC) barcode identifier for the reserved item. Used for RFID scanning, POS reconciliation, and regulatory recall identification per GS1 standards.']
  updated_timestamp timestamp [note: 'System-generated timestamp of the most recent modification to the reservation record (e.g., quantity adjustment, status change, expiry extension). Used for change data capture (CDC) and incremental processing in the Databricks Lakehouse Silver layer.']

  Note: 'Records all inventory encumbrances that restrict stock from general availability — including soft-allocations (BOPIS reservation, ship-from-store allocation, e-commerce hold) and hard holds (quality hold, regulatory recall, legal hold, damage hold, price investigation). Captures encumbrance type, SKU, quantity, node, start/expiry timestamps, associated order or case reference, authorizing party, hold reason, authorizing department, release status, and resolution details. Single source of truth for all reserved and held stock, enabling accurate ATP calculation on stock_position.'
}

Table inventory.reorder_policy {
  reorder_policy_id varchar [pk, note: 'Unique surrogate identifier for the reorder policy record. Primary key for the reorder_policy data product in the inventory domain.']
  cluster_id varchar [note: 'Foreign key linking to store.cluster. Business justification: Retail replenishment policies are commonly defined at the store cluster level (e.g., all high-volume urban stores share a reorder policy). Cluster-based replenishment policy assignment is a named reta']
  demand_forecast_id varchar [note: 'Reference to the demand forecast record from Blue Yonder Demand Planning that drives replenishment quantity calculations for forecast_driven reorder method. Null for non-forecast-driven methods.']
  department_id varchar [note: 'Foreign key linking to store.department. Business justification: Reorder policies in retail are scoped to a specific department within a store (e.g., Produce has different min/max rules than Electronics). Department-level replenishment policy management is a standa']
  inventory_node_id varchar [note: 'Foreign key linking to inventory.inventory_node. Business justification: Reorder policies are defined at the SKU-location level, where location is an inventory node (store, DC, MFC). reorder_policy currently references inventory.location via location_id, but inventory_node is ']
  item_hierarchy_id varchar [note: 'Foreign key linking to product.item_hierarchy. Business justification: Retail replenishment planning sets policies at category/hierarchy level (item_hierarchy.replenishment_method, safety_stock_weeks). A reorder_policy can govern all SKUs in a hierarchy node, enabling ca']
  lead_time_agreement_id varchar [note: 'Foreign key linking to supplier.lead_time_agreement. Business justification: Reorder policies use lead time to calculate reorder points and safety stock. Linking to the governing lead_time_agreement ensures policy parameters stay aligned with contractual SLAs and enables autom']
  location_id varchar [note: 'Reference to the inventory node (store, Distribution Center (DC), or Micro-Fulfillment Center (MFC)) where this reorder policy governs stock replenishment. Combined with sku_id, forms the natural business key.']
  promo_calendar_id varchar [note: 'Foreign key linking to promotion.promo_calendar. Business justification: Reorder policies are adjusted for promotional periods defined in the promo_calendar (safety stock uplift, lead time compression). Linking reorder_policy to promo_calendar enables promotional replenish']
  replenishment_plan_id varchar [note: 'Reference to the parent replenishment plan that governs or generated this reorder policy. Links the policy to the broader supply chain planning context managed in Blue Yonder Demand Planning.']
  sku_id varchar [note: 'Reference to the specific SKU (Stock Keeping Unit) for which this reorder policy applies. Combined with location_id, forms the natural business key for a reorder policy.']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: reorder_policy.unit_of_measure is a denormalized text field. Reorder point quantities, MOQ, and safety stock quantities must reference the authoritative UOM to ensure replenishment calculations are co']
  vendor_id varchar [note: 'Reference to the preferred supplier for replenishment orders generated by this policy. Used by the replenishment engine to route purchase orders. May be overridden at order generation time if the supplier is unavailable.']
  vendor_item_id varchar [note: 'Foreign key linking to supplier.vendor_item. Business justification: Reorder policies are configured per SKU-vendor combination using vendor_item pack size, MOQ, and order increment. Linking reorder_policy to vendor_item enables automatic policy recalculation when vend']
  abc_classification varchar [note: 'ABC classification of the SKU at this location based on sales velocity and revenue contribution: A (high-velocity/high-value), B (medium), C (low-velocity/low-value), D (dead stock or near-dead). Influences replenishment priority, safety stock levels, and review cycle frequency.']
  approved_by varchar [note: 'Name or employee identifier of the replenishment planner or manager who approved this reorder policy for activation. Supports governance, audit trail, and accountability for policy parameters.']
  approved_timestamp timestamp [note: 'The date and time when this reorder policy was formally approved for activation by the authorized planner or manager. Supports audit trail and policy lifecycle management.']
  created_timestamp timestamp [note: 'The date and time when this reorder policy record was first created in the system. Supports audit trail, data lineage, and policy lifecycle tracking.']
  effective_date date [note: 'The calendar date from which this reorder policy becomes active and the replenishment engine begins applying its parameters. Supports time-bound policy management and seasonal policy transitions.']
  expiry_date date [note: 'The calendar date after which this reorder policy is no longer active. Null indicates an open-ended policy with no planned expiration. Used to manage seasonal policies, promotional replenishment windows, and policy version transitions.']
  is_auto_replenishment boolean [note: 'Indicates whether replenishment orders are automatically generated and submitted when the reorder trigger is breached (True), or whether a replenishment planner must manually review and approve the suggested order (False).']
  is_seasonal boolean [note: 'Indicates whether this reorder policy applies seasonal adjustments to replenishment parameters (e.g., elevated safety stock or WOS targets during peak seasons). When True, seasonal override parameters may be applied by the replenishment engine.']
  is_vendor_managed boolean [note: 'Indicates whether this SKU-location replenishment is managed by the supplier under a Vendor Managed Inventory (VMI) agreement. When True, the supplier is responsible for monitoring stock levels and initiating replenishment orders rather than the retailer\'s automated engine.']
  last_reviewed_date date [note: 'The most recent date on which a replenishment planner reviewed and validated the parameters of this reorder policy. Supports governance and audit of policy maintenance cadence.']
  lead_time_days varchar [note: 'The expected number of calendar days from placement of a replenishment purchase order to receipt of goods at the destination location. Used to calculate the reorder point and ensure stock does not fall below safety stock during the replenishment cycle.']
  location_type varchar [note: 'Classification of the inventory node type to which this policy applies: store (retail store), DC (Distribution Center), MFC (Micro-Fulfillment Center), dark_store (fulfillment-only location), or warehouse. Drives replenishment logic differences by node type.']
  max_stock_quantity decimal(18,4) [note: 'The maximum allowable on-hand inventory level (in units) for this SKU at this location. Used in min/max reorder method as the upper bound. Replenishment orders are sized to bring stock up to this level without exceeding it.']
  min_stock_quantity decimal(18,4) [note: 'The minimum allowable on-hand inventory level (in units) for this SKU at this location. Used in min/max reorder method as the lower bound. Stock falling below this level triggers an urgent replenishment order.']
  moq decimal(18,4) [note: 'The minimum number of units that must be ordered per replenishment order as stipulated by the supplier contract. Replenishment engine enforces this floor when generating inventory_replenishment_order records.']
  next_review_date date [note: 'The scheduled date for the next planner review of this reorder policy\'s parameters. Calculated from last_reviewed_date plus the review_cycle_days. Drives planner workqueue prioritization.']
  notes varchar [note: 'Free-text field for replenishment planners to document rationale for policy parameter choices, exceptions, seasonal considerations, or supplier-specific constraints associated with this reorder policy.']
  order_multiple decimal(18,4) [note: 'The quantity increment in which orders must be placed, reflecting the supplier\'s case pack size or Minimum Order Quantity (MOQ). All replenishment order quantities are rounded up to the nearest multiple of this value to comply with supplier constraints.']
  order_quantity decimal(18,4) [note: 'The fixed quantity (in units) to order each time a replenishment trigger is activated. Used for fixed_quantity reorder method. For other methods, this field may be null and the order quantity is dynamically calculated.']
  policy_code varchar [note: 'Business-facing unique alphanumeric code identifying the reorder policy, used by replenishment planners and referenced in automated replenishment engines (e.g., Blue Yonder). Externally visible identifier across systems.']
  policy_name varchar [note: 'Human-readable descriptive name for the reorder policy, used by replenishment planners to identify and manage policies (e.g., \'DC Grocery Min/Max Weekly\', \'Store Electronics WOS-Based\').']
  policy_status varchar [note: 'Current lifecycle state of the reorder policy. Controls whether the policy is actively used by the replenishment engine to generate inventory_replenishment_order records. [ENUM-REF-CANDIDATE: active|inactive|draft|pending_approval|expired|suspended — promote to reference product]']
  policy_version varchar [note: 'Incrementing version number for this reorder policy record, incremented each time parameters are materially changed. Supports policy change history tracking and rollback capability for replenishment planners.']
  reorder_method varchar [note: 'The replenishment calculation method applied by this policy: min_max (reorder when stock falls below minimum, order up to maximum), days_of_supply (maintain a target number of days of inventory), wos_based (Weeks of Supply (WOS) target), forecast_driven (demand forecast from Blue Yonder), fixed_quantity (constant order quantity), vendor_managed (VMI — Vendor Managed Inventory where supplier controls replenishment). [ENUM-REF-CANDIDATE: min_max|days_of_supply|wos_based|forecast_driven|fixed_quantity|vendor_managed — promote to reference product]']
  reorder_point_quantity decimal(18,4) [note: 'The on-hand stock level (in units) at which a replenishment order is automatically triggered. When the stock_position in inventory falls at or below this threshold, an inventory_replenishment_order record is generated. Core parameter for min/max and fixed-quantity reorder methods.']
  review_cycle_days varchar [note: 'The frequency in calendar days at which the replenishment engine evaluates this policy and checks whether a reorder trigger has been breached. Defines the periodic review interval (e.g., daily=1, weekly=7, bi-weekly=14).']
  safety_stock_quantity decimal(18,4) [note: 'Buffer stock quantity (in units) maintained above the reorder point to protect against demand variability and supply lead time uncertainty. Prevents stockouts during replenishment cycles. A key input to the reorder point calculation.']
  source_system_code varchar [note: 'Code identifying the operational system of record from which this reorder policy was originated or last updated: ORMS (Oracle Retail Merchandising System), SAP_MM (SAP S/4HANA MM Module), BLUE_YONDER (Blue Yonder Demand Planning), MANUAL (planner-entered), MDM (Informatica MDM). Supports data lineage in the Databricks Silver Layer.']
  target_days_of_supply decimal(10,2) [note: 'The desired number of days of inventory coverage to maintain at this location for this SKU. Used in days_of_supply reorder method to calculate the replenishment order quantity based on forecasted daily demand.']
  target_wos decimal(10,2) [note: 'The desired number of weeks of inventory coverage (Weeks of Supply — WOS) to maintain at this location for this SKU. Used in wos_based reorder method. Replenishment orders are sized to achieve this WOS target based on forecasted weekly demand.']
  updated_timestamp timestamp [note: 'The date and time when this reorder policy record was most recently modified. Tracks parameter changes made by replenishment planners and supports change audit trails.']

  Note: 'SKU-location level replenishment parameters defining when and how much to reorder. Captures reorder method (min/max, days-of-supply, WOS-based, forecast-driven), reorder point, safety stock, min/max levels, order multiple (MOQ/case pack), lead time, review cycle, supplier preference, and policy effective/expiry dates. Trigger thresholds generate inventory_replenishment_order records when stock_position breaches defined levels. Owned and maintained by replenishment planners; consumed by automated replenishment engines.'
}

Table inventory.lot {
  lot_id varchar [pk, note: 'Unique identifier for the inventory lot or batch record. Primary key for the lot entity.']
  cost_price_id varchar [note: 'Foreign key linking to pricing.cost_price. Business justification: Lot-level costing for FEFO/FIFO valuation and batch-specific cost tracking. Perishables, pharmaceuticals, and regulated products require lot-specific cost basis for accurate inventory valuation, recal']
  goods_receipt_id varchar [note: 'Reference to the goods receipt transaction that brought this lot into inventory. Links to receiving documentation.']
  gtin_registry_id varchar [note: 'Foreign key linking to product.gtin_registry. Business justification: lot.gtin is a denormalized text field. Lot traceability for recall management (lot.is_recalled, recall_reference_number) requires linking to the authoritative product.gtin_registry for GTIN validation']
  inventory_node_id varchar [note: 'Foreign key linking to inventory.inventory_node. Business justification: A lot/batch is physically stored at an inventory node. lot currently has storage_location_code (a string bin/zone reference) but no FK to the inventory node where the lot resides. Adding inventory_nod']
  parent_lot_id varchar [note: 'Self-referencing FK on lot (parent_lot_id)']
  purchase_order_id varchar [note: 'Reference to the purchase order that sourced this lot. Links lot traceability to procurement records.']
  sku_id varchar [note: 'Reference to the product SKU that this lot represents. Links lot-level tracking to product master data.']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: lot.unit_of_measure is a denormalized text field. Lot-level quantity tracking (available_quantity, quantity) for FEFO rotation, expiry management, and recall traceability requires validated UOM from p']
  vendor_id varchar [note: 'Reference to the supplier or vendor who provided this lot. Critical for recall management and vendor performance tracking.']
  vendor_item_id varchar [note: 'Foreign key linking to supplier.vendor_item. Business justification: Lot traceability and product recall management require knowing which vendor item a lot originated from. Retail quality and food safety teams trace lots back to the vendor\'s specific item catalog entry']
  available_quantity decimal(18,3) [note: 'Current quantity available for sale or allocation from this lot. Decreases as units are sold or reserved.']
  batch_number varchar [note: 'Manufacturer or supplier assigned batch identifier. May differ from internal lot number for vendor-managed inventory scenarios.']
  best_before_date date [note: 'Date indicating optimal quality period. Product may still be safe after this date but quality may degrade. Distinct from expiry date.']
  certification_code varchar [note: 'Product certification or compliance code for the lot. Examples: organic, kosher, halal, fair trade, non-GMO. Supports labeling and marketing claims.']
  country_of_origin varchar [note: 'Three-letter ISO country code indicating where the product was manufactured or grown. Required for customs and labeling compliance.']
  created_timestamp timestamp [note: 'Timestamp when the lot record was first created in the system. Audit trail for data lineage and compliance reporting.']
  currency_code varchar [note: 'Three-letter ISO currency code for unit cost. Standard codes include USD, EUR, GBP, CAD, etc.']
  expiry_date date [note: 'Date when the product lot expires and should no longer be sold or consumed. Mandatory for perishable goods and pharmaceuticals.']
  fefo_sequence varchar [note: 'Sequence number for FEFO picking logic. Lower numbers indicate earlier expiry and should be picked first to minimize waste.']
  inspection_date date [note: 'Date when quality inspection was performed on the lot. Required for compliance with food safety and product safety regulations.']
  inspection_result varchar [note: 'Detailed outcome or notes from the quality inspection process. Captures defects, non-conformances, or approval notes.']
  is_private_label boolean [note: 'Indicates whether this lot is a private label or store brand product. True if private label; false if national brand.']
  is_recalled boolean [note: 'Indicates whether this lot is subject to a product recall. True if recalled; false otherwise. Triggers immediate hold and customer notification.']
  is_vendor_managed boolean [note: 'Indicates whether this lot is part of a vendor-managed inventory agreement. True if VMI; false if retailer-owned.']
  lot_number varchar [note: 'Business identifier for the lot or batch. Human-readable code used for tracking and traceability across the supply chain.']
  lot_status varchar [note: 'Current lifecycle status of the lot. Determines whether the lot is available for sale, held for quality inspection, or restricted. [ENUM-REF-CANDIDATE: available|quarantine|hold|released|expired|recalled|disposed — 7 candidates stripped; promote to reference product]']
  manufacture_date date [note: 'Date when the product lot was manufactured or produced. Critical for shelf life calculation and food safety compliance.']
  notes varchar [note: 'Free-text notes or comments about the lot. Captures special handling instructions, quality observations, or operational remarks.']
  quality_status varchar [note: 'Quality inspection outcome for the lot. Approved lots are available for sale; rejected lots must be returned or disposed.']
  quantity decimal(18,3) [note: 'Total quantity of units in the lot at receipt. Used for inventory valuation and traceability reporting.']
  recall_reference_number varchar [note: 'Official recall case or reference number issued by regulatory authority or manufacturer. Links to recall management system.']
  receipt_date date [note: 'Date when the lot was received into inventory at the destination node. Used for aging analysis and FEFO sequencing.']
  remaining_shelf_life_days varchar [note: 'Number of days remaining until expiry as of the current date. Calculated field used for near-expiry alerts and markdown triggers.']
  shelf_life_days varchar [note: 'Total shelf life of the product in days from manufacture date to expiry date. Used for aging analysis and markdown planning.']
  source_system_code varchar [note: 'Identifier of the operational system that created or owns this lot record. Examples: WMS, ERP, MDM. Supports data lineage and reconciliation.']
  storage_location_code varchar [note: 'Warehouse bin, zone, or storage location where the lot is physically stored. Supports pick/pack operations and cycle counting.']
  supplier_lot_reference varchar [note: 'Supplier\'s original lot or batch identifier. Used for traceability back to the supplier\'s manufacturing records.']
  temperature_zone varchar [note: 'Required storage temperature zone for the lot. Critical for cold chain compliance and food safety.']
  unit_cost decimal(18,4) [note: 'Cost per unit for this lot. Used for inventory valuation and cost of goods sold calculation. May vary by lot due to pricing changes.']
  updated_timestamp timestamp [note: 'Timestamp when the lot record was last modified. Tracks changes to lot status, quantity, or other attributes for audit purposes.']

  Note: 'Master record for inventory lot/batch tracking at the SKU level. Captures lot number, manufacture date, expiry date, supplier lot reference, and quality status. Supports traceability for food safety (FDA FSMA) and recall management.'
}

Table customer.profile {
  profile_id varchar [pk, note: 'Unique identifier for the customer profile. Primary key for the golden customer record in the customer master data system.']
  household_id varchar [note: 'Identifier linking this customer to a household group for family-level analytics and shared loyalty benefits.']
  location_id varchar [note: 'Identifier of the customer\'s preferred or most frequently visited store location, used for localized assortment and clienteling.']
  acquisition_channel varchar [note: 'The channel through which the customer was originally acquired, used for CAC (Customer Acquisition Cost) analysis and channel effectiveness measurement.']
  acquisition_date date [note: 'Date when the customer first engaged with the business, marking the start of the customer lifecycle.']
  created_timestamp timestamp [note: 'Timestamp when the customer profile record was first created in the master data management system.']
  customer_role varchar [note: 'Business relationship role the customer plays. Allowed values: consumer, employee, wholesale_buyer, corporate']
  date_of_birth date [note: 'Date of birth of the customer, used for age verification, lifecycle marketing, and personalized birthday promotions.']
  effective_end_date date [note: 'End date of this record version in the SCD Type-2 history; NULL or 9999-12-31 indicates the current active version.']
  effective_start_date date [note: 'Start date of this record version in the SCD Type-2 history; the date from which this version of the record is considered active.']
  email_address varchar [note: 'Primary email address for customer communication across all channels including e-commerce, loyalty programs, and promotional campaigns.']
  entity_type varchar [note: 'Legal entity classification of the customer. Allowed values: individual, organization']
  first_name varchar [note: 'Legal first name or given name of the customer as recorded in the master data management system.']
  full_name varchar [note: 'Complete legal name of the customer, typically concatenated from first, middle, and last name components.']
  gender varchar [note: 'Self-identified gender of the customer, used for personalized merchandising and assortment planning.']
  is_current boolean [note: 'Flag indicating this is the current active version of the profile record.']
  is_current_flag boolean [note: 'Indicates whether this is the currently active version of the record in the SCD Type-2 history.']
  last_name varchar [note: 'Legal last name or family name of the customer as recorded in the master data management system.']
  lifecycle_stage varchar [note: 'Current stage in the customer lifecycle journey, used for targeted marketing campaigns and retention strategies. [ENUM-REF-CANDIDATE: prospect|new|active|at_risk|dormant|churned|reactivated — 7 candidates stripped; promote to reference product]']
  loyalty_tier varchar [note: 'Current tier level in the loyalty program, determining benefits, discounts, and personalized services.']
  marketing_opt_in varchar
  mdm_confidence_score decimal(5,2) [note: 'Confidence score (0-100) from the customer master data system indicating the quality and reliability of the golden record match and data completeness.']
  mdm_last_match_date timestamp [note: 'Timestamp of the last MDM matching and survivorship process execution that updated this golden record.']
  mdm_source_system varchar [note: 'Name of the primary source system that contributed the authoritative data for this golden record (e.g., the retail analytics platform, the e-commerce platform, POS).']
  middle_name varchar [note: 'Middle name or initial of the customer. Nullable field for customers without a middle name.']
  mobile_number bigint [note: 'Mobile phone number used for SMS notifications, mobile app authentication, and last-mile delivery coordination.']
  nationality varchar [note: 'ISO 3166-1 alpha-3 country code representing the customer\'s nationality or citizenship.']
  phone_number bigint [note: 'Primary contact phone number for customer service, order notifications, and BOPIS (Buy Online Pick Up In Store) communications.']
  preferred_channel varchar
  preferred_contact_method varchar [note: 'Customer\'s preferred method for receiving communications and notifications from the business.']
  preferred_language varchar [note: 'ISO 639-2 three-letter language code representing the customer\'s preferred language for communication and marketing materials.']
  profile_status varchar [note: 'Current operational status of the customer profile, controlling access to services and transactions across all channels.']
  record_version varchar [note: 'Monotonically increasing version number for this record in the SCD Type-2 history.']
  scd_change_reason varchar [note: 'Business reason for the change that created this version, supporting GDPR audit trail requirements.']
  scd_change_timestamp timestamp [note: 'Exact timestamp when this SCD Type-2 version was created, used for change-data-capture reconciliation and GDPR audit trails.']
  scd_changed_by varchar [note: 'Identifier of the user or system process that triggered this SCD Type-2 version change, supporting GDPR accountability requirements.']
  version_number varchar [note: 'Sequential version identifier for SCD Type-2 tracking of this record.']

  Note: 'Core customer identity record. Represents a single known individual or organization with master attributes. B2C customers typically have only a profile; B2B relationships additionally use the account entity.'
}

Table customer.account {
  account_id varchar [pk, note: 'Unique identifier for the account. Primary key.']
  billing_address_id varchar [note: 'Reference to the default billing address for this account. Used for invoicing, credit checks, and payment processing. Null if no billing address on file.']
  default_payment_method_id decimal(18,2) [note: 'Reference to the customer\'s default payment method for this account (e.g., credit card on file, bank account). Null if no default set. Used for one-click checkout and recurring billing.']
  location_id varchar [note: 'Reference to the customer\'s preferred or home store location for in-store pickup, returns, and personalized store-based services. Null if no preference set.']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: Retail B2B accounts with contract_pricing_flag, employee_discount_eligible, or loyalty_program_enrolled are assigned specific price lists. Pricing teams and POS systems resolve the correct price list ']
  profile_id varchar [note: 'Reference to the customer profile who owns this account. One customer may have multiple accounts (e.g., personal and business).']
  sales_territory_id varchar [note: 'Foreign key linking to store.sales_territory. Business justification: B2B sales territory management assigns customer accounts to territories for sales rep coverage, quota tracking, and revenue reporting. sales_territory.customer_count implies accounts are territory-sco']
  shipping_address_id varchar [note: 'Reference to the default shipping address for this account. Used for order fulfillment and delivery. Null if no default shipping address set.']
  account_number bigint [note: 'Externally-visible unique account number used for customer communication, statements, and customer service lookup. Distinct from internal account_id.']
  account_status bigint [note: 'Current status of the B2B account: active, suspended, closed, pending_approval. Only active accounts may place wholesale orders.']
  account_type bigint [note: 'Type of business account. Values: corporate, wholesale, franchise, reseller.']
  b2b_pricing_flag boolean [note: 'Always TRUE for account records since accounts exist only for B2B relationships. Retained for backward compatibility with legacy integrations.']
  close_date date [note: 'Date when the account was permanently closed. Null for active accounts. Used for churn analysis and account lifecycle reporting.']
  company_name varchar [note: 'Legal company or organization name for B2B/wholesale accounts.']
  created_timestamp timestamp [note: 'Timestamp when this account record was first created in the system. Used for audit trail and data lineage tracking.']
  credit_limit decimal(15,2) [note: 'Maximum credit extended to this B2B account for net-terms purchasing. NULL for prepay-only accounts.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the account\'s base currency (e.g., USD, EUR, GBP). All monetary transactions and balances for this account are denominated in this currency.']
  effective_end_date date [note: 'End date of this record version in the SCD Type-2 history; NULL or 9999-12-31 indicates the current active version.']
  effective_start_date date [note: 'Start date of this record version in the SCD Type-2 history; the date from which this version of the record is considered active.']
  employee_discount_eligible decimal(18,2) [note: 'Indicates whether this account is eligible for employee discount pricing. True for employee accounts and authorized family members; false otherwise.']
  is_current boolean [note: 'Flag indicating this is the current active version of the account record.']
  is_current_flag boolean [note: 'Indicates whether this is the currently active version of the record in the SCD Type-2 history.']
  loyalty_program_enrolled boolean [note: 'Indicates whether this account is enrolled in the retailer\'s loyalty or rewards program. True if enrolled; false otherwise. Used for loyalty analytics and targeted promotions.']
  notes varchar [note: 'Free-text field for internal notes about the account (e.g., special handling instructions, VIP preferences, service history, escalation notes). Used by customer service and account management teams.']
  open_date date [note: 'Date when the account was first opened and activated. Used for account age calculations, tenure-based benefits, and lifecycle analytics.']
  record_version varchar [note: 'Monotonically increasing version number for this record in the SCD Type-2 history.']
  scd_change_reason varchar [note: 'Business reason for the change that created this version, supporting GDPR audit trail requirements.']
  scd_change_timestamp timestamp [note: 'Exact timestamp when this SCD Type-2 version was created, used for change-data-capture reconciliation and GDPR audit trails.']
  scd_changed_by varchar [note: 'Identifier of the user or system process that triggered this SCD Type-2 version change, supporting GDPR accountability requirements.']
  suspension_date date [note: 'Date when the account was most recently suspended. Null if never suspended or currently active. Used for compliance and risk management reporting.']
  suspension_reason varchar [note: 'Free-text explanation of why the account was suspended (e.g., payment default, fraud investigation, customer request, policy violation). Null if never suspended.']
  tax_exempt_certificate_number decimal(18,2) [note: 'Government-issued tax exemption certificate number for tax-exempt accounts. Null for non-exempt accounts. Required for audit and compliance verification.']
  tax_exempt_expiry_date decimal(18,2) [note: 'Expiration date of the tax exemption certificate. Null for non-exempt accounts or perpetual exemptions. Used for compliance monitoring and renewal reminders.']
  tax_exempt_flag decimal(18,2) [note: 'Indicates whether this account is exempt from sales tax (e.g., non-profit organizations, government entities, resellers with valid tax exemption certificates). True if exempt; false otherwise.']
  version_number varchar [note: 'Sequential version identifier for SCD Type-2 tracking of this record.']

  Note: 'Optional B2B/wholesale account entity. Exists only for corporate, wholesale, or multi-user business relationships. Most B2C customers do not have an account record; their identity lives solely on the profile.'
}

Table customer.household {
  household_id varchar [pk, note: 'Unique surrogate key identifying a household grouping of customer profiles.']
  location_id varchar [note: 'Reference to the store location nearest to or preferred by this household.']
  average_basket_value decimal(10,2) [note: 'Average transaction basket value across all household members.']
  combined_cltv decimal(15,2) [note: 'Combined customer lifetime value estimate aggregated across all household members.']
  communication_preference varchar [note: 'Preferred communication channel for household-level outreach (e.g. email, mail, phone, sms).']
  created_timestamp timestamp [note: 'Timestamp when the household record was first created in the system.']
  data_sharing_consent boolean [note: 'Indicates whether the household has consented to data sharing for analytics purposes.']
  effective_end_date timestamp [note: 'SCD Type 2 effective end timestamp; NULL indicates the current active version.']
  effective_start_date timestamp [note: 'SCD Type 2 effective start timestamp for this version of the household record.']
  estimated_income_band varchar [note: 'Estimated household income bracket used for segmentation (e.g. low, medium, high, affluent).']
  external_household_code varchar [note: 'Identifier for this household in an external system or third-party data provider.']
  household_status varchar [note: 'Current lifecycle status of the household record (e.g. active, inactive, merged, dissolved).']
  household_type varchar [note: 'Classification of the household (e.g. single, family, multi-generational, shared).']
  is_current_flag boolean [note: 'Boolean flag indicating whether this is the current active version of the household record (SCD Type 2).']
  last_purchase_date date [note: 'Most recent purchase date across all household members.']
  loyalty_tier varchar [note: 'Highest loyalty program tier achieved by any member of the household.']
  marketing_opt_in boolean [note: 'Indicates whether the household has opted in to receive marketing communications.']
  name varchar [note: 'Display name or surname associated with the household grouping.']
  preferred_channel varchar [note: 'Preferred shopping channel for the household (e.g. in_store, online, omnichannel).']
  primary_language varchar [note: 'Primary language spoken in the household, used for communication preferences.']
  record_version varchar [note: 'Monotonically increasing version number for SCD Type 2 tracking of household changes.']
  segment varchar [note: 'Marketing or behavioral segment classification assigned to this household.']
  size varchar [note: 'Number of individuals (customer profiles) associated with this household.']
  total_loyalty_points decimal(18,2) [note: 'Aggregate loyalty points balance across all household members.']
  total_purchase_count decimal(18,2) [note: 'Total number of purchases made by all household members combined.']
  total_spend_amount decimal(15,2) [note: 'Total monetary spend across all household members over the lifetime of the household.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to this household record.']

  Note: 'Represents a household grouping of one or more customer profiles sharing a residence or economic unit. Enables household-level analytics, marketing, and deduplication across individual profiles.'
}

Table customer.corporate_account {
  corporate_account_id decimal(9,4) [pk, note: 'Unique identifier for the B2B corporate customer account. Primary key for the corporate account entity.']
  billing_address_id varchar [note: 'FK to customer.address']
  location_id varchar [note: 'Foreign key linking to store.location. Business justification: B2B account management assigns corporate accounts to a primary store location for dedicated servicing, sales rep assignment, and account-level revenue reporting. No existing FK from corporate_account ']
  parent_account_id varchar [note: 'Reference to the parent corporate account if this account is part of a multi-location or subsidiary hierarchy. Null for standalone accounts or top-level parent accounts. Enables consolidated billing and enterprise-wide reporting.']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: corporate_account.contract_pricing_flag explicitly signals a negotiated price list is assigned. B2B retail operations require corporate accounts to reference their contracted price list for order pric']
  primary_contact_id varchar [note: 'Foreign key linking to customer.contact. Business justification: Corporate accounts have a designated primary contact person. Currently, corporate_account stores primary_contact_name, primary_contact_email, primary_contact_phone as denormalized columns. Adding prim']
  shipping_address_id varchar [note: 'FK to customer.address']
  account_established_date bigint [note: 'Date when the corporate account was first created in the system. Used to calculate customer tenure and lifetime value metrics.']
  annual_spend_tier decimal(18,2) [note: 'Classification of the corporate account based on annual purchase volume. Used to determine discount levels, service priority, and account management resources. Tier_1 = highest spend (>$1M), Tier_5 = lowest spend (<$10K). Tiers recalculated annually.']
  business_entity_type varchar [note: 'Legal structure of the corporate entity. Values: sole_proprietorship, partnership, llc (Limited Liability Company), corporation (C-Corp), s_corp (S-Corporation), non_profit (501c3 or similar), government (public sector entity). [ENUM-REF-CANDIDATE: sole_proprietorship|partnership|llc|corporation|s_corp|non_profit|government — 7 candidates stripped; promote to reference product]']
  contract_pricing_flag boolean [note: 'Indicates whether the corporate account has negotiated contract pricing that overrides standard catalog prices. True = custom pricing agreement in place; False = standard pricing applies.']
  created_timestamp timestamp [note: 'System timestamp when this corporate account record was first created in the database. Used for audit trail and data lineage tracking.']
  credit_limit decimal(15,2) [note: 'Maximum outstanding balance allowed for the corporate account before requiring payment or credit hold. Expressed in USD. Null if account is cash-only.']
  credit_status decimal(18,2) [note: 'Current credit approval status for the corporate account. Determines whether the customer can purchase on credit terms. Values: approved (credit line active), pending (application submitted), declined (credit denied), under_review (periodic credit review in progress), suspended (credit privileges temporarily revoked).']
  dba_name varchar [note: 'Trade name or fictitious business name under which the corporate customer operates, if different from legal name. Used for marketing and customer-facing communications.']
  duns_number bigint [note: 'Nine-digit unique identifier assigned by Dun & Bradstreet to establish business credit profile and track commercial credit history. Used for supplier onboarding and credit evaluation.']
  industry_classification_naics varchar [note: 'Six-digit code classifying the corporate customer\'s primary industry using the NAICS standard. Provides more granular industry segmentation than SIC for modern business categories.']
  industry_classification_sic varchar [note: 'Four-digit code classifying the corporate customer\'s primary industry sector using the U.S. Standard Industrial Classification system. Used for market segmentation and industry analysis.']
  last_order_date date [note: 'Date of the most recent purchase order placed by this corporate account. Used for recency analysis and dormant account identification.']
  legal_business_name varchar [note: 'The official registered legal name of the corporate entity as it appears on government filings and tax documents. Used for contracts, invoicing, and legal compliance.']
  payment_terms decimal(18,2) [note: 'Standard payment terms negotiated with the corporate customer. Values: net_30 (payment due 30 days after invoice), net_45, net_60, net_90, due_on_receipt (immediate payment), prepay (payment before shipment), custom (non-standard terms documented separately). [ENUM-REF-CANDIDATE: net_30|net_45|net_60|net_90|due_on_receipt|prepay|custom — 7 candidates stripped; promote to reference product]']
  preferred_delivery_method varchar [note: 'Default shipping method preference for corporate orders. Values: standard_ground, expedited, next_day, freight (for large/bulk orders), customer_pickup (will-call).']
  tax_exempt_certificate_number decimal(18,2) [note: 'Government-issued tax exemption certificate number. Required for tax-exempt accounts to validate exemption status during order processing and audits.']
  tax_exempt_flag decimal(18,2) [note: 'Indicates whether the corporate account is exempt from sales tax (e.g., government entities, non-profits with valid exemption certificates). True = tax exempt; False = taxable.']
  tax_identifier decimal(18,2) [note: 'Federal tax identification number (EIN) assigned by the IRS for business tax reporting and compliance. Format: XX-XXXXXXX.']
  updated_timestamp timestamp [note: 'System timestamp when this corporate account record was last modified. Used for change tracking and data synchronization across systems.']

  Note: 'B2B corporate customer entity representing business clients such as small businesses, restaurants, and institutional buyers purchasing from Retail. Stores legal business name, tax ID / EIN, DUNS number, industry classification (SIC/NAICS), credit terms, assigned account manager, annual spend tier, contract pricing flag, and parent-subsidiary hierarchy reference. Supports B2B procurement workflows distinct from B2C consumer accounts. Deployed to retail_mvm (MVM) and retail_mvm (ECM) as distinct schemas.'
}

Table customer.contact {
  contact_id varchar [pk, note: 'Unique identifier for the contact method record. Primary key.']
  profile_id varchar [note: 'Reference to the customer profile or corporate account that owns this contact method. Links to the customer master record in the customer master data system.']
  bounce_count varchar [note: 'The cumulative number of times communication attempts via this contact method have bounced or failed. Used to trigger contact validation workflows and suppress invalid addresses.']
  consent_source varchar [note: 'The channel or touchpoint where the customer provided consent for this contact method (e.g., web registration, mobile app, POS, call center, in-store signup). Supports consent audit trails. [ENUM-REF-CANDIDATE: web|mobile_app|pos|call_center|email|in_store|third_party — 7 candidates stripped; promote to reference product]']
  contact_status varchar [note: 'Current lifecycle status of the contact method. Active indicates usable for communication; bounced/invalid indicates delivery failure; suppressed indicates customer request or compliance block; pending_verification indicates awaiting confirmation.']
  contact_type varchar [note: 'The type or category of contact method (e.g., primary email, mobile phone, work phone, WhatsApp, SMS, fax). Determines the channel and priority for omnichannel outreach. [ENUM-REF-CANDIDATE: primary_email|secondary_email|mobile|home_phone|work_phone|whatsapp|sms|fax — 8 candidates stripped; promote to reference product]']
  country_code bigint [note: 'Three-letter ISO 3166-1 alpha-3 country code indicating the country associated with this contact method (e.g., USA, GBR, CAN). Used for regional compliance and localization of communications.']
  created_timestamp timestamp [note: 'The timestamp when this contact method record was first created in the system. Supports audit trails and data lineage.']
  effective_end_date date [note: 'The date when this contact method ceased to be active or valid. Nullable for currently active contact methods. Supports temporal tracking and historical analysis.']
  effective_start_date date [note: 'The date from which this contact method became active and valid for customer communication. Supports temporal tracking and historical analysis.']
  is_primary boolean [note: 'Boolean flag indicating whether this is the primary contact method for the customer. Used to prioritize communication channels in omnichannel campaigns and clienteling.']
  is_verified boolean [note: 'Boolean flag indicating whether the contact method has been verified (e.g., email verification link clicked, phone number confirmed via OTP). Ensures data quality for marketing and transactional communications.']
  language_preference varchar [note: 'Two-letter ISO 639-1 language code indicating the customers preferred language for communications via this contact method (e.g., en, es, fr). Supports personalized omnichannel outreach.']
  last_bounce_date date [note: 'The date of the most recent bounce or delivery failure for this contact method. Nullable if no bounces have occurred.']
  last_modified_timestamp timestamp [note: 'The timestamp when this contact method record was last updated. Supports change tracking and audit trails.']
  last_used_date date [note: 'The date when this contact method was last successfully used for customer communication (email sent, SMS delivered, call completed). Helps identify stale or inactive contact points.']
  priority_rank varchar [note: 'Numeric ranking indicating the priority order of this contact method relative to other contact methods for the same customer. Lower numbers indicate higher priority. Used for fallback logic in omnichannel campaigns.']
  source_system_code varchar [note: 'The unique identifier for this contact method in the source system. Enables traceability and cross-system reconciliation.']
  value decimal(18,2) [note: 'The actual contact value (email address, phone number, social handle, etc.).']
  verification_date date [note: 'The date when the contact method was last verified by the customer. Used to track data freshness and trigger re-verification workflows.']

  Note: 'Stores all contact points for a customer profile or corporate account including email addresses, phone numbers, and social handles. Each row represents a single contact method with type (primary email, mobile, work phone, WhatsApp), verification status, opt-in/opt-out flags per channel, verification date, and source system. Supports omnichannel outreach, CRM campaigns via the case management system, and GDPR/CCPA consent enforcement at the contact-method level. Deployed to retail_mvm (MVM) and retail_mvm (ECM) as distinct schemas.'
}

Table customer.address {
  address_id varchar [pk, note: 'Unique identifier for the address record. Primary key.']
  profile_id varchar [note: 'Reference to the customer or corporate account associated with this address.']
  address_status varchar [note: 'Current lifecycle status of the address record. Active addresses are available for use in orders and shipments.']
  address_type varchar [note: 'Classification of the address purpose: billing, shipping, store pickup (BOPIS/ROPIS), home, work, or mailing.']
  city varchar [note: 'City or municipality name for the address.']
  country_code bigint [note: 'Three-letter ISO country code (e.g., USA, CAN, GBR) identifying the country of the address.']
  created_timestamp timestamp [note: 'Timestamp when the address record was first created in the system.']
  delivery_instructions varchar [note: 'Special delivery instructions provided by the customer (e.g., gate code, leave at door, ring bell).']
  delivery_point_barcode varchar [note: 'USPS Delivery Point Barcode (DPBC) or equivalent postal barcode for automated mail sorting and delivery.']
  effective_end_date timestamp [note: 'End date of this record version in the SCD Type-2 history; NULL or 9999-12-31 indicates the current active version.']
  effective_start_date timestamp [note: 'Start date of this record version in the SCD Type-2 history; the date from which this version of the record is considered active.']
  is_current_flag boolean [note: 'Indicates whether this is the currently active version of the record in the SCD Type-2 history.']
  is_default_billing boolean [note: 'Flag indicating whether this address is the default billing address for the customer.']
  is_default_shipping boolean [note: 'Flag indicating whether this address is the default shipping destination for the customer.']
  last_used_date date [note: 'Date when this address was last used in a transaction (order, shipment, or billing event).']
  latitude decimal(10,7) [note: 'Geographic latitude coordinate in decimal degrees for geolocation and last-mile delivery optimization.']
  line_1 varchar [note: 'Primary street address line including street number, street name, and unit/apartment number.']
  line_2 varchar [note: 'Secondary address line for additional location details such as building name, floor, suite, or department.']
  longitude decimal(10,7) [note: 'Geographic longitude coordinate in decimal degrees for geolocation and last-mile delivery optimization.']
  military_address_flag boolean [note: 'Indicates whether the address is a military address (APO/FPO/DPO). Requires special handling for international military mail.']
  nickname varchar [note: 'Customer-provided friendly name for the address (e.g., Home, Office, Mom\'s House) for easy identification.']
  po_box_flag boolean [note: 'Indicates whether the address is a PO Box. Some carriers and products cannot deliver to PO Boxes.']
  postal_code varchar [note: 'Postal code, ZIP code, or postcode for the address. Used for delivery routing and tax jurisdiction determination.']
  record_version varchar [note: 'Monotonically increasing version number for this record in the SCD Type-2 history.']
  residential_flag boolean [note: 'Indicates whether the address is a residential location (true) or commercial/business location (false). Impacts shipping rates and delivery windows.']
  scd_change_reason varchar [note: 'Business reason for the change that created this version, supporting GDPR audit trail requirements.']
  scd_change_timestamp timestamp [note: 'Exact timestamp when this SCD Type-2 version was created, used for change-data-capture reconciliation and GDPR audit trails.']
  scd_changed_by varchar [note: 'Identifier of the user or system process that triggered this SCD Type-2 version change, supporting GDPR accountability requirements.']
  standardization_flag boolean [note: 'Indicates whether the address has been standardized to postal service formatting rules (USPS Publication 28, etc.).']
  state_province varchar [note: 'State, province, or region code or name. For US addresses, use two-letter state abbreviation (e.g., CA, NY).']
  tax_jurisdiction_code decimal(18,2) [note: 'Tax jurisdiction identifier derived from the address, used to determine applicable sales tax rates and rules.']
  validation_status varchar [note: 'Status of address validation against postal service standards (USPS, Canada Post, etc.). Validated addresses reduce delivery failures.']
  verification_timestamp timestamp [note: 'Timestamp when the address was last verified against postal service databases or address validation services.']
  version_number varchar [note: 'Sequential version identifier for SCD Type-2 tracking of this record.']

  Note: 'Customer postal/delivery address with SCD Type 2 versioning for full change history and GDPR audit trails.'
}

Table customer.segment {
  segment_id varchar [pk, note: 'Primary key for segment']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: Retail segment-based pricing assigns a specific price list to each customer segment (VIP, B2B, discount-sensitive). The price_list.loyalty_tier_code and segment.discount_sensitivity confirm this desig']
  auto_refresh_flag boolean [note: 'Indicates whether customer membership in this segment is automatically recalculated on a scheduled basis (True) or manually managed (False). True for dynamic segments (e.g., RFM tiers recalculated nightly); False for static segments (e.g., one-time campaign lists).']
  average_aov decimal(18,2) [note: 'Mean Average Order Value for customers in this segment over the measurement period. Key metric for pricing strategy, promotion design, and basket optimization. Expressed in base currency (USD).']
  average_cltv decimal(18,2) [note: 'Mean Customer Lifetime Value across all customers currently assigned to this segment. Used for segment valuation, investment prioritization, and ROI forecasting. Expressed in base currency (USD).']
  average_purchase_frequency decimal(8,2) [note: 'Mean number of transactions per customer in this segment over the measurement period (typically 12 months). Used for replenishment forecasting, loyalty program design, and churn prediction.']
  avg_basket_size varchar [note: 'Average basket size for the segment in the customer domain (avg basket size).']
  avg_transaction_value decimal(18,2)
  b2b_b2c_indicator varchar [note: 'Indicates whether this segment applies to B2B customers (business accounts, wholesale, corporate), B2C customers (individual consumers), or both. Drives differentiated engagement strategies, pricing models, and service levels.']
  ccpa_opt_out_honored_flag boolean [note: 'Indicates whether this segment respects CCPA \'Do Not Sell My Personal Information\' opt-out requests (True) or is exempt (False, e.g., service-related communications). Ensures compliance for California residents.']
  churn_risk_score decimal(5,2) [note: 'Aggregate churn risk score for this segment, ranging from 0.00 (no risk) to 100.00 (high risk). Calculated from recency, frequency, and engagement metrics. Drives retention campaign prioritization and at-risk customer interventions.']
  code varchar [note: 'Short alphanumeric code uniquely identifying the segment for operational use (e.g., VIP_GOLD, LAPSED_90D, HIGH_VALUE_B2B). Used in marketing campaigns, pricing rules, and POS systems.']
  created_timestamp timestamp [note: 'Date and time when this segment definition was first created in the system. Audit trail for segment lifecycle tracking and governance.']
  description varchar [note: 'Detailed narrative describing the segment\'s defining characteristics, business rationale, and strategic purpose. Includes target customer profile, expected behaviors, and recommended engagement strategies.']
  discount_sensitivity decimal(18,2) [note: 'Behavioral classification of segment\'s responsiveness to promotional pricing. High: primarily purchases on promotion (Hi-Lo shoppers). Medium: balanced full-price and promotional purchases. Low: primarily full-price purchases (EDLP preference or premium segment).']
  effective_end_date date [note: 'Date when this segment definition was retired or superseded. Null for currently active segments. Enables segment lifecycle management and historical reporting.']
  effective_start_date date [note: 'Date when this segment definition became active and available for customer assignment. Supports temporal segmentation strategies and historical analysis.']
  gdpr_consent_required_flag boolean [note: 'Indicates whether explicit customer consent is required under GDPR for marketing communications to this segment (True) or whether legitimate interest or other legal basis applies (False). Ensures regulatory compliance for EU customers.']
  geographic_scope varchar [note: 'Geographic boundary or region to which this segment applies (e.g., \'USA\', \'Northeast Region\', \'Urban Markets\', \'Global\'). Supports localized segmentation strategies and regional campaign targeting. Use ISO 3166-1 alpha-3 country codes where applicable.']
  last_modified_timestamp timestamp [note: 'Date and time when this segment definition was last updated (criteria, name, status, or any other attribute). Supports change tracking and audit compliance.']
  last_refresh_timestamp timestamp [note: 'Date and time when segment membership was last recalculated and customer assignments were updated. Critical for data freshness validation and SLA monitoring.']
  max_rfm_score decimal(9,4) [note: 'Maximum RFM composite score for customer assignment to this segment (if segment_type is rfm_tier). Defines the upper bound of the RFM tier. Null for non-RFM segments.']
  member_count varchar
  membership_count varchar [note: 'Current count of customers assigned to this segment. Updated periodically based on auto-refresh schedule. Used for segment sizing, campaign planning, and capacity forecasting.']
  min_rfm_score decimal(9,4) [note: 'Minimum RFM composite score required for customer assignment to this segment (if segment_type is rfm_tier). RFM scores typically range from 3 (lowest: 1-1-1) to 15 (highest: 5-5-5). Null for non-RFM segments.']
  name varchar [note: 'Human-readable name of the segment (e.g., \'VIP Gold Tier\', \'Lapsed Customers - 90 Days\', \'High-Value B2B Accounts\'). Used in reporting, dashboards, and customer-facing communications.']
  nps_score decimal(5,2) [note: 'Average Net Promoter Score for customers in this segment, ranging from -100.00 (all detractors) to +100.00 (all promoters). Measures customer satisfaction, loyalty, and likelihood to recommend. Used for segment health monitoring and experience improvement prioritization.']
  owning_business_unit varchar [note: 'Name of the business unit or department responsible for defining, maintaining, and governing this segment (e.g., \'Marketing Analytics\', \'Customer Insights\', \'Loyalty Program Management\'). Establishes accountability for segment quality and usage.']
  priority_tier varchar [note: 'Service and engagement priority level assigned to this segment. Platinum: highest CLTV, white-glove service. Gold: high-value, priority support. Silver: mid-value, standard service. Bronze: emerging value. Standard: baseline service. Drives clienteling strategies and resource allocation.']
  qualification_criteria varchar [note: 'Summary of the business rules and thresholds used to assign customers to this segment (e.g., \'Purchased in last 30 days AND total spend > $5000 in last 12 months\', \'RFM Score >= 9\', \'Age 25-34 AND lives in urban area\'). Human-readable representation of the segmentation logic.']
  refresh_frequency decimal(9,4) [note: 'Cadence at which segment membership is recalculated for auto-refresh segments. Daily: high-velocity behavioral segments. Weekly: standard RFM tiers. Monthly: demographic or lifecycle segments. Quarterly: strategic value tiers. On-Demand: manual trigger only.']
  segment_status varchar [note: 'Current lifecycle status of the segment definition. Active: in production use for customer assignment and campaigns. Inactive: temporarily suspended, no new assignments. Archived: retired, historical reference only. Draft: under development, not yet released.']
  segment_type varchar [note: 'Classification of the segmentation methodology applied. RFM Tier: Recency, Frequency, Monetary analysis. Demographic: age, gender, income. Behavioral: purchase patterns, product affinity. Psychographic: lifestyle, values. Lifecycle Stage: new, active, at-risk, lapsed. Geographic: region, climate zone. Channel Preference: omnichannel, e-commerce-only, store-only. Value Tier: CLTV-based stratification. [ENUM-REF-CANDIDATE: rfm_tier|demographic|behavioral|psychographic|lifecycle_stage|geographic|channel_preference|value_tier — 8 candidates stripped; promote to reference product]']
  target_marketing_channel varchar [note: 'Primary communication channel recommended for engaging customers in this segment. Aligns segment strategy with channel preference and regulatory consent. All Channels: omnichannel engagement strategy. [ENUM-REF-CANDIDATE: email|sms|push_notification|direct_mail|in_store|call_center|social_media|all_channels — 8 candidates stripped; promote to reference product]']

  Note: 'Defines market segmentation classifications applied to customer profiles for targeted marketing, personalized pricing, and assortment decisions. Stores segment code, segment name, segment type (RFM tier, demographic, behavioral, psychographic, lifecycle stage, geographic, channel preference, value tier), segment description, qualification criteria summary, membership count, effective date range, auto-refresh flag, owning business unit, and profile-to-segment assignments with effective dates and expiry dates. Enables Retail to execute clienteling strategies, personalized promotions, and differentiated service levels across POS and e-commerce channels. Deployed to retail_mvm (MVM) and retail_mvm (ECM) as distinct schemas.'
}

Table customer.interaction {
  interaction_id varchar [pk, note: 'Unique identifier for the customer interaction event. Primary key.']
  department_id varchar [note: 'Foreign key linking to store.department. Business justification: In-store customer service tracking and department-level NPS/sentiment reporting requires knowing which department an interaction occurred in. Retail operations teams report on service quality and comp']
  location_id varchar [note: 'Identifier of the physical store location where the interaction occurred. Applicable for in-store interactions (POS visit, clienteling visit, in-store event). Null for digital interactions.']
  profile_id varchar [note: 'Identifier of the customer who participated in this interaction. Links to the customer master record.']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Campaign response tracking — email opens, clicks, and digital interactions are attributed to specific promotional campaigns in retail. This FK enables campaign engagement reporting, A/B test analysis,']
  rma_id varchar [note: 'Foreign key linking to returns.rma. Business justification: Customer service operations log interactions (calls, chats, emails) against specific RMAs — a named retail customer service process. Enables RMA-level interaction history reporting, SLA tracking, and ']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Product Interaction Tracking: retail customer service and digital analytics require linking interaction events (product views, support calls, complaints, returns inquiries) to the specific SKU involve']
  browser varchar [note: 'The web browser used by the customer during this interaction (e.g., Chrome, Safari, Firefox, Edge). Applicable for web-based interactions. Null for non-web interactions.']
  channel varchar [note: 'The channel or medium through which the interaction occurred (e.g., store, web, mobile app, call center, email, SMS, push notification, social media, kiosk). [ENUM-REF-CANDIDATE: store|web|mobile_app|call_center|email|sms|push|social_media|kiosk|chat|video — promote to reference product]']
  created_timestamp timestamp [note: 'The date and time when this interaction record was first created in the data platform. Audit field for data lineage and compliance.']
  delivery_status varchar [note: 'The delivery and engagement status for outbound communication interactions (email, SMS, push notification). Indicates whether the message was delivered, opened, clicked, bounced, or failed. Null for inbound or non-message interactions.']
  device_type varchar [note: 'The type of device used by the customer during this interaction (e.g., desktop, mobile, tablet, kiosk, POS terminal). Applicable for digital and in-store interactions. Null if device type is unknown.']
  digital_property varchar [note: 'The specific digital asset or platform where the interaction occurred (e.g., main website, mobile app, partner site, social media platform name). Applicable for digital interactions. Null for in-store interactions.']
  direction varchar [note: 'Indicates whether the interaction was initiated by the customer (inbound) or by Retail (outbound).']
  duration_seconds decimal(9,4) [note: 'The length of the interaction in seconds. Applicable for sessions, calls, chats, and visits. Null for instantaneous events (e.g., email send, SMS send).']
  email_clicked_flag boolean [note: 'Boolean flag indicating whether the customer clicked a link within an outbound email. Applicable only for email interactions. Null for non-email interactions.']
  email_opened_flag boolean [note: 'Boolean flag indicating whether an outbound email was opened by the customer. Applicable only for email interactions. Null for non-email interactions.']
  geolocation_latitude decimal(9,6) [note: 'The latitude coordinate of the customer location at the time of this interaction, if available. Applicable for mobile app interactions with location services enabled. Null if location data is unavailable.']
  geolocation_longitude decimal(9,6) [note: 'The longitude coordinate of the customer location at the time of this interaction, if available. Applicable for mobile app interactions with location services enabled. Null if location data is unavailable.']
  interaction_timestamp timestamp [note: 'The date and time when the interaction event occurred. This is the business event timestamp (when the customer engaged), distinct from record audit timestamps.']
  interaction_type varchar [note: 'The category of customer touchpoint or engagement event. Defines the nature of the interaction (e.g., POS visit, website session, app open, call center contact, email send, SMS send, push notification, chat, clienteling visit, NPS survey response). [ENUM-REF-CANDIDATE: pos_visit|website_session|mobile_app_open|call_center_contact|email_campaign|sms_campaign|push_notification|live_chat|clienteling_visit|nps_survey|social_media_engagement|kiosk_interaction|video_call|in_store_event — promote to reference product]']
  ip_address varchar [note: 'The IP address of the customer device during this interaction. Applicable for digital interactions. Null for in-store interactions. May be considered PII in some jurisdictions.']
  landing_page_url varchar [note: 'The URL of the first page visited by the customer during this interaction session. Applicable for web-based interactions. Null for non-web interactions.']
  notes varchar [note: 'Free-text notes or comments recorded by the associate or agent during or after the interaction. Captures additional context, customer requests, or follow-up actions. Null if no notes were recorded.']
  nps_score decimal(9,4) [note: 'The Net Promoter Score (NPS) provided by the customer during or after this interaction, if applicable. Scale 0-10. Null if no NPS was collected.']
  operating_system varchar [note: 'The operating system of the device used during this interaction (e.g., Windows, macOS, iOS, Android). Applicable for digital interactions. Null for non-digital interactions.']
  outcome varchar [note: 'The result or resolution status of the interaction (e.g., completed, abandoned, escalated, resolved, converted, bounced, unsubscribed). [ENUM-REF-CANDIDATE: completed|abandoned|escalated|resolved|converted|bounced|unsubscribed|pending|transferred|no_response — promote to reference product]']
  referrer_url varchar [note: 'The URL of the page or source that referred the customer to this interaction (e.g., search engine, social media, email link). Applicable for web-based interactions. Null for non-web interactions.']
  sentiment_score decimal(3,2) [note: 'A numeric score representing the sentiment or emotional tone of the interaction, derived from text analytics or voice analytics. Scale typically -1.0 (negative) to +1.0 (positive). Null if sentiment analysis was not performed.']
  sms_delivered_flag boolean [note: 'Boolean flag indicating whether an outbound SMS message was successfully delivered to the customer. Applicable only for SMS interactions. Null for non-SMS interactions.']
  subject varchar [note: 'A brief subject or title describing the purpose or topic of the interaction (e.g., product inquiry, order status check, complaint, feedback). Applicable for call center contacts, service cases, and clienteling visits. Null for automated or non-subject-based interactions.']
  unsubscribed_flag boolean [note: 'Boolean flag indicating whether the customer unsubscribed from communications as a result of this interaction. Applicable for outbound communication interactions.']
  updated_timestamp timestamp [note: 'The date and time when this interaction record was last updated in the data platform. Audit field for data lineage and compliance.']

  Note: 'Records every customer touchpoint, engagement event, and outbound communication across all Retail channels sourced from SAP Customer Activity Repository (CAR) and the case management system. Stores interaction type (POS visit, website session, app open, call center contact, email send/open/click, SMS send/delivery, push notification, chat, clienteling visit, NPS survey response), direction (inbound/outbound), channel, store or digital property, timestamp, duration, outcome, NPS score (when applicable), associated campaign or promotion ID, delivery status and engagement metrics for outbound messages (delivered/opened/clicked/bounced/unsubscribed), and agent/associate ID. This is the single consolidated product for all customer communication and engagement history — foundation for omnichannel interaction timeline, communication audit trail, campaign response tracking, and CLTV modeling. Deployed to retail_mvm (MVM) and retail_mvm (ECM) as distinct schemas.'
}

Table customer.payment_method {
  payment_method_id decimal(18,2) [pk, note: 'Primary key for payment_method']
  billing_address_id varchar [note: 'Foreign key linking to customer.address. Business justification: payment_method has embedded billing address fields (billing_address_line1, billing_address_line2, billing_city, billing_state_province, billing_postal_code, billing_country_code) that should be normal']
  profile_id varchar [note: 'Reference to the customer who owns this payment method. Links to the customer master record for omnichannel recognition and clienteling.']
  bin_number bigint [note: 'First six digits of the card number (Bank Identification Number). Used for card type identification, fraud detection, and routing. Not considered sensitive under PCI DSS.']
  bnpl_provider varchar [note: 'Buy-now-pay-later provider. Free-form string; common values include: klarna, affirm, afterpay, zip, sezzle.']
  card_brand varchar [note: 'Brand of the payment card; common values include visa, mastercard, amex, discover.']
  card_country_code bigint [note: 'Three-letter ISO 3166-1 alpha-3 country code for the country where the card was issued. Derived from BIN lookup. Used for fraud detection and international transaction processing.']
  cardholder_name varchar [note: 'Full name of the cardholder. PII-sensitive; masked in non-production environments. Canonical source now in finance.payment_instrument.']
  consent_channel varchar [note: 'Channel through which the customer provided consent to store this payment method (web, mobile app, POS, call center, in-store). Required for GDPR and CCPA compliance.']
  consent_timestamp timestamp [note: 'Timestamp when the customer provided consent to store this payment method. Required for GDPR and CCPA compliance.']
  created_timestamp timestamp [note: 'Timestamp when this payment method record was first created in the system. Used for audit trail and customer lifecycle analysis.']
  deactivated_timestamp timestamp [note: 'Timestamp when this payment method was deactivated. Null if the payment method is still active. Used for lifecycle tracking and compliance reporting.']
  deactivation_reason varchar [note: 'Reason why the payment method was deactivated. Used for customer service, fraud analysis, and operational reporting.']
  digital_wallet_provider varchar [note: 'Digital wallet provider. Free-form string; common values include: apple_pay, google_pay, paypal, samsung_pay, venmo.']
  expiry_month varchar [note: 'Expiration month of the payment card (1-12). Used to validate card validity at checkout and trigger proactive customer notifications for expiring cards.']
  expiry_year varchar [note: 'Expiration year of the payment card (four-digit year). Used to validate card validity at checkout and trigger proactive customer notifications for expiring cards.']
  gift_card_balance decimal(15,2) [note: 'Current balance remaining on the gift card. Updated after each transaction. Applicable only when payment_method_type is gift_card.']
  gift_card_number bigint [note: 'Tokenized or masked gift card number. Applicable only when payment_method_type is gift_card. Used for gift card balance inquiries and redemption.']
  is_active boolean [note: 'Flag indicating whether this payment method is currently active and available for use. Inactive methods are retained for historical transaction reference but cannot be used for new purchases.']
  is_default boolean [note: 'Flag indicating whether this is the customers default payment method for one-click checkout and recurring purchases. Only one payment method per customer should be marked as default.']
  issuing_bank varchar [note: 'Name of the bank or financial institution that issued the payment card. Used for transaction routing and fraud detection.']
  last_four_digits varchar [note: 'Last four digits of the card number for customer recognition and display purposes. Used in clienteling and checkout confirmation screens.']
  last_used_date date [note: 'Date when this payment method was last used for a transaction. Used for RFM (Recency Frequency Monetary) analytics and customer engagement.']
  nickname varchar [note: 'Customer-defined nickname for this payment method (e.g., My Visa, Work Card, Personal Checking). Used for customer convenience in payment selection.']
  payment_method_type decimal(18,2) [note: 'Type of payment method. Allowed values: credit_card, debit_card, wallet, gift_card, store_credit, bnpl.']
  payment_processor decimal(18,2) [note: 'Name of the payment processor or gateway used to process transactions with this payment method (e.g., Stripe, Adyen, Braintree, Cybersource). Used for transaction routing and reconciliation.']
  primary_digital_wallet_account_reference varchar [note: 'Tokenized identifier for the digital wallet account. Used for digital wallet transactions and reconciliation.']
  processor_token varchar [note: 'Payment processor-specific token for this payment method. Used for transaction processing and vault management.']
  store_credit_balance decimal(15,2) [note: 'Current balance of store credit available to the customer. Typically issued from returns or promotional campaigns. Applicable only when payment_method_type is store_credit.']
  token varchar [note: 'PCI DSS compliant tokenized reference to the payment instrument. No raw PAN (Primary Account Number) is stored. Token is used for recurring purchases and one-click checkout.']
  updated_timestamp timestamp [note: 'Timestamp when this payment method record was last updated. Used for audit trail and data quality monitoring.']
  usage_count varchar [note: 'Total number of times this payment method has been used for transactions. Used for RFM analytics and customer behavior analysis.']
  verification_date date [note: 'Date when the payment method was last verified. Used for compliance and fraud prevention tracking.']
  verification_status varchar [note: 'Status of payment method verification (e.g., AVS check, CVV verification, micro-deposit confirmation). Used for fraud prevention and risk management.']
  wallet_provider varchar [note: 'Digital wallet provider; common values include apple_pay, google_pay, paypal.']

  Note: 'DEPRECATED: Payment method records for customers. This table is superseded by finance.payment_instrument for PCI DSS isolation. Retained as a view/reference for backward compatibility; new integrations should use finance.payment_instrument.'
}

Table customer.membership {
  membership_id varchar [pk, note: 'Primary key for customer_membership']
  customer_segment_id varchar [note: 'Foreign key linking to the segment definition to which this profile is assigned']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: Loyalty membership tiers directly determine price list eligibility in retail. price_list.loyalty_tier_code confirms this design intent. The POS and e-commerce pricing engine resolves the active member']
  profile_id varchar [note: 'Foreign key linking to the customer profile participating in this segment membership']
  assignment_confidence_score decimal(5,2) [note: 'Confidence score (0.00-100.00) indicating the strength of this customer\'s qualification for this segment. For rule-based assignments, reflects how strongly the customer meets qualification criteria. For ML-based assignments, reflects model prediction confidence. Used for prioritizing marketing outreach and identifying borderline members.']
  assignment_method varchar [note: 'Mechanism by which this customer was assigned to this segment. AutoRefresh: automatically assigned via scheduled segment refresh process. ManualOverride: manually assigned by business user overriding qualification rules. RuleEngine: assigned via real-time rule evaluation. MLModel: assigned via predictive model scoring. BulkImport: assigned via batch data load.']
  created_timestamp timestamp [note: 'Timestamp when this membership record was first created in the system. Audit field for data lineage and troubleshooting.']
  customer_membership_status varchar [note: 'Current operational status of this segment membership. Active: customer currently qualifies and membership is in effect. Expired: membership ended due to disqualification or time-based expiry. Suspended: temporarily inactive due to business rules. PendingQualification: awaiting next refresh cycle to confirm eligibility.']
  end_date date [note: 'Date when this customer profile exited this segment or the membership was terminated. Null for currently active memberships. Used for churn analysis and segment tenure calculations.']
  fee decimal(18,2) [note: 'The membership fee of the customer membership.']
  last_modified_timestamp timestamp [note: 'Timestamp when this membership record was last updated (status change, confidence score update, override modification). Audit field for change tracking.']
  last_qualification_check_date timestamp [note: 'Timestamp of the most recent evaluation of this customer\'s eligibility for this segment. Updated during auto-refresh cycles or manual re-qualification checks. Used for audit trails and determining when next qualification check is due.']
  manual_override_flag boolean [note: 'Boolean flag indicating whether this membership was manually assigned by a business user, overriding automated qualification rules. True: manual override in effect, customer may not meet standard qualification criteria. False: standard rule-based or automated assignment. Used for governance and audit purposes.']
  override_reason varchar [note: 'Free-text explanation provided by business user when manual_override_flag is true. Documents business justification for overriding automated qualification rules (e.g., \'VIP customer per executive request\', \'Strategic account exception\', \'Retention offer\'). Null when no override is in effect.']
  renewal_rate decimal(18,2) [note: 'The renewal rate of the customer membership.']
  start_date date [note: 'Date when this customer profile was assigned to this segment and the membership became active. Used for lifecycle tracking and historical analysis of segment transitions.']

  Note: '[References SSOT: loyalty.loyalty_membership] Customer-to-membership assignment linking table. References loyalty.loyalty_membership as the authoritative membership record. Tracks segment-based membership assignments and qualification methods.'
}

Table product.sku {
  sku_id varchar [pk, note: 'Primary key for the SKU record']
  brand_id varchar [note: 'Foreign key linking to product.product_brand. Business justification: Every SKU belongs to exactly one brand (national brand or private label). product_brand is the SSOT for brand master data in this domain. The sku table has private_label_flag as a denormalized indicat']
  item_hierarchy_id varchar [note: 'FK to item hierarchy']
  uom_id varchar [note: 'FK to unit of measure']
  vendor_id varchar [note: 'FK to primary vendor']
  age_restriction_flag boolean [note: 'Indicates if age restriction applies to this SKU']
  country_of_origin varchar [note: 'Country where the item is manufactured or sourced']
  created_timestamp timestamp [note: 'Record creation timestamp']
  cube decimal(10,3) [note: 'Cubic volume of the item for storage calculations']
  description varchar [note: 'Full description of the SKU']
  dimension_unit_of_measure varchar [note: 'Unit of measure for length/width/height dimensions']
  discontinuation_date date [note: 'Date when the SKU is discontinued']
  ean varchar [note: 'European Article Number barcode']
  effective_date date [note: 'Date when the SKU becomes active']
  generic_monetary_dummy decimal(18,2) [note: 'Placeholder monetary attribute added by mutator to ensure change.']
  gross_weight decimal(10,3) [note: 'Gross weight including packaging']
  gtin varchar [note: 'Global Trade Item Number']
  hazmat_flag boolean [note: 'Indicates if the item is classified as hazardous material']
  height decimal(10,2) [note: 'Height dimension of the item']
  hi varchar [note: 'Number of layers high on a pallet']
  image_url varchar [note: 'URL to the primary product image']
  internal_item_number varchar [note: 'Internal item identifier used by the organization']
  length decimal(10,2) [note: 'Length dimension of the item']
  lifecycle_status varchar [note: 'Current lifecycle status of the SKU (e.g. active, discontinued, pending)']
  minimum_age_requirement varchar [note: 'Minimum age required to purchase this item']
  modified_timestamp timestamp [note: 'Last modification timestamp']
  net_weight decimal(10,3) [note: 'Net weight of the item without packaging']
  pack_size varchar [note: 'Number of individual units in a pack']
  private_label_flag boolean [note: 'Indicates if this is a private label/store brand item']
  shelf_life_days varchar [note: 'Number of days the item remains sellable']
  short_description varchar [note: 'Short description for POS and labels']
  stackable_flag boolean [note: 'Indicates if the item can be stacked during storage']
  temperature_requirement varchar [note: 'Temperature storage requirement (e.g. ambient, chilled, frozen)']
  ti varchar [note: 'Number of cases per pallet layer (tie)']
  upc varchar [note: 'Universal Product Code']
  vendor_item_number varchar [note: 'Vendor-assigned item number']
  volume decimal(10,3) [note: 'Volume of the item']
  volume_unit_of_measure varchar [note: 'Unit of measure for volume']
  weight_unit_of_measure varchar [note: 'Unit of measure for weight']
  width decimal(10,2) [note: 'Width dimension of the item']

  Note: 'Stock keeping unit - the most granular sellable/stockable item in the product master.'
}

Table product.item_hierarchy {
  item_hierarchy_id varchar [pk, note: 'Primary key for item hierarchy node']
  parent_hierarchy_node_item_hierarchy_id varchar [note: 'Self-referencing FK to parent hierarchy node']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: Category management process: retail category managers assign a default price list to each hierarchy node (e.g., \'Clearance\', \'Premium\', \'Value\'), governing all SKUs within that category. item_hierarch']
  allows_direct_sku_assignment boolean [note: 'Whether SKUs can be directly assigned to this node']
  assortment_breadth_target varchar [note: 'Target number of distinct SKUs in assortment']
  assortment_depth_target varchar [note: 'Target depth of inventory per SKU']
  category_manager_name varchar [note: 'Name of the category manager responsible']
  created_timestamp timestamp [note: 'Record creation timestamp']
  data_quality_score decimal(5,2) [note: 'Data quality score for this hierarchy node']
  effective_end_date date [note: 'End date of validity for this hierarchy node']
  effective_start_date date [note: 'Start date of validity for this hierarchy node']
  external_reference_code varchar [note: 'External system reference code']
  generic_monetary_dummy decimal(18,2) [note: 'Placeholder monetary attribute added by mutator to ensure change.']
  hierarchy_description varchar [note: 'Description of the hierarchy node']
  hierarchy_level varchar [note: 'Level within the hierarchy (e.g. division, department, class, subclass)']
  hierarchy_node_code varchar [note: 'Code identifier for the hierarchy node']
  hierarchy_node_name varchar [note: 'Display name of the hierarchy node']
  hierarchy_path varchar [note: 'Full materialized path from root to this node']
  hierarchy_type varchar [note: 'Type of hierarchy (e.g. merchandise, financial, planning)']
  is_leaf_node boolean [note: 'Whether this is a leaf node with no children']
  last_modified_by varchar [note: 'User who last modified this record']
  last_modified_timestamp timestamp [note: 'Last modification timestamp']
  lead_time_days varchar [note: 'Default lead time in days for items in this category']
  lifecycle_status varchar [note: 'Status of the hierarchy node (active, inactive, pending)']
  markdown_cadence varchar [note: 'Default markdown cadence for items in this category']
  minimum_order_quantity varchar [note: 'Default minimum order quantity for this category']
  omnichannel_enabled boolean [note: 'Whether items in this category are available across all channels']
  planner_name varchar [note: 'Name of the planner responsible for this category']
  pricing_strategy varchar [note: 'Default pricing strategy for items in this category']
  private_label_penetration_target_percent decimal(5,2) [note: 'Target percentage of private label penetration']
  replenishment_method varchar [note: 'Default replenishment method for this category']
  safety_stock_weeks decimal(5,2) [note: 'Default safety stock in weeks of supply']
  seasonality_indicator varchar [note: 'Seasonality classification for this category']
  sort_order varchar [note: 'Display sort order among siblings']
  strategic_classification varchar [note: 'Strategic classification (e.g. growth, maintain, exit)']
  target_gross_margin_percent decimal(5,2) [note: 'Target gross margin percentage for this category']

  Note: 'Hierarchical classification of products into departments, categories, subcategories, and classes.'
}

Table product.attribute {
  attribute_id varchar [pk, note: 'Primary key for the attribute record']
  sku_id varchar [note: 'FK to the SKU this attribute belongs to']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: The attribute table stores flexible key-value metadata for SKUs and has a unit_of_measure STRING column for attributes that have a measurable value (e.g., \'net weight: 500 g\', \'voltage: 110 V\'). This ']
  approved_by varchar [note: 'User who approved this attribute value']
  approved_timestamp timestamp [note: 'Timestamp when the attribute was approved']
  attribute_group varchar [note: 'Grouping category for the attribute']
  attribute_status varchar [note: 'Status of the attribute (active, pending, deprecated)']
  certification_body varchar [note: 'Certifying body if the attribute is certified']
  certification_date date [note: 'Date of certification']
  conversion_factor decimal(18,6) [note: 'Conversion factor for unit transformations']
  created_timestamp timestamp [note: 'Record creation timestamp']
  data_quality_score decimal(5,2) [note: 'Data quality score for this attribute']
  data_type varchar [note: 'Data type of the attribute value (string, numeric, boolean, date)']
  display_order varchar [note: 'Display order for UI rendering']
  effective_end_date date [note: 'End date of attribute validity']
  effective_start_date date [note: 'Start date of attribute validity']
  generic_monetary_dummy decimal(18,2) [note: 'Placeholder monetary attribute added by mutator to ensure change.']
  is_certified boolean [note: 'Whether this attribute value is certified']
  is_comparable boolean [note: 'Whether this attribute can be used for product comparison']
  is_regulatory_required boolean [note: 'Whether this attribute is required by regulation']
  is_required boolean [note: 'Whether this attribute is mandatory for the SKU']
  is_searchable boolean [note: 'Whether this attribute is indexed for search']
  last_updated_timestamp timestamp [note: 'Last update timestamp']
  locale varchar [note: 'Locale for localized attribute values']
  name varchar [note: 'Name of the attribute']
  notes varchar [note: 'Free-text notes about the attribute']
  regulatory_reference varchar [note: 'Reference to regulatory requirement']
  source_system_code varchar [note: 'Code in the source system']
  validation_rule varchar [note: 'Validation rule expression for the attribute value']
  value decimal(18,2) [note: 'Numeric value of the attribute when applicable']

  Note: 'Extended product attributes providing flexible key-value metadata for SKUs.'
}

Table product.brand {
  brand_id varchar [pk, note: 'Primary key for the product brand']
  vendor_id varchar [note: 'FK to the primary vendor for this brand']
  average_margin_percent decimal(5,2) [note: 'Average margin percentage across brand products']
  brand_status varchar [note: 'Current status (active, inactive, pending)']
  brand_type varchar [note: 'Type of brand (national, private_label, licensed)']
  code varchar [note: 'Short code identifier for the brand']
  country_of_origin_code varchar [note: 'Country of origin for the brand']
  created_timestamp timestamp [note: 'Record creation timestamp']
  description varchar [note: 'Detailed description of the brand']
  discontinuation_date date [note: 'Date when the brand was discontinued']
  generic_monetary_dummy decimal(18,2) [note: 'Placeholder monetary attribute added by mutator to ensure change.']
  is_exclusive boolean [note: 'Whether this brand is exclusive to the retailer']
  is_licensed boolean [note: 'Whether this is a licensed brand']
  is_private_label boolean [note: 'Whether this is a private label brand']
  last_modified_timestamp timestamp [note: 'Last modification timestamp']
  launch_date date [note: 'Date the brand was launched']
  lead_time_days varchar [note: 'Default lead time in days for brand products']
  license_expiration_date date [note: 'Expiration date of the brand license']
  logo_asset_url varchar [note: 'URL to the brand logo asset']
  minimum_order_quantity varchar [note: 'Default minimum order quantity for brand products']
  modified_by_user varchar [note: 'User who last modified this record']
  name varchar [note: 'Display name of the brand']
  owner_country_code varchar [note: 'Country code of the brand owner']
  owner_name varchar [note: 'Name of the brand owner']
  portfolio_group varchar [note: 'Portfolio grouping for brand management']
  quality_rating decimal(3,2) [note: 'Quality rating score for the brand']
  return_rate_percent decimal(5,2) [note: 'Average return rate percentage for brand products']
  sustainability_certification varchar [note: 'Sustainability certification held by the brand']
  target_customer_segment varchar [note: 'Target customer segment for the brand']
  tier varchar [note: 'Tier classification (premium, mid-tier, value)']
  website_url varchar [note: 'Brand website URL']

  Note: '[SSOT Owner] Authoritative source for product brand master data. Defines brand identity, ownership, licensing, and commercial attributes used across merchandising and supply chain.'
}

Table product.item_variant {
  item_variant_id varchar [pk, note: 'Primary key for item variant/substitution record']
  primary_item_sku_id varchar [note: 'FK to the primary SKU in the variant relationship']
  target_item_sku_id varchar [note: 'FK to the target/substitute SKU']
  variant_dimension_uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: item_variant has variant_dimension_value (DECIMAL) representing the measured dimension of a variant (e.g., 500 for a 500ml size variant, 32 for a 32-inch size variant) and variant_dimension_type (STRI']
  approval_timestamp timestamp [note: 'Timestamp when the variant relationship was approved']
  auto_substitute_flag boolean [note: 'Whether automatic substitution is allowed']
  channel_applicability varchar [note: 'Channels where this variant relationship applies']
  created_timestamp timestamp [note: 'Record creation timestamp']
  customer_consent_required_flag boolean [note: 'Whether customer consent is needed for substitution']
  display_sequence varchar [note: 'Display sequence for variant ordering']
  effective_end_date date [note: 'End date of the variant relationship']
  effective_start_date date [note: 'Start date of the variant relationship']
  generic_monetary_dummy decimal(18,2) [note: 'Placeholder monetary attribute added by mutator to ensure change.']
  inventory_interchangeable_flag boolean [note: 'Whether inventory is interchangeable between variants']
  last_modified_timestamp timestamp [note: 'Last modification timestamp']
  notes varchar [note: 'Free-text notes about the variant relationship']
  price_differential_amount decimal(18,2) [note: 'Price difference between primary and target item']
  relationship_status varchar [note: 'Status of the variant relationship']
  relationship_type varchar [note: 'Type of relationship (variant, substitute, upgrade, downgrade)']
  source_system_code varchar [note: 'Source system code']
  substitution_priority_rank varchar [note: 'Priority rank for substitution selection']
  substitution_type varchar [note: 'Type of substitution (equivalent, upgrade, similar)']
  variant_dimension_type varchar [note: 'Dimension type that differentiates variants (size, color, flavor)']
  variant_dimension_value decimal(18,2) [note: 'Numeric value of the variant dimension when applicable']
  variant_ean varchar [note: 'EAN of the variant item']
  variant_group_code varchar [note: 'Group code linking related variants']
  variant_gtin varchar [note: 'GTIN of the variant item']
  variant_upc varchar [note: 'UPC of the variant item']

  Note: 'Relationships between SKUs representing variants, substitutes, and cross-sell associations.'
}

Table product.compliance {
  compliance_id varchar [pk, note: 'Primary key for product compliance record']
  sku_id varchar [note: 'FK to the SKU']
  age_restriction_required boolean [note: 'Whether age restriction is required for sale']
  allergen_declaration_compliant boolean [note: 'Whether allergen declaration is compliant']
  certification_number varchar [note: 'Certification number']
  certifying_body varchar [note: 'Name of the certifying body']
  compliance_status varchar [note: 'Current compliance status']
  compliance_type varchar [note: 'Type of compliance (food_safety, hazmat, environmental, labeling)']
  country_code varchar [note: 'Country code for the compliance requirement']
  country_of_origin_compliant boolean [note: 'Whether country of origin labeling is compliant']
  created_timestamp timestamp [note: 'Record creation timestamp']
  effective_date date [note: 'Effective date of compliance certification']
  expiry_date date [note: 'Expiry date of compliance certification']
  fda_food_facility_registration varchar [note: 'FDA food facility registration number']
  generic_monetary_dummy decimal(18,2) [note: 'Placeholder monetary attribute added by mutator to ensure change.']
  hazmat_classification varchar [note: 'Hazardous material classification code']
  import_license_number varchar [note: 'Import license number']
  last_audit_date date [note: 'Date of last compliance audit']
  last_modified_timestamp timestamp [note: 'Last modification timestamp']
  minimum_age_years varchar [note: 'Minimum age in years for purchase']
  modified_by_user varchar [note: 'User who last modified this record']
  next_audit_date date [note: 'Date of next scheduled audit']
  notes varchar [note: 'Free-text compliance notes']
  nutrition_labeling_compliant boolean [note: 'Whether nutrition labeling is compliant']
  organic_certification varchar [note: 'Organic certification details']
  prop_65_chemical_list varchar [note: 'List of Prop 65 chemicals present']
  prop_65_warning_required boolean [note: 'Whether Prop 65 warning is required']
  recall_date date [note: 'Date of recall if applicable']
  recall_reason varchar [note: 'Reason for recall']
  recall_severity_level varchar [note: 'Severity level of recall']
  recall_status varchar [note: 'Status of recall']
  region_code varchar [note: 'Region code for the compliance requirement']
  responsible_party_contact varchar [note: 'Contact information for responsible party']
  sustainability_certification varchar [note: 'Sustainability certification details']
  tariff_classification_code varchar [note: 'Harmonized tariff classification code']
  test_report_number varchar [note: 'Test report reference number']
  testing_laboratory varchar [note: 'Name of the testing laboratory']

  Note: 'Regulatory compliance records for products including certifications, hazmat classifications, and safety requirements.'
}

Table product.item_bundle {
  item_bundle_id varchar [pk, note: 'Primary key for the item bundle']
  bundle_sku_id varchar [note: 'FK to the bundle SKU']
  component_uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: item_bundle has component_quantity (DECIMAL) representing how many units of the component SKU are included in the bundle, but no unit of measure FK for that quantity. A bundle could include 2 EA, 500 ']
  item_hierarchy_id varchar [note: 'Foreign key linking to product.item_hierarchy. Business justification: item_bundle has assortment_category as a STRING column describing the category context of the bundle. item_hierarchy is the authoritative product classification structure (departments, categories, sub']
  location_id varchar [note: 'FK to store location where bundle is available']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: Bundle pricing management: retail bundles are governed by a dedicated price list (e.g., \'Bundle Promotions\' or \'Value Pack\' price list) that controls bundle pricing rules, currency, and approval workf']
  vendor_contract_id varchar [note: 'Foreign key linking to supplier.vendor_contract. Business justification: Bundle pricing and component sourcing in retail are governed by specific vendor contracts. Linking item_bundle to vendor_contract enables contract compliance tracking, bundle margin analysis against c']
  vendor_id varchar [note: 'FK to the vendor']
  bundle_description varchar [note: 'Description of the bundle']
  bundle_name varchar [note: 'Name of the bundle']
  bundle_price_amount decimal(18,2) [note: 'Price of the bundle']
  bundle_status varchar [note: 'Status of the bundle (active, inactive, draft)']
  bundle_type varchar [note: 'Type of bundle (fixed, configurable, mix_and_match)']
  channel_availability varchar [note: 'Channels where the bundle is available']
  component_quantity decimal(10,3) [note: 'Quantity of the component in the bundle']
  component_sequence varchar [note: 'Sequence order of the component']
  component_sku varchar [note: 'SKU code of the component item']
  component_substitution_allowed boolean [note: 'Whether component substitution is allowed']
  created_timestamp timestamp [note: 'Record creation timestamp']
  currency_code varchar [note: 'Currency code for pricing']
  discount_amount decimal(18,2) [note: 'Discount amount on the bundle']
  discount_percentage decimal(5,2) [note: 'Discount percentage on the bundle']
  effective_end_date date [note: 'End date of bundle availability']
  effective_start_date date [note: 'Start date of bundle availability']
  generic_monetary_dummy decimal(18,2) [note: 'Placeholder monetary attribute added by mutator to ensure change.']
  inventory_deduction_method varchar [note: 'How inventory is deducted (component_level, bundle_level)']
  last_modified_timestamp timestamp [note: 'Last modification timestamp']
  loyalty_points_eligible boolean [note: 'Whether the bundle earns loyalty points']
  maximum_purchase_quantity varchar [note: 'Maximum quantity per purchase']
  minimum_purchase_quantity varchar [note: 'Minimum quantity per purchase']
  modified_by_user varchar [note: 'User who last modified this record']
  pricing_method varchar [note: 'Pricing method (fixed, calculated, dynamic)']
  promotion_eligible boolean [note: 'Whether the bundle is eligible for promotions']
  return_policy_code varchar [note: 'Return policy code applicable to the bundle']
  returnable boolean [note: 'Whether the bundle is returnable']

  Note: 'Product bundles and kits composed of multiple component SKUs sold together.'
}

Table product.gtin_registry {
  gtin_registry_id varchar [pk, note: 'Primary key for the GTIN registry record']
  sku_id varchar [note: 'FK to the SKU']
  barcode_image_url varchar [note: 'URL to the barcode image']
  barcode_symbology varchar [note: 'Barcode symbology type (EAN-13, UPC-A, ITF-14)']
  check_digit varchar [note: 'Check digit of the GTIN']
  child_gtin_quantity varchar [note: 'Number of child GTINs contained']
  country_of_sale varchar [note: 'Country where the GTIN is registered for sale']
  created_timestamp timestamp [note: 'Record creation timestamp']
  discontinuation_date date [note: 'Date when the GTIN was discontinued']
  effective_date date [note: 'Effective date of the GTIN registration']
  gdsn_last_sync_timestamp timestamp [note: 'Last synchronization with GDSN']
  gdsn_publication_status varchar [note: 'GDSN publication status']
  generic_monetary_dummy decimal(18,2) [note: 'Placeholder monetary attribute added by mutator to ensure change.']
  gross_weight_unit varchar [note: 'Unit of measure for gross weight']
  gross_weight_value decimal(18,4) [note: 'Gross weight value']
  gs1_company_prefix varchar [note: 'GS1 company prefix']
  gtin varchar [note: 'Global Trade Item Number']
  gtin_type varchar [note: 'Type of GTIN (GTIN-8, GTIN-12, GTIN-13, GTIN-14)']
  is_base_unit boolean [note: 'Whether this is the base unit GTIN']
  is_consumer_unit boolean [note: 'Whether this is a consumer-facing unit']
  is_orderable_unit boolean [note: 'Whether this unit is orderable']
  is_variable_measure boolean [note: 'Whether this is a variable measure item']
  last_modified_timestamp timestamp [note: 'Last modification timestamp']
  modified_by_user varchar [note: 'User who last modified this record']
  net_content_unit varchar [note: 'Unit of measure for net content']
  net_content_value decimal(18,4) [note: 'Net content value']
  package_depth_value decimal(18,4) [note: 'Package depth']
  package_dimension_unit varchar [note: 'Unit of measure for package dimensions']
  package_height_value decimal(18,4) [note: 'Package height']
  package_width_value decimal(18,4) [note: 'Package width']
  packaging_level varchar [note: 'Packaging level (each, inner_pack, case, pallet)']
  parent_gtin varchar [note: 'Parent GTIN for hierarchical packaging']
  registration_status varchar [note: 'Registration status of the GTIN']
  regulatory_compliance_status varchar [note: 'Regulatory compliance status']
  replacement_gtin varchar [note: 'Replacement GTIN if discontinued']

  Note: 'Global Trade Item Number registry maintaining barcode and packaging hierarchy data for all sellable units.'
}

Table product.uom {
  uom_id varchar [pk, note: 'Primary key for unit of measure']
  base_uom_id varchar [note: 'FK to the base UOM for conversion']
  class varchar [note: 'Class of UOM (weight, volume, length, count)']
  code varchar [note: 'Short code for the UOM']
  conversion_factor decimal(18,6) [note: 'Conversion factor to base unit']
  created_timestamp timestamp [note: 'Record creation timestamp']
  data_quality_score decimal(5,2) [note: 'Data quality score']
  description varchar [note: 'Description of the UOM']
  effective_end_date date [note: 'End date of UOM validity']
  effective_start_date date [note: 'Start date of UOM validity']
  generic_monetary_dummy decimal(18,2) [note: 'Placeholder monetary attribute added by mutator to ensure change.']
  gs1_uom_code varchar [note: 'GS1 standard UOM code']
  inverse_conversion_factor decimal(18,6) [note: 'Inverse conversion factor from base unit']
  is_base_unit boolean [note: 'Whether this is the base unit for its class']
  is_consumer_unit boolean [note: 'Whether this is a consumer-facing unit']
  is_fractional_allowed boolean [note: 'Whether fractional quantities are allowed']
  is_inventory_tracked boolean [note: 'Whether inventory is tracked in this UOM']
  is_orderable boolean [note: 'Whether this UOM is orderable']
  is_variable_measure boolean [note: 'Whether this is a variable measure UOM']
  iso_uom_code varchar [note: 'ISO standard UOM code']
  last_modified_timestamp timestamp [note: 'Last modification timestamp']
  lifecycle_status varchar [note: 'Lifecycle status (active, deprecated, retired)']
  modified_by_user varchar [note: 'User who last modified this record']
  name varchar [note: 'Display name of the UOM']
  precision_decimal_places varchar [note: 'Number of decimal places for precision']
  sort_order varchar [note: 'Display sort order']
  superseded_by_uom_code varchar [note: 'UOM code that supersedes this one']
  symbol varchar [note: 'Symbol for the UOM (kg, lb, ea)']
  unece_code varchar [note: 'UN/ECE Recommendation 20 code']
  uom_type varchar [note: 'Type of UOM (selling, buying, storage)']
  usage_context varchar [note: 'Context where this UOM is used']

  Note: 'Unit of measure master data defining measurement units, conversions, and packaging hierarchies.'
}

Table product.assortment {
  assortment_id varchar [pk, note: 'Primary key for the assortment record']
  fulfillment_node_id varchar [note: 'FK to the fulfillment node']
  location_id varchar [note: 'Foreign key linking to store.location. Business justification: Store-level assortment planning — the core retail process of determining which SKUs are stocked at which store locations — requires this FK. Assortment reports, replenishment triggers, planogram gener']
  sku_id varchar [note: 'FK to the SKU']
  storefront_id varchar [note: 'Foreign key linking to ecommerce.storefront. Business justification: Online assortment management requires defining which SKUs are available on which storefronts (e.g., US site vs. CA site vs. marketplace storefront). Retail merchants use storefront-level assortment as']
  allocation_priority varchar [note: 'Priority for allocation']
  assignment_effective_date date [note: 'Effective date of the assortment assignment']
  assignment_end_date date [note: 'End date of the assortment assignment']
  created_timestamp timestamp [note: 'Record creation timestamp']
  generic_monetary_dummy decimal(18,2) [note: 'Placeholder monetary attribute added by mutator to ensure change.']
  last_modified_timestamp timestamp [note: 'Last modification timestamp']
  last_received_date date [note: 'Date the item was last received at this node']
  max_stock_quantity varchar [note: 'Maximum stock quantity for this assortment']
  min_stock_quantity varchar [note: 'Minimum stock quantity for this assortment']
  replenishment_lead_time_days varchar [note: 'Lead time in days for replenishment']
  stocking_status varchar [note: 'Stocking status (active, discontinued, seasonal)']

  Note: 'SKU-to-fulfillment-node assignment defining which products are stocked at which locations.'
}

Table order.header {
  header_id varchar [pk, note: 'Unique identifier for the order header record. Primary key for the order header entity.']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: B2B and account-based retail operations require tracking orders against customer accounts for credit limit enforcement, account statement generation, billing cycle management, and corporate purchasing']
  billing_address_id varchar [note: 'Foreign key linking to customer.address. Business justification: Order billing address normalization: linking to customer.address enforces referential integrity, enables address-level order history reporting, and eliminates denormalized flat billing address columns']
  contact_id varchar [note: 'Foreign key linking to customer.contact. Business justification: Order confirmation and shipping notification delivery should use the customer\'s verified, consent-managed contact record. header.customer_email and customer_phone are denormalized. Linking to customer']
  corporate_account_id decimal(9,4) [note: 'Foreign key linking to customer.corporate_account. Business justification: Corporate B2B retail requires linking orders to corporate accounts (distinct from individual accounts) for contract pricing application, consolidated invoicing, credit terms enforcement, annual spend ']
  fulfillment_node_id varchar [note: 'Reference to the store, distribution center, or warehouse responsible for fulfilling this order. Cross-domain reference to inventory or store domain.']
  marketplace_listing_id varchar [note: 'Foreign key linking to ecommerce.marketplace_listing. Business justification: Marketplace order attribution: orders originating from marketplace listings must link to the specific listing for marketplace fee reconciliation, sell-through rate calculation, buy-box performance ana']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: Order headers are fulfilled under a specific price list (e.g., wholesale, loyalty tier, regional). Retail margin reporting and order audit require knowing which price list governed the entire order. N']
  profile_id varchar [note: 'Reference to the customer who placed the order. Links to customer master data.']
  source_purchase_order_id varchar [note: 'Foreign key linking to supplychain.purchase_order. Business justification: Retail drop-ship orders where vendor ships directly to customer require tracking the source supplier PO for cost reconciliation, vendor chargeback processing, and fulfillment exception handling. Essen']
  store_location_id varchar [note: 'Add column store_location_id (BIGINT) to store.header with FK to store.location.location_id because orders placed in-store must reference the originating store location. P20: connect_table: store.header** - add column store_location_id (BIG']
  subscription_id varchar [note: 'Foreign key linking to order.subscription. Business justification: Subscription orders (subscribe-and-save, auto-replenishment) generate recurring order headers on each delivery cycle. The header table currently has no FK back to the subscription that generated it, m']
  actual_delivery_date date [note: 'Actual date the order was delivered to the customer. Null until delivery is confirmed.']
  carrier_code varchar [note: 'Code identifying the shipping carrier or third-party logistics (3PL) provider handling delivery (e.g., UPS, FedEx, USPS).']
  channel varchar [note: 'Sales channel through which the order was originated. Distinguishes omnichannel order sources for analytics and fulfillment routing.']
  created_timestamp timestamp [note: 'Date and time when this order header record was first created in the system. Audit trail for record creation.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts in this order (e.g., USD, EUR, GBP).']
  discount_amount decimal(18,2) [note: 'Total discount applied to the order including promotional discounts, coupons, loyalty rewards, and markdowns.']
  grand_total_amount decimal(18,2) [note: 'Final order total including subtotal, tax, shipping, minus discounts. Amount charged to customer payment method.']
  locale varchar [note: 'Language and regional locale for the order (e.g., en_US, fr_CA). Used for localized content and formatting.']
  oms_reference_code varchar [note: 'External reference identifier from the Order Management System for end-to-end order orchestration and tracking.']
  order_date timestamp [note: 'Date and time when the order was placed by the customer. Principal business event timestamp for the transaction.']
  order_number varchar [note: 'Externally-known unique business identifier for the order. Used for customer communication, tracking, and cross-system reference.']
  order_status varchar [note: 'Current lifecycle status of the order in the fulfillment workflow. Tracks progression from creation through final disposition. [ENUM-REF-CANDIDATE: draft|submitted|confirmed|processing|picking|packing|shipped|delivered|completed|cancelled|returned — 11 candidates stripped; promote to reference product]']
  order_type varchar [note: 'Classification of order fulfillment method. BOPIS (Buy Online Pick Up In Store), ROPIS (Reserve Online Pick Up In Store), SFS (Ship From Store), or standard home delivery. [ENUM-REF-CANDIDATE: standard|bopis|ropis|ship_from_store|drop_ship|exchange|replacement — 7 candidates stripped; promote to reference product]']
  payment_method varchar [note: 'Primary payment instrument used for the order. Identifies the payment type without exposing sensitive card details. [ENUM-REF-CANDIDATE: credit_card|debit_card|paypal|apple_pay|google_pay|gift_card|store_credit|cash|check|bank_transfer — 10 candidates stripped; promote to reference product]']
  payment_status varchar [note: 'Current status of payment processing for the order. Tracks authorization, capture, and settlement lifecycle. [ENUM-REF-CANDIDATE: pending|authorized|captured|paid|failed|refunded|partially_refunded — 7 candidates stripped; promote to reference product]']
  promised_delivery_date date [note: 'Date committed to the customer for order delivery. Used for SLA compliance measurement.']
  requested_delivery_date date [note: 'Customer-requested target delivery date. Used for scheduling and SLA tracking.']
  shipping_address_line1 varchar [note: 'First line of the shipping address including street number and name. Primary delivery location identifier.']
  shipping_address_line2 varchar [note: 'Second line of the shipping address for apartment, suite, or unit number. Optional address detail.']
  shipping_amount decimal(18,2) [note: 'Shipping and handling charges for order delivery. Zero for in-store pickup orders.']
  shipping_city varchar [note: 'City or municipality for the shipping address.']
  shipping_country_code varchar [note: 'Three-letter ISO 3166-1 alpha-3 country code for the shipping address (e.g., USA, CAN, GBR).']
  shipping_postal_code varchar [note: 'Postal or ZIP code for the shipping address. Critical for carrier routing and delivery zone determination.']
  shipping_state_province varchar [note: 'State, province, or region for the shipping address. Used for tax jurisdiction and carrier routing.']
  special_instructions varchar [note: 'Customer-provided delivery instructions or notes (e.g., gate code, leave at door, signature required).']
  subtotal_amount decimal(18,2) [note: 'Sum of all line item amounts before taxes, discounts, and shipping charges. Base merchandise value.']
  tax_amount decimal(18,2) [note: 'Total sales tax applied to the order based on jurisdiction and product taxability rules.']
  tracking_number varchar [note: 'Carrier-provided tracking number for shipment visibility and customer self-service tracking.']
  updated_timestamp timestamp [note: 'Date and time when this order header record was last modified. Audit trail for record changes.']

  Note: 'Core master record for every omnichannel order. Captures order number, channel origin (web, app, call center, marketplace), order date/time, customer reference, fulfillment node reference (FK to store/distribution domain), order status, currency, locale, totals (subtotal, tax, discount, shipping, grand total), OMS reference ID, source system, and audit timestamps. SSOT for order identity and lifecycle. Carrier and fulfillment node masters are owned by peer domains and referenced via cross-domain FK.'
}

Table order.order_line {
  order_line_id varchar [pk, note: 'Unique identifier for the order line item. Primary key for the order line product.']
  digital_catalog_id varchar [note: 'Foreign key linking to ecommerce.digital_catalog. Business justification: Ecommerce order attribution: retailers must trace which digital catalog listing (product page, content version, SEO entry) drove each order line purchase. Required for catalog content performance repo']
  fulfillment_node_id varchar [note: 'Identifier of the distribution center, store, or warehouse assigned to fulfill this line. Supports split-fulfillment where different lines ship from different nodes.']
  header_id varchar [note: 'Foreign key reference to the parent order header. Links this line item to its containing order transaction.']
  lot_id varchar [note: 'Foreign key linking to inventory.lot. Business justification: Lot traceability is mandatory for recalls, quality issues, and regulatory compliance in retail (especially food, pharma, cosmetics). Fulfillment systems must record which specific lot/batch was picked']
  promo_offer_id varchar [note: 'Identifier of the promotion applied to this line item. Links to the promotion master for discount calculation and campaign tracking.']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Order lines must reference the product SKU being ordered. The product_description column becomes redundant as it can be joined from product.sku. This is a fundamental cross-domain relationship between']
  sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: Order lines capture actual transaction prices. Linking to sku_price enables margin variance analysis, promotional effectiveness measurement, price compliance auditing, and reconciliation between plann']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: Order line fulfillment requires UOM conversion factor lookups for inventory deduction accuracy, carrier weight calculations, and cross-channel unit reconciliation. Current unit_of_measure string preve']
  vendor_id varchar [note: 'Foreign key linking to supplier.vendor. Business justification: Direct Ship Vendor (DSV) fulfillment: in retail, drop-ship order lines are routed to a specific vendor for direct-to-consumer fulfillment. This FK enables EDI order transmission, vendor performance tr']
  actual_ship_date date [note: 'Actual date when this line item was shipped from the fulfillment node. Used for SLA performance measurement and delivery estimation.']
  backorder_flag boolean [note: 'Indicates whether this line item is on backorder due to insufficient inventory at order time. True if the item will be shipped when inventory becomes available.']
  cancellation_reason_code varchar [note: 'Standardized code indicating why this line was cancelled. Populated only when line_status is CANCELLED. Enables root cause analysis of order cancellations.']
  cancelled_quantity decimal(10,3) [note: 'Quantity cancelled and not fulfilled. Tracks partial cancellations where only a portion of the ordered quantity is cancelled.']
  carrier_code varchar [note: 'Code identifying the shipping carrier assigned to deliver this line item. Supports multi-carrier fulfillment strategies. [ENUM-REF-CANDIDATE: FEDEX|UPS|USPS|DHL|ONTRAC|LASERSHIP|LOCAL_COURIER — 7 candidates stripped; promote to reference product]']
  cost_of_goods_sold decimal(12,2) [note: 'Unit cost of the product at the time of order fulfillment. Used for margin analysis and profitability reporting. Business-confidential financial data.']
  created_timestamp timestamp [note: 'Timestamp when this order line record was first created in the system. Represents the moment the line item was added to the order.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts on this line. Supports multi-currency transactions in global retail operations.']
  discount_amount decimal(12,2) [note: 'Total discount applied to this line item. Includes promotional discounts, markdowns, coupons, and loyalty rewards applied at the line level.']
  expected_ship_date date [note: 'Planned date when this line item is expected to ship from the fulfillment node. Used for customer communication and Service Level Agreement (SLA) tracking.']
  extended_price decimal(12,2) [note: 'Total price for this line item before discounts and taxes. Calculated as ordered_quantity multiplied by unit_retail_price.']
  fulfillment_method varchar [note: 'Method by which this line will be fulfilled. Supports omnichannel fulfillment including ship-to-home, Buy Online Pick Up In Store (BOPIS), Reserve Online Pick Up In Store (ROPIS), Ship-from-Store (SFS), and drop-ship.']
  gift_flag boolean [note: 'Indicates whether this line item is marked as a gift. True if the customer designated this item for gift wrapping, gift messaging, or special handling.']
  gift_message varchar [note: 'Customer-provided gift message to be included with this line item. Populated only when gift_flag is true.']
  gtin varchar [note: '14-digit Global Trade Item Number. International standard for product identification across the supply chain.']
  line_number varchar [note: 'Sequential line number within the order. Determines the display and processing order of line items within a single order header.']
  line_status varchar [note: 'Current fulfillment status of this order line. Tracks the line through the fulfillment lifecycle from order confirmation to final delivery or cancellation. [ENUM-REF-CANDIDATE: PENDING|CONFIRMED|ALLOCATED|PICKED|PACKED|SHIPPED|DELIVERED|CANCELLED|RETURNED — 9 candidates stripped; promote to reference product]']
  margin_amount decimal(12,2) [note: 'Gross margin for this line item calculated as line_total minus cost_of_goods_sold. Key metric for profitability analysis and Gross Margin Return on Investment (GMROI) calculations.']
  modified_timestamp timestamp [note: 'Timestamp when this order line record was last modified. Tracks any updates to quantity, status, pricing, or fulfillment details.']
  ordered_quantity decimal(10,3) [note: 'Quantity of the product ordered by the customer. Supports fractional quantities for weight-based or volume-based items.']
  original_sku varchar [note: 'Original SKU that was ordered by the customer, populated only when substitution_flag is true. Enables tracking of substitution patterns and customer acceptance rates.']
  personalization_notes varchar [note: 'Special instructions for product personalization such as monogramming, engraving, or custom text. Captured at order time and passed to fulfillment operations.']
  return_reason_code varchar [note: 'Standardized code indicating why this line was returned by the customer. Populated when returned_quantity is greater than zero. Supports Return Merchandise Authorization (RMA) processing.']
  returned_quantity decimal(10,3) [note: 'Quantity returned by the customer after delivery. Supports partial returns and links to Return Merchandise Authorization (RMA) processing.']
  shipped_quantity decimal(10,3) [note: 'Actual quantity shipped to the customer. May differ from ordered_quantity due to partial fulfillment, substitutions, or inventory constraints.']
  sku varchar [note: 'Internal stock keeping unit code identifying the specific product variant at the most granular level. Used for inventory tracking and fulfillment.']
  substitution_flag boolean [note: 'Indicates whether this line item is a substitution for an out-of-stock product. True if a substitute product was provided instead of the originally ordered item.']
  tax_amount decimal(12,2) [note: 'Total tax charged on this line item. Includes sales tax, VAT, GST, or other applicable taxes based on jurisdiction and product category.']
  tax_jurisdiction_code varchar [note: 'Code identifying the tax jurisdiction for this line item. Determines applicable tax rates based on ship-to location and product tax category.']
  tax_rate decimal(5,4) [note: 'Effective tax rate applied to this line item expressed as a decimal. For example, 0.0825 represents 8.25 percent sales tax.']
  total decimal(12,2) [note: 'Final total amount for this line item after discounts and taxes. Calculated as extended_price minus discount_amount plus tax_amount.']
  tracking_number varchar [note: 'Carrier tracking number for this line item shipment. Enables customer self-service tracking and last-mile delivery visibility.']
  unit_retail_price decimal(12,2) [note: 'Price per unit at the time of order. Represents the Average Unit Retail (AUR) before any line-level discounts or promotions.']
  upc varchar [note: '12-digit Universal Product Code barcode identifier. Standard North American product identifier used at point of sale.']

  Note: '[SSOT Owner] Authoritative source for order line items. Captures what the customer ordered including SKU, quantity, pricing, and tax details. The commercial record of the transaction.'
}

Table order.pos_transaction {
  pos_transaction_id varchar [pk, note: 'Unique identifier for the POS transaction record. Primary key for in-store register transactions.']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: B2B in-store purchases on account (net-30 terms, employee discount accounts, corporate charge accounts) require linking POS transactions to customer accounts. pos_transaction links to profile but not ']
  header_id varchar [note: 'Reference to the order header for omnichannel transactions such as BOPIS (Buy Online Pick Up In Store) pickups or ship-from-store fulfillments that originated as digital orders.']
  original_transaction_pos_transaction_id varchar [note: 'Reference to the original POS transaction being returned or exchanged when transaction_type is return or exchange.']
  pos_terminal_id varchar [note: 'Unique identifier of the POS terminal device used to process the transaction.']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: POS transactions execute under a specific price list (regular, employee, clearance). Stamping the active price list on the transaction enables price list performance reporting, in-store pricing audit,']
  primary_pos_location_id varchar [note: 'Identifier of the retail store location where the transaction occurred.']
  profile_id varchar [note: 'Identifier of the customer who made the purchase. Populated when loyalty card is scanned or customer account is identified.']
  business_date date [note: 'Retail business day to which this transaction is attributed for financial reporting. May differ from transaction timestamp for transactions after store closing but before end-of-day processing.']
  change_amount decimal(18,2) [note: 'Cash change returned to the customer when tender_amount exceeds total_amount.']
  coupon_count varchar [note: 'Number of coupons redeemed in the transaction including manufacturer coupons and store coupons.']
  created_timestamp timestamp [note: 'Timestamp when the POS transaction record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the transaction monetary amounts.']
  discount_amount decimal(18,2) [note: 'Total discount amount applied to the transaction including promotional discounts, coupons, markdowns, and employee discounts.']
  fiscal_receipt_number varchar [note: 'Government-mandated fiscal receipt identifier for tax compliance and audit purposes. Required in jurisdictions with fiscal receipt regulations.']
  fulfillment_type varchar [note: 'Fulfillment method for the transaction distinguishing between traditional in-store purchases and omnichannel fulfillment scenarios.']
  item_count varchar [note: 'Total number of distinct line items in the transaction basket. Used for basket analysis and UPT (Units Per Transaction) calculation.']
  last_modified_timestamp timestamp [note: 'Timestamp when the POS transaction record was last updated. Used for audit trail and data synchronization.']
  loyalty_card_number varchar [note: 'Loyalty program card number scanned during the transaction for points accrual and customer identification.']
  loyalty_points_earned varchar [note: 'Number of loyalty program points earned by the customer for this transaction based on purchase amount and promotional multipliers.']
  loyalty_points_redeemed varchar [note: 'Number of loyalty program points redeemed by the customer during this transaction for discounts or rewards.']
  manager_override_flag boolean [note: 'Indicates whether a manager override was required during the transaction for actions such as large discounts, voids, or policy exceptions.']
  payment_method_count varchar [note: 'Number of distinct payment methods used in the transaction. Supports split-tender analysis.']
  primary_payment_method varchar [note: 'Primary payment instrument used for the transaction. For split-tender transactions, this is the method with the largest payment amount. [ENUM-REF-CANDIDATE: cash|credit_card|debit_card|gift_card|mobile_payment|check|store_credit — 7 candidates stripped; promote to reference product]']
  promotion_count varchar [note: 'Number of distinct promotions applied to the transaction. Used for promotional effectiveness analysis.']
  receipt_email varchar [note: 'Email address provided by the customer for digital receipt delivery.']
  receipt_phone varchar [note: 'Phone number provided by the customer for SMS receipt delivery or order pickup notifications.']
  register_number varchar [note: 'Physical register or checkout lane number within the store where the transaction was processed.']
  return_reason_code varchar [note: 'Standardized code indicating the reason for return when transaction_type is return. Used for return analytics and product quality monitoring.']
  subtotal_amount decimal(18,2) [note: 'Sum of all line item amounts before taxes, fees, and discounts are applied.']
  tax_amount decimal(18,2) [note: 'Total sales tax charged on the transaction based on applicable tax jurisdiction and product tax categories.']
  tender_amount decimal(18,2) [note: 'Total amount tendered by the customer across all payment methods. May exceed total_amount when cash change is given.']
  total_amount decimal(18,2) [note: 'Final total amount tendered by the customer including all items, taxes, fees, and after all discounts. Represents the net transaction value and ATV (Average Transaction Value).']
  total_quantity decimal(15,3) [note: 'Total quantity of all items purchased in the transaction, summed across all line items. May differ from item_count when multiple units of the same SKU are purchased.']
  training_mode_flag boolean [note: 'Indicates whether the transaction was processed in training mode for new cashier onboarding. Training transactions are excluded from financial reporting.']
  transaction_number varchar [note: 'Business-readable transaction number printed on the customer receipt. Externally visible identifier for customer service and returns processing.']
  transaction_status varchar [note: 'Current lifecycle status of the POS transaction indicating whether it was completed, voided, suspended for later completion, or refunded.']
  transaction_timestamp timestamp [note: 'Date and time when the transaction was completed at the register. Primary business event timestamp for sales analytics and footfall analysis.']
  transaction_type varchar [note: 'Type of POS transaction distinguishing between sales, returns, exchanges, voids, and no-sale register opens.']
  void_reason_code varchar [note: 'Standardized code indicating the reason for voiding the transaction when transaction_status is voided. Used for fraud detection and operational quality monitoring.']

  Note: 'Point-of-Sale transaction record for in-store purchase events at registers. Captures POS terminal ID, register number, cashier/associate ID, store number, transaction date/time, transaction type (sale, return, exchange, void), total tender, tax, discount, loyalty card number, basket metrics (item count, UPT, ATV), and fiscal receipt number. SSOT for brick-and-mortar register transactions. Complements order_header for transactions originating at physical registers rather than digital order flow. Payment tenders linked via the payment product.'
}

Table order.pos_transaction_line {
  pos_transaction_line_id varchar [pk, note: 'Unique identifier for the individual line item within a POS transaction. Primary key for the transaction line detail record.']
  coupon_id varchar [note: 'Foreign key linking to promotion.coupon. Business justification: pos_transaction_line.coupon_code is a denormalized coupon reference. A proper FK to promotion.coupon enables coupon redemption reconciliation, single-use coupon enforcement, and vendor-funded coupon c']
  department_id varchar [note: 'Foreign key linking to store.department. Business justification: Department-level POS sales reporting, shrinkage tracking, and licensed-department regulatory compliance all require knowing which store department each transaction line belongs to. A retail domain exp']
  markdown_id varchar [note: 'Foreign key linking to pricing.markdown. Business justification: POS line items sold at marked-down prices must reference the markdown event for sell-through reporting (units sold per markdown event) — a core retail KPI. The existing sku_price_id path does not dire']
  pos_transaction_id varchar [note: 'Foreign key reference to the parent POS transaction header. Links this line item to the overall transaction.']
  promo_offer_id varchar [note: 'Foreign key linking to promotion.promo_offer. Business justification: In-store POS line-item promotional reporting requires linking each sold line to the specific promo offer applied. Enables offer-level redemption analytics, vendor chargeback calculations, and promotio']
  sku_id varchar [note: 'Foreign key reference to the master product record. Links to product information management system for detailed product attributes.']
  sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: POS lines record actual selling prices at point of sale. Linking to sku_price enables real-time price verification, override detection, shrinkage analysis from pricing discrepancies, and margin tracki']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: Retail POS sells items by weight (lb/kg), volume, or each — requiring UOM master reference for variable-measure items, scale-integrated POS, and cross-channel UOM-consistent sales reporting. order_lin']
  vendor_item_id varchar [note: 'Foreign key linking to supplier.vendor_item. Business justification: DSD (Direct Store Delivery) cost reconciliation and chargeback processing: POS transaction lines for DSD items must reference the specific vendor item record to validate unit cost, pack configuration,']
  category_code varchar [note: 'Product category or subcategory code within the department. Supports assortment planning and basket analysis.']
  cost_of_goods_sold decimal(12,4) [note: 'Unit cost of the product at the time of sale. Used for gross margin calculation and profitability analysis. Business confidential.']
  created_timestamp timestamp [note: 'Date and time when this transaction line record was first created in the system. Used for data lineage and audit trails.']
  ean varchar [note: '13-digit European Article Number for international product identification. Used for global product tracking and cross-border commerce.']
  extended_price decimal(12,2) [note: 'Total price for this line item calculated as quantity multiplied by unit price before discounts. Gross line amount before markdown.']
  fulfillment_type varchar [note: 'Method by which this line item was fulfilled. Supports omnichannel order orchestration and fulfillment analytics.']
  gtin varchar [note: 'Global Trade Item Number that uniquely identifies trade items worldwide. Can be 8, 12, 13, or 14 digits depending on product type.']
  item_description varchar [note: 'Human-readable description of the product as it appears on the receipt. Includes brand, product name, size, and variant details.']
  line_number varchar [note: 'Sequential line number within the transaction. Determines the order in which items were scanned or entered at the point of sale.']
  loyalty_points_earned varchar [note: 'Number of loyalty program points earned for this line item purchase. Used for customer loyalty program management and engagement.']
  loyalty_points_redeemed varchar [note: 'Number of loyalty program points redeemed to discount this line item. Reduces the net amount paid by the customer.']
  markdown_amount decimal(12,2) [note: 'Total discount amount applied to this line item. Includes promotional discounts, coupons, and price reductions.']
  modified_timestamp timestamp [note: 'Date and time when this transaction line record was last modified. Used for change tracking and data quality monitoring.']
  net_line_amount decimal(12,2) [note: 'Net amount for this line item after markdown but before tax. Calculated as extended price minus markdown amount.']
  private_label_flag boolean [note: 'Indicates whether this product is a store brand or private label item. True for private label, false for national brands.']
  promotion_code varchar [note: 'Promotional campaign code applied to this line item. Links to promotion management system for campaign tracking and analysis.']
  quantity_sold decimal(10,3) [note: 'Number of units sold for this line item. Supports fractional quantities for variable-weight items such as produce and deli products.']
  return_flag boolean [note: 'Indicates whether this line item represents a product return. True for returned items, false for normal sales.']
  return_reason_code varchar [note: 'Standardized code indicating the reason for product return. Used for return analytics and quality management.']
  scanned_timestamp timestamp [note: 'Date and time when this item was scanned or entered at the point of sale. Used for transaction timing analysis and basket sequence.']
  serial_number varchar [note: 'Unique serial number for serialized products such as electronics and appliances. Used for warranty tracking and theft prevention.']
  sku varchar [note: 'Internal stock keeping unit identifier for the product sold. Used for inventory tracking and assortment management.']
  tax_amount decimal(12,2) [note: 'Total sales tax charged for this line item. Calculated by applying the tax rate to the net line amount.']
  tax_code varchar [note: 'Tax jurisdiction and category code for this line item. Determines applicable sales tax rate based on product category and location.']
  tax_rate decimal(5,4) [note: 'Sales tax rate applied to this line item expressed as a decimal. Example: 0.0825 represents 8.25 percent sales tax.']
  total_line_amount decimal(12,2) [note: 'Final total amount for this line item including tax. Sum of net line amount and tax amount.']
  unit_retail_price decimal(12,4) [note: 'Regular retail price per unit before any discounts or promotions. Represents the shelf price or list price of the item.']
  upc varchar [note: '12-digit Universal Product Code scanned at point of sale. Standard barcode identifier for North American retail products.']
  void_reason_code varchar [note: 'Standardized code indicating the reason for voiding this line item. Used for shrinkage analysis and operational improvement.']
  voided_flag boolean [note: 'Indicates whether this line item was voided or cancelled during the transaction. True for voided items, false for completed sales.']
  weight_actual decimal(10,3) [note: 'Actual weight of variable-weight items measured at point of sale. Captured for produce, deli, meat, and bakery items sold by weight.']
  weight_unit varchar [note: 'Unit of measure for the actual weight. Indicates whether weight is measured in pounds, kilograms, ounces, or grams.']

  Note: 'Individual line-item detail within a POS transaction. Captures SKU, UPC, EAN, GTIN, item description, quantity sold, unit retail price, extended price, markdown amount, promotion code applied, tax code, tax amount, return reason (if applicable), serial number (for electronics), and weight (for variable-weight items). Supports basket analysis and sell-through rate calculations.'
}

Table order.payment {
  payment_id varchar [pk, note: 'Unique identifier for the payment tender record. Primary key.']
  gift_card_id varchar [note: 'Masked or tokenized gift card number used for this payment tender. Applicable only when payment method type is gift card.']
  header_id varchar [note: 'Reference to the order or POS (Point of Sale) transaction to which this payment tender is applied. Links payment to the originating order header.']
  payment_method_id decimal(18,2) [note: 'Foreign key linking to customer.payment_method. Business justification: Payment reconciliation, chargeback management, and tokenized card lifecycle tracking require linking captured order payments to the customer\'s stored payment method. Enables \'all orders charged to thi']
  pos_transaction_id varchar [note: 'Foreign key linking to order.pos_transaction. Business justification: A payment tender record in a retail POS environment is directly associated with a specific POS transaction. While payment.header_id links to the order header, POS transactions are the immediate transa']
  shipment_id varchar [note: 'Foreign key linking to fulfillment.shipment. Business justification: Ship-and-capture payment model: retail payments are authorized at order placement and captured on shipment. Linking payment to shipment enables automated capture triggers, financial reconciliation of ']
  amount decimal(18,4) [note: 'Monetary amount applied by this payment tender toward the order total. In split-tender scenarios, multiple payment records sum to the order total.']
  authorization_code varchar [note: 'Authorization code returned by the payment processor or issuing bank confirming approval of the payment transaction. Used for reconciliation and dispute resolution.']
  authorization_timestamp timestamp [note: 'Date and time when the payment was authorized by the payment processor or issuing bank. Represents the principal business event timestamp for this payment tender.']
  avs_result_code varchar [note: 'Result code returned by Address Verification Service (AVS) indicating match status of billing address and postal code. Used for fraud prevention and risk assessment.']
  billing_address_line1 varchar [note: 'First line of the billing address associated with the payment method. Used for AVS (Address Verification Service) and fraud prevention.']
  billing_address_line2 varchar [note: 'Second line of the billing address (apartment, suite, unit number). Optional field for AVS (Address Verification Service).']
  billing_city varchar [note: 'City of the billing address associated with the payment method. Used for AVS (Address Verification Service) and fraud prevention.']
  billing_country_code varchar [note: 'Three-letter ISO 3166-1 alpha-3 country code of the billing address (e.g., USA, CAN, GBR). Used for AVS (Address Verification Service) and international payment processing.']
  billing_postal_code varchar [note: 'Postal or ZIP code of the billing address. Critical for AVS (Address Verification Service) validation and fraud prevention.']
  billing_state_province varchar [note: 'State or province of the billing address. Used for AVS (Address Verification Service) and tax calculation.']
  bnpl_provider varchar [note: 'Free text; common values include klarna, affirm, afterpay, sezzle, etc.']
  capture_timestamp timestamp [note: 'Date and time when the authorized payment was captured (funds marked for settlement). Typically occurs at order fulfillment or shipment.']
  card_brand varchar [note: 'Free text; common values include visa, mastercard, amex, discover, jcb, unionpay, maestro, diners, rupay, regional/store cards']
  card_expiry_month varchar [note: 'Expiration month of the payment card (1-12). Used for validation and recurring payment processing. Stored securely per PCI DSS requirements.']
  card_expiry_year varchar [note: 'Expiration year of the payment card (four-digit format, e.g., 2025). Used for validation and recurring payment processing. Stored securely per PCI DSS requirements.']
  cardholder_name varchar [note: 'Name of the cardholder as it appears on the payment card. Used for verification and fraud prevention. Stored securely per PCI DSS and GDPR requirements.']
  channel varchar [note: 'Channel or interface through which the payment was initiated. Distinguishes web, mobile app, in-store POS (Point of Sale), call center, kiosk, or third-party platform.']
  created_timestamp timestamp [note: 'Date and time when this payment tender record was first created in the system. Used for audit trail and data lineage.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the payment amount (e.g., USD, EUR, GBP, CAD). Supports multi-currency transactions.']
  cvv_result_code varchar [note: 'Result code indicating whether the Card Verification Value (CVV/CVV2/CVC) provided by the cardholder matched the issuer\'s records. Used for fraud prevention.']
  digital_wallet_type varchar [note: 'Free text; common values include apple_pay, google_pay, paypal, samsung_pay, etc.']
  fraud_decision varchar [note: 'Decision outcome from fraud detection system. Indicates whether the payment was approved, declined, flagged for manual review, or challenged with additional authentication.']
  fraud_score decimal(5,2) [note: 'Numerical fraud risk score assigned by fraud detection system, typically ranging from 0 (low risk) to 100 (high risk). Used for payment approval decisions and risk management.']
  loyalty_points_redeemed varchar [note: 'Number of loyalty program points redeemed as payment for this tender. Applicable only when payment method type is loyalty points.']
  masked_pan varchar [note: 'Masked or truncated version of the payment card Primary Account Number (PAN), typically showing only the last four digits (e.g., ****1234). Used for display and customer service without exposing full card number.']
  method_type varchar [note: 'Type of payment instrument used for this tender. Includes credit card, debit card, gift card, loyalty points, BNPL (Buy Now Pay Later), cash, digital wallet (e.g., Apple Pay, Google Pay), or check. [ENUM-REF-CANDIDATE: credit_card|debit_card|gift_card|loyalty_points|bnpl|cash|digital_wallet|check — 8 candidates stripped; promote to reference product]']
  payment_status varchar [note: 'Current lifecycle status of the payment tender. Tracks progression from authorization through settlement, including declined, voided, or refunded states.']
  processor_reference_code varchar [note: 'Unique transaction identifier assigned by the payment gateway or processor. Used for tracing and reconciliation with external payment systems.']
  refund_amount decimal(18,4) [note: 'Monetary amount refunded to the customer for this payment tender. May be partial or full refund of the original payment amount.']
  refund_timestamp timestamp [note: 'Date and time when a refund was processed for this payment tender. Applicable for returns and RMA (Return Merchandise Authorization) scenarios.']
  settlement_timestamp timestamp [note: 'Date and time when the payment was settled and funds were transferred from the customer\'s account to the merchant\'s account. Final step in payment lifecycle.']
  tender_sequence varchar [note: 'Sequence number indicating the order in which this payment tender was applied in a split-tender scenario. First tender is 1, second is 2, etc.']
  three_ds_authentication_result varchar [note: 'Result of 3-D Secure (3DS) authentication protocol for card-not-present transactions. Indicates whether cardholder was successfully authenticated, reducing fraud liability.']
  three_ds_version varchar [note: 'Version of the 3-D Secure protocol used for authentication (e.g., 1.0.2, 2.1.0, 2.2.0). Newer versions provide enhanced security and user experience.']
  token varchar [note: 'Tokenized reference to the payment instrument, replacing sensitive card data. Token is generated by PCI DSS compliant tokenization service and used for recurring payments or stored payment methods.']
  updated_timestamp timestamp [note: 'Date and time when this payment tender record was last modified. Used for audit trail and change tracking.']
  void_timestamp timestamp [note: 'Date and time when the payment authorization was voided (cancelled before capture). Applicable when order is cancelled before fulfillment.']

  Note: 'Payment tender record capturing each payment instrument applied to an order or POS transaction. Stores payment method type (credit card, debit, gift card, loyalty points, BNPL, cash, digital wallet), masked PAN/token, payment processor reference, authorization code, settlement status (authorized, captured, settled, declined, voided), payment amount, currency, tender sequence for split-tender scenarios, PCI DSS tokenization reference, fraud score, and 3DS authentication result. Supports split-tender where multiple payment methods cover a single order total. Integrates with PCI SSC compliance requirements and payment gateway APIs.'
}

Table order.discount {
  discount_id varchar [pk, note: 'Primary key for discount']
  coupon_id varchar [note: 'Foreign key linking to promotion.coupon. Business justification: discount.discount_code is a denormalized coupon reference when the discount is coupon-driven. A FK to promotion.coupon enables coupon-driven discount reconciliation, single-use coupon validation, and ']
  header_id varchar [note: 'Reference to the order to which this discount is applied. Links to the order header.']
  location_id varchar [note: 'Reference to the physical store location where the discount was applied. Null for online or non-store channels.']
  markdown_id varchar [note: 'Foreign key linking to pricing.markdown. Business justification: Discounts applied at order or POS level may originate from a markdown event. Linking discount to the source markdown enables markdown sell-through tracking and markdown effectiveness reporting — core ']
  order_line_id varchar [note: 'Reference to the specific order line item to which this discount is applied. Null if discount is applied at order header level.']
  pos_terminal_id varchar [note: 'The identifier of the Point of Sale (POS) terminal or register where the discount was applied. Null for online channels.']
  pos_transaction_id varchar [note: 'Foreign key linking to order.pos_transaction. Business justification: Discounts applied during POS transactions need a direct link to the POS transaction record. The discount table already has header_id (for order-level context) and order_line_id (for e-commerce line-le']
  promo_campaign_id varchar [note: 'Reference to the marketing or promotional campaign that generated this discount. Links to the promotion campaign master data for attribution and performance analysis.']
  promo_offer_id varchar [note: 'Foreign key linking to promotion.promo_offer. Business justification: discount already links to promo_campaign but not the specific promo_offer that drove it. Offer-level discount attribution is required for vendor chargeback calculations, promotional P&L reporting, and']
  promotion_banner_id varchar [note: 'Foreign key linking to ecommerce.promotion_banner. Business justification: Marketing ROI reporting: retailers attribute applied discounts to the specific promotion banner that drove the conversion. Required for banner click-to-discount conversion analysis, campaign spend jus']
  rebate_id varchar [note: 'Foreign key linking to promotion.rebate. Business justification: Rebate programs generate discount records at point of sale or post-purchase. Linking discount to rebate enables rebate accrual reconciliation against actual discounts applied, vendor rebate settlement']
  rule_id varchar [note: 'Foreign key linking to pricing.rule. Business justification: Discounts applied to orders are generated by pricing rules. Linking discount to the triggering pricing rule enables rule effectiveness reporting, audit of rule-driven discounts, and compliance validat']
  vendor_allowance_id varchar [note: 'Foreign key linking to supplier.vendor_allowance. Business justification: Vendor-funded discount accrual reconciliation: retail finance tracks which vendor allowance authorized each applied discount for co-op billing and accrual accounting. Linking discount records to the a']
  amount decimal(18,2) [note: 'The monetary value of the discount applied, in the order currency. Represents the total reduction in price due to this discount.']
  applied_at_level varchar [note: 'Indicates whether the discount was applied at the order header level (affecting the entire order) or at the line item level (affecting a specific product).']
  applied_timestamp timestamp [note: 'The date and time when the discount was applied to the order or line item. Represents the business event time of discount application.']
  approval_status varchar [note: 'The approval status of the discount application. Indicates whether the discount was automatically applied, requires manager approval, has been approved, or was rejected.']
  approval_timestamp timestamp [note: 'The date and time when the discount was approved. Null if auto-applied or pending approval.']
  channel varchar [note: 'The sales channel through which the discount was applied. Indicates whether the discount was applied via online e-commerce, in-store Point of Sale (POS), mobile app, call center, or kiosk.']
  created_timestamp timestamp [note: 'The date and time when this discount record was first created in the data platform. Audit field for data lineage and record lifecycle tracking.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the discount amount. Typically matches the order currency.']
  discount_type varchar [note: 'Classification of the discount mechanism. Indicates the nature of the discount applied (e.g., coupon, promotional code, loyalty reward, markdown, Buy One Get One (BOGO), clearance, employee discount, volume discount, seasonal promotion, bundle discount, price override, manager override). [ENUM-REF-CANDIDATE: coupon|promo_code|loyalty_reward|markdown|bogo|clearance|employee_discount|volume_discount|seasonal_promotion|bundle_discount|price_override|manager_override — 12 candidates stripped; promote to reference product]']
  final_price decimal(18,2) [note: 'The final price after the discount has been applied. Represents the net amount the customer pays for the discounted item or order.']
  generic_monetary_dummy decimal(18,2) [note: 'Placeholder monetary attribute added by mutator to ensure change.']
  loyalty_points_redeemed varchar [note: 'The number of loyalty program points redeemed to obtain this discount. Null if discount is not loyalty-based.']
  method varchar [note: 'The calculation method used to determine the discount value. Indicates whether the discount is a percentage off, fixed dollar amount, tiered based on quantity or spend, Buy One Get One (BOGO) offer, or free shipping.']
  original_price decimal(18,2) [note: 'The original price of the item or order before the discount was applied. Used to calculate discount impact and markdown analysis.']
  percentage decimal(5,2) [note: 'The percentage discount applied to the order or line item. Populated when discount_method is percentage. Expressed as a decimal (e.g., 15.00 for 15% off).']
  priority_rank varchar [note: 'The priority order in which this discount is applied when multiple discounts are present. Lower numbers indicate higher priority. Used to determine discount application sequence.']
  reason_code varchar [note: 'A code indicating the business reason for the discount. Examples include customer complaint resolution, price match, damaged goods, loyalty reward, seasonal clearance, or promotional campaign.']
  reason_description varchar [note: 'Free-text description providing additional context or justification for the discount application. Used for audit trail and customer service reference.']
  source_system_discount_code varchar [note: 'The unique identifier for this discount record in the source system. Used for traceability and reconciliation with upstream systems.']
  stackable_flag boolean [note: 'Indicates whether this discount can be combined (stacked) with other discounts on the same order or line item. True if stackable, False if exclusive.']
  tax_treatment_flag boolean [note: 'Indicates whether the discount is applied before tax calculation (pre-tax) or after tax calculation (post-tax). Affects the taxable amount and final tax computation.']
  taxable_amount_adjustment decimal(18,2) [note: 'The adjustment to the taxable base amount resulting from this discount. Used to recalculate sales tax when discount affects the tax basis.']
  updated_timestamp timestamp [note: 'The date and time when this discount record was last modified in the data platform. Audit field for change tracking and data quality monitoring.']
  valid_from_date date [note: 'The start date from which the discount code or promotion is valid. Used to enforce discount eligibility windows.']
  valid_to_date date [note: 'The end date until which the discount code or promotion is valid. Used to enforce discount eligibility windows. Null for open-ended discounts.']

  Note: 'Discount and promotion application record at the order header or line level. Captures discount type (coupon, promo code, loyalty reward, markdown, BOGO, clearance, employee discount), discount code, discount amount or percentage, promotion campaign reference, stackability flag, applied-at level (header vs line), and approval status. Enables promotion attribution, markdown tracking, sell-through analysis, and P&L impact per order. Tax calculation attributes (taxable amount adjustment) included where discount affects tax basis.'
}

Table order.cancellation {
  cancellation_id varchar [pk, note: 'Unique identifier for the cancellation event. Primary key for the cancellation record.']
  header_id varchar [note: 'Reference to the parent order that was cancelled. Links this cancellation to the originating order header.']
  order_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_order. Business justification: Order cancellation workflow: cancellations must directly reference the fulfillment order to trigger WMS cancellation signals, halt pick/pack tasks, and track fulfillment cancellation costs. Retail OMS']
  order_line_id varchar [note: 'Reference to the specific order line item that was cancelled. Null if the entire order was cancelled rather than individual lines.']
  pos_transaction_id varchar [note: 'Foreign key linking to order.pos_transaction. Business justification: In-store cancellations and returns are initiated at the POS terminal and are directly tied to a specific POS transaction. The cancellation table has header_id and order_line_id for e-commerce cancella']
  profile_id varchar [note: 'Reference to the customer associated with the cancelled order. Links cancellation to the customer master record for analytics and customer service.']
  approval_required_flag boolean [note: 'Indicates whether the cancellation requires managerial or supervisory approval before execution. True for high-value orders or policy exceptions.']
  approval_timestamp timestamp [note: 'Date and time when the cancellation was approved by an authorized agent or manager. Null if no approval required or not yet approved.']
  cancellation_number varchar [note: 'Business-facing unique cancellation reference number used for customer communication and tracking. Format: CXL-XXXXXXXXXX.']
  cancellation_status varchar [note: 'Current processing status of the cancellation request. Tracks the cancellation through its approval and execution workflow.']
  cancellation_timestamp timestamp [note: 'Date and time when the cancellation was initiated or requested. Represents the business event time of the cancellation action.']
  cancelled_amount decimal(18,2) [note: 'Total order or line value that was cancelled, including product cost, taxes, and fees. Represents the gross cancelled transaction value.']
  cancelled_quantity decimal(10,3) [note: 'Quantity of the product or item that was cancelled. Relevant for line-level cancellations. Measured in the unit of measure of the ordered item.']
  channel varchar [note: 'Channel or interface through which the cancellation was submitted. Tracks omnichannel cancellation touchpoints. [ENUM-REF-CANDIDATE: web|mobile_app|call_center|store|email|chat|system_automated — 7 candidates stripped; promote to reference product]']
  created_timestamp timestamp [note: 'Date and time when this cancellation record was first created in the system. Audit field for data lineage and record lifecycle tracking.']
  customer_notification_sent_flag boolean [note: 'Indicates whether a cancellation confirmation notification was sent to the customer via email, SMS, or app notification. True if notification sent.']
  customer_notification_timestamp timestamp [note: 'Date and time when the cancellation confirmation notification was sent to the customer. Null if notification not sent or failed.']
  fee_amount decimal(18,2) [note: 'Administrative or processing fee charged for the cancellation. Zero if no cancellation fee applies per business policy or customer segment.']
  fraud_flag boolean [note: 'Indicates whether the cancellation was triggered by fraud detection rules or suspected fraudulent activity. True if fraud-related cancellation.']
  fraud_score decimal(5,2) [note: 'Fraud risk score assigned by the fraud detection system at the time of cancellation. Higher scores indicate higher fraud risk. Null if not fraud-related.']
  initiator_type varchar [note: 'Category of entity that initiated the cancellation. Distinguishes between customer-initiated, system-initiated, agent-initiated, and automated rule-based cancellations.']
  inventory_release_timestamp timestamp [note: 'Date and time when allocated inventory was released back to available stock following the cancellation. Null if inventory was never allocated or not yet released.']
  inventory_released_flag boolean [note: 'Indicates whether inventory allocated to the cancelled order or line has been released back to available stock. True if inventory release confirmed.']
  processing_system_code varchar [note: 'Identifier of the system or automated process that executed the cancellation. Used for system-initiated cancellations to track which rule engine or service triggered the action.']
  reason_code varchar [note: 'Standardized code representing the reason for cancellation. [ENUM-REF-CANDIDATE: customer_request|out_of_stock|pricing_error|duplicate_order|payment_declined|fraud_suspected|delivery_delay|product_unavailable|customer_changed_mind|incorrect_item_ordered|found_better_price|shipping_cost_too_high|delivery_time_too_long|order_placed_by_mistake|item_no_longer_needed|quality_concerns|other — promote to reference product]']
  reason_description varchar [note: 'Free-text description or additional details provided by the initiator explaining the reason for cancellation. Captures customer comments or agent notes.']
  refund_amount decimal(18,2) [note: 'Total monetary amount to be refunded to the customer for this cancellation. Includes product cost, taxes, and fees as applicable.']
  refund_currency_code varchar [note: 'Three-letter ISO 4217 currency code for the refund amount. Indicates the currency in which the refund will be processed.']
  refund_eligible_flag boolean [note: 'Indicates whether the cancelled order or line is eligible for a refund based on payment status and business rules. True if refund should be processed.']
  refund_method varchar [note: 'Method by which the refund will be issued to the customer. Typically matches the original payment method but may differ based on business rules.']
  refund_processed_timestamp timestamp [note: 'Date and time when the refund was successfully processed and submitted to the payment gateway or finance system. Null if refund not yet processed.']
  restocking_fee_amount decimal(18,2) [note: 'Fee charged to the customer for cancelling the order after certain fulfillment stages. Zero if no restocking fee applies per business policy.']
  reversal_flag boolean [note: 'Indicates whether this cancellation was subsequently reversed and the order reinstated. True if the cancellation was undone.']
  reversal_reason varchar [note: 'Free-text explanation of why the cancellation was reversed. Captures business justification for reinstating the order.']
  reversal_timestamp timestamp [note: 'Date and time when the cancellation was reversed and the order reinstated. Null if no reversal occurred.']
  stage varchar [note: 'Order fulfillment stage at which the cancellation occurred. Indicates how far the order progressed before cancellation and impacts inventory release and refund processing.']
  updated_timestamp timestamp [note: 'Date and time when this cancellation record was last modified. Audit field for tracking changes to cancellation status, refund processing, or other attributes.']

  Note: 'Order or line-level cancellation event record capturing the full context of why and when an order or individual line was cancelled before shipment. Captures cancellation number, order/line reference, cancellation initiator (customer-initiated via web/app/call-center, system-initiated via OMS rules, fraud-hold auto-cancel, inventory allocation failure), cancellation reason code, cancellation timestamp, cancellation stage (pre-allocation, post-allocation-pre-pick, post-pick-pre-ship), refund eligibility flag, inventory release confirmation, and processing agent/system ID. Distinct from RMA which covers post-shipment returns.'
}

Table order.promise {
  promise_id varchar [pk, note: 'Unique identifier for the order promise record. Primary key.']
  carrier_id varchar [note: 'Foreign key linking to fulfillment.carrier. Business justification: Promise calculation engine uses carrier-specific transit times as primary input. Business needs carrier_id to trace which carrier\'s SLA drove the customer promise for promise accuracy analysis, carrie']
  carrier_service_id varchar [note: 'Foreign key linking to fulfillment.carrier_service. Business justification: Promise dates calculated from carrier service level transit times (2-day vs. overnight). Business requires carrier_service_id to validate promise accuracy against service-level SLAs, analyze promise v']
  fulfillment_node_id varchar [note: 'Identifier of the fulfillment node (DC, store, dark store) from which the order will be shipped.']
  header_id varchar [note: 'Reference to the order header for which this delivery promise was made.']
  inbound_shipment_id varchar [note: 'Foreign key linking to supplychain.inbound_shipment. Business justification: Available-to-Promise (ATP) calculation: delivery promises depend on inbound shipment arrival dates to determine when stock will be available. Retail ATP engines link promises to inbound shipments to c']
  order_line_id varchar [note: 'Reference to the specific order line if the promise is line-level; null if promise is order-level.']
  revised_promise_id varchar [note: 'Self-referencing FK on promise (revised_promise_id)']
  shipping_address_id varchar [note: 'Foreign key linking to customer.address. Business justification: Delivery promise accuracy analysis by address/region requires linking promise records to the customer address used for SLA calculation. Eliminates denormalized postal_code and country_code columns. En']
  store_location_id varchar [note: 'Foreign key linking to store.location. Business justification: BOPIS/ROPIS promise management requires associating each delivery promise with the specific store location where pickup is promised. Store-level SLA breach reporting and omnichannel promise accuracy K']
  accuracy_flag boolean [note: 'Indicates whether the delivery was completed within the promised window (true = on-time, false = missed).']
  actual_delivery_timestamp timestamp [note: 'Actual timestamp when the order was delivered to the customer, used for promise accuracy measurement.']
  calculation_engine_version varchar [note: 'Version identifier of the promise calculation engine or algorithm used.']
  calculation_source varchar [note: 'System or method used to calculate the delivery promise (carrier API, static SLA table, DOM engine, manual override).']
  carrier_service_level varchar [note: 'Specific service level offered by the carrier (e.g., Ground, Express, Priority).']
  confidence_score decimal(5,2) [note: 'Confidence score (0-100) indicating the likelihood of meeting the delivery promise based on historical performance.']
  created_timestamp timestamp [note: 'Timestamp when the delivery promise was initially created and communicated to the customer.']
  customer_notification_channel varchar [note: 'Channel through which the customer was notified of the delivery promise.']
  customer_notification_sent_flag boolean [note: 'Indicates whether the customer was notified of the delivery promise or any revisions.']
  customer_notification_timestamp timestamp [note: 'Timestamp when the customer was notified of the delivery promise or revision.']
  cutoff_time_applied varchar [note: 'Order cutoff time applied for same-day or next-day promise calculation (e.g., 2:00 PM local time).']
  fulfillment_method varchar [note: 'Method by which the order will be fulfilled (ship-to-home, BOPIS, ROPIS, ship-from-store, curbside pickup).']
  inventory_availability_timestamp timestamp [note: 'Timestamp when inventory availability was confirmed for promise calculation.']
  last_modified_timestamp timestamp [note: 'Timestamp when this promise record was last updated in the data platform.']
  last_revision_timestamp timestamp [note: 'Timestamp of the most recent revision to the delivery promise.']
  order_channel varchar [note: 'Channel through which the order was placed, influencing promise calculation logic.']
  peak_season_flag boolean [note: 'Indicates whether the promise was made during a peak season (e.g., holiday shopping period) affecting delivery times.']
  promise_number varchar [note: 'Business-readable identifier for the delivery promise, used for customer communication and tracking.']
  promise_status varchar [note: 'Current lifecycle status of the delivery promise.']
  promise_type varchar [note: 'Type of delivery promise made to the customer at checkout or order confirmation.']
  promised_delivery_date_end date [note: 'End date of the promised delivery window communicated to the customer.']
  promised_delivery_date_start date [note: 'Start date of the promised delivery window communicated to the customer.']
  promised_delivery_time_end timestamp [note: 'Precise end timestamp of the promised delivery window for time-specific promises.']
  promised_delivery_time_start timestamp [note: 'Precise start timestamp of the promised delivery window for time-specific promises.']
  revision_count varchar [note: 'Number of times the delivery promise has been revised after initial creation.']
  revision_reason_code varchar [note: 'Code indicating the reason for promise revision (e.g., inventory delay, carrier delay, weather).']
  revision_reason_description varchar [note: 'Detailed description of why the delivery promise was revised.']
  sla_breach_flag boolean [note: 'Indicates whether the delivery promise was breached (actual delivery exceeded promised window).']
  sla_target_hours varchar [note: 'Target number of hours from order placement to delivery as defined by the SLA.']
  variance_hours decimal(10,2) [note: 'Difference in hours between actual delivery and promised delivery (positive = late, negative = early).']
  weather_impact_flag boolean [note: 'Indicates whether weather conditions were factored into the promise calculation or caused a delay.']

  Note: 'Delivery commitment made to the customer at checkout or order confirmation. Captures promise type (standard, expedited, same-day, next-day), promised delivery window (start/end), calculation source (carrier API, static SLA table, DOM engine), revision history when promises are updated, actual vs promised variance, and SLA breach flag. Enables promise accuracy KPI tracking, customer experience measurement, and carrier performance evaluation.'
}

Table order.gift_card {
  gift_card_id varchar [pk, note: 'Unique identifier for the gift card record. Primary key.']
  header_id varchar [note: 'Identifier of the order transaction in which this gift card was purchased. Links gift card to originating sales transaction. Nullable for cards issued outside normal order flow (e.g., corporate bulk issuance).']
  location_id varchar [note: 'Identifier of the physical store location where the gift card was issued or sold. Nullable for non-store channels.']
  primary_gift_profile_id varchar [note: 'Identifier of the customer who purchased the gift card. May differ from the recipient. Nullable if purchased anonymously or by guest.']
  promo_campaign_id varchar [note: 'Identifier of the promotional campaign associated with this gift card issuance (e.g., holiday bonus card, purchase-with-purchase offer). Nullable for non-promotional cards.']
  replacement_for_gift_card_id varchar [note: 'Self-referencing FK on gift_card (replacement_for_gift_card_id)']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Physical and digital gift cards are sold as SKUs with UPCs, shelf placement, and inventory tracking. Linking gift_card to the product SKU enables gift card sales reporting by product, inventory deplet']
  storefront_id varchar [note: 'Foreign key linking to ecommerce.storefront. Business justification: Gift cards sold or redeemed through digital channels require storefront attribution for revenue recognition, liability tracking by channel, and fraud prevention. Retailers must track which digital sto']
  activation_date date [note: 'Date when the gift card was activated and became available for redemption. May differ from issue date if activation is delayed (e.g., physical cards activated at first use).']
  barcode varchar [note: 'Barcode value encoded on physical gift cards for scanning at Point of Sale (POS). May be UPC (Universal Product Code), EAN (European Article Number), or proprietary format.']
  card_number varchar [note: 'Unique card number printed or encoded on the gift card. Typically 16-19 digits. Used for identification and redemption at Point of Sale (POS) or e-commerce checkout.']
  card_status varchar [note: 'Current lifecycle status of the gift card. Inactive: issued but not yet activated; Active: available for use; Suspended: temporarily blocked; Expired: past validity period; Depleted: balance fully redeemed; Cancelled: voided or returned.']
  card_type varchar [note: 'Type of gift card instrument. Physical cards are tangible plastic cards; digital/virtual cards are delivered electronically via email or app; mobile wallet cards are provisioned into digital wallets (Apple Pay, Google Pay).']
  created_timestamp timestamp [note: 'Timestamp when this gift card record was first created in the system. Audit trail for data lineage and compliance.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code representing the denomination of the gift card balance (e.g., USD, EUR, GBP, CAD).']
  current_balance decimal(15,2) [note: 'Remaining monetary value available on the gift card after all redemptions, adjustments, and fees. Updated in real-time with each transaction.']
  escheatment_date date [note: 'Date when the gift card balance was escheated (transferred) to state unclaimed property authority. Nullable if not yet escheated.']
  escheatment_eligible_flag boolean [note: 'Indicates whether the gift card balance is eligible for escheatment (transfer to state unclaimed property) based on dormancy period and state regulations. True: eligible; False: not eligible.']
  expiry_date date [note: 'Date when the gift card expires and can no longer be redeemed. Nullable for cards with no expiration. Subject to regulatory requirements (e.g., CARD Act in USA mandates minimum 5-year validity).']
  fraud_flag boolean [note: 'Indicates whether this gift card has been flagged for suspected fraudulent activity (e.g., unauthorized use, balance tampering, stolen card). True: fraud suspected; False: no fraud detected.']
  fraud_reason_code varchar [note: 'Code indicating the reason for fraud flag (e.g., STOLEN, COUNTERFEIT, BALANCE_TAMPERING, SUSPICIOUS_ACTIVITY). Nullable if fraud_flag is false.']
  initial_balance decimal(15,2) [note: 'Original monetary value loaded onto the gift card at the time of issuance or purchase. Represents the starting balance before any redemptions or adjustments.']
  issue_date date [note: 'Date when the gift card was originally issued or sold to the customer. Marks the beginning of the card lifecycle.']
  issuing_channel varchar [note: 'Sales channel through which the gift card was originally issued or purchased. Store: in-store POS; Ecommerce: online storefront; Mobile App: mobile commerce; Call Center: phone order; Corporate Sales: bulk B2B sales; Third Party: external marketplace or partner.']
  last_modified_timestamp timestamp [note: 'Timestamp when this gift card record was last updated. Tracks data currency and supports change data capture (CDC) processes.']
  last_transaction_date date [note: 'Date of the most recent transaction (redemption, reload, or adjustment) on this gift card. Used for dormancy tracking and escheatment compliance.']
  pin_code varchar [note: 'Personal Identification Number (PIN) required for online redemption or balance inquiry. Typically 4-8 digits. Stored encrypted in production systems.']
  program_code varchar [note: 'Code identifying the gift card program or product line (e.g., standard gift card, promotional card, employee reward card, corporate incentive card). Used for segmentation and reporting.']
  qr_code varchar [note: 'Quick Response (QR) code data for mobile wallet provisioning or contactless redemption. Encoded with card number and validation data.']
  recipient_email varchar [note: 'Email address of the gift card recipient. Used for digital card delivery and balance notifications. Required for digital/virtual cards.']
  recipient_phone varchar [note: 'Phone number of the gift card recipient. Used for SMS delivery of digital cards and balance inquiries.']
  redemption_count varchar [note: 'Total number of redemption transactions (purchases) made using this gift card since activation.']
  reload_count varchar [note: 'Total number of times the gift card has been reloaded with additional funds since issuance. Zero for non-reloadable or never-reloaded cards.']
  reloadable_flag boolean [note: 'Indicates whether the gift card can be reloaded with additional funds after initial issuance. True: reloadable; False: single-load only.']
  terms_and_conditions_version varchar [note: 'Version identifier of the terms and conditions that govern this gift card (e.g., expiration policy, fee schedule, usage restrictions). Used for compliance and customer service.']
  total_fees_charged decimal(15,2) [note: 'Cumulative fees deducted from the gift card balance (e.g., dormancy fees, maintenance fees, replacement fees). Subject to regulatory restrictions (e.g., CARD Act limits dormancy fees).']
  total_redeemed_amount decimal(15,2) [note: 'Cumulative monetary value redeemed from the gift card across all transactions since activation. Equals initial_balance + total_reloaded_amount - current_balance - total_fees.']
  total_reloaded_amount decimal(15,2) [note: 'Cumulative monetary value added to the gift card through all reload transactions since issuance. Excludes initial balance.']

  Note: 'Master record for gift cards and stored-value instruments sold and redeemed across all channels. Captures card number, card type (physical, digital), initial balance, current balance, activation date, expiry date, and issuing channel.'
}

Table order.gift_card_transaction {
  gift_card_transaction_id varchar [pk, note: 'Unique identifier for the gift card transaction record.']
  gift_card_id varchar [note: 'Unique identifier of the gift card involved in this transaction. May be masked for security.']
  header_id varchar [note: 'Reference to the online order if this gift card activity was part of an e-commerce transaction.']
  location_id varchar [note: 'Identifier of the physical store where the transaction occurred. Null for online channels.']
  payment_id varchar [note: 'Foreign key linking to order.payment. Business justification: When a gift card is redeemed as a payment instrument, both a payment record (capturing the tender) and a gift_card_transaction record (capturing the balance change) are created. These two records repr']
  pos_terminal_id varchar [note: 'Identifier of the POS terminal or kiosk where the transaction was processed.']
  pos_transaction_id varchar [note: 'Reference to the POS transaction if this gift card activity was part of a store purchase or return.']
  primary_gift_profile_id varchar [note: 'Identifier of the customer who performed the transaction. May be null for anonymous gift card purchases.']
  primary_original_transaction_gift_card_transaction_id varchar [note: 'Reference to the original gift card transaction that is being reversed or refunded.']
  storefront_id varchar [note: 'Foreign key linking to ecommerce.storefront. Business justification: Channel-level gift card liability and fraud monitoring: gift card activations, redemptions, and reloads on ecommerce storefronts must be attributed to the specific storefront for per-channel liability']
  activation_fee_amount decimal(10,2) [note: 'Fee charged to the customer for activating or loading the gift card, if applicable.']
  authorization_code varchar [note: 'Authorization or approval code returned by the gift card processor for this transaction.']
  balance_after decimal(15,2) [note: 'Gift card balance immediately after this transaction was applied.']
  balance_before decimal(15,2) [note: 'Gift card balance immediately before this transaction was applied.']
  business_date date [note: 'Fiscal business date on which the transaction is recorded for accounting and reporting purposes.']
  channel varchar [note: 'Channel through which the gift card transaction was initiated (POS, e-commerce, mobile app, call center, kiosk, third-party partner).']
  created_timestamp timestamp [note: 'Timestamp when this gift card transaction record was first created in the data platform.']
  currency_code varchar [note: 'Three-letter ISO currency code for the transaction amount (e.g., USD, CAD, EUR).']
  escheatment_flag boolean [note: 'Indicates whether this transaction represents an escheatment event where unclaimed gift card funds are transferred to state authorities.']
  escheatment_jurisdiction varchar [note: 'State or jurisdiction to which unclaimed gift card funds were escheated, if applicable.']
  expiration_date date [note: 'Date on which the gift card balance expires, if applicable. Null for non-expiring cards.']
  fraud_decision varchar [note: 'Fraud system decision for this transaction (approved, declined, manual review required, customer challenge required).']
  fraud_score decimal(5,2) [note: 'Risk score assigned by fraud detection system indicating likelihood of fraudulent activity (0-100 scale).']
  last_modified_timestamp timestamp [note: 'Timestamp when this gift card transaction record was last updated in the data platform.']
  notes varchar [note: 'Free-text notes or comments about the gift card transaction, typically entered by customer service or store associates.']
  payment_method_type varchar [note: 'Type of payment method used to fund the gift card load or activation (credit card, debit card, cash, bank transfer, digital wallet, loyalty points).']
  processor_reference_code varchar [note: 'Unique transaction identifier assigned by the third-party gift card processor or payment gateway.']
  reversal_flag boolean [note: 'Indicates whether this transaction is a reversal or void of a previous gift card transaction.']
  reversal_reason_code varchar [note: 'Code indicating the reason for reversing or voiding the gift card transaction (e.g., customer request, fraud, system error).']
  source_system_transaction_code varchar [note: 'Unique transaction identifier in the source operational system for traceability and reconciliation.']
  transaction_amount decimal(15,2) [note: 'Monetary value of the transaction. Positive for loads and activations, negative for redemptions.']
  transaction_number varchar [note: 'Business-facing unique transaction reference number for this gift card activity.']
  transaction_status varchar [note: 'Current processing status of the gift card transaction.']
  transaction_timestamp timestamp [note: 'Date and time when the gift card transaction occurred in the source system.']
  transaction_type varchar [note: 'Type of gift card transaction: activation (initial issuance), load (add funds), redemption (spend funds), balance inquiry (check balance), escheatment (unclaimed property transfer), or reversal (void/refund).']

  Note: 'Transactional record of gift card activations, loads, redemptions, balance inquiries, and escheatment events. Captures transaction type, amount, resulting balance, associated order/POS transaction, and channel.'
}

Table order.subscription {
  subscription_id varchar [pk, note: 'Unique identifier for the subscription record. Primary key for the subscription entity.']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: B2B/corporate account subscription management requires linking subscriptions to customer accounts for credit limit enforcement, account status checks, and account-level subscription spend reporting. s']
  carrier_id varchar [note: 'Foreign key linking to fulfillment.carrier. Business justification: Recurring subscription deliveries require consistent carrier assignment for customer experience and SLA management. Business tracks preferred carrier at subscription level for cost optimization and de']
  carrier_service_id varchar [note: 'Foreign key linking to fulfillment.carrier_service. Business justification: Subscription service level (ground vs. expedited) drives recurring delivery promises and cost structure. Business needs carrier_service_id to enforce consistent service tier across subscription lifecy']
  fulfillment_node_id varchar [note: 'Reference to the distribution center, store, or fulfillment location assigned to process subscription orders. Links to the fulfillment node master record.']
  payment_method_id decimal(18,2) [note: 'Reference to the stored payment method used for recurring subscription charges. Links to the customer payment method record.']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: Subscriptions lock in pricing terms at enrollment. Linking to price_list enables subscription pricing governance, renewal price determination, grandfathered rate tracking, and price change impact anal']
  profile_id varchar [note: 'Reference to the customer who owns this subscription. Links to the customer master record.']
  promo_offer_id varchar [note: 'Foreign key linking to promotion.promo_offer. Business justification: subscription.promotion_code is a denormalized promo offer reference. Subscriptions are frequently acquired via promotional offers (e.g., \'first 3 months free\'). A FK to promo_offer enables subscriptio']
  renewed_from_subscription_id varchar [note: 'Self-referencing FK on subscription (renewed_from_subscription_id)']
  replenishment_plan_id varchar [note: 'Foreign key linking to supplychain.replenishment_plan. Business justification: Subscription commerce (auto-replenishment programs for consumables, pet supplies, household goods) generates predictable demand patterns that drive dedicated replenishment plans. Retailers use this li']
  shipping_address_id varchar [note: 'Reference to the default delivery address for subscription orders. Links to the customer address record.']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Subscribe-and-save / auto-replenishment subscriptions are tied to a specific SKU. Without sku_id on subscription, subscription revenue by product, SKU discontinuation impact on active subscriptions, a']
  storefront_id varchar [note: 'Foreign key linking to ecommerce.storefront. Business justification: Subscriptions sold through digital channels require storefront attribution for revenue recognition, channel performance analysis, and fraud monitoring. Retail subscription businesses track which digit']
  amount decimal(15,2) [note: 'Base recurring charge amount for the subscription per billing cycle, excluding taxes, discounts, and shipping fees.']
  auto_renewal_flag boolean [note: 'Indicates whether the subscription automatically renews at the end of its term. True for auto-renewing subscriptions, false for subscriptions that require manual renewal.']
  billing_cycle varchar [note: 'Frequency at which the customer is charged for the subscription: per_delivery for charges with each order, monthly for monthly billing regardless of delivery frequency, quarterly for every 3 months, annual for yearly billing, or upfront for prepaid subscriptions.']
  cancellation_date date [note: 'Date when the subscription was cancelled by the customer or system. Null for active subscriptions.']
  cancellation_reason_code varchar [note: 'Standardized code indicating why the subscription was cancelled (e.g., CUST_REQUEST, PAYMENT_FAILURE, PRODUCT_UNAVAILABLE, FRAUD_DETECTED).']
  cancellation_reason_description varchar [note: 'Free-text explanation of the subscription cancellation reason, providing additional context beyond the standardized code.']
  carrier_service_level varchar [note: 'Shipping service tier for subscription deliveries: ground for economy shipping, express for expedited delivery, two_day for 2-day service, next_day for overnight, or standard for default carrier service.']
  channel varchar [note: 'Channel through which the subscription was originally created: web for website, mobile_app for mobile application, call_center for phone orders, in_store for retail location sign-ups, chatbot for automated chat enrollment, or voice_assistant for smart speaker subscriptions.']
  created_timestamp timestamp [note: 'Timestamp when this subscription record was first created in the system, capturing the initial enrollment date and time.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts in this subscription record.']
  delivery_frequency varchar [note: 'Cadence at which subscription orders are automatically generated and fulfilled: weekly for every 7 days, biweekly for every 14 days, monthly for every 30 days, quarterly for every 90 days, or custom for non-standard intervals.']
  delivery_frequency_days varchar [note: 'Numeric representation of the delivery interval in days. Used for custom frequencies and precise scheduling calculations.']
  discount_amount decimal(15,2) [note: 'Recurring discount applied to each subscription billing cycle, such as promotional discounts, loyalty rewards, or volume-based savings.']
  end_date date [note: 'Date when the subscription is scheduled to terminate. Null for open-ended subscriptions without a defined end date.']
  external_subscription_code varchar [note: 'Subscription identifier from the source system or external platform, used for cross-system reconciliation and integration.']
  gift_message varchar [note: 'Personalized message from the gift giver to the recipient, included with gift subscription deliveries.']
  gift_subscription_flag boolean [note: 'Indicates whether this subscription was purchased as a gift for another person. True for gift subscriptions, false for self-purchased subscriptions.']
  last_delivery_date date [note: 'Date when the most recent subscription order was delivered to the customer. Null if no deliveries have occurred yet.']
  last_modified_timestamp timestamp [note: 'Timestamp of the most recent update to this subscription record, tracking changes to subscription details, status, or preferences.']
  next_delivery_date date [note: 'Date when the next subscription order is scheduled to be fulfilled and shipped to the customer.']
  pause_end_date date [note: 'Date when a paused subscription is scheduled to resume. Null for indefinite pauses or active subscriptions.']
  pause_start_date date [note: 'Date when the subscription was paused. Null if the subscription has never been paused or is currently active.']
  skip_next_delivery_flag boolean [note: 'Indicates whether the customer has requested to skip the next scheduled delivery. True when the upcoming order should be skipped, false for normal delivery processing.']
  special_instructions varchar [note: 'Customer-provided delivery instructions, preferences, or notes for subscription fulfillment (e.g., gate codes, preferred delivery times, substitution preferences).']
  start_date date [note: 'Date when the subscription became active and the first delivery or service period began.']
  subscription_number varchar [note: 'Human-readable business identifier for the subscription, used in customer communications and service interactions.']
  subscription_status varchar [note: 'Current lifecycle state of the subscription: active for ongoing subscriptions, paused for temporarily suspended deliveries, cancelled for terminated subscriptions, expired for subscriptions past their end date, pending_activation for new subscriptions awaiting first order, or suspended for subscriptions on hold due to payment or compliance issues.']
  subscription_type varchar [note: 'Classification of the subscription model: subscribe-and-save for recurring product delivery, auto-replenishment for inventory-triggered orders, meal kit for prepared meal subscriptions, curated box for personalized selections, membership for access-based subscriptions, or service plan for ongoing service contracts.']
  total_deliveries_completed varchar [note: 'Cumulative count of subscription orders that have been successfully delivered to the customer since subscription inception.']
  total_deliveries_skipped varchar [note: 'Cumulative count of scheduled deliveries that were skipped at the customer\'s request or due to system holds.']

  Note: 'Master record for recurring subscription orders (subscribe-and-save, auto-replenishment, meal kit subscriptions). Captures subscription ID, customer, SKU list, delivery frequency, next delivery date, payment method, and subscription status.'
}

Table store.location {
  location_id varchar [pk, note: 'Unique identifier for the physical retail location. Primary key for the store_location data product. This is the system-of-record identifier used across all domains (inventory, order, workforce, finance) to reference this specific store, dark store, or micro-fulfillment center (MFC).']
  format_id varchar [note: 'Foreign key linking to store.store_format. Business justification: Every store location is classified by a store format (hypermarket, discount outlet, department store, etc.). The store_location record currently denormalizes format_type as a STRING. Adding FK to stor']
  price_zone_id varchar [note: 'Foreign key linking to pricing.price_zone. Business justification: Stores belong to price zones for regional pricing strategies. This is a fundamental retail concept - stores in the same geographic area or market segment share pricing rules. No visible redundant colu']
  region_id varchar [note: 'Foreign key linking to store.region. Business justification: location currently stores region_code as a denormalized STRING. Adding region_id FK to store.region.region_id normalizes this relationship — a store location belongs to exactly one geographic region. ']
  sales_territory_id varchar [note: 'Foreign key linking to store.sales_territory. Business justification: A store location belongs to exactly one sales territory for sales planning, rep assignment, and revenue targeting. The location table has district_code as a string but no FK to the sales_territory mas']
  accessibility_certified boolean [note: 'Indicates whether the store location is certified as fully accessible for customers with disabilities, meeting ADA (Americans with Disabilities Act) or equivalent local accessibility standards. True = certified accessible; False = not certified or non-compliant.']
  address_line1 varchar [note: 'Primary street address line for the store location (street number and name). Used for customer navigation, delivery routing, and regulatory filings. Organizational contact data classified as confidential.']
  address_line2 varchar [note: 'Secondary address line for the store location (suite, unit, building). Null if not applicable. Organizational contact data classified as confidential.']
  assortment_breadth_norm varchar [note: 'Standard assortment breadth (range of categories) for this store format. Narrow = limited category count (convenience); Moderate = balanced category mix; Broad = wide category range; Very Broad = full-line assortment (hypermarket). Used for merchandising strategy.']
  assortment_depth_norm varchar [note: 'Standard assortment depth (variety within a category) for this store format. Shallow = limited SKU count per category; Moderate = balanced SKU selection; Deep = extensive SKU variety; Very Deep = maximum SKU variety. Used for category management and space planning.']
  banner_brand varchar [note: 'The retail banner or brand under which this location operates (e.g., \'Retail Hypermarket\', \'Retail Discount\', \'Retail Express\'). Used for brand segmentation, assortment planning, and marketing strategy.']
  bopis_capable boolean [note: 'Indicates whether this store location supports BOPIS (Buy Online Pick Up In Store) fulfillment. True = BOPIS enabled with dedicated pickup area; False = BOPIS not available. Used for omnichannel order routing and customer service.']
  city varchar [note: 'City or municipality where the store location is situated. Used for geographic segmentation, market analysis, and regulatory compliance.']
  climate_zone varchar [note: 'Climate zone classification for the store location. Used for seasonal assortment planning, HVAC energy management, and merchandise mix optimization (e.g., winter apparel depth in continental zones).']
  closure_date date [note: 'The date this store location permanently ceased operations. Null for active stores. Used for historical analysis, lease termination tracking, and asset disposition planning.']
  country_code varchar [note: 'ISO 3166-1 alpha-3 country code where the store location is situated (e.g., USA, CAN, MEX). Used for regulatory compliance, currency determination, and international reporting.']
  created_timestamp timestamp [note: 'Timestamp when this store location record was first created in the system. Used for data lineage, audit trails, and record lifecycle tracking.']
  district_code varchar [note: 'Code identifying the retail district or region to which this store location belongs. Used for hierarchical reporting, district manager accountability, and regional performance analysis.']
  dsd_receiving boolean [note: 'Indicates whether this store location accepts Direct Store Delivery (DSD) from vendors, bypassing the distribution center (DC). True = DSD receiving enabled; False = all inventory flows through DC. Common for beverages, snacks, and bread.']
  email_address varchar [note: 'Primary email address for the store location. Used for operational communications, customer service escalations, and vendor coordination. Organizational contact data classified as confidential.']
  format_size_band varchar [note: 'Size classification band for the store format, used for assortment planning and operational benchmarking. Small = <20K sq ft; Medium = 20K-50K sq ft; Large = 50K-100K sq ft; Extra Large = >100K sq ft. Bands are format-specific.']
  last_remodel_date date [note: 'The date of the most recent major remodel or renovation of this store location. Used for capital expenditure tracking, store refresh planning, and performance analysis post-remodel.']
  latitude decimal(10,7) [note: 'Geographic latitude coordinate of the store location in decimal degrees. Used for geospatial analysis, delivery routing, trade area mapping, and proximity-based customer targeting.']
  legal_entity_name varchar [note: 'The legal entity name under which this store location operates. Used for regulatory filings, tax reporting, and legal compliance. May differ from the trading name.']
  lifecycle_status varchar [note: 'Current operational status of the store location in its lifecycle. Planned = approved but not yet built; Under Construction = site work in progress; Open = actively trading; Temporarily Closed = closed for short-term reasons (weather, emergency); Permanently Closed = ceased operations; Remodeling = closed for renovation.']
  locale varchar [note: 'Locale identifier for the store location in format \'language_COUNTRY\' (e.g., \'en_US\', \'es_MX\', \'fr_CA\'). Used for localized pricing, signage, customer communications, and regulatory compliance.']
  longitude decimal(10,7) [note: 'Geographic longitude coordinate of the store location in decimal degrees. Used for geospatial analysis, delivery routing, trade area mapping, and proximity-based customer targeting.']
  manager_name varchar [note: 'Full name of the current store manager responsible for this location. Used for operational accountability, escalation routing, and organizational reporting. Business reference, not direct PII.']
  modified_timestamp timestamp [note: 'Timestamp when this store location record was last modified. Used for data lineage, change tracking, and audit trails. Updated on every record change.']
  number_of_floors varchar [note: 'Total number of customer-accessible floors in the store location. Used for store layout planning, accessibility compliance, and customer flow analysis.']
  opening_date date [note: 'The date this store location first opened for business. Used for comp sales (SSS - Same-Store Sales) calculations, anniversary planning, and store maturity analysis. Null for planned stores not yet opened.']
  operating_hours varchar [note: 'Standard operating hours for the store location, typically in format \'Mon-Fri 8:00-22:00, Sat-Sun 9:00-21:00\'. Used for workforce scheduling, customer communications, and omnichannel order fulfillment time windows.']
  parking_capacity varchar [note: 'Total number of customer parking spaces available at the store location. Used for site selection, customer convenience analysis, and BOPIS/ROPIS pickup planning. Null for urban locations without dedicated parking.']
  phone_number varchar [note: 'Primary contact phone number for the store location. Used for customer inquiries, BOPIS/ROPIS coordination, and operational communications. Organizational contact data classified as confidential.']
  postal_code varchar [note: 'Postal code or ZIP code for the store location. Used for delivery routing, trade area analysis, and demographic segmentation. Organizational contact data classified as confidential.']
  primary_dc_facility_code varchar [note: 'Foreign key linking to supplychain.dc_facility. Business justification: Every store has a primary DC assignment for standard replenishment routing. Fundamental retail supply chain topology required for: replenishment order routing, freight cost allocation, lead time calcu']
  ropis_capable boolean [note: 'Indicates whether this store location supports ROPIS (Reserve Online Pick Up In Store) fulfillment, where customers reserve items online and complete purchase in-store. True = ROPIS enabled; False = ROPIS not available.']
  selling_square_footage decimal(10,2) [note: 'Square footage of customer-accessible selling floor space, excluding back-of-house, storage, and office areas. Used for sales per square foot calculations, planogram (POG) planning, and merchandising density analysis.']
  sfs_capable boolean [note: 'Indicates whether this store location is enabled as a Ship-from-Store (SFS) fulfillment node, capable of picking, packing, and shipping e-commerce orders directly from store inventory. True = SFS enabled; False = SFS not available.']
  staffing_model_type varchar [note: 'The staffing model classification for this store format. Full Service = high staff-to-customer ratio with clienteling; Limited Service = moderate staffing; Self Service = minimal staff, customer self-checkout; Automated = dark store or MFC with no customer-facing staff.']
  state_province varchar [note: 'State or province code (2-letter ISO or postal abbreviation) where the store location is situated. Used for tax jurisdiction determination, regulatory compliance, and regional reporting.']
  store_name varchar [note: 'The trading name or display name of the store location as it appears to customers (e.g., \'Retail Superstore Downtown\', \'Retail Express Market Hill\'). Used for customer communications, receipts, and marketing materials.']
  store_number varchar [note: 'Externally-known business identifier for the store location. This is the human-readable store number used in operational communications, signage, and customer-facing materials. Unique within the retail banner/brand.']
  time_zone varchar [note: 'IANA time zone identifier for the store location (e.g., \'America/New_York\', \'America/Chicago\'). Used for POS transaction timestamping, workforce scheduling, and omnichannel order fulfillment coordination.']
  total_square_footage decimal(10,2) [note: 'Total building square footage of the store location, including selling floor, back-of-house, storage, and office space. Used for productivity metrics (sales per square foot), lease accounting, and facility management.']

  Note: 'Master record for every physical retail location operated by the business, including hypermarkets, department stores, discount outlets, dark stores, and micro-fulfillment centers (MFCs). Captures store number, banner/brand, format type (hypermarket, department, discount, dark store, MFC), format size band, assortment depth/breadth norms, staffing model type, fulfillment capability flags (BOPIS-capable, ROPIS-capable, SFS-capable, DSD-receiving), trading name, legal entity, opening date, closure date, remodel history, square footage (total and selling), number of floors, parking capacity, operating hours, time zone, locale, climate zone, accessibility certifications, and store lifecycle status. This is the SSOT for all store identity, classification, and format configuration data consumed by inventory, order, workforce, and finance domains.'
}

Table store.format {
  format_id varchar [pk, note: 'Unique identifier for the store format. Primary key.']
  parent_format_id varchar [note: 'Add column parent_format_id (BIGINT) to store.format with FK to store.format.format_id because store formats may have hierarchical relationships. P17: connect_table: store.format** - add column parent_format_id (BIGINT) with FK to store.for']
  assortment_breadth_level varchar [note: 'Typical range of product categories carried by this format. Narrow = few categories (e.g., convenience); broad = many categories (e.g., hypermarket).']
  assortment_depth_level varchar [note: 'Typical variety within each product category for this format. Shallow = limited SKU (Stock Keeping Unit) variety per category; deep = extensive SKU variety per category.']
  bopis_capable_flag boolean [note: 'Indicates whether stores of this format are capable of supporting BOPIS (Buy Online Pick Up In Store) fulfillment. True if BOPIS is supported; false otherwise.']
  clienteling_service_flag boolean [note: 'Indicates whether stores of this format offer clienteling (personalized in-store service) to customers. True if clienteling is offered; false otherwise.']
  code varchar [note: 'Short alphanumeric code representing the store format (e.g., HM for hypermarket, SS for superstore, DS for discount store, CONV for convenience, DARK for dark store, MFC for micro-fulfillment center).']
  created_timestamp timestamp [note: 'Timestamp when this store format record was first created in the system.']
  description varchar [note: 'Detailed description of the store format including its purpose, target customer segment, and operational characteristics.']
  dsd_receiving_flag boolean [note: 'Indicates whether stores of this format receive DSD (Direct Store Delivery) shipments directly from vendors, bypassing the DC (Distribution Center). True if DSD receiving is supported; false otherwise.']
  effective_end_date date [note: 'Date when this store format definition was retired or deprecated. Null for currently active formats.']
  effective_start_date date [note: 'Date when this store format definition became effective and available for use in store planning and operations.']
  endcap_count_typical varchar [note: 'Typical number of endcaps (end-of-aisle displays) available for promotional merchandising in stores of this format.']
  format_status varchar [note: 'Current lifecycle status of the store format. Active formats are in use across the banner portfolio; deprecated formats are being phased out; pilot formats are under testing.']
  format_type varchar [note: 'High-level classification of the format: physical_retail (customer-facing), fulfillment_only (dark store, MFC), or hybrid (ship-from-store capable retail location).']
  gondola_configuration_type varchar [note: 'Typical gondola (shelving unit) configuration used in stores of this format. Defines the standard shelving layout and fixture type.']
  last_modified_timestamp timestamp [note: 'Timestamp when this store format record was last updated in the system.']
  loyalty_program_participation_flag boolean [note: 'Indicates whether stores of this format participate in the enterprise loyalty program. True if loyalty program is active; false otherwise.']
  name varchar [note: 'Full descriptive name of the store format (e.g., Hypermarket, Superstore, Department Store, Discount Outlet, Convenience Store, Dark Store, Micro-Fulfillment Center, Ship-from-Store Node).']
  operating_hours_type varchar [note: 'Typical operating hours pattern for stores of this format. 24_7 = open 24 hours; extended = long hours (e.g., 6am-midnight); standard = typical retail hours; limited = short hours; variable = hours vary by location.']
  parking_capacity_typical varchar [note: 'Typical number of parking spaces available at stores of this format. Null for formats without customer parking (e.g., dark stores, MFCs).']
  planogram_template_code varchar [note: 'Code identifying the standard planogram (POG - Shelf Layout Diagram) template used for visual merchandising in stores of this format. Links to master planogram library.']
  pos_terminal_count_max varchar [note: 'Maximum number of POS (Point of Sale) terminals typically deployed in stores of this format. Defines the upper bound of checkout capacity.']
  pos_terminal_count_min varchar [note: 'Minimum number of POS (Point of Sale) terminals typically deployed in stores of this format. Defines the lower bound of checkout capacity.']
  pricing_strategy_type varchar [note: 'Typical pricing strategy employed by stores of this format. EDLP (Everyday Low Price) = consistent low prices; Hi-Lo (High-Low Pricing Strategy) = regular prices with frequent promotions; premium = higher prices with quality focus; discount = below-market pricing; dynamic = algorithmic pricing.']
  rfid_enabled_flag boolean [note: 'Indicates whether stores of this format use RFID (Radio Frequency Identification) technology for inventory tracking and shrinkage prevention. True if RFID is deployed; false otherwise.']
  ropis_capable_flag boolean [note: 'Indicates whether stores of this format are capable of supporting ROPIS (Reserve Online Pick Up In Store) fulfillment. True if ROPIS is supported; false otherwise.']
  sfs_capable_flag boolean [note: 'Indicates whether stores of this format are capable of serving as SFS (Ship-from-Store) fulfillment nodes for e-commerce orders. True if SFS is supported; false otherwise.']
  size_band_max_sqft decimal(10,2) [note: 'Maximum store size in square feet for this format. Defines the upper bound of the typical size range.']
  size_band_min_sqft decimal(10,2) [note: 'Minimum store size in square feet for this format. Defines the lower bound of the typical size range.']
  staffing_model_type varchar [note: 'Typical staffing and service model for this format. Full service = high staff-to-customer ratio with personalized assistance; self-service = minimal staff, customer-driven; automated = robotic/automated fulfillment.']
  target_demographic varchar [note: 'Primary customer demographic segment targeted by this store format (e.g., value-conscious families, urban professionals, convenience shoppers, bulk buyers).']
  typical_sku_count_max varchar [note: 'Maximum number of SKUs (Stock Keeping Units) typically carried by stores of this format. Defines the upper bound of product assortment size.']
  typical_sku_count_min varchar [note: 'Minimum number of SKUs (Stock Keeping Units) typically carried by stores of this format. Defines the lower bound of product assortment size.']
  wms_integration_required_flag boolean [note: 'Indicates whether stores of this format require integration with WMS (Warehouse Management System) for inventory management. True for fulfillment-heavy formats (dark stores, MFCs, SFS nodes); false for traditional retail-only formats.']

  Note: 'Reference classification of retail store formats used across the banner portfolio. Defines format codes and descriptions (hypermarket, superstore, department store, discount outlet, convenience, dark store, MFC, ship-from-store node), typical size bands (sq ft ranges), assortment depth/breadth norms, staffing model type, and fulfillment capability flags (BOPIS-capable, ROPIS-capable, SFS-capable, DSD-receiving). Used to drive operational standards, planogram templates, and omnichannel routing rules.'
}

Table store.pos_terminal {
  pos_terminal_id varchar [pk, note: 'Unique identifier for the POS terminal. Primary key. Inferred role: MASTER_RESOURCE.']
  department_id varchar [note: 'Foreign key linking to store.store_department. Business justification: POS terminals are assigned to specific departments within a store (e.g., electronics department checkout, grocery department checkout). The pos_terminal record currently denormalizes department_code a']
  location_id varchar [note: 'Foreign key reference to the store location where this POS terminal is deployed.']
  vendor_id varchar [note: 'Foreign key linking to supplier.vendor. Business justification: POS terminals are capital equipment procured from hardware vendors. Tracking the vendor supports warranty claims, maintenance contract management, service call routing, and replacement parts procureme']
  barcode_scanner_type varchar [note: 'Type of barcode scanner peripheral attached to the POS terminal. Determines scanning workflow and throughput capabilities.']
  cash_drawer_enabled boolean [note: 'Indicates whether the terminal is connected to a cash drawer for handling cash transactions. False for self-checkout kiosks and mobile POS devices that do not accept cash.']
  contactless_enabled boolean [note: 'Indicates whether the terminal supports Near Field Communication (NFC) contactless payments (tap-to-pay, mobile wallets like Apple Pay, Google Pay).']
  created_timestamp timestamp [note: 'Timestamp when this POS terminal record was first created in the master data system. Used for audit trail and data lineage tracking.']
  customer_display_type varchar [note: 'Type of customer-facing display device attached to the terminal. Shows transaction details, pricing, and promotional messages to the customer during checkout.']
  ebt_snap_enabled boolean [note: 'Indicates whether the terminal is certified to accept Electronic Benefits Transfer (EBT) and Supplemental Nutrition Assistance Program (SNAP) payments. Required for grocery retailers serving SNAP recipients.']
  emv_chip_enabled boolean [note: 'Indicates whether the terminal supports EMV chip card transactions (contact chip reading). Required for PCI DSS compliance and fraud reduction.']
  encryption_enabled boolean [note: 'Indicates whether the terminal encrypts payment card data at the point of interaction (P2PE - Point-to-Point Encryption). Required for PCI DSS compliance and fraud prevention.']
  hardware_model varchar [note: 'Manufacturer model number or identifier for the POS terminal hardware (e.g., \'NCR RealPOS 82XRT\', \'Toshiba TCx Sky\', \'Zebra TC52\'). Critical for maintenance planning and compatibility management.']
  hardware_serial_number varchar [note: 'Manufacturer-assigned unique serial number for the physical POS terminal device. Used for warranty tracking, asset management, and theft prevention.']
  installation_date date [note: 'Date when the POS terminal was first installed and commissioned at the store location. Used for asset lifecycle tracking and depreciation calculations.']
  ip_address varchar [note: 'Internet Protocol (IP) address assigned to the POS terminal on the store network. Used for network troubleshooting, security monitoring, and remote management.']
  lane_number varchar [note: 'Physical lane or checkout position number within the store layout. Used for customer wayfinding and operational reporting. Null for mobile POS devices.']
  last_maintenance_date date [note: 'Date of the most recent preventive maintenance or repair service performed on the terminal. Used for maintenance schedule compliance tracking.']
  last_transaction_timestamp timestamp [note: 'Timestamp of the most recent transaction processed by this terminal. Used for terminal utilization analysis and anomaly detection (e.g., identifying inactive terminals).']
  mac_address varchar [note: 'Media Access Control (MAC) address of the POS terminal network interface. Unique hardware identifier used for network access control and device authentication.']
  mobile_wallet_enabled boolean [note: 'Indicates whether the terminal supports mobile wallet payment methods (Apple Pay, Google Pay, Samsung Pay, etc.). Typically requires NFC hardware.']
  network_zone varchar [note: 'Network security zone or segment where the POS terminal is deployed. Cardholder Data Environment (CDE) terminals are subject to stricter PCI DSS controls.']
  next_scheduled_maintenance_date date [note: 'Date when the next preventive maintenance service is scheduled for the terminal. Used for proactive maintenance planning and resource allocation.']
  operating_system varchar [note: 'Operating system running on the POS terminal (e.g., \'Windows 10 IoT\', \'Android 11\', \'Linux Ubuntu 20.04\'). Impacts security posture and application compatibility.']
  payment_processor varchar [note: 'Name of the payment processing service or gateway integrated with this terminal (e.g., \'First Data\', \'Worldpay\', \'Square\'). Determines payment acceptance capabilities and settlement routing.']
  pci_dss_certification_date date [note: 'Date when the terminal last passed Payment Card Industry Data Security Standard (PCI DSS) compliance certification. Must be renewed annually to maintain payment acceptance capabilities.']
  pci_dss_certification_expiry_date date [note: 'Date when the current PCI DSS certification expires. Terminals must be recertified before this date to continue processing payment card transactions.']
  pin_debit_enabled boolean [note: 'Indicates whether the terminal supports PIN-based debit card transactions. Requires secure PIN pad hardware.']
  qr_code_payment_enabled boolean [note: 'Indicates whether the terminal supports QR code-based payment methods (e.g., Alipay, WeChat Pay, retailer-specific QR payment apps).']
  receipt_printer_model varchar [note: 'Model identifier for the receipt printer peripheral attached to the POS terminal. Used for consumables ordering and maintenance scheduling.']
  remote_management_enabled boolean [note: 'Indicates whether the terminal can be remotely monitored, configured, and updated from a central management system. Enables efficient fleet management and rapid issue resolution.']
  scale_integrated boolean [note: 'Indicates whether the terminal has an integrated scale for weighing produce, bulk items, or other variable-weight merchandise. Common in grocery checkout lanes.']
  signature_capture_enabled boolean [note: 'Indicates whether the terminal supports electronic signature capture for credit card transactions and delivery confirmations.']
  software_version varchar [note: 'Version number of the POS application software currently installed on the terminal. Critical for security patch management and feature compatibility.']
  terminal_name varchar [note: 'Human-readable name or label for the POS terminal, often indicating its location or purpose within the store (e.g., \'Lane 5\', \'Customer Service Desk\', \'Pharmacy Register\').']
  terminal_number varchar [note: 'Business identifier for the POS terminal, typically displayed on the terminal and used in operational communications. Unique within a store location.']
  terminal_status varchar [note: 'Current operational status of the POS terminal. Determines whether the terminal is available for transaction processing. Active terminals are in production use; offline terminals are temporarily unavailable; maintenance terminals are undergoing service; decommissioned terminals are permanently retired.']
  terminal_type varchar [note: 'Classification of the POS terminal based on its operational function and staffing model. Determines transaction workflows and customer interaction patterns.']
  tokenization_enabled boolean [note: 'Indicates whether the terminal supports payment tokenization, replacing sensitive card data with non-sensitive tokens for storage and transmission. Reduces PCI DSS scope.']
  updated_timestamp timestamp [note: 'Timestamp when this POS terminal record was last modified in the master data system. Used for change tracking and data synchronization.']

  Note: 'Master record for every Point-of-Sale (POS) terminal deployed within a store location. Captures terminal ID, lane number, terminal type (staffed checkout lane, self-checkout kiosk, mobile POS, customer service desk, pharmacy register), hardware model, software version, payment acceptance capabilities (EMV chip, NFC/contactless, PIN debit, EBT/SNAP, mobile wallet), peripheral devices (scanner, scale, receipt printer), installation date, last maintenance date, next scheduled maintenance, terminal status (active, offline, maintenance, decommissioned), PCI DSS compliance certification date, and assigned department or zone within the store. Critical for POS transaction reconciliation, shrinkage investigation, lane productivity analysis, and omnichannel payment compliance.'
}

Table store.fixture {
  fixture_id varchar [pk, note: 'Unique identifier for the store fixture. Primary key.']
  department_id varchar [note: 'Foreign key linking to store.store_department. Business justification: Fixtures are physically located within store departments. The fixture record currently denormalizes department_code as a STRING. Adding FK to store_department allows joining to get department_name, de']
  location_id varchar [note: 'Identifier of the retail store location where this fixture is currently assigned. Links to the store master record.']
  vendor_id varchar [note: 'Identifier of the vendor or supplier from whom the fixture was purchased. Links to the supplier master record for procurement history and vendor performance tracking.']
  ada_compliant_flag boolean [note: 'Indicates whether the fixture meets ADA accessibility requirements for height, reach range, and clearance. True indicates compliant, false indicates non-compliant or exempted.']
  adjustable_shelves_flag boolean [note: 'Indicates whether the fixture has adjustable shelf heights. True enables flexible merchandising for varying product sizes, false indicates fixed shelf positions.']
  aisle_number varchar [note: 'Aisle identifier where the fixture is positioned within the store. Used for store navigation, planogram assignment, and customer wayfinding.']
  bay_position varchar [note: 'Specific bay or section position within the aisle (e.g., Bay 1, Bay 2). Provides granular location tracking for planogram compliance and inventory audits.']
  category varchar [note: 'Categorization of the fixture based on its intended duration and purpose. Permanent fixtures are long-term store infrastructure, seasonal fixtures support recurring seasonal merchandising, promotional fixtures are used for short-term campaigns, and temporary fixtures are ad-hoc displays.']
  code varchar [note: 'Business identifier code for the fixture, used for asset tracking and inventory management. Typically alphanumeric code assigned by merchandising or facilities team.']
  created_timestamp timestamp [note: 'Timestamp when this fixture record was first created in the system. Used for data lineage and audit trail.']
  depth_inches decimal(8,2) [note: 'Depth of the fixture measured in inches. Important for aisle width planning, product capacity calculation, and customer navigation.']
  digital_display_flag boolean [note: 'Indicates whether the fixture includes digital signage or electronic shelf labels (ESL) for dynamic pricing and promotions. True indicates digital capability, false indicates traditional static signage.']
  finish_color varchar [note: 'Color or finish of the fixture exterior (e.g., white, black, chrome, wood grain). Used for visual merchandising consistency and brand alignment across store fleet.']
  fixture_status varchar [note: 'Current lifecycle status of the fixture. Active indicates in-use and operational, inactive indicates temporarily not in use, maintenance indicates undergoing repair or refurbishment, retired indicates permanently removed from service, damaged indicates requiring repair, and pending installation indicates purchased but not yet deployed.']
  fixture_type varchar [note: 'Classification of the fixture by its primary merchandising function. Gondola refers to standard shelving units, endcap to end-of-aisle displays, cooler/freezer to refrigerated cases, pegboard to hanging merchandise panels, display table to promotional tables, checkout lane to POS area fixtures, shelf unit to standalone shelving, and rack to hanging garment fixtures. [ENUM-REF-CANDIDATE: gondola|endcap|cooler|freezer|pegboard|display_table|checkout_lane|shelf_unit|rack — 9 candidates stripped; promote to reference product]']
  height_inches decimal(8,2) [note: 'Height of the fixture measured in inches. Critical for vertical space utilization, sight line planning, and compliance with accessibility standards.']
  installation_date date [note: 'Date the fixture was installed in its current store location. Used for age tracking, depreciation calculation, and maintenance scheduling.']
  last_refurbishment_date date [note: 'Date of the most recent refurbishment, repair, or significant maintenance performed on the fixture. Null if never refurbished since installation.']
  last_updated_timestamp timestamp [note: 'Timestamp when this fixture record was most recently modified. Used for change tracking and data quality monitoring.']
  lighting_integrated_flag boolean [note: 'Indicates whether the fixture has built-in lighting to highlight merchandise. True indicates integrated lighting system, false indicates no built-in lighting.']
  manufacturer_name varchar [note: 'Name of the company that manufactured the fixture. Used for warranty tracking, parts sourcing, and vendor performance analysis.']
  material_composition varchar [note: 'Primary materials used in fixture construction (e.g., steel, wood, laminate, glass, acrylic). Impacts durability, maintenance requirements, and aesthetic alignment with store design.']
  mobility_type varchar [note: 'Indicates whether the fixture is permanently installed (fixed), easily movable (mobile with casters), or requires tools to relocate (semi-mobile). Impacts flexibility for store resets and seasonal merchandising changes.']
  model_number varchar [note: 'Manufacturer\'s model or part number for the fixture. Critical for ordering replacement parts, warranty claims, and standardization across stores.']
  next_maintenance_date date [note: 'Planned date for the next preventive maintenance or inspection. Used for maintenance scheduling and compliance with safety standards.']
  notes varchar [note: 'Free-text field for additional comments, special handling instructions, maintenance history notes, or other relevant information about the fixture.']
  power_required_flag boolean [note: 'Indicates whether the fixture requires electrical power for operation (e.g., refrigeration, lighting, digital displays). True requires power connection, false indicates passive fixture.']
  purchase_order_number varchar [note: 'Purchase order number under which the fixture was procured. Used for procurement audit trail and invoice reconciliation.']
  refrigeration_type varchar [note: 'Temperature control classification for the fixture. Ambient indicates no refrigeration, chilled indicates 32-40°F range for dairy and produce, frozen indicates below 0°F for frozen foods, multi-temp indicates multiple temperature zones, and none indicates non-refrigerated fixtures.']
  rfid_enabled_flag boolean [note: 'Indicates whether the fixture is equipped with RFID readers for automated inventory tracking and shrinkage prevention. True indicates RFID capability, false indicates no RFID integration.']
  security_features varchar [note: 'Description of anti-theft or security features integrated into the fixture (e.g., locking doors, security hooks, EAS tag compatibility, camera integration). Used for shrinkage prevention and loss prevention planning.']
  serial_number varchar [note: 'Manufacturer-assigned unique serial number for the individual fixture unit. Used for warranty claims, theft recovery, and precise asset tracking.']
  shelf_count varchar [note: 'Number of shelves or display levels on the fixture. Used for capacity planning and planogram assignment. Null for fixtures without shelves (e.g., pegboards, hanging racks).']
  weight_capacity_lbs decimal(10,2) [note: 'Maximum weight load the fixture can safely support, measured in pounds. Critical for safety compliance and preventing structural failure when merchandising heavy products.']
  width_inches decimal(8,2) [note: 'Width of the fixture measured in inches. Used for space planning, planogram design, and store layout optimization.']

  Note: 'Master record for physical store fixtures including gondolas (shelving units), endcaps (end-of-aisle displays), cooler/freezer cases, pegboard panels, display tables, and checkout lane fixtures. Captures fixture ID, fixture type, manufacturer, model number, dimensions (width, height, depth), number of shelves, adjustable shelf flag, refrigeration type (ambient, chilled, frozen), installation date, last refurbishment date, assigned store location, assigned department/zone, and current planogram assignment. Supports visual merchandising planning, maintenance scheduling, and capital asset tracking.'
}

Table store.department {
  department_id varchar [pk, note: 'Unique identifier for the store department. Primary key for the store department entity.']
  item_hierarchy_id varchar [note: 'Foreign key linking to product.item_hierarchy. Business justification: Store departments map to merchandise categories (item hierarchy). Department managers are responsible for specific categories. Essential for departmental P&L reporting by category and category manager']
  location_id varchar [note: 'Reference to the parent store location where this department is physically located.']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: Retail departments (e.g., grocery, electronics, apparel) are assigned department-level price lists that govern valid selling prices for items in that department. This supports department-level price l']
  vendor_id varchar [note: 'Foreign key linking to supplier.vendor. Business justification: Category management in retail assigns a primary vendor (category captain) to each department. This drives assortment decisions, planogram ownership, and vendor collaboration. A retail category manager']
  created_timestamp timestamp [note: 'Timestamp when the department record was first created in the system. Used for audit trail and data lineage.']
  department_status varchar [note: 'Current operational status of the department. Active departments are open for business; inactive departments are closed or not yet operational.']
  department_type varchar [note: 'Classification of the department by merchandise category. Determines merchandising strategy, planogram standards, and operational procedures. [ENUM-REF-CANDIDATE: grocery|apparel|electronics|household|pharmacy|bakery|deli|produce|frozen|health_beauty|seasonal|home_garden|automotive|sporting_goods|toys|jewelry|furniture — 17 candidates stripped; promote to reference product]']
  effective_end_date date [note: 'Date when the department ceased operations or when the current configuration ended. Null for currently active departments.']
  effective_start_date date [note: 'Date when the department became operational or when the current configuration became effective. Used for historical tracking and comp sales analysis.']
  endcap_count varchar [note: 'Number of endcap display positions (end-of-aisle promotional displays) available in the department. Prime real estate for high-margin or promotional items.']
  fixture_count varchar [note: 'Total number of fixtures (gondolas, endcaps, shelving units, display cases) assigned to the department. Used for planogram capacity planning.']
  floor_number varchar [note: 'Floor level where the department is located within the store. Ground floor is typically 1, basement levels may be 0 or negative.']
  gondola_count varchar [note: 'Number of gondola shelving units (freestanding double-sided shelving) in the department. Key metric for planogram assignment and merchandising capacity.']
  gross_margin_target_percent decimal(5,2) [note: 'Target gross margin percentage for the department. Used to measure profitability and pricing effectiveness.']
  labor_budget_monthly decimal(12,2) [note: 'Monthly labor budget allocation for the department in local currency. Used for workforce scheduling and labor-to-sales ratio management.']
  last_modified_by varchar [note: 'User ID or system identifier of the person or process that last modified the department record. Used for audit trail and accountability.']
  last_modified_timestamp timestamp [note: 'Timestamp when the department record was last updated. Used for audit trail and change tracking.']
  license_expiry_date date [note: 'Expiration date of the regulatory license or permit for licensed departments. Null for non-licensed departments.']
  license_number varchar [note: 'Regulatory license or permit number for licensed departments (e.g., pharmacy license, alcohol retail license). Null for non-licensed departments.']
  licensed_department_flag boolean [note: 'Indicates whether the department requires special licensing or regulatory compliance (e.g., pharmacy, alcohol, tobacco, firearms). True if licensing is required.']
  notes varchar [note: 'Free-form text field for additional notes, comments, or special instructions related to the department. Used for operational context and exception handling.']
  omnichannel_fulfillment_enabled_flag boolean [note: 'Indicates whether the department supports omnichannel fulfillment operations (BOPIS, ROPIS, ship-from-store). True if omnichannel fulfillment is enabled.']
  planogram_count varchar [note: 'Number of active planograms (shelf layout diagrams) assigned to the department. Each planogram defines product placement and facings for a fixture or section.']
  pos_terminal_count varchar [note: 'Number of POS terminals or checkout lanes assigned to or located within the department. Relevant for departments with dedicated checkout (e.g., pharmacy, jewelry).']
  sales_target_monthly decimal(15,2) [note: 'Monthly sales target or quota for the department in local currency. Used for performance management and comp sales (SSS) analysis.']
  selling_area_sq_ft decimal(10,2) [note: 'Total selling floor space allocated to the department measured in square feet. Used to calculate sales per square foot and space productivity metrics.']
  shrinkage_rate_percent decimal(5,2) [note: 'Historical shrinkage rate (inventory loss due to theft, damage, spoilage) for the department expressed as a percentage of sales. Used for loss prevention planning.']
  temperature_controlled_flag boolean [note: 'Indicates whether the department requires temperature-controlled environment (e.g., frozen, refrigerated, deli, bakery). True if climate control is required.']
  temperature_range_max_f decimal(5,2) [note: 'Maximum temperature threshold in Fahrenheit for temperature-controlled departments. Null for non-temperature-controlled departments.']
  temperature_range_min_f decimal(5,2) [note: 'Minimum temperature threshold in Fahrenheit for temperature-controlled departments. Null for non-temperature-controlled departments.']
  visual_merchandising_standard varchar [note: 'Code or reference to the visual merchandising standard or guideline applied to the department. Defines display aesthetics, signage, and presentation rules.']
  zone_code varchar [note: 'Alphanumeric code identifying the physical zone or area within the store floor plan. Used for wayfinding, inventory location, and planogram assignment.']

  Note: 'Master record for departments or selling zones within a store location — the primary sub-location operational unit in retail. Captures department ID, department name, department code, parent store location, floor number, zone coordinates, department type (grocery, apparel, electronics, household, pharmacy, bakery, deli, produce, frozen, health & beauty, seasonal, etc.), selling area (sq ft), number of fixtures, department manager assignment reference, labor budget allocation, and active status. Departments are the fundamental unit for planogram assignment, inventory allocation, staffing schedules, shrinkage attribution, and P&L sub-reporting within a store. Most operational KPIs (sales per sq ft, shrink rate, labor-to-sales ratio) are measured at department level.'
}

Table store.cluster {
  cluster_id varchar [pk, note: 'Unique identifier for the store cluster. Primary key.']
  parent_cluster_id varchar [note: 'Reference to a parent cluster if this cluster is part of a hierarchical clustering structure (e.g., sub-clusters within a regional cluster). Null for top-level clusters.']
  price_zone_id varchar [note: 'Foreign key linking to pricing.price_zone. Business justification: Retail clusters are assigned price zones to apply uniform pricing strategy across member stores. Cluster-based price zone assignment drives zone-level pricing execution, promotional intensity calibrat']
  primary_fulfillment_node_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_node. Business justification: Store clusters are assigned a primary fulfillment node (e.g., regional dark store or DC-as-node) for cluster-level fulfillment capacity planning, SLA target-setting, and promotional surge routing. Ret']
  promo_calendar_id varchar [note: 'Foreign key linking to promotion.promo_calendar. Business justification: Store clusters follow specific promotional calendars based on their shared characteristics (urbanization, format mix, customer segment). Cluster-to-calendar assignment drives promotional cadence plann']
  region_id varchar [note: 'Foreign key linking to store.region. Business justification: A store cluster is a logical grouping of locations that typically aligns to a geographic region for assortment, pricing, and promotional strategy. The cluster table has geographic_scope (string) and c']
  allows_overlap boolean [note: 'Indicates whether a store can belong to multiple clusters of this type simultaneously. True for concurrent clustering schemes (e.g., a store can be in both an assortment cluster and a pricing zone cluster); false for mutually exclusive schemes.']
  assortment_depth_strategy varchar [note: 'Planned depth of product assortment for this cluster. Deep assortment offers extensive variety within categories; moderate offers balanced selection; shallow offers limited SKU count; curated offers highly selective premium assortment. Drives OTB planning and space allocation.']
  average_annual_sales_usd decimal(15,2) [note: 'Average annual sales volume in USD for stores in this cluster. Used for performance tier clustering and benchmarking. Business-confidential financial metric.']
  average_store_size_sqft decimal(12,2) [note: 'Average selling floor area in square feet of stores in this cluster. Used for format-based clustering and space productivity benchmarking.']
  climate_zone varchar [note: 'Predominant climate classification for stores in this cluster. Used for climate-based clustering to drive seasonal assortment and inventory planning (e.g., winter apparel depth, cooling appliances).']
  cluster_status varchar [note: 'Current lifecycle status of the cluster. Active clusters are in operational use; inactive clusters are temporarily disabled; pending clusters are awaiting approval; archived clusters are historical; under_review clusters are being evaluated for changes.']
  cluster_type varchar [note: 'Classification of the clustering scheme. Assortment clusters drive localized product mix; pricing zone clusters enable zone-based pricing strategies; demographic clusters group by customer profile; performance tier clusters segment by sales volume or profitability; climate clusters address seasonal/weather-driven needs; geographic clusters group by region; format clusters group by store format (hypermarket, discount, dark store); omnichannel clusters optimize fulfillment network. [ENUM-REF-CANDIDATE: assortment|pricing_zone|demographic|performance_tier|climate|geographic|format|omnichannel — 8 candidates stripped; promote to reference product]']
  clustering_criteria varchar [note: 'Business rules or data attributes used to assign stores to this cluster (e.g., sales volume > $10M, urban location, customer income > $75K, climate zone = temperate). Supports transparency and auditability of cluster logic.']
  clustering_methodology varchar [note: 'Method used to define the cluster. Algorithmic indicates data-driven segmentation (e.g., k-means, hierarchical clustering); manual indicates business-defined groupings; hybrid combines both; machine_learning indicates advanced ML models; rule_based indicates business rules engine.']
  code varchar [note: 'Business-friendly alphanumeric code for the store cluster, used in reporting and operational systems. Typically follows a pattern like REGION-TYPE-SEQ (e.g., NE-ASSORT-01, SW-PRICE-03).']
  created_timestamp timestamp [note: 'Timestamp when this cluster record was first created in the system. Supports audit trail and data lineage.']
  description varchar [note: 'Detailed business description of the cluster purpose, characteristics, and intended use. Explains the rationale for grouping these stores together.']
  effective_end_date date [note: 'Date when this cluster definition ceases to be effective. Null indicates the cluster is currently active with no planned end date.']
  effective_start_date date [note: 'Date when this cluster definition becomes effective for operational use. Supports temporal validity and historical analysis of cluster changes.']
  external_cluster_code varchar [note: 'Cluster identifier from the source system of record. Used for cross-system reconciliation and data lineage tracking.']
  geographic_scope varchar [note: 'Geographic coverage of the cluster. National clusters span the entire country; regional clusters cover multi-state regions; state clusters are state-specific; metro clusters cover metropolitan areas; local clusters are city or neighborhood-level.']
  last_modified_timestamp timestamp [note: 'Timestamp when this cluster record was last updated. Supports change tracking and audit trail.']
  last_review_date date [note: 'Date when this cluster definition was last reviewed and validated by the cluster owner. Used to track cluster maintenance and ensure clustering logic remains current.']
  level varchar [note: 'Depth level in the cluster hierarchy. Level 1 is top-level (e.g., national or regional); higher numbers indicate more granular sub-clusters. Supports hierarchical rollup and drill-down analysis.']
  member_store_count varchar [note: 'Total number of store locations currently assigned to this cluster. Updated as stores join or leave the cluster.']
  name varchar [note: 'Human-readable name of the store cluster, used for display and business communication (e.g., Northeast Urban High-Income, Southwest Discount Tier 1).']
  next_review_date date [note: 'Scheduled date for the next cluster review. Ensures periodic validation of cluster definitions and membership. Typically quarterly or semi-annually.']
  owner_name varchar [note: 'Name of the individual or role responsible for this cluster definition (e.g., Regional Merchandising Manager, Pricing Director).']
  owner_team varchar [note: 'Business function responsible for defining and maintaining this cluster. Merchandising owns assortment clusters; pricing owns pricing zone clusters; operations owns performance tier clusters; supply chain owns fulfillment clusters; marketing owns demographic clusters; analytics owns data-driven experimental clusters.']
  pricing_strategy varchar [note: 'Pricing approach for this cluster. EDLP (Everyday Low Price) maintains consistent low prices; hi-lo uses frequent promotions; premium targets high-margin customers; competitive matches market prices; value emphasizes affordability. Drives zone pricing rules.']
  primary_business_purpose varchar [note: 'Primary operational use case for this cluster (e.g., localized assortment planning, zone pricing strategy, promotional targeting, operational benchmarking, fulfillment network optimization).']
  promotional_intensity varchar [note: 'Frequency and depth of promotional activity targeted at this cluster. High intensity clusters receive frequent deep discounts; low intensity clusters have minimal promotions; none indicates EDLP strategy with no promotions.']
  replenishment_frequency varchar [note: 'Standard inventory replenishment cadence for stores in this cluster. Drives supply chain planning and DC allocation. High-volume urban stores typically receive daily replenishment; lower-volume rural stores may be weekly or bi-weekly.']
  store_format_mix varchar [note: 'Comma-separated list of store formats included in this cluster (e.g., hypermarket, discount, dark_store, MFC). Used for format-based clustering and omnichannel fulfillment optimization.']
  supports_omnichannel boolean [note: 'Indicates whether stores in this cluster are enabled for omnichannel fulfillment capabilities (BOPIS, ROPIS, ship-from-store, curbside pickup). True if cluster is designed for omnichannel operations.']
  urbanization_level varchar [note: 'Population density classification for stores in this cluster. Urban stores serve high-density city centers; suburban stores serve residential areas; rural stores serve low-density regions; exurban stores serve outer suburban fringe areas.']

  Note: 'Master record defining store clusters — logical groupings of store locations used for localized assortment planning, zone pricing, promotional targeting, and operational benchmarking. Captures cluster ID, name, type (assortment, pricing zone, demographic, performance tier, climate), clustering methodology (algorithmic, manual override, hybrid), effective date range, member store count, and cluster owner (merchandising, pricing, or operations team). Also owns store-to-cluster membership associations including effective dates and override reasons, supporting many-to-many store-cluster relationships across concurrent clustering schemes.'
}

Table store.sfs_fulfillment_node {
  sfs_fulfillment_node_id varchar [pk, note: 'Unique identifier for the ship-from-store fulfillment node. Primary key for this entity.']
  fulfillment_node_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_node. Business justification: fulfillment.sfs_fulfillment_node defines a store\'s ship-from-store capability configuration; fulfillment.fulfillment_node is the operational execution record. Linking them enables SFS order routing, capacit']
  location_id varchar [note: 'Reference to the physical store location that serves as this fulfillment node. Links to the store master record.']
  price_zone_id varchar [note: 'Foreign key linking to pricing.price_zone. Business justification: Ship-from-store fulfillment nodes serve specific geographic markets and must operate under a price zone for omnichannel/ecommerce pricing. price_zone.fulfillment_node_count confirms this relationship ']
  activation_date date [note: 'Date when this fulfillment node was first activated and began accepting orders for fulfillment.']
  average_pack_time_minutes decimal(6,2) [note: 'Average time in minutes required to pack a standard order at this fulfillment node. Used for capacity planning and throughput estimation.']
  average_pick_time_minutes decimal(6,2) [note: 'Average time in minutes required to pick a standard order at this fulfillment node. Used for capacity planning and Service Level Agreement (SLA) estimation.']
  carrier_account_number varchar [note: 'Account number or identifier used for billing and tracking with the primary carrier. Business-confidential information used for shipment processing.']
  contact_email varchar [note: 'Email address of the primary operational contact for this fulfillment node. Organizational contact data classified as confidential.']
  contact_name varchar [note: 'Name of the primary operational contact or fulfillment manager for this node. Business-confidential organizational contact information.']
  contact_phone varchar [note: 'Phone number of the primary operational contact for this fulfillment node. Organizational contact data classified as confidential.']
  cost_per_order decimal(10,2) [note: 'Average operational cost in local currency to fulfill one order from this node, including labor, packaging, and overhead. Used for profitability analysis and routing optimization.']
  created_timestamp timestamp [note: 'Timestamp when this fulfillment node record was first created in the system. Audit trail for data lineage and compliance.']
  daily_capacity_orders varchar [note: 'Maximum number of orders this fulfillment node can process per day, based on staffing, space, and operational constraints. Used by OMS for capacity-based order routing.']
  daily_capacity_units varchar [note: 'Maximum number of individual units (SKUs) this fulfillment node can pick, pack, and ship per day. Complements order capacity for more granular planning.']
  deactivation_date date [note: 'Date when this fulfillment node was deactivated or decommissioned. Null for currently active nodes.']
  inventory_sync_frequency_minutes varchar [note: 'Frequency in minutes at which inventory positions at this fulfillment node are synchronized with the central inventory system. Lower values enable more accurate real-time inventory visibility.']
  next_day_cutoff_time timestamp [note: 'Local time cutoff (HH:MM format) by which orders must be placed to qualify for next-day delivery from this node. Null if next-day delivery is not supported.']
  node_code varchar [note: 'Externally-known unique business identifier for this fulfillment node, used in Order Management System (OMS) and Warehouse Management System (WMS) integrations.']
  node_name varchar [note: 'Human-readable name of the fulfillment node, typically matching the store name or including a fulfillment designation (e.g., \'Downtown Store - SFS Node\').']
  node_type varchar [note: 'Classification of the fulfillment node: ship_from_store (SFS - regular store with fulfillment capability), dark_store (fulfillment-only location closed to customers), micro_fulfillment_center (MFC - automated compact fulfillment facility), or hybrid (combination model).']
  notes varchar [note: 'Free-text field for operational notes, special instructions, or configuration details specific to this fulfillment node. Used for documentation and knowledge transfer.']
  oms_integration_enabled boolean [note: 'Indicates whether this fulfillment node is integrated with the Order Management System (OMS) for automated order routing and status updates. True if OMS integration is active; false otherwise.']
  operating_hours varchar [note: 'Standard operating hours for fulfillment operations at this node, typically in format \'Mon-Fri: 08:00-20:00, Sat-Sun: 09:00-18:00\'. Used for capacity planning and order routing.']
  operational_status varchar [note: 'Current operational state of the fulfillment node. Active nodes accept orders; inactive nodes are temporarily offline; suspended nodes are under review; testing nodes are in pilot phase; decommissioned nodes are permanently closed.']
  picking_zone_count varchar [note: 'Number of active picking zones configured within this fulfillment node. Zones organize inventory by category or location to optimize picking efficiency.']
  picking_zone_identifiers varchar [note: 'Comma-separated list of picking zone codes or identifiers active in this fulfillment node (e.g., \'ZONE-A,ZONE-B,ZONE-C\'). Used for WMS integration and picker assignment.']
  primary_carrier_code varchar [note: 'Code identifying the primary Third-Party Logistics (3PL) carrier or delivery service provider assigned to this fulfillment node (e.g., \'UPS\', \'FEDEX\', \'USPS\', \'DHL\').']
  priority_rank varchar [note: 'Numeric priority rank for this fulfillment node in the order routing algorithm. Lower numbers indicate higher priority. Used when multiple nodes can fulfill an order.']
  same_day_cutoff_time timestamp [note: 'Local time cutoff (HH:MM format) by which orders must be placed to qualify for same-day delivery from this node. Null if same-day delivery is not supported.']
  service_postal_codes varchar [note: 'Comma-separated list of postal codes or postal code prefixes this fulfillment node serves. Used for zone-based order routing when radius-based routing is insufficient.']
  service_radius_km decimal(8,2) [note: 'Geographic service radius in kilometers from this fulfillment node. Orders within this radius are eligible for fulfillment from this node. Used by OMS for proximity-based routing.']
  supports_bopis boolean [note: 'Indicates whether this fulfillment node supports Buy Online Pick Up In Store (BOPIS) service. True if BOPIS is available; false otherwise.']
  supports_curbside_pickup boolean [note: 'Indicates whether this fulfillment node offers curbside pickup service where customers can collect orders without entering the store. True if curbside pickup is available; false otherwise.']
  supports_next_day_delivery boolean [note: 'Indicates whether this fulfillment node offers next-day delivery service. True if next-day delivery is available; false otherwise.']
  supports_same_day_delivery boolean [note: 'Indicates whether this fulfillment node offers same-day delivery service. True if same-day delivery is available; false otherwise.']
  timezone varchar [note: 'IANA timezone identifier for this fulfillment node (e.g., \'America/New_York\', \'Europe/London\'). Used to interpret cutoff times and operating hours in local time.']
  updated_by varchar [note: 'User identifier or system account that last modified this fulfillment node record. Audit trail for accountability and compliance.']
  updated_timestamp timestamp [note: 'Timestamp when this fulfillment node record was last modified. Audit trail for change tracking and data governance.']
  wms_integration_enabled boolean [note: 'Indicates whether this fulfillment node is integrated with the Warehouse Management System (WMS) for automated pick/pack/ship workflows. True if WMS integration is active; false if manual processes are used.']

  Note: 'Master record designating a store location as a Ship-from-Store (SFS), dark store, or MFC fulfillment node within the omnichannel network. Captures node ID, store location reference, node type, daily fulfillment capacity (orders/day), active picking zones within the store, assigned carrier accounts, same-day/next-day cutoff times, geographic service radius, supported delivery SLAs, and node activation status. This is the SSOT for store-as-fulfillment-node configuration consumed by OMS and fulfillment domains. The fulfillment domain owns execution (pick/pack/ship); this product owns the node capability and capacity definition.'
}

Table store.cluster_membership {
  cluster_membership_id varchar [pk, note: 'Unique identifier for this store cluster membership record. Primary key for the association.']
  cluster_id varchar [note: 'Foreign key linking to the store cluster. Identifies which logical cluster this membership record associates with the store location.']
  location_id varchar [note: 'Foreign key linking to the store location. Identifies which physical retail location is a member of the cluster.']
  assigned_by varchar [note: 'Name or identifier of the user, system, or process that created this cluster membership assignment. Used for audit trail and accountability.']
  assignment_effective_date date [note: 'Date when this cluster assignment becomes operationally effective for planning and execution purposes. May differ from membership_start_date to support advance planning and staged rollouts.']
  assignment_method varchar [note: 'How the store was assigned to this cluster (manual, algorithmic, rule_based).']
  assignment_notes varchar [note: 'Free-text notes providing additional context about this cluster membership assignment. Used to document special circumstances, exceptions, or business rationale.']
  assignment_status varchar [note: 'Current lifecycle status of this cluster membership. Active = currently in operational use; Pending = scheduled for future activation; Suspended = temporarily inactive; Expired = past membership; Overridden = superseded by manual reassignment.']
  cluster_assignment_reason varchar [note: 'Business justification or methodology for assigning this store to this cluster. Examples: algorithmic segmentation based on sales patterns, manual override by merchandising team, geographic proximity, demographic alignment, performance tier classification.']
  confidence_score varchar [note: 'Confidence score of algorithmic cluster assignment.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  effective_end_date date [note: 'End date of cluster membership.']
  effective_start_date date [note: 'Start date of cluster membership.']
  is_primary_cluster boolean [note: 'Indicates whether this cluster is the primary cluster assignment for this store location within this cluster type. Used when a store belongs to multiple clusters of the same type and one must be designated as primary for operational purposes.']
  last_modified_by varchar [note: 'User or system identifier that last modified this cluster membership record. Used for audit trail and accountability.']
  last_modified_date timestamp [note: 'Timestamp of the most recent modification to this cluster membership record. Used for audit trail and change tracking.']
  last_modified_timestamp timestamp [note: 'Record last modification timestamp.']
  membership_end_date date [note: 'Date when this store location ceased to be a member of this cluster. Null indicates current active membership. Used for historical analysis of cluster composition changes.']
  membership_start_date date [note: 'Date when this store location became a member of this cluster. Supports temporal tracking of cluster membership changes over time.']
  membership_status varchar [note: 'Status of membership (active, inactive, pending).']
  override_flag boolean [note: 'Whether this assignment was manually overridden.']
  override_reason varchar [note: 'Reason for manual override of cluster assignment.']
  primary_flag boolean [note: 'Whether this is the primary cluster for the location.']
  weight varchar [note: 'Weight or degree of membership for fuzzy clustering.']

  Note: 'This association product represents the membership relationship between store clusters and store locations. It captures the assignment of individual stores to logical clusters used for localized assortment planning, zone pricing, promotional targeting, and operational benchmarking. Each record links one store cluster to one store location with effective dates, primary cluster designation, assignment reason, and status that exist only in the context of this relationship. Supports concurrent membership in multiple overlapping clustering schemes (assortment clusters, pricing zones, demographic clusters, performance tiers, climate zones).. Existence Justification: Store cluster membership is a genuine operational M:N relationship in retail. Retailers actively manage multiple concurrent clustering schemes (assortment clusters, pricing zones, demographic segments, performance tiers, climate zones) where a single store participates in multiple clusters simultaneously, and each cluster contains multiple stores. The relationship has its own lifecycle (effective dates), business rules (primary cluster designation), and operational significance (drives localized merchandising, pricing, and planning decisions).'
}

Table store.sales_territory {
  sales_territory_id varchar [pk, note: 'Primary key for sales_territory']
  parent_sales_territory_id varchar [note: 'Self-referencing FK on sales_territory (parent_sales_territory_id)']
  parent_territory_id varchar [note: 'Reference to the parent sales territory in a hierarchical territory structure. Null for top-level territories.']
  region_id varchar [note: 'Reference to the geographic region this territory belongs to, for regional sales reporting and management.']
  annual_revenue_target decimal(18,2) [note: 'Target annual revenue goal for this sales territory, used for performance measurement and incentive compensation.']
  boundary_definition varchar [note: 'Textual or structured definition of territory boundaries (e.g., list of counties, postal codes, geographic coordinates, or natural boundaries).']
  competition_level varchar [note: 'Assessment of competitive intensity within this sales territory: low (few competitors), moderate (balanced), high (many competitors), very_high (saturated market), monopoly (single dominant player).']
  country_code varchar [note: 'Three-letter ISO country code representing the primary country for this sales territory (e.g., USA, CAN, GBR, DEU).']
  created_timestamp timestamp [note: 'Timestamp when this sales territory record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO currency code for financial targets and reporting in this territory (e.g., USD, CAD, EUR, GBP).']
  customer_count varchar [note: 'Number of active customers assigned to this sales territory. Used for territory balancing and performance benchmarking.']
  effective_end_date date [note: 'Date when this sales territory ceases or ceased to be active. Null for open-ended territories.']
  effective_start_date date [note: 'Date when this sales territory becomes or became active and operational for sales assignments and reporting.']
  household_count varchar [note: 'Total number of households within this sales territory. Used for consumer market analysis and targeting.']
  language_code varchar [note: 'Primary language code for customer communication and marketing in this territory (e.g., en, es, fr, de).']
  last_modified_by varchar [note: 'Username or identifier of the user who last modified this sales territory record.']
  last_modified_timestamp timestamp [note: 'Timestamp when this sales territory record was last updated or modified.']
  market_potential_score decimal(5,2) [note: 'Quantitative score (0-100) representing the market opportunity and growth potential of this territory, based on demographics, competition, and economic indicators.']
  median_household_income decimal(12,2) [note: 'Median annual household income within this territory, used for demographic profiling and product assortment planning.']
  notes varchar [note: 'Free-form notes and comments about this sales territory, including special instructions, historical context, or operational considerations.']
  population_size varchar [note: 'Total population count within the geographic boundaries of this sales territory. Used for market sizing and penetration analysis.']
  postal_code_range_end varchar [note: 'Ending postal code for territories defined by postal code ranges. Used for geographic territory assignment.']
  postal_code_range_start varchar [note: 'Starting postal code for territories defined by postal code ranges. Used for geographic territory assignment.']
  priority_tier varchar [note: 'Strategic priority classification for resource allocation and management focus. Tier 1/strategic territories receive highest investment; tier 3/maintenance receive baseline support.']
  sales_channel varchar [note: 'Primary sales channel served by this territory: retail (physical stores), wholesale (bulk/distributor), ecommerce (online), B2B (business customers), B2C (consumers), omnichannel (integrated).']
  sales_rep_count varchar [note: 'Number of sales representatives currently assigned to this territory. Used for capacity planning and workload balancing.']
  sales_territory_status varchar [note: 'Current lifecycle status of the sales territory. Active territories are operational; inactive are closed; pending are awaiting activation; suspended are temporarily halted; archived are historical; planned are future territories.']
  state_province_code varchar [note: 'State or province code for territories defined at sub-national level (e.g., CA, TX, ON, QC).']
  store_count varchar [note: 'Number of retail stores located within this sales territory. Used for territory sizing and resource allocation.']
  territory_code varchar [note: 'Unique business identifier code for the sales territory, used for external reference and reporting.']
  territory_description varchar [note: 'Detailed textual description of the sales territory, including geographic boundaries, key characteristics, strategic focus, and special considerations.']
  territory_level varchar [note: 'Numeric level in the territory hierarchy (e.g., 1=National, 2=Regional, 3=District, 4=Local). Used for rollup reporting and organizational structure.']
  territory_name varchar [note: 'Human-readable name of the sales territory (e.g., \'Northeast Region\', \'California Metro\', \'EMEA South\').']
  territory_type varchar [note: 'Classification of the territory segmentation strategy: geographic (region-based), account-based (customer segments), product-based (product lines), channel-based (retail/wholesale/online), hybrid (combination), or strategic (key accounts).']
  time_zone varchar [note: 'Primary time zone for this sales territory (e.g., America/New_York, America/Los_Angeles, Europe/London). Used for scheduling and reporting.']
  created_by varchar [note: 'Username or identifier of the user who created this sales territory record.']

  Note: 'Master reference table for sales_territory. Referenced by sales_territory_id.'
}

Table store.region {
  region_id varchar [pk, note: 'Primary key for region']
  parent_region_id varchar [note: 'Self-referencing identifier pointing to the parent region in the regional hierarchy (e.g., a district rolls up to a region, which rolls up to a division). Null for top-level regions.']
  price_zone_id varchar [note: 'Foreign key linking to pricing.price_zone. Business justification: Regions map to price zones for regional pricing strategy governance and zone assignment reporting. The existing \'price_zone_code\' on region is a denormalized representation of the price_zone entity. A']
  climate_zone varchar [note: 'Köppen climate classification zone for this region. Used by merchandising and buying teams to align seasonal assortment planning, planogram (POG) configurations, and inventory allocation to regional climate patterns.']
  code varchar [note: 'Short, externally-known alphanumeric code uniquely identifying the region (e.g., EMEA-WEST, US-SE, APAC-AU). Used in reporting, system integrations, and store master data.']
  comp_sales_base_year varchar [note: 'The fiscal year used as the baseline for Same-Store Sales (SSS / Comp Sales) calculations in this region. Stores must have been open for at least 12 months relative to this base year to qualify as comparable.']
  country_code varchar [note: 'ISO 3166-1 alpha-3 three-letter country code for the primary country this region is associated with (e.g., USA, GBR, AUS). For multi-country regions, reflects the primary operating country.']
  country_name varchar [note: 'Full English name of the country associated with this region (e.g., United States of America, United Kingdom). Denormalized for reporting convenience.']
  created_timestamp timestamp [note: 'Timestamp when this region record was first created in the system. Used for audit trail and data lineage tracking.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the primary trading currency used in this region (e.g., USD, GBP, EUR, AUD). Used for regional financial reporting and comp-sales calculations.']
  description varchar [note: 'Free-text narrative description of the region, including geographic boundaries, key markets, strategic importance, and any operational notes relevant to store management and planning teams.']
  division_name varchar [note: 'Name of the top-level business division this region belongs to (e.g., North America Retail, EMEA Wholesale). Supports divisional P&L and comp-sales (Same-Store Sales) reporting.']
  effective_end_date date [note: 'Date on which this region definition ceased to be operationally effective. Null for currently active regions. Supports slowly changing dimension (SCD) patterns for historical store reporting.']
  effective_start_date date [note: 'Date from which this region definition became operationally effective. Used for temporal queries and historical comp-sales (Same-Store Sales) analysis.']
  fiscal_calendar_code varchar [note: 'Code referencing the fiscal calendar applied to this region for financial reporting (e.g., 4-4-5, 4-5-4, Gregorian). Ensures correct period alignment for regional P&L and comp-sales reporting.']
  gdp_index decimal(10,4) [note: 'Indexed GDP value for the region relative to a global or national baseline (baseline = 1.0000). Used by finance and strategy teams for market potential scoring, store investment prioritization, and regional P&L benchmarking.']
  hierarchy_level varchar [note: 'Numeric depth of this region within the regional hierarchy. Level 1 is the top (e.g., global or continental division); higher numbers represent finer granularity (e.g., district or zone). Used for roll-up aggregations in comp-sales and P&L reporting.']
  hierarchy_path varchar [note: 'Materialized path string representing the full ancestry of the region from root to current node (e.g., /GLOBAL/AMERICAS/US/SOUTHEAST). Enables efficient subtree queries without recursive CTEs.']
  is_franchise_territory boolean [note: 'Indicates whether this region operates under a franchise model (True) or is directly operated by the retailer (False). Drives franchise fee calculations, royalty reporting, and operational governance rules.']
  is_pilot_region boolean [note: 'Indicates whether this region is currently designated as a pilot or test market (True). Pilot regions receive new store formats, planogram configurations, or promotional strategies before broader rollout.']
  locale_code varchar [note: 'IETF BCP 47 locale code representing the primary language and regional formatting conventions for this region (e.g., en_US, fr_FR, de_DE). Drives localization of POS displays, receipts, and digital communications.']
  name varchar [note: 'Full human-readable name of the region as used in business reporting and store operations (e.g., Southeast United States, Western Europe).']
  notes varchar [note: 'Operational notes or annotations added by regional planning or store development teams. May include boundary change history, pending restructuring notes, or special operational considerations.']
  omnichannel_enabled boolean [note: 'Indicates whether stores in this region are enabled for omnichannel fulfillment capabilities such as ship-from-store, click-and-collect (BOPIS), and dark store / micro-fulfillment center (MFC) operations.']
  population_size_band varchar [note: 'Categorical band representing the total population served by this region. Used for market sizing, store network planning, and trade area analysis. Micro: <500K; Small: 500K–2M; Medium: 2M–10M; Large: 10M–50M; Mega: >50M.']
  region_status varchar [note: 'Current lifecycle status of the region record. Active regions are operational and contain live stores. Planned regions are being set up. Inactive regions have been decommissioned. Archived regions are retained for historical reporting only.']
  region_type varchar [note: 'Classification of the region\'s primary purpose. Geographic regions reflect physical territory groupings; operational regions reflect store management hierarchies; sales regions align to revenue reporting; franchise regions define franchisee territories; tax and compliance regions reflect regulatory jurisdictions.']
  regional_director_email varchar [note: 'Business email address of the Regional Director accountable for this region. Used for operational escalations, store performance alerts, and regional P&L distribution.']
  regional_director_name varchar [note: 'Name of the Regional Director or VP of Retail Operations accountable for this region. Stored as a reference label for operational communications and org chart reporting; not a PII-sensitive personal record.']
  regional_director_phone varchar [note: 'Business phone number of the Regional Director accountable for this region. Used for operational escalations and emergency store communications.']
  regulatory_zone varchar [note: 'Identifier for the regulatory compliance zone applicable to this region (e.g., GDPR-EU, CCPA-US-CA, PDPA-TH). Drives data privacy controls, product labelling requirements, and consumer protection rule enforcement.']
  sales_channel_scope varchar [note: 'Primary sales channel model operating within this region. Determines which store formats, fulfillment models (ship-from-store, dark store, MFC), and digital commerce capabilities are active in the region.']
  ship_from_store_enabled boolean [note: 'Indicates whether stores in this region are authorized to fulfill online orders by shipping directly from store inventory. Distinct from general omnichannel enablement; drives fulfillment routing logic.']
  store_count varchar [note: 'Number of physical retail locations (stores) currently assigned to this region. Maintained as a denormalized count for operational dashboards and regional planning. Not a computed aggregate — updated by store master data management processes.']
  tax_jurisdiction_code varchar [note: 'Code identifying the primary tax jurisdiction governing retail transactions in this region. Used for tax calculation, compliance reporting, and VAT/GST/sales-tax configuration on POS systems.']
  timezone varchar [note: 'IANA timezone identifier for the primary timezone of this region (e.g., America/New_York, Europe/London). Used for scheduling store operations, promotional windows, and footfall reporting.']
  updated_timestamp timestamp [note: 'Timestamp when this region record was most recently modified. Used for change detection, incremental ETL processing, and audit trail.']

  Note: 'Master reference table for region. Referenced by region_id.'
}

Table pricing.price_list {
  price_list_id varchar [pk, note: 'Unique surrogate identifier for the price list record. Primary key for the pricing.price_list data product in the Databricks Silver Layer.']
  promo_calendar_id varchar [note: 'Foreign key linking to promotion.promo_calendar. Business justification: Price lists are activated and deactivated in alignment with the promotional calendar. Retail pricing operations require calendar-driven price list scheduling — linking price_list to promo_calendar ena']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Retailers create campaign-specific price lists (e.g., Black Friday price list, loyalty event price list) tied directly to a promotional campaign. This link supports campaign-level price list managemen']
  approval_status varchar [note: 'Workflow approval state of the price list within Oracle RPM\'s pricing governance process. PENDING = submitted for approval; APPROVED = authorized for activation; REJECTED = returned for revision; UNDER_REVIEW = in active review by pricing committee. Price lists must be APPROVED before transitioning to ACTIVE status.']
  approved_by varchar [note: 'Name or employee identifier of the pricing manager or director who approved this price list for activation. Supports audit trail requirements for pricing governance and SOX compliance. Sourced from Oracle RPM workflow approval records.']
  approved_timestamp timestamp [note: 'Date and time when the price list was formally approved by the pricing authority in Oracle RPM. Part of the price change audit trail required for pricing governance and regulatory compliance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  base_margin_pct decimal(5,2) [note: 'Target gross margin percentage applied as the baseline for cost-plus pricing calculations within this price list. Expressed as a percentage (e.g., 35.00 = 35%). Used in GMROI (Gross Margin Return on Investment) analysis and OTB (Open to Buy) planning. Confidential as it reveals internal margin strategy.']
  channel varchar [note: 'The retail channel(s) to which this price list applies. IN_STORE = physical POS; ECOMMERCE = Salesforce Commerce Cloud digital storefront; MOBILE = mobile app; BOPIS = Buy Online Pick Up In Store; CATALOG = print/digital catalog; ALL = omnichannel. Drives channel-specific price resolution logic.']
  code varchar [note: 'Externally-known alphanumeric code uniquely identifying the price list within Oracle Retail Price Management (RPM) and SAP S/4HANA SD module. Used as the business key in EDI transactions, POS price resolution, and e-commerce checkout. Examples: EDLP_BASE, HILO_PROMO_Q4, ECOM_MEMBER.']
  competitive_index decimal(5,2) [note: 'Ratio of this price list\'s average price level relative to key competitors, expressed as an index (e.g., 100.00 = price parity; 95.00 = 5% below market; 105.00 = 5% above market). Used in competitive pricing strategy analysis and EDLP positioning validation.']
  country_code varchar [note: 'ISO 3166-1 alpha-3 country code indicating the country in which this price list is applicable (e.g., USA, CAN, GBR). Supports international retail operations and country-specific pricing compliance requirements.']
  created_timestamp timestamp [note: 'Date and time when this price list record was first created in the system of record (Oracle RPM or Informatica MDM). Part of the mandatory audit trail for pricing governance and SOX compliance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code in which all prices within this price list are denominated (e.g., USD, CAD, GBP, EUR). Ensures correct monetary interpretation at POS and in financial reporting under FASB ASC 606.']
  department_code varchar [note: 'Merchandise department code within the retail hierarchy to which this price list is scoped, as defined in Oracle Retail Merchandising System (ORMS). Enables department-level pricing governance and category management alignment.']
  description varchar [note: 'Detailed business description of the price list\'s purpose, scope, and intended use. Captures the pricing strategy rationale (e.g., EDLP everyday low price baseline, Hi-Lo promotional cadence, competitive response pricing).']
  division_code varchar [note: 'Code identifying the retail division or business unit (e.g., GROCERY, APPAREL, ELECTRONICS, HOUSEHOLD) to which this price list is scoped. Enables division-specific pricing governance and GMROI tracking by merchandise division.']
  effective_end_date date [note: 'The calendar date after which this price list is no longer active for price resolution. Nullable for open-ended price lists (e.g., permanent EDLP base). When populated, the price list expires at end of this date. Format: yyyy-MM-dd.']
  effective_start_date date [note: 'The calendar date from which this price list becomes active and eligible for price resolution at POS and e-commerce checkout. Aligns with Oracle RPM effective dating and SAP S/4HANA SD pricing condition validity. Format: yyyy-MM-dd.']
  external_reference_code varchar [note: 'The price list identifier as it exists in the originating source system (e.g., Oracle RPM price list ID, SAP SD pricing condition group). Enables cross-system reconciliation and EDI integration with supplier systems.']
  is_default boolean [note: 'Indicates whether this price list serves as the default fallback price list when no other price list matches the resolution criteria at POS or e-commerce checkout. Only one price list per channel and price zone should be flagged as default. True = default; False = non-default.']
  is_taxable boolean [note: 'Indicates whether prices in this price list are tax-inclusive (True) or tax-exclusive (False). Tax-inclusive pricing is common in international markets; tax-exclusive is standard in US retail. Drives tax calculation logic at POS and e-commerce checkout.']
  list_type varchar [note: 'Classification of the pricing strategy this list represents. EDLP = Everyday Low Price stable baseline; HI_LO = High-Low promotional cadence; PROMOTIONAL = time-limited campaign price; CLEARANCE = markdown/end-of-life pricing; CLUB_MEMBER = loyalty or membership tier pricing; COMPETITIVE = market-response pricing. Drives price resolution logic at POS and e-commerce checkout. [ENUM-REF-CANDIDATE: EDLP|HI_LO|PROMOTIONAL|CLEARANCE|CLUB_MEMBER|COMPETITIVE|COST_PLUS|DYNAMIC — promote to reference product]']
  loyalty_tier_code varchar [note: 'Code identifying the customer loyalty tier (e.g., GOLD, PLATINUM, CLUB_MEMBER) for which this price list is exclusively applicable. Null for price lists that apply to all customers regardless of loyalty status. Links to the CRM loyalty program configuration for member-specific pricing.']
  markdown_pct decimal(5,2) [note: 'Default markdown percentage applied to AUR (Average Unit Retail) for clearance or promotional price lists. Expressed as a percentage reduction from the regular retail price (e.g., 20.00 = 20% off). Drives markdown optimization and end-of-season clearance planning.']
  max_selling_price decimal(18,4) [note: 'Ceiling price above which no SKU within this price list may be sold, ensuring competitive positioning and consumer protection compliance. Expressed in the price list\'s currency. Used in dynamic pricing guardrails to prevent price gouging.']
  min_selling_price decimal(18,4) [note: 'Floor price below which no SKU within this price list may be sold, protecting minimum margin thresholds and preventing below-cost selling. Enforced at POS and e-commerce checkout via Oracle RPM price guardrails. Expressed in the price list\'s currency.']
  name varchar [note: 'Human-readable name of the price list as displayed in Oracle RPM and merchandising systems. Examples: \'EDLP Base Price List\', \'Hi-Lo Promotional Q4 2024\', \'E-Commerce Club Member Pricing\'.']
  next_review_date date [note: 'Scheduled date for the next pricing review of this price list by the category management or pricing team. Used to trigger review workflows in Oracle RPM and ensure timely price updates aligned with market conditions and promotional calendars.']
  notes varchar [note: 'Free-text field for additional business context, pricing committee decisions, exceptions, or operational notes associated with this price list. Captured in Oracle RPM and surfaced for pricing analysts and category managers.']
  price_list_status varchar [note: 'Current lifecycle state of the price list within Oracle RPM. DRAFT = under construction, not yet approved; ACTIVE = currently in use for price resolution; SUSPENDED = temporarily deactivated; EXPIRED = past effective end date; ARCHIVED = retired and no longer available for assignment.']
  priority_rank varchar [note: 'Numeric rank determining the order of precedence when multiple price lists are applicable to a single SKU at POS or e-commerce checkout. Lower values indicate higher priority (e.g., 1 = highest priority). Critical for price resolution logic in omnichannel environments where EDLP, promotional, and member prices may overlap.']
  review_frequency varchar [note: 'Scheduled cadence at which this price list is reviewed and potentially updated by the pricing team. Drives pricing governance workflows in Oracle RPM. DAILY is typical for dynamic pricing; WEEKLY for Hi-Lo promotional; QUARTERLY for EDLP base reviews. [ENUM-REF-CANDIDATE: DAILY|WEEKLY|BIWEEKLY|MONTHLY|QUARTERLY|ANNUALLY|AD_HOC — 7 candidates stripped; promote to reference product]']
  rounding_rule varchar [note: 'Rule applied to computed prices within this price list to produce consumer-facing shelf prices. NEAREST_CENT = standard rounding; ROUND_UP = always round up; ROUND_DOWN = always round down; CHARM_PRICING = round to nearest .99 or .95 (psychological pricing); NONE = no rounding applied. Configured in Oracle RPM price calculation engine.']
  source_system_code varchar [note: 'Code identifying the operational system of record from which this price list record originated. RPM = Oracle Retail Price Management; SAP_SD = SAP S/4HANA Sales & Distribution; SFCC = Salesforce Commerce Cloud; ORMS = Oracle Retail Merchandising System; MANUAL = manually created. Supports data lineage and MDM reconciliation.']
  updated_timestamp timestamp [note: 'Date and time when this price list record was most recently modified. Tracks the last change event for audit trail purposes and supports incremental data loading in the Databricks Silver Layer. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  version_number varchar [note: 'Monotonically increasing version counter tracking revisions to this price list. Incremented each time the price list is modified and re-approved. Supports price change audit trail requirements and enables rollback to prior pricing versions.']

  Note: 'Master record defining named price lists (e.g., EDLP base, Hi-Lo promotional, e-commerce, club member) with effective date ranges, currency, applicable channel, and price zone scope. Serves as the top-level pricing container from which individual SKU prices are derived. Each price list represents a distinct pricing context used in price resolution at POS and e-commerce checkout.'
}

Table pricing.price_zone {
  price_zone_id varchar [pk, note: 'Unique surrogate identifier for a price zone record in the Oracle Retail Price Management (RPM) system. Serves as the primary key for all zone-level pricing governance and store cluster assignments.']
  parent_zone_price_zone_id varchar [note: 'Self-referencing identifier pointing to a parent price zone in a zone hierarchy. Enables multi-tier zone structures (e.g., a national zone containing regional sub-zones). Null for top-level zones with no parent. Used in Oracle Retail Price Management (RPM) zone inheritance for pricing rule cascades.']
  base_price_multiplier decimal(6,4) [note: 'Zone-level multiplier applied to the national base price to derive the zone-specific retail price. A value of 1.0000 means no adjustment; 0.9500 means a 5% reduction; 1.0500 means a 5% premium. Used in Oracle Retail Price Management (RPM) zone pricing calculations to support Hi-Lo and EDLP strategies.']
  channel_applicability varchar [note: 'Defines which retail channels this price zone governs. \'in_store\' applies only to physical POS (Point of Sale) transactions; \'ecommerce\' applies to Salesforce Commerce Cloud digital orders; \'omnichannel\' applies uniformly across all channels supporting BOPIS and ROPIS (Reserve Online Pick Up In Store); \'wholesale\' applies to B2B pricing.']
  competitive_index decimal(5,2) [note: 'Numeric index (0.00–999.99) representing the relative competitive pricing intensity of this zone compared to the baseline zone (index = 100.00). Values above 100 indicate a more price-competitive market requiring lower AUR (Average Unit Retail). Sourced from competitive intelligence feeds integrated with Oracle Retail Price Management (RPM).']
  country_code varchar [note: 'ISO 3166-1 alpha-3 country code identifying the primary country of operation for this price zone. Supports multi-country retail operations and regulatory compliance with FTC pricing transparency requirements. Example: \'USA\', \'CAN\', \'GBR\'.']
  created_timestamp timestamp [note: 'The date and time when this price zone record was first created in the Databricks Silver Layer, sourced from Oracle Retail Price Management (RPM) or Informatica MDM. Supports data lineage, audit trail, and GDPR/CCPA data governance requirements.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code governing all price points within this zone. Ensures consistent monetary representation across SAP S/4HANA FI/CO and Oracle Retail Price Management (RPM). Example: \'USD\', \'CAD\', \'GBP\'.']
  effective_end_date date [note: 'The calendar date on which this price zone expires and ceases to govern pricing for assigned stores. Null indicates an open-ended zone with no planned expiry. Used in zone reassignment workflows and markdown audit trails.']
  effective_start_date date [note: 'The calendar date on which this price zone becomes active and its pricing rules begin governing assigned stores or fulfillment nodes. Used in Open-to-Buy (OTB) planning and markdown optimization scheduling.']
  fulfillment_node_count varchar [note: 'Current number of e-commerce fulfillment nodes (dark stores, micro-fulfillment centers, distribution centers) assigned to this price zone. Supports omnichannel pricing governance for BOPIS (Buy Online Pick Up In Store) and Ship-from-Store (SFS) operations.']
  is_competitive_zone boolean [note: 'Indicates whether this zone is subject to active competitive price monitoring and response rules. When True, Oracle Retail Price Management (RPM) applies competitive pricing overrides based on competitor intelligence feeds, enabling dynamic Hi-Lo or EDLP adjustments.']
  is_default_zone boolean [note: 'Indicates whether this zone serves as the fallback default pricing zone when a store or fulfillment node has no explicit zone assignment. Only one zone per country should carry this flag as True. Prevents pricing gaps in Oracle Retail Price Management (RPM).']
  is_ecommerce_enabled boolean [note: 'Indicates whether this price zone\'s pricing rules are applied to digital commerce channels via Salesforce Commerce Cloud. When True, zone prices are broadcast to the e-commerce storefront and govern online GMV (Gross Merchandise Value) pricing.']
  last_review_date date [note: 'The most recent calendar date on which this price zone\'s strategy, competitive index, and store assignments were formally reviewed and validated by the pricing governance team. Supports audit trail requirements and zone maintenance SLA (Service Level Agreement) tracking.']
  market_tier varchar [note: 'Market size and competitive intensity classification for the zone. Tier 1 represents major metropolitan markets with high competitive density; Tier 4 represents rural or low-competition markets. Drives GMROI (Gross Margin Return on Investment) targets and markdown depth thresholds per zone.']
  max_markdown_pct decimal(5,2) [note: 'The maximum allowable markdown depth (as a percentage of the original retail price) permitted for any SKU within this zone. Governs markdown optimization rules in Oracle Retail Price Management (RPM) to protect zone-level profitability and prevent excessive sell-through distortion.']
  min_margin_pct decimal(5,2) [note: 'The minimum acceptable gross margin percentage (COGS-based) enforced for all SKUs priced within this zone. Prevents markdown rules from eroding profitability below the zone\'s GMROI (Gross Margin Return on Investment) floor. Expressed as a percentage (e.g., 18.50 = 18.5%).']
  next_review_date date [note: 'Scheduled calendar date for the next formal review of this price zone\'s strategy and assignments. Calculated from last_review_date and review_frequency. Used to trigger pricing governance workflow tasks in Oracle Retail Price Management (RPM).']
  override_allowed boolean [note: 'Indicates whether store managers or regional pricing teams are permitted to apply local price overrides beyond the zone\'s standard pricing rules. When False, all prices are centrally governed with no local deviation permitted. Supports pricing compliance and FTC advertising standards.']
  price_approval_required boolean [note: 'Indicates whether price changes within this zone require explicit managerial approval before activation in Oracle Retail Price Management (RPM). Supports pricing governance workflows and audit trail requirements for high-sensitivity competitive or promotional zones.']
  price_change_lead_days varchar [note: 'Minimum number of calendar days required between a price change approval and its effective implementation at POS (Point of Sale) for stores in this zone. Accounts for shelf label reprinting, planogram updates, and EDI broadcast lead times to store systems.']
  pricing_strategy varchar [note: 'The primary pricing strategy governing all SKUs within this zone. EDLP (Everyday Low Price) maintains stable low prices; Hi-Lo (High-Low) uses promotional spikes and markdowns; cost_plus applies a fixed margin over COGS; competitive mirrors or undercuts competitor prices; dynamic adjusts prices algorithmically based on demand signals from SAP Customer Activity Repository (CAR).']
  region_code varchar [note: 'Internal geographic region code used to group price zones for regional merchandise planning and Comp Sales (Comparable Store Sales) reporting. Aligns with Oracle Retail Merchandising System (ORMS) regional hierarchy. Example: \'NE\', \'SE\', \'MW\', \'WEST\'.']
  review_frequency varchar [note: 'Scheduled frequency at which this price zone\'s pricing strategy, competitive index, and store assignments are reviewed and potentially updated. Drives Oracle Retail Price Management (RPM) workflow scheduling and category management calendar alignment.']
  rpm_zone_code varchar [note: 'Native zone identifier from Oracle Retail Price Management (RPM) source system. Preserved for cross-system reconciliation, EDI integration, and audit trail linkage back to the operational pricing system of record.']
  sap_pricing_condition_group varchar [note: 'SAP S/4HANA SD module pricing condition group code associated with this price zone. Used to apply zone-specific pricing conditions (VK11/VK12) in SAP for sales order pricing, ensuring consistency between Oracle RPM zone definitions and SAP transactional pricing.']
  store_count varchar [note: 'Current number of physical store locations assigned to this price zone. Used in zone-level Comp Sales (Comparable Store Sales) and SSS (Same-Store Sales) reporting. Updated automatically when store-to-zone assignments change.']
  tax_jurisdiction_code varchar [note: 'Code identifying the tax jurisdiction applicable to this price zone for sales tax calculation and FTC pricing transparency compliance. Maps to SAP S/4HANA FI/CO tax condition records. Example: \'US_NY_NYC\', \'US_CA_LA\'.']
  updated_timestamp timestamp [note: 'The date and time when this price zone record was most recently modified. Tracks zone attribute changes including strategy updates, multiplier adjustments, and status transitions. Essential for price change audit trail compliance and Informatica MDM golden record synchronization.']
  zone_code varchar [note: 'Externally-known alphanumeric code uniquely identifying the price zone within Oracle Retail Price Management (RPM) and SAP S/4HANA. Used in EDI transactions, pricing rule references, and cross-system integrations. Example: \'PZ_NORTHEAST_01\', \'COMP_URBAN_W\'.']
  zone_description varchar [note: 'Free-text business description of the price zone\'s purpose, geographic scope, competitive rationale, and any special pricing governance rules. Used by category management and merchandise planning teams for zone strategy documentation.']
  zone_hierarchy_level varchar [note: 'Numeric depth of this zone within the price zone hierarchy (1 = top-level national zone, 2 = regional zone, 3 = sub-regional or competitive cluster). Used to resolve pricing rule inheritance and override precedence in Oracle Retail Price Management (RPM).']
  zone_name varchar [note: 'Human-readable business name for the price zone used in reporting, planogram management, and pricing governance communications. Example: \'Northeast Competitive Urban Zone\', \'Rural EDLP Cluster South\'.']
  zone_status varchar [note: 'Current lifecycle status of the price zone within Oracle Retail Price Management (RPM). \'active\' zones are live and applied to store pricing; \'pending\' zones are approved but not yet effective; \'inactive\' zones are suspended; \'archived\' zones are retained for historical audit and markdown optimization analysis.']
  zone_type varchar [note: 'Categorical classification of the price zone indicating the market segmentation strategy applied. \'regional\' zones group stores by geography; \'competitive\' zones respond to local competitor pricing; \'urban\'/\'rural\' zones reflect demographic cost structures; \'omnichannel\' zones unify in-store and digital pricing; \'ecommerce\' zones apply exclusively to digital fulfillment nodes.']

  Note: 'Defines geographic or store-cluster pricing zones used to differentiate retail prices by market, region, or competitive environment. Each zone groups stores or fulfillment nodes sharing the same pricing strategy. Includes zone code, name, type (regional, competitive, urban/rural), effective dates, and zone-to-store/node membership assignments with assignment effective dates, expiry dates, assignment reasons, override flags, and historical tracking of zone reassignments.'
}

Table pricing.sku_price {
  sku_price_id varchar [pk, note: 'Unique surrogate identifier for each SKU-to-price-list-to-zone-to-channel binding record. Primary key of the sku_price data product in the Databricks Silver Layer.']
  cost_price_id varchar [note: 'Foreign key linking to pricing.cost_price. Business justification: SKU retail prices are based on cost prices for margin calculation. Adding cost_price_id FK links retail price to authoritative cost record. Removes cost_price DECIMAL as redundant with cost_price.land']
  price_list_id varchar [note: 'Reference to the price list under which this SKU price is governed. Supports multi-list resolution priority for EDLP, Hi-Lo, promotional, and clearance price lists.']
  price_zone_id varchar [note: 'Reference to the geographic or competitive price zone in which this price applies. Price zones enable regional pricing differentiation across store clusters and markets.']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: SKU prices are set at the campaign level for promotional pricing (e.g., campaign-specific retail prices). While sku_price links to promo_offer, the parent campaign link enables campaign-level price re']
  promo_offer_id varchar [note: 'Foreign key linking to promotion.promo_offer. Business justification: Promotional offers define temporary price adjustments at SKU level. Retailers must link offer mechanics to SKU price records to calculate promotional pricing, validate discount limits, and reconcile v']
  rule_id varchar [note: 'Foreign key linking to pricing.pricing_rule. Business justification: SKU prices may be calculated or adjusted by pricing rules (e.g., dynamic pricing rules, competitive response rules). Adding pricing_rule_id FK tracks which rule generated or last adjusted the price.']
  sku_id varchar [note: 'Reference to the product SKU for which this price record applies. Resolves to the canonical product master in the Product domain.']
  approval_status varchar [note: 'Workflow approval status of this price record within the Oracle Retail Price Management (RPM) pricing governance process. Only records in \'approved\' status are eligible for price resolution at POS and digital channels.']
  approved_by varchar [note: 'Username or employee identifier of the pricing manager who approved this price record in Oracle Retail Price Management (RPM). Required for price change audit trail and SOX compliance.']
  approved_timestamp timestamp [note: 'The date and time at which this price record was approved by the pricing manager. Part of the price change audit trail required for regulatory compliance and pricing governance.']
  channel_price_variance decimal(18,4) [note: 'The absolute price difference between this channel-specific price and the base in-store retail price for the same SKU, price list, and zone. Quantifies omnichannel price differentiation (e.g., e-commerce price vs. in-store price).']
  channel_price_variance_reason varchar [note: 'Business justification for any price variance between this channel price and the base retail price. Required for compliance with FTC pricing transparency guidelines and internal pricing governance. Examples: \'Online-only promotion\', \'Marketplace fee offset\', \'BOPIS incentive\'.']
  channel_type varchar [note: 'The retail channel for which this price applies. Supports omnichannel price resolution across in-store Point of Sale (POS), e-commerce, mobile app, marketplace, and Buy Online Pick Up In Store (BOPIS) channels.']
  competitive_price_ref decimal(18,4) [note: 'The competitor\'s observed price for this SKU that triggered a competitive match pricing action. Captured when price_type = \'competitive_match\'. Supports competitive pricing analytics and price index reporting.']
  competitor_name varchar [note: 'Name of the competitor whose price was used as the reference for a competitive match pricing action. Populated when price_type = \'competitive_match\'. Used in competitive pricing intelligence reporting.']
  created_timestamp timestamp [note: 'The date and time at which this SKU price record was first created in the Silver Layer data product. Part of the price change audit trail and data lineage tracking.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for all monetary price fields in this record (e.g., USD, CAD, GBP). Supports multi-currency retail operations across international markets.']
  effective_date date [note: 'The calendar date on which this SKU price becomes active and valid for use at Point of Sale (POS) and digital channels. Supports bi-temporal price management and scheduled price changes.']
  expiry_date date [note: 'The calendar date on which this SKU price record expires and is no longer valid. Null indicates an open-ended price with no scheduled expiry. Used for Hi-Lo promotional price windows and clearance event management.']
  gross_margin_pct decimal(7,4) [note: 'Current gross margin percentage for this SKU at the current retail price, accounting for any markdowns applied. Calculated as (retail_price - cost_price) / retail_price * 100. Drives GMROI (Gross Margin Return on Investment) reporting.']
  initial_markup_pct decimal(7,4) [note: 'The Initial Markup (IMU) percentage calculated as (retail_price - cost_price) / retail_price * 100. Represents the planned gross margin at the time of price setting before any markdowns.']
  is_dynamic_pricing_enabled boolean [note: 'Indicates whether dynamic pricing rules are active for this SKU in this price list, zone, and channel context. When True, the price may be algorithmically adjusted within price_floor and price_ceiling bounds based on demand signals from SAP Customer Activity Repository (CAR).']
  is_price_locked boolean [note: 'Indicates whether this price record is locked and protected from automated price changes or markdown optimization algorithms. When True, the price can only be changed through a manual approval workflow in Oracle Retail Price Management (RPM).']
  markdown_amount decimal(18,4) [note: 'The absolute currency amount by which the original retail price has been reduced (markdown). Markdown = original_retail_price - retail_price. Used for markdown optimization and P&L (Profit and Loss) reporting.']
  markdown_pct decimal(7,4) [note: 'The percentage reduction from the original retail price to the current retail price. Markdown% = (original_retail_price - retail_price) / original_retail_price * 100. Supports markdown depth analysis and clearance optimization.']
  min_advertised_price decimal(18,4) [note: 'The Minimum Advertised Price (MAP) floor set by the supplier or brand for this SKU. The retail_price must not be advertised below this threshold. Enforced for compliance with supplier MAP agreements and FTC advertising standards.']
  original_retail_price decimal(18,4) [note: 'The initial retail price at which the SKU was first offered for sale in this zone and channel, prior to any markdowns or price changes. Used for markdown optimization and sell-through rate analysis.']
  price_ceiling decimal(18,4) [note: 'The maximum allowable retail price for this SKU in this zone and channel. Prevents price gouging and ensures compliance with consumer protection regulations. Used in dynamic pricing guardrails.']
  price_change_reason varchar [note: 'Business reason code or description explaining why this price was set or changed. Examples: \'Competitive match\', \'Seasonal markdown\', \'Clearance\', \'Cost increase\', \'Promotional event\'. Supports price change audit trail and markdown optimization analysis.']
  price_floor decimal(18,4) [note: 'The minimum allowable retail price for this SKU in this zone and channel, below which the price cannot be set without executive override. Protects gross margin and prevents below-cost selling. Distinct from MAP which is a supplier-imposed advertising constraint.']
  price_per_unit_display decimal(18,4) [note: 'The normalized price per standard unit (e.g., price per 100g, price per litre) used for shelf-edge price comparison display. Required by consumer protection regulations for grocery and FMCG categories to enable fair price comparison.']
  price_per_unit_uom varchar [note: 'The unit of measure denominator for the price_per_unit_display field (e.g., \'100G\', \'1L\', \'1OZ\'). Required alongside price_per_unit_display for regulatory shelf-edge unit pricing compliance.']
  price_resolution_priority varchar [note: 'Numeric priority rank used by the price resolution engine to determine which price list takes precedence when multiple price lists apply to the same SKU-zone-channel combination. Lower integer = higher priority. Drives POS and digital channel price resolution logic.']
  price_type varchar [note: 'Classification of the pricing strategy applied to this SKU-price-list-zone-channel binding. Supports EDLP (Everyday Low Price), Hi-Lo (High-Low Pricing Strategy), clearance, competitive match, markdown, and promotional pricing. [ENUM-REF-CANDIDATE: edlp|hi_lo|clearance|competitive_match|markdown|promotional — promote to reference product]']
  retail_price decimal(18,4) [note: 'The current regular retail selling price for the SKU in this price list, zone, and channel context. Represents the Average Unit Retail (AUR) — the price a customer pays before any promotional discount or markdown is applied.']
  source_system_code varchar [note: 'Code identifying the operational system of record from which this price record originated. Supports data lineage tracking in the Databricks Silver Layer. Values: RPM = Oracle Retail Price Management, SAP = SAP S/4HANA, ORMS = Oracle Retail Merchandising System, SFCC = Salesforce Commerce Cloud, CAR = SAP Customer Activity Repository.']
  source_system_price_code varchar [note: 'The native price record identifier from the originating operational system (e.g., Oracle RPM Price Event ID, SAP condition record number). Enables bi-directional traceability between the Silver Layer and the system of record for audit and reconciliation.']
  tax_code varchar [note: 'Tax classification code applied to this SKU for VAT, GST, or sales tax calculation at Point of Sale (POS). Sourced from SAP S/4HANA FI/CO tax configuration. Determines the applicable tax rate for price display and checkout.']
  uom_code varchar [note: 'The unit of measure for which the retail_price applies (e.g., EA = Each, KG = Kilogram, LB = Pound, L = Litre). Critical for price-per-unit display compliance and weight-based pricing at POS. [ENUM-REF-CANDIDATE: EA|KG|LB|L|ML|M|FT|OZ|PK|CS — 10 candidates stripped; promote to reference product]']
  updated_timestamp timestamp [note: 'The date and time at which this SKU price record was last modified in the Silver Layer data product. Tracks price change events and supports audit trail requirements for pricing governance.']

  Note: 'Authoritative current and historical retail price for each SKU resolved by price list, price zone, and channel. Captures regular retail price (AUR), cost reference, initial markup (IMU), gross margin percentage, price type (EDLP, Hi-Lo, clearance, competitive match), channel type (in-store, e-commerce, mobile app, marketplace, BOPIS), channel price variance and justification, effective date range, priority for multi-list resolution, and approval status. This is the single source of truth for what a customer pays for any SKU in any pricing context — the granular SKU-to-price-list-to-zone-to-channel binding that drives price resolution at POS and across all digital channels.'
}

Table pricing.price_change {
  price_change_id varchar [pk, note: 'Unique surrogate identifier for each price change event record in the pricing audit trail. Primary key for the price_change data product.']
  competitive_price_id varchar [note: 'Foreign key linking to pricing.competitive_price. Business justification: price_change has denormalized competitor_name (STRING) and competitive_reference_price (DECIMAL) fields. Adding competitive_price_id normalizes the link to the specific competitive price observation t']
  cost_price_id varchar [note: 'Foreign key linking to pricing.cost_price. Business justification: Price changes triggered by cost changes should reference the authoritative cost record. Adding cost_price_id FK links to cost_price. Keeps prior_cost/new_cost as point-in-time snapshots for audit trai']
  location_id varchar [note: 'Reference to the specific store or location where the price change applies. Null when the change applies enterprise-wide or to a price zone rather than a single store.']
  markdown_id varchar [note: 'Foreign key linking to pricing.markdown. Business justification: Price changes are frequently triggered by markdown events. Adding markdown_id FK allows tracking which markdown event caused a price change. Removes markdown_type as it can be retrieved from markdown.']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: Price changes are often scoped to specific price lists (e.g., updating the promotional price list vs. base price list). Adding price_list_id FK tracks which price list is being modified.']
  price_rule_id varchar [note: 'Reference to the pricing rule or pricing strategy definition in Oracle RPM that generated or governs this price change event. Links to the EDLP, Hi-Lo, cost-plus, or competitive pricing rule configuration.']
  price_zone_id varchar [note: 'Reference to the geographic or competitive price zone to which this price change applies. Price zones group stores with similar competitive environments for unified pricing governance.']
  promo_calendar_id varchar [note: 'Foreign key linking to promotion.promo_calendar. Business justification: Price changes are scheduled and executed in alignment with promotional calendar periods. Retail operations require price changes to be traceable to the calendar event that triggered them, supporting p']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Price changes are frequently triggered by promotional campaigns (weekly ads, seasonal events). Linking campaign to price change enables promotional effectiveness analysis, margin impact tracking, vend']
  promo_offer_id varchar [note: 'Reference to the promotion or promotional event that triggered this temporary price change. Null for non-promotional price changes. Links the price change audit trail to the promotions management domain.']
  sku_id varchar [note: 'Reference to the specific SKU (Stock Keeping Unit) for which the price or cost change is being recorded. Links to the product master.']
  vendor_allowance_id varchar [note: 'Foreign key linking to supplier.vendor_allowance. Business justification: Vendor-funded temporary price reduction tracking: vendors fund short-term price reductions (off-invoice allowances, bill-back deals) that trigger price_change events. vendor_allowance_id on price_chan']
  vendor_contract_id varchar [note: 'Foreign key linking to supplier.vendor_contract. Business justification: Vendor contract renegotiation is a primary trigger for retail price changes. Linking price_change to vendor_contract enables audit traceability of which contract clause (new cost terms, volume rebate)']
  vendor_id varchar [note: 'Reference to the supplier associated with a cost-side change event (e.g., supplier cost increase, contract renegotiation, tariff change). Null for retail-only price changes with no supplier involvement.']
  vendor_promo_agreement_id varchar [note: 'Foreign key linking to promotion.vendor_promo_agreement. Business justification: Price changes driven by vendor promotional deals must reference the governing vendor promotional agreement. price_change has supplier_reference_number as a denormalized reference. This link enables ve']
  approval_status varchar [note: 'Current workflow lifecycle state of the price change event: pending (awaiting approval), approved (authorized and scheduled), rejected (denied by approver), cancelled (withdrawn before execution), or superseded (overridden by a subsequent change).']
  approved_timestamp timestamp [note: 'The date and time when the price change was formally approved by an authorized pricing manager or automated approval workflow. Null if not yet approved or if approval is not required for the execution mode.']
  change_category varchar [note: 'High-level classification of the change event: retail_price_change (consumer-facing price), supplier_cost_change (vendor invoice cost), landed_cost_adjustment (total delivered cost including duties/tariffs), or freight_surcharge (transportation cost component).']
  change_type varchar [note: 'Nature of the price change: permanent (indefinite retail price reset), temporary (time-bounded promotional price), markdown (clearance or end-of-season price reduction), or automated (algorithm-driven dynamic pricing adjustment).']
  channel varchar [note: 'The retail channel to which this price change applies: in_store (physical POS), online (e-commerce/digital), omnichannel (unified price across all channels), or wholesale. Supports omnichannel pricing governance and channel-specific margin analysis.']
  competitive_reference_price decimal(18,4) [note: 'The competitor\'s observed price that triggered or informed a competitive_response price change. Captured for competitive pricing analysis, price matching governance, and FTC pricing transparency compliance. Null for non-competitive change reasons.']
  cost_change_pct decimal(8,4) [note: 'Percentage change in supplier or landed cost relative to the prior cost. Calculated as ((new_cost - prior_cost) / prior_cost) * 100. Key metric for supplier negotiation analysis and tariff impact assessment.']
  created_timestamp timestamp [note: 'The date and time when this price change record was first created and persisted in the data platform. System audit timestamp for data lineage and regulatory compliance.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code applicable to all monetary amounts in this price change record (e.g., USD, GBP, EUR, CAD). Supports multi-currency retail operations.']
  effective_date date [note: 'The calendar date on which the new price or cost becomes active at the point of sale or in procurement systems. Drives POS price activation, e-commerce price display, and purchase order cost updates.']
  event_timestamp timestamp [note: 'The precise date and time when the price change event was triggered or submitted in the source pricing system (Oracle RPM or SAP). Represents the real-world business event time, distinct from system audit timestamps.']
  execution_mode varchar [note: 'Method by which the price change was executed: manual (user-initiated via RPM UI), batch (scheduled overnight or periodic bulk update), or real_time (event-driven immediate execution, e.g., dynamic pricing engine).']
  expiry_date date [note: 'The calendar date on which a temporary price change or promotional price expires and the price reverts to the prior or standard price. Null for permanent price changes with no defined end date.']
  is_cost_change boolean [note: 'Indicates whether this price change event includes a supplier or landed cost change component (True) or is a retail-price-only change (False). Enables efficient filtering for COGS recalculation and GMROI impact workflows.']
  is_margin_breach boolean [note: 'Indicates whether the new_margin_pct resulting from this change falls below the category or SKU-level minimum margin threshold defined in pricing governance rules (True) or remains within acceptable bounds (False). Triggers escalation workflows in Oracle RPM.']
  new_cost decimal(18,4) [note: 'The supplier or landed cost of the SKU after this change event is applied. Drives COGS recalculation, margin impact assessment, and GMROI analysis.']
  new_margin_pct decimal(8,4) [note: 'Projected gross margin percentage on the SKU after this change event is applied, calculated as ((new_retail_price - new_cost) / new_retail_price) * 100. Used for margin impact assessment, GMROI recalculation triggers, and pricing governance.']
  new_retail_price decimal(18,4) [note: 'The consumer-facing retail selling price of the SKU after this change event is applied. Expressed in local currency. Drives POS (Point of Sale) pricing, e-commerce display price, and AUR calculations.']
  notes varchar [note: 'Free-text field for additional context, justification, or commentary provided by the pricing analyst or approver regarding this price change event. Supports audit trail completeness and regulatory compliance documentation.']
  pricing_strategy varchar [note: 'The overarching pricing strategy under which this change was made: EDLP (Everyday Low Price), hi_lo (High-Low promotional pricing), cost_plus (margin-based pricing), competitive (market-responsive pricing), dynamic (algorithm-driven real-time pricing), or clearance (end-of-lifecycle markdown).']
  prior_cost decimal(18,4) [note: 'The supplier or landed cost of the SKU immediately before this change event. Used for COGS (Cost of Goods Sold) baseline and GMROI (Gross Margin Return on Investment) impact assessment.']
  prior_margin_pct decimal(8,4) [note: 'Gross margin percentage on the SKU immediately before this change event, calculated as ((prior_retail_price - prior_cost) / prior_retail_price) * 100. Baseline for margin impact assessment and GMROI analysis.']
  prior_retail_price decimal(18,4) [note: 'The consumer-facing retail selling price of the SKU immediately before this change event. Expressed in local currency. Used for before/after comparison, markdown depth analysis, and AUR (Average Unit Retail) tracking.']
  reason_code varchar [note: 'Business reason driving the price or cost change. [ENUM-REF-CANDIDATE: competitive_response|cost_increase|seasonal_adjustment|clearance_initiation|tariff_change|contract_renegotiation|raw_material_increase|promotional_event|regulatory_compliance — promote to reference product]']
  retail_price_change_amount decimal(18,4) [note: 'Absolute monetary difference between new_retail_price and prior_retail_price. Negative values indicate a price decrease (markdown); positive values indicate a price increase. Used for markdown optimization and pricing governance reporting.']
  retail_price_change_pct decimal(8,4) [note: 'Percentage change in retail price relative to the prior retail price. Calculated as ((new_retail_price - prior_retail_price) / prior_retail_price) * 100. Used for markdown depth analysis and Hi-Lo pricing strategy reporting.']
  trigger_signal varchar [note: 'The specific signal or event that initiated an automated or algorithm-driven price change. Examples include competitive_price_match, demand_surge, inventory_clearance_threshold, cost_feed_update, or promotional_calendar_event. Null for manually initiated changes. [ENUM-REF-CANDIDATE: competitive_price_match|demand_surge|inventory_clearance_threshold|cost_feed_update|promotional_calendar_event|replenishment_signal — promote to reference product]']
  updated_timestamp timestamp [note: 'The date and time when this price change record was last modified in the data platform. Used for incremental data processing, change data capture, and audit trail completeness.']

  Note: 'Transactional record of every approved price or cost change event for a SKU. Captures before/after values, change category (retail price change, supplier cost change, landed cost adjustment, freight surcharge), reason code (competitive response, cost increase, seasonal adjustment, clearance initiation, tariff change, contract renegotiation, raw material increase), change type (permanent, temporary, markdown, automated/algorithm-driven), execution mode (manual, batch, real-time), effective/expiry dates, approver, supplier reference (for cost changes), cost change percentage, margin impact assessment, and trigger signal (for automated changes). Provides the single unified audit trail for ALL pricing-relevant changes — retail and cost-side — supporting governance, GMROI analysis, margin recalculation triggers, and regulatory compliance.'
}

Table pricing.markdown {
  markdown_id varchar [pk, note: 'Unique system-generated identifier for each markdown event record. Primary key for the markdown data product in the pricing domain.']
  competitive_price_id varchar [note: 'Foreign key linking to pricing.competitive_price. Business justification: markdown has an is_competitive_response boolean flag indicating the markdown was triggered by a competitive price observation. Adding competitive_price_id normalizes this by linking to the specific co']
  cost_price_id varchar [note: 'Foreign key linking to pricing.cost_price. Business justification: Markdown decisions consider cost price to avoid selling below cost. Adding cost_price_id FK links to authoritative cost record. Removes cost_price DECIMAL as redundant with cost_price.landed_cost.']
  demand_forecast_id varchar [note: 'Foreign key linking to supplychain.demand_forecast. Business justification: Markdown depth and sell_through_target_pct are calibrated against the demand forecast for the SKU/location. Linking markdown to the governing demand forecast enables sell-through variance analysis (ac']
  location_id varchar [note: 'Reference to the store, zone, or distribution center where the markdown is applied. Supports price zone and location-level markdown governance.']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: Markdowns are executed within the context of a specific price list (e.g., a clearance markdown applies to the clearance price list, a Hi-Lo markdown applies to the promotional price list). Linking mar']
  price_zone_id varchar [note: 'Reference to the price zone grouping under which this markdown is governed. Price zones aggregate locations with identical pricing strategies for enterprise-wide markdown management.']
  promo_calendar_id varchar [note: 'Foreign key linking to promotion.promo_calendar. Business justification: Markdowns are planned and executed against promotional calendar periods (e.g., post-holiday clearance tied to a specific calendar event). This link supports markdown planning reports, calendar-driven ']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Markdowns are coordinated with promotional campaigns (clearance events, end-of-season sales). Retailers track which campaign drove markdown decisions for vendor funding claims, promotional markdown bu']
  promo_offer_id varchar [note: 'Foreign key linking to promotion.promo_offer. Business justification: Markdowns are frequently executed as part of a specific promotional offer (e.g., a clearance offer within a campaign). Linking markdown to promo_offer enables offer-level markdown reconciliation, vend']
  replenishment_plan_id varchar [note: 'Foreign key linking to supplychain.replenishment_plan. Business justification: Markdown decisions are directly triggered by excess weeks-of-supply and inventory position signals from replenishment plans. Markdown analysts must trace which replenishment plan\'s on-hand/WOS data in']
  rule_id varchar [note: 'Foreign key linking to pricing.pricing_rule. Business justification: Markdowns may be triggered by pricing rules (e.g., automated clearance rules based on weeks of supply, sell-through targets). Adding pricing_rule_id FK distinguishes rule-driven markdowns from manual ']
  sku_id varchar [note: 'Reference to the specific SKU (Stock Keeping Unit) subject to the markdown event. Links to the product master for item-level markdown tracking.']
  stock_position_id varchar [note: 'Foreign key linking to inventory.stock_position. Business justification: Clearance markdown workflows are initiated from and monitored against specific stock positions (sell_through_rate, weeks_of_supply, is_dead_stock). Linking markdown to the triggering stock_position en']
  vendor_allowance_id varchar [note: 'Foreign key linking to supplier.vendor_allowance. Business justification: Vendor-funded markdown reconciliation: retailers negotiate vendor allowances to fund clearance markdowns. markdown.vendor_allowance_id enables financial settlement — tracking which vendor allowance of']
  vendor_promo_agreement_id varchar [note: 'Foreign key linking to promotion.vendor_promo_agreement. Business justification: Vendor-funded markdowns must reference the vendor promotional agreement that authorizes the funding. This link is essential for vendor chargeback processing, markdown funding reconciliation, and compl']
  actual_exit_date date [note: 'The actual date on which all inventory units subject to this markdown were fully cleared, returned, or liquidated. Compared against planned_exit_date to measure markdown execution efficiency.']
  amount decimal(18,4) [note: 'The absolute monetary reduction applied to the original retail price (original_retail_price minus marked_down_price). Used for financial reporting, P&L impact analysis, and markdown budget tracking.']
  approved_by varchar [note: 'The name or employee identifier of the merchandising or pricing manager who authorized the markdown event. Required for markdown audit trail compliance and governance under Oracle Retail Price Management (RPM) approval workflows.']
  approved_timestamp timestamp [note: 'The date and time at which the markdown event was formally approved by the authorized pricing or merchandising manager. Part of the price change audit trail required for pricing governance and regulatory compliance.']
  channel varchar [note: 'The retail channel(s) through which the markdown is applied. In-Store: physical store POS only; Online: e-commerce platform only; Omnichannel: applied across all channels simultaneously; BOPIS (Buy Online Pick Up In Store): applied for click-and-collect transactions.']
  clearance_closure_date date [note: 'The date on which the clearance event was formally closed, indicating all inventory has been disposed of or the clearance program has ended. Used for clearance lifecycle reporting and dead stock elimination tracking.']
  clearance_initiation_date date [note: 'The date on which the clearance event was formally initiated for this SKU and location. Marks the start of the clearance lifecycle, distinct from the markdown effective start date which may precede formal clearance designation.']
  clearance_stage varchar [note: 'Indicates the progression stage within a clearance event lifecycle. Not applicable for non-clearance markdowns. First Reduction: initial clearance price cut; Second Reduction: intermediate further reduction; Final Reduction: last price before disposition or liquidation.']
  created_timestamp timestamp [note: 'The date and time at which this markdown record was first created in the system. Supports audit trail, data lineage, and compliance reporting requirements.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts on this markdown record (e.g., USD, GBP, EUR, CAD). Supports multi-currency retail operations across international markets.']
  disposition_method varchar [note: 'The planned or actual method for final inventory disposition after markdown. In-Store Clearance: sold through physical store; Online Clearance: sold through e-commerce channel; RTV (Return to Vendor): returned to supplier; Liquidation: sold to third-party liquidator; Donation: donated to charity.']
  effective_end_date date [note: 'The date on which the markdown price expires and the item reverts to regular pricing or transitions to the next clearance stage. Null for permanent markdowns with no planned end date.']
  effective_start_date date [note: 'The date on which the markdown price becomes effective and is applied at POS (Point of Sale) and digital channels. Represents the planned or actual activation date of the markdown event.']
  is_competitive_response boolean [note: 'Flag indicating whether this markdown was triggered by a competitive pricing event (e.g., a competitor price reduction requiring a matching response). Supports competitive pricing analytics and FTC pricing transparency compliance.']
  is_dead_stock boolean [note: 'Flag indicating whether this markdown is specifically targeting dead stock (unsold obsolete inventory with no expected organic demand). Dead stock markdowns typically require aggressive pricing or liquidation disposition to eliminate carrying costs.']
  markdown_number varchar [note: 'Externally-known business identifier for the markdown event, used in Oracle Retail Price Management (RPM) and cross-system references. Follows the enterprise markdown numbering convention (e.g., MD-202400012345).']
  markdown_status varchar [note: 'Current lifecycle state of the markdown event. Tracks progression from planning through execution and closure: draft (being planned), approved (authorized), active (currently applied at POS), completed (sell-through achieved or exit date passed), cancelled (voided before activation).']
  markdown_type varchar [note: 'Classification of the markdown by business purpose. Permanent: lasting price reduction; POS (Point of Sale): temporary promotional reduction applied at checkout; Clearance: inventory liquidation; End-of-Season: seasonal assortment exit; End-of-Life: product discontinuation; Dead Stock: elimination of unsold obsolete inventory.']
  marked_down_price decimal(18,4) [note: 'The new retail price after the markdown is applied. This is the price presented to customers at POS (Point of Sale) or on the e-commerce platform during the markdown event.']
  notes varchar [note: 'Free-text field for additional business context, merchandising rationale, or operational notes associated with the markdown event. Used by category managers and pricing analysts to document non-standard markdown decisions.']
  on_hand_units_at_initiation varchar [note: 'The number of inventory units on hand at the time the markdown was initiated. Establishes the baseline inventory position for sell-through rate calculation and markdown ROI assessment.']
  original_retail_price decimal(18,4) [note: 'The full regular retail price of the SKU before any markdown is applied. Represents the AUR (Average Unit Retail) baseline used to calculate markdown depth and GMROI (Gross Margin Return on Investment) impact.']
  percent decimal(7,4) [note: 'The markdown expressed as a percentage of the original retail price (markdown_amount / original_retail_price * 100). Used for category management reporting, markdown depth analysis, and sell-through optimization.']
  planned_exit_date date [note: 'The target date by which all inventory units subject to this markdown are expected to be sold, returned, or otherwise disposed of. Used for OTB (Open to Buy) planning and clearance lifecycle management.']
  reason_code varchar [note: 'Standardized reason code explaining the business driver for the markdown (e.g., SLOW_MOVER, COMPETITIVE_RESPONSE, SEASONAL_EXIT, DAMAGE, OVERSTOCK, STYLE_DISCONTINUATION). Sourced from Oracle Retail Price Management (RPM) reason code table. [ENUM-REF-CANDIDATE: SLOW_MOVER|COMPETITIVE_RESPONSE|SEASONAL_EXIT|DAMAGE|OVERSTOCK|STYLE_DISCONTINUATION|VENDOR_ALLOWANCE — promote to reference product]']
  sell_through_actual_pct decimal(7,4) [note: 'The actual sell-through rate achieved as of the most recent data refresh (units sold / on_hand_units_at_initiation * 100). Compared against sell_through_target_pct to determine if further markdown action is required.']
  sell_through_target_pct decimal(7,4) [note: 'The planned sell-through rate (percentage of on-hand inventory expected to be sold) by the effective end date or planned exit date. Used as the primary KPI for markdown performance evaluation and clearance stage progression decisions.']
  source_system_code varchar [note: 'Identifies the operational system of record from which this markdown record originated. RPM: Oracle Retail Price Management; ORMS: Oracle Retail Merchandising System; SAP: SAP S/4HANA Retail; SFCC: Salesforce Commerce Cloud; MANUAL: manually entered override.']
  units_remaining varchar [note: 'The current number of unsold inventory units still subject to this markdown event. Calculated as on_hand_units_at_initiation minus units_sold. Drives replenishment suppression and dead stock elimination decisions.']
  units_sold varchar [note: 'The cumulative number of units sold at the marked-down price since the markdown became effective. Used to calculate actual sell-through rate and markdown revenue impact.']
  updated_timestamp timestamp [note: 'The date and time at which this markdown record was most recently modified. Used for change data capture (CDC), audit trail maintenance, and Silver layer incremental processing in the Databricks Lakehouse.']
  weeks_of_supply decimal(7,2) [note: 'The estimated number of weeks of inventory coverage remaining at the current rate of sale for the marked-down SKU. WOS (Weeks of Supply) is a key metric for determining markdown urgency and clearance stage escalation timing.']

  Note: 'Manages the full lifecycle of planned and unplanned markdowns and clearance events at the SKU, category, and location level. Captures markdown type (permanent, POS, clearance, end-of-season, end-of-life, dead stock), markdown amount (percentage or absolute), original and marked-down retail price, clearance stage progression (first/second/final reduction with price and sell-through at each stage), sell-through targets and actuals, disposition method (in-store clearance, online clearance, RTV, liquidation), planned and actual exit dates, markdown ROI, clearance initiation and closure dates, and dead stock elimination tracking. Tracks the complete reduction lifecycle from initial markdown through final clearance disposition and exit.'
}

Table pricing.cost_price {
  cost_price_id varchar [pk, note: 'Unique surrogate identifier for each cost price record in the pricing domain. Primary key for the cost_price data product.']
  cost_zone_id varchar [note: 'Reference to the geographic or operational cost zone for which this cost applies. Cost zones allow differentiated landed costs by region, distribution center, or market.']
  sku_id varchar [note: 'Reference to the product SKU for which this cost record applies. Links to the product master to identify the specific item being costed.']
  vendor_contract_id varchar [note: 'Foreign key linking to supplier.vendor_contract. Business justification: Cost negotiations are contract-specific. Buyers trace landed costs to contract terms, pricing tiers, payment terms, and volume commitments for vendor negotiations, cost variance analysis, and contract']
  vendor_id varchar [note: 'Reference to the supplier from whom this SKU is sourced. Cost records are supplier-specific as different suppliers may offer different costs for the same SKU.']
  vendor_item_id varchar [note: 'Foreign key linking to supplier.vendor_item. Business justification: Retail cost confirmation process: cost_price records are sourced directly from vendor_item catalog entries (unit_cost, cost_effective_date, gtin). vendor_item_id on cost_price enables direct audit tra']
  vendor_promo_agreement_id varchar [note: 'Foreign key linking to promotion.vendor_promo_agreement. Business justification: Promotional cost prices negotiated under vendor promotional agreements must reference that agreement. cost_price has supplier_deal_code as a denormalized reference. This link supports vendor deal cost']
  approved_by varchar [note: 'The user ID or name of the buyer, merchandise manager, or finance approver who authorized this cost record. Part of the cost change audit trail required for financial controls and SOX compliance.']
  approved_timestamp timestamp [note: 'The date and time when this cost record was formally approved by the authorized buyer or finance manager. Part of the cost change audit trail for financial controls and SOX compliance.']
  base_cost decimal(18,4) [note: 'The unit purchase cost of the SKU as invoiced by the supplier before any additional charges such as freight, duty, or handling. Represents the ex-works or FOB (Free on Board) cost. Core input for COGS (Cost of Goods Sold) and GMROI (Gross Margin Return on Investment) calculations.']
  cost_change_pct decimal(8,4) [note: 'The percentage change in total landed cost compared to the prior cost record for this SKU-supplier combination. Calculated as ((landed_cost - prior_landed_cost) / prior_landed_cost) * 100. Supports cost variance alerting, procurement performance KPIs, and margin impact analysis.']
  cost_change_reason varchar [note: 'Business reason code explaining why this cost record was created or why the cost changed from the prior record. Supports cost change audit trails, markdown optimization analysis, and procurement performance reporting. [ENUM-REF-CANDIDATE: new_item|supplier_negotiation|commodity_change|fx_adjustment|tariff_change|deal_activation|deal_expiry — promote to reference product]']
  cost_currency varchar [note: 'ISO 4217 three-letter currency code in which the cost components are denominated (e.g., USD, EUR, GBP, CNY). Essential for multi-currency cost management and foreign exchange (FX) rate application in landed cost calculations.']
  cost_notes varchar [note: 'Free-text field for buyer or finance team annotations regarding this cost record. May include negotiation context, exception justifications, or temporary cost arrangement details. Supports operational transparency and audit trail completeness.']
  cost_per_inner_pack decimal(18,4) [note: 'The landed cost allocated to each inner pack unit within a case or master carton. Supports cost breakdown for items sold in multiple pack configurations (e.g., a case of 12 inner packs). Used in assortment planning and margin analysis at the inner pack level.']
  cost_status varchar [note: 'Current lifecycle status of the cost record. Active records are used in margin calculations. Pending records are approved but not yet effective. Expired records have passed their end date. Superseded records have been replaced by a newer cost. Cancelled records were voided before activation.']
  cost_type varchar [note: 'Classification of the cost record indicating the pricing arrangement: standard (catalogue cost), contract (negotiated agreement cost), promotional (temporary supplier deal cost), spot (one-time market cost), or transfer (inter-company transfer cost). Drives cost-plus margin calculations and GMROI analysis.']
  cost_uom varchar [note: 'The unit of measure to which the cost components apply (e.g., EA=Each, CS=Case, PK=Pack, LB=Pound, KG=Kilogram). Ensures cost-per-unit calculations are correctly interpreted across different pack configurations and ordering units. [ENUM-REF-CANDIDATE: EA|CS|PK|LB|KG|OZ|L|M|FT — 9 candidates stripped; promote to reference product]']
  country_of_origin varchar [note: 'ISO 3166-1 alpha-3 country code indicating the country where the SKU was manufactured or substantially transformed. Drives duty rate determination, trade compliance, and country-of-origin labeling requirements per FDA and FTC regulations.']
  created_timestamp timestamp [note: 'The date and time when this cost record was first created in the system. Supports audit trail, data lineage, and cost change history analysis. Aligns with RECORD_AUDIT_CREATED category requirement.']
  duty_amount decimal(18,4) [note: 'Per-unit import duty, customs tariff, and trade compliance charges applied to the SKU upon importation. Varies by country of origin, product classification (HTS code), and applicable trade agreements. Critical for landed cost accuracy on imported merchandise.']
  duty_rate_pct decimal(8,4) [note: 'The applicable import duty rate expressed as a percentage of the base cost or customs value. Used to calculate the duty_amount component of landed cost. Varies by HTS code, country of origin, and applicable trade agreements (e.g., USMCA, CAFTA).']
  effective_date date [note: 'The date from which this cost record becomes operative for margin calculations, COGS (Cost of Goods Sold) accounting, and purchase order costing. Aligns with the cost effective date in Oracle Retail Merchandising System (ORMS).']
  end_date date [note: 'The date on which this cost record ceases to be operative. Null indicates an open-ended cost with no scheduled expiry. Used to manage cost versioning and ensure the correct cost is applied within a given date range.']
  exchange_rate decimal(18,6) [note: 'The exchange rate applied to convert the cost from the cost currency to the retailer\'s functional (home) currency at the time the cost record was established. Supports accurate COGS reporting and margin analysis in the reporting currency.']
  freight_cost decimal(18,4) [note: 'Per-unit freight and transportation cost incurred to move the SKU from the supplier origin to the retailer\'s distribution center or store. Includes ocean freight, air freight, or ground transport charges as applicable. Component of total landed cost.']
  handling_cost decimal(18,4) [note: 'Per-unit warehousing, distribution center handling, and processing charges allocated to the SKU. Includes DC (Distribution Center) receiving, put-away, and value-added services such as ticketing or re-packaging.']
  hts_code varchar [note: 'The Harmonized Tariff Schedule code classifying the SKU for customs and import duty purposes. Determines the applicable duty rate and trade compliance requirements. Required for accurate duty cost calculation in the landed cost model.']
  incoterm varchar [note: 'The International Chamber of Commerce (ICC) Incoterm governing the transfer of risk and cost responsibility between the supplier and the retailer (e.g., FOB=Free on Board, DDP=Delivered Duty Paid, CIF=Cost Insurance Freight). Determines which cost components are borne by the retailer versus the supplier. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]']
  is_current boolean [note: 'Boolean flag indicating whether this is the currently active cost record for the SKU-supplier-cost zone combination. True for the single active record; False for historical or superseded records. Simplifies queries for current cost without requiring date range filtering.']
  landed_cost decimal(18,4) [note: 'The total per-unit cost of the SKU inclusive of base cost, freight, duty, handling, and other charges. Represents the true buy-side cost used for margin management, GMROI (Gross Margin Return on Investment) tracking, and cost-plus retail price calculations. Sourced from Oracle Retail Merchandising System (ORMS) landed cost module.']
  landed_cost_local decimal(18,4) [note: 'Total landed cost converted to the retailer\'s functional (home) currency using the applied exchange rate. Used for domestic P&L (Profit and Loss) reporting, GMROI calculations, and financial planning in the reporting currency.']
  prior_landed_cost decimal(18,4) [note: 'The total landed cost from the immediately preceding active cost record for this SKU-supplier combination. Enables cost variance analysis, markdown optimization, and audit trail review without requiring a self-join to the history table.']
  source_system_cost_code varchar [note: 'The native identifier of this cost record in the originating source system (e.g., ORMS cost record number, SAP condition record number). Enables reconciliation between the Silver Layer data product and the operational system of record.']
  updated_timestamp timestamp [note: 'The date and time when this cost record was last modified. Tracks amendments to cost components, status changes, or corrections. Supports audit trail and data lineage requirements.']

  Note: 'Authoritative record of landed cost and COGS for each SKU from each supplier. Includes base cost, freight, duty/tariff, handling charges, total landed cost, cost effective date, cost currency, and cost change reason. Supports cost-plus margin calculations, GMROI tracking, and margin management. This is the buy-side cost record distinct from the sell-side retail price in sku_price.'
}

Table pricing.rule {
  rule_id varchar [pk, note: 'Unique system-generated identifier for each pricing rule record. Serves as the primary key for the pricing_rule data product within the Oracle Retail Price Management (RPM) integrated lakehouse silver layer.']
  department_id varchar [note: 'Reference to the merchandise department (e.g., Grocery, Apparel, Electronics) to which this pricing rule is scoped when sku_scope = \'department\'. Aligns with Oracle Retail Merchandising System (ORMS) department hierarchy. Null if rule applies at a different scope level.']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: Pricing rules are often scoped to a specific price list (e.g., EDLP rules vs. Hi-Lo promotional rules vs. clearance rules). A rule governing EDLP pricing should reference the EDLP price list. No exist']
  price_zone_id varchar [note: 'Reference to the geographic or market-based price zone to which this rule applies. Price zones allow differentiated pricing across store clusters, regions, or markets. Null if the rule applies uniformly across all zones. Managed in Oracle Retail Price Management (RPM) zone configuration.']
  promo_calendar_id varchar [note: 'Foreign key linking to promotion.promo_calendar. Business justification: Pricing rules are activated and deactivated based on promotional calendar periods (e.g., holiday pricing rules, seasonal rules). Linking rule to promo_calendar enables calendar-driven rule activation ']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Pricing rules are frequently scoped to specific promotional campaigns (e.g., campaign-exclusive stackable rules, campaign-triggered price adjustments). Retail pricing teams need to audit which rules w']
  adjustment_method varchar [note: 'Specifies the mathematical method used to compute the price adjustment. \'percentage\' = apply a % change to the base price (e.g., 15% markdown); \'absolute\' = apply a fixed monetary amount change (e.g., reduce by $5.00); \'index_based\' = adjust relative to a reference index (e.g., competitor price index, CPI).']
  adjustment_value decimal(18,4) [note: 'The numeric magnitude of the price adjustment as defined by the adjustment_method. For \'percentage\', this is the rate (e.g., 15.00 = 15%); for \'absolute\', this is the currency amount (e.g., 5.0000 = $5.00); for \'index_based\', this is the index multiplier. Negative values represent price reductions (markdowns); positive values represent increases.']
  algorithm_version varchar [note: 'Version identifier of the dynamic pricing algorithm or rule engine logic applied by this rule. Used for reproducibility, audit, and A/B testing of pricing models. Example: \'v2.1.0\', \'v3.0\'. Applicable for rule_type = \'dynamic_trigger\', \'demand_based\', or \'inventory_based\'. Null for static manual rules.']
  applicable_days_of_week varchar [note: 'Comma-separated list of days of the week on which this pricing rule is active. Enables day-parting and weekly promotional cadence (e.g., \'MON,TUE,WED,THU,FRI\' for weekday rules; \'SAT,SUN\' for weekend Hi-Lo swings). Null if the rule applies every day within the effective date range. Format: MON|TUE|WED|THU|FRI|SAT|SUN.']
  approved_by varchar [note: 'The name or employee identifier of the pricing manager or merchant who approved this rule for activation in Oracle RPM. Supports audit trail requirements and SOX internal control documentation. Populated upon rule activation; null for draft rules pending approval.']
  approved_timestamp timestamp [note: 'The date and time when this pricing rule was formally approved for activation by an authorized pricing manager in Oracle RPM. Part of the price change audit trail required for SOX compliance and FTC pricing transparency. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  channel varchar [note: 'The retail sales channel to which this pricing rule applies. Supports omnichannel pricing governance — rules may be scoped to in-store POS (Point of Sale), e-commerce (Salesforce Commerce Cloud), mobile app, or applied uniformly across all channels.']
  code varchar [note: 'Externally-known alphanumeric business identifier for the pricing rule, used in Oracle Retail Price Management (RPM) and SAP S/4HANA SD module for cross-system reference and audit trail correlation. Example: \'EDLP-GRC-001\', \'HILO-APP-Q4\'.']
  competitor_price_index decimal(18,2) [note: 'The reference competitor price index value used as the benchmark for competitive match ceiling or competitive pricing rules. A value of 1.0000 = price parity; values below 1.0 indicate undercutting strategy; values above 1.0 indicate premium positioning. Sourced from competitive intelligence feeds integrated with Oracle RPM.']
  cost_plus_margin_pct decimal(18,2) [note: 'The gross margin percentage applied above COGS (Cost of Goods Sold) when the rule_type is \'cost_plus_floor\'. Defines the minimum acceptable margin to protect GMROI (Gross Margin Return on Investment) targets. Example: 35.0000 = 35% margin above cost. Sourced from SAP S/4HANA CO (Controlling) module.']
  created_timestamp timestamp [note: 'The date and time when this pricing rule record was first created in the system. Serves as the audit trail creation marker for data lineage, SOX compliance, and Oracle RPM change management. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code in which all monetary values (min_price, max_price, adjustment_value) for this rule are denominated. Example: \'USD\', \'CAD\', \'GBP\'. Supports multi-currency retail operations across international markets.']
  description varchar [note: 'Free-text narrative description of the pricing rule\'s business purpose, scope, and rationale. Authored by the pricing analyst or category manager in Oracle RPM. Provides context for audit reviews, merchant onboarding, and pricing governance documentation.']
  effective_end_date date [note: 'The calendar date on which this pricing rule expires and ceases execution. Null indicates an open-ended rule with no planned expiry (common for EDLP lock rules). Oracle RPM automatically transitions rule_status to \'expired\' when this date is passed. Format: yyyy-MM-dd.']
  effective_start_date date [note: 'The calendar date on which this pricing rule becomes active and eligible for execution. Used by Oracle RPM\'s scheduling engine to activate rules at the correct time. Aligns with OTB (Open to Buy) planning cycles and promotional calendar. Format: yyyy-MM-dd.']
  exception_count varchar [note: 'Number of exceptions generated by this rule']
  execution_mode varchar [note: 'Defines how the pricing rule is triggered and applied. \'manual\' = merchant-initiated via Oracle RPM UI; \'batch\' = scheduled overnight or periodic run via SAP S/4HANA SD; \'real_time\' = instantaneous algorithmic trigger at POS or checkout; \'near_real_time\' = sub-minute latency via SAP CAR demand signals.']
  generic_monetary_dummy decimal(18,2) [note: 'Placeholder monetary attribute added by mutator to ensure change.']
  impact_estimate_amount decimal(18,2) [note: 'Estimated revenue impact of applying this rule']
  is_system_generated boolean [note: 'Whether rule was auto-generated by pricing engine']
  last_execution_timestamp timestamp [note: 'Last time the rule was executed']
  last_updated_timestamp timestamp [note: 'The date and time when this pricing rule record was most recently modified. Used for incremental data pipeline processing, change data capture (CDC) in the Databricks lakehouse silver layer, and audit trail maintenance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  loyalty_exclusive boolean [note: 'Indicates whether this pricing rule applies exclusively to loyalty program members. True = price adjustment is only available to enrolled loyalty customers (e.g., member-only pricing); False = rule applies to all customers regardless of loyalty status. Integrates with CRM (Customer Relationship Management) loyalty program data.']
  markdown_depth_pct decimal(8,4) [note: 'The maximum allowable markdown percentage from the AUR (Average Unit Retail) or original retail price for markdown and clearance rules. Prevents excessive margin erosion. Example: 40.0000 = maximum 40% markdown. Used in markdown optimization workflows within Oracle RPM and Blue Yonder Demand Planning.']
  max_price decimal(18,2) [note: 'The absolute ceiling price above which this rule must not raise the selling price. Prevents price gouging and ensures compliance with FTC consumer protection standards. Used in competitive match ceiling rules to cap price increases. Expressed in the operating currency (USD). Corresponds to the \'price ceiling\' concept in Oracle RPM.']
  min_price decimal(18,2) [note: 'The absolute floor price below which this rule must not reduce the selling price, regardless of adjustment logic. Protects against below-cost selling and ensures compliance with FTC pricing transparency and predatory pricing regulations. Expressed in the operating currency (USD). Corresponds to the \'price floor\' concept in Oracle RPM.']
  name varchar [note: 'Human-readable descriptive name for the pricing rule, used by merchants and pricing analysts to identify the rule in Oracle RPM dashboards and reporting. Example: \'Grocery EDLP Floor — Q1 2025\', \'Electronics Hi-Lo Weekend Swing\'.']
  override_approval_required boolean [note: 'Indicates whether a manual price override for this rule requires supervisory approval before taking effect. True = approval workflow triggered in Oracle RPM; False = override can be applied immediately by authorized users. Relevant only when override_permitted = True.']
  override_permitted boolean [note: 'Indicates whether a merchant or store manager is permitted to manually override this pricing rule at the POS (Point of Sale) or in Oracle RPM. True = override allowed with appropriate role-based authorization; False = rule is locked and cannot be overridden (common for EDLP lock and regulatory compliance rules).']
  priority varchar [note: 'Integer ranking that determines execution order when multiple pricing rules apply to the same SKU simultaneously. Lower numeric value = higher priority (1 = highest). Used by Oracle RPM\'s rule conflict resolution engine to determine which rule wins in overlapping scenarios. Critical for Hi-Lo vs EDLP conflict resolution.']
  rounding_rule varchar [note: 'Specifies the price rounding convention applied after the adjustment calculation. \'charm_99\' rounds to the nearest X.99 (psychological pricing); \'charm_95\' rounds to X.95; \'nearest_cent\' rounds to two decimal places; \'nearest_dollar\' rounds to whole dollar; \'custom\' uses a merchant-defined rounding table in Oracle RPM.']
  rule_status varchar [note: 'Current lifecycle state of the pricing rule within Oracle RPM. Controls whether the rule is eligible for execution in batch or real-time pricing engines. \'draft\' = under configuration; \'active\' = live and enforced; \'inactive\' = disabled but retained; \'suspended\' = temporarily halted; \'expired\' = past effective end date.']
  rule_type varchar [note: 'Categorical classification of the pricing rule\'s business logic. Defines the algorithmic or policy basis for price determination. [ENUM-REF-CANDIDATE: cost_plus_floor|competitive_match_ceiling|edlp_lock|hilo_swing_limit|rounding|dynamic_trigger|demand_based|inventory_based|time_of_day|markdown — promote to reference product]']
  sell_through_target_pct decimal(8,4) [note: 'The target sell-through rate (percentage of inventory sold) that this pricing rule is designed to achieve. Used in inventory-based and markdown rules to drive clearance of dead stock. Example: 85.0000 = target 85% sell-through. Aligns with Blue Yonder Demand Planning replenishment signals and ORMS inventory management.']
  simulation_run_code varchar [note: 'Reference to pricing simulation that validated this rule']
  sku_scope varchar [note: 'Defines the breadth of SKU (Stock Keeping Unit) applicability for this pricing rule. \'all_skus\' applies enterprise-wide; \'category\' scopes to a merchandise category; \'department\' scopes to a department; \'specific_sku\' targets individual SKUs; \'price_zone\' applies to a geographic price zone. Aligns with Oracle Retail Merchandising System (ORMS) hierarchy.']
  source_system_rule_code varchar [note: 'The native identifier of this pricing rule in the originating operational system of record (Oracle Retail Price Management RPM). Enables bidirectional traceability between the lakehouse silver layer and the RPM source system for audit and reconciliation purposes.']
  stackable boolean [note: 'Indicates whether this pricing rule can be combined (stacked) with other active pricing rules or promotions for the same SKU. True = rule can stack with other discounts/promotions; False = rule is exclusive and prevents other rules from applying simultaneously. Critical for promotion conflict management in Oracle RPM.']
  time_of_day_end varchar [note: 'The daily end time (HH:MM in 24-hour format) at which this rule ceases to be active for intraday pricing windows. Paired with time_of_day_start to define the active window. Null if the rule applies all day.']
  time_of_day_start varchar [note: 'The daily start time (HH:MM in 24-hour format) from which this rule is active, applicable when trigger_type = \'time_based\' or rule_type = \'time_of_day\'. Enables intraday dynamic pricing (e.g., happy hour markdowns, peak-hour surcharges). Null if the rule applies all day.']
  trigger_threshold_value decimal(18,4) [note: 'The numeric threshold value that must be breached to activate the trigger condition. Interpretation depends on trigger_type: for \'inventory_threshold\' this is the WOS (Weeks of Supply) or unit count; for \'demand_surge\' this is the demand index multiplier; for \'sell_through_rate\' this is the percentage. Sourced from Blue Yonder Demand Planning signals.']
  trigger_type varchar [note: 'The business condition or event that activates this pricing rule. Defines what must occur for the rule to fire. [ENUM-REF-CANDIDATE: inventory_threshold|demand_surge|competitor_undercut|time_based|weather|event_driven|scheduled|manual_override|sell_through_rate — promote to reference product]']
  version varchar [note: 'Version number of the rule']

  Note: 'Defines all business logic and constraints governing how prices are calculated, adjusted, and enforced — covering manual policies, batch processes, and real-time algorithm-driven automation. Includes rule type (cost-plus floor, competitive match ceiling, EDLP lock, Hi-Lo swing limit, rounding, dynamic trigger, demand-based, inventory-based, time-of-day), priority, applicable SKU scope, channel (in-store, e-commerce, mobile app), execution mode (manual, batch, real-time/near-real-time), trigger conditions (inventory threshold, demand surge, competitor undercut, time-based, weather, event-driven), adjustment method (percentage, absolute, index-based), min/max price guardrails, effective dates, activation status, algorithm version reference, and override permissions. Serves as the unified policy engine for all pricing governance — from static business rules to real-time algorithmic adjustments.'
}

Table pricing.competitive_price {
  competitive_price_id varchar [pk, note: 'Unique surrogate identifier for each competitive price observation record in the pricing domain. Primary key for the competitive_price data product.']
  location_id varchar [note: 'Identifier for the specific competitor store location or online channel URL where the price was observed. Enables store-level competitive analysis and geographic price gap tracking.']
  price_zone_id varchar [note: 'Reference to the price zone in which the competitive observation was made. Price zones define geographic or market segments used in Oracle Retail Price Management (RPM) for zone-based pricing governance.']
  rule_id varchar [note: 'Foreign key linking to pricing.rule. Business justification: Competitive price observations drive pricing rule evaluations and responses. The response_action field on competitive_price indicates what action was taken, but linking to the specific pricing rule th']
  sku_id varchar [note: 'Reference to the internal SKU (Stock Keeping Unit) for which the competitive price observation was captured. Links the observation to the retailer\'s own product master.']
  sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: Competitive price observations compare competitor prices against our own retail price. Adding sku_price_id FK links to authoritative retail price record. Removes own_retail_price DECIMAL as redundant ']
  category_code varchar [note: 'Merchandise category code for the observed SKU, aligned with the retailer\'s category management hierarchy. Enables category-level competitive index aggregation and assortment breadth analysis across competitive observations.']
  competitor_channel varchar [note: 'Sales channel through which the competitor price was observed. Distinguishes between in-store shelf prices, e-commerce website prices, mobile app prices, and third-party marketplace listings to support omnichannel competitive analysis.']
  competitor_in_stock_flag boolean [note: 'Indicates whether the competitor had the product in stock at the time of the price observation (True = in stock, False = out of stock). Out-of-stock competitor observations may reduce the urgency of a price response.']
  competitor_name varchar [note: 'Name of the competing retailer or marketplace whose price was observed (e.g., Walmart, Target, Amazon). Used for competitive index tracking and Hi-Lo / EDLP strategy calibration.']
  competitor_pack_size decimal(10,3) [note: 'Numeric pack size or quantity of the competitor\'s product offering (e.g., 12 for a 12-pack, 1.5 for 1.5 liters). Combined with competitor_unit_of_measure to normalize prices to a common unit for accurate like-for-like competitive comparisons.']
  competitor_price decimal(18,4) [note: 'The retail selling price observed at the competitor for the matched product, expressed in the local currency. This is the primary competitive intelligence data point used for price gap analysis, competitive index calculation, and pricing response recommendations.']
  competitor_product_name varchar [note: 'Product name or description as listed by the competitor for the observed item. Used for like-for-like and comparable match validation, especially when GTIN-based exact matching is not available.']
  competitor_promo_end_date date [note: 'Date on which the competitor\'s promotional price is expected to expire, if known. Enables time-sensitive pricing response planning and markdown optimization scheduling.']
  competitor_promo_flag boolean [note: 'Indicates whether the observed competitor price is a promotional or temporary price (True) rather than the regular everyday price (False). Critical for distinguishing Hi-Lo promotional pricing from EDLP baseline prices in competitive analysis.']
  competitor_promo_type varchar [note: 'Type of promotional pricing mechanism observed at the competitor when competitor_promo_flag is True. Includes Temporary Price Reduction (TPR), clearance markdown, loyalty card price, bundle deal, coupon redemption, or rollback. Supports Hi-Lo strategy calibration and promotional response planning. [ENUM-REF-CANDIDATE: tpr|clearance|loyalty_price|bundle|coupon|rollback — promote to reference product if additional types are needed]']
  competitor_sku_code varchar [note: 'The competitor\'s own SKU or item code for the observed product. Supports cross-reference mapping between own assortment and competitor assortment for comparable product matching.']
  competitor_unit_of_measure varchar [note: 'Unit of measure for the competitor\'s observed price (e.g., each, lb, kg, liter). Required for unit-price normalization when comparing products sold in different pack sizes or weights to ensure valid price-per-unit competitive comparisons. [ENUM-REF-CANDIDATE: each|lb|kg|oz|liter|ml|pack|case — promote to reference product if additional UOMs are needed]']
  competitor_url varchar [note: 'Web URL of the competitor\'s product listing page where the price was observed for online channel observations. Provides a direct audit trail link to the source of the competitive price data for web scrape and third-party feed validations.']
  created_timestamp timestamp [note: 'Timestamp when this competitive price observation record was first created in the Silver Layer data product. Supports audit trail, data lineage, and GDPR/CCPA data retention compliance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the competitor observed price (e.g., USD, CAD, GBP). Required for multi-currency competitive analysis in cross-border retail operations.']
  data_source_type varchar [note: 'Method by which the competitor price was collected. Distinguishes between manual in-store surveys, automated third-party competitive intelligence feeds, web scraping, EDI (Electronic Data Interchange) feeds, and mystery shopping programs. Affects confidence scoring and data quality weighting.']
  data_source_vendor varchar [note: 'Name of the third-party competitive intelligence provider or data feed vendor supplying the price observation (e.g., Profitero, Nielsen, Numerator, Wiser). Null for internally collected observations (manual survey, mystery shop).']
  department_code varchar [note: 'Merchandise department code for the observed SKU within the retailer\'s organizational hierarchy. Supports department-level competitive pricing governance and GMROI (Gross Margin Return on Investment) impact analysis.']
  geographic_market varchar [note: 'ISO 3166-1 alpha-2 or alpha-3 country/market code where the competitive observation was made. Supports multi-market competitive intelligence aggregation and cross-border pricing strategy governance.']
  gtin varchar [note: 'GS1-standard Global Trade Item Number (GTIN) used to uniquely identify the product observed at the competitor. Enables high-confidence exact-match comparisons across retailers using a universal product identifier. Includes UPC-A (12-digit), EAN-13 (13-digit), and GTIN-14 formats.']
  match_confidence_score decimal(5,2) [note: 'Numeric score (0.00–100.00) representing the confidence level that the competitor product is a true comparable match to the retailer\'s own SKU. Derived from GTIN exact match, product attribute similarity, or algorithmic matching. Higher scores indicate stronger comparability for pricing decisions.']
  match_type varchar [note: 'Classification of how the competitor product was matched to the retailer\'s own SKU. Exact GTIN/UPC matches carry the highest confidence; like-for-like and comparable matches involve attribute-based similarity; private label equivalent matches compare store brand to national brand. Drives weighting in competitive index calculations.']
  normalized_unit_price decimal(18,4) [note: 'Competitor price normalized to a standard unit of measure (e.g., price per kg, price per liter) to enable valid cross-pack-size competitive comparisons. Computed from competitor_price, competitor_pack_size, and competitor_unit_of_measure. Essential for grocery and FMCG category competitive analysis.']
  observation_date date [note: 'Calendar date on which the competitor price was observed or collected. The principal business event date for this record. Used for time-series competitive trend analysis and markdown optimization timing.']
  observation_quality_flag boolean [note: 'Data quality assessment status for the competitive price observation. Verified observations have been validated against a secondary source; unverified are raw inputs; suspect observations have anomalies flagged for review; rejected observations are excluded from competitive index calculations.']
  observation_timestamp timestamp [note: 'Precise date and time at which the competitor price was captured, including timezone offset. Provides intraday granularity for dynamic pricing use cases and web-scrape frequency analysis. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  previous_competitor_price decimal(18,4) [note: 'The competitor\'s price from the immediately preceding observation for the same SKU and competitor. Enables point-in-time price change detection and price gap trend calculation without requiring a self-join on historical records.']
  previous_observation_date date [note: 'Date of the immediately preceding competitive price observation for the same SKU and competitor. Used alongside previous_competitor_price to compute price gap trend direction and velocity.']
  price_gap decimal(18,4) [note: 'Absolute monetary difference between the retailer\'s own retail price and the competitor\'s observed price (own_retail_price minus competitor_price). A positive value indicates the retailer is priced higher; negative indicates the retailer is priced lower. Core metric for competitive index tracking and price war early warning.']
  price_gap_pct decimal(10,4) [note: 'Price gap expressed as a percentage of the retailer\'s own retail price ((own_retail_price - competitor_price) / own_retail_price * 100). Enables normalized cross-category competitive index tracking and Hi-Lo / EDLP strategy calibration independent of absolute price levels.']
  price_gap_trend varchar [note: 'Directional trend of the price gap compared to the previous observation for the same SKU and competitor. Indicates whether the competitive position is improving (narrowing), deteriorating (widening), stable, or has reversed polarity. Supports price war early warning detection.']
  price_index decimal(10,4) [note: 'Ratio of the retailer\'s own retail price to the competitor\'s observed price (own_retail_price / competitor_price). A value above 1.0 indicates the retailer is priced higher than the competitor; below 1.0 indicates a price advantage. Core KPI for competitive pricing governance and EDLP positioning.']
  response_action varchar [note: 'System-recommended or analyst-assigned pricing response action based on the competitive observation. Options include: match competitor price, undercut competitor price, hold current price, continue monitoring, or escalate to pricing manager. Feeds competitive pricing rules in Oracle Retail Price Management (RPM).']
  response_implemented_date date [note: 'Date on which the recommended pricing response action was implemented in the retailer\'s own pricing system. Used for measuring response latency and audit trail completeness.']
  response_status varchar [note: 'Current workflow status of the recommended pricing response action. Tracks whether the response has been reviewed, approved, rejected, implemented in Oracle Retail Price Management (RPM), or has expired without action. Supports price change audit trail requirements.']
  updated_timestamp timestamp [note: 'Timestamp when this competitive price observation record was last modified, such as when the response_status was updated or observation_quality_flag was revised. Supports audit trail and data lineage requirements. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']

  Note: 'Observed competitor retail prices for matching SKUs or comparable products. Captures competitor name, store or URL, observed price, observation date, data source (manual survey, third-party feed, web scrape), match confidence score, price gap versus own retail price, price gap trend over time, and recommended response action. Feeds competitive pricing rules and supports Hi-Lo and EDLP strategy calibration, competitive index tracking, and price war early warning.'
}

Table pricing.price_approval {
  price_approval_id varchar [pk, note: 'Unique system-generated identifier for each price approval workflow record. Primary key for the price_approval data product.']
  competitive_price_id varchar [note: 'Foreign key linking to pricing.competitive_price. Business justification: price_approval has denormalized competitor_name (STRING) and competitive_price_ref (DECIMAL) fields. Adding competitive_price_id normalizes the link to the specific competitive price observation refer']
  cost_price_id varchar [note: 'Foreign key linking to pricing.cost_price. Business justification: Approval workflow needs to verify margin against cost. Adding cost_price_id FK links to authoritative cost record. Removes cost_price DECIMAL as redundant with cost_price.landed_cost.']
  department_id varchar [note: 'Reference to the merchandise department or category associated with the price change request. Used for routing approvals to the correct category manager or merchandise director.']
  markdown_id varchar [note: 'Foreign key linking to pricing.markdown. Business justification: Price approval workflow often specifically approves markdown events. Adding markdown_id FK links approval records to the markdown being approved. Removes markdown_reason_code as it can be retrieved fr']
  price_change_id varchar [note: 'Reference to the governed price change request, markdown event, or price list activation that this approval record governs. Links the approval workflow to the underlying pricing action in Oracle Retail Price Management (RPM).']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: Price approvals can be initiated for price list-level changes (e.g., updating the EDLP base price list or creating a new promotional price list). Linking price_approval directly to price_list allows t']
  price_zone_id varchar [note: 'Foreign key linking to pricing.price_zone. Business justification: price_approval has a denormalized price_zone_code (STRING) but no FK to price_zone. Price approvals are scoped to a pricing zone — the zone determines approval thresholds and authority levels. Adding ']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Promotional price approvals require campaign context for compliance validation, margin threshold enforcement, and vendor funding verification. Approval workflows differ for promotional vs. permanent p']
  promo_offer_id varchar [note: 'Foreign key linking to promotion.promo_offer. Business justification: Price approvals are often required for specific promotional offer prices (e.g., approving a deep-discount offer price). Retail governance workflows require approval records to reference the specific o']
  rule_id varchar [note: 'Foreign key linking to pricing.rule. Business justification: Price approvals are frequently triggered by rule override scenarios — when a proposed price violates a pricing rule, an approval workflow is initiated. Linking price_approval directly to the governing']
  approval_channel varchar [note: 'The channel or interface through which the approver submitted their decision. Supports audit trail completeness and governance reporting on approval workflow efficiency.']
  approval_notes varchar [note: 'Free-text notes or comments entered by the requestor or approver to provide additional business context for the price change request. May include competitive intelligence, promotional rationale, or supplier negotiation context.']
  approval_number varchar [note: 'Externally-known, human-readable reference number for the price approval workflow record. Used in communications, audit reports, and cross-system references. Format: PA-{YYYY}-{NNNNNN}.']
  approval_status varchar [note: 'Current lifecycle state of the price approval workflow record. Drives downstream pricing activation in Oracle Retail Price Management (RPM). [ENUM-REF-CANDIDATE: pending|approved|rejected|escalated|cancelled|expired — promote to reference product if additional states are required]']
  approval_tier varchar [note: 'Organizational approval tier currently responsible for acting on this request. Reflects the segregation-of-duties hierarchy: Category Manager for routine markdowns, Merchandise Director for material price changes, VP Merchandising or CFO for strategic pricing decisions. [ENUM-REF-CANDIDATE: category_manager|merchandise_director|vp_merchandising|cfo|auto_approved — promote to reference product]']
  approval_type varchar [note: 'Classification of the pricing action requiring approval. Distinguishes between standard price changes, markdowns (temporary or permanent), price list activations, promotional pricing, and clearance events. [ENUM-REF-CANDIDATE: price_change|markdown|price_list_activation|promotional_price|clearance — promote to reference product]']
  business_justification varchar [note: 'Structured business justification narrative submitted by the requestor explaining the strategic or operational rationale for the price change. Distinct from approval_notes in that it is a formal, required field for material price decisions routed to senior approval tiers.']
  created_timestamp timestamp [note: 'The date and time when this price approval record was first created in the system. Audit trail field for data lineage and compliance reporting.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for all monetary amounts in this approval record (current_price, proposed_price, cost_price). Supports multi-currency retail operations across international markets.']
  current_price decimal(18,4) [note: 'The current active retail selling price (AUR - Average Unit Retail) of the item or price zone before the proposed change. Expressed in the store\'s operating currency. Used for margin impact analysis and GMROI calculation.']
  decision_timestamp timestamp [note: 'The date and time when the approver rendered a final decision (approved, rejected, or escalated) on the price change request. Null if the approval is still pending. Critical for SLA measurement and audit trail.']
  effective_date date [note: 'The planned date on which the approved price change or markdown is scheduled to take effect at the point of sale (POS) or e-commerce platform. Drives downstream price activation in Oracle Retail Price Management (RPM) and SAP S/4HANA SD module.']
  end_date date [note: 'The date on which the approved price change or markdown ceases to be active. Applicable for promotional and Hi-Lo pricing events. Null for permanent price changes or EDLP adjustments.']
  escalation_tier varchar [note: 'The approval tier to which this request was escalated. Populated only when is_escalated = True. Tracks the escalation path for audit and governance reporting.']
  escalation_timestamp timestamp [note: 'The date and time when the approval request was escalated to a higher approval tier due to timeout, threshold breach, or manual escalation. Null if no escalation occurred.']
  expiry_date date [note: 'The date by which the approval must be granted for the price change to take effect. If the approval is not completed by this date, the request expires and must be resubmitted. Enforces time-bound pricing governance.']
  gross_margin_pct decimal(8,4) [note: 'The projected gross margin percentage at the proposed price, calculated as ((proposed_price - cost_price) / proposed_price) * 100. Validates that the proposed price meets minimum margin floor requirements before approval.']
  is_auto_approved boolean [note: 'Indicates whether this price change was automatically approved by the system based on pre-configured rules (e.g., price change below threshold, EDLP adjustment within margin floor). True = system auto-approved; False = requires human approval.']
  is_escalated boolean [note: 'Indicates whether this approval request has been escalated to a higher approval tier. True = escalated; False = not escalated. Complements approval_status to enable efficient filtering of escalated approvals for management review.']
  price_change_pct decimal(8,4) [note: 'The percentage change between the current price and the proposed price. Calculated as ((proposed_price - current_price) / current_price) * 100. Used to determine approval tier routing thresholds — larger percentage changes require higher-tier approval.']
  pricing_strategy varchar [note: 'The pricing strategy governing the requested price change. EDLP (Everyday Low Price) indicates a stable low-price approach; Hi-Lo (High-Low) indicates promotional cycling; competitive pricing is driven by market benchmarks; cost-plus is margin-based; dynamic pricing is algorithm-driven. Aligns with Oracle Retail Price Management (RPM) strategy configuration.']
  proposed_price decimal(18,4) [note: 'The new retail selling price being requested for approval. Compared against current_price to determine the magnitude of the price change and route to the appropriate approval tier.']
  rejection_reason varchar [note: 'Free-text or coded explanation provided by the approver when rejecting a price change request. Captures the business rationale for rejection (e.g., margin floor breach, insufficient competitive justification, incorrect price zone). Required when approval_status = \'rejected\'.']
  requested_timestamp timestamp [note: 'The date and time when the price change or markdown approval request was formally submitted by the requestor. Principal business event timestamp for the approval workflow lifecycle.']
  rpm_event_code varchar [note: 'The source system event identifier from Oracle Retail Price Management (RPM) that triggered this approval workflow. Enables traceability back to the originating RPM pricing event for reconciliation and audit purposes.']
  sap_change_doc_number varchar [note: 'The SAP S/4HANA change document number generated when the approved price change is posted to the SD (Sales and Distribution) or MM (Materials Management) module. Populated after approval and downstream activation. Supports cross-system audit trail.']
  sla_response_hours varchar [note: 'The maximum number of hours within which the assigned approver must respond to the price approval request per the pricing governance SLA (Service Level Agreement). Drives escalation logic when decision_timestamp exceeds requested_timestamp + sla_response_hours.']
  updated_timestamp timestamp [note: 'The date and time when this price approval record was last modified. Tracks any changes to approval status, tier reassignment, or rejection reason updates.']
  version_number varchar [note: 'Incremental version counter for this price approval record. Incremented each time the approval is revised, resubmitted after rejection, or modified. Supports optimistic concurrency control and change history tracking in the Silver Layer.']

  Note: 'Workflow record tracking the approval lifecycle for price change requests, markdowns, and price list activations. Captures requestor, approver hierarchy, approval status (pending, approved, rejected, escalated), approval tier (category manager, merchandise director, VP), timestamps, rejection reason, and references to the governed price change or markdown. Enforces pricing governance controls and audit trails for material price decisions requiring segregation of duties.'
}

Table pricing.cost_zone {
  cost_zone_id varchar [pk, note: 'Primary key for cost_zone']
  dc_facility_id varchar [note: 'Foreign key linking to supplychain.dc_facility. Business justification: Cost zones are structured around DC facility catchment areas — freight_factor_percentage, overhead_factor_percentage, and duty_factor_percentage in cost_zone are driven by the DC facility\'s location a']
  parent_cost_zone_id varchar [note: 'Reference to a parent cost zone in a hierarchical cost zone structure, enabling nested or regional rollup of cost zones.']
  price_zone_id varchar [note: 'Foreign key linking to pricing.price_zone. Business justification: Cost zones and price zones are related geographic constructs that often align for margin calculation purposes. A cost zone (defining supplier cost structures for a geographic area) maps to a correspon']
  vendor_id varchar [note: 'Vendor for this cost zone']
  annual_revenue_amount decimal(18,2) [note: 'Estimated or actual annual revenue generated within this cost zone in the zone\'s currency.']
  annual_volume_units varchar [note: 'Estimated or actual annual sales volume in units for this cost zone, used for cost allocation and pricing optimization.']
  approval_required_flag boolean [note: 'Indicates whether pricing changes in this cost zone require management approval before implementation.']
  approval_threshold_amount decimal(18,2) [note: 'Monetary threshold above which pricing changes in this zone require additional approval levels.']
  code varchar [note: 'Business identifier code for the cost zone used in pricing systems and external integrations. Typically alphanumeric and unique across the enterprise.']
  competitive_intensity varchar [note: 'Level of competitive pressure in this cost zone affecting pricing flexibility and margin targets.']
  cost_adjustment_factor decimal(7,4) [note: 'Multiplier applied to base costs to account for zone-specific cost variations, typically ranging from 0.8 to 1.5.']
  cost_review_frequency varchar [note: 'Scheduled frequency for reviewing and updating cost factors and margins for this cost zone.']
  cost_zone_status varchar [note: 'Current lifecycle status of the cost zone indicating whether it is actively used in pricing calculations.']
  cost_zone_type varchar [note: 'Classification of the cost zone based on the segmentation strategy used (geographic regions, sales channels, store formats, vendor agreements, product categories, or custom business rules).']
  country_code varchar [note: 'Three-letter ISO 3166-1 alpha-3 country code indicating the primary country for this cost zone.']
  created_timestamp timestamp [note: 'Timestamp when the cost zone record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code used for cost calculations within this zone.']
  default_cost_method varchar [note: 'Primary costing methodology applied to products within this cost zone for inventory valuation and pricing calculations.']
  description varchar [note: 'Detailed description of the cost zone including its purpose, geographic coverage, and business rationale.']
  duty_factor_percentage decimal(5,2) [note: 'Percentage applied to base product cost to account for import duties and tariffs applicable to this cost zone.']
  effective_end_date date [note: 'Date when the cost zone ceases to be active. Null indicates an open-ended cost zone with no planned expiration.']
  effective_start_date date [note: 'Date when the cost zone becomes active and applicable for pricing calculations.']
  freight_factor_percentage decimal(5,2) [note: 'Percentage applied to base product cost to account for freight and transportation expenses specific to this cost zone.']
  geographic_scope varchar [note: 'Geographic coverage level of the cost zone indicating the breadth of locations included.']
  hierarchy_level varchar [note: 'Numeric level in the cost zone hierarchy where 1 represents the top level and higher numbers represent deeper nesting.']
  last_cost_review_date date [note: 'Date when cost factors and pricing parameters for this zone were last reviewed and validated.']
  last_modified_timestamp timestamp [note: 'Timestamp when the cost zone record was last updated.']
  minimum_margin_percentage decimal(5,2) [note: 'Minimum acceptable gross margin percentage for products sold within this cost zone, used as a pricing floor constraint.']
  name varchar [note: 'Human-readable name of the cost zone for display and reporting purposes.']
  next_cost_review_date date [note: 'Scheduled date for the next cost review and potential adjustment of zone parameters.']
  notes varchar [note: 'Free-form text field for additional business context, special instructions, or historical information about the cost zone.']
  overhead_factor_percentage decimal(5,2) [note: 'Percentage applied to base product cost to account for warehousing, handling, and operational overhead costs in this zone.']
  pricing_strategy varchar [note: 'Primary pricing strategy employed in this cost zone. EDLP (Everyday Low Price) maintains consistent low prices; Hi-Lo uses promotional pricing cycles.']
  store_count varchar [note: 'Number of retail locations assigned to this cost zone for operational reporting and volume analysis.']
  target_margin_percentage decimal(5,2) [note: 'Target gross margin percentage that pricing strategies aim to achieve for products in this cost zone.']

  Note: 'Master reference table for cost_zone. Referenced by cost_zone_id.'
}

Table promotion.promo_campaign {
  promo_campaign_id varchar [pk, note: 'Unique identifier for the promotional campaign. Primary key.']
  brand_id varchar [note: 'Foreign key linking to product.product_brand. Business justification: Retail promotion campaigns are frequently brand-level events (e.g., \'Pepsi brand week\', \'private label push\'). This FK enables brand-level promotion spend tracking, vendor co-op funding reconciliation']
  format_id varchar [note: 'Foreign key linking to store.format. Business justification: Store format drives promotional strategy — hypermarket formats run different campaigns than convenience formats. A format_id FK on promo_campaign enables format-specific promotional planning, campaign']
  parent_promo_campaign_id varchar [note: 'Self-referencing FK on promo_campaign (parent_promo_campaign_id)']
  promo_calendar_id varchar [note: 'Foreign key linking to promotion.promo_calendar. Business justification: Campaigns are planned and executed according to promotional calendar periods. The promo_campaign has start_date and end_date that should align with promotional periods defined in promo_calendar (e.g.,']
  sales_territory_id varchar [note: 'Foreign key linking to store.sales_territory. Business justification: Promotional campaigns are scoped to sales territories to align with sales rep coverage and territory-based revenue targets. promo_campaign.geographic_scope is a plain-text field that should be replace']
  vendor_id varchar [note: 'Identifier of the vendor providing funding or support for the campaign, if applicable.']
  approval_status varchar [note: 'Approval workflow status indicating whether the campaign has been reviewed and authorized for execution.']
  approved_by varchar [note: 'Name or identifier of the business user who approved the campaign for execution.']
  approved_timestamp timestamp [note: 'Date and time when the campaign was approved for execution.']
  budget_amount decimal(18,2) [note: 'Total allocated budget for the promotional campaign including discounts, advertising, and operational costs.']
  budget_currency_code varchar [note: 'Three-letter ISO 4217 currency code for the campaign budget amount.']
  campaign_code varchar [note: 'Externally-known unique business identifier for the campaign used across systems and communications.']
  campaign_description varchar [note: 'Detailed description of the campaign objectives, target audience, and promotional strategy.']
  campaign_name varchar [note: 'Human-readable name of the promotional campaign for business user identification and reporting.']
  campaign_type varchar [note: 'Classification of the promotional campaign by strategic purpose and funding model.']
  channel_scope varchar [note: 'Distribution channels where the promotional campaign is active (omnichannel, in-store, e-commerce, mobile).']
  circular_ad_flag boolean [note: 'Indicates whether the campaign is featured in printed or digital circular advertisements.']
  cost_center_code varchar [note: 'Financial cost center code to which campaign expenses are allocated for P&L reporting.']
  created_timestamp timestamp [note: 'Date and time when the campaign record was first created in the system.']
  customer_segment_target varchar [note: 'Target customer segment or persona for the promotional campaign (e.g., loyalty members, new customers, high-value).']
  digital_promotion_flag boolean [note: 'Indicates whether the campaign includes digital promotions delivered via e-commerce, mobile app, or email.']
  discount_strategy varchar [note: 'Primary discount mechanism used in the campaign (percentage off, fixed amount, BOGO, bundle pricing, tiered discounts, rebate).']
  end_date date [note: 'Date when the promotional campaign concludes and offers are no longer valid.']
  event_classification varchar [note: 'Specific promotional event type within the campaign (e.g., Flash Sale, Doorbuster, BOGO). [ENUM-REF-CANDIDATE: flash_sale|doorbuster|holiday_sale|weekly_circular|bogo|markdown|rebate — 7 candidates stripped; promote to reference product]']
  geographic_scope varchar [note: 'Geographic reach of the promotional campaign (national, regional, local, or specific stores).']
  loyalty_exclusive_flag boolean [note: 'Indicates whether the campaign offers are exclusive to loyalty program members.']
  modified_by varchar [note: 'Name or identifier of the user who last modified the campaign record.']
  modified_timestamp timestamp [note: 'Date and time when the campaign record was last updated.']
  owner_email varchar [note: 'Email address of the campaign owner for communication and escalation.']
  owner_name varchar [note: 'Name of the marketing manager or business owner responsible for the campaign execution and performance.']
  priority_level varchar [note: 'Business priority level of the campaign for resource allocation and conflict resolution.']
  promo_campaign_status varchar [note: 'Current lifecycle status of the promotional campaign.']
  stackable_flag boolean [note: 'Indicates whether campaign offers can be combined with other promotions or coupons.']
  start_date date [note: 'Date when the promotional campaign becomes active and offers are available to customers.']
  target_customer_reach varchar [note: 'Number of unique customers the campaign aims to reach or engage.']
  target_revenue decimal(18,2) [note: 'Expected revenue target for the promotional campaign period.']
  target_units_sold varchar [note: 'Target number of units expected to be sold during the promotional campaign.']
  terms_and_conditions varchar [note: 'Legal terms, conditions, and exclusions governing the promotional campaign offers.']
  vendor_funded_flag boolean [note: 'Indicates whether the promotional campaign is partially or fully funded by vendor cooperative marketing agreements.']

  Note: 'Master record for a promotional campaign representing a time-bound marketing initiative encompassing both the strategic campaign wrapper and discrete promotional sales events (Flash Sales, Doorbuster Events, Holiday Sales). Captures campaign name, type, start/end dates, event classification, budget, and performance targets.'
}

Table promotion.promo_offer {
  promo_offer_id varchar [pk, note: 'Unique identifier for the promotional offer. Primary key for this entity.']
  brand_id varchar [note: 'Foreign key linking to product.product_brand. Business justification: Promotional offers are frequently brand-scoped (e.g., \'buy any Kraft product, save $2\'). This FK enables brand-level offer performance reporting, vendor co-op tracking, and brand manager analysis — a ']
  carrier_service_id varchar [note: 'Foreign key linking to fulfillment.carrier_service. Business justification: Shipping promotion offers (free ground shipping, discounted overnight) must specify which carrier_service is eligible. Retailers enforce this at offer creation to control cost exposure and carrier con']
  cluster_id varchar [note: 'Foreign key linking to store.cluster. Business justification: Promotional offers are targeted to store clusters — cluster-based offer eligibility is a core retail promotional planning process. promo_offer.store_eligibility_scope is a plain-text denormalization. ']
  item_hierarchy_id varchar [note: 'Foreign key linking to product.item_hierarchy. Business justification: Retail promotions are frequently scoped at the category level (e.g., \'20% off all beverages\'). Category managers require this FK for category-level offer planning, promotion performance reporting by d']
  promo_campaign_id varchar [note: 'Reference to the parent promotional campaign under which this offer is organized.']
  region_id varchar [note: 'Foreign key linking to store.region. Business justification: Promotional offers have regional eligibility driven by regulatory differences, tax jurisdictions, and market conditions. promo_offer.jurisdiction_restriction_flag and store_eligibility_scope indicate ']
  return_policy_id varchar [note: 'Foreign key linking to returns.return_policy. Business justification: Promotional offers frequently carry specific return policy overrides — final-sale offers restrict returns, loyalty offers extend return windows. POS and e-commerce systems must enforce the correct ret']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Promotional offers target specific SKUs for discount application. Essential for offer eligibility validation, POS redemption logic, inventory planning for promoted items, and promotional ROI analysis ']
  vendor_id varchar [note: 'Reference to the vendor/supplier funding or co-funding this promotional offer. Null if retailer-funded.']
  vendor_item_id varchar [note: 'Foreign key linking to supplier.vendor_item. Business justification: Promotional offers in retail are planned at the vendor item level (specific pack size, cost, and configuration). \'Vendor item promotional planning\' requires linking offers to the exact vendor_item to ']
  activation_trigger varchar [note: 'Event or condition that activates this offer for a customer. manual = customer enters code; cart_threshold = automatically applied when cart meets criteria; login = activated upon customer login; geofence = triggered by location; time_based = activated at specific time; event_based = triggered by business event.']
  approval_status varchar [note: 'Approval workflow status for this promotional offer. pending = awaiting approval; approved = authorized for execution; rejected = not approved.']
  approved_by varchar [note: 'Name or identifier of the business user who approved this promotional offer. Null if not yet approved.']
  approved_timestamp timestamp [note: 'Timestamp when this promotional offer was approved. Null if not yet approved.']
  channel_eligibility varchar [note: 'Sales channels where this offer is valid. POS = in-store Point of Sale; ecommerce = online web storefront; mobile = mobile app; BOPIS = Buy Online Pick Up In Store; ROPIS = Reserve Online Pick Up In Store; all_channels = valid across all channels. [ENUM-REF-CANDIDATE: POS|ecommerce|mobile|BOPIS|ROPIS|call_center|kiosk — promote to reference product]']
  cost_share_percentage decimal(5,2) [note: 'Percentage of promotional discount cost borne by the vendor (0-100). Null if not applicable or fully retailer-funded.']
  created_timestamp timestamp [note: 'Timestamp when this promotional offer record was first created in the system.']
  customer_segment_eligibility varchar [note: 'Defines which customer segments are eligible to redeem this offer. all_customers = no restrictions; loyalty_members = requires loyalty program membership; VIP = high-value customers only; new_customers = first-time buyers; targeted_segment = specific marketing segment.']
  digital_delivery_flag boolean [note: 'Indicates whether this offer is delivered digitally (e.g., via email, mobile app push notification, personalized web banner). True = digital delivery; False = traditional circular/print or in-store signage only.']
  discount_method varchar [note: 'Method by which the discount is calculated and applied. Percentage = discount as a percentage of price; fixed_amount = flat dollar/currency discount; tiered = discount varies by purchase tier; quantity_based = discount based on quantity purchased.']
  discount_value decimal(10,2) [note: 'Numeric value of the discount. Interpretation depends on discount_method: for percentage, this is the percentage (e.g., 15.00 for 15%); for fixed_amount, this is the currency amount (e.g., 5.00 for $5 off).']
  display_message varchar [note: 'Customer-facing promotional message displayed at Point of Sale (POS), e-commerce checkout, and mobile app. Concise marketing copy highlighting the offer value.']
  effective_end_date date [note: 'Date when this promotional offer expires and is no longer eligible for redemption. Null indicates an open-ended offer.']
  effective_end_time timestamp [note: 'Precise timestamp when this promotional offer expires, supporting time-of-day specific promotions. Null indicates no specific end time constraint.']
  effective_start_date date [note: 'Date when this promotional offer becomes active and eligible for redemption.']
  effective_start_time timestamp [note: 'Precise timestamp when this promotional offer becomes active, supporting time-of-day specific promotions (e.g., happy hour deals, flash sales).']
  jurisdiction_restriction_flag boolean [note: 'Indicates whether this offer has jurisdiction-specific restrictions (e.g., state-level promotional laws, EU consumer protection price display requirements). True = restrictions apply; False = no jurisdiction restrictions.']
  maximum_redemption_per_customer varchar [note: 'Maximum number of times a single customer can redeem this offer. Null indicates unlimited redemptions per customer.']
  maximum_redemption_total decimal(18,2) [note: 'Maximum total number of redemptions allowed across all customers for this offer. Null indicates unlimited total redemptions.']
  minimum_purchase_amount decimal(10,2) [note: 'Minimum purchase amount (in currency) required to qualify for this promotional offer. Null if no minimum threshold applies.']
  minimum_purchase_quantity varchar [note: 'Minimum quantity of eligible items required to qualify for this promotional offer. Null if no quantity threshold applies.']
  modified_by varchar [note: 'Name or identifier of the business user who last modified this promotional offer record.']
  modified_timestamp timestamp [note: 'Timestamp when this promotional offer record was last modified.']
  offer_code varchar [note: 'Externally-known unique alphanumeric code for the promotional offer, used for redemption at Point of Sale (POS), e-commerce checkout, and mobile applications.']
  offer_description varchar [note: 'Detailed description of the promotional offer, including terms, conditions, and customer-facing messaging.']
  offer_name varchar [note: 'Human-readable name of the promotional offer for internal reference and customer-facing display.']
  offer_priority varchar [note: 'Priority ranking for offer application when multiple offers are eligible. Lower numbers indicate higher priority. Used by Point of Sale (POS) and e-commerce checkout engines to resolve offer conflicts.']
  offer_status varchar [note: 'Current lifecycle status of the promotional offer. draft = under development; scheduled = approved and awaiting activation; active = currently redeemable; paused = temporarily suspended; expired = past end date; cancelled = terminated before completion.']
  offer_type varchar [note: 'Classification of the promotional offer mechanics. BOGO = Buy One Get One; percent_off = percentage discount; dollar_off = fixed amount discount; free_gift = gift with purchase; bundle = bundled product deal; threshold_discount = discount upon reaching purchase threshold.']
  personalization_flag boolean [note: 'Indicates whether this offer is personalized to individual customers based on purchase history, preferences, or predictive analytics. True = personalized; False = mass-market offer.']
  product_eligibility_scope varchar [note: 'Defines which products are eligible for this offer. all_products = applies to entire catalog; category = applies to specific product categories; SKU_list = applies to specific Stock Keeping Units (SKUs); brand = applies to specific brands; excluded_products = applies to all products except specified exclusions.']
  restricted_jurisdictions varchar [note: 'Comma-separated list of jurisdiction codes (ISO 3166-1 alpha-3 country codes or state/province codes) where this offer is restricted or prohibited due to regulatory compliance requirements. Null if no restrictions.']
  stackable_flag boolean [note: 'Indicates whether this offer can be combined (stacked) with other promotional offers in a single transaction. True = stackable; False = exclusive offer.']
  store_eligibility_scope varchar [note: 'Defines the scope of store eligibility for this offer. all_stores = valid at all retail locations; store_group = valid at a defined group of stores; individual_store = valid at specific stores only; excluded_stores = valid everywhere except specified stores.']
  terms_and_conditions varchar [note: 'Full legal terms and conditions text for this promotional offer, including disclaimers, exclusions, and fine print required for regulatory compliance.']
  vendor_funded_flag boolean [note: 'Indicates whether this promotional offer is funded (wholly or partially) by a vendor/supplier rather than the retailer. True = vendor-funded; False = retailer-funded.']
  created_by varchar [note: 'Name or identifier of the business user who created this promotional offer record.']

  Note: 'Defines a specific promotional offer within a campaign, representing the actual deal mechanics (BOGO, percent-off, dollar-off, free gift with purchase, bundle deal, threshold discount). Captures offer type, discount value, discount method (percentage vs. fixed), minimum purchase threshold, maximum redemption limit, stackability rules, offer priority, eligible SKUs/categories/product hierarchies (with inclusion/exclusion flags), channel eligibility (POS, e-commerce, mobile, BOPIS), store/store-group scope, digital delivery attributes (targeting segment, personalization, activation trigger) when applicable, effective date range, and jurisdictional compliance flags (e.g., state-level promotional restrictions, EU consumer protection price display requirements). This is the atomic unit of promotion logic executed at POS and e-commerce checkout engines. Encompasses SKU eligibility rules, channel assignments, store assignments, and digital offer mechanics as integral attributes. Supports international compliance by carrying jurisdiction-specific restriction flags that gate offer activation by market.'
}

Table promotion.coupon {
  coupon_id varchar [pk, note: 'Unique identifier for the coupon instrument. Primary key.']
  item_hierarchy_id varchar [note: 'Foreign key linking to product.item_hierarchy. Business justification: Coupons are frequently scoped to a product category (e.g., \'$1 off any cereal\', \'save on all organic produce\'). This FK enables category-level coupon planning, redemption analysis by department, and c']
  promo_campaign_id varchar [note: 'Reference to the parent promotional campaign under which this coupon was issued.']
  promo_offer_id varchar [note: 'Foreign key linking to promotion.promo_offer. Business justification: Coupons are instruments that implement specific promotional offers. While coupon already has promotion_campaign_id (linking to the campaign), it needs promo_offer_id to identify the exact offer the co']
  region_id varchar [note: 'Foreign key linking to store.region. Business justification: Coupons have geographic restrictions by region — coupon.geographic_restriction is a plain-text denormalization of region data. A region_id FK enables proper geographic restriction enforcement, regiona']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Coupons restrict redemption to qualifying SKUs. POS systems validate coupon eligibility against product attributes (brand, category, vendor). Inventory planning uses this to forecast demand spikes. Ve']
  vendor_id varchar [note: 'Reference to the supplier or manufacturer funding the coupon, if applicable. Null for retailer-funded coupons.']
  barcode varchar [note: 'UPC or EAN barcode number for physical coupon scanning at POS. May be 12-digit UPC-A or 13-digit EAN format.']
  code varchar [note: 'Alphanumeric code that customers enter or scan to redeem the coupon. Unique business identifier for the coupon across all channels.']
  coupon_status varchar [note: 'Current lifecycle state of the coupon. active means available for redemption, inactive means not yet released, expired means past expiration_date, suspended means temporarily disabled, redeemed means fully used (for single-use coupons).']
  coupon_type varchar [note: 'Classification of coupon by issuing authority and format. Manufacturer coupons are vendor-funded, store coupons are retailer-funded, digital coupons are app/email-based, paper coupons are physical print, loyalty coupons are tied to loyalty programs, vendor_funded are supplier co-op promotions.']
  created_timestamp timestamp [note: 'Timestamp when the coupon record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the face value (e.g., USD, CAD, EUR).']
  digital_distribution_quantity varchar [note: 'Total number of digital coupon codes issued via email, app, or SMS. Null for paper-only coupons.']
  digital_wallet_enabled_flag boolean [note: 'Indicates whether this coupon can be stored in a digital wallet (mobile app, Apple Wallet, Google Pay) for redemption (True) or is paper-only (False).']
  discount_type varchar [note: 'Mechanism by which the coupon provides value. Percentage applies a percent off, fixed_amount deducts a dollar value, BOGO is buy-one-get-one, free_shipping waives delivery charges, tiered applies different discounts based on purchase thresholds.']
  eligible_channel varchar [note: 'Sales channels where the coupon can be redeemed. all_channels means omnichannel, pos is in-store only, ecommerce is online only, mobile_app is app-only, bopis is buy-online-pickup-in-store.']
  eligible_product_scope varchar [note: 'Defines the breadth of products to which the coupon applies. all_products means store-wide, category restricts to a product category, brand restricts to a specific brand, sku restricts to specific SKUs, basket applies to entire cart total.']
  exclusion_list varchar [note: 'Comma-separated list of product SKUs, categories, or brands explicitly excluded from coupon eligibility. Null if no exclusions apply.']
  expiration_date date [note: 'Last date on which the coupon can be redeemed. After this date, the coupon is no longer valid.']
  face_value decimal(10,2) [note: 'Nominal discount value of the coupon. For fixed_amount coupons, this is the dollar discount. For percentage coupons, this is the percentage (e.g., 15.00 for 15% off). For BOGO, may represent the value of the free item.']
  issue_channel varchar [note: 'Distribution channel through which the coupon was issued to customers. Circular refers to weekly print ads, mobile_app and email are digital channels, in_store_kiosk is physical print at store, website is online portal, social_media includes Facebook/Instagram ads, direct_mail is postal delivery, SMS is text message. [ENUM-REF-CANDIDATE: circular|mobile_app|email|in_store_kiosk|website|social_media|direct_mail|sms — 8 candidates stripped; promote to reference product]']
  issue_date date [note: 'Date on which the coupon was first made available to customers. Marks the start of the coupons validity window.']
  issuing_authority varchar [note: 'Entity responsible for funding and issuing the coupon. Retailer indicates store-funded, manufacturer indicates vendor-funded, vendor indicates supplier co-op, third_party indicates external promotion partner.']
  last_modified_by varchar [note: 'User ID or system identifier of the person or process that last modified the coupon record.']
  last_modified_timestamp timestamp [note: 'Timestamp when the coupon record was last updated.']
  maximum_discount_amount decimal(10,2) [note: 'Cap on the total discount that can be applied by this coupon, regardless of cart value. Null if no cap applies. Relevant for percentage-based coupons.']
  minimum_purchase_amount decimal(10,2) [note: 'Minimum transaction subtotal required to qualify for coupon redemption. Null if no minimum applies.']
  print_quantity varchar [note: 'Total number of physical paper coupons printed for distribution. Null for digital-only coupons.']
  redemption_limit_per_customer varchar [note: 'Maximum number of times a single customer can redeem this coupon. Null or 0 indicates unlimited redemptions per customer.']
  single_use_flag boolean [note: 'Indicates whether the coupon can only be used once (True) or multiple times (False) by the same customer, subject to redemption_limit_per_customer.']
  stackable_flag boolean [note: 'Indicates whether this coupon can be combined with other coupons or promotions in a single transaction (True) or must be used alone (False).']
  terms_and_conditions varchar [note: 'Full legal text of coupon usage terms, restrictions, and disclaimers. Required for regulatory compliance and customer transparency.']
  total_redemption_limit varchar [note: 'Maximum total number of redemptions allowed across all customers for this coupon. Null or 0 indicates unlimited total redemptions.']
  created_by varchar [note: 'User ID or system identifier of the person or process that created the coupon record.']

  Note: 'Master record for a coupon instrument issued as part of a promotional campaign. Captures coupon code, barcode/UPC, coupon type (manufacturer, store, digital, paper), face value, discount type, issue channel (circular, app, email, in-store kiosk), expiration date, single-use vs. multi-use flag, maximum redemption count, stackability with other offers, issuing authority (store vs. vendor-funded), and print/digital distribution quantity. Supports both digital wallet coupons and physical paper formats across POS and e-commerce channels. Coupon redemption events are recorded in promo_redemption (the SSOT for all redemption activity).'
}

Table promotion.circular_ad {
  circular_ad_id varchar [pk, note: 'Unique identifier for the circular advertisement. Primary key for the circular ad entity.']
  featured_sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Circular ads feature specific hero SKUs on cover/pages. Production teams need product images, descriptions, compliance attributes. Inventory planning ensures featured items are in stock. Performance t']
  item_hierarchy_id varchar [note: 'Foreign key linking to product.item_hierarchy. Business justification: Circular ads are planned by department/category (e.g., \'produce feature page\', \'frozen foods spread\'). Category managers require this FK for circular space allocation planning and category-level ad pe']
  promo_budget_id varchar [note: 'Foreign key linking to promotion.promo_budget. Business justification: Circular ads have production costs (production_cost_amount, production_cost_currency_code) that are funded from promotional budgets. While circular_ad.promo_campaign_id links to campaign, the specific']
  promo_calendar_id varchar [note: 'Foreign key linking to promotion.promo_calendar. Business justification: Circular ads are published according to promotional calendar periods. The circular_ad has effective_start_date and effective_end_date that align with promotional periods defined in promo_calendar (e.g']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Circular ads are marketing vehicles that promote specific promotional campaigns. While circular_ad already links to promotion.campaign (cross-domain for overall marketing campaign), it needs a link to']
  region_id varchar [note: 'Foreign key linking to store.region. Business justification: Circular ads are published for specific geographic markets/regions. circular_ad.geographic_market is a plain-text denormalization of region data. A region_id FK enables circular distribution planning,']
  vendor_id varchar [note: 'Reference to the external vendor or agency responsible for circular design, production, or distribution services.']
  approval_date date [note: 'Date when the circular content and design were officially approved for production and distribution by marketing management.']
  circular_name varchar [note: 'Marketing name or title of the circular advertisement, such as \'Weekly Savings\', \'Holiday Spectacular\', or \'Back to School Event\'.']
  circular_number varchar [note: 'Business identifier for the circular advertisement, typically a human-readable code or number used for reference in marketing and merchandising operations.']
  circular_type varchar [note: 'Classification of the circular advertisement based on its purpose and timing, such as weekly promotional circular, seasonal event, holiday special, clearance sale, or grand opening.']
  compliance_review_flag boolean [note: 'Indicates whether the circular has undergone legal and regulatory compliance review for advertising standards, pricing transparency, and consumer protection requirements. True if reviewed, false otherwise.']
  cover_image_url varchar [note: 'URL or file path to the cover image or hero graphic for the circular, used for digital display and thumbnail previews.']
  created_timestamp timestamp [note: 'Timestamp when the circular record was first created in the system, used for audit trail and lifecycle tracking.']
  digital_impressions_target varchar [note: 'Target number of digital impressions or views for the circular across digital channels, used for campaign planning and performance measurement.']
  distribution_channel varchar [note: 'Primary channel through which the circular is distributed to customers, including print mail, digital web, email, mobile app, social media, or in-store display.']
  edition_number varchar [note: 'Edition or version number of the circular, used to track revisions and multiple releases within a campaign period.']
  effective_end_date date [note: 'Date when the promotional offers and pricing featured in the circular expire and are no longer valid for customer redemption.']
  effective_start_date date [note: 'Date when the promotional offers and pricing featured in the circular become valid and active for customer redemption.']
  is_vendor_funded boolean [note: 'Indicates whether the circular includes vendor-funded promotional offers or co-op advertising agreements. True if vendor funding is involved, false otherwise.']
  language_code varchar [note: 'Two-letter ISO 639-1 language code indicating the primary language of the circular content, such as \'en\' for English or \'es\' for Spanish.']
  last_modified_timestamp timestamp [note: 'Timestamp when the circular record was most recently updated, used for audit trail and change tracking.']
  notes varchar [note: 'Free-text field for additional notes, special instructions, or context about the circular production, distribution, or performance.']
  page_count varchar [note: 'Total number of pages in the circular advertisement, used for production planning and cost management.']
  pdf_file_url varchar [note: 'URL or file path to the complete PDF version of the circular, used for digital distribution and archival purposes.']
  print_quantity varchar [note: 'Total number of physical copies printed for distribution, used for production cost tracking and circulation analysis. Null for digital-only circulars.']
  production_cost_amount decimal(15,2) [note: 'Total cost to produce and distribute the circular, including design, printing, mailing, and digital distribution expenses. Used for marketing ROI analysis.']
  production_cost_currency_code varchar [note: 'Three-letter ISO 4217 currency code for the production cost amount, such as USD, CAD, or EUR.']
  production_status varchar [note: 'Current lifecycle status of the circular in the production workflow, from initial draft through review, approval, production, publication, and archival.']
  publication_date date [note: 'Date when the circular advertisement is officially published or released to customers across distribution channels.']
  target_audience varchar [note: 'Primary customer segment or demographic targeted by this circular, such as families, millennials, budget shoppers, or loyalty members. Supports personalized marketing strategies.']
  theme varchar [note: 'Marketing theme or creative concept for the circular, such as \'Summer Savings\', \'Holiday Gift Guide\', or \'Spring Refresh\', used for brand consistency and customer engagement.']
  vendor_funding_amount decimal(15,2) [note: 'Total amount of vendor co-op funding or promotional allowances applied to this circular, used for cost allocation and vendor settlement.']

  Note: 'Master record for a printed or digital weekly/seasonal circular advertisement, including both the circular header and its featured item lines. Header captures circular name, edition number, publication date, effective date range, distribution channel (print, digital, email, app), geographic market coverage, page count, and production status. Item lines capture featured SKU, advertised price, promotional price, page number, position on page, feature type (front page, endcap feature, in-book), ad copy headline, image reference, and loss-leader flag. The circular is a key promotional vehicle in retail that drives planned traffic and is directly linked to campaign offers. Supports circular effectiveness analysis by item and planogram alignment with advertised features.'
}

Table promotion.rebate {
  rebate_id varchar [pk, note: 'Unique identifier for the rebate program. Primary key.']
  item_hierarchy_id varchar [note: 'Foreign key linking to product.item_hierarchy. Business justification: Retail rebate programs are frequently structured at the category level (e.g., \'all frozen foods rebate\'). The existing rebate.sku_id covers SKU-level rebates; this FK enables category-level rebate acc']
  promo_budget_id varchar [note: 'Foreign key linking to promotion.promo_budget. Business justification: A rebate program is funded from a promotional budget. rebate.total_budget_amount is a budget tracking field that duplicates the authoritative budget record in promo_budget. Adding promo_budget_id to r']
  promo_campaign_id varchar [note: 'Identifier of the parent promotional campaign or event to which this rebate belongs. Null if rebate is standalone.']
  region_id varchar [note: 'Foreign key linking to store.region. Business justification: Rebates have geographic eligibility by region — rebate.geographic_eligibility is a plain-text denormalization of region data. A region_id FK enables proper regional rebate eligibility enforcement, reg']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Rebates apply to specific qualifying products. Claim validation verifies purchased SKU matches rebate terms. Vendor chargeback reconciliation requires SKU-level tracking. Inventory planning adjusts fo']
  vendor_id varchar [note: 'Identifier of the supplier or vendor sponsoring or funding the rebate program. Null for retailer-funded rebates.']
  vendor_item_id varchar [note: 'Foreign key linking to supplier.vendor_item. Business justification: Vendor rebates in retail are negotiated at the vendor item level — qualifying purchase quantities and costs are specific to a vendor\'s item configuration (pack size, unit cost). \'Vendor item rebate tr']
  vendor_promo_agreement_id varchar [note: 'Foreign key linking to promotion.vendor_promo_agreement. Business justification: rebate has vendor_funding_percentage indicating vendor-funded rebates. The vendor_promo_agreement is the contractual basis governing vendor-funded rebate programs — it defines the funding terms, settl']
  amount decimal(15,2) [note: 'Fixed monetary value of the rebate in the transaction currency. Null if rebate is percentage-based.']
  approval_status varchar [note: 'Workflow approval state for the rebate program before it can be activated. Ensures financial and legal review compliance.']
  approved_timestamp timestamp [note: 'Date and time when the rebate program was approved. Null if not yet approved.']
  channel_eligibility varchar [note: 'Sales channels where the rebate can be redeemed: all_channels (any touchpoint), pos_only (in-store Point of Sale only), ecommerce_only (online purchases), mobile_app_only (mobile app transactions), or omnichannel (integrated cross-channel).']
  created_timestamp timestamp [note: 'Date and time when the rebate program record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the rebate amount (e.g., USD, EUR, GBP).']
  customer_segment_eligibility varchar [note: 'Comma-separated list of customer segment codes eligible for the rebate (e.g., loyalty_member, employee, senior, student). Null if available to all customers.']
  description varchar [note: 'Detailed internal description of the rebate program purpose, target audience, and business objectives. Used for internal planning and reporting.']
  effective_end_date date [note: 'Date when the rebate program expires and is no longer available for new submissions. Null for open-ended programs.']
  effective_start_date date [note: 'Date when the rebate program becomes active and eligible for customer redemption.']
  exclusion_product_list varchar [note: 'Comma-separated list of Stock Keeping Unit (SKU) codes or product categories explicitly excluded from the rebate program.']
  last_modified_timestamp timestamp [note: 'Date and time when the rebate program record was last updated.']
  marketing_message varchar [note: 'Customer-facing promotional message displayed in circulars, digital ads, and at Point of Sale to communicate the rebate offer.']
  maximum_rebate_amount decimal(15,2) [note: 'Cap on the total rebate value that can be claimed per transaction or per customer. Null if no cap applies.']
  minimum_purchase_amount decimal(15,2) [note: 'Minimum transaction value required to qualify for the rebate. Null if no minimum threshold applies.']
  minimum_purchase_quantity varchar [note: 'Minimum number of qualifying units (Stock Keeping Units) that must be purchased to qualify for the rebate. Null if no quantity threshold applies.']
  name varchar [note: 'Marketing name of the rebate program displayed to customers and used in promotional materials.']
  payment_method varchar [note: 'Mechanism by which the rebate value is returned to the customer: check (mailed physical check), store_credit (loyalty account credit), digital_credit (e-wallet or app credit), prepaid_card (branded debit card), bank_transfer (direct deposit), or instant_discount (applied at Point of Sale).']
  payment_processing_days varchar [note: 'Expected number of business days from rebate approval to payment issuance. Used for customer Service Level Agreement (SLA) communication.']
  percentage decimal(5,2) [note: 'Percentage discount applied as rebate (e.g., 10.00 for 10% off). Null if rebate is fixed-amount.']
  qualifying_product_list varchar [note: 'Comma-separated list of Stock Keeping Unit (SKU) codes, Universal Product Code (UPC) numbers, or product category codes that qualify for the rebate. Null if rebate applies to all products.']
  rebate_number varchar [note: 'Externally-visible unique business identifier for the rebate program, used in customer communications and vendor agreements.']
  rebate_status varchar [note: 'Current lifecycle state of the rebate program: draft (being configured), active (live and accepting submissions), paused (temporarily suspended), expired (past end date), cancelled (terminated early), or completed (ended successfully).']
  rebate_type varchar [note: 'Classification of the rebate mechanism: instant rebate (applied at Point of Sale), mail-in rebate (customer submits proof of purchase), vendor-funded rebate (supplier-sponsored), digital rebate (online redemption), promotional allowance (trade promotion), or volume rebate (quantity-based incentive).']
  redemption_limit_per_customer varchar [note: 'Maximum number of times a single customer can claim this rebate during the program period. Null if no limit applies.']
  redemption_limit_per_transaction varchar [note: 'Maximum number of rebate instances that can be applied in a single transaction. Null if no limit applies.']
  requires_proof_of_purchase boolean [note: 'Indicates whether customers must submit receipt or purchase documentation to claim the rebate. True for mail-in rebates, false for instant rebates applied at Point of Sale.']
  stackable_with_other_promotions boolean [note: 'Indicates whether this rebate can be combined with other promotional offers (coupons, markdowns, Buy One Get One (BOGO) deals) in the same transaction.']
  submission_deadline_date date [note: 'Final date by which customers must submit rebate claims for purchases made during the effective period. Typically extends beyond the effective end date for mail-in rebates.']
  terms_and_conditions varchar [note: 'Full legal text of the rebate program terms, conditions, restrictions, and disclaimers. Must comply with Federal Trade Commission (FTC) disclosure requirements.']
  vendor_funding_percentage decimal(5,2) [note: 'Percentage of the rebate cost funded by the vendor in co-op promotional agreements (e.g., 75.00 means vendor pays 75%, retailer pays 25%). Null for fully retailer-funded rebates.']

  Note: 'Master record for a rebate program offered to customers or funded by vendors. Captures rebate name, rebate type (instant rebate, mail-in rebate, vendor-funded rebate), rebate amount or percentage, qualifying purchase conditions, submission deadline, payment method (check, store credit, digital credit), sponsoring vendor, and rebate program status. Supports both consumer-facing rebates and vendor-funded promotional allowances.'
}

Table promotion.vendor_promo_agreement {
  vendor_promo_agreement_id varchar [pk, note: 'Unique identifier for the vendor-funded promotional agreement record. Primary key.']
  brand_id varchar [note: 'Foreign key linking to product.product_brand. Business justification: Vendor promo agreements are negotiated at the brand level (e.g., \'Unilever brand promotion agreement\'). This FK enables brand-level funding reconciliation, accrual tracking, and settlement reporting —']
  item_hierarchy_id varchar [note: 'Foreign key linking to product.item_hierarchy. Business justification: Vendor promo agreements in retail are negotiated at the category level (e.g., \'all private label dairy\'). This FK enables structured category-level vendor funding reconciliation, accrual reporting, an']
  promo_budget_id varchar [note: 'Foreign key linking to promotion.promo_budget. Business justification: A vendor promotional agreement is the contractual basis for vendor-funded budget contributions. vendor_promo_agreement tracks funding_amount, total_accrued_amount, total_settled_amount, and outstandin']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Vendor promotional agreements (co-op advertising, promotional allowances) fund specific promotional campaigns. The vendor_promo_agreement table currently only links to vendor but needs promo_campaign_']
  region_id varchar [note: 'Foreign key linking to store.region. Business justification: Vendor promotional agreements are scoped to geographic markets/regions — vendors fund promotions only in specific regions based on distribution footprint and market strategy. A region_id FK enables re']
  vendor_contract_id varchar [note: 'Foreign key linking to supplier.vendor_contract. Business justification: Promotional funding agreements are executed under master vendor contracts. Finance teams perform \'promotional contract reconciliation\' — validating that agreed funding amounts and terms in vendor_prom']
  vendor_id varchar [note: 'Identifier of the vendor or supplier providing promotional funding for this agreement.']
  accrual_method varchar [note: 'Method used to calculate promotional funding accrual. Purchase-based: accrues on retailer purchase volume. Sales-based: accrues on consumer sales (scan data). Display-based: accrues on compliance with display requirements. Hybrid: combination of methods.']
  ad_placement_required boolean [note: 'Indicates whether the retailer must feature the product in circular ads, digital promotions, or other marketing materials to qualify for co-op advertising funding.']
  agreement_name varchar [note: 'Human-readable descriptive name for the promotional agreement, typically including campaign theme or product category.']
  agreement_number varchar [note: 'Externally-known unique business identifier for the promotional agreement, used in vendor communications and settlement documents.']
  agreement_type varchar [note: 'Classification of the vendor promotional funding mechanism. Co-op advertising: shared advertising cost. Off-invoice allowance: upfront discount on purchase invoice. Bill-back: post-event reimbursement. Scan allowance: per-unit sold rebate. New item allowance: slotting fee for new SKU introduction. Volume rebate: tiered discount based on purchase volume.']
  approval_date date [note: 'Date when the promotional agreement was internally approved and authorized for execution.']
  chargeback_eligible boolean [note: 'Indicates whether the retailer can issue chargebacks to the vendor for non-compliance with agreement terms (e.g., late delivery, incorrect pricing, missing promotional materials).']
  chargeback_penalty_amount decimal(18,2) [note: 'Fixed monetary penalty amount per chargeback incident for vendor non-compliance, in the agreement currency. Nullable if chargeback is not eligible or penalty is variable.']
  contract_document_reference varchar [note: 'Reference identifier or file path to the signed legal contract or agreement document stored in the document management system.']
  created_timestamp timestamp [note: 'Timestamp when this promotional agreement record was first created in the system.']
  display_compliance_required boolean [note: 'Indicates whether the retailer must meet specific in-store display requirements (endcap placement, planogram compliance, shelf positioning) to qualify for funding.']
  effective_end_date date [note: 'Date when the promotional agreement expires and funding accrual ceases. Nullable for open-ended agreements.']
  effective_start_date date [note: 'Date when the promotional agreement becomes active and funding accrual begins.']
  funding_amount decimal(18,2) [note: 'Total monetary value of vendor promotional funding committed under this agreement, in the agreement currency.']
  funding_currency_code varchar [note: 'Three-letter ISO 4217 currency code for the funding amount (e.g., USD, EUR, GBP).']
  funding_percentage decimal(5,2) [note: 'Percentage of qualifying costs or sales that the vendor will fund, expressed as a decimal (e.g., 15.00 for 15%). Used for co-op advertising and scan-based allowances.']
  last_modified_timestamp timestamp [note: 'Timestamp when this promotional agreement record was most recently updated.']
  minimum_purchase_amount decimal(18,2) [note: 'Minimum monetary value of purchases required to qualify for the promotional funding, in the agreement currency. Nullable if no minimum applies.']
  minimum_purchase_quantity decimal(15,3) [note: 'Minimum quantity of product that must be purchased to qualify for the promotional funding. Nullable if no minimum applies.']
  notes varchar [note: 'Free-text field for additional comments, special conditions, or internal notes related to the promotional agreement.']
  outstanding_balance decimal(18,2) [note: 'Difference between total accrued amount and total settled amount, representing funding owed by the vendor but not yet paid, in the agreement currency.']
  performance_obligation_description varchar [note: 'Detailed narrative of the retailer\'s obligations under this agreement, including display requirements, advertising commitments, volume targets, and reporting duties.']
  qualifying_product_scope varchar [note: 'Defines which products are eligible for promotional funding under this agreement. Specific SKU: single item. Product category: all items in a category. Brand: all items of a vendor brand. Private label: retailer-branded items.']
  settlement_frequency varchar [note: 'Frequency at which funding settlements or accruals are processed under this agreement.']
  settlement_terms varchar [note: 'Defines how and when the vendor funding will be paid or credited. Upfront credit: applied at purchase. Monthly accrual: credited monthly. Quarterly settlement: paid quarterly. Post-event claim: retailer submits claim after promotion ends. Scan-based settlement: paid based on POS scan data.']
  termination_date date [note: 'Date when the agreement was terminated early, if applicable. Nullable for agreements that completed normally or are still active.']
  termination_reason varchar [note: 'Explanation for early termination of the agreement, such as vendor non-compliance, retailer strategic change, or mutual agreement. Nullable if not terminated.']
  total_accrued_amount decimal(18,2) [note: 'Cumulative amount of promotional funding accrued to date under this agreement, in the agreement currency. Updated as qualifying events occur.']
  total_settled_amount decimal(18,2) [note: 'Cumulative amount of promotional funding that has been paid or credited to the retailer to date, in the agreement currency.']
  vendor_promo_agreement_status varchar [note: 'Current lifecycle state of the promotional agreement. Draft: under negotiation. Pending approval: awaiting internal sign-off. Active: in effect and accruing. Suspended: temporarily paused. Completed: ended normally. Terminated: ended early. Settled: financially reconciled. [ENUM-REF-CANDIDATE: draft|pending approval|active|suspended|completed|terminated|settled — 7 candidates stripped; promote to reference product]']

  Note: 'Master record for a vendor-funded promotional agreement (co-op advertising, promotional allowance, scan-based trading deal). Captures vendor identifier, agreement type (co-op ad, off-invoice allowance, bill-back, scan allowance, new item allowance), agreed funding amount, funding percentage, qualifying conditions (minimum volume, display compliance, ad placement), performance obligations, agreement start/end dates, settlement terms, and agreement status. Distinct from the supplier contract in the supplier domain — this is specifically the promotional funding arrangement that drives vendor chargeback and deduction management. Supports accounts receivable accrual and vendor compliance auditing.'
}

Table promotion.promo_redemption {
  promo_redemption_id varchar [pk, note: 'Unique identifier for each promotional offer redemption instance. Primary key for the promo_redemption product.']
  coupon_id varchar [note: 'Foreign key linking to promotion.coupon. Business justification: When a redemption is triggered by a coupon, promo_redemption needs a structured FK to the coupon master record. Currently has coupon_code as STRING, which should be replaced with coupon_id FK. This en']
  header_id varchar [note: 'Foreign key linking to order.order_header. Business justification: Promotion redemptions in e-commerce/omnichannel orders need order-level context for multi-line promotion analysis, customer journey tracking, and cross-channel promotional effectiveness measurement. D']
  location_id varchar [note: 'Reference to the physical store location where the redemption occurred. Populated for POS and BOPIS transactions. Null for pure e-commerce fulfillment.']
  order_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_order. Business justification: Shipping promotions (free shipping, expedited upgrade offers) are redeemed against a specific fulfillment_order. Retailers need direct linkage for vendor chargeback reconciliation, shipping cost subsi']
  order_line_id varchar [note: 'Foreign key linking to order.order_line. Business justification: promo_redemption links to header and pos_transaction but not to the specific order_line where the promotion was redeemed. Line-level redemption tracking is required for item-level promotional margin a']
  pos_terminal_id varchar [note: 'Identifier of the POS terminal or register where the redemption was processed. Used for audit trail and fraud detection. Null for e-commerce transactions.']
  pos_transaction_id varchar [note: 'Reference to the customer transaction (POS or e-commerce order) where this promotion was applied. Links to the sales transaction header.']
  primary_promo_customer_profile_id varchar [note: 'Customer who redeemed']
  promo_campaign_id varchar [note: 'Reference to the promotional offer that was redeemed. Links to the promotion master data defining the offer terms, discount rules, and eligibility criteria.']
  promo_offer_id varchar [note: 'Foreign key linking to promotion.promo_offer. Business justification: Promotional redemptions capture the application of a specific promotional offer to a transaction. While promo_redemption already has promo_campaign_id, it needs promo_offer_id to identify the exact of']
  rebate_id varchar [note: 'Foreign key linking to promotion.rebate. Business justification: Redemptions can be for rebate offers specifically. A customer may redeem a rebate offer at transaction time (e.g., instant rebate applied at POS), and tracking which rebate was redeemed is essential f']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Redemption records must reference the redeemed SKU via proper FK for product-level promotion performance reporting, margin analysis, and vendor chargeback reconciliation. The existing plain `sku` colu']
  vendor_promo_agreement_id varchar [note: 'Foreign key linking to promotion.vendor_promo_agreement. Business justification: promo_redemption has chargeback_amount and chargeback_status fields that are directly governed by vendor_promo_agreement\'s chargeback_eligible and chargeback_penalty_amount terms. When a redemption is']
  chargeback_amount decimal(15,2) [note: 'The amount claimed from or paid by the vendor for this promotion redemption. May differ from discount_amount due to negotiated funding rates or caps.']
  chargeback_status varchar [note: 'Status of the vendor chargeback claim for vendor-funded promotions. Tracks the lifecycle from pending submission through payment receipt.']
  created_timestamp timestamp [note: 'System timestamp when this redemption record was first created in the database. Used for audit trail and data lineage tracking.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the discount amount. Supports multi-currency operations across international markets.']
  discount_amount decimal(15,2) [note: 'The monetary value of the discount granted to the customer through this promotion redemption. Expressed in the transaction currency. Critical for promotional ROI calculation and vendor chargeback reconciliation.']
  discount_type varchar [note: 'The category of discount applied. Distinguishes between percentage-based discounts, fixed dollar amounts, buy-one-get-one offers, bundle deals, spend threshold promotions, and shipping incentives.']
  final_price decimal(15,2) [note: 'The post-discount price after this promotion was applied. May differ from transaction final price if multiple promotions were stacked.']
  fraud_score decimal(5,2) [note: 'Risk score assigned by fraud detection algorithms to assess the likelihood of fraudulent coupon use or promotion abuse. Higher scores indicate higher risk. Scale 0-100.']
  loyalty_points_earned varchar [note: 'The number of loyalty program points awarded to the customer as part of this promotion redemption. Null if the promotion does not include a points component.']
  loyalty_points_redeemed varchar [note: 'The number of loyalty program points the customer spent to activate or qualify for this promotion. Null if no points were used.']
  modified_timestamp timestamp [note: 'System timestamp when this redemption record was last updated. Tracks changes to status, chargeback processing, or validation outcomes.']
  original_price decimal(15,2) [note: 'The pre-discount price of the item or basket to which the promotion was applied. Used to calculate discount percentage and promotional lift.']
  processing_system varchar [note: 'The system or platform that processed and validated the promotion redemption. Identifies the source system for audit and reconciliation purposes.']
  promotion_tier varchar [note: 'The tier or level of the promotion when tiered discount structures are used (e.g., spend $50 get 10% off, spend $100 get 20% off). Indicates which threshold was achieved.']
  quantity_redeemed varchar [note: 'The number of units or items to which the promotion was applied. For BOGO offers, represents the number of qualifying item sets. For single-item discounts, typically 1.']
  redemption_channel varchar [note: 'The sales channel through which the promotion was redeemed. Distinguishes between in-store POS, e-commerce platforms, mobile apps, and other customer touchpoints.']
  redemption_limit_type varchar [note: 'The scope of redemption limits enforced for this promotion. Indicates whether limits apply per customer, per transaction, per day, or across the entire campaign period.']
  redemption_mechanism varchar [note: 'Method by which the promotion was applied to the transaction. Indicates whether the discount was automatically triggered by system rules, manually entered via coupon code, applied through loyalty program, or activated through other channels. [ENUM-REF-CANDIDATE: automatic_system_triggered|coupon_code_entry|loyalty_auto_apply|cart_rule|manual_cashier_apply|mobile_app_clip|digital_wallet — 7 candidates stripped; promote to reference product]']
  redemption_sequence_number varchar [note: 'The sequential count of this redemption within the applicable limit scope. For example, if limit is per_customer, this tracks which redemption number this is for that customer (1st, 2nd, 3rd, etc.).']
  redemption_status varchar [note: 'Validation status of the promotion redemption. Indicates whether the redemption was successfully processed or rejected due to expiration, duplicate use, limit violations, or fraud detection.']
  redemption_timestamp timestamp [note: 'The precise date and time when the promotion was applied to the transaction. Represents the business event time of redemption, distinct from record creation time.']
  source_record_reference varchar [note: 'The unique identifier of this redemption record in the source operational system. Enables traceability back to the system of record.']
  stack_sequence varchar [note: 'The order in which this promotion was applied within a stacked promotion scenario. Determines calculation precedence when multiple discounts are layered.']
  validation_error_code varchar [note: 'System error code returned when a redemption attempt fails validation. Provides technical detail for troubleshooting invalid redemptions. Null for successful redemptions.']
  validation_error_message varchar [note: 'Human-readable error message explaining why a redemption was rejected. Displayed to customers or cashiers. Null for successful redemptions.']
  vendor_funded_flag boolean [note: 'Indicates whether this promotion discount is funded by a vendor/supplier through a trade promotion agreement. True when the cost is charged back to the vendor; false when retailer-funded.']

  Note: 'Transactional record capturing each instance of a promotional offer being applied to a customer transaction at POS or e-commerce checkout. Records offer applied, redemption mechanism (automatic system-triggered, coupon code entry, loyalty auto-apply, cart rule), coupon reference (when coupon-based), transaction reference, store or channel, customer identifier, discount amount granted, redemption timestamp, redemption status (valid, invalid, duplicate, expired), and processing system. Serves as the single source of truth for all promotion redemption activity — including coupon redemptions, automatic BOGO applications, threshold discounts, and bundle deals. Critical for promotional ROI calculation, coupon fraud prevention, vendor chargeback evidence, and real-time redemption limit enforcement.'
}

Table promotion.promo_budget {
  promo_budget_id varchar [pk, note: 'Unique identifier for the promotional budget record. Primary key for the promotional budget master data.']
  promo_calendar_id varchar [note: 'Foreign key linking to promotion.promo_calendar. Business justification: Promotional budgets are planned and allocated against promotional calendar periods (fiscal year, fiscal quarter, seasonal events). The promo_budget table has fiscal_year and fiscal_period as standalon']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Promotional budgets are allocated to specific promotional campaigns. The promo_budget table tracks budget_owner_type and budget_owner_id as generic strings, but needs a structured FK to promo_campaign']
  region_id varchar [note: 'Foreign key linking to store.region. Business justification: Regional promotional budgets are a core retail financial construct — regional directors manage and report on promotional spend for their markets. A region_id FK on promo_budget enables regional budget']
  actual_spend_amount decimal(18,2) [note: 'Cumulative actual spend to date against this promotional budget, including all posted promotional costs, markdowns, vendor co-op claims, and advertising expenses. Updated in real-time as promotional transactions are processed.']
  approval_date date [note: 'Date when this promotional budget was formally approved by authorized management. Marks the transition from pending to approved status.']
  approval_status varchar [note: 'Current approval workflow status for the promotional budget. Not submitted indicates budget has not been submitted for approval; pending review indicates awaiting management approval; approved indicates budget has been authorized; rejected indicates budget was not approved; revision required indicates budget must be modified and resubmitted.']
  approved_by varchar [note: 'Identifier or name of the manager or executive who approved this promotional budget. Typically a user ID or employee identifier from the HR system.']
  budget_currency_code varchar [note: 'Three-letter ISO 4217 currency code for the budget amount (e.g., USD, EUR, GBP, CAD). All budget amounts and spend tracking for this budget are denominated in this currency.']
  budget_name varchar [note: 'Descriptive name of the promotional budget plan, typically indicating the campaign, event, or category scope (e.g., \'Q4 Holiday Electronics Promotion\', \'Spring Apparel Clearance\').']
  budget_number varchar [note: 'Human-readable business identifier for the promotional budget, typically following format PB-YYYYNNNN where YYYY is fiscal year and NNNN is sequence number.']
  budget_owner_type varchar [note: 'Classification of the organizational unit responsible for managing and executing this promotional budget. Department indicates merchandising department ownership; category indicates product category team ownership; brand indicates brand management team ownership; channel indicates channel-specific ownership (e-commerce, stores); region indicates geographic region ownership; store cluster indicates store group ownership.']
  budget_status varchar [note: 'Current lifecycle status of the promotional budget. Draft indicates initial planning stage; pending approval indicates submitted for management review; approved indicates authorized but not yet active; active indicates currently in use for promotional spend; suspended indicates temporarily paused; closed indicates completed and finalized; cancelled indicates terminated before completion. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|closed|cancelled — 7 candidates stripped; promote to reference product]']
  budget_type varchar [note: 'Classification of the promotional budget source and purpose. Internal marketing budgets are company-funded campaigns; vendor co-op budgets are supplier-funded promotional agreements; markdown allowance budgets cover planned price reductions; clearance reserve budgets are set aside for end-of-season inventory liquidation; trade promotion budgets support B2B channel incentives; digital advertising budgets fund online and mobile promotional campaigns.']
  circular_ad_allocation decimal(18,2) [note: 'Portion of the total budget allocated specifically for circular advertising and weekly ad production, including print circulars, digital circulars, and featured promotional items in weekly ad campaigns.']
  committed_amount decimal(18,2) [note: 'Amount committed but not yet spent, representing approved promotional activities that have been scheduled or contracted but not yet executed (e.g., scheduled markdowns, booked advertising placements, approved vendor co-op agreements).']
  created_timestamp timestamp [note: 'Timestamp when this promotional budget record was first created in the system. Audit field for data lineage and record lifecycle tracking.']
  ecommerce_channel_allocation decimal(18,2) [note: 'Portion of the total budget allocated specifically for e-commerce and digital promotional activities, including online discounts, digital coupons, email campaigns, and website promotional banners. Supports omnichannel budget planning and digital channel ROI tracking.']
  effective_end_date date [note: 'Date when this promotional budget expires and is no longer available for new promotional spend allocation. Any uncommitted budget remaining after this date typically rolls back to the general promotional fund or is reallocated.']
  effective_start_date date [note: 'Date when this promotional budget becomes active and available for promotional spend allocation. Promotional activities can begin drawing from this budget on or after this date.']
  fiscal_period varchar [note: 'Fiscal period within the fiscal year for which this budget is allocated. Format: Q1-Q4 for quarters, M01-M12 for months, H1-H2 for half-years, FY for full fiscal year. Supports period-based budget planning and performance tracking.']
  fiscal_year varchar [note: 'Fiscal year for which this promotional budget is allocated, typically a four-digit year (e.g., 2024). Aligns with the company\'s financial planning and reporting calendar.']
  gl_account_code varchar [note: 'General ledger account code to which promotional spend from this budget is posted for financial reporting and P&L tracking. Links operational promotional budget management to financial accounting.']
  last_modified_timestamp timestamp [note: 'Timestamp when this promotional budget record was last updated. Audit field for change tracking and data quality monitoring.']
  mobile_channel_allocation decimal(18,2) [note: 'Portion of the total budget allocated specifically for mobile app promotional activities, including app-exclusive offers, push notification campaigns, and mobile wallet coupons. Supports omnichannel budget planning and mobile channel ROI tracking.']
  notes varchar [note: 'Free-text notes and comments about the promotional budget, including planning assumptions, special conditions, vendor agreement details, or budget reallocation history. Supports collaborative budget management and audit trail documentation.']
  otb_integration_flag boolean [note: 'Boolean indicator of whether this promotional budget is integrated with the Open to Buy (OTB) merchandise planning system. When true, promotional markdowns and clearance budgets are factored into inventory purchasing decisions and margin planning.']
  planned_spend_amount decimal(18,2) [note: 'Total planned or forecasted spend amount for the promotional budget based on campaign planning and historical performance. May be less than or equal to total budget amount, representing the expected utilization.']
  pos_channel_allocation decimal(18,2) [note: 'Portion of the total budget allocated specifically for in-store point-of-sale promotional activities, including store markdowns, in-store coupons, and physical promotional displays. Supports omnichannel budget planning and channel-specific ROI tracking.']
  profit_center_code varchar [note: 'Profit center code associated with this promotional budget, used for segment reporting and profitability analysis. Enables tracking of promotional ROI by business unit or product line.']
  remaining_budget_amount decimal(18,2) [note: 'Available budget remaining for new promotional activities, calculated as total budget amount minus actual spend amount minus committed amount. Represents the unallocated budget available for additional promotional planning.']
  total_budget_amount decimal(18,2) [note: 'Total allocated budget amount for the promotional plan in the budget currency. Represents the maximum authorized spend for this promotional budget across all channels and activities.']
  variance_threshold_amount decimal(18,2) [note: 'Absolute amount threshold for budget variance alerts. When actual spend deviates from planned spend by more than this amount, automated alerts are triggered to budget owners and finance teams. Used in conjunction with or as an alternative to percentage-based thresholds.']
  variance_threshold_percent decimal(5,2) [note: 'Percentage threshold for budget variance alerts. When actual spend deviates from planned spend by more than this percentage, automated alerts are triggered to budget owners and finance teams. Typical values range from 5% to 20%.']
  vendor_funded_amount decimal(18,2) [note: 'Portion of the total budget that is funded by vendor co-op agreements, trade promotion allowances, or supplier marketing development funds. Represents external funding contribution to the promotional budget.']

  Note: 'Master record for the promotional budget allocated to a campaign, promotional event, or category-level promotional plan. Captures total budget amount, budget type (internal marketing, vendor co-op, markdown allowance, clearance reserve), budget owner (department, category, or brand team), planned spend by channel, actual spend to date, committed but unspent amount, remaining budget, budget approval status, fiscal period, and variance threshold for alerts. Supports OTB (Open to Buy) integration, promotional P&L management, and real-time budget consumption monitoring. Distinct from finance domain general ledger — this is the operational promotional spend plan that feeds GL accruals.'
}

Table promotion.promo_calendar {
  promo_calendar_id varchar [pk, note: 'Unique identifier for the promotional calendar period. Primary key for the promotional calendar master record.']
  applicable_banner_codes varchar [note: 'Comma-separated list of banner codes to which this promotional period applies. Populated only when banner_applicability is \'banner_specific\'.']
  applicable_market_codes varchar [note: 'Comma-separated list of market or region codes to which this promotional period applies. Populated when market_applicability is \'regional\' or \'local\'.']
  approval_date date [note: 'The date when this promotional calendar period was formally approved by management. Null if still pending approval.']
  approval_required_flag boolean [note: 'Indicates whether executive or senior management approval is required for promotions during this period (true) or standard approval workflows apply (false).']
  approved_by_name varchar [note: 'Name of the executive or manager who approved this promotional calendar period.']
  banner_applicability varchar [note: 'Indicates whether this promotional period applies across all retail banners (enterprise-wide) or is specific to individual banners (banner-specific). Supports multi-banner coordination.']
  blackout_reason varchar [note: 'Business justification for why this period is designated as a promotional blackout (e.g., inventory transition, system maintenance, post-holiday recovery).']
  budget_amount decimal(15,2) [note: 'Total budget allocated for this promotional period including markdown funding, advertising spend, and vendor co-op contributions.']
  budget_currency_code varchar [note: 'Three-letter ISO 4217 currency code for the promotional budget amount (e.g., USD, CAD, EUR).']
  channel_applicability varchar [note: 'Indicates which sales channels this promotional period applies to (omnichannel, store-only, e-commerce-only, mobile-app-only).']
  circular_production_deadline date [note: 'The deadline by which all promotional circular materials (print ads, digital circulars) must be finalized for production and distribution.']
  competitive_response_flag boolean [note: 'Indicates whether this promotional period was created as a competitive response to rival retailer promotions (true) or is part of the planned calendar (false).']
  competitive_trigger_description varchar [note: 'Description of the competitive market event or rival promotion that triggered this promotional period. Populated when competitive_response_flag is true.']
  created_timestamp timestamp [note: 'Timestamp when this promotional calendar record was first created in the system.']
  end_date date [note: 'The date when the promotional period ends. Defines the effective end of promotional activity and pricing.']
  expected_sales_lift_pct decimal(5,2) [note: 'Forecasted percentage increase in sales revenue expected during this promotional period compared to baseline or prior year.']
  expected_traffic_lift_pct decimal(5,2) [note: 'Forecasted percentage increase in customer traffic (footfall and digital visits) expected during this promotional period compared to baseline.']
  fiscal_month varchar [note: 'The fiscal month (1-12) to which this promotional period belongs.']
  fiscal_quarter varchar [note: 'The fiscal quarter (1-4) to which this promotional period belongs.']
  fiscal_week varchar [note: 'The fiscal week number (1-52 or 1-53) to which this promotional period belongs, aligned with the retail 4-5-4 calendar.']
  fiscal_year varchar [note: 'The fiscal year to which this promotional period belongs (e.g., 2024, 2025).']
  inventory_build_start_date date [note: 'The date when inventory positioning and build-up for this promotional period should begin to ensure adequate stock levels.']
  is_active boolean [note: 'Indicates whether this promotional calendar period is currently active and valid (true) or has been logically deleted or superseded (false).']
  is_blackout_period boolean [note: 'Flag indicating whether this period is a promotional blackout window where no new promotions should be launched (true) or a normal promotional period (false).']
  last_modified_timestamp timestamp [note: 'Timestamp when this promotional calendar record was last updated or modified.']
  market_applicability varchar [note: 'Geographic scope of the promotional period indicating whether it applies nationally, regionally, or to specific local markets.']
  notes varchar [note: 'Free-text notes and comments regarding special considerations, constraints, or coordination requirements for this promotional period.']
  period_name varchar [note: 'Business-friendly name for the promotional period (e.g., \'Spring Sale 2024\', \'Black Friday Week\', \'Back to School August\').']
  period_type varchar [note: 'Classification of the promotional period indicating the nature and purpose of the promotion (weekly ad cycle, seasonal event, holiday, clearance window, competitive response, vendor-funded).']
  planning_lock_date date [note: 'The date by which all promotional planning for this period must be finalized and locked. After this date, changes require executive approval.']
  planning_owner_email varchar [note: 'Email address of the planning owner for coordination and communication regarding this promotional period.']
  planning_owner_name varchar [note: 'Name of the merchandising or marketing manager responsible for planning and executing this promotional period.']
  planning_status varchar [note: 'Current lifecycle status of the promotional calendar period (draft - under development, locked - finalized for execution, active - currently running, archived - completed and historical).']
  priority_tier varchar [note: 'Priority classification of the promotional period indicating strategic importance and resource allocation level (tier 1 strategic, tier 2 major, tier 3 standard, tier 4 tactical).']
  source_system_code varchar [note: 'Code identifying the source system from which this promotional calendar record originated (e.g., ORMS, RPM, internal planning tool).']
  start_date date [note: 'The date when the promotional period begins. Defines the effective start of promotional activity and pricing.']
  target_customer_segment varchar [note: 'Primary customer segment or demographic group targeted by this promotional period (e.g., \'families\', \'millennials\', \'loyalty members\', \'value shoppers\').']
  theme_description varchar [note: 'Marketing theme or creative concept for the promotional period (e.g., \'Summer Savings\', \'Holiday Gift Guide\', \'New Year New You\').']
  vendor_negotiation_deadline date [note: 'The deadline by which all vendor-funded promotional agreements and co-op advertising commitments must be finalized.']

  Note: 'Master record for the retail promotional calendar defining planned promotional periods, key retail events, blackout dates, and competitive response windows for a fiscal year. Captures period name, period type (weekly ad cycle, seasonal event, holiday, clearance window, competitive response), start/end dates, fiscal week/month/quarter alignment, priority tier, planning lock date, planning status (draft, locked, active, archived), and banner/market applicability for multi-banner retailers. Used by merchandising, marketing, and supply chain teams to coordinate promotional activity, inventory positioning, and circular production timelines. Serves as the shared planning backbone that prevents promotional conflicts and ensures adequate lead time for vendor negotiations and inventory builds. Supports multi-banner coordination by allowing banner-specific or enterprise-wide calendar periods.'
}

Table promotion.circular_ad_placement {
  circular_ad_placement_id varchar [pk, note: 'Primary key for the circular_ad_placement association']
  circular_ad_id varchar [note: 'Foreign key linking this placement record to the parent circular advertisement.']
  promo_offer_id varchar [note: 'Foreign key linking this placement record to the specific promotional offer being featured.']
  ad_copy_override varchar [note: 'Circular-specific advertising copy headline or tagline for this offer, overriding the offer\'s default display_message when the circular requires custom messaging for this placement.']
  ad_placement_position varchar [note: 'The specific position on the page where this offer is displayed within the circular. Captures the commercial value of premium placement positions.']
  display_priority varchar [note: 'Numeric priority or ordering of this offer\'s prominence within the circular, used to resolve display conflicts and rank featured items for digital rendering.']
  feature_size varchar [note: 'The physical or digital size of the ad feature for this offer within the circular. Determines production cost allocation and vendor co-op billing.']
  page_number varchar [note: 'The page number within the circular on which this promotional offer is featured. Belongs to the placement, not the circular header or the offer definition.']
  vendor_funded_placement_flag boolean [note: 'Indicates whether the vendor co-funded or fully funded this specific placement within this circular, as distinct from the offer-level cost_share_percentage. A placement may be vendor-funded even when the parent offer is not, or vice versa.']

  Note: 'This association product represents the Contract between circular_ad and promo_offer. It captures the commercial placement of a specific promotional offer within a specific circular advertisement, including the physical or digital position, feature size, page number, display priority, and vendor funding status for that placement. Each record links one circular_ad to one promo_offer and carries attributes that exist only in the context of that specific placement — a given offer may appear in multiple circulars at different positions and sizes, and a given circular features many offers at distinct locations.. Existence Justification: In retail, a circular advertisement features multiple promotional offers (e.g., a weekly circular may include a BOGO offer on beverages, a percent-off offer on produce, and a dollar-off offer on household goods simultaneously). Conversely, a single promotional offer can be featured across multiple circulars (e.g., a vendor-funded BOGO offer appearing in both the weekly print circular and the digital holiday circular). The placement of an offer within a circular is a recognized commercial transaction — retailers charge vendors for featured ad space, and each placement carries its own page number, position, feature size, and vendor-funding flag that belong to neither the circular nor the offer alone.'
}

Table supplier.vendor {
  vendor_id varchar [pk, note: 'Surrogate primary key uniquely identifying each vendor record.']
  contract_expiry_date date [note: 'Date on which the current master agreement with this vendor expires.']
  created_timestamp timestamp [note: 'UTC timestamp when this vendor record was first created.']
  currency_code varchar [note: 'ISO 4217 currency code for the vendor\'s default transaction currency.']
  diversity_certification varchar [note: 'Diversity certification type held by the vendor: minority_owned, women_owned, veteran_owned, disabled_owned, or none.']
  duns_number varchar [note: 'Dun & Bradstreet DUNS number for vendor identity verification and credit assessment.']
  edi_capable_flag boolean [note: 'Whether the vendor supports EDI-based electronic document exchange.']
  edi_identifier varchar [note: 'Vendor\'s EDI interchange identifier (ISA ID) for electronic transactions.']
  fill_rate_pct decimal(5,2) [note: 'Percentage of ordered units fulfilled completely on first shipment, measured over trailing period.']
  insurance_certificate_expiry_date date [note: 'Expiration date of the vendor\'s liability insurance certificate on file.']
  last_modified_timestamp timestamp [note: 'UTC timestamp of the most recent modification to this vendor record.']
  last_purchase_order_date date [note: 'Date of the last purchase order placed with this vendor.']
  lead_time_days varchar [note: 'Standard lead time in calendar days from PO placement to delivery.']
  modified_by_user varchar [note: 'Username or system identifier of the last user to modify this record.']
  moq_units decimal(15,3) [note: 'Minimum order quantity in units required by the vendor per purchase order.']
  name varchar [note: 'Legal or trading name of the vendor organization.']
  on_time_delivery_rate_pct decimal(5,2) [note: 'Percentage of purchase orders delivered on or before the agreed delivery date.']
  onboarding_date date [note: 'Date when the vendor completed the onboarding process and became active.']
  payment_method varchar [note: 'Preferred payment method: ach, wire, check, virtual_card.']
  payment_terms_code varchar [note: 'Standard payment terms code, e.g. NET30, NET60, 2_10_NET30.']
  primary_contact_email varchar [note: 'Primary contact email address for this vendor.']
  primary_contact_name varchar [note: 'Full name of the primary contact person at this vendor.']
  primary_contact_phone varchar [note: 'Primary contact phone number for this vendor.']
  quality_acceptance_rate_pct decimal(5,2) [note: 'Percentage of received units passing quality inspection without defect or damage.']
  remittance_email varchar [note: 'Email address for sending payment remittance advices to this vendor.']
  risk_rating varchar [note: 'Overall supply risk rating assigned to this vendor: low, medium, high, critical.']
  sustainability_certified_flag boolean [note: 'Whether the vendor holds a recognized sustainability certification.']
  tax_classification varchar [note: 'Tax classification of the vendor entity for withholding and reporting purposes.']
  tax_identifier varchar [note: 'Tax identification number (EIN, VAT number, etc.) for this vendor entity.']
  vendor_status varchar [note: 'Current lifecycle status of the vendor relationship. Values: active, inactive, suspended, pending_onboarding, terminated.']
  vendor_type varchar [note: 'Classification of vendor by business relationship type. Values: manufacturer, distributor, wholesaler, service_provider, drop_ship, private_label.']
  vmi_enabled_flag boolean [note: 'Whether vendor-managed inventory is active for this vendor.']

  Note: 'Master record for each supplier/vendor with whom the retailer has a commercial relationship. Contains identity, contact, compliance, and performance attributes. Serves as the root entity for all supplier-domain relationships.'
}

Table supplier.vendor_contact {
  vendor_contact_id varchar [pk, note: 'Unique identifier for the vendor contact person. Primary key.']
  vendor_id varchar [note: 'Reference to the parent vendor organization this contact represents. Links to the vendor master record.']
  address_line_1 varchar [note: 'First line of the business address for the vendor contact\'s office location. Typically includes street number and name.']
  address_line_2 varchar [note: 'Second line of the business address for additional location details such as suite, floor, or building number.']
  city varchar [note: 'City or municipality where the vendor contact\'s office is located.']
  contact_status varchar [note: 'Current lifecycle status of the vendor contact. Inactive or terminated contacts should not receive communications.']
  contact_type varchar [note: 'The functional role or responsibility area of this contact within the vendor organization. Determines escalation paths and communication routing.']
  country_code varchar [note: 'Three-letter ISO country code for the vendor contact\'s office location. [ENUM-REF-CANDIDATE: USA|CAN|MEX|GBR|DEU|FRA|CHN|JPN — 8 candidates stripped; promote to reference product]']
  created_timestamp timestamp [note: 'The date and time when this vendor contact record was first created in the system. Supports audit trail and data lineage.']
  department varchar [note: 'The department or business unit within the vendor organization where this contact works (e.g., Sales, Logistics, Quality Assurance, Finance).']
  effective_end_date date [note: 'The date when this vendor contact ceased to be active. Null for currently active contacts. Used for historical tracking and audit trails.']
  effective_start_date date [note: 'The date when this vendor contact became active and available for business communications. Supports temporal tracking of contact relationships.']
  email_address varchar [note: 'Primary business email address for the vendor contact. Used for official communications, purchase orders, and compliance notifications.']
  fax_number varchar [note: 'Fax number for the vendor contact, if still used for formal document transmission.']
  first_name varchar [note: 'The given name of the vendor contact person.']
  is_escalation_contact boolean [note: 'Indicates whether this contact should be included in escalation workflows for critical issues such as compliance violations, quality failures, or delivery delays.']
  is_primary_contact boolean [note: 'Indicates whether this contact is the primary point of contact for the vendor. Used for default routing of communications and escalations.']
  job_title varchar [note: 'The official job title or position of the contact within the vendor organization (e.g., Account Manager, Supply Chain Director, Compliance Officer).']
  language_preference varchar [note: 'Preferred language for business communications with this contact. Uses ISO 639-2 three-letter language codes.']
  last_contact_date date [note: 'The most recent date when this vendor contact was engaged in business communication. Used for relationship health monitoring and engagement tracking.']
  last_name varchar [note: 'The family name or surname of the vendor contact person.']
  last_updated_timestamp timestamp [note: 'The date and time when this vendor contact record was most recently modified. Supports change tracking and audit compliance.']
  middle_name varchar [note: 'The middle name or initial of the vendor contact person, if applicable.']
  mobile_number varchar [note: 'Mobile phone number for the vendor contact. Used for urgent escalations and time-sensitive communications.']
  notes varchar [note: 'Free-form text field for additional information about the vendor contact, such as special instructions, preferences, or relationship history.']
  office_location varchar [note: 'The physical office location or site where this contact is based (e.g., headquarters, regional office, manufacturing plant).']
  phone_number varchar [note: 'Primary business phone number for the vendor contact. Includes country code and extension if applicable.']
  postal_code varchar [note: 'Postal or ZIP code for the vendor contact\'s office location.']
  preferred_communication_channel varchar [note: 'The contact\'s preferred method for receiving business communications. Supports personalized engagement and improved response rates.']
  state_province varchar [note: 'State, province, or region where the vendor contact\'s office is located.']
  time_zone varchar [note: 'The time zone where the vendor contact is located. Used for scheduling meetings and understanding business hours. Format follows IANA Time Zone Database (e.g., America/New_York, Europe/London).']

  Note: 'Contact persons associated with a vendor including account managers, EDI coordinators, compliance contacts, and executive sponsors. Tracks name, title, role type, phone, email, preferred communication channel, and active status. Supports relationship management and escalation workflows.'
}

Table supplier.vendor_address {
  vendor_address_id varchar [pk, note: 'Unique identifier for the vendor address record. Primary key.']
  vendor_id varchar [note: 'Identifier of the vendor to whom this address belongs. Links to the vendor master record.']
  address_line_1 varchar [note: 'Primary street address line including street number, street name, and building identifier. Organizational contact data classified as confidential.']
  address_line_2 varchar [note: 'Secondary address line for suite, floor, department, or additional location details. Organizational contact data classified as confidential.']
  address_line_3 varchar [note: 'Tertiary address line for complex addresses requiring additional location specification. Organizational contact data classified as confidential.']
  address_name varchar [note: 'Descriptive name or label for the address location (e.g., \'Main Distribution Center\', \'Corporate HQ\', \'Returns Processing Facility\').']
  address_status varchar [note: 'Current lifecycle status of the address: active (in use), inactive (no longer used), pending_validation (awaiting verification), invalid (failed validation), temporary (short-term use).']
  address_type varchar [note: 'Classification of the address purpose: headquarters (corporate office), remittance (payment processing), ship_from (origin for DSD or shipments), returns (RTV processing location), billing (invoice address), warehouse (distribution or storage facility).']
  city varchar [note: 'City or municipality name where the vendor address is located. Organizational contact data classified as confidential.']
  country_code varchar [note: 'Three-letter ISO country code identifying the country of the address (e.g., USA, CAN, MEX, GBR, DEU).']
  created_timestamp timestamp [note: 'Timestamp when this address record was first created in the system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  duns_number varchar [note: 'Dun & Bradstreet DUNS number for the location, used for business identity verification, credit assessment, and supplier risk management. 9-digit numeric identifier.']
  effective_end_date date [note: 'Date when this address is no longer valid or was deactivated. Null indicates the address is currently active. Format: yyyy-MM-dd.']
  effective_start_date date [note: 'Date when this address became active and valid for use in procurement, logistics, and vendor transactions. Format: yyyy-MM-dd.']
  email_address varchar [note: 'Primary email contact for the address location, used for logistics coordination, RTV notifications, and operational communication. Organizational contact data classified as confidential.']
  fax_number varchar [note: 'Fax number for the address location, used for EDI transmission or document exchange with vendors. Organizational contact data classified as confidential.']
  gln varchar [note: 'GS1 Global Location Number uniquely identifying the physical location for EDI transactions, logistics routing, and supply chain integration. 13-digit numeric identifier.']
  is_dsd_location boolean [note: 'Flag indicating whether this address is a DSD (Direct Store Delivery) origin location where vendors deliver directly to retail stores bypassing distribution centers. True if DSD location, False otherwise.']
  is_primary_address boolean [note: 'Flag indicating whether this is the primary or default address for the vendor. True if primary, False otherwise.']
  is_remittance_address boolean [note: 'Flag indicating whether this address is used for payment remittance and accounts payable processing. True if remittance address, False otherwise.']
  is_rtv_address boolean [note: 'Flag indicating whether this address is designated for RTV (Return to Vendor) processing and merchandise returns. True if RTV address, False otherwise. Critical for reverse logistics and vendor compliance.']
  last_updated_timestamp timestamp [note: 'Timestamp when this address record was last modified or updated. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  latitude decimal(10,7) [note: 'Geographic latitude coordinate in decimal degrees for geospatial routing, logistics optimization, and mapping. Supports last-mile delivery planning and ship-from-store calculations.']
  longitude decimal(10,7) [note: 'Geographic longitude coordinate in decimal degrees for geospatial routing, logistics optimization, and mapping. Supports last-mile delivery planning and ship-from-store calculations.']
  notes varchar [note: 'Free-text field for additional address-specific information, special delivery instructions, access requirements, or operational notes for logistics and procurement teams.']
  phone_number varchar [note: 'Primary contact phone number for the address location. Organizational contact data classified as confidential.']
  postal_code varchar [note: 'Postal or ZIP code for mail delivery routing. Format varies by country (e.g., 5-digit ZIP in USA, alphanumeric in Canada). Organizational contact data classified as confidential.']
  state_province varchar [note: 'State, province, or regional subdivision where the address is located. Organizational contact data classified as confidential.']
  tax_jurisdiction_code varchar [note: 'Tax jurisdiction or district code applicable to this address location, used for sales tax calculation, VAT compliance, and financial reporting.']
  time_zone varchar [note: 'IANA time zone identifier for the address location (e.g., America/New_York, America/Chicago, Europe/London). Supports scheduling, delivery windows, and cross-timezone coordination.']
  validation_date date [note: 'Date when the address was last validated against postal authority or third-party address verification services. Format: yyyy-MM-dd.']
  validation_source varchar [note: 'Name of the service or system used to validate the address (e.g., USPS Address Validation API, Canada Post AddressComplete, UPS Address Validation, manual verification).']
  validation_status varchar [note: 'Indicates whether the address has been verified against postal authority databases or third-party address validation services: validated (confirmed accurate), unvalidated (not yet checked), failed (does not match postal records), partial (some fields validated).']

  Note: 'Physical and mailing addresses for vendors including headquarters, remittance, ship-from, and returns (RTV) addresses. Tracks address type, street, city, state, postal code, country, geo-coordinates, and validation status. Supports procurement, logistics routing, and RTV processing.'
}

Table supplier.vendor_contract {
  vendor_contract_id varchar [pk, note: 'Unique identifier for the vendor contract. Primary key for the vendor contract entity.']
  receiving_location_id varchar [note: 'Foreign key linking to store.location. Business justification: Vendor contracts specify which store or DC location receives goods — a core contract management and inbound logistics process. receiving_location_code is a denormalized text field; normalizing to loca']
  sales_territory_id varchar [note: 'Foreign key linking to store.sales_territory. Business justification: Exclusive distribution agreements in retail are scoped to sales territories — a legally significant contract term. exclusivity_scope is a plain-text denormalization of territory; normalizing to sales_']
  vendor_id varchar [note: 'Identifier of the supplier or vendor party to this contract. Links to the vendor master record.']
  auto_renewal_flag boolean [note: 'Indicates whether the contract automatically renews at expiration. True if the contract extends for another term unless either party provides termination notice. False if the contract expires without action.']
  chargeback_terms varchar [note: 'Description of vendor compliance penalties and chargeback conditions. Defines scenarios where the buyer may deduct fees from vendor payments for non-compliance (late delivery, incorrect labeling, missing ASN, pallet configuration errors).']
  compliance_certifications_required varchar [note: 'List of regulatory and industry certifications the vendor must maintain to fulfill this contract. Examples include FDA registration for food suppliers, CPSC compliance for consumer products, organic certifications, fair trade certifications, and safety standards.']
  contract_currency_code varchar [note: 'Three-letter ISO 4217 currency code for the contract value and payment terms. All financial terms in this contract are denominated in this currency.']
  contract_document_url varchar [note: 'Uniform Resource Locator pointing to the digitally stored contract document. Links to the document management system or secure file repository where the full contract PDF or scanned image is stored.']
  contract_number varchar [note: 'Externally visible business identifier for the vendor contract. Used in procurement documents, purchase orders, and vendor communications.']
  contract_status varchar [note: 'Current lifecycle state of the vendor contract. Draft contracts are under negotiation. Pending approval contracts await internal sign-off. Active contracts are in force. Suspended contracts are temporarily paused. Terminated contracts are ended before expiry. Expired contracts have passed their end date. Renewed contracts have been extended. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|terminated|expired|renewed — 7 candidates stripped; promote to reference product]']
  contract_type varchar [note: 'Classification of the vendor contract. National brand contracts cover branded merchandise from manufacturers. Private label contracts govern store-brand product manufacturing. DSD (Direct Store Delivery) contracts define vendor-managed delivery terms. Master service agreements cover ongoing services. Blanket orders establish terms for recurring purchases. Framework agreements set umbrella terms for multiple purchase orders.']
  contract_value_amount decimal(18,2) [note: 'Total monetary value committed under this vendor contract. Represents the aggregate purchase commitment or spending cap over the contract term. Used for budget planning and vendor performance tracking.']
  created_timestamp timestamp [note: 'Date and time when this vendor contract record was first created in the system. Used for audit trail and data lineage tracking.']
  discount_percentage decimal(5,2) [note: 'Standard discount rate applied to purchases under this contract. Expressed as a percentage off list price. Used for volume discounts, early payment discounts, or negotiated pricing agreements.']
  edi_enabled_flag boolean [note: 'Indicates whether Electronic Data Interchange is enabled for transactions under this contract. True if purchase orders, invoices, and shipping notices are exchanged via EDI. False for manual or email-based document exchange.']
  edi_identifier varchar [note: 'Vendor EDI interchange identifier corresponding to the EDI qualifier. Used in EDI message headers to identify the sender and receiver.']
  edi_qualifier varchar [note: 'EDI interchange identifier qualifier for the vendor. Examples include 01 (DUNS number), 12 (phone number), 14 (UPC), ZZ (mutually defined). Used to route EDI messages to the correct vendor system.']
  effective_end_date date [note: 'Date when the vendor contract terms expire. Nullable for open-ended contracts. Procurement transactions must occur before this date unless the contract is renewed.']
  effective_start_date date [note: 'Date when the vendor contract terms become binding and enforceable. Procurement transactions referencing this contract must occur on or after this date.']
  exclusivity_flag boolean [note: 'Indicates whether this contract grants the vendor exclusive rights to supply specific products or categories. True if the buyer commits to purchasing exclusively from this vendor for the covered scope. False for non-exclusive agreements.']
  incoterms_code varchar [note: 'International Commercial Terms code defining the division of costs and risks between buyer and seller. EXW (Ex Works) - buyer collects from vendor premises. FOB (Free On Board) - vendor delivers to shipping vessel. DDP (Delivered Duty Paid) - vendor delivers to buyer location with all duties paid. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]']
  insurance_requirements varchar [note: 'Minimum insurance coverage the vendor must carry to fulfill this contract. Typically includes general liability, product liability, and cargo insurance with specified coverage limits.']
  last_updated_timestamp timestamp [note: 'Date and time when this vendor contract record was most recently modified. Used for audit trail, change tracking, and data synchronization.']
  lead_time_days varchar [note: 'Standard number of calendar days from purchase order submission to delivery at the receiving location. Used for replenishment planning, inventory forecasting, and order scheduling.']
  minimum_order_quantity decimal(15,3) [note: 'Minimum order quantity required per purchase order under this contract. Vendor will not accept orders below this threshold. Used for production planning and logistics optimization.']
  moq_unit_of_measure varchar [note: 'Unit of measure for the minimum order quantity. Examples include EA (each), CS (case), PLT (pallet), KG (kilogram), LB (pound). Must align with vendor catalog and purchase order units.']
  notes varchar [note: 'Free-text field for additional contract details, special terms, negotiation history, or operational notes. Used by procurement teams to capture context not covered by structured fields.']
  payment_method varchar [note: 'Preferred payment instrument for settling invoices under this contract. ACH (Automated Clearing House) for electronic bank transfers. Wire transfer for same-day settlement. Check for paper-based payment. EDI (Electronic Data Interchange) payment for automated remittance. Credit card for small purchases. Letter of credit for international trade.']
  payment_terms_code varchar [note: 'Standard payment terms code defining the due date calculation and discount structure. Examples include Net 30, Net 60, 2/10 Net 30 (2% discount if paid within 10 days, otherwise net 30 days).']
  quality_assurance_terms varchar [note: 'Quality standards and inspection requirements for goods supplied under this contract. Defines acceptable quality levels, sampling procedures, defect rates, and vendor quality certifications required.']
  renewal_term_months varchar [note: 'Duration in months for each automatic renewal period. Applicable only when auto_renewal_flag is true. Contract extends by this duration at each renewal.']
  return_to_vendor_policy varchar [note: 'Terms governing the return of defective, damaged, or unsold merchandise to the vendor. Defines RTV authorization process, restocking fees, return shipping responsibility, and credit issuance timeline.']
  shipping_point varchar [note: 'Vendor facility or distribution center from which goods are shipped under this contract. Used for logistics planning, freight cost calculation, and delivery time estimation.']
  signature_date date [note: 'Date when the contract was signed by the authorized buyer representative. Used for contract validity verification and audit trail.']
  termination_notice_days varchar [note: 'Number of calendar days advance notice required to terminate the contract. Either party must provide written notice this many days before the desired termination date.']
  vendor_signatory_name varchar [note: 'Full name of the authorized representative who signed the contract on behalf of the vendor organization. Used for contract validation and audit trail.']
  vendor_signatory_title varchar [note: 'Job title or role of the vendor authorized signatory. Examples include CEO, VP Sales, Director of Business Development. Used to verify vendor signing authority.']
  vendor_signature_date date [note: 'Date when the contract was signed by the authorized vendor representative. Used for contract validity verification and audit trail.']
  vmi_enabled_flag boolean [note: 'Indicates whether Vendor Managed Inventory is enabled under this contract. True if the vendor monitors buyer inventory levels and automatically replenishes stock. False for buyer-managed replenishment.']

  Note: 'Supplier trading agreements and master vendor contracts including terms and conditions, payment terms, discount structures, exclusivity clauses, private label agreements, and contract validity periods. Tracks contract type (national brand, private label, DSD), effective and expiry dates, auto-renewal flags, and signatory details. Sourced from SAP S/4HANA SD/MM contract management.'
}

Table supplier.chargeback {
  chargeback_id varchar [pk, note: 'Unique identifier for the vendor compliance chargeback penalty record.']
  dc_facility_id varchar [note: 'Reference to the distribution center or receiving facility where the compliance violation was detected.']
  goods_receipt_id varchar [note: 'Foreign key linking to inventory.goods_receipt. Business justification: Chargebacks for receipt discrepancies (short shipments, damaged goods, labeling violations) require direct link to the specific goods_receipt event for validation, dispute resolution, and vendor score']
  inbound_shipment_id varchar [note: 'Foreign key linking to supplychain.inbound_shipment. Business justification: Chargebacks triggered by shipment violations (short ship, ASN non-compliance, seal failure) require direct reference to the inbound_shipment for root cause investigation and vendor dispute resolution.']
  lead_time_agreement_id varchar [note: 'Foreign key linking to supplier.lead_time_agreement. Business justification: A chargeback issued for a lead time or MOQ violation should reference the specific lead_time_agreement that was breached. chargeback already has vendor_contract_id (the governing contract) and vendor_']
  purchase_order_id varchar [note: 'Reference to the purchase order associated with the compliance violation that triggered this chargeback.']
  receiving_event_id varchar [note: 'Foreign key linking to supplychain.receiving_event. Business justification: Receiving discrepancy chargebacks (shortage, damage, overage) are directly triggered by receiving_event records containing discrepancy_reason_code and damage_flag. \'Receiving discrepancy chargeback\' p']
  returns_rma_id varchar [note: 'Foreign key linking to returns.rma. Business justification: Vendor chargebacks often stem from customer returns (damaged/defective goods). AP teams reconcile chargebacks against originating RMAs to validate penalty legitimacy and negotiate vendor disputes. Ena']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Chargebacks for quality, compliance, or labeling violations must identify affected SKUs. Business process: chargeback dispute resolution, root cause analysis, vendor scorecard impact assessment, and f']
  vendor_contract_id varchar [note: 'Foreign key linking to supplier.vendor_contract. Business justification: Chargebacks enforce contract compliance by penalizing vendors for violations. Linking to vendor_contract enables retrieving penalty schedules, dispute resolution procedures, and recovery methods defin']
  vendor_id varchar [note: 'Reference to the supplier or vendor against whom this chargeback penalty is issued.']
  vendor_item_id varchar [note: 'Foreign key linking to supplier.vendor_item. Business justification: Chargebacks for item-specific violations (incorrect labeling, wrong UPC/GTIN, non-compliant pack configuration, wrong case pack quantity) must reference the specific vendor_item catalog entry — not ju']
  vendor_promo_agreement_id varchar [note: 'Foreign key linking to promotion.vendor_promo_agreement. Business justification: Promotional chargebacks are issued when vendors fail to fulfill promotional funding commitments. \'Promotional chargeback management\' requires linking each chargeback to the specific vendor_promo_agree']
  violation_location_id varchar [note: 'Foreign key linking to store.store_location. Business justification: Chargebacks for routing guide violations, labeling errors, or receiving discrepancies originate at specific receiving locations (stores or DCs). Tracking the violation location supports root cause ana']
  affected_units varchar [note: 'The number of units (SKUs, cartons, or pallets) impacted by the compliance violation.']
  approval_date date [note: 'The date on which the chargeback was formally approved for issuance.']
  approved_by varchar [note: 'User ID of the procurement or compliance manager who approved the chargeback for issuance to the vendor.']
  chargeback_number varchar [note: 'Externally visible business identifier for the chargeback penalty, used in vendor communications and dispute resolution.']
  chargeback_status varchar [note: 'Current lifecycle state of the chargeback penalty in the dispute and recovery workflow. [ENUM-REF-CANDIDATE: pending|issued|disputed|under_review|approved|rejected|paid|written_off|cancelled — 9 candidates stripped; promote to reference product]']
  chargeback_type varchar [note: 'High-level category of the compliance violation that triggered the chargeback penalty. [ENUM-REF-CANDIDATE: routing_guide_violation|labeling_non_compliance|edi_failure|late_shipment|fill_rate_shortfall|asn_error|packaging_defect|quality_defect|documentation_error|other — 10 candidates stripped; promote to reference product]']
  created_timestamp timestamp [note: 'The date and time when this chargeback record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the penalty amount.']
  debit_memo_number varchar [note: 'The external document number of the debit memo issued to the vendor for the chargeback penalty, if applicable.']
  detection_date date [note: 'The date on which the compliance violation was formally identified and logged in the system, which may differ from the violation date.']
  dispute_date date [note: 'The date on which the vendor formally disputed the chargeback penalty.']
  dispute_reason varchar [note: 'Free-text explanation provided by the vendor for disputing the chargeback, including supporting evidence references.']
  dispute_status varchar [note: 'Indicates whether the vendor has disputed the chargeback and the current state of the dispute resolution process.']
  is_repeat_violation boolean [note: 'Flag indicating whether this chargeback represents a repeat violation of the same compliance rule by the vendor within a defined time window.']
  last_updated_timestamp timestamp [note: 'The date and time when this chargeback record was most recently modified.']
  notes varchar [note: 'Free-text field for additional context, supporting documentation references, or special handling instructions related to the chargeback.']
  notification_method varchar [note: 'The communication channel used to notify the vendor of the chargeback penalty.']
  notification_sent_date date [note: 'The date on which the chargeback notification was sent to the vendor through the vendor portal or EDI channel.']
  penalty_amount decimal(15,2) [note: 'The monetary value of the chargeback penalty assessed against the vendor for the compliance violation.']
  penalty_calculation_method varchar [note: 'The method used to calculate the chargeback penalty amount, such as a fixed flat fee or a percentage of the order value.']
  penalty_percentage decimal(5,2) [note: 'The percentage rate applied to the order or shipment value when the penalty calculation method is percentage-based.']
  previous_violation_count varchar [note: 'The number of prior chargebacks issued to this vendor for the same violation category within the trailing 12-month period.']
  recovery_date date [note: 'The date on which the chargeback penalty amount was successfully recovered from the vendor through the specified recovery method.']
  recovery_method varchar [note: 'The mechanism used to recover the chargeback penalty amount from the vendor, such as accounts payable deduction or separate debit memo.']
  resolution_date date [note: 'The date on which the chargeback dispute was resolved and a final decision was made.']
  resolution_notes varchar [note: 'Internal notes documenting the outcome of the dispute resolution process, including any adjustments or waivers granted.']
  vendor_scorecard_impact decimal(5,2) [note: 'The negative impact score applied to the vendors performance scorecard as a result of this chargeback, used in vendor relationship management and future sourcing decisions.']
  violation_category varchar [note: 'Detailed classification of the specific compliance rule or requirement that was violated, such as GS1-128 labeling failure, RFID tag missing, or incorrect pallet configuration.']
  violation_date date [note: 'The date on which the compliance violation occurred or was detected by the receiving facility or quality control process.']
  created_by varchar [note: 'User ID or system identifier of the person or automated process that created the chargeback record.']

  Note: 'Vendor compliance penalty records issued to suppliers for violations of routing guides, labeling requirements (GS1-128, RFID/EPC), EDI non-compliance, late shipments, fill rate shortfalls, ASN failures, and packaging defects. Tracks chargeback type, violation category, violation date, penalty amount (flat fee or percentage), dispute status, resolution date, recovery method (AP deduction or separate debit memo), and linkage to the originating routing guide rule. Critical for vendor compliance enforcement, cost recovery, and feeds vendor scorecard KPIs. Supports automated penalty calculation and vendor portal notification workflows.'
}

Table supplier.vendor_scorecard {
  vendor_scorecard_id varchar [pk, note: 'Unique identifier for the vendor scorecard record. Primary key. Role: TRANSACTION_HEADER (scorecard is a periodic performance evaluation event).']
  supply_purchase_order_id varchar [note: 'Foreign key linking to supplychain.purchase_order. Business justification: Scorecards measure vendor performance (on-time delivery, fill rate, invoice accuracy) across PO history. Retail buyers review scorecard metrics tied to specific POs for vendor negotiations, tier assig']
  vendor_contract_id varchar [note: 'Foreign key linking to supplier.vendor_contract. Business justification: Vendor scorecards measure performance against contract SLAs (on-time delivery rate, fill rate, EDI compliance). Linking to vendor_contract enables comparing actual performance metrics to contractual c']
  vendor_id varchar [note: 'Reference to the vendor being evaluated in this scorecard. Links to the vendor master data entity.']
  chargeback_amount decimal(15,2) [note: 'Total monetary value of chargebacks assessed against the vendor during the scoring period, typically in USD.']
  chargeback_count varchar [note: 'Total number of chargebacks (vendor compliance penalties) issued to the vendor during the scoring period for violations such as late delivery, incorrect labeling, or packaging non-compliance.']
  composite_score decimal(5,2) [note: 'Weighted overall vendor performance score calculated from individual KPI values (on-time delivery, fill rate, quality, etc.). Scale typically 0-100. Used for vendor tier classification.']
  corrective_action_due_date date [note: 'Deadline by which the vendor must submit a corrective action plan if required.']
  corrective_action_required boolean [note: 'Flag indicating whether the vendor is required to submit a corrective action plan based on scorecard results (true if performance is below acceptable thresholds).']
  created_timestamp timestamp [note: 'Timestamp when this scorecard record was first created in the system.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for all monetary amounts in this scorecard (e.g., USD, EUR, GBP).']
  edi_compliance_rate decimal(5,2) [note: 'Percentage of transactions (purchase orders, ASNs, invoices) successfully transmitted via EDI without errors or manual intervention during the scoring period.']
  evaluation_date date [note: 'Date when the scorecard was completed and finalized by the evaluator.']
  fill_rate decimal(5,2) [note: 'Percentage of ordered quantity that was fulfilled by the vendor during the scoring period. Measures vendor ability to meet demand without stockouts.']
  invoice_accuracy_rate decimal(5,2) [note: 'Percentage of invoices submitted without pricing, quantity, or calculation errors during the scoring period. Measures vendor billing quality.']
  last_updated_timestamp timestamp [note: 'Timestamp when this scorecard record was last modified.']
  lead_time_adherence_rate decimal(5,2) [note: 'Percentage of orders where the vendor met the agreed lead time from order placement to delivery during the scoring period.']
  minimum_order_quantity_compliance_rate decimal(5,2) [note: 'Percentage of orders where the vendor honored MOQ agreements without imposing additional fees or rejecting orders during the scoring period.']
  notes varchar [note: 'Free-text field for additional comments, context, or qualitative observations about vendor performance during the scoring period.']
  on_time_delivery_rate decimal(5,2) [note: 'Percentage of purchase orders or shipments delivered on or before the promised delivery date during the scoring period. Key KPI for vendor reliability.']
  prior_period_composite_score decimal(5,2) [note: 'Composite score from the previous scoring period, used to calculate trend and performance improvement or decline.']
  product_quality_score decimal(5,2) [note: 'Composite quality score based on defect rates, customer returns, and quality inspection results for products supplied by the vendor during the scoring period. Scale typically 0-100.']
  return_to_vendor_amount decimal(15,2) [note: 'Total monetary value of goods returned to the vendor during the scoring period, typically in USD.']
  return_to_vendor_count varchar [note: 'Total number of RTV transactions initiated during the scoring period due to defects, overstock, or non-compliance.']
  score_trend varchar [note: 'Directional trend of vendor performance compared to the prior period (improving, stable, or declining).']
  scorecard_number varchar [note: 'Business identifier for the scorecard, typically formatted as SC-YYYYMMDD or similar pattern for external reference and reporting.']
  scorecard_status varchar [note: 'Current lifecycle status of the scorecard indicating whether it is in draft, published for vendor review, under internal review, finalized, or archived.']
  scoring_period_end_date date [note: 'The end date of the evaluation period covered by this scorecard (e.g., end of quarter or month).']
  scoring_period_start_date date [note: 'The start date of the evaluation period covered by this scorecard (e.g., beginning of quarter or month).']
  total_purchase_order_count varchar [note: 'Total number of purchase orders issued to the vendor during the scoring period. Provides context for volume-based KPI interpretation.']
  total_purchase_order_value decimal(15,2) [note: 'Total monetary value of purchase orders issued to the vendor during the scoring period, typically in USD. Provides spend context for scorecard evaluation.']
  vendor_acknowledgment_date date [note: 'Date when the vendor acknowledged receipt and review of the scorecard.']
  vendor_notification_date date [note: 'Date when the scorecard was shared with the vendor for review and discussion.']
  vendor_tier varchar [note: 'Classification tier assigned to the vendor based on the composite score and strategic importance. Preferred vendors receive priority, probation vendors face restrictions, suspended vendors are blocked from new orders.']

  Note: 'Periodic vendor performance scorecards measuring KPIs including on-time delivery rate, fill rate, EDI compliance rate, invoice accuracy, chargeback frequency, product quality scores, and overall vendor rating. Tracks scoring period, individual KPI values, weighted composite score, tier classification (preferred, approved, probation), and trend vs prior period. Enables strategic vendor relationship management.'
}

Table supplier.edi_config {
  edi_config_id varchar [pk, note: 'Unique identifier for the EDI configuration record. Primary key for the EDI configuration entity.']
  primary_edi_trading_partner_vendor_id varchar [note: 'Unique identifier assigned to the trading partner in the EDI network. Used in EDI envelope segments to identify sender and receiver.']
  vendor_contract_id varchar [note: 'Foreign key linking to supplier.vendor_contract. Business justification: EDI integration requirements (transaction sets, acknowledgment SLAs, compliance thresholds) are typically defined in vendor contracts. Linking edi_config to vendor_contract enables tracking which cont']
  alert_email_addresses varchar [note: 'Comma-separated list of email addresses to notify when EDI errors, SLA violations, or integration health issues occur. Used for operational alerting.']
  authentication_method varchar [note: 'The authentication mechanism used to secure the EDI connection. Certificate-based authentication is standard for AS2; SSH keys are common for SFTP.']
  certification_date date [note: 'The date when the EDI integration was certified and approved for production use after successful testing. Null if not yet certified.']
  chargeback_currency_code varchar [note: 'Three-letter ISO 4217 currency code for the chargeback penalty amount. Example: USD, EUR, GBP.']
  chargeback_penalty_amount decimal(15,2) [note: 'The monetary penalty amount (in base currency) assessed per EDI compliance violation. Chargebacks are vendor compliance penalties for failing to meet EDI standards or SLAs.']
  communication_protocol varchar [note: 'The technical protocol used to transmit EDI documents between trading partners. AS2 is the most common secure protocol; VAN refers to Value-Added Network services.']
  compliance_threshold_error_rate decimal(5,2) [note: 'The maximum acceptable error rate (as a percentage) for EDI transactions before compliance penalties or chargebacks are triggered. Example: 2.00 means 2% error rate threshold.']
  connection_endpoint varchar [note: 'The URL, IP address, or network address used to connect to the trading partner for EDI transmission. May be an AS2 URL, SFTP host, or VAN mailbox identifier.']
  connection_port varchar [note: 'The network port number used for EDI communication. Common ports: 22 for SFTP, 443 for AS2 over HTTPS.']
  created_timestamp timestamp [note: 'The timestamp when this EDI configuration record was first created in the system. Audit trail field for record lifecycle tracking.']
  edi_version varchar [note: 'The EDI standard version supported by this configuration. Examples: 4010, 5010 for ANSI X12; D96A, D01B for EDIFACT.']
  effective_end_date date [note: 'The date on which this EDI configuration ceases to be effective. Null for currently active configurations. Supports temporal validity tracking and configuration history.']
  effective_start_date date [note: 'The date from which this EDI configuration becomes effective and valid for use. Supports temporal validity tracking.']
  environment_type varchar [note: 'Indicates whether this EDI configuration is for production use or a non-production environment (test, development, staging). Test environments are used during EDI onboarding and integration testing.']
  fa_sla_hours varchar [note: 'The maximum number of hours allowed to send a functional acknowledgment (997) after receiving an EDI document. Failure to meet this SLA may trigger compliance chargebacks.']
  functional_acknowledgment_required boolean [note: 'Indicates whether the trading partner requires a 997 Functional Acknowledgment to be sent in response to received EDI documents. True if FA is mandatory per trading partner agreement.']
  go_live_date date [note: 'The date when the EDI configuration was activated for production transaction processing. Marks the transition from test to production environment.']
  gs_qualifier varchar [note: 'GS qualifier code that identifies the type of identification being used in the functional group envelope. Defines how the sender/receiver codes are interpreted.']
  inbound_enabled boolean [note: 'Indicates whether this configuration is enabled to receive inbound EDI documents from the trading partner. True if inbound processing is active.']
  integration_health_status varchar [note: 'Current operational health status of the EDI integration. Derived from recent transmission success rates, error rates, and SLA compliance. Used for proactive monitoring.']
  is_active boolean [note: 'Indicates whether this EDI configuration is currently active and operational. False if the configuration has been deactivated or suspended.']
  isa_qualifier varchar [note: 'ISA qualifier code that identifies the type of identification being used in the EDI interchange envelope. Common values: 01=DUNS, 14=DUNS+4, ZZ=Mutually Defined. [ENUM-REF-CANDIDATE: 01|14|20|27|28|29|30|33|ZZ — 9 candidates stripped; promote to reference product]']
  last_error_code varchar [note: 'The error code or identifier for the most recent EDI processing failure. Used in conjunction with last_error_timestamp for diagnostics.']
  last_error_description varchar [note: 'Human-readable description of the most recent EDI error. Provides context for troubleshooting and resolution.']
  last_error_timestamp timestamp [note: 'The timestamp of the most recent EDI transmission or processing error. Used for troubleshooting and error resolution tracking.']
  last_successful_transmission_timestamp timestamp [note: 'The timestamp of the most recent successful EDI document transmission (inbound or outbound). Used for integration health monitoring and alerting.']
  last_updated_timestamp timestamp [note: 'The timestamp when this EDI configuration record was most recently modified. Audit trail field for change tracking.']
  max_retry_attempts varchar [note: 'The maximum number of times a failed EDI transmission will be retried before being marked as permanently failed and requiring manual intervention.']
  notes varchar [note: 'Free-form text field for capturing additional configuration details, special requirements, or historical context about the EDI integration.']
  onboarding_start_date date [note: 'The date when EDI onboarding activities began for this trading partner. Marks the start of the integration project.']
  onboarding_status varchar [note: 'Current status of the EDI onboarding lifecycle for this trading partner. Tracks progression from initial setup through testing, certification, and production activation. [ENUM-REF-CANDIDATE: not_started|in_progress|testing|certified|active|suspended|terminated — 7 candidates stripped; promote to reference product]']
  outbound_enabled boolean [note: 'Indicates whether this configuration is enabled to send outbound EDI documents to the trading partner. True if outbound processing is active.']
  retry_policy varchar [note: 'The retry strategy applied when EDI transmission failures occur. Defines how and when failed transmissions are retried.']
  supported_transaction_sets varchar [note: 'Comma-separated list of EDI transaction set codes supported by this trading partner. Common retail sets: 850 (Purchase Order), 855 (PO Acknowledgment), 856 (Advance Ship Notice), 810 (Invoice), 832 (Price/Sales Catalog), 846 (Inventory Inquiry/Advice), 997 (Functional Acknowledgment).']

  Note: 'EDI (Electronic Data Interchange) integration configuration for each trading partner defining connection parameters and supported transaction sets. Captures vendor trading partner ID, ISA/GS qualifiers, supported EDI documents (850, 855, 856, 810, 832, 846), communication protocol (AS2, SFTP, VAN), test vs production status, functional acknowledgment SLA, and compliance thresholds that trigger chargebacks. Manages EDI onboarding lifecycle, ongoing integration health monitoring, and serves as the reference record for edi_transaction processing and error resolution.'
}

Table supplier.lead_time_agreement {
  lead_time_agreement_id varchar [pk, note: 'Unique identifier for the lead time agreement record. Primary key.']
  dc_facility_id varchar [note: 'Reference to the distribution center or warehouse that receives shipments under this agreement.']
  destination_inventory_node_id varchar [note: 'Foreign key linking to inventory.inventory_node. Business justification: Lead time agreements specify delivery terms to specific DCs, stores, or cross-dock facilities. Essential for replenishment planning, inbound appointment scheduling, and on-time delivery SLA measuremen']
  vendor_contract_id varchar [note: 'Foreign key linking to supplier.vendor_contract. Business justification: Lead time agreements define MOQ, lead times, and delivery SLAs that are typically negotiated as part of vendor contracts. Linking to vendor_contract enables tracking agreement lineage, contract renewa']
  vendor_id varchar [note: 'Reference to the supplier or vendor party covered by this lead time agreement.']
  agreement_name varchar [note: 'Descriptive name or title of the lead time agreement for easy identification.']
  agreement_number varchar [note: 'Business identifier for the lead time agreement, used for external reference and vendor communication.']
  agreement_status varchar [note: 'Current lifecycle status of the lead time agreement.']
  agreement_type varchar [note: 'Classification of the lead time agreement based on its purpose and operational context. VMI indicates Vendor Managed Inventory agreements.']
  auto_renewal_flag boolean [note: 'Indicates whether this agreement automatically renews upon expiration.']
  compliance_penalty_rate decimal(5,2) [note: 'Percentage rate applied as chargeback penalty for vendor non-compliance with lead time or delivery terms.']
  created_timestamp timestamp [note: 'Timestamp when this lead time agreement record was first created in the system.']
  delivery_frequency varchar [note: 'Standard frequency of deliveries from vendor. DSD indicates Direct Store Delivery model.']
  delivery_window_end_time timestamp [note: 'End time of the agreed delivery window at distribution center (HH:MM format).']
  delivery_window_start_time timestamp [note: 'Start time of the agreed delivery window at distribution center (HH:MM format).']
  edi_enabled_flag boolean [note: 'Indicates whether purchase orders and ASNs are exchanged via EDI for this agreement.']
  effective_end_date date [note: 'Date when this lead time agreement expires or is terminated. Null for open-ended agreements.']
  effective_start_date date [note: 'Date when this lead time agreement becomes active and enforceable.']
  expedited_lead_time_days varchar [note: 'Reduced lead time in days available for rush or expedited orders, typically at premium cost.']
  fill_rate_sla_percent decimal(5,2) [note: 'Target percentage of ordered quantity that vendor must deliver to meet order completion SLA.']
  incoterm varchar [note: 'Standard trade term defining responsibilities for shipping, insurance, and customs (e.g., FOB, CIF, DDP).']
  inner_pack_quantity varchar [note: 'Number of consumer units in an inner pack within the master case, used for store-level replenishment.']
  last_updated_timestamp timestamp [note: 'Timestamp when this lead time agreement record was last modified.']
  minimum_order_quantity decimal(18,3) [note: 'Minimum number of units that must be ordered per purchase order to meet vendor requirements.']
  notes varchar [note: 'Free-text field for additional terms, special instructions, or exceptions related to this lead time agreement.']
  on_time_delivery_sla_percent decimal(5,2) [note: 'Target percentage of deliveries that must arrive within the agreed lead time window to meet SLA.']
  order_increment_quantity decimal(18,3) [note: 'Quantity increment in which orders must be placed above the MOQ (e.g., must order in multiples of 12 units).']
  origin_location varchar [note: 'Geographic location or facility from which vendor ships products (city, state, country).']
  pack_size varchar [note: 'Number of consumer units contained in a single vendor pack or case.']
  pallet_quantity varchar [note: 'Standard number of cases or units per pallet for warehouse receiving and cross-docking operations.']
  renewal_notice_days varchar [note: 'Number of days advance notice required before agreement renewal or termination.']
  scope_level varchar [note: 'Granularity level at which this lead time agreement applies: vendor-wide, product category, subcategory, individual SKU, or product group.']
  seasonal_lead_time_adjustment_days varchar [note: 'Additional days added to standard lead time during peak seasonal periods (e.g., holiday season, back-to-school).']
  seasonal_period_end_date date [note: 'End date of the seasonal period when lead time adjustments apply.']
  seasonal_period_start_date date [note: 'Start date of the seasonal period when lead time adjustments apply.']
  sku varchar [note: 'Specific SKU identifier when this agreement applies to an individual product. Null when agreement is at vendor or category level.']
  standard_lead_time_days varchar [note: 'Standard number of days from purchase order placement to goods receipt at distribution center under normal operating conditions.']
  transportation_mode varchar [note: 'Primary mode of transportation used for shipments under this agreement.']
  unit_of_measure varchar [note: 'Standard unit of measure for quantities in this agreement (each, case, pallet, weight, volume). [ENUM-REF-CANDIDATE: each|case|pallet|pound|kilogram|liter|gallon — 7 candidates stripped; promote to reference product]']
  vmi_enabled_flag boolean [note: 'Indicates whether this agreement operates under a VMI model where vendor manages inventory replenishment.']
  created_by varchar [note: 'User ID or name of the procurement specialist who created this agreement record.']

  Note: 'Documented lead time and MOQ (Minimum Order Quantity) agreements per vendor and product category or SKU. Captures standard lead time (days), expedited lead time, MOQ units, order increment, pack size, inner pack quantity, and seasonal lead time adjustments. Feeds Blue Yonder demand planning replenishment parameters and OTB calculations.'
}

Table supplier.vendor_item {
  vendor_item_id varchar [pk, note: 'Unique identifier for the vendor-item relationship record. Primary key.']
  lead_time_agreement_id varchar [note: 'Foreign key linking to supplier.lead_time_agreement. Business justification: Vendor_item captures item-specific lead times and MOQ values that should be governed by a lead_time_agreement. Adding this FK normalizes lead time and MOQ data to the authoritative agreement record. R']
  sku_id varchar [note: 'Reference to the internal product master record. Links vendor catalog to internal SKU (Stock Keeping Unit).']
  vendor_contract_id varchar [note: 'Foreign key linking to supplier.vendor_contract. Business justification: A vendor item\'s unit_cost, cost_effective_date, cost_expiration_date, and terms (dsd_eligible_flag, vmi_enabled_flag, edi_enabled_flag) are governed by a specific vendor contract. vendor_item already ']
  vendor_id varchar [note: 'Reference to the supplier or vendor providing this item. Links to the vendor master record.']
  case_pack_quantity varchar [note: 'Number of individual units contained in one vendor case pack. Used for ordering and receiving calculations.']
  category varchar [note: 'The vendor\'s product category classification for this item. May differ from internal merchandising hierarchy.']
  cost_currency_code varchar [note: 'Three-letter ISO 4217 currency code for the unit cost (e.g., USD, EUR, GBP).']
  cost_effective_date date [note: 'The date from which the current unit cost is effective. Used for cost change tracking and historical cost analysis.']
  cost_expiration_date date [note: 'The date through which the current unit cost remains valid. Null indicates open-ended pricing.']
  country_of_origin varchar [note: 'Three-letter ISO 3166-1 alpha-3 country code indicating where the item is manufactured or produced. Required for customs, tariffs, and trade compliance.']
  created_timestamp timestamp [note: 'The date and time when this vendor-item record was first created in the system.']
  description varchar [note: 'The vendor\'s description of the item as it appears in their catalog. May differ from internal product description.']
  dsd_eligible_flag boolean [note: 'Indicates whether this item can be delivered directly to stores by the vendor, bypassing the DC (Distribution Center). Common for beverages, bread, and snacks.']
  ean varchar [note: '13-digit European Article Number barcode identifier used internationally for retail product identification.']
  edi_enabled_flag boolean [note: 'Indicates whether purchase orders and ASN (Advanced Shipping Notice) transactions for this vendor-item are transmitted via EDI (Electronic Data Interchange).']
  effective_end_date date [note: 'The date through which this vendor-item relationship remains active. Null indicates an open-ended relationship.']
  effective_start_date date [note: 'The date from which this vendor-item relationship became active and available for ordering.']
  gtin varchar [note: 'Global Trade Item Number assigned by GS1 for worldwide product identification. Can be 8, 12, 13, or 14 digits.']
  inner_pack_quantity varchar [note: 'Number of individual units contained in one inner pack within a case. Used for shelf-ready packaging and store replenishment.']
  last_cost_change_date date [note: 'The date when the unit cost was last modified. Used for cost trend analysis and vendor negotiation tracking.']
  last_order_date date [note: 'The date when this vendor-item combination was last ordered. Used to identify slow-moving or obsolete vendor relationships.']
  last_updated_timestamp timestamp [note: 'The date and time when this vendor-item record was last modified.']
  notes varchar [note: 'Free-form text field for additional information about this vendor-item relationship, such as special handling instructions or ordering restrictions.']
  pallet_hi varchar [note: 'Number of layers (tiers) stacked on a pallet. Part of the TI/HI pallet configuration used in warehouse and DC operations.']
  pallet_ti varchar [note: 'Number of cases per layer on a pallet. Part of the TI/HI pallet configuration used in warehouse and DC (Distribution Center) operations.']
  preferred_vendor_flag boolean [note: 'Indicates whether this vendor is the preferred source for this item when multiple vendors supply the same product. Used in automated sourcing decisions.']
  private_label_flag boolean [note: 'Indicates whether this item is a private label (store brand) product manufactured exclusively for the retailer by this vendor.']
  seasonal_lead_time_adjustment_days varchar [note: 'Additional lead time days required during peak seasonal periods (e.g., holiday season). Added to standard lead time for seasonal planning.']
  unit_cost decimal(15,4) [note: 'The cost per individual unit charged by the vendor. Used for COGS (Cost of Goods Sold) calculations and margin analysis. Excludes freight and other charges.']
  upc varchar [note: '12-digit Universal Product Code barcode identifier used primarily in North America for retail scanning at POS (Point of Sale).']
  vendor_item_number varchar [note: 'The vendor\'s unique part number or catalog identifier for this item. Used in purchase orders and EDI (Electronic Data Interchange) transactions.']
  vendor_item_status varchar [note: 'Current lifecycle status of this vendor-item relationship. Active items are available for ordering; discontinued items are being phased out.']
  vendor_pack_configuration varchar [note: 'Description of how the vendor packages this item (e.g., case pack, master carton, pallet). Defines the vendor\'s standard shipping unit.']
  vmi_enabled_flag boolean [note: 'Indicates whether this vendor-item combination is managed under a VMI (Vendor Managed Inventory) agreement where the vendor controls replenishment.']

  Note: 'Vendor-specific item catalog linking vendor part numbers, UPCs, GTINs, and EANs to internal SKUs. Captures vendor item number, vendor pack configuration, case pack quantity, inner pack, pallet TI/HI, unit cost, cost effective date, country of origin, and item status. Includes lead time and MOQ agreements per vendor-item combination: standard lead time (days), expedited lead time, MOQ units, order increment, pack size, inner pack quantity, seasonal lead time adjustments, and category-level defaults. Serves as the cross-reference between vendor catalogs and the internal product master, and feeds Blue Yonder demand planning replenishment parameters and OTB calculations.'
}

Table supplier.vendor_allowance {
  vendor_allowance_id varchar [pk, note: 'Unique identifier for the vendor allowance record. Primary key.']
  circular_ad_id varchar [note: 'Foreign key linking to promotion.circular_ad. Business justification: Co-op advertising is a core retail process: vendors pay allowances specifically to fund circular ad placements. Retailers track \'vendor-funded circular placement\' — matching allowance payments to the ']
  cluster_id varchar [note: 'Foreign key linking to store.cluster. Business justification: Trade promotion allowances in retail are routinely negotiated at the store-cluster level (e.g., regional promotional funding for a cluster of stores). Linking vendor_allowance to cluster enables clust']
  promo_campaign_id varchar [note: 'Identifier linking the allowance to a specific promotional campaign or event if the allowance is promotion-specific.']
  promo_offer_id varchar [note: 'Foreign key linking to promotion.promo_offer. Business justification: Vendor allowances frequently fund specific promotional offers (e.g., temporary price reductions, BOGOs) rather than entire campaigns. Merchandising teams reconcile allowance accruals and claims agains']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Vendor allowances (scan-based trading, promotional funding, volume rebates) are frequently SKU-specific or apply to defined SKU lists. Business process: promotional cost accounting, margin analysis, a']
  supply_purchase_order_id varchar [note: 'Foreign key linking to supplychain.purchase_order. Business justification: Allowances (rebates, volume discounts, promotional funding) accrue based on qualifying PO spend. Retail finance teams reconcile allowance claims to PO history for accrual accuracy, settlement validati']
  vendor_contract_id varchar [note: 'Foreign key linking to supplier.vendor_contract. Business justification: Vendor_allowance currently has contract_reference as a STRING field. Trade allowances, co-op funds, and promotional funding are typically defined in vendor contracts. Normalizing this to a FK enables ']
  vendor_id varchar [note: 'Identifier of the supplier or vendor providing the allowance. Links to the vendor master record.']
  vendor_promo_agreement_id varchar [note: 'Foreign key linking to promotion.vendor_promo_agreement. Business justification: Vendor allowances are the financial execution of vendor_promo_agreements. AP teams perform \'promotional funding reconciliation\' — matching allowance payments received against committed funding in the ']
  accrual_method varchar [note: 'Method by which the allowance is accrued in financial systems: invoice-based (at purchase), sales-based (at POS), volume-based (cumulative tier), time-based (periodic), or event-based (specific milestone).']
  accrued_amount decimal(18,2) [note: 'Total monetary value of allowances earned but not yet settled or paid by the vendor.']
  allowance_amount decimal(18,2) [note: 'Fixed monetary value of the allowance if structured as a lump sum payment or credit.']
  allowance_description varchar [note: 'Detailed narrative description of the allowance terms, purpose, and business rationale.']
  allowance_number varchar [note: 'Business identifier or agreement number for the vendor allowance as referenced in contracts and supplier communications.']
  allowance_percentage decimal(5,2) [note: 'Percentage rate applied to qualifying purchase volume or sales to calculate the allowance value.']
  allowance_status varchar [note: 'Current lifecycle status of the vendor allowance agreement.']
  allowance_type varchar [note: 'Classification of the vendor allowance mechanism: off-invoice (deducted at purchase), bill-back (claimed post-sale), scan-based (tied to POS data), slotting fee (shelf placement), co-op advertising (marketing fund), or volume rebate (tier-based discount).']
  approval_status varchar [note: 'Internal approval workflow status for the allowance setup or claim.']
  approved_by varchar [note: 'Name or identifier of the procurement or finance manager who approved the allowance agreement or claim.']
  approved_timestamp timestamp [note: 'Date and time when the allowance was approved in the system.']
  claimed_amount decimal(18,2) [note: 'Total monetary value of allowances formally claimed from the vendor through bill-back or settlement process.']
  cost_center_code varchar [note: 'Cost center or profit center code associated with the allowance for internal financial allocation and P&L reporting.']
  created_timestamp timestamp [note: 'Date and time when the vendor allowance record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the allowance monetary values.']
  disputed_amount decimal(18,2) [note: 'Monetary value of allowances under dispute or chargeback contention with the vendor.']
  effective_end_date date [note: 'Date when the vendor allowance agreement expires or is no longer eligible for new accruals.']
  effective_start_date date [note: 'Date when the vendor allowance agreement becomes active and eligible for accrual.']
  gl_account_code varchar [note: 'General ledger account code to which the vendor allowance is posted for financial reporting and cost of goods sold (COGS) adjustment.']
  last_claim_date date [note: 'Most recent date when an allowance claim was submitted to the vendor.']
  last_settlement_date date [note: 'Most recent date when the vendor made a payment or credit against the allowance.']
  last_updated_timestamp timestamp [note: 'Date and time when the vendor allowance record was most recently modified.']
  minimum_purchase_amount decimal(18,2) [note: 'Minimum purchase value required to qualify for the allowance.']
  minimum_purchase_quantity decimal(15,3) [note: 'Minimum order quantity (MOQ) in units required to qualify for the allowance.']
  notes varchar [note: 'Free-text field for additional comments, special instructions, or clarifications regarding the allowance agreement or settlement.']
  payment_method varchar [note: 'Mechanism by which the vendor settles the allowance: credit memo, check, electronic funds transfer (EFT), invoice offset, or promotional credit.']
  payment_terms varchar [note: 'Negotiated terms for allowance settlement timing and conditions, such as net 30, net 60, or upon claim submission.']
  product_category varchar [note: 'Merchandise category or product line to which the allowance applies, used for category management and gross margin return on investment (GMROI) analysis.']
  qualifying_condition varchar [note: 'Business rules and criteria that must be met to earn or claim the allowance, such as minimum order quantity (MOQ), purchase volume thresholds, promotional participation, or compliance requirements.']
  redemption_end_date date [note: 'Final date by which accrued allowances must be claimed or they expire.']
  redemption_start_date date [note: 'Earliest date when accrued allowances can be claimed or redeemed from the vendor.']
  settled_amount decimal(18,2) [note: 'Total monetary value of allowances paid or credited by the vendor.']
  settlement_status varchar [note: 'Current state of financial settlement for the allowance: pending claim, partially paid, fully paid, under dispute, or written off.']
  sku_list varchar [note: 'Comma-separated or structured list of specific SKUs (Stock Keeping Units) eligible for the allowance, if restricted to specific items.']

  Note: 'Vendor-funded trade allowances, co-op advertising funds, slotting fees, promotional funding, and volume rebates negotiated with suppliers. Tracks allowance type (off-invoice, bill-back, scan-based), allowance amount or percentage, qualifying conditions, accrual method, redemption period, and settlement status. Critical for net landed cost and P&L accuracy.'
}

Table ecommerce.storefront {
  storefront_id varchar [pk, note: 'Unique surrogate identifier for each digital storefront or online channel record. Primary key for the storefront master data product within the e-commerce domain.']
  digital_catalog_id varchar [note: 'Identifier of the product catalog assigned to this storefront within the e-commerce platform or the PIM system. Determines which assortment of SKUs, categories, and product content is surfaced to customers on this channel. Aligns with Oracle Retail Merchandising System (ORMS) assortment planning and the customer master data system product golden records.']
  format_id varchar [note: 'Foreign key linking to store.format. Business justification: Omnichannel configuration management: storefronts are configured per store format to mirror BOPIS/ROPIS/SFS capabilities and assortment breadth. Retail omnichannel architects link storefronts to store']
  fulfillment_node_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_node. Business justification: Retail storefronts are operationally configured to route BOPIS, ship-from-store, and same-day orders to a designated fulfillment node. This link drives order routing logic, delivery promise display, a']
  location_id varchar [note: 'Foreign key linking to store.store_location. Business justification: Storefronts often represent specific physical stores\' online presence for store-specific inventory visibility, local pricing, BOPIS fulfillment, and "shop my store" features. Real business process: st']
  price_list_id varchar [note: 'Identifier of the price book or pricing list assigned to this storefront, sourced from Oracle Retail Price Management (RPM) or the e-commerce platform. Governs the base retail prices (AUR — Average Unit Retail) and EDLP (Everyday Low Price) rules applied to products displayed on this channel. Critical for channel-specific pricing strategy execution.']
  price_zone_id varchar [note: 'Foreign key linking to pricing.price_zone. Business justification: Each regional or country-specific ecommerce storefront operates within a defined price zone governing base price multipliers, markdown limits, and currency rules. Retail pricing operations require sto']
  region_id varchar [note: 'Foreign key linking to store.region. Business justification: Regulatory compliance and regional pricing: storefronts must be scoped to a region for GDPR/CCPA enforcement, fiscal calendar alignment, tax jurisdiction assignment, and regional promotional campaign ']
  sfs_fulfillment_node_id varchar [note: 'Foreign key linking to store.sfs_fulfillment_node. Business justification: Ship-from-store operations: storefronts with is_ship_from_store_enabled must be linked to their SFS fulfillment node for order routing, same-day/next-day cutoff time display, daily capacity management']
  analytics_tracking_code varchar [note: 'The web analytics platform tracking identifier assigned to this storefront (e.g., Google Analytics 4 Measurement ID \'G-XXXXXXXXXX\' or Adobe Analytics Report Suite ID). Used to attribute digital customer journey events, CTR (Click-Through Rate), CR (Conversion Rate), and session data to the correct storefront channel. Classified confidential as it represents proprietary analytics configuration.']
  ccpa_opt_out_enabled boolean [note: 'Indicates whether this storefront has activated the CCPA (California Consumer Privacy Act) \'Do Not Sell or Share My Personal Information\' opt-out mechanism, required for storefronts serving California consumers. Governs data sharing controls and consumer rights workflows.']
  channel_type varchar [note: 'Classification of the digital commerce channel operated by this storefront. Segments storefronts by their primary consumer interface: web (desktop/browser), mobile_app (iOS/Android native), marketplace (third-party platform such as Amazon or eBay), social_commerce (shoppable social media), or dark_store (fulfillment-only digital channel). Drives channel-specific analytics including CTR, CR, and GMV reporting.']
  country_code varchar [note: 'ISO 3166-1 alpha-3 three-letter country code indicating the primary geographic market served by this storefront (e.g., \'USA\', \'CAN\', \'GBR\'). Used for regulatory compliance scoping (GDPR, CCPA, FTC), tax jurisdiction assignment, and regional assortment planning.']
  created_timestamp timestamp [note: 'The timestamp when this storefront record was first created in the system of record (the e-commerce platform or the customer master data system). Represents the audit trail creation event for data governance and lineage tracking purposes. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code representing the primary transactional currency for this storefront (e.g., \'USD\', \'CAD\', \'EUR\'). Governs pricing display, checkout totals, AOV calculations, and GMV reporting. Aligns with Oracle Retail Price Management (RPM) currency configuration.']
  customer_service_email varchar [note: 'The operational customer service email address displayed to customers on this storefront for support inquiries, returns (RMA — Return Merchandise Authorization), and complaints. Routed to the case management system for case management. Classified confidential as an organizational contact identifier.']
  decommission_date date [note: 'The calendar date on which this storefront was or is scheduled to be permanently retired and removed from active digital commerce operations. Nullable for currently active storefronts. Used for channel sunset planning, data retention scheduling, and regulatory compliance archival.']
  default_language_code varchar [note: 'ISO 639-1 two-letter language code representing the default display language for this storefront (e.g., \'en\', \'fr\', \'es\'). Used when a customer\'s browser language preference cannot be resolved or when the storefront operates in a single-language mode. Distinct from locale_code which also encodes regional formatting.']
  domain_url varchar [note: 'The primary public-facing domain URL for this storefront (e.g., \'https://www.retail.com\' or \'https://m.retail.com\'). Used for SEO configuration, SSL certificate management, CDN routing, and digital marketing attribution. Classified confidential as it represents proprietary digital infrastructure configuration.']
  free_shipping_threshold decimal(18,2) [note: 'The minimum order value (in the storefront\'s primary currency) at which free standard shipping is automatically applied at checkout. A key lever for AOV (Average Order Value) optimization and customer acquisition. Configured in Oracle Retail Price Management (RPM) or the e-commerce platform promotion rules.']
  gdpr_consent_required boolean [note: 'Indicates whether this storefront is subject to GDPR (General Data Protection Regulation) consent requirements, triggering cookie consent banners, data processing notices, and opt-in workflows for customers in EU/EEA jurisdictions. Drives compliance configuration in the e-commerce platform and CRM systems.']
  is_bopis_enabled boolean [note: 'Indicates whether this storefront supports the BOPIS (Buy Online Pick Up In Store) fulfillment mode, allowing customers to purchase online and collect from a physical store location. Drives fulfillment routing logic in the OMS (Order Management System) and store operations workflows.']
  is_drop_ship_enabled boolean [note: 'Indicates whether this storefront supports drop-ship fulfillment, where vendors ship products directly to customers without passing through Retail\'s DC (Distribution Center). Relevant for extended assortment and marketplace-style operations. Aligns with supplier management and EDI (Electronic Data Interchange) integration.']
  is_loyalty_enabled boolean [note: 'Indicates whether this storefront is integrated with Retail\'s customer loyalty and engagement program, enabling points accrual, redemption, and CLTV (Customer Lifetime Value) tracking at the digital channel level. Drives loyalty-specific promotional targeting and RFM (Recency Frequency Monetary) segmentation.']
  is_ropis_enabled boolean [note: 'Indicates whether this storefront supports ROPIS (Reserve Online Pick Up In Store), allowing customers to reserve items online without payment and collect them in-store. Distinct from BOPIS in that no payment transaction occurs at the digital checkout stage.']
  is_ship_from_store_enabled boolean [note: 'Indicates whether this storefront supports SFS (Ship-from-Store) fulfillment, where physical store locations act as fulfillment centers for online orders. Enables distributed inventory utilization and faster last-mile delivery. Integrates with Manhattan Associates WMS for store-level pick/pack/ship operations.']
  is_ship_to_home_enabled boolean [note: 'Indicates whether this storefront supports ship-to-home fulfillment, where orders are dispatched from a DC (Distribution Center) or store directly to the customer\'s delivery address. Governs last-mile delivery eligibility and carrier integration activation for this channel.']
  is_tax_inclusive_pricing boolean [note: 'Indicates whether product prices displayed on this storefront include taxes (tax-inclusive, common in EU/UK markets) or exclude taxes (tax-exclusive, common in US markets). Governs price display logic at the product listing and checkout stages. Aligns with Oracle Retail Price Management (RPM) tax display configuration.']
  last_modified_timestamp timestamp [note: 'The timestamp when this storefront record was most recently updated in the system of record. Used for change data capture (CDC), incremental ETL processing, and audit trail maintenance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  launch_date date [note: 'The calendar date on which this storefront was first made publicly available to customers. Used for channel age analysis, anniversary promotions, and historical performance benchmarking. Represents the effective-from date for the storefront\'s commercial lifecycle.']
  locale_code varchar [note: 'IETF BCP 47 locale code defining the primary language and regional formatting for this storefront (e.g., \'en_US\', \'fr_CA\', \'es_MX\'). Controls language display, date/number formatting, and content localization within the e-commerce platform. Critical for omnichannel customer experience consistency.']
  max_cart_line_items varchar [note: 'The maximum number of distinct line items (SKUs) permitted in a single shopping cart session on this storefront. Governs cart capacity limits configured in the e-commerce platform to manage checkout performance and order processing capacity. Relevant for B2B or bulk-purchase storefronts.']
  min_order_amount decimal(18,2) [note: 'The minimum cart value (in the storefront\'s primary currency) required for a customer to complete checkout on this storefront. Used to enforce MOQ (Minimum Order Quantity) value thresholds, qualify for free shipping promotions, or meet marketplace seller requirements. Configured in the e-commerce platform checkout rules.']
  name varchar [note: 'Human-readable display name of the digital storefront or online channel (e.g., \'Retail Main Site\', \'Retail Mobile App\', \'Retail Marketplace — Amazon\'). Used in reporting dashboards, operational tooling, and business communications.']
  pci_compliance_level varchar [note: 'The PCI DSS (Payment Card Industry Data Security Standard) merchant compliance level assigned to this storefront, determined by annual card transaction volume (Level 1: >6M transactions; Level 2: 1M–6M; Level 3: 20K–1M; Level 4: <20K). Governs the scope of annual security assessments and SAQ (Self-Assessment Questionnaire) requirements. Classified confidential as it reveals security posture.']
  platform_version varchar [note: 'The version identifier of the the e-commerce platform (SFCC) platform release deployed for this storefront (e.g., \'SFCC 23.7\', \'B2C Commerce 22.10\'). Used for release management, compatibility tracking, and upgrade planning across the digital commerce estate.']
  robots_indexing_policy varchar [note: 'The default robots meta directive applied to this storefront, controlling whether search engine crawlers may index pages and follow links (e.g., \'index_follow\' for the main site, \'noindex_nofollow\' for staging or dark-store channels). Impacts organic search visibility and SEO strategy.']
  seo_meta_title varchar [note: 'The default HTML meta title tag content for the storefront\'s homepage, used by search engines for indexing and SERP (Search Engine Results Page) display. Impacts organic search traffic and digital marketing performance. Managed within the e-commerce platform site preferences.']
  session_timeout_minutes varchar [note: 'The number of minutes of customer inactivity after which a shopping session is automatically expired on this storefront. Governs cart abandonment timing, session-based analytics, and security compliance for authenticated customer sessions. Configured in the e-commerce platform site security settings.']
  site_code varchar [note: 'The externally-known unique site identifier assigned within the e-commerce platform (SFCC) for this storefront. Used as the operational reference key across digital commerce platform configurations, API calls, and integration touchpoints. Aligns to the SFCC Site object\'s siteID field.']
  source_system_code varchar [note: 'Code identifying the operational system of record from which this storefront record was sourced or last updated (e.g., \'SFCC\' for the e-commerce platform, \'MDM\' for the customer master data system, \'MANUAL\' for manually entered records). Used for data lineage tracking, reconciliation, and master data governance within the Silver Layer lakehouse.']
  storefront_status varchar [note: 'Current operational lifecycle state of the storefront. \'active\' indicates the storefront is live and accepting customer traffic; \'maintenance\' indicates a temporary service window; \'draft\' indicates pre-launch configuration; \'decommissioned\' indicates the channel has been permanently retired. Governs whether the storefront is eligible for traffic routing, promotional targeting, and digital commerce operations.']
  supported_payment_methods varchar [note: 'Comma-delimited list of payment methods accepted at checkout on this storefront (e.g., \'credit_card,debit_card,paypal,apple_pay,google_pay,gift_card,buy_now_pay_later\'). Governs payment gateway configuration and PCI DSS compliance scope for this channel. Managed within the e-commerce platform payment processor settings. [ENUM-REF-CANDIDATE: credit_card|debit_card|paypal|apple_pay|google_pay|gift_card|buy_now_pay_later|bank_transfer — promote to reference product]']
  tax_jurisdiction_code varchar [note: 'Code identifying the primary tax jurisdiction applicable to this storefront for sales tax, VAT, or GST calculation purposes (e.g., \'US-CA\', \'CA-ON\', \'GB\'). Used by the tax engine integrated with the e-commerce platform to apply correct tax rates at checkout. Aligns with FASB ASC 606 revenue recognition and FTC pricing transparency requirements.']
  theme_code varchar [note: 'Identifier referencing the visual theme or template applied to this storefront within the e-commerce platform (e.g., \'sfra-retail-v3\', \'pwa-kit-2024\'). Controls the storefront\'s UI/UX presentation layer, including layout, typography, and brand styling. Used by digital merchandising and visual merchandising teams for planogram-equivalent digital shelf configuration.']
  time_zone varchar [note: 'IANA time zone identifier for the storefront\'s primary operating time zone (e.g., \'America/New_York\', \'America/Los_Angeles\'). Used for scheduling promotional campaigns, flash sales, maintenance windows, and business-hours-based SLA calculations. Aligns with the e-commerce platform site time zone configuration.']

  Note: 'Master record for each digital storefront or online channel operated by Retail, including the main e-commerce site, mobile app storefronts, and marketplace presences. Captures storefront identity, locale, currency, domain URL, platform configuration (the e-commerce platform site ID, channel-specific settings, feature flags, theme/template references), launch date, status, supported payment methods, and supported fulfillment modes (BOPIS, ship-to-home, drop-ship). SSOT for digital channel identity and configuration within the e-commerce domain. Domain ownership principle: the ecommerce domain owns digital commerce operations from storefront configuration through checkout completion. Customer identity is owned by the customer domain; post-checkout order lifecycle is owned by the order domain; promotional campaign definitions are owned by the promotion domain; product master data is owned by the product domain.'
}

Table ecommerce.digital_catalog {
  digital_catalog_id varchar [pk, note: 'Unique surrogate identifier for each digital catalog record representing a channel-specific published view of a SKU on a given storefront. Primary key for this entity. Entity role: MASTER_RESOURCE — represents a digital presentation asset managed and published via the e-commerce platform.']
  brand_id varchar [note: 'Foreign key linking to product.product_brand. Business justification: Brand landing pages, brand-level SEO, and brand content management in ecommerce require digital catalog entries to reference the canonical brand record. brand_name is a denormalized representation of ']
  department_id varchar [note: 'Foreign key linking to store.department. Business justification: Omnichannel category management: digital catalog entries must reference the store department for cross-channel category performance reporting, planogram alignment, and department-level promotional eli']
  location_id varchar [note: 'Foreign key linking to store.store_location. Business justification: Products displayed online show store-specific availability and fulfillment options. Real business process: "check store availability" feature, store-specific assortment display, local inventory querie']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: Retail catalog publication workflows scope digital catalogs to a specific price list (e.g., \'Holiday Catalog\', \'Wholesale Price List\'). Content managers and pricing teams use this link to control whic']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Product pages display active promotions; linking enables merchandising teams to verify promotional pricing accuracy across catalog, SEO teams to optimize promotional landing pages, and compliance team']
  return_policy_id varchar [note: 'Foreign key linking to returns.return_policy. Business justification: Product detail pages must display the applicable return policy at point of sale — an FTC-guided retail disclosure requirement. Linking digital_catalog to return_policy enables PDP return policy displa']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Catalog publishing process requires authoritative link to product master for attributes, compliance flags, lifecycle status, vendor data, and pricing rules. Retail operations depend on single source o']
  sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: Digital catalog product pages must display authoritative online prices from sku_price, which maintains channel-specific and zone-specific pricing. Core business process: e-commerce price display and c']
  vendor_item_id varchar [note: 'Foreign key linking to supplier.vendor_item. Business justification: Drop-ship catalog management requires knowing which vendor item record backs each digital listing — governing cost, pack config, lead time, and DSD eligibility. Merchandising and drop-ship onboarding ']
  age_restriction varchar [note: 'Age-gating requirement for this SKU on the digital storefront, applicable to regulated product categories such as alcohol, tobacco, and certain pharmaceuticals. Drives age verification workflows at checkout. Regulated by FTC and FDA.']
  canonical_url varchar [note: 'The canonical URL of the product detail page (PDP) used to prevent duplicate content issues across multiple storefront URLs or faceted navigation paths. Declared in the HTML link rel=canonical tag. Managed in the e-commerce platform.']
  content_completeness_score decimal(5,2) [note: 'Percentage score (0.00–100.00) measuring how complete the digital content is for this catalog record, based on presence of required fields such as title, description, images, SEO metadata, and rich media. Used to prioritize content enrichment efforts and improve Conversion Rate (CR).']
  created_timestamp timestamp [note: 'The date and time when this digital catalog record was first created in the system. Used for data lineage, audit trails, and content age analysis. Satisfies MASTER_RESOURCE RECORD_AUDIT_CREATED category.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code applicable to the online_price for this digital catalog record (e.g., USD, GBP, EUR). Supports multi-currency storefronts in international e-commerce operations.']
  has_video boolean [note: 'Indicates whether at least one product video (e.g., demonstration, unboxing, lifestyle) is published for this SKU on the storefront. Rich media presence is a key driver of Conversion Rate (CR) improvement in digital commerce.']
  hazmat_flag boolean [note: 'Indicates whether this SKU contains hazardous materials subject to special shipping, handling, or labeling requirements. Affects last-mile delivery eligibility and carrier selection in the Order Management System (OMS). Regulated by CPSC and OSHA.']
  image_count varchar [note: 'Total number of product images published for this SKU on the storefront, including hero, alternate angles, lifestyle, and swatch images. Used to measure digital content completeness and identify SKUs requiring additional imagery.']
  is_drop_ship_eligible boolean [note: 'Indicates whether this SKU is fulfilled via Drop Ship, where the vendor ships directly to the customer without passing through a Distribution Center (DC). Relevant for extended aisle and marketplace assortment strategies.']
  is_featured boolean [note: 'Indicates whether this SKU has been manually designated as a featured product by digital merchandisers, qualifying it for placement in featured product carousels, homepage spotlights, or category hero positions on the storefront.']
  is_online_available boolean [note: 'Indicates whether the SKU is currently available for purchase on the digital storefront. Distinct from publication_status — a product may be published but temporarily unavailable due to inventory depletion or fulfillment constraints. Drives add-to-cart eligibility.']
  is_private_label boolean [note: 'Indicates whether this SKU is a private label (store brand) product owned and sold exclusively by the retailer. Private label products typically carry higher gross margins and are a key strategic differentiator in assortment planning.']
  is_searchable boolean [note: 'Indicates whether this SKU is indexed and returned in on-site search results on the digital storefront. A product may be published but excluded from search (e.g., exclusive landing page products or clearance items managed via direct URL only).']
  last_published_timestamp timestamp [note: 'The exact date and time when this digital catalog record was most recently published or re-published to the live storefront. Used for content freshness tracking, cache invalidation, and audit trails in the e-commerce platform.']
  locale_code varchar [note: 'IETF BCP 47 locale code specifying the language and regional variant for this digital catalog record (e.g., en-US, fr-CA, es-MX). Supports multi-locale storefront content management and international e-commerce operations in the e-commerce platform.']
  long_description varchar [note: 'Full consumer-facing product description displayed on the product detail page (PDP), including features, benefits, materials, and usage instructions. Supports rich HTML formatting. Managed in the e-commerce platform content management.']
  primary_image_url varchar [note: 'URL of the primary hero product image displayed on the product detail page (PDP) and product listing pages (PLP). Hosted on the digital asset management (DAM) system or CDN. Critical for digital content completeness scoring.']
  product_name varchar [note: 'The consumer-facing product title as displayed on the digital storefront. May differ from the master product name in PIM to reflect channel-specific merchandising copy or A/B tested titles. Satisfies MASTER_RESOURCE IDENTITY_LABEL category.']
  publication_status varchar [note: 'Current lifecycle state of the digital catalog record on the storefront. Controls whether the SKU is visible and purchasable by online shoppers. Satisfies MASTER_RESOURCE LIFECYCLE_STATUS category. [ENUM-REF-CANDIDATE: draft|published|unpublished|scheduled|archived|suspended — promote to reference product]']
  publish_end_date date [note: 'The date on which this digital catalog record is scheduled to be or was deactivated and removed from the storefront. Used for seasonal assortment management, limited-time offers, and clearance markdown lifecycle management.']
  publish_start_date date [note: 'The date on which this digital catalog record is scheduled to become or became active and visible on the storefront. Used for pre-launch product scheduling and promotional launch coordination in the e-commerce platform.']
  rating_average decimal(3,2) [note: 'Average customer review rating for this SKU on the digital storefront, on a scale of 0.00 to 5.00. Aggregated from verified purchase reviews. Used in product ranking algorithms, content completeness scoring, and conversion rate optimization analytics.']
  review_count varchar [note: 'Total number of published customer reviews for this SKU on the digital storefront. Used alongside rating_average to assess review volume credibility and identify SKUs requiring review generation campaigns.']
  seo_meta_description varchar [note: 'The HTML meta description tag for the product detail page (PDP), summarizing the product for search engine result snippets. Typically 150-160 characters. Drives organic Click-Through Rate (CTR) from search engine results pages.']
  seo_title varchar [note: 'The HTML page title tag for the product detail page (PDP), optimized for search engine indexing. Typically limited to 60 characters per SEO best practices. Managed in the e-commerce platform content management.']
  short_description varchar [note: 'Brief consumer-facing product description displayed in product listing pages (PLP) and search results. Typically 100-200 characters. Sourced from the e-commerce platform product content and may differ from the master description in PIM.']
  sort_order varchar [note: 'Numeric position used to control the default display sequence of this SKU within its assigned digital category on the storefront. Lower values appear first. Used by merchandisers to manually curate product listing page (PLP) rankings.']
  source_system_code varchar [note: 'Code identifying the operational system of record from which this digital catalog record originated or was last updated. Supports data lineage tracking across the e-commerce platform (SFCC), Oracle Retail Merchandising System (ORMS), the customer master data system, and Oracle Retail Price Management (RPM).']
  tax_category_code varchar [note: 'Tax classification code assigned to this SKU for digital commerce tax calculation purposes, determining applicable sales tax rates at checkout. Mapped to tax engine rules in the e-commerce platform. Relevant for FDA-regulated food items with tax exemptions.']
  updated_timestamp timestamp [note: 'The date and time when this digital catalog record was most recently modified, including content updates, price changes, status transitions, or SEO edits. Used for change detection, incremental ETL processing, and audit compliance.']
  url_slug varchar [note: 'The human-readable URL path segment for the product detail page (PDP), used in constructing the storefront URL. Must be lowercase, hyphen-separated, and unique per storefront. Example: \'mens-slim-fit-chino-pants-navy\'.']

  Note: 'E-commerce product catalog record representing the published, channel-specific view of merchandise available on a given storefront. Tracks which SKUs are active online, digital content completeness (images, descriptions, rich media), SEO metadata (title, meta description, canonical URL), online availability flags, digital-only pricing overrides, and publication status. This is the digital presentation layer — distinct from the master product catalog in the product domain which owns canonical SKU/UPC definitions and the master merchandise hierarchy.'
}

Table ecommerce.web_session {
  web_session_id varchar [pk, note: 'Unique surrogate identifier for each individual visitor session on the digital storefront. Primary key for the web_session data product in the Databricks Silver Layer.']
  cart_id varchar [note: 'Reference to the shopping cart created or interacted with during this session. Enables abandoned cart analysis and cart-level GMV (Gross Merchandise Value) attribution even when no order is placed.']
  header_id varchar [note: 'Reference to the order placed during this session, if is_order_placed is True. Enables direct linkage between digital session analytics and order-level GMV (Gross Merchandise Value) and AOV (Average Order Value) reporting.']
  profile_id varchar [note: 'Reference to the authenticated customer associated with this session. Null for anonymous/guest sessions. Enables online-to-offline attribution and CLTV (Customer Lifetime Value) analysis.']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Sessions originate from promotional emails, paid search for promotional keywords, or circular ad QR codes; tracking campaign attribution at session level is fundamental to digital marketing ROI, omnic']
  promo_offer_id varchar [note: 'Foreign key linking to promotion.promo_offer. Business justification: Sessions initiated via offer-specific links (email campaigns, affiliate offers) require offer-level attribution for conversion funnel analysis. Offer-driven session reporting, personalization engine i']
  storefront_id varchar [note: 'Reference to the digital storefront or e-commerce site where the session occurred. Supports multi-brand and multi-region digital commerce operations.']
  browser_name varchar [note: 'Name of the web browser used during the session (e.g., Chrome, Safari, Firefox, Edge). Used for compatibility analysis and identifying browser-specific conversion drop-offs in the digital funnel.']
  browser_version varchar [note: 'Version string of the web browser used during the session. Supports technical compatibility analysis and identification of outdated browser populations impacting checkout CR (Conversion Rate).']
  consent_version varchar [note: 'Version identifier of the consent notice or cookie policy presented to the visitor at session start. Enables compliance audit trails demonstrating which consent framework version was in effect at the time of data collection.']
  created_timestamp timestamp [note: 'Audit timestamp indicating when this web session record was first captured and written to the Silver Layer data product. Distinct from session_start_timestamp which reflects the real-world event time.']
  data_consent_flag boolean [note: 'Indicates whether the visitor provided explicit consent for data collection and tracking during this session, as required under GDPR and CCPA. True = consent granted. Governs permissible use of session data for analytics and personalization.']
  device_type varchar [note: 'Category of device used by the visitor during the session. Supports omnichannel digital journey analytics and device-specific CR (Conversion Rate) and AOV (Average Order Value) reporting.']
  exit_page_url varchar [note: 'Full URL of the last page viewed before the visitor ended the session. Used to identify drop-off points in the digital funnel and optimize checkout flow to improve CR (Conversion Rate).']
  fulfillment_type varchar [note: 'Fulfillment method selected or browsed during the session. BOPIS (Buy Online Pick Up In Store), ROPIS (Reserve Online Pick Up In Store), home_delivery, ship_from_store (SFS), or drop_ship. Supports omnichannel attribution and last-mile delivery analytics.']
  geo_country_code varchar [note: 'ISO 3166-1 alpha-3 three-letter country code inferred from the visitor\'s IP address or browser locale. Supports international digital commerce analytics and regional GMV (Gross Merchandise Value) reporting.']
  ip_address varchar [note: 'IP address of the visitor at session initiation. Used for geolocation inference, fraud detection, and bot traffic filtering. May be considered PII under GDPR/CCPA in some jurisdictions. Stored in compliance with data minimization principles.']
  is_bot boolean [note: 'Indicates whether the session was identified as automated bot or crawler traffic rather than a genuine human visitor. True = bot session. Used to filter non-human traffic from CR (Conversion Rate), CTR (Click-Through Rate), and Footfall analytics.']
  is_bounce boolean [note: 'Indicates whether the session was a bounce — the visitor viewed only a single page and exited without further interaction. True = bounce session. Used to calculate bounce rate as a digital storefront health KPI.']
  is_cart_created boolean [note: 'Indicates whether the visitor created a shopping cart (added at least one item) during this session. True = cart was created. Key funnel stage flag for CR (Conversion Rate) and abandoned cart analysis in the e-commerce platform.']
  is_checkout_initiated boolean [note: 'Indicates whether the visitor initiated the checkout flow during this session. True = checkout was started. Enables measurement of cart-to-checkout conversion rate and identification of checkout abandonment in the digital funnel.']
  is_order_placed boolean [note: 'Indicates whether the session resulted in a completed order placement. True = order was placed. Primary conversion flag for CR (Conversion Rate) calculation and GMV (Gross Merchandise Value) attribution to digital sessions.']
  landing_page_url varchar [note: 'Full URL of the first page viewed by the visitor upon entering the digital storefront. Critical for measuring landing page CR (Conversion Rate) and identifying high-performing entry points in the digital customer journey.']
  last_search_query varchar [note: 'The most recent on-site search term entered by the visitor during the session. Supports merchandising and assortment planning by revealing demand signals and zero-result search patterns.']
  operating_system varchar [note: 'Operating system of the visitor\'s device during the session (e.g., Windows, macOS, iOS, Android). Used for device ecosystem analysis and platform-specific performance optimization.']
  page_view_count varchar [note: 'Total number of distinct pages viewed by the visitor during the session. Indicator of session engagement depth and product discovery behavior. Used in basket analysis and digital journey analytics.']
  referral_source varchar [note: 'High-level channel classification of how the visitor arrived at the digital storefront. Supports digital marketing attribution, CTR (Click-Through Rate) analysis, and channel-level CR (Conversion Rate) reporting. [ENUM-REF-CANDIDATE: organic_search|paid_search|social|email|direct|affiliate|display|referral|sms|push_notification — promote to reference product]']
  referral_url varchar [note: 'Full URL of the referring page or external site that directed the visitor to the digital storefront. Null for direct traffic. Enables granular attribution analysis beyond high-level referral_source classification.']
  search_query_count varchar [note: 'Number of on-site search queries executed by the visitor during the session. Indicator of product discovery intent and search effectiveness. Used to optimize PIM (Product Information Management) and assortment depth.']
  session_duration_seconds varchar [note: 'Total elapsed time in seconds between session_start_timestamp and session_end_timestamp. Raw measurement used to compute average session duration KPIs and correlate engagement with CR (Conversion Rate) and AOV (Average Order Value).']
  session_end_timestamp timestamp [note: 'The precise date and time when the visitor session ended, either through explicit logout, timeout, or browser close. Null if session is still active. Used to compute session duration.']
  session_start_timestamp timestamp [note: 'The precise date and time (ISO 8601 with timezone offset) when the visitor session was initiated on the digital storefront. Principal business event timestamp for session lifecycle analysis.']
  session_status varchar [note: 'Current lifecycle state of the web session. \'active\' = session in progress; \'completed\' = session ended with a conversion event; \'abandoned\' = session ended without conversion; \'timed_out\' = session expired due to inactivity; \'bounced\' = single-page session with immediate exit.']
  session_token varchar [note: 'Externally-known alphanumeric session identifier generated by the e-commerce platform (SFCC) at session initiation. Used for cross-system session correlation and digital journey stitching across touchpoints.']
  updated_timestamp timestamp [note: 'Audit timestamp indicating when this web session record was last modified in the Silver Layer, such as when session_end_timestamp or conversion flags are updated upon session close.']
  utm_campaign varchar [note: 'Urchin Tracking Module (UTM) campaign parameter identifying the specific marketing campaign name or promotion (e.g., spring_sale_2024, loyalty_reactivation). Links sessions to Pricing and Promotions Management campaigns.']
  utm_content varchar [note: 'Urchin Tracking Module (UTM) content parameter used to differentiate ads or links pointing to the same URL (e.g., banner_top, text_link). Supports A/B testing and creative-level CTR (Click-Through Rate) analysis.']
  utm_medium varchar [note: 'Urchin Tracking Module (UTM) medium parameter identifying the marketing medium (e.g., cpc, email, social, banner). Used alongside utm_source for multi-channel attribution and GMV (Gross Merchandise Value) contribution analysis.']
  utm_source varchar [note: 'Urchin Tracking Module (UTM) source parameter from the session entry URL, identifying the advertiser, site, publication, or other source (e.g., google, newsletter, facebook). Core dimension for digital marketing campaign attribution.']
  utm_term varchar [note: 'Urchin Tracking Module (UTM) term parameter capturing the paid search keyword that triggered the session. Used for paid search keyword-level ROI (Return on Investment) and CTR (Click-Through Rate) analysis.']
  visitor_type varchar [note: 'Classification of the visitor for this session. \'new\' = first-time visitor; \'returning\' = previously visited but not authenticated; \'authenticated\' = logged-in registered customer; \'guest\' = checkout without account. Supports CR (Conversion Rate) segmentation and personalization.']

  Note: 'Tracks individual visitor sessions on digital storefronts, capturing session start/end timestamps, device type, browser, OS, referral source, UTM parameters, landing page, exit page, page view count, session duration, and whether the session resulted in a cart creation, checkout initiation, or completed order. Supports CTR, CR, and digital journey analytics. High-volume event data — recommend 90-day hot retention with archival to cold storage for historical trend analysis.'
}

Table ecommerce.cart {
  cart_id varchar [pk, note: 'Unique system-generated identifier for a shopping cart instance created during a customer\'s digital session on a storefront. Serves as the primary key for the cart data product and is referenced by cart line items, abandoned cart recovery workflows, and order conversion records.']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: B2B retail carts are tied to a customer account to enforce contract pricing, credit limits, and tax-exempt rules at cart-build time. Account-level cart abandonment and spend reporting require this dir']
  coupon_id varchar [note: 'Foreign key linking to promotion.coupon. Business justification: Coupon validation at cart entry, redemption limit enforcement, and coupon performance reporting (which coupons drive cart conversions vs. abandonment) require linking cart to the specific coupon recor']
  location_id varchar [note: 'Reference to the physical store location selected by the customer for Buy Online Pick Up In Store (BOPIS) or Reserve Online Pick Up In Store (ROPIS) fulfillment. Null for ship-to-home and drop-ship carts. Supports online-to-offline attribution, store-level BOPIS volume reporting, and inventory reservation at the designated store.']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: In loyalty-tiered and B2B retail, the entire cart is governed by a single negotiated or loyalty price list. Cart-level price list assignment drives discount eligibility, loyalty pricing application, a']
  profile_id varchar [note: 'Reference to the authenticated customer who owns this cart. Null for guest/anonymous sessions where no login has occurred. Used for abandoned cart recovery, Customer Lifetime Value (CLTV) attribution, and personalization workflows.']
  promo_campaign_id varchar [note: 'Reference to the primary promotion applied to this cart. Used for promotion effectiveness measurement, discount attribution, and digital marketing ROI analysis. A cart may have one primary promotion; additional promotions are tracked at the line level.']
  promo_offer_id varchar [note: 'Foreign key linking to promotion.promo_offer. Business justification: Cart-level offer eligibility validation, discount preview calculation, and abandoned cart recovery with offer context all require linking cart to the specific promo_offer applied. Offer conversion fun']
  storefront_id varchar [note: 'Reference to the digital storefront or site context in which this cart was created. Supports multi-brand, multi-region, and multi-locale storefront configurations within the e-commerce platform. Enables Gross Merchandise Value (GMV) and Average Order Value (AOV) analysis by storefront.']
  abandoned_timestamp timestamp [note: 'The date and time when the cart was classified as abandoned, either by session timeout or explicit inactivity threshold breach. Null for non-abandoned carts. Used to calculate time-to-abandonment metrics, trigger abandoned cart recovery email sequences, and measure recovery window effectiveness.']
  abandonment_reason varchar [note: 'Classified reason code for why the cart was abandoned. \'session_timeout\' indicates the session expired; \'inactivity\' indicates no user action within the inactivity window; \'explicit_exit\' indicates the customer navigated away; \'payment_failure\' indicates checkout was attempted but payment was declined; \'out_of_stock\' indicates items became unavailable; \'price_change\' indicates a price change triggered cart exit. Null for non-abandoned carts. Supports abandonment root cause analysis.']
  cart_number varchar [note: 'Human-readable, externally referenceable business identifier for the cart instance. Used in customer service interactions, abandoned cart recovery email communications, and cross-system reconciliation between the e-commerce platform and the Order Management System (OMS). Formatted as CART- followed by a 10-digit sequence.']
  cart_status varchar [note: 'Current lifecycle state of the shopping cart. \'active\' indicates the cart is open and being interacted with; \'abandoned\' indicates the session timed out or the customer left without checkout; \'converted\' indicates the cart was successfully submitted as an order; \'expired\' indicates the cart exceeded the maximum retention window; \'merged\' indicates the cart was consolidated with another cart (e.g., guest-to-authenticated merge). Drives abandoned cart recovery workflows and Conversion Rate (CR) reporting.']
  channel varchar [note: 'The digital channel or interface through which the cart was created and is being managed. Supports omnichannel analytics distinguishing web browser, native mobile application, mobile web browser, email-link-initiated sessions, and Buy Online Pick Up In Store (BOPIS) kiosk interactions. Critical for channel-level Conversion Rate (CR) and Average Order Value (AOV) analysis.']
  converted_timestamp timestamp [note: 'The date and time when the cart was successfully converted to an order at checkout completion. Null for carts that have not converted. Used for cart-to-order conversion time analysis, checkout funnel performance measurement, and Conversion Rate (CR) reporting.']
  coupon_redemption_channel varchar [note: 'The digital channel through which the coupon code was delivered and redeemed by the customer. Distinguishes between web browser entry, mobile app redemption, email link click-through, push notification, and SMS-triggered redemption. Supports digital marketing attribution and channel-level promotion ROI analysis.']
  coupon_redemption_status varchar [note: 'Current validation and application status of the coupon code entered on this cart. \'applied\' means the code was entered and discount applied; \'validated\' means the code passed validation rules but discount is pending; \'rejected\' means the code failed validation (expired, invalid, usage limit exceeded); \'reversed\' means a previously applied discount was removed. Supports promotion effectiveness and fraud monitoring.']
  created_timestamp timestamp [note: 'The date and time when the cart instance was first created in the system, recorded in ISO 8601 format with timezone offset (yyyy-MM-ddTHH:mm:ss.SSSXXX). Represents the start of the cart lifecycle. Used for cart age calculation, session duration analysis, and abandonment timeout determination.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for all monetary amounts on this cart (e.g., USD, GBP, EUR, CAD). Supports multi-currency storefronts and international e-commerce operations. All amount fields on this cart are denominated in this currency.']
  data_consent_flag boolean [note: 'Indicates whether the customer has provided explicit consent for their cart and behavioral data to be used for personalization, marketing, and analytics purposes (True) or has not consented or opted out (False). Mandatory for GDPR and CCPA compliance. Governs eligibility for abandoned cart recovery communications and behavioral targeting.']
  device_type varchar [note: 'Classification of the device category used by the customer to create and interact with this cart. Supports device-level Conversion Rate (CR) analysis, responsive design optimization, and omnichannel customer journey analytics. Derived from user-agent parsing at session creation.']
  discount_amount decimal(18,2) [note: 'Total monetary value of all discounts applied to the cart, including promotional markdowns, coupon redemptions, and loyalty reward deductions. Represents the aggregate reduction from subtotal_amount. Used for promotion effectiveness measurement and markdown analysis per Oracle Retail Price Management (RPM).']
  estimated_shipping_amount decimal(18,2) [note: 'Estimated shipping and handling cost calculated for the cart based on the selected fulfillment type, destination, and applicable shipping promotions. This is an estimate at cart stage; final shipping cost is confirmed at order submission. Relevant for BOPIS and ROPIS carts where this may be zero.']
  estimated_tax_amount decimal(18,2) [note: 'Estimated sales tax calculated on the cart based on the customer\'s shipping destination and applicable tax jurisdiction rules. This is an estimate at cart stage; final tax is confirmed at order submission. Supports pre-checkout transparency requirements per FTC pricing standards.']
  expiry_timestamp timestamp [note: 'The date and time at which this cart is scheduled to expire and be purged from the active cart pool if not converted or explicitly abandoned. Determined by storefront-level cart retention policy configuration. Used for cart lifecycle management, data retention compliance, and inventory reservation release scheduling.']
  fulfillment_type varchar [note: 'The intended fulfillment method selected by the customer for this cart. Values include standard Ship-to-Home, Buy Online Pick Up In Store (BOPIS), Reserve Online Pick Up In Store (ROPIS), Ship-from-Store (SFS), and Drop Ship (vendor direct-to-customer). Drives downstream Order Management System (OMS) routing and Last-Mile Delivery planning.']
  ip_address varchar [note: 'IP address of the customer\'s device at the time of cart creation. Used for geolocation-based tax and shipping estimation, fraud detection, and digital analytics. May be considered PII under GDPR and CCPA in certain jurisdictions. Stored in compliance with data minimization principles.']
  is_abandoned boolean [note: 'Boolean flag indicating whether this cart has been classified as abandoned based on session timeout or inactivity threshold rules. True when cart_status is \'abandoned\'. Drives abandoned cart recovery workflow triggers in the abandoned_cart_recovery product. Supports cart abandonment rate KPI reporting.']
  is_guest_cart boolean [note: 'Indicates whether this cart was created by an unauthenticated guest user (True) or an authenticated registered customer (False). Guest carts have limited personalization and recovery capabilities. Used for guest-to-registered conversion analysis and Customer Acquisition Cost (CAC) attribution.']
  item_count varchar [note: 'Total number of distinct line items (unique Stock Keeping Units / SKUs) currently in the cart. Used in Units Per Transaction (UPT) analysis, basket analysis, and assortment effectiveness reporting. Distinct from total_quantity which counts aggregate units across all line items.']
  last_modified_timestamp timestamp [note: 'The date and time when the cart was most recently updated, including item additions, removals, quantity changes, coupon applications, or address updates. Recorded in ISO 8601 format with timezone offset. Used to determine cart inactivity duration for abandonment classification and session recency analysis.']
  locale_code varchar [note: 'IETF BCP 47 locale code representing the language and regional settings of the storefront session in which this cart was created (e.g., en_US, fr_CA, es_MX). Supports multi-locale storefront operations, localized pricing, and regional promotion targeting.']
  loyalty_points_earned varchar [note: 'Estimated number of loyalty reward points the customer will earn upon successful conversion of this cart to an order. Displayed to the customer during checkout to incentivize purchase completion. Actual points are confirmed and awarded at order fulfillment. Supports loyalty program engagement and abandoned cart recovery messaging.']
  loyalty_points_redeemed varchar [note: 'Number of customer loyalty reward points applied as a discount on this cart. Supports loyalty program redemption tracking, Customer Lifetime Value (CLTV) analysis, and loyalty ROI measurement. Zero if no loyalty points were applied. Integrates with the Customer Loyalty and Engagement Programs business process.']
  recovery_email_sent boolean [note: 'Indicates whether an abandoned cart recovery email has been dispatched to the customer for this cart (True) or not yet sent (False). Prevents duplicate recovery communications and supports recovery campaign performance tracking. Integrates with the abandoned_cart_recovery product for full recovery workflow visibility.']
  saved_for_later_count varchar [note: 'Number of items the customer has moved from the active cart to a \'saved for later\' or wishlist holding area within the same session context. Supports purchase intent analysis, re-engagement campaign targeting, and assortment demand signal capture for merchandise planning.']
  subtotal_amount decimal(18,2) [note: 'Pre-discount, pre-tax gross merchandise value of all items in the cart at their listed retail prices. Represents the sum of (unit price × quantity) for all line items before any promotions, coupons, or markdowns are applied. Used as the base for Average Order Value (AOV) and Gross Merchandise Value (GMV) calculations.']
  total_amount decimal(18,2) [note: 'Estimated grand total for the cart calculated as subtotal_amount minus discount_amount plus estimated_tax_amount plus estimated_shipping_amount. Represents the net amount the customer is expected to pay. Used for Average Order Value (AOV) benchmarking and abandoned cart recovery value prioritization.']
  total_quantity varchar [note: 'Aggregate unit count across all line items in the cart (sum of quantities for all SKUs). Supports Units Per Transaction (UPT) calculation and inventory reservation planning. Differs from item_count which counts distinct SKU lines.']
  utm_campaign varchar [note: 'Urchin Tracking Module (UTM) campaign parameter captured from the URL at cart creation, identifying the specific marketing campaign that drove the customer session (e.g., summer_sale_2024, loyalty_reactivation). Supports campaign-level Conversion Rate (CR), Average Order Value (AOV), and Gross Merchandise Value (GMV) attribution.']
  utm_source varchar [note: 'Urchin Tracking Module (UTM) source parameter captured from the URL at cart creation, identifying the marketing channel or platform that drove the customer to the storefront (e.g., google, facebook, email_newsletter). Supports digital marketing attribution, Customer Acquisition Cost (CAC) analysis, and Return on Investment (ROI) reporting for paid and organic channels.']

  Note: 'Represents a shopping cart instance created during a customer\'s digital session on a storefront. Captures cart creation timestamp, last modified timestamp, cart status (active, abandoned, converted, expired), total item count, subtotal, applied promotion/coupon identifiers, discount amounts, estimated tax, estimated shipping, and the channel/storefront context. Includes digital promotion redemption details: promotion ID, coupon code, discount amount, redemption channel (web, mobile app, email link), redemption status (applied, validated, rejected, reversed), and customer identity reference. SSOT for cart-level data supporting abandoned cart recovery, AOV analysis, and promotion effectiveness measurement within the digital channel. Cart abandonment is determined by timeout or session expiry; recovery workflows are tracked in the abandoned_cart_recovery product.'
}

Table ecommerce.cart_item {
  cart_item_id varchar [pk, note: 'Unique surrogate identifier for each line item within a shopping cart. Primary key for the cart_item data product in the Databricks Silver Layer.']
  cart_id varchar [note: 'Reference to the parent shopping cart that contains this line item. Establishes the header-to-line relationship between the cart session and its individual items.']
  department_id varchar [note: 'Foreign key linking to store.department. Business justification: Department-level cart analytics and promotional eligibility: cart items must reference store department for category-level basket analysis, department-specific promotional rules, and omnichannel categ']
  digital_catalog_id varchar [note: 'Foreign key linking to ecommerce.digital_catalog. Business justification: A cart item is added from a specific digital catalog listing on a storefront. Linking cart_item to digital_catalog (via digital_catalog_id) enables attribution of add-to-cart events to specific catalo']
  location_id varchar [note: 'Reference to the physical store selected for BOPIS or ROPIS fulfillment of this cart line item. Null for ship-to-home or drop-ship items. Supports online-to-offline attribution and store-level demand signal analysis.']
  profile_id varchar [note: 'Reference to the authenticated customer who owns this cart. Null for guest/anonymous sessions. Used for abandoned cart recovery, Customer Lifetime Value (CLTV) analysis, and personalization.']
  promo_campaign_id varchar [note: 'Reference to the item-level promotion applied to this cart line item at the time of add-to-cart. Null if no promotion was applied. Supports Pricing and Promotions Management analytics.']
  promo_offer_id varchar [note: 'Foreign key linking to promotion.promo_offer. Business justification: Line-item offer attribution (BOGO, item-level discounts), offer performance by SKU, and discount breakdown per line item for financial reporting all require linking cart_item to the specific promo_off']
  sku_id varchar [note: 'Reference to the master product record associated with this cart line item. Links to the product catalog managed in the customer master data system and Oracle Retail Merchandising System (ORMS).']
  sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: Cart items resolve pricing at add-to-cart time from sku_price, which provides channel-specific, zone-specific, and promotion-adjusted prices. Core business process: cart pricing resolution and price l']
  stock_position_id varchar [note: 'Foreign key linking to inventory.stock_position. Business justification: Cart items validate real-time inventory availability (ATP, on-hand qty) at specific nodes to prevent overselling during add-to-cart and checkout. Critical for omnichannel inventory visibility and BOPI']
  web_session_id varchar [note: 'The web or app session identifier active when this item was added to the cart. Used for digital customer journey tracking, Click-Through Rate (CTR) attribution, and abandoned cart session-level recovery workflows in the e-commerce platform.']
  add_to_cart_source varchar [note: 'The digital touchpoint or page from which the customer added this item to the cart. Supports Click-Through Rate (CTR) and Conversion Rate (CR) attribution analysis and product recommendation engine performance measurement. [ENUM-REF-CANDIDATE: product_detail_page|search_results|recommendation|wishlist|email_campaign|homepage|category_page|social_media|paid_ad — promote to reference product]']
  add_to_cart_timestamp timestamp [note: 'The date and time when the customer added this item to the shopping cart. Principal business event timestamp for this entity. Used for abandoned cart analysis, session duration analytics, and digital customer journey tracking in the e-commerce platform.']
  created_timestamp timestamp [note: 'The date and time when this cart line item record was first created in the data platform. Serves as the audit creation timestamp for the Silver Layer record. Distinct from add_to_cart_timestamp which captures the business event time.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for all monetary values on this cart line item (e.g., USD, GBP, EUR, CAD). Supports multi-currency e-commerce operations.']
  device_type varchar [note: 'The type of device used by the customer when adding this item to the cart. Supports digital channel analytics, mobile commerce conversion rate (CR) analysis, and omnichannel customer journey attribution.']
  discount_amount decimal(18,4) [note: 'The monetary discount applied to this line item due to promotions, markdowns, or loyalty rewards. Calculated as list_price minus unit_price multiplied by quantity. Supports promotion ROI and markdown analysis.']
  fulfillment_type varchar [note: 'The intended fulfillment method selected by the customer for this cart line item. Supports omnichannel fulfillment analytics including Buy Online Pick Up In Store (BOPIS), Reserve Online Pick Up In Store (ROPIS), Ship-from-Store (SFS), and Drop Ship operations.']
  gift_message varchar [note: 'Optional personalized message entered by the customer for a gift item. Null if is_gift is False or no message was provided. Relevant only when is_gift is True.']
  is_gift boolean [note: 'Indicates whether the customer designated this cart line item as a gift. True if the item is intended as a gift (may include gift wrapping or message); False otherwise. Supports gifting analytics and seasonal demand planning.']
  is_in_stock boolean [note: 'Indicates whether the product was in stock at the time the item was added to the cart. True if inventory was available; False if the item was added as a pre-order or back-order. Supports stockout-driven cart abandonment analysis.']
  is_private_label boolean [note: 'Indicates whether the product is a Private Label (store brand) item. True if the product is a store-owned brand; False if it is a national or third-party brand. Supports private label penetration rate and margin analysis.']
  item_status varchar [note: 'Current lifecycle status of the cart line item. \'active\' indicates the item is in the active cart; \'removed\' indicates the customer explicitly removed it; \'saved_for_later\' indicates the item was moved to a wishlist/save-for-later list; \'purchased\' indicates the item was converted to an order; \'expired\' indicates the cart session expired before checkout.']
  last_modified_timestamp timestamp [note: 'The date and time when this cart line item record was last updated (e.g., quantity change, status change, price update). Used for audit trail, data lineage, and incremental data pipeline processing in the Databricks Silver Layer.']
  line_sequence varchar [note: 'Sequential ordering number of this line item within the parent cart. Used to maintain consistent display order and support basket analysis sequencing.']
  line_subtotal decimal(18,4) [note: 'The total monetary value of this cart line item calculated as unit_price multiplied by quantity before tax. Contributes to Average Order Value (AOV) and Gross Merchandise Value (GMV) calculations at the cart level.']
  loyalty_points_earned varchar [note: 'The number of loyalty program points earned by the customer for purchasing this cart line item. Supports Customer Loyalty and Engagement Program analytics and Customer Lifetime Value (CLTV) calculations.']
  price_override_flag boolean [note: 'Indicates whether the unit price on this cart line item was manually overridden from the standard Oracle Retail Price Management (RPM) price. True if a price override was applied; False otherwise. Supports pricing compliance and audit reporting.']
  promotion_type varchar [note: 'Classification of the promotion applied to this cart line item. Supports promotion effectiveness analysis and Gross Margin Return on Investment (GMROI) reporting. [ENUM-REF-CANDIDATE: percentage_off|fixed_amount_off|buy_x_get_y|free_shipping|bundle|loyalty_reward|clearance_markdown — promote to reference product]']
  purchased_timestamp timestamp [note: 'The date and time when this cart line item was converted to a confirmed order line. Null if the item has not been purchased. Used for cart-to-order conversion rate (CR) analysis and Gross Merchandise Value (GMV) attribution.']
  quantity varchar [note: 'Number of units of the product added to the cart for this line item. Supports Units Per Transaction (UPT) analysis and inventory reservation checks.']
  quantity_available varchar [note: 'The inventory quantity available for the SKU at the time the item was added to the cart. Captured as a snapshot from the inventory system. Supports out-of-stock analysis, abandoned cart attribution to stockouts, and Fill Rate reporting.']
  removal_timestamp timestamp [note: 'The date and time when the customer explicitly removed this item from the cart. Null if the item has not been removed. Used for abandoned cart item-level recovery workflows and assortment affinity analysis.']
  saved_for_later_timestamp timestamp [note: 'The date and time when the customer moved this item from the active cart to the saved-for-later list. Null if the item was never saved. Supports wishlist conversion rate analysis and re-engagement campaign targeting.']
  tax_amount decimal(18,4) [note: 'The calculated tax amount applicable to this cart line item based on the product tax category and customer shipping destination. Supports financial reporting and FASB ASC 606 revenue recognition compliance.']
  tax_rate decimal(8,6) [note: 'The applicable tax rate (as a decimal fraction, e.g., 0.0875 for 8.75%) applied to this cart line item. Varies by product category and jurisdiction. Supports tax compliance reporting and financial reconciliation.']

  Note: 'Line-item level detail within a shopping cart, capturing the SKU/UPC added, quantity, unit price at time of add, any item-level promotion applied, item status (active, removed, saved-for-later), add-to-cart timestamp, and removal timestamp if applicable. Supports basket analysis, assortment affinity, and abandoned cart item-level recovery workflows.'
}

Table ecommerce.checkout {
  checkout_id varchar [pk, note: 'Unique system-generated identifier for a checkout session. Primary key for the checkout data product. Tracks the full funnel progression from cart review through order placement.']
  account_id varchar [note: 'Foreign key linking to customer.account. Business justification: B2B retail checkout must reference the customer account to enforce credit limits, tax-exempt status, contract pricing, and account-level billing. Account-level order reporting and AR reconciliation de']
  cart_id varchar [note: 'Reference to the shopping cart that initiated this checkout session. Links the checkout funnel back to the cart and its line items in the e-commerce domain.']
  fulfillment_node_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_node. Business justification: During checkout, the selected fulfillment method (BOPIS, ship-from-store, home delivery) resolves to a specific fulfillment node. This FK enables accurate delivery promise display at checkout, post-ch']
  header_id varchar [note: 'Reference to the order record created upon successful checkout completion. Null for abandoned or expired checkouts. Represents the handoff boundary between the checkout domain and the order domain. Enables checkout-to-order attribution and funnel completion tracking.']
  location_id varchar [note: 'Reference to the physical store associated with this checkout when the fulfillment mode is Buy Online Pick Up In Store (BOPIS) or Reserve Online Pick Up In Store (ROPIS). Null for ship-to-home and drop-ship fulfillment modes.']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: Checkout price list application is a distinct retail process from price zone (already linked). Loyalty member price lists, B2B negotiated lists, and promotional price lists are applied at checkout to ']
  price_zone_id varchar [note: 'Foreign key linking to pricing.price_zone. Business justification: Checkout must apply zone-specific pricing rules, tax jurisdictions, and fulfillment-based price adjustments from price_zone. Core business process: final order pricing calculation based on customer lo']
  profile_id varchar [note: 'Reference to the authenticated customer who initiated the checkout. Null for guest checkouts. Used for Conversion Rate (CR) funnel analysis segmented by customer cohort and Customer Lifetime Value (CLTV) attribution.']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Checkout captures final promotional context before conversion; essential for last-touch attribution, promotional effectiveness measurement at conversion stage, reconciling promotional discounts with p']
  promo_offer_id varchar [note: 'Foreign key linking to promotion.promo_offer. Business justification: Checkout discount calculation and offer validation require knowing the exact promo_offer applied. Offer-level redemption reporting, discount audit trails, and offer performance analytics (conversion r']
  sfs_fulfillment_node_id varchar [note: 'Foreign key linking to store.sfs_fulfillment_node. Business justification: SFS order fulfillment assignment: at checkout, the specific SFS node is selected to fulfill ship-from-store orders, driving cutoff time enforcement, same-day eligibility confirmation, and carrier rout']
  shipping_address_id varchar [note: 'Foreign key linking to customer.address. Business justification: Captures shipping destination for order fulfillment. Business need: address validation during checkout flow, shipping cost calculation by carrier, tax jurisdiction determination for sales tax complian']
  storefront_id varchar [note: 'Foreign key linking to ecommerce.storefront. Business justification: A checkout session occurs on a specific digital storefront. While the relationship is derivable via checkout.web_session_id → web_session.storefront_id, adding a direct storefront_id FK on checkout en']
  web_session_id varchar [note: 'Unique identifier for the digital browsing session in which this checkout was initiated. Sourced from the e-commerce platform session tracking. Enables online-to-offline attribution and digital customer journey analysis.']
  abandoned_timestamp timestamp [note: 'Date and time when the checkout session was identified as abandoned (customer exited without placing order). Null for completed or in-progress checkouts. Used for abandoned cart recovery campaigns and CR funnel drop-off analysis.']
  abandonment_step varchar [note: 'The checkout funnel step at which the customer abandoned the session. Null for completed checkouts. Identifies the highest-friction point in the checkout funnel for Conversion Rate (CR) optimization and targeted recovery messaging.']
  address_validation_status varchar [note: 'Status of the shipping address validation performed during the address entry checkout step. \'not_validated\' = address entry step not yet reached; \'validated\' = address confirmed by address verification service; \'failed\' = address could not be validated; \'overridden\' = customer proceeded with unvalidated address. Impacts last-mile delivery success rates.']
  channel varchar [note: 'The digital commerce channel through which the checkout was initiated. \'web\' = desktop/mobile web storefront; \'mobile_app\' = native iOS or Android application; \'in_store_kiosk\' = assisted selling kiosk in physical store; \'call_center\' = agent-assisted checkout. Supports omnichannel attribution and channel-level Conversion Rate (CR) reporting.']
  checkout_number varchar [note: 'Human-readable, externally visible reference number for the checkout session. Used in customer communications, customer service case management, and cross-system reconciliation with the e-commerce platform. Format: CHK- followed by 10 digits.']
  checkout_status varchar [note: 'Current lifecycle state of the checkout session. \'initiated\' = checkout started from cart; \'in_progress\' = customer is progressing through funnel steps; \'completed\' = order successfully placed; \'abandoned\' = customer exited without placing order; \'expired\' = session timed out before completion. Core field for Conversion Rate (CR) funnel analysis.']
  completed_timestamp timestamp [note: 'Date and time when the checkout was successfully completed and the order was placed. Null if the checkout was abandoned or expired. Marks the boundary between the checkout domain and the order domain.']
  created_timestamp timestamp [note: 'Date and time when this checkout record was first written to the data platform (Silver Layer). Represents the RECORD_AUDIT_CREATED category for audit trail and data lineage purposes.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for all monetary amounts in this checkout record (e.g., USD, CAD, GBP). Supports multi-currency e-commerce operations and financial reporting normalization.']
  current_step varchar [note: 'The most recent checkout funnel step reached by the customer. Tracks progression through: cart_review → address_entry → shipping_selection → payment_entry → order_review → order_placed. Core field for Conversion Rate (CR) funnel step analysis in the e-commerce platform.']
  device_type varchar [note: 'The type of device used by the customer to initiate and progress through the checkout funnel. \'desktop\' = web browser on desktop/laptop; \'mobile\' = mobile web browser; \'tablet\' = tablet web browser; \'app\' = native mobile application. Enables device-level Conversion Rate (CR) analysis and checkout UX optimization.']
  discount_amount decimal(18,2) [note: 'Total promotional discount applied to this checkout from coupon codes, promotional pricing rules, and loyalty reward redemptions. Excludes gift card and store credit redemptions (tracked separately). Used for promotion effectiveness and markdown analysis.']
  fulfillment_mode varchar [note: 'The selected fulfillment method for this checkout. \'ship_to_home\' = standard home delivery; \'bopis\' = Buy Online Pick Up In Store (BOPIS); \'ropis\' = Reserve Online Pick Up In Store (ROPIS); \'drop_ship\' = vendor ships directly to customer. Drives omnichannel attribution and last-mile delivery cost analysis.']
  gift_card_amount decimal(18,2) [note: 'Total value of gift cards applied as payment during this checkout. Zero if no gift cards were used. Tracked separately from promotional discounts for gift card liability accounting and tender type analysis.']
  initiated_timestamp timestamp [note: 'Date and time when the customer first entered the checkout funnel from the cart. Represents the principal business event timestamp (TRANSACTION_HEADER: BUSINESS_EVENT_TIMESTAMP). Used to measure total checkout duration and time-to-abandon metrics.']
  ip_address varchar [note: 'IP address of the customer\'s device at the time of checkout initiation. Used for fraud detection, geolocation-based tax calculation, and digital analytics. Classified as potentially PII under GDPR and CCPA.']
  is_address_entry_completed boolean [note: 'Indicates whether the customer completed the address entry step of the checkout funnel. True = shipping/billing address entered and validated; False = not yet reached or abandoned at this step.']
  is_cart_review_completed boolean [note: 'Indicates whether the customer completed the cart review step of the checkout funnel. True = step completed and customer advanced; False = step not yet reached or abandoned at this step. Enables granular step-level Conversion Rate (CR) funnel analysis.']
  is_gift_order boolean [note: 'Indicates whether the customer designated this checkout as a gift order. True = gift order with gift messaging and/or gift wrapping selected; False = standard order. Drives gift packaging fulfillment instructions and suppresses price display on packing slips.']
  is_guest_checkout boolean [note: 'Indicates whether this checkout was completed as a guest (without a registered customer account). True = guest checkout; False = authenticated customer checkout. Used to measure guest-to-registered conversion rates and assess the impact of account creation friction on Conversion Rate (CR).']
  is_order_review_completed boolean [note: 'Indicates whether the customer completed the order review step (final summary before placement). True = customer reviewed and confirmed order summary; False = not yet reached or abandoned at this step.']
  is_payment_entry_completed boolean [note: 'Indicates whether the customer completed the payment entry step. True = payment instrument entered and validated; False = not yet reached or abandoned at this step. High abandonment at this step may indicate payment friction or trust issues.']
  is_shipping_selection_completed boolean [note: 'Indicates whether the customer completed the shipping method selection step. True = shipping method selected and confirmed; False = not yet reached or abandoned at this step.']
  loyalty_points_redeemed varchar [note: 'Number of loyalty program points redeemed by the customer during this checkout. Zero if no points were redeemed. Used for loyalty program liability accounting, Customer Lifetime Value (CLTV) analysis, and loyalty engagement reporting.']
  order_total_amount decimal(18,2) [note: 'The final net amount due from the customer after applying subtotal, shipping, tax, discounts, gift cards, and store credits. Represents the actual charge to the customer\'s payment instrument. Core metric for Average Order Value (AOV) and Gross Merchandise Value (GMV) reporting.']
  payment_method varchar [note: 'The primary payment instrument type selected by the customer during checkout. Tracks the tender type for payment mix analysis, fraud risk scoring, and PCI DSS compliance reporting. Split-tender checkouts record the primary instrument. [ENUM-REF-CANDIDATE: credit_card|debit_card|paypal|apple_pay|google_pay|gift_card|store_credit|buy_now_pay_later|bank_transfer — promote to reference product]']
  payment_status varchar [note: 'Status of the payment authorization attempt during checkout. \'pending\' = authorization not yet attempted; \'authorized\' = payment instrument pre-authorized; \'captured\' = funds captured at order placement; \'declined\' = authorization declined by payment processor; \'failed\' = technical failure during authorization. Tracks payment friction in the checkout funnel.']
  shipping_amount decimal(18,2) [note: 'The shipping and handling charge applied to this checkout. Zero for free shipping promotions, BOPIS, and ROPIS fulfillment modes. Contributes to total order value and is tracked separately for shipping revenue and promotion effectiveness analysis.']
  shipping_method_code varchar [note: 'Code identifying the selected shipping method (e.g., STANDARD_5DAY, EXPRESS_2DAY, OVERNIGHT, SAME_DAY). Sourced from the e-commerce platform shipping method catalog. Applicable when fulfillment_mode is \'ship_to_home\' or \'drop_ship\'. Null for BOPIS/ROPIS.']
  shipping_method_name varchar [note: 'Human-readable display name of the selected shipping method as shown to the customer during checkout (e.g., \'Standard Shipping (5-7 Business Days)\', \'Express 2-Day Delivery\'). Preserved for customer-facing reporting and service resolution.']
  store_credit_amount decimal(18,2) [note: 'Total store credit balance applied as payment during this checkout. Zero if no store credit was used. Store credits typically originate from returns, loyalty rewards, or customer service adjustments. Tracked separately for liability accounting.']
  subtotal_amount decimal(18,2) [note: 'The gross merchandise value of all items in the checkout before shipping charges, taxes, discounts, gift card redemptions, and store credit applications. Represents the raw basket value. Used in Average Order Value (AOV) and Gross Merchandise Value (GMV) calculations.']
  tax_amount decimal(18,2) [note: 'Total sales tax calculated and applied during checkout based on the shipping destination and applicable tax jurisdiction rules. Includes state, county, and local taxes. Required for financial reporting and tax compliance under FASB ASC 606.']
  updated_timestamp timestamp [note: 'Date and time when this checkout record was last modified in the data platform. Represents the RECORD_AUDIT_UPDATED category. Updated on each step progression, status change, or field modification.']

  Note: 'Captures the checkout funnel progression for a cart, recording each checkout step reached (cart review, address entry, shipping selection, payment entry, order review, order placed), step timestamps, step completion flags, abandonment step, selected shipping method, selected fulfillment mode (ship-to-home, BOPIS, ROPIS, drop-ship), and applied gift cards or store credits. Enables CR funnel analysis and checkout abandonment identification. Domain boundary: the checkout lifecycle ends at order placement — the order domain owns all post-placement order lifecycle (confirmation, fulfillment tracking, cancellation, modification). Digital return initiation is handed off to the returns domain.'
}

Table ecommerce.digital_payment {
  digital_payment_id varchar [pk, note: 'Unique surrogate identifier for each digital payment transaction record in the e-commerce channel. Primary key for the digital_payment data product.']
  cart_id varchar [note: 'Reference to the shopping cart associated with this payment transaction. Enables abandoned cart recovery analysis and checkout funnel attribution.']
  checkout_id varchar [note: 'Foreign key linking to ecommerce.checkout. Business justification: Payment transactions are processed during checkout sessions. Linking digital_payment to checkout provides complete funnel tracking from cart → checkout → payment. The checkout_id attribute is not curr']
  customer_payment_method_id decimal(18,2) [note: 'Foreign key linking to customer.payment_method. Business justification: Links payment transaction to stored payment instrument. Business need: payment method performance analysis (authorization rates by card type), fraud pattern detection by instrument, PCI compliance aud']
  header_id varchar [note: 'Reference to the e-commerce order for which this digital payment was processed. Links the payment to the originating customer order in the Order Management System (OMS).']
  profile_id varchar [note: 'Reference to the customer who initiated the digital payment transaction. Supports Customer Lifetime Value (CLTV) and RFM (Recency Frequency Monetary) analytics.']
  storefront_id varchar [note: 'Reference to the digital storefront (e.g., desktop web, mobile web, mobile app, marketplace) through which the payment was initiated. Supports omnichannel payment analytics and storefront-level Conversion Rate (CR) reporting.']
  authorization_code varchar [note: 'The alphanumeric authorization code returned by the issuing bank or payment network upon successful authorization of the payment. Required for dispute resolution, chargeback management, and financial reconciliation.']
  authorization_timestamp timestamp [note: 'The timestamp when the payment authorization response was received from the issuing bank or payment network. Distinct from the initiated timestamp; used for authorization latency monitoring and SLA (Service Level Agreement) tracking.']
  avs_result_code varchar [note: 'The Address Verification Service (AVS) result code returned by the issuing bank, indicating whether the billing address provided by the customer matches the address on file. Used for fraud risk assessment and chargeback liability management.']
  billing_country_code varchar [note: 'Three-letter ISO 3166-1 Alpha-3 country code of the customer\'s billing address (e.g., USA, GBR, DEU). Used for fraud geo-risk scoring, tax jurisdiction determination, and international payment compliance.']
  billing_postal_code varchar [note: 'The postal/ZIP code of the customer\'s billing address. Used for Address Verification Service (AVS) fraud checks, tax jurisdiction determination, and geographic sales analytics.']
  capture_timestamp timestamp [note: 'The timestamp when the authorized payment was captured (settled) from the customer\'s account. Marks the point of revenue recognition per FASB ASC 606. Null if payment was not captured (e.g., declined or voided).']
  card_bin varchar [note: 'The Bank Identification Number (BIN), the first 6-8 digits of the payment card number, identifying the issuing bank and card network. Used for fraud analytics, card-type classification, and interchange fee analysis. Not a full PAN — PCI DSS compliant to store.']
  card_expiry_month varchar [note: 'The expiration month of the payment card (1–12). Used in conjunction with card_expiry_year for card validity checks and customer payment method management. PCI DSS permits storage of expiry date.']
  card_expiry_year varchar [note: 'The four-digit expiration year of the payment card. Used in conjunction with card_expiry_month for card validity checks and customer payment method management. PCI DSS permits storage of expiry date.']
  card_last_four varchar [note: 'The last four digits of the payment card number. PCI DSS permits storage of the last four digits for customer service, dispute resolution, and payment method recognition. Not a full PAN.']
  card_network varchar [note: 'The payment card network associated with the transaction (e.g., Visa, Mastercard, Amex, Discover, UnionPay). Used for interchange fee analysis, network-level fraud monitoring, and tender-mix reporting.']
  created_timestamp timestamp [note: 'Timestamp when this digital payment record was first created in the Silver Layer data product. Audit trail field for data lineage and compliance.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the payment transaction (e.g., USD, EUR, GBP). Supports multi-currency e-commerce operations and international financial reporting.']
  cvv_result_code varchar [note: 'The Card Verification Value (CVV/CVC) check result code returned by the issuing bank (M=Match, N=No Match, P=Not Processed, S=Issuer Not Certified, U=Unknown). Used for fraud risk assessment. Note: The actual CVV value is NEVER stored per PCI DSS Requirement 3.2.']
  fraud_score decimal(5,2) [note: 'Numeric fraud risk score assigned by the fraud screening engine, typically on a scale of 0–100 or 0–1000 depending on the provider. Higher scores indicate greater fraud risk. Used for threshold-based decisioning and fraud analytics.']
  fraud_screening_result varchar [note: 'The outcome of the automated fraud screening check applied to the payment transaction by the fraud detection engine (e.g., Adyen RevenueProtect, Stripe Radar). Values: pass (cleared), review (flagged for manual review), reject (blocked). Drives order hold and manual review workflows.']
  gateway_response_code varchar [note: 'The raw response code returned by the payment gateway for the transaction (e.g., \'00\' for approved, \'05\' for declined). Used for decline reason analysis, gateway troubleshooting, and Conversion Rate (CR) optimization.']
  gateway_transaction_reference varchar [note: 'The unique transaction identifier assigned by the payment gateway (Adyen, Stripe, PayPal) for this payment. Used for cross-system reconciliation, dispute management, and gateway-level reporting.']
  initiated_timestamp timestamp [note: 'The real-world timestamp when the customer submitted the payment during online checkout. Principal business event time for the payment transaction. Stored in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).']
  installment_count varchar [note: 'The number of installment payments agreed upon for Buy Now Pay Later (BNPL) transactions. Null or 1 for non-installment payment methods. Supports BNPL provider reconciliation and deferred revenue tracking.']
  is_recurring boolean [note: 'Indicates whether this payment is part of a recurring or subscription billing arrangement (True) or a one-time transaction (False). Relevant for subscription commerce, loyalty auto-renewal, and recurring revenue reporting.']
  is_test_transaction boolean [note: 'Indicates whether this payment record is a test or sandbox transaction (True) rather than a live production transaction (False). Ensures test transactions are excluded from financial reporting, GMV calculations, and fraud analytics.']
  net_amount decimal(18,4) [note: 'The net total amount actually charged to the customer after all adjustments (discounts, promotions, taxes). Represents the final settled monetary value of the transaction. Core field for revenue recognition per FASB ASC 606.']
  payment_amount decimal(18,4) [note: 'The gross base payment amount submitted by the customer before any adjustments. Represents the principal monetary value of the digital payment transaction. Used in Gross Merchandise Value (GMV) and Average Order Value (AOV) calculations.']
  payment_channel varchar [note: 'The digital channel interface through which the payment was submitted (e.g., web, mobile app, mobile web, marketplace, Buy Online Pick Up In Store (BOPIS), Reserve Online Pick Up In Store (ROPIS)). Distinct from payment_method_type. Supports omnichannel attribution and channel-level GMV reporting.']
  payment_gateway varchar [note: 'The third-party payment gateway provider that processed the digital payment transaction (e.g., Adyen, Stripe, PayPal, Braintree, Worldpay). Used for gateway performance monitoring, fee reconciliation, and failover analysis.']
  payment_method_type varchar [note: 'The payment instrument used by the customer for the digital transaction (e.g., credit card, debit card, PayPal, Buy Now Pay Later (BNPL), gift card, store credit, Apple Pay, Google Pay). Drives tender-mix reporting and payment method preference analytics. [ENUM-REF-CANDIDATE: credit_card|debit_card|paypal|bnpl|gift_card|store_credit|apple_pay|google_pay — promote to reference product]']
  payment_status varchar [note: 'Current lifecycle state of the digital payment transaction. Tracks the payment workflow from authorization through capture, decline, void, or refund. Drives order fulfillment gating and financial reconciliation.']
  pci_token varchar [note: 'The PCI DSS-compliant tokenization reference that replaces the actual payment card number (PAN) in storage. Ensures cardholder data is never stored in plain text. Issued by the payment gateway tokenization vault.']
  refund_amount decimal(18,4) [note: 'The monetary amount refunded to the customer for this payment transaction. Supports partial refund scenarios. Null if no refund has been processed. Used in net revenue and Return Merchandise Authorization (RMA) reporting.']
  refund_timestamp timestamp [note: 'The timestamp when a refund or partial refund was initiated for this payment transaction. Null if no refund has been processed. Supports return merchandise authorization (RMA) and customer service workflows.']
  tax_amount decimal(18,4) [note: 'The tax component of the payment transaction, representing sales tax, VAT, or GST applied at checkout. Required for financial reporting and tax compliance.']
  three_ds_status varchar [note: 'The result of the 3D Secure (3DS) strong customer authentication challenge applied during checkout. Indicates whether the cardholder was successfully authenticated by their issuing bank. Drives liability shift determination and chargeback risk management.']
  three_ds_version varchar [note: 'The version of the 3D Secure protocol used during authentication (e.g., 1.0, 2.1, 2.2, 2.3). Relevant for compliance tracking as 3DS 1.0 is deprecated and 3DS 2.x is the current standard.']
  transaction_reference varchar [note: 'Externally-known unique transaction reference number assigned by the payment gateway (e.g., Adyen, Stripe, PayPal) at the time of payment initiation. Used for reconciliation, dispute resolution, and cross-system tracing.']
  updated_timestamp timestamp [note: 'Timestamp when this digital payment record was last modified in the Silver Layer data product. Tracks status changes such as capture, void, or refund events.']
  wallet_provider varchar [note: 'The digital wallet provider used when payment_method_type is a wallet-based instrument (e.g., Apple Pay, Google Pay, Samsung Pay, PayPal). Null for non-wallet payment methods. Supports digital wallet adoption analytics.']

  Note: 'Records digital payment transactions processed during online checkout, including payment method type (credit card, debit card, PayPal, BNPL, gift card, store credit, Apple Pay, Google Pay), payment gateway used (Adyen, Stripe, PayPal), authorization code, transaction reference, payment status (authorized, captured, declined, voided, refunded, partially_refunded), payment amount, currency, fraud screening result (pass, review, reject), 3DS authentication status, and PCI DSS tokenization reference. Distinct from in-store POS payment processing. SSOT for digital payment transaction data within the e-commerce channel.'
}

Table ecommerce.product_review {
  product_review_id varchar [pk, note: 'Unique surrogate identifier for each customer-submitted product review record on the digital storefront. Primary key for the product_review data product.']
  header_id varchar [note: 'Reference to the originating order that included the reviewed SKU. Used to validate verified purchase status and support post-purchase review solicitation workflows.']
  order_line_id varchar [note: 'Foreign key linking to order.order_line. Business justification: Verified purchase review validation: linking reviews to the specific order line (not just header) enables variant/size-specific review authenticity checks, return-correlated review flagging, and line-']
  profile_id varchar [note: 'Reference to the authenticated customer who submitted the review. Null for anonymous or guest reviewers. Used for CRM linkage and CLTV analysis.']
  promo_offer_id varchar [note: 'Foreign key linking to promotion.promo_offer. Business justification: FTC compliance requires tracking which promotional offer incentivized a review (is_incentivized=true). Incentivized review program management, offer-driven review volume reporting, and regulatory audi']
  sku_id varchar [note: 'Reference to the specific SKU (Stock Keeping Unit) being reviewed. Links the review to the product master for quality signal aggregation and assortment analysis.']
  storefront_id varchar [note: 'Reference to the digital storefront or e-commerce site on which the review was submitted. Supports multi-banner and multi-locale storefront segmentation within the e-commerce platform.']
  abuse_report_count varchar [note: 'Number of times shoppers have reported this review as abusive, spam, or inappropriate. Triggers automatic escalation to moderation queue when threshold is exceeded. Supports community trust and safety operations.']
  created_timestamp timestamp [note: 'Date and time when the product_review record was first ingested into the Silver Layer data lakehouse. Audit field for data lineage and pipeline monitoring. Distinct from submission_timestamp which reflects the business event time.']
  data_consent_flag boolean [note: 'Indicates whether the reviewer provided explicit consent for their review content and associated personal data to be processed, stored, and displayed in accordance with GDPR and CCPA requirements at the time of submission.']
  external_review_reference varchar [note: 'The native identifier assigned by the originating review platform or syndication source (e.g., Bazaarvoice review ID, native platform UUID). Enables deduplication and traceability back to the source system.']
  fit_feedback varchar [note: 'Structured fit feedback provided by the reviewer for apparel and footwear SKUs. Values: \'runs_small\', \'true_to_size\', \'runs_large\', \'not_applicable\'. Aggregated to generate size recommendation signals on the PDP and to inform private label product development.']
  has_media boolean [note: 'Boolean flag indicating whether the review includes at least one image or video attachment. Derived from media_attachment_count > 0 but stored explicitly for efficient filtering in storefront display queries and analytics.']
  helpful_vote_count varchar [note: 'Cumulative count of \'helpful\' votes cast by other shoppers on this review. Used to rank and surface the most useful reviews on the product detail page (PDP) and to weight social proof signals.']
  incentive_type varchar [note: 'Type of incentive provided to the reviewer when is_incentivized is true. Populated for FTC disclosure compliance and loyalty program attribution. \'none\' when no incentive was provided.']
  is_deleted boolean [note: 'Soft-delete flag indicating whether the review has been logically removed from active display and analytics. Set to true when a review is withdrawn by the customer (GDPR/CCPA right to erasure request) or permanently removed by moderation. Preserves the record for audit trail purposes.']
  is_incentivized boolean [note: 'Indicates whether the reviewer received an incentive (discount, loyalty points, free product) in exchange for submitting the review. Required for FTC endorsement disclosure compliance. Incentivized reviews must be disclosed on the storefront.']
  is_verified_purchase boolean [note: 'Indicates whether the reviewer has a confirmed purchase of the reviewed SKU on record, as validated against the order management system. Verified reviews carry higher trust weight in social proof algorithms and FTC compliance for endorsements.']
  media_attachment_count varchar [note: 'Number of media files (images or videos) attached to the review by the reviewer. Reviews with media attachments have higher engagement rates and conversion lift. Used to prioritize rich-media reviews for prominent display on the PDP.']
  moderated_by varchar [note: 'Username or system identifier of the moderator (human or automated system) who last updated the moderation status. Supports accountability and audit trail for content governance.']
  moderated_timestamp timestamp [note: 'Date and time when the review moderation decision was last applied. Used for SLA tracking of moderation turnaround and compliance audit trails.']
  moderation_notes varchar [note: 'Free-text notes entered by the content moderator explaining the moderation decision, particularly for flagged or rejected reviews. Supports audit trail and escalation workflows.']
  moderation_rejection_reason varchar [note: 'Categorical reason code assigned when a review is rejected or flagged during content moderation. Supports compliance audit trails and moderator quality reporting. [ENUM-REF-CANDIDATE: spam|profanity|off_topic|fake_review|safety_concern|competitor_mention|other — promote to reference product]']
  moderation_status varchar [note: 'Current workflow state of the review in the content moderation pipeline. \'pending\' = awaiting review; \'approved\' = cleared for public display; \'rejected\' = removed for policy violation; \'flagged\' = escalated for manual review. Controls storefront visibility.']
  product_size_purchased varchar [note: 'Self-reported or order-derived size variant of the SKU purchased by the reviewer (e.g., \'M\', \'32x30\', \'500ml\'). Enables size-specific review filtering on the PDP and informs fit/sizing feedback for assortment planning.']
  published_timestamp timestamp [note: 'Date and time when the review was approved and made publicly visible on the storefront. Distinct from submission_timestamp; the gap between the two measures moderation turnaround time and SLA compliance.']
  purchase_channel varchar [note: 'The fulfillment channel through which the reviewer acquired the product. Values include: \'online\' (standard e-commerce), \'bopis\' (Buy Online Pick Up In Store), \'ropis\' (Reserve Online Pick Up In Store), \'in_store\', \'drop_ship\', \'marketplace\'. Enables channel-specific product quality analysis.']
  review_body varchar [note: 'Full free-text narrative of the customer review. Primary input for NLP-based sentiment analysis, topic modelling, and product quality signal extraction. May be subject to moderation before display.']
  review_language_code varchar [note: 'ISO 639-1 two-letter language code (optionally with ISO 3166-1 country subtag) of the review text, e.g., \'en\', \'fr\', \'es-MX\'. Supports multi-locale storefront display, NLP model routing, and translation workflows.']
  review_title varchar [note: 'Short headline or subject line of the review as entered by the customer. Used for display on the product detail page (PDP) and for text analytics and sentiment classification.']
  reviewer_display_name varchar [note: 'Pseudonymous or chosen display name shown publicly alongside the review on the storefront. May be a username alias rather than a legal name. Classified as confidential PII as it can be linked back to a customer identity.']
  reviewer_expertise_level varchar [note: 'Categorical tier assigned to the reviewer based on their review history, helpfulness votes, and engagement on the platform. Used to weight review credibility in product quality scoring and to surface expert reviews prominently on the PDP.']
  reviewer_location_country_code varchar [note: 'ISO 3166-1 alpha-3 three-letter country code representing the self-reported or inferred country of the reviewer. Used for geo-segmented product quality analysis and regulatory compliance (GDPR for EU reviewers, CCPA for California residents).']
  sentiment_label varchar [note: 'Categorical sentiment classification derived from the sentiment_score: \'positive\', \'neutral\', or \'negative\'. Provides a human-readable bucketing of the ML score for reporting dashboards and product quality KPI tracking.']
  sentiment_score decimal(5,4) [note: 'Machine-learning-derived sentiment polarity score for the review body text, ranging from -1.0000 (most negative) to 1.0000 (most positive). Computed by the NLP enrichment pipeline and stored as a Silver Layer attribute for downstream analytics and AI/ML model features.']
  star_rating boolean [note: 'Numeric star rating submitted by the reviewer on a 1-to-5 scale, where 1 is the lowest satisfaction and 5 is the highest. Core quantitative signal for product quality scoring, NPS-adjacent sentiment tracking, and GMROI analysis.']
  submission_timestamp timestamp [note: 'Date and time when the customer submitted the review on the digital storefront. This is the principal business event timestamp representing when the review was created by the reviewer. Used for recency ranking and post-purchase review solicitation SLA measurement.']
  syndication_partner_review_reference varchar [note: 'The unique review identifier assigned by the third-party syndication partner (e.g., Bazaarvoice, PowerReviews). Populated only when syndication_source is not \'native\'. Enables reconciliation with partner platforms.']
  syndication_source varchar [note: 'Identifies the platform or syndication network from which the review originated. \'native\' = submitted directly on the retailer\'s own storefront; other values indicate third-party review syndication partners. Drives deduplication and source attribution logic.']
  unhelpful_vote_count varchar [note: 'Cumulative count of \'not helpful\' votes cast by other shoppers on this review. Used alongside helpful_vote_count to compute net helpfulness score and filter low-quality reviews from prominent display.']
  updated_timestamp timestamp [note: 'Date and time when the product_review record was last modified in the Silver Layer, including moderation status changes, vote count updates, or syndication enrichments. Supports incremental processing and change data capture.']

  Note: 'Customer-submitted product review and rating record on a digital storefront, capturing the SKU reviewed, star rating (1-5), review title, review body text, reviewer display name, verified purchase flag, submission timestamp, moderation status (pending, approved, rejected, flagged), helpful votes count, and syndication source (native, Bazaarvoice, etc.). Supports social proof, product quality signals, and NPS-adjacent sentiment tracking.'
}

Table ecommerce.marketplace_listing {
  marketplace_listing_id varchar [pk, note: 'Unique surrogate identifier for each marketplace listing record in the Retail data platform. Primary key for the marketplace_listing product. Role: MASTER_RESOURCE.']
  brand_id varchar [note: 'Foreign key linking to product.product_brand. Business justification: Marketplace brand protection, authorized seller verification, and brand-level sell-through reporting require marketplace listings to reference the canonical brand record. brand_name is denormalized. R']
  fulfillment_location_id varchar [note: 'Foreign key linking to store.store_location. Business justification: Marketplace orders fulfilled from stores require tracking which store ships the item. Real business process: marketplace ship-from-store operations, store-level marketplace performance reporting, inve']
  return_policy_id varchar [note: 'Foreign key linking to returns.return_policy. Business justification: Marketplace listings must display and enforce the applicable return policy per listing — a standard retail marketplace compliance requirement. Linking marketplace_listing to return_policy enables per-']
  sku_id varchar [note: 'Reference to the internal SKU (Stock Keeping Unit) that this marketplace listing represents. Links the marketplace listing to Retail\'s internal product master record managed in Oracle Retail Merchandising System (ORMS) and the customer master data system.']
  sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: Marketplace price parity and MAP (minimum advertised price) compliance reporting require linking each marketplace listing to the retailer\'s canonical sku_price. Retail pricing analysts use this to enf']
  stock_position_id varchar [note: 'Foreign key linking to inventory.stock_position. Business justification: Marketplace listings sync real-time inventory quantities from warehouse stock positions to prevent overselling across channels. Enables automated marketplace inventory updates and multi-channel ATP al']
  vendor_contract_id varchar [note: 'Foreign key linking to supplier.vendor_contract. Business justification: Marketplace listings for drop-ship items operate under a specific vendor contract governing pricing, return policy, and compliance terms. Compliance and merchandising teams need this link to enforce c']
  vendor_id varchar [note: 'Foreign key linking to supplier.vendor. Business justification: Marketplace drop-ship and third-party seller models require tracking which vendor fulfills each listing. Business processes: drop-ship order routing to correct vendor, vendor performance scorecarding']
  vendor_item_id varchar [note: 'Foreign key linking to supplier.vendor_item. Business justification: Marketplace drop-ship listing management requires the specific vendor item record for fulfillment cost, pack configuration, and lead time. Operations teams use this link to route marketplace orders to']
  age_restriction_flag boolean [note: 'Indicates whether the product listing has an age restriction (e.g., alcohol, tobacco, adult content, rated video games). True = age-gated product; False = no age restriction. Drives marketplace compliance controls and checkout age verification flows.']
  category_path varchar [note: 'The full hierarchical category path assigned to this listing on the marketplace (e.g., \'Electronics > Computers > Laptops\'). Used for category management, assortment breadth analysis, and marketplace taxonomy alignment. May differ from internal Oracle Retail Merchandising System (ORMS) category hierarchy.']
  competitor_price decimal(18,4) [note: 'The lowest competing seller price observed for this listing on the marketplace at the time of last sync. Used for competitive pricing intelligence, Hi-Lo (High-Low Pricing Strategy) analysis, and automated repricing decisions via Oracle Retail Price Management (RPM). Populated from marketplace API competitive pricing data.']
  content_compliance_flag boolean [note: 'Indicates whether the listing content meets all applicable marketplace content policies and regulatory requirements (e.g., FDA labeling for food/grocery, CPSC safety warnings, FTC advertising standards). True = compliant; False = compliance issue detected requiring remediation.']
  country_code varchar [note: 'ISO 3166-1 alpha-3 country code of the marketplace locale where this listing is published (e.g., USA, GBR, CAN, DEU). Supports international marketplace operations, cross-border compliance, and regional GMV (Gross Merchandise Value) reporting.']
  created_timestamp timestamp [note: 'The timestamp when this marketplace_listing record was first created in the Retail data platform (Silver Layer). Distinct from listed_timestamp which reflects the marketplace publication date. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the marketplace_price (e.g., USD, GBP, EUR, CAD). Required for multi-currency marketplace operations and GMV (Gross Merchandise Value) reporting.']
  ean varchar [note: 'The 13-digit European Article Number (EAN) / GTIN-13 for the listed product. Required for international marketplace listings (e.g., eBay international, Google Shopping). Sourced from the customer master data system product golden record.']
  fulfillment_method varchar [note: 'The fulfillment method used for this marketplace listing. FBM = Fulfilled by Merchant (Retail ships directly); FBA = Fulfilled by Amazon (Amazon warehouses and ships); WFS = Walmart Fulfillment Services; SFS = Ship-from-Store; Dropship = vendor direct-to-customer; 3PL = Third-Party Logistics provider. Drives operational routing in Manhattan Associates WMS and Blue Yonder Demand Planning.']
  hazmat_flag boolean [note: 'Indicates whether the listed product is classified as hazardous material, requiring special handling, packaging, or shipping restrictions on the marketplace. True = hazmat product; False = standard product. Impacts FBA/WFS eligibility and shipping method selection.']
  image_count varchar [note: 'The total number of product images published on this marketplace listing. Contributes to listing_quality_score; marketplaces typically reward listings with multiple high-quality images with improved search placement.']
  inventory_quantity varchar [note: 'The current available inventory quantity published to the marketplace for this listing. Drives out-of-stock status and buy box eligibility. Synchronized from Manhattan Associates WMS or Blue Yonder Demand Planning replenishment signals.']
  is_buy_box_owner boolean [note: 'Indicates whether Retail currently owns the buy box (featured offer) for this marketplace listing. True = Retail is the featured seller; False = a competing seller holds the buy box. Critical KPI for marketplace channel management and competitive pricing strategy. Sourced from marketplace API sync.']
  is_private_label boolean [note: 'Indicates whether this listing is for a private label (store brand) product owned by Retail. True = private label / own-brand product; False = national or third-party brand. Private label listings typically have exclusive buy box ownership and different margin profiles.']
  last_sync_timestamp timestamp [note: 'The timestamp of the most recent successful data synchronization between Retail\'s internal systems (the e-commerce platform / the customer master data system) and the marketplace platform API. Used to detect stale listings and trigger re-sync workflows. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  listed_timestamp timestamp [note: 'The timestamp when this listing was first published or activated on the marketplace platform. RECORD_AUDIT_CREATED equivalent for the MASTER_RESOURCE role. Used for listing age analysis and new product launch tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  listing_quality_score decimal(5,2) [note: 'Marketplace-assigned or internally calculated score (0–100) reflecting the completeness and quality of the listing content (title, images, bullet points, description, A+ content). Higher scores correlate with improved search ranking and conversion rate (CR). Sourced from marketplace API or internal PIM (Product Information Management) audit.']
  listing_status varchar [note: 'Current operational lifecycle status of the marketplace listing. LIFECYCLE_STATUS for the MASTER_RESOURCE role. \'active\' = live and buyable; \'suppressed\' = marketplace has hidden the listing due to content/compliance issues; \'inactive\' = manually deactivated; \'out_of_stock\' = no inventory available; \'pending_review\' = awaiting marketplace approval; \'removed\' = permanently delisted. [ENUM-REF-CANDIDATE: active|suppressed|inactive|out_of_stock|pending_review|removed — promote to reference product]']
  listing_title varchar [note: 'The product title as displayed on the marketplace listing page. This is the IDENTITY_LABEL for the MASTER_RESOURCE role. Optimized per marketplace SEO and content guidelines; may differ from the internal product name in the PIM (Product Information Management) system.']
  listing_url varchar [note: 'The direct URL to the product listing page on the marketplace. Used for competitive monitoring, digital marketing attribution, and customer service reference. Sourced from marketplace API.']
  locale_code varchar [note: 'The IETF BCP 47 locale code for the marketplace listing (e.g., en-US, en-GB, fr-FR, de-DE). Determines language, currency formatting, and regulatory content requirements for the listing. Supports localization compliance for international marketplace operations.']
  main_image_url varchar [note: 'URL of the primary product image displayed on the marketplace listing. Image quality and compliance with marketplace image standards directly impacts listing_quality_score and conversion rate (CR). Managed via PIM (Product Information Management) system.']
  marketplace_item_code varchar [note: 'The platform-native unique identifier assigned by the marketplace to this listing (e.g., Amazon ASIN, eBay Item ID, Walmart Item ID). Used for API synchronization, competitive pricing intelligence, and marketplace-specific operations. This is the BUSINESS_IDENTIFIER for the MASTER_RESOURCE role.']
  marketplace_platform varchar [note: 'The third-party marketplace platform on which this listing is published (e.g., Amazon, eBay, Walmart Marketplace, Google Shopping). Drives channel-specific GMV (Gross Merchandise Value) reporting and marketplace channel management strategy. [ENUM-REF-CANDIDATE: amazon|ebay|walmart_marketplace|google_shopping|target_plus|other — promote to reference product if additional platforms are onboarded]']
  marketplace_price decimal(18,4) [note: 'The current selling price of the product on the marketplace listing, expressed in the listing currency. MEASUREMENT_OR_VALUE for the MASTER_RESOURCE role. Used for competitive pricing intelligence, AUR (Average Unit Retail) tracking, and GMV (Gross Merchandise Value) calculation. Managed via Oracle Retail Price Management (RPM).']
  marketplace_rating decimal(3,2) [note: 'The average customer star rating for this listing on the marketplace (typically 1.0–5.0 scale). Influences buy box eligibility, search ranking, and conversion rate (CR). Sourced from marketplace API.']
  marketplace_seller_code varchar [note: 'Retail\'s seller account identifier on the marketplace platform (e.g., Amazon Merchant ID, Walmart Seller ID). Used to distinguish Retail\'s listings from third-party sellers on the same marketplace and to attribute GMV (Gross Merchandise Value) to the correct seller account.']
  marketplace_storefront_name varchar [note: 'The display name of Retail\'s storefront or seller profile on the marketplace (e.g., \'Retail Official Store\' on Amazon). Used for brand consistency monitoring and customer-facing identity management across marketplace channels.']
  msrp decimal(18,4) [note: 'The manufacturer\'s suggested retail price (MSRP) or list price for the product. Used as the reference price for markdown calculations and marketplace price compliance. Sourced from Oracle Retail Merchandising System (ORMS).']
  prime_eligible_flag boolean [note: 'Indicates whether this listing qualifies for marketplace premium fast-shipping programs (e.g., Amazon Prime, Walmart TwoDay). True = eligible for fast-shipping badge; False = standard shipping only. Directly impacts buy box eligibility and conversion rate (CR).']
  promotion_eligibility_flag boolean [note: 'Indicates whether this marketplace listing is eligible to participate in marketplace-native promotions (e.g., Amazon Lightning Deals, Walmart Rollback). True = eligible; False = ineligible due to price, category, or performance constraints. Supports Pricing and Promotions Management business process.']
  reorder_threshold varchar [note: 'The minimum inventory quantity level at which a replenishment order is triggered for this marketplace listing. Used in conjunction with Blue Yonder Demand Planning to prevent out-of-stock events and maintain listing availability.']
  review_count varchar [note: 'The total number of customer reviews submitted for this listing on the marketplace. Used alongside marketplace_rating to assess listing credibility and conversion rate (CR) performance. Sourced from marketplace API.']
  sell_through_rate decimal(5,4) [note: 'The ratio of units sold to units available for this listing over a rolling period (expressed as a decimal, e.g., 0.75 = 75% sell-through rate). Used for inventory health monitoring, markdown decision support, and dead stock identification. Calculated from SAP Customer Activity Repository (CAR) POS/digital transaction data.']
  shipping_weight_kg decimal(10,4) [note: 'The shipping weight of the product in kilograms as declared on the marketplace listing. Used for marketplace fulfillment fee calculation (FBA, WFS), shipping cost estimation, and hazmat classification. Sourced from the customer master data system product master.']
  suppression_reason varchar [note: 'The reason code or description provided by the marketplace when a listing is suppressed or removed (e.g., \'missing_main_image\', \'price_violation\', \'restricted_product\', \'safety_recall\'). Populated only when listing_status = \'suppressed\' or \'removed\'. Used for remediation workflow management.']
  upc varchar [note: 'The 12-digit Universal Product Code (UPC) associated with this listing. Used by marketplaces for product catalog matching and compliance. Sourced from the customer master data system product golden record.']
  updated_timestamp timestamp [note: 'The timestamp of the most recent update to this marketplace listing record in the Retail data platform (Silver Layer). Tracks content changes, price updates, status transitions, and inventory adjustments. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']

  Note: 'Master record for Retail\'s product listings on third-party marketplaces (Amazon, eBay, Walmart Marketplace, Google Shopping), capturing the marketplace platform, marketplace-specific identifier (ASIN, eBay item ID, Walmart item ID), mapped internal SKU/UPC, listing title, listing status (active, suppressed, inactive, out-of-stock), buy-box ownership flag, marketplace price, marketplace fulfillment method (FBM, FBA, WFS), listing quality score, content compliance flags, and last sync timestamp. Supports marketplace channel management, competitive pricing intelligence, and GMV tracking across third-party channels.'
}

Table ecommerce.promotion_banner {
  promotion_banner_id varchar [pk, note: 'Unique identifier for the promotional banner. Primary key for the promotion banner entity.']
  item_hierarchy_id varchar [note: 'Foreign key linking to product.item_hierarchy. Business justification: Category-level promotional banners (e.g., \'All Electronics 20% off\') are a standard retail ecommerce operation. Linking promotion_banner to item_hierarchy enables category-targeted banner placement, c']
  promo_campaign_id varchar [note: 'Reference to the underlying promotion campaign that this banner represents. Links to the promotion entity.']
  promo_offer_id varchar [note: 'Foreign key linking to promotion.promo_offer. Business justification: A banner promotes a specific offer (e.g., \'20% off shoes\'). Banner-to-offer click-through attribution, A/B testing of offer creative performance, and offer impression/conversion reporting all require ']
  replaced_promotion_banner_id varchar [note: 'Self-referencing FK on promotion_banner (replaced_promotion_banner_id)']
  segment_id varchar [note: 'Foreign key linking to customer.segment. Business justification: Promotion banners are targeted at specific customer segments for personalization and campaign performance reporting. \'target_audience_segment\' is a denormalized text field; replacing it with a proper ']
  storefront_id varchar [note: 'Reference to the digital storefront where this banner is displayed. Links to the storefront entity.']
  ab_test_variant varchar [note: 'Identifier for the A/B test variant or multivariate test cell that this banner belongs to. Used for controlled experimentation and optimization.']
  attributed_revenue decimal(18,2) [note: 'Total revenue in the storefront currency attributed to this banner through click-through and conversion tracking. Used to calculate campaign ROI (Return on Investment) and GMV (Gross Merchandise Value) contribution.']
  banner_description varchar [note: 'Detailed description of the banner content, messaging, and promotional offer for internal reference and content management.']
  banner_name varchar [note: 'Internal name or title of the promotional banner used for identification and campaign management purposes.']
  banner_status varchar [note: 'Current lifecycle state of the promotional banner indicating whether it is being designed, scheduled for future display, actively shown to customers, temporarily paused, past its display window, or archived.']
  banner_title varchar [note: 'Customer-facing headline or title text displayed on the banner creative.']
  banner_type varchar [note: 'Classification of the banner format and display style. Determines rendering behavior and placement rules.']
  call_to_action_text varchar [note: 'Text displayed on the banner button or link that prompts user interaction (e.g., Shop Now, Learn More, Get Offer).']
  click_count varchar [note: 'Total number of times visitors have clicked on the banner. Used to calculate CTR (Click-Through Rate) and engagement metrics.']
  click_through_url varchar [note: 'Destination URL where users are directed when they click on the banner. Typically links to a product detail page, category page, or promotional landing page.']
  conversion_count varchar [note: 'Total number of conversions (orders placed) attributed to this banner through click-through attribution. Used to calculate CR (Conversion Rate) and campaign ROI (Return on Investment).']
  created_timestamp timestamp [note: 'Date and time when the banner record was first created in the system. Audit trail for content lifecycle management.']
  creative_asset_url varchar [note: 'Fully qualified URL or path to the banner image or video creative asset stored in the content delivery network or digital asset management system.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for attributed revenue and financial metrics associated with this banner.']
  device_targeting varchar [note: 'Device type targeting rule that determines which device classes should display this banner for responsive and device-optimized campaigns.']
  display_priority varchar [note: 'Numeric ranking that determines the order in which banners are displayed when multiple banners compete for the same placement zone. Lower numbers indicate higher priority.']
  end_date date [note: 'Date when the banner is no longer eligible for display on the storefront. Defines the end of the scheduled display window.']
  end_timestamp timestamp [note: 'Precise date and time when the banner is no longer eligible for display, supporting time-of-day targeting and flash sale campaigns.']
  geo_targeting_country_code varchar [note: 'ISO 3166-1 alpha-3 country code(s) for geographic targeting. Restricts banner display to visitors from specific countries. Pipe-separated for multiple countries.']
  impression_count varchar [note: 'Total number of times the banner has been displayed to visitors. Used to calculate CTR (Click-Through Rate) and campaign reach metrics.']
  is_personalized boolean [note: 'Flag indicating whether this banner is dynamically personalized using AI/ML algorithms based on customer behavior, preferences, or segment membership.']
  locale_code varchar [note: 'Language and regional locale code (e.g., en_US, fr_CA) for which this banner content is localized. Supports multi-language storefronts.']
  mobile_asset_url varchar [note: 'Fully qualified URL or path to the mobile-optimized version of the banner creative asset for responsive design and mobile-first experiences.']
  placement_zone varchar [note: 'Designated area or slot on the storefront where the banner is displayed (e.g., homepage-hero, category-top, checkout-sidebar). Defines the physical location within the page layout.']
  source_system_code varchar [note: 'Code identifying the operational system of record that originated this banner data (e.g., SFCC for the e-commerce platform, CMS for Content Management System).']
  start_date date [note: 'Date when the banner becomes eligible for display on the storefront. Part of the scheduled display window.']
  start_timestamp timestamp [note: 'Precise date and time when the banner becomes eligible for display, supporting time-of-day targeting and flash sale campaigns.']
  updated_by varchar [note: 'User identifier or system account that last modified the banner record. Supports audit trail and content governance requirements.']
  updated_timestamp timestamp [note: 'Date and time when the banner record was last modified. Audit trail for content lifecycle management and change tracking.']
  created_by varchar [note: 'User identifier or system account that created the banner record. Supports audit trail and content governance requirements.']

  Note: 'Manages promotional banners and hero images displayed on digital storefronts. Captures banner name, placement zone, creative asset reference, click-through URL, display schedule, and impression/click metrics.'
}

Table fulfillment.fulfillment_order {
  fulfillment_order_id varchar [pk, note: 'Unique identifier for the fulfillment order. Primary key for this entity.']
  carrier_id varchar [note: 'Reference to the third-party logistics provider or carrier assigned to deliver this fulfillment order.']
  carrier_service_id varchar [note: 'Foreign key linking to fulfillment.carrier_service. Business justification: fulfillment_order has carrier_id FK and denormalized carrier_service_level column, but no FK to carrier_service. Business reality: a fulfillment order is assigned a specific carrier service for shipme']
  fulfillment_node_id varchar [note: 'Identifier of the inventory node (store, dark store, distribution center, or warehouse) assigned to fulfill this order.']
  location_id varchar [note: 'Reference to the retail store location when fulfillment method is ship-from-store, BOPIS, or ROPIS.']
  order_fulfillment_customer_profile_id varchar [note: 'Customer who placed the order']
  order_fulfillment_header_id varchar [note: 'Reference to the originating customer order that spawned this fulfillment work order. Links back to the order domain.']
  order_fulfillment_profile_id varchar [note: 'Reference to the customer who placed the originating order. Required for customer communication and service.']
  outbound_order_id varchar [note: 'Foreign key linking to supplychain.outbound_order. Business justification: Store replenishment orders fulfilled from DC create both outbound_order (DC perspective) and fulfillment_order (execution). Links DC dispatch to fulfillment execution for ship-to-store scenarios, enab']
  pickup_pos_transaction_id varchar [note: 'Foreign key linking to order.pos_transaction. Business justification: BOPIS pickup completion tracking: when a customer collects a BOPIS order, the POS transaction records the sale/tender event. Linking fulfillment_order to the completing POS transaction enables BOPIS c']
  primary_fulfillment_order_header_id varchar [note: 'Reference to the originating order header']
  shipping_address_id varchar [note: 'Reference to the customer address where this fulfillment order will be delivered. Not applicable for BOPIS/ROPIS orders.']
  sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: Fulfillment orders require actual selling price for shipment value declaration, insurance coverage calculation, customs documentation, and financial reconciliation. Links fulfillment execution to the ']
  subscription_id varchar [note: 'Foreign key linking to order.subscription. Business justification: Subscription fulfillment tracking: subscription programs generate recurring fulfillment orders. Linking fulfillment_order to subscription enables delivery history per subscription, skip/pause impact a']
  actual_fulfillment_hours decimal(10,2) [note: 'The actual elapsed time in hours from fulfillment order creation to completion. Used for performance measurement against SLA.']
  cancellation_reason varchar [note: 'Free-text explanation of why this fulfillment order was cancelled, if applicable. Used for root cause analysis.']
  completed_timestamp timestamp [note: 'Timestamp when the fulfillment order reached final completion state (delivered or picked up by customer).']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts in this fulfillment order.']
  fulfillment_assigned_timestamp timestamp [note: 'Timestamp when the fulfillment order was assigned to a specific fulfillment node and became actionable.']
  fulfillment_created_timestamp timestamp [note: 'Timestamp when this fulfillment order record was created in the system. Marks the start of fulfillment processing.']
  fulfillment_method varchar [note: 'The operational fulfillment strategy used to complete this order. BOPIS = Buy Online Pick Up In Store, ROPIS = Reserve Online Pick Up In Store.']
  fulfillment_order_number varchar [note: 'Human-readable business identifier for the fulfillment order, used for tracking and communication across systems and with partners.']
  fulfillment_status varchar [note: 'Current lifecycle state of the fulfillment order in the pick-pack-ship workflow. [ENUM-REF-CANDIDATE: created|assigned|picking|picked|packing|packed|shipped|ready_for_pickup|completed|cancelled — 10 candidates stripped; promote to reference product]']
  gift_message varchar [note: 'Customer-provided gift message to be included with the shipment, if this is a gift order.']
  is_gift boolean [note: 'Indicates whether this fulfillment order is a gift, requiring special packaging and excluding pricing information from packing slip.']
  last_modified_timestamp timestamp [note: 'Timestamp of the most recent update to this fulfillment order record. Used for change tracking and audit trails.']
  order_date timestamp [note: 'Timestamp when the customer placed the originating order. Used for SLA calculation and aging analysis.']
  package_count varchar [note: 'Number of physical packages or parcels created for this fulfillment order. Orders may be split across multiple packages.']
  packing_completed_timestamp timestamp [note: 'Timestamp when the fulfillment order was packed and ready for shipment or pickup.']
  packing_slip_url varchar [note: 'URL to the packing slip document that accompanies the shipment, listing order contents.']
  picking_completed_timestamp timestamp [note: 'Timestamp when all items in the fulfillment order were successfully picked from inventory.']
  picking_started_timestamp timestamp [note: 'Timestamp when the picking process began for this fulfillment order.']
  pickup_location_code varchar [note: 'Designated area or counter code within the store where BOPIS/ROPIS orders are staged for customer pickup.']
  priority_level varchar [note: 'Processing priority assigned to this fulfillment order based on customer tier, service level, or business rules.']
  promised_delivery_date date [note: 'The date communicated to the customer as the expected delivery or pickup availability date. Used for SLA tracking.']
  shipped_timestamp timestamp [note: 'Timestamp when the fulfillment order was handed off to the carrier for delivery.']
  shipping_cost_amount decimal(15,2) [note: 'Actual cost incurred for carrier services to ship this fulfillment order. Used for profitability analysis and cost allocation.']
  shipping_label_url varchar [note: 'URL to the generated shipping label document for this fulfillment order, used by warehouse staff for package labeling.']
  sla_target_hours varchar [note: 'The number of hours from order creation to promised delivery, representing the committed service level for this fulfillment method.']
  special_handling_instructions varchar [note: 'Additional instructions for fulfillment staff regarding fragile items, gift wrapping, temperature control, or other special requirements.']
  total_item_quantity varchar [note: 'Total number of individual units across all line items in this fulfillment order. Used for capacity planning and picker productivity.']
  total_line_count varchar [note: 'Number of distinct SKU line items in this fulfillment order. Impacts picking complexity and time.']
  total_volume_cubic_meters decimal(10,3) [note: 'Total volumetric size of the fulfillment order in cubic meters, used for transportation planning and dimensional weight pricing.']
  total_weight_kg decimal(10,3) [note: 'Total weight of the fulfillment order in kilograms, used for carrier selection, shipping cost calculation, and capacity planning.']
  tracking_number varchar [note: 'The carrier-provided tracking identifier used by customers and operations to monitor shipment progress.']

  Note: 'Core operational record representing a fulfillment work order created from a customer order. Tracks the end-to-end execution of picking, packing, and shipping activities for a single order or order subset. Captures fulfillment method (ship-from-store, dark store, DC, BOPIS, ROPIS, drop-ship), assigned fulfillment node, SLA commitment, promised delivery date, current fulfillment status, and carrier assignment. This is the primary entity in the fulfillment domain and the operational counterpart to the order domain\'s order record.'
}

Table fulfillment.fulfillment_line {
  fulfillment_line_id varchar [pk, note: 'Unique identifier for the fulfillment line item. Primary key for this entity.']
  fulfillment_node_id varchar [note: 'Identifier of the specific fulfillment location (DC number, store number, vendor ID, etc.). Links to the physical location that executed fulfillment.']
  gtin_registry_id varchar [note: 'Foreign key linking to product.gtin_registry. Business justification: Scan-based fulfillment workflows scan GTIN barcodes during pick/pack; resolving to gtin_registry enables GS1 compliance validation, variable-measure item handling, and packaging-level verification. Re']
  item_variant_id varchar [note: 'Foreign key linking to product.item_variant. Business justification: Retail substitution audit process: when substitution_flag is set on a fulfillment_line, the authorized item_variant record must be traceable for customer consent verification, substitution_priority co']
  lot_id varchar [note: 'Foreign key linking to inventory.lot. Business justification: Lot-tracked fulfillment (perishables, pharmaceuticals, regulated goods) requires FEFO compliance and recall traceability at the pick line level. Linking fulfillment_line to lot enables regulatory audi']
  order_id varchar [note: 'Reference to the parent fulfillment order header. Links this line to the overall fulfillment order.']
  order_line_id varchar [note: 'Reference to the original sales order line that this fulfillment line is satisfying. Links fulfillment execution back to customer order.']
  outbound_order_line_id varchar [note: 'Foreign key linking to supplychain.outbound_order_line. Business justification: Line-level linkage for DC-to-store replenishment. Each fulfillment_line executing store replenishment corresponds to outbound_order_line in DC system. Critical for SKU-level reconciliation and invento']
  shipment_package_id varchar [note: 'Foreign key linking to fulfillment.shipment_package. Business justification: A fulfillment_line represents a specific SKU quantity being picked, packed, and shipped. Each fulfillment_line is packed into a specific shipment_package (carton/box). Adding shipment_package_id to fu']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Fulfillment lines must reference the product SKU being fulfilled. The product_name column becomes redundant as it can be joined from product.sku. This links fulfillment execution to the product catalo']
  sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: Retail margin reporting and returns processing require each fulfillment line to reference the exact sku_price record active at fulfillment time. Enables price verification, margin-by-line analytics, a']
  stock_position_id varchar [note: 'Foreign key linking to inventory.stock_position. Business justification: Post-fulfillment inventory reconciliation and shrinkage reporting require linking each pick line to the specific stock position it drew from. WMS systems universally track this for ATP accuracy, cycle']
  vendor_item_id varchar [note: 'Foreign key linking to supplier.vendor_item. Business justification: Fulfillment costing and allocation decisions require vendor item master data for cost, pack configuration, and vendor-specific attributes. Real-world WMS systems query vendor_item during order fulfill']
  created_timestamp timestamp [note: 'Date and time when this fulfillment line record was first created in the system. Audit trail for record creation.']
  exception_code varchar [note: 'Code identifying any exception or issue encountered during fulfillment of this line (stockout, damage, mispick, etc.). Null if no exception occurred.']
  exception_description varchar [note: 'Detailed description of the fulfillment exception or issue. Provides context for exception resolution and process improvement.']
  expiry_date date [note: 'Expiration date of the picked inventory. Critical for perishable goods, food safety, and FEFO (First Expired First Out) fulfillment strategies.']
  extended_cost decimal(15,2) [note: 'Total cost for this line (unit cost × quantity shipped). Represents total COGS for the fulfilled quantity.']
  fulfillment_source_type varchar [note: 'Type of fulfillment location from which this line was fulfilled (distribution center, store, dark store, vendor direct, third-party logistics). Enables omnichannel fulfillment analysis.']
  line_number varchar [note: 'Sequential line number within the fulfillment order. Used for ordering and referencing specific line items.']
  line_status varchar [note: 'Current fulfillment status of this line item. Tracks progression through the fulfillment workflow from allocation to shipment. [ENUM-REF-CANDIDATE: pending|allocated|picked|packed|shipped|cancelled|exception — 7 candidates stripped; promote to reference product]']
  modified_timestamp timestamp [note: 'Date and time when this fulfillment line record was last updated. Audit trail for record changes.']
  original_sku varchar [note: 'The originally ordered SKU if this line is a substitution. Null if no substitution occurred. Enables tracking of substitution patterns and customer acceptance.']
  pack_timestamp timestamp [note: 'Date and time when this line was packed into a shipping container. Used for throughput analysis and bottleneck identification.']
  pick_location varchar [note: 'The warehouse location (aisle, bin, shelf) from which this item was picked. Used for inventory tracking and pick path optimization.']
  pick_timestamp timestamp [note: 'Date and time when this line was physically picked from inventory. Critical for cycle time analysis and SLA tracking.']
  quantity_allocated decimal(12,3) [note: 'The quantity of inventory allocated or reserved for this fulfillment line. Represents inventory commitment before physical picking.']
  quantity_cancelled decimal(12,3) [note: 'The quantity cancelled and not fulfilled for this line. Represents unfulfilled demand due to stockouts, customer cancellation, or other exceptions.']
  quantity_ordered decimal(12,3) [note: 'The quantity of this item originally requested in the order. Represents the customer demand that fulfillment is attempting to satisfy.']
  quantity_packed decimal(12,3) [note: 'The quantity successfully packed into shipping containers for this line. Represents items ready for shipment.']
  quantity_picked decimal(12,3) [note: 'The actual quantity physically picked from inventory for this line. May differ from ordered quantity due to stockouts or picking errors.']
  quantity_shipped decimal(12,3) [note: 'The quantity actually shipped to the customer for this line. Final fulfilled quantity that left the facility.']
  serial_number varchar [note: 'Unique serial number of the individual item picked, if serialized inventory. Enables item-level tracking for high-value or regulated products.']
  ship_timestamp timestamp [note: 'Date and time when this line was shipped from the facility. Marks completion of fulfillment execution and start of delivery.']
  sku varchar [note: 'Stock Keeping Unit identifier for the product being fulfilled. The internal product identifier used for inventory tracking and fulfillment operations.']
  substitution_flag boolean [note: 'Indicates whether this line represents a product substitution (true) or the originally ordered item (false). Used to track when alternative products are fulfilled.']
  substitution_reason_code varchar [note: 'Reason code explaining why a substitution was made. Used for root cause analysis and inventory planning.']
  unit_cost decimal(15,4) [note: 'Cost of Goods Sold (COGS) per unit for this item. Used for inventory valuation and profitability analysis.']
  unit_of_measure varchar [note: 'The unit of measure for all quantities on this line (each, case, pallet, etc.). Defines how quantities are counted and tracked.']
  upc varchar [note: 'Universal Product Code barcode identifier. Standard 12-digit product identifier used for scanning and product identification.']
  weight decimal(10,3) [note: 'Total weight of the picked quantity for this line. Used for shipping cost calculation and carrier selection.']
  weight_unit varchar [note: 'Unit of measure for the weight field (pounds, kilograms, etc.). Standardizes weight reporting across fulfillment operations.']

  Note: '[References SSOT: order.order_line] Fulfillment execution line tracking pick, pack, and ship progress. References order.order_line as the authoritative commercial line record. Tracks physical fulfillment state and warehouse operations.'
}

Table fulfillment.shipment {
  shipment_id varchar [pk, note: 'Primary key for shipment']
  carrier_id varchar [note: 'Foreign key linking to fulfillment.carrier. Business justification: shipment has denormalized carrier_code and carrier_name columns but no FK to carrier master. Adding carrier_id FK allows joining to carrier for full carrier details (contact info, capabilities, contra']
  carrier_service_id varchar [note: 'Foreign key linking to fulfillment.carrier_service. Business justification: shipment has denormalized service_level column but no FK to carrier_service (in addition to the carrier_id FK proposed above). Business reality: a shipment is dispatched using a specific carrier servi']
  fulfillment_node_id varchar [note: 'Reference to the fulfillment node (distribution center, store, dark store, or micro-fulfillment center) from which the shipment originated.']
  header_id varchar [note: 'Reference to the parent order that this shipment fulfills. Links shipment to the originating customer order.']
  order_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_order. Business justification: shipment is the physical dispatch output of a fulfillment_order (the operational work order). Currently shipment only links to order_header, missing the operational lineage. Adding fulfillment_order_i']
  origin_location_id varchar [note: 'Foreign key linking to store.location. Business justification: Ship-from-store shipments must be attributed to the originating store location for carrier billing reconciliation, store-level shipping cost reporting, and SLA compliance tracking. shipment.ship_from_']
  outbound_order_id varchar [note: 'Foreign key linking to supplychain.outbound_order. Business justification: DC-to-store replenishment shipments must be traceable to the originating outbound order for carrier billing reconciliation, SLA compliance reporting, and supply chain execution dashboards. A retail DC']
  profile_id varchar [note: 'Reference to the customer receiving the shipment. Primary party reference for the transaction.']
  shipping_address_id varchar [note: 'Foreign key linking to customer.address. Business justification: Delivery performance analysis by customer address, address-level exception reporting, and returns routing all require linking shipments to the canonical customer address record. Retail operations team']
  actual_delivery_date date [note: 'Actual date when the shipment was successfully delivered to the recipient. Used for on-time delivery performance measurement.']
  carrier_charge_amount decimal(12,2) [note: 'Actual cost charged by the carrier for transporting this shipment. Used for freight cost accounting and margin analysis.']
  carrier_charge_currency_code varchar [note: 'Three-letter ISO currency code for the carrier charge amount (e.g., USD, CAD, EUR).']
  created_timestamp timestamp [note: 'Timestamp when the shipment record was first created in the system. Audit field for record lifecycle tracking.']
  declared_value_amount decimal(15,2) [note: 'Declared monetary value of the shipment contents for insurance and customs purposes. Used to determine carrier liability limits.']
  declared_value_currency_code varchar [note: 'Three-letter ISO currency code for the declared value amount (e.g., USD, CAD, EUR).']
  delivery_instructions varchar [note: 'Special instructions provided by the customer for delivery handling (e.g., leave at door, ring bell, gate code). Passed to carrier for execution.']
  delivery_signature_required_flag boolean [note: 'Indicates whether a recipient signature is required upon delivery for proof of receipt. True if signature required, false otherwise.']
  estimated_delivery_date date [note: 'Carrier-provided or system-calculated expected delivery date communicated to the customer. Used for Service Level Agreement (SLA) tracking.']
  fulfillment_type varchar [note: 'Classification of the fulfillment method used for this shipment. Distinguishes between standard shipping, Buy Online Pick Up In Store (BOPIS), Reserve Online Pick Up In Store (ROPIS), ship-from-store, drop-ship, and curbside pickup.']
  hazmat_flag boolean [note: 'Indicates whether the shipment contains hazardous materials requiring special handling and documentation. True if hazmat, false otherwise.']
  height_cm decimal(8,2) [note: 'Shortest dimension of the shipment in centimeters. Used for carrier rating and dimensional weight calculations.']
  last_updated_timestamp timestamp [note: 'Timestamp when the shipment record was most recently modified. Audit field for change tracking and data freshness monitoring.']
  length_cm decimal(8,2) [note: 'Longest dimension of the shipment in centimeters. Used for carrier rating and dimensional weight calculations.']
  package_count varchar [note: 'Total number of physical packages or parcels included in this shipment. Supports multi-package shipment tracking.']
  ship_date date [note: 'Date when the shipment was physically dispatched from the fulfillment node. Key business event timestamp for fulfillment cycle time measurement.']
  ship_from_location_type varchar [note: 'Classification of the originating fulfillment location type. Supports omnichannel fulfillment analytics including ship-from-store (SFS) and dark store operations.']
  ship_to_contact_name varchar [note: 'Name of the recipient or contact person at the delivery destination. Used for delivery confirmation and communication.']
  ship_to_email_address varchar [note: 'Email address for shipment tracking notifications and delivery updates sent to the recipient.']
  ship_to_phone_number varchar [note: 'Contact phone number for the shipment recipient. Used by carriers for delivery coordination and customer notifications.']
  shipment_number varchar [note: 'Externally visible unique shipment identifier used for customer tracking and carrier communication. Business identifier for the shipment.']
  shipment_status varchar [note: 'Current lifecycle status of the shipment in the fulfillment workflow. Tracks progression from creation through final delivery or return. [ENUM-REF-CANDIDATE: created|picked|packed|manifested|in_transit|out_for_delivery|delivered|failed_delivery|returned|cancelled — 10 candidates stripped; promote to reference product]']
  shipping_cost_amount decimal(12,2) [note: 'Total cost charged to the customer for shipping this shipment. Includes base shipping rate and any surcharges.']
  shipping_cost_currency_code varchar [note: 'Three-letter ISO currency code for the shipping cost amount (e.g., USD, CAD, EUR).']
  signature_name varchar [note: 'Name of the person who signed for the shipment upon delivery. Captured for proof of delivery and dispute resolution.']
  total_volume_cubic_meters decimal(10,4) [note: 'Total volumetric measurement of the shipment in cubic meters. Used for dimensional weight pricing and transportation planning.']
  total_weight_kg decimal(10,3) [note: 'Total weight of the shipment in kilograms, including all packages and packaging materials. Used for carrier billing and capacity planning.']
  tracking_number varchar [note: 'Carrier-assigned unique tracking identifier used for shipment visibility and proof of delivery. Enables customer and internal tracking through carrier systems.']
  width_cm decimal(8,2) [note: 'Middle dimension of the shipment in centimeters. Used for carrier rating and dimensional weight calculations.']

  Note: 'Master record for a physical shipment dispatched to a customer or transfer destination. Captures carrier, tracking number, ship date, estimated delivery date, actual delivery date, shipment weight, dimensions, number of packages, ship-from node, ship-to address, service level (ground, 2-day, overnight), and shipment status. Serves as the SSOT for all outbound shipment tracking across channels including e-commerce, BOPIS, and store-to-door.'
}

Table fulfillment.shipment_package {
  shipment_package_id varchar [pk, note: 'Unique identifier for the shipment package. Primary key.']
  carrier_id varchar [note: 'Reference to the carrier (third-party logistics provider) responsible for transporting this package.']
  carrier_service_id varchar [note: 'Foreign key linking to fulfillment.carrier_service. Business justification: shipment_package has carrier_id FK and denormalized carrier_service_level column, but no FK to carrier_service. Business reality: each package is shipped using a specific carrier service offering. Add']
  fulfillment_node_id varchar [note: 'Reference to the fulfillment location (distribution center, store, dark store, or micro-fulfillment center) where this package was prepared.']
  header_id varchar [note: 'Reference to the customer order being fulfilled by this package.']
  shipment_id varchar [note: 'Reference to the parent shipment that contains this package. A single shipment may contain multiple packages.']
  actual_delivery_timestamp timestamp [note: 'Date and time when the package was actually delivered to the customer, confirming successful fulfillment.']
  billable_weight_kg decimal(10,3) [note: 'The greater of actual weight or dimensional weight, used as the basis for carrier shipping charges.']
  contents_summary varchar [note: 'High-level description of package contents, often used for customs declarations or customer communication (e.g., \'Apparel and Electronics\').']
  created_timestamp timestamp [note: 'Date and time when this package record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts in this record.']
  delivery_confirmation_method varchar [note: 'Method used to confirm successful delivery of the package (e.g., signature, photo proof, GPS coordinates, contactless delivery). [ENUM-REF-CANDIDATE: signature|photo|gps|contactless|left_at_door|handed_to_resident|locker — 7 candidates stripped; promote to reference product]']
  delivery_notes varchar [note: 'Free-text notes from the carrier or driver regarding delivery (e.g., \'Left at front door\', \'Delivered to neighbor\').']
  dimensional_weight_kg decimal(10,3) [note: 'Calculated dimensional weight based on package volume, used by carriers for rating when dimensional weight exceeds actual weight.']
  estimated_delivery_date date [note: 'Carrier-provided estimated date when the package will be delivered to the customer.']
  height_cm decimal(10,2) [note: 'Height dimension of the package in centimeters, used for carrier rating and capacity planning.']
  insurance_value_amount decimal(15,2) [note: 'Declared value of the package contents for insurance purposes.']
  is_hazmat boolean [note: 'Indicates whether the package contains hazardous materials requiring special handling and labeling per regulatory requirements.']
  is_insured boolean [note: 'Indicates whether the package has been insured for loss or damage during transit.']
  is_label_printed boolean [note: 'Indicates whether the shipping label has been printed for this package.']
  is_manifested boolean [note: 'Indicates whether the package has been included in a carrier manifest and is ready for pickup.']
  is_sealed boolean [note: 'Indicates whether the package has been sealed and is ready for shipment.']
  is_signature_required boolean [note: 'Indicates whether a signature is required upon delivery for this package.']
  item_count varchar [note: 'Total number of individual items (SKUs) contained in this package.']
  labeled_timestamp timestamp [note: 'Date and time when the shipping label was printed and affixed to the package.']
  length_cm decimal(10,2) [note: 'Length dimension of the package in centimeters, used for carrier rating and capacity planning.']
  manifested_timestamp timestamp [note: 'Date and time when the package was included in the carrier manifest, indicating readiness for carrier pickup.']
  package_number varchar [note: 'Human-readable business identifier for the package, often printed on the label. May follow internal numbering conventions.']
  package_sequence varchar [note: 'Sequential position of this package within the parent shipment (e.g., package 1 of 3).']
  package_status varchar [note: 'Current lifecycle status of the package in the fulfillment and delivery process. [ENUM-REF-CANDIDATE: created|packed|sealed|labeled|manifested|picked_up|in_transit|out_for_delivery|delivered|exception|returned — 11 candidates stripped; promote to reference product]']
  package_type varchar [note: 'Type of packaging container used for this package.']
  packed_timestamp timestamp [note: 'Date and time when the package was packed and sealed, marking readiness for shipment.']
  picked_up_timestamp timestamp [note: 'Date and time when the carrier physically picked up the package from the fulfillment location.']
  shipping_cost_amount decimal(15,2) [note: 'Actual shipping cost charged by the carrier for this package.']
  shipping_method varchar [note: 'Fulfillment method used for this package (e.g., Ship-from-Store (SFS), Distribution Center (DC) fulfillment, Buy Online Pick Up In Store (BOPIS), Reserve Online Pick Up In Store (ROPIS), drop ship). [ENUM-REF-CANDIDATE: ship_from_store|dc_fulfillment|drop_ship|bopis|ropis|curbside|locker — 7 candidates stripped; promote to reference product]']
  total_packages_in_shipment varchar [note: 'Total number of packages in the parent shipment, providing context for the package sequence.']
  tracking_number varchar [note: 'Carrier-assigned tracking barcode or number used for end-to-end package visibility and customer tracking.']
  unit_count varchar [note: 'Total quantity of units across all items in the package (sum of quantities for all SKUs).']
  updated_timestamp timestamp [note: 'Date and time when this package record was last modified.']
  weight_kg decimal(10,3) [note: 'Actual weight of the package in kilograms, including contents and packaging materials. Used for carrier rating and shipping cost calculation.']
  width_cm decimal(10,2) [note: 'Width dimension of the package in centimeters, used for carrier rating and capacity planning.']

  Note: 'Represents an individual physical package or carton within a shipment. Tracks package dimensions, weight, package type (box, poly bag, envelope), seal status, label printed flag, tracking barcode, contents summary, and package-level delivery confirmation. A single shipment may contain multiple packages, each with its own tracking and delivery status.'
}

Table fulfillment.pick_task {
  pick_task_id varchar [pk, note: 'Primary key for pick_task']
  carrier_id varchar [note: 'Foreign key linking to fulfillment.carrier. Business justification: pick_task has denormalized carrier_code and service_level columns but no FKs to carrier or carrier_service. Business reality: pick tasks are prioritized and routed based on carrier and service level (']
  carrier_service_id varchar [note: 'Foreign key linking to fulfillment.carrier_service. Business justification: Following from pick_task carrier_id FK above, pick_task also needs carrier_service_id FK to normalize service_level. Business reality: pick task prioritization and routing depend on service level (ove']
  department_id varchar [note: 'Foreign key linking to store.department. Business justification: Pick tasks are executed within a specific store department (grocery, apparel, electronics). This FK enables department-level pick productivity reporting, shrinkage attribution, and labor scheduling — ']
  fulfillment_line_id varchar [note: 'Line item to pick']
  fulfillment_node_id varchar [note: 'Reference to the fulfillment center, store, or dark store where the task is executed. Supports omnichannel fulfillment including ship-from-store and BOPIS.']
  header_id varchar [note: 'Reference to the parent order that generated this pick task. Links the task to the customer order being fulfilled.']
  outbound_order_id varchar [note: 'Foreign key linking to supplychain.outbound_order. Business justification: DC pick tasks fulfill outbound orders (store replenishment). Direct link enables task-to-order traceability for DC operations, supports labor planning tied to outbound order volume, and facilitates pi']
  outbound_order_line_id varchar [note: 'Foreign key linking to supplychain.outbound_order_line. Business justification: DC pick tasks execute against specific outbound order lines. Line-level pick accuracy reporting, short-pick exception tracking, and fill-rate measurement per outbound line require this direct link. A ']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: WMS pick execution requires SKU master data (weight, dimensions, hazmat_flag, stackable_flag) to determine pick method and equipment. Retail warehouse operations always resolve the picked SKU to its p']
  warehouse_zone_id varchar [note: 'Foreign key linking to supplychain.warehouse_zone. Business justification: Pick tasks are executed within specific warehouse zones. Zone-level productivity reporting, slotting optimization, labor management analytics, and cycle count coordination all require knowing which zo']
  aisle varchar [note: 'Aisle location within the warehouse where the item is stored. Part of the physical location hierarchy for item retrieval.']
  assigned_timestamp timestamp [note: 'Date and time when the task was assigned to the warehouse associate. Marks the start of the task lifecycle.']
  bay varchar [note: 'Bay location within the aisle where the item is stored. Provides granular location detail for picking accuracy.']
  completion_timestamp timestamp [note: 'Date and time when the task was completed by the associate. Used for throughput analysis and SLA tracking.']
  created_timestamp timestamp [note: 'Date and time when the pick task record was created in the system. Audit field for data lineage and task generation tracking.']
  customer_approval_status varchar [note: 'Customer approval status for the substitution. Tracks whether customer accepted the replacement item for BOPIS and delivery orders.']
  exception_code varchar [note: 'Code identifying the type of exception encountered during task execution. Used for root cause analysis and process improvement.']
  exception_reason varchar [note: 'Detailed description of the exception or issue encountered during task execution. Provides context for exception resolution.']
  fulfillment_channel varchar [note: 'Channel through which the order is being fulfilled. Supports omnichannel fulfillment strategy including store-based and centralized fulfillment.']
  label_applied boolean [note: 'Indicates whether the shipping label was successfully applied to the package. Critical checkpoint for shipment readiness.']
  package_type varchar [note: 'Type of packaging used for the shipment. Determines shipping method, carrier selection, and dimensional weight calculation.']
  packing_slip_printed boolean [note: 'Indicates whether the packing slip was printed and included in the package. Required for customer order verification.']
  packing_station_code varchar [note: 'Identifier for the packing station where the item is packed. Used for pack tasks and station utilization tracking.']
  pick_task_status varchar [note: 'Current lifecycle state of the pick task. Tracks progression from assignment through completion or exception handling. [ENUM-REF-CANDIDATE: pending|assigned|in_progress|completed|exception|cancelled|on_hold — 7 candidates stripped; promote to reference product]']
  priority_level varchar [note: 'Numeric priority ranking for task execution sequence. Lower numbers indicate higher priority. Used for queue management and SLA adherence.']
  quality_check_outcome varchar [note: 'Result of the quality check performed on the picked items. Ensures accuracy and condition standards before shipment.']
  quantity_picked decimal(10,2) [note: 'Actual quantity of the item picked by the associate. May differ from requested quantity due to inventory discrepancies or short picks.']
  quantity_requested decimal(10,2) [note: 'Original quantity of the item requested for picking. Represents the target quantity from the order or wave plan.']
  shelf varchar [note: 'Shelf level within the bay where the item is stored. Completes the physical location coordinates for item retrieval.']
  start_timestamp timestamp [note: 'Date and time when the associate began executing the task. Used to calculate task duration and associate productivity.']
  substituted_sku varchar [note: 'Replacement SKU provided when original item was unavailable. Used for substitution analysis and customer communication.']
  substitution_occurred boolean [note: 'Indicates whether a product substitution was made during picking. Common in grocery and BOPIS fulfillment when original item is unavailable.']
  task_duration_seconds varchar [note: 'Total time in seconds from task start to completion. Used for associate productivity analysis and labor standards calibration.']
  task_method varchar [note: 'Picking methodology used for task execution. Defines how items are grouped and picked for optimal efficiency.']
  task_number varchar [note: 'Human-readable business identifier for the pick task. Used by warehouse associates to reference and track tasks.']
  task_type varchar [note: 'Classification of the fulfillment task activity. Determines the workflow and execution requirements for the task.']
  unit_of_measure varchar [note: 'Unit of measure for the quantity being picked. Defines whether picking is by individual units, cases, or other packaging levels.']
  upc varchar [note: 'Universal Product Code barcode for the item. Used for scanning and verification during pick execution.']
  updated_timestamp timestamp [note: 'Date and time when the pick task record was last modified. Audit field for change tracking and data quality monitoring.']
  void_fill_used boolean [note: 'Indicates whether void fill material was used in the package. Tracks packaging material usage for cost and sustainability reporting.']
  work_zone varchar [note: 'Designated zone within the fulfillment location where the task is performed. Used for zone-based picking and associate assignment.']

  Note: 'Unified operational task record for all fulfillment execution activities including picking, packing, quality checks, and value-added services. Captures task type (pick, pack, QC, VAS), assigned associate, work zone, location (aisle, bay, shelf, packing station), SKU/items, quantity requested vs actual, task method (single, batch, zone, wave), priority, status (assigned, in-progress, completed, exception), start time, completion time, quality check outcome, packing details (station ID, package type, void fill, label applied, packing slip printed), and substitution outcome (original SKU, substituted SKU, customer approval status). Supports wave-based task generation from WMS systems including Manhattan Associates and Blue Yonder. Enables associate productivity tracking, task queue management, and fulfillment throughput analytics across the entire pick-pack-QC workflow.'
}

Table fulfillment.pack_task {
  pack_task_id varchar [pk, note: 'Unique identifier for the packing task record. Primary key for the pack task entity.']
  carrier_id varchar [note: 'Foreign key linking to fulfillment.carrier. Business justification: pack_task has denormalized carrier_code and service_level columns but no FKs to carrier or carrier_service. Business reality: a pack task prepares a package for a specific carrier. Adding carrier_id F']
  carrier_service_id varchar [note: 'Foreign key linking to fulfillment.carrier_service. Business justification: Following from pack_task carrier_id FK above, pack_task also needs carrier_service_id FK to normalize service_level. Business reality: packing requirements vary by service level (overnight requires sp']
  fulfillment_line_id varchar [note: 'Line item to pack']
  fulfillment_node_id varchar [note: 'Reference to the fulfillment location (distribution center, dark store, or ship-from-store location) where packing occurred.']
  header_id varchar [note: 'Reference to the customer order being fulfilled by this pack task. Enables traceability from packing back to the original order.']
  outbound_order_id varchar [note: 'Foreign key linking to supplychain.outbound_order. Business justification: DC pack tasks package outbound orders for store replenishment. Links packing execution to supply chain order, supports packing productivity analysis by order type, and enables outbound order status up']
  outbound_order_line_id varchar [note: 'Foreign key linking to supplychain.outbound_order_line. Business justification: Pack tasks in a DC pack specific outbound order lines into cartons. Carton-to-line reconciliation, pack accuracy audits, and outbound order line status updates (packed_qty) depend on this link. A DC f']
  pick_task_id varchar [note: 'Reference to the upstream pick task that provided the items for this packing operation. Links the packing workflow to the picking workflow.']
  shipment_id varchar [note: 'Reference to the shipment record that this packed package will be included in for carrier handoff and delivery.']
  shipment_package_id varchar [note: 'Package being packed into']
  assigned_timestamp timestamp [note: 'Timestamp when the pack task was assigned to the packer. Used to measure queue time and task aging.']
  completed_timestamp timestamp [note: 'Timestamp when the pack task reached completed status and the package was ready for carrier handoff. Used for SLA tracking and throughput measurement.']
  created_timestamp timestamp [note: 'Timestamp when the pack task record was first created in the system. Used for audit trail and data lineage.']
  exception_code varchar [note: 'Code identifying the type of exception encountered during packing. Used for root cause analysis and process improvement. [ENUM-REF-CANDIDATE: short_pick|damaged_item|wrong_item|missing_label|scale_mismatch|oversized|none — 7 candidates stripped; promote to reference product]']
  exception_notes varchar [note: 'Free-text notes describing the exception or special handling required. Provides context for exception resolution and audit trail.']
  fulfillment_type varchar [note: 'Type of fulfillment method for this pack task. Determines packing requirements, labeling, and handoff process. BOPIS (Buy Online Pick Up In Store), ROPIS (Reserve Online Pick Up In Store), SFS (Ship From Store).']
  gift_message_included_flag boolean [note: 'Indicates whether a personalized gift message was printed and included in the package per customer request.']
  gift_wrap_flag boolean [note: 'Indicates whether gift wrapping service was requested and applied to this package. Impacts packing time and material cost.']
  hazmat_flag boolean [note: 'Indicates whether the package contains hazardous materials requiring special handling, labeling, and carrier compliance documentation.']
  insurance_value_amount decimal(12,2) [note: 'Declared value of the package contents for insurance purposes. Used to determine insurance premium and claim limits.']
  items_packed_count varchar [note: 'Total number of individual items (SKUs) packed into the package for this task. Used for productivity measurement and quality verification.']
  pack_duration_seconds varchar [note: 'Total time in seconds spent on the packing operation from start to completion. Key metric for labor standards and productivity analysis.']
  pack_end_timestamp timestamp [note: 'Timestamp when the packing operation was completed and the package was sealed. Used to calculate pack cycle time and throughput.']
  pack_start_timestamp timestamp [note: 'Timestamp when the packer began the packing operation. Used to calculate pack cycle time and labor productivity.']
  package_height_cm decimal(8,2) [note: 'Height dimension of the package in centimeters. Used for dimensional weight calculation and carrier compliance.']
  package_length_cm decimal(8,2) [note: 'Length dimension of the package in centimeters. Used for dimensional weight calculation and carrier compliance.']
  package_size varchar [note: 'Standardized size designation of the package selected. Used for dimensional weight calculation and carrier rate determination. [ENUM-REF-CANDIDATE: XS|S|M|L|XL|XXL|custom — 7 candidates stripped; promote to reference product]']
  package_type varchar [note: 'Type of packaging material selected by the packer for this task. Influences shipping cost, protection level, and carrier handling.']
  package_weight_kg decimal(10,3) [note: 'Actual weight of the sealed package in kilograms, measured at the packing station. Used for carrier rate calculation and compliance verification.']
  package_width_cm decimal(8,2) [note: 'Width dimension of the package in centimeters. Used for dimensional weight calculation and carrier compliance.']
  packing_slip_printed_flag boolean [note: 'Indicates whether the packing slip document was successfully printed and included in the package. Required for customer order verification.']
  packing_station_code varchar [note: 'Identifier of the physical packing station where the task was performed. Used for workload balancing and station performance analysis.']
  quality_check_performed_by varchar [note: 'Identifier of the associate who performed the quality inspection. Used for accountability and training needs identification.']
  quality_check_status varchar [note: 'Result of the quality inspection performed on the packed package. Failed status triggers rework or escalation.']
  shipping_label_applied_flag boolean [note: 'Indicates whether the carrier shipping label was successfully printed and affixed to the package. Required for carrier acceptance.']
  signature_required_flag boolean [note: 'Indicates whether the shipment requires recipient signature upon delivery. Impacts carrier service selection and cost.']
  task_number varchar [note: 'Human-readable business identifier for the pack task. Used for operational tracking, troubleshooting, and communication between warehouse staff.']
  task_priority varchar [note: 'Priority level assigned to the pack task based on order SLA, shipping cutoff time, or customer tier. Determines task sequencing at the packing station.']
  task_status varchar [note: 'Current lifecycle state of the packing task. Tracks progression from assignment through completion or exception handling.']
  tracking_number varchar [note: 'Unique tracking identifier assigned by the carrier for shipment visibility. Provided to customer for delivery status monitoring.']
  units_packed_count varchar [note: 'Total quantity of units packed across all items. Differs from items_packed_count when multiple units of the same SKU are included.']
  updated_timestamp timestamp [note: 'Timestamp when the pack task record was last modified. Used for audit trail and change tracking.']
  void_fill_type varchar [note: 'Type of void fill material used to protect items and prevent shifting during transit. Impacts packaging cost and sustainability metrics.']

  Note: 'Operational task record for the packing station workflow. Captures packer assignment, packing station ID, items packed, package type selected, void fill used, packing slip printed flag, label applied flag, pack start time, pack end time, and quality check status. Tracks the transition from picked items to sealed, labeled packages ready for carrier handoff.'
}

Table fulfillment.carrier {
  carrier_id varchar [pk, note: 'Primary key for carrier']
  vendor_id varchar [note: 'Add column vendor_id (BIGINT) to supplier.carrier with FK to supplier.vendor.vendor_id because carriers are vendors with contracts and should link to the vendor record. P18: connect_table: supplier.carrier** - add column vendor_id (BI']
  api_integration_flag boolean [note: 'Indicates whether the carrier provides API integration capabilities for real-time rate shopping, booking, and tracking.']
  base_rate_per_lb decimal(10,4) [note: 'Negotiated base shipping rate per pound for standard service level, before surcharges and adjustments.']
  bopis_ready_flag boolean [note: 'Indicates whether the carrier supports BOPIS fulfillment logistics including store-to-customer handoff coordination.']
  carrier_status varchar [note: 'Current operational status of the carrier relationship indicating whether the carrier is available for shipment assignment.']
  carrier_type varchar [note: 'Classification of the carrier based on service model: parcel (small package), LTL (Less Than Truckload), FTL (Full Truckload), last-mile delivery, same-day delivery, or third-party logistics (3PL) provider.']
  code varchar [note: 'Internal short code or abbreviation used to identify the carrier in operational systems.']
  contact_email varchar [note: 'Email address of the primary carrier contact for operational communication and escalations.']
  contact_name varchar [note: 'Name of the primary account representative or contact person at the carrier for operational coordination and issue resolution.']
  contact_phone varchar [note: 'Phone number of the primary carrier contact for urgent operational issues and coordination.']
  contract_end_date date [note: 'Date when the carrier service contract expires or is scheduled for renewal.']
  contract_start_date date [note: 'Date when the carrier service contract or agreement became effective.']
  created_timestamp timestamp [note: 'Timestamp when the carrier master record was first created in the system.']
  cutoff_time_local varchar [note: 'Daily cutoff time in local warehouse time zone (HH:MM format) by which shipments must be tendered to the carrier to qualify for same-day pickup and service level commitment.']
  dimensional_weight_factor decimal(8,2) [note: 'Divisor used to calculate dimensional weight from package dimensions (length x width x height / factor). Common values are 139 for domestic and 166 for international.']
  edi_capable_flag boolean [note: 'Indicates whether the carrier supports Electronic Data Interchange (EDI) for automated shipment booking, tracking, and invoicing.']
  extended_area_surcharge decimal(8,2) [note: 'Additional fee charged for deliveries to remote or extended service areas beyond standard coverage zones.']
  fuel_surcharge_percentage decimal(5,2) [note: 'Current fuel surcharge percentage applied to base shipping rates, typically adjusted monthly based on fuel price indices.']
  geographic_coverage varchar [note: 'Description of the geographic regions and countries where the carrier provides service coverage. May include restrictions or limitations.']
  hazmat_certified_flag boolean [note: 'Indicates whether the carrier is certified and authorized to transport hazardous materials under Department of Transportation (DOT) regulations.']
  insurance_coverage_flag boolean [note: 'Indicates whether the carrier offers shipment insurance or declared value coverage for high-value packages.']
  max_height_inches decimal(8,2) [note: 'Maximum package height dimension in inches that the carrier will accept for shipment.']
  max_length_inches decimal(8,2) [note: 'Maximum package length dimension in inches that the carrier will accept for shipment.']
  max_weight_lbs decimal(10,2) [note: 'Maximum package weight in pounds that the carrier will accept for shipment under standard service terms.']
  max_width_inches decimal(8,2) [note: 'Maximum package width dimension in inches that the carrier will accept for shipment.']
  name varchar [note: 'The legal business name of the carrier or third-party logistics (3PL) provider.']
  negotiated_discount_percentage decimal(5,2) [note: 'Volume-based discount percentage negotiated off published carrier rates based on annual shipping commitment.']
  rate_effective_date date [note: 'Date when the current rate card and pricing terms became effective.']
  rate_expiry_date date [note: 'Date when the current rate card expires and requires renegotiation or renewal.']
  residential_delivery_surcharge decimal(8,2) [note: 'Additional flat fee charged for deliveries to residential addresses versus commercial addresses.']
  scac_code varchar [note: 'Standard Carrier Alpha Code assigned by the National Motor Freight Traffic Association for freight carriers in North America.']
  service_level_ground boolean [note: 'Indicates whether the carrier offers standard ground shipping service.']
  service_level_overnight boolean [note: 'Indicates whether the carrier offers overnight express shipping service.']
  service_level_same_day boolean [note: 'Indicates whether the carrier offers same-day delivery service for local or regional shipments.']
  service_level_two_day boolean [note: 'Indicates whether the carrier offers two-day expedited shipping service.']
  signature_required_flag boolean [note: 'Indicates whether the carrier requires recipient signature upon delivery as a standard service feature.']
  tracking_capability_flag boolean [note: 'Indicates whether the carrier provides real-time shipment tracking and visibility capabilities.']
  transit_days_zone_1 varchar [note: 'Standard number of business days for ground shipment delivery to Zone 1 (typically local or adjacent regions).']
  transit_days_zone_2 varchar [note: 'Standard number of business days for ground shipment delivery to Zone 2 (typically regional).']
  transit_days_zone_3 varchar [note: 'Standard number of business days for ground shipment delivery to Zone 3 (typically extended regional).']
  updated_timestamp timestamp [note: 'Timestamp when the carrier master record was last modified or updated.']

  Note: 'Master record for carrier and 3PL partners used for outbound shipment execution, encompassing carrier identity, service catalog, and contracted rate cards. Captures carrier name, carrier code, carrier type (parcel, LTL, FTL, last-mile, same-day), SCAC code, EDI/API integration capabilities. Service catalog includes service levels (ground, 2-day, overnight, same-day, BOPIS-ready), transit days by zone, cutoff times, max weight/dimensions, surcharge types, tracking capability, signature required flag, and geographic restrictions. Rate card includes base rates by zone/weight/service, dimensional weight factor, fuel surcharges, residential delivery surcharges, extended area surcharges, negotiated discount percentages, rate effective and expiry dates, and weight breaks. Serves as the single source of truth for all carrier master data, service definitions, and freight cost references within the fulfillment domain. Used in carrier selection logic during fulfillment order routing and freight cost estimation.'
}

Table fulfillment.carrier_service {
  carrier_service_id varchar [pk, note: 'Unique identifier for the carrier service offering. Primary key.']
  carrier_id varchar [note: 'Reference to the carrier (logistics provider) offering this service. Links to the carrier master entity.']
  base_rate decimal(10,2) [note: 'Base shipping rate for this carrier service in the default currency. Used as starting point for total shipping cost calculation before surcharges and discounts.']
  bopis_eligible_flag boolean [note: 'Indicates whether this carrier service is eligible for BOPIS (Buy Online Pick Up In Store) fulfillment scenarios. Used in omnichannel order routing.']
  carbon_neutral_flag boolean [note: 'Indicates whether this carrier service is certified as carbon-neutral or participates in carbon offset programs. Used in sustainability reporting and eco-conscious customer service selection.']
  created_timestamp timestamp [note: 'Timestamp when this carrier service record was first created in the system. Used for audit trail and data lineage tracking.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the base rate (e.g., USD, EUR, GBP). Used in multi-currency pricing and cost normalization.']
  cutoff_time timestamp [note: 'Daily cutoff time (HH:MM format, 24-hour) by which orders must be placed to qualify for same-day shipment with this service. Critical for order routing and fulfillment scheduling.']
  cutoff_timezone varchar [note: 'Timezone identifier for the cutoff time (e.g., EST, PST, CST, UTC). Ensures accurate cutoff enforcement across distributed fulfillment centers.']
  effective_end_date date [note: 'Date after which this carrier service configuration is no longer active. Null indicates indefinite availability. Used in temporal service availability logic.']
  effective_start_date date [note: 'Date from which this carrier service configuration becomes active and available for order routing. Used in temporal service availability logic.']
  geographic_restriction_type varchar [note: 'Type of geographic restriction applied to this carrier service (e.g., domestic only, specific regions, postal code whitelist/blacklist). Used in carrier eligibility filtering.']
  hazmat_eligible_flag boolean [note: 'Indicates whether this carrier service is certified to transport hazardous materials. Used in carrier selection for restricted product categories.']
  holiday_delivery_flag boolean [note: 'Indicates whether this carrier service supports delivery on recognized holidays. Used in delivery date estimation and peak season planning.']
  insurance_included_flag boolean [note: 'Indicates whether shipment insurance is automatically included with this carrier service. Affects cost calculations and risk management decisions.']
  insurance_max_value decimal(12,2) [note: 'Maximum insured value (in base currency) covered by this carrier service. Orders exceeding this value may require additional insurance or alternative services.']
  international_eligible_flag boolean [note: 'Indicates whether this carrier service supports international cross-border shipments. Used in carrier selection for international orders.']
  max_girth_cm decimal(10,2) [note: 'Maximum package girth (length + 2×width + 2×height) in centimeters. Some carriers enforce combined dimensional limits beyond individual dimension constraints.']
  max_height_cm decimal(10,2) [note: 'Maximum package height dimension in centimeters accepted by this carrier service. Used in dimensional eligibility checks during carrier selection.']
  max_length_cm decimal(10,2) [note: 'Maximum package length dimension in centimeters accepted by this carrier service. Used in dimensional eligibility checks during carrier selection.']
  max_weight_kg decimal(10,2) [note: 'Maximum shipment weight in kilograms that this carrier service can handle. Used in carrier selection logic to filter eligible services based on order weight.']
  max_width_cm decimal(10,2) [note: 'Maximum package width dimension in centimeters accepted by this carrier service. Used in dimensional eligibility checks during carrier selection.']
  perishable_eligible_flag boolean [note: 'Indicates whether this carrier service supports temperature-controlled or time-sensitive perishable goods (e.g., groceries, fresh food). Used in carrier selection for perishable SKUs.']
  restricted_countries varchar [note: 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this carrier service is NOT available. Used in international order routing and carrier selection.']
  restricted_postal_codes varchar [note: 'Comma-separated list of postal codes or postal code prefixes where this carrier service is NOT available. Used in carrier eligibility filtering during order routing.']
  saturday_delivery_flag boolean [note: 'Indicates whether this carrier service supports Saturday delivery. Used in delivery date estimation and customer service selection.']
  service_code varchar [note: 'Unique alphanumeric code identifying the carrier service offering (e.g., GROUND, 2DAY, OVERNIGHT, SAMEDAY). Used in carrier selection logic and order routing.']
  service_name varchar [note: 'Human-readable name of the carrier service offering (e.g., Ground Shipping, Two-Day Express, Overnight Priority, Same-Day Delivery).']
  service_status varchar [note: 'Current operational status of the carrier service. Determines availability for order routing and fulfillment selection.']
  service_type varchar [note: 'Classification of the carrier service by delivery speed and priority level. Used for service tier segmentation and customer selection.']
  ship_from_store_eligible_flag boolean [note: 'Indicates whether this carrier service is eligible for SFS (Ship From Store) fulfillment scenarios. Used in omnichannel order routing and inventory optimization.']
  signature_required_flag boolean [note: 'Indicates whether this carrier service mandates recipient signature upon delivery. Impacts service selection for high-value or restricted items.']
  sla_delivery_guarantee_flag boolean [note: 'Indicates whether this carrier service includes a contractual SLA (Service Level Agreement) delivery guarantee with refund or credit for late deliveries. Used in service selection and customer promise management.']
  sunday_delivery_flag boolean [note: 'Indicates whether this carrier service supports Sunday delivery. Used in delivery date estimation and customer service selection.']
  surcharge_types varchar [note: 'Comma-separated list of surcharge types applicable to this carrier service (e.g., fuel_surcharge, residential_delivery, remote_area, oversized, peak_season). Used in total shipping cost calculation.']
  tracking_capability_flag boolean [note: 'Indicates whether this carrier service provides real-time shipment tracking capability. Used to determine customer visibility options and service selection.']
  transit_days_max varchar [note: 'Maximum number of business days required for delivery from shipment date. Used in delivery date estimation and SLA (Service Level Agreement) calculations.']
  transit_days_min varchar [note: 'Minimum number of business days required for delivery from shipment date. Used in delivery date estimation and SLA (Service Level Agreement) calculations.']
  updated_timestamp timestamp [note: 'Timestamp when this carrier service record was last modified. Used for audit trail, change tracking, and data synchronization.']

  Note: 'Defines specific service offerings provided by a carrier, such as ground, 2-day, overnight, same-day, or BOPIS-ready services. Captures service code, service name, transit days, cutoff time, max weight, max dimensions, surcharge types, tracking capability, signature required flag, and geographic restrictions. Used in carrier selection logic during fulfillment order routing.'
}

Table fulfillment.fulfillment_node {
  fulfillment_node_id varchar [pk, note: 'Unique identifier for the node data product.']
  dc_facility_id varchar [note: 'Foreign key linking to supplychain.dc_facility. Business justification: Fulfillment nodes include DCs. When node is a DC, linking to dc_facility provides full facility details (dock doors, capacity, WMS, zones). Essential for DC-based fulfillment operations, capacity plan']
  department_id varchar [note: 'Foreign key linking to store.department. Business justification: Ship-from-store and BOPIS fulfillment nodes operating inside a store are assigned to a specific department (e.g., grocery pickup, electronics). This drives department-level labor budgeting, space allo']
  inventory_node_id varchar [note: 'Foreign key reference to the SSOT owner inventory.inventory_node.']
  location_id varchar [note: 'Physical location of this fulfillment node']
  price_zone_id varchar [note: 'Foreign key linking to pricing.price_zone. Business justification: Each fulfillment node (store or DC) operates within a price zone, driving ship-from-store pricing, BOPIS price applicability, and zone-based fulfillment routing decisions. Retail pricing operations re']
  activation_date date [note: 'Date when the fulfillment node became operational and available for order fulfillment.']
  address_line_1 varchar [note: 'Primary street address of the fulfillment node (street number, street name). Organizational contact data classified as confidential per business policy.']
  address_line_2 varchar [note: 'Secondary address information (suite, building, floor). Organizational contact data classified as confidential per business policy.']
  automation_level varchar [note: 'Degree of automation in fulfillment operations: manual (human-only picking/packing), semi_automated (conveyor systems, pick-to-light), fully_automated (robotic picking, automated storage and retrieval systems).']
  bopis_enabled boolean [note: 'Indicates whether this node supports Buy Online Pick Up In Store (BOPIS) fulfillment capability. True if customers can place online orders for in-store pickup at this location.']
  city varchar [note: 'City where the fulfillment node is located. Organizational contact data classified as confidential per business policy.']
  country_code varchar [note: 'Three-letter ISO country code where the fulfillment node is located (e.g., USA, CAN, MEX).']
  created_timestamp timestamp [note: 'Timestamp when this fulfillment node record was first created in the system.']
  curbside_pickup_enabled boolean [note: 'Indicates whether this node supports curbside pickup fulfillment. True if customers can pick up orders without entering the building.']
  deactivation_date date [note: 'Date when the fulfillment node was decommissioned or permanently closed. Null for active nodes.']
  delivery_zone_coverage_radius_miles decimal(5,2) [note: 'Maximum delivery radius in miles from this fulfillment node for last-mile delivery services. Used for order routing and delivery zone assignment.']
  dock_door_count varchar [note: 'Number of loading dock doors available at this fulfillment node for inbound receiving and outbound shipping. Key constraint for DC and cross-dock operations.']
  email_address varchar [note: 'Primary email contact for the fulfillment node operations team. Organizational contact data classified as confidential per business policy.']
  hazmat_certified boolean [note: 'Indicates whether this node is certified to handle and store hazardous materials per OSHA and DOT regulations. True if hazmat fulfillment is permitted.']
  last_modified_timestamp timestamp [note: 'Timestamp when this fulfillment node record was last updated in the system.']
  latitude decimal(10,7) [note: 'Geographic latitude coordinate of the fulfillment node, used for distance calculations, delivery zone mapping, and route optimization.']
  longitude decimal(10,7) [note: 'Geographic longitude coordinate of the fulfillment node, used for distance calculations, delivery zone mapping, and route optimization.']
  manager_name varchar [note: 'Name of the fulfillment operations manager responsible for this node. Business reference, not direct PII.']
  next_day_delivery_enabled boolean [note: 'Indicates whether this node supports next-day delivery fulfillment. True if orders can be delivered to customers on the day following order placement.']
  node_code varchar [note: 'Business identifier code for the fulfillment node, used across operational systems for node identification and routing logic. Typically alphanumeric, uppercase.']
  node_name varchar [note: 'Human-readable name of the fulfillment node (e.g., \'Downtown Distribution Center\', \'Store #1234 - Main Street\', \'MFC Phoenix West\').']
  node_status varchar [note: 'Current operational lifecycle status of the fulfillment node. Active nodes are available for order routing; inactive/temporarily_closed nodes are excluded from fulfillment logic.']
  node_type varchar [note: 'Classification of the fulfillment node by its primary operational purpose: distribution_center (DC - regional warehouse), store (retail location with fulfillment capability), dark_store (fulfillment-only location, no customer traffic), micro_fulfillment_center (MFC - automated urban fulfillment hub), cross_dock (direct transfer facility), returns_center (reverse logistics hub).']
  operating_hours_weekday varchar [note: 'Standard operating hours for weekdays (Monday-Friday) in format HH:MM-HH:MM (e.g., 08:00-20:00). Used for order cutoff time calculations and fulfillment scheduling.']
  operating_hours_weekend varchar [note: 'Standard operating hours for weekends (Saturday-Sunday) in format HH:MM-HH:MM (e.g., 09:00-18:00). Used for order cutoff time calculations and fulfillment scheduling.']
  pack_station_count varchar [note: 'Number of packing stations available at this fulfillment node. Determines packing throughput capacity for ship-from-store and DC operations.']
  phone_number varchar [note: 'Primary contact phone number for the fulfillment node. Organizational contact data classified as confidential per business policy.']
  pick_capacity_orders_per_hour varchar [note: 'Maximum number of orders that can be picked per hour at this fulfillment node under normal operating conditions. Used for capacity planning and order routing decisions.']
  postal_code varchar [note: 'Postal or ZIP code for the fulfillment node address. Organizational contact data classified as confidential per business policy.']
  primary_carrier_code varchar [note: 'Code identifying the primary shipping carrier assigned to this fulfillment node (e.g., UPS, FedEx, USPS, regional 3PL). Used for default carrier selection in order routing.']
  refrigerated_storage_enabled boolean [note: 'Indicates whether this node has refrigerated storage capability for perishable goods (dairy, produce, frozen foods). True if cold chain fulfillment is supported.']
  ropis_enabled boolean [note: 'Indicates whether this node supports Reserve Online Pick Up In Store (ROPIS) fulfillment capability. True if customers can reserve items online for later in-store pickup and payment.']
  same_day_delivery_enabled boolean [note: 'Indicates whether this node supports same-day delivery fulfillment. True if orders can be delivered to customers on the same day they are placed.']
  ship_from_store_enabled boolean [note: 'Indicates whether this node supports Ship From Store (SFS) fulfillment capability. True if this location can pick, pack, and ship online orders directly to customers.']
  state_province varchar [note: 'Two-letter state or province code (e.g., CA, TX, ON). Organizational contact data classified as confidential per business policy.']
  storage_capacity_square_feet varchar [note: 'Total storage capacity of the fulfillment node measured in square feet. Used for inventory capacity planning and space utilization analysis.']
  storage_zone_count varchar [note: 'Number of distinct storage zones within the fulfillment node (e.g., ambient, refrigerated, frozen, hazmat). Used for inventory placement and pick path optimization.']
  time_zone varchar [note: 'IANA time zone identifier for the fulfillment node (e.g., America/New_York, America/Los_Angeles), used for scheduling and cutoff time calculations.']
  wms_system_code varchar [note: 'Identifier of the WMS system instance managing this fulfillment node. Links to the operational WMS platform (e.g., Manhattan Associates instance ID).']

  Note: '[References SSOT: inventory.inventory_node] Fulfillment-specific node configuration for order routing and execution. References inventory.inventory_node for the authoritative physical location record. Adds fulfillment capabilities like pick capacity and carrier assignments.'
}

Table fulfillment.bopis_appointment {
  bopis_appointment_id varchar [pk, note: 'Unique identifier for the BOPIS or ROPIS pickup appointment record.']
  fulfillment_node_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_node. Business justification: A BOPIS appointment is serviced at a specific fulfillment node (the store\'s fulfillment operation). bopis_appointment currently has location_id pointing to fulfillment.location (cross-domain), but lacks a d']
  header_id varchar [note: 'Reference to the e-commerce or omnichannel order associated with this pickup appointment.']
  location_id varchar [note: 'Reference to the store or fulfillment node where the customer will pick up the order.']
  order_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_order. Business justification: bopis_appointment tracks BOPIS/ROPIS customer pickup appointments. It links to order_header but not to the operational fulfillment_order that picks and stages the items. Adding fulfillment_order_id FK']
  pickup_pos_transaction_id varchar [note: 'Foreign key linking to order.pos_transaction. Business justification: BOPIS pickup reconciliation: the bopis_appointment records the scheduled pickup event while the POS transaction records the actual tender/completion. Linking these enables BOPIS no-show analysis, pick']
  profile_id varchar [note: 'Reference to the customer who placed the order and scheduled the pickup appointment.']
  actual_pickup_timestamp timestamp [note: 'Timestamp when the customer physically received and collected the order from the store.']
  actual_ready_minutes varchar [note: 'Actual elapsed time in minutes from order placement to ready-for-pickup status, used for SLA performance tracking.']
  alternate_pickup_person_name varchar [note: 'Name of an alternate person authorized to pick up the order on behalf of the customer.']
  appointment_number varchar [note: 'Human-readable unique appointment confirmation number provided to the customer for reference at pickup.']
  appointment_status varchar [note: 'Current lifecycle status of the BOPIS appointment: scheduled (appointment created), ready (order ready for pickup), picked_up (customer collected order), expired (pickup window passed), cancelled (customer or system cancelled), no_show (customer did not arrive).']
  appointment_type varchar [note: 'Type of pickup appointment: BOPIS (Buy Online Pick Up In Store - order already paid) or ROPIS (Reserve Online Pick Up In Store - payment at pickup).']
  cancellation_reason varchar [note: 'Reason code for appointment cancellation: customer_request, out_of_stock (item unavailable), store_closure, system_error, fraud (suspected fraudulent order), other.']
  cancellation_timestamp timestamp [note: 'Timestamp when the appointment was cancelled by customer or system.']
  check_in_method varchar [note: 'Method used by the customer to check in for pickup: mobile_app (customer used retailer app), kiosk (in-store self-service kiosk), associate (checked in with store associate), phone (called store), walk_in (arrived without prior check-in).']
  check_in_timestamp timestamp [note: 'Timestamp when the customer checked in to notify the store of their arrival for pickup.']
  created_timestamp timestamp [note: 'Timestamp when the BOPIS appointment record was first created in the system.']
  customer_email varchar [note: 'Email address for sending pickup ready notifications and appointment confirmations.']
  customer_name varchar [note: 'Full name of the customer who will pick up the order, used for identity verification at the pickup counter.']
  customer_phone varchar [note: 'Contact phone number for the customer, used for pickup notifications and communication.']
  expiration_timestamp timestamp [note: 'Timestamp when the appointment expired due to customer not picking up within the allowed window.']
  id_verification_method varchar [note: 'Method used to verify customer identity at pickup: drivers_license, passport, order_confirmation (email/SMS), photo_id, none (no verification required).']
  modified_timestamp timestamp [note: 'Timestamp when the BOPIS appointment record was last modified.']
  parking_spot_number varchar [note: 'Designated parking spot number for curbside pickup where the customer is waiting.']
  pickup_instructions varchar [note: 'Special instructions provided by the customer for pickup (e.g., curbside delivery, vehicle description, accessibility needs).']
  pickup_location_code varchar [note: 'Code identifying the specific pickup area within the store (e.g., customer service desk, dedicated BOPIS counter, curbside zone).']
  ready_for_pickup_timestamp timestamp [note: 'Timestamp when the order was marked as ready for customer pickup by store associates or fulfillment system.']
  ready_notification_sent_flag boolean [note: 'Boolean flag indicating whether the ready-for-pickup notification (email/SMS) was successfully sent to the customer.']
  ready_notification_sent_timestamp timestamp [note: 'Timestamp when the ready-for-pickup notification was sent to the customer.']
  scheduled_date date [note: 'The date on which the customer scheduled to pick up the order.']
  scheduled_time_slot_end timestamp [note: 'End timestamp of the customer-selected pickup time window.']
  scheduled_time_slot_start timestamp [note: 'Start timestamp of the customer-selected pickup time window.']
  sla_met_flag boolean [note: 'Boolean flag indicating whether the BOPIS readiness SLA commitment was met (true) or missed (false).']
  sla_target_ready_minutes varchar [note: 'Target time in minutes from order placement to ready-for-pickup status, as committed in the BOPIS service level agreement.']
  vehicle_description varchar [note: 'Description of the customers vehicle for curbside pickup identification (make, model, color, license plate).']
  wait_time_minutes varchar [note: 'Time in minutes the customer waited from check-in to actual pickup, used for customer experience KPI tracking.']

  Note: 'Tracks BOPIS (Buy Online Pick Up In Store) and ROPIS (Reserve Online Pick Up In Store) customer pickup appointments. Captures order reference, customer name, pickup store/node, appointment window (date and time slot), check-in method (app, kiosk, associate), check-in timestamp, ready-for-pickup notification sent flag, actual pickup timestamp, and appointment status (scheduled, ready, picked-up, expired, cancelled). Enables SLA tracking for BOPIS readiness commitments.'
}

Table fulfillment.drop_ship_order {
  drop_ship_order_id varchar [pk, note: 'Primary key for drop_ship_order']
  carrier_id varchar [note: 'Reference to the shipping carrier used by the vendor for drop ship delivery.']
  carrier_service_id varchar [note: 'Foreign key linking to fulfillment.carrier_service. Business justification: drop_ship_order has carrier_id FK and denormalized carrier_service_level column, but no FK to carrier_service. Business reality: a drop-ship order is fulfilled by the vendor using a specific carrier s']
  cost_price_id varchar [note: 'Foreign key linking to pricing.cost_price. Business justification: Drop ship orders track vendor cost for margin analysis, profitability reporting, and vendor performance evaluation. Currently has denormalized unit_cost/extended_cost; linking to cost_price provides f']
  header_id varchar [note: 'Reference to the parent customer order that this drop ship fulfillment is executing against.']
  lead_time_agreement_id varchar [note: 'Foreign key linking to supplier.lead_time_agreement. Business justification: Drop-ship SLA compliance process: when a drop_ship_order is created, the applicable lead_time_agreement governs promised_ship_date and drives vendor_sla_compliance_flag evaluation. Retail operations t']
  order_id varchar [note: 'Parent fulfillment order']
  order_line_id varchar [note: 'Reference to the specific order line item being fulfilled via drop ship.']
  profile_id varchar [note: 'Reference to the customer who will receive the drop ship delivery.']
  purchase_order_id varchar [note: 'Foreign key linking to supplychain.purchase_order. Business justification: Drop ship orders are commercially backed by vendor purchase orders. AP invoice matching, vendor SLA compliance reporting, and cost reconciliation for drop ship transactions require linking the drop sh']
  shipment_id varchar [note: 'Foreign key linking to fulfillment.shipment. Business justification: A drop-ship order results in a physical shipment dispatched by the vendor to the customer. When the vendor ships, a shipment record should be created in the fulfillment domain to enable unified tracki']
  shipping_address_id varchar [note: 'Foreign key linking to customer.address. Business justification: Drop ship orders ship directly to the customer\'s canonical address. Linking enables address validation, vendor SLA compliance analysis by delivery zone, returns routing, and address change impact on i']
  sku_id varchar [note: 'SKU being drop-shipped']
  sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: Drop-ship margin calculation requires linking the vendor cost (cost_price_id already exists) to the retail selling price (sku_price). Retail drop-ship operations use this for margin compliance reporti']
  vendor_contact_id varchar [note: 'Foreign key linking to supplier.vendor_contact. Business justification: Drop ship operations require designated vendor contact for order transmission, shipment coordination, exception resolution, and SLA escalation. Retail drop ship systems maintain contact assignments pe']
  vendor_contract_id varchar [note: 'Foreign key linking to supplier.vendor_contract. Business justification: Drop ship orders execute under specific vendor contracts defining pricing, terms, SLAs, and chargeback provisions. Contract reference required for compliance verification, SLA monitoring, dispute reso']
  vendor_id varchar [note: 'Reference to the supplier or vendor who will ship directly to the customer on behalf of the retailer.']
  vendor_item_id varchar [note: 'Foreign key linking to supplier.vendor_item. Business justification: Drop ship PO generation requires vendor item number, pack configuration, and vendor-specific cost from vendor item master. Critical for accurate vendor order transmission, invoice reconciliation, and ']
  vendor_promo_agreement_id varchar [note: 'Foreign key linking to promotion.vendor_promo_agreement. Business justification: Vendor-funded promotional terms (discounts, co-op funding) governing drop-shipped items are defined in vendor_promo_agreement. Linking drop_ship_order to vendor_promo_agreement enables vendor promotio']
  actual_delivery_date date [note: 'Date the customer actually received the drop ship delivery. Confirmed via carrier proof of delivery.']
  actual_ship_date date [note: 'Date the vendor actually shipped the order to the customer. Used for SLA compliance measurement.']
  cancellation_reason varchar [note: 'Reason the drop ship order was cancelled, either by the customer, retailer, or vendor.']
  created_timestamp timestamp [note: 'Date and time this drop ship order record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO currency code for all monetary amounts in this drop ship order.']
  drop_ship_order_number varchar [note: 'Unique business identifier for the drop ship order, used for external communication and tracking.']
  drop_ship_status varchar [note: 'Current lifecycle status of the drop ship order. Tracks progression from vendor notification through final delivery. [ENUM-REF-CANDIDATE: sent_to_vendor|acknowledged|in_progress|shipped|delivered|cancelled|exception|returned — 8 candidates stripped; promote to reference product]']
  estimated_delivery_date date [note: 'Expected date the customer will receive the drop ship delivery.']
  exception_code varchar [note: 'Standardized code identifying the type of exception or issue encountered during drop ship fulfillment (e.g., out of stock, address invalid, delivery failed).']
  exception_description varchar [note: 'Detailed explanation of the exception or issue that occurred during drop ship processing or delivery.']
  gtin varchar [note: 'Global standard identifier for the trade item being drop shipped.']
  modified_timestamp timestamp [note: 'Date and time this drop ship order record was last updated.']
  product_name varchar [note: 'Human-readable name or description of the product being drop shipped.']
  promised_ship_date date [note: 'Date the vendor committed to ship the order to the customer. Used for SLA tracking and customer expectation management.']
  quantity_ordered varchar [note: 'Number of units requested from the vendor for drop ship fulfillment.']
  quantity_shipped varchar [note: 'Actual number of units shipped by the vendor to the customer.']
  sent_to_vendor_timestamp timestamp [note: 'Date and time the drop ship request was transmitted to the vendor via EDI, API, or portal.']
  ship_to_email varchar [note: 'Email address for delivery notifications and tracking updates.']
  ship_to_name varchar [note: 'Name of the recipient for the drop ship delivery.']
  ship_to_phone varchar [note: 'Contact phone number for delivery coordination and customer communication.']
  sku varchar [note: 'Retailer\'s internal product identifier for the item being drop shipped.']
  unit_of_measure varchar [note: 'Standard unit used to quantify the product (e.g., each, case, box).']
  upc varchar [note: 'Standard barcode identifier for the product being drop shipped.']
  vendor_acknowledged_timestamp timestamp [note: 'Date and time the vendor confirmed receipt and acceptance of the drop ship order.']
  vendor_order_reference varchar [note: 'Vendor\'s internal order reference or confirmation number for this drop ship request.']
  vendor_po_number varchar [note: 'Purchase order number sent to the vendor to authorize the drop ship fulfillment. Used for vendor reconciliation and invoice matching.']
  vendor_sla_compliance_flag boolean [note: 'Indicates whether the vendor met the promised ship date commitment. True if shipped on or before promised date, false otherwise.']

  Note: 'Tracks vendor drop-ship fulfillment orders where the supplier ships directly to the customer on behalf of the retailer. Captures vendor reference, PO number sent to vendor, customer ship-to address, promised ship date, actual ship date, vendor tracking number, drop-ship status (sent-to-vendor, acknowledged, shipped, delivered, exception), and vendor SLA compliance flag. Distinct from standard fulfillment orders — drop-ship bypasses the retailer\'s physical fulfillment nodes entirely.'
}

Table returns.rma {
  rma_id varchar [pk, note: 'Primary key for rma']
  header_id varchar [note: 'Reference to the original sales order from which the items are being returned.']
  order_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_order. Business justification: RMAs must trace back to the specific fulfillment that generated the return for carrier performance analysis, fulfillment quality metrics by node/method, and root-cause analysis of returns. Essential f']
  originating_storefront_id varchar [note: 'Foreign key linking to ecommerce.storefront. Business justification: RMAs originate from a specific ecommerce storefront, enabling storefront-level return rate reporting, channel P&L attribution for returns, and storefront-specific return SLA tracking. return_channel i']
  pos_transaction_id varchar [note: 'Foreign key linking to order.pos_transaction. Business justification: In-store return initiation: RMAs created at the POS terminal must link to the originating POS transaction for store-level return reporting, loss-prevention review, and associate accountability trackin']
  profile_id varchar [note: 'Reference to the customer who is initiating the return.']
  return_department_id varchar [note: 'Foreign key linking to store.department. Business justification: In-store returns are processed at a specific department (e.g., electronics returns counter, customer service desk). Department-level RMA volume drives staffing models and shrinkage reporting by depart']
  return_location_id varchar [note: 'Reference to the store or distribution center where the returned merchandise will be received and processed.']
  return_policy_id varchar [note: 'Foreign key linking to returns.return_policy. Business justification: An RMA (Return Merchandise Authorization) is formally issued under a specific return policy that governs eligibility, return window, restocking fees, and resolution options. The rma table has no exist']
  shipment_id varchar [note: 'Foreign key linking to fulfillment.shipment. Business justification: RMA processing requires the original outbound shipment to generate prepaid return labels using the same carrier/service, validate carrier SLA compliance for returns, and support return shipping cost a']
  authorization_date date [note: 'The date when the return merchandise authorization was approved and issued to the customer.']
  authorization_timestamp timestamp [note: 'Precise timestamp when the RMA was authorized, capturing the exact moment of approval for audit and SLA tracking purposes.']
  closed_date date [note: 'The date when the RMA was closed and all return processing activities were completed.']
  created_timestamp timestamp [note: 'Timestamp when the RMA record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the expected return value amount.']
  customer_comments varchar [note: 'Free-text comments provided by the customer explaining the reason for return or providing additional details about the issue.']
  disposition_code varchar [note: 'Code indicating the final disposition of the returned merchandise: restock to inventory, liquidate through clearance channel, rework/refurbish, scrap/destroy, RTV (Return to Vendor), or donate to charity.']
  expected_return_value_amount decimal(15,2) [note: 'The total monetary value of merchandise expected to be returned under this RMA, calculated from the original order line items.']
  expiry_date date [note: 'The date by which the customer must return the merchandise. After this date, the RMA becomes invalid and the return may not be accepted.']
  fraud_score decimal(5,2) [note: 'Numerical score (0-100) representing the likelihood that this return is fraudulent, generated by fraud detection algorithms.']
  inspection_date date [note: 'The date when the returned merchandise was inspected to determine its condition and disposition.']
  inspection_status varchar [note: 'Result of the merchandise inspection indicating whether items meet return acceptance criteria.']
  is_fraudulent boolean [note: 'Boolean flag indicating whether this return has been identified as potentially fraudulent based on fraud detection rules or manual review.']
  last_modified_timestamp timestamp [note: 'Timestamp when the RMA record was last updated, used for audit trail and change tracking.']
  priority_level varchar [note: 'Processing priority assigned to this RMA based on customer tier, return value, or business rules.']
  received_date date [note: 'The date when the returned merchandise was physically received at the return location.']
  received_timestamp timestamp [note: 'Precise timestamp when the returned merchandise was received, used for SLA tracking and operational metrics.']
  refund_amount decimal(15,2) [note: 'The actual refund amount to be issued to the customer after inspection and approval, which may differ from expected return value due to restocking fees or partial returns.']
  refund_method varchar [note: 'The method by which the refund is issued to the customer.']
  refund_processed_date date [note: 'The date when the refund payment was processed and issued to the customer.']
  restocking_fee_amount decimal(15,2) [note: 'Fee charged to the customer for processing the return, typically applied to non-defective returns or opened merchandise.']
  return_channel varchar [note: 'The channel through which the customer initiated the return request. BOPIS = Buy Online Pick Up In Store, ROPIS = Reserve Online Pick Up In Store.']
  return_method varchar [note: 'The logistics method by which the customer will return the merchandise (ship to distribution center, drop at store, carrier pickup from customer location, or direct return to vendor).']
  return_reason_code varchar [note: 'Standardized code representing the primary reason for the return (e.g., defective, wrong item, size issue, customer remorse, damaged in transit).']
  return_reason_description varchar [note: 'Detailed textual description of the reason for return, providing additional context beyond the standardized reason code.']
  return_shipping_cost decimal(15,2) [note: 'Cost of shipping the returned merchandise back to the retailer, which may be borne by customer or retailer depending on return reason and policy.']
  return_shipping_paid_by varchar [note: 'Indicates which party is responsible for paying the return shipping cost.']
  return_type varchar [note: 'The type of resolution requested or authorized for this return: full refund to original payment method, exchange for different item, store credit, or replacement of defective item.']
  rma_number varchar [note: 'Externally-visible unique business identifier for the return authorization issued to the customer. Used in customer communications and tracking.']
  rma_status varchar [note: 'Current lifecycle status of the RMA. Tracks progression from initial request through final disposition. [ENUM-REF-CANDIDATE: pending|authorized|received|inspected|approved|denied|closed|cancelled|expired — 9 candidates stripped; promote to reference product]']
  store_credit_issued_amount decimal(15,2) [note: 'The amount of store credit issued to the customer as part of the return resolution.']

  Note: 'Return Merchandise Authorization master record representing the formal authorization issued to a customer to return one or more items. Captures the RMA number, originating order reference, customer identity, return channel (in-store, online, BOPIS), authorization date, expiry date, return reason code, return type (refund, exchange, store credit), total expected return value, and current RMA status (pending, authorized, received, closed, denied). Primary master entity for the returns domain and the anchor for all downstream return processing workflows.'
}

Table returns.rma_line {
  rma_line_id varchar [pk, note: 'Primary key for rma_line']
  cost_price_id varchar [note: 'Foreign key linking to pricing.cost_price. Business justification: Returns processing requires original landed cost for refund calculations, margin impact analysis, vendor credit determination (RTV), and financial reconciliation. Core operational link between returns']
  dc_facility_id varchar [note: 'Foreign key linking to supplychain.dc_facility. Business justification: Returns processing at DC facilities requires tracking which DC received and inspected returned items for disposition routing, inventory restocking, and warehouse operations. Essential for RTV shipment']
  fulfillment_line_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_line. Business justification: Line-level traceability from return to original fulfillment line enables picker/packer quality scoring, defect tracking by associate, lot/serial reconciliation for recalls, and substitution error anal']
  goods_receipt_id varchar [note: 'Foreign key linking to inventory.goods_receipt. Business justification: Connects returned item to original receipt for cost basis validation, vendor chargeback processing, and defect tracking to specific inbound shipments. Critical for vendor performance management and qu']
  header_id varchar [note: 'Reference to the original sales order from which this item is being returned. Links the return to the originating transaction.']
  lot_id varchar [note: 'Foreign key linking to inventory.lot. Business justification: Lot-tracked returns (food, pharma, cosmetics) require linking to original lot for recall traceability, FEFO compliance, and quality root-cause analysis. Regulatory requirement for perishable goods. En']
  markdown_id varchar [note: 'Foreign key linking to pricing.markdown. Business justification: Markdown-aware refund calculation: items purchased at a marked-down price require the markdown record to validate the correct refund amount (marked_down_price, not original_retail_price). Retail retur']
  original_order_line_id varchar [note: 'Reference to the specific line item on the original sales order. Enables precise traceability from return to original purchase.']
  purchase_order_id varchar [note: 'Foreign key linking to supplychain.purchase_order. Business justification: Return-to-Vendor (RTV) process requires tracing returned rma_line items back to the originating purchase_order for vendor chargeback reconciliation and credit memo processing. Retail buyers and AP tea']
  rma_id varchar [note: 'Foreign key reference to the parent RMA header. Links this line item to the overall return authorization.']
  shipment_package_id varchar [note: 'Foreign key linking to fulfillment.shipment_package. Business justification: Carrier damage claims and package-level insurance recovery require linking the returned item to the specific shipment_package it arrived in. Retail reverse logistics teams file package-level damage cl']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Return lines must reference the product SKU being returned. The product_description column becomes redundant as it can be joined from product.sku. This links returns processing to the product catalog.']
  sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: Refund calculation and return value validation require the original sku_price record used at sale. Links rma_line to the exact retail price for accurate refund amount determination and return value au']
  stock_position_id varchar [note: 'Foreign key linking to inventory.stock_position. Business justification: RMA line authorization requires knowing the stock_position of the returned SKU at the return location to assess restocking capacity and reserved quantities. Drives restocking eligibility decisions and']
  vendor_id varchar [note: 'Supplier identifier for the vendor who originally supplied this product. Used when disposition is Return to Vendor (RTV).']
  vendor_item_id varchar [note: 'Foreign key linking to supplier.vendor_item. Business justification: RTV processing requires the vendor\'s item catalog record to retrieve vendor item number, unit cost, and pack configuration for vendor credit calculation and RTV authorization. rma_line has vendor_id b']
  condition_code varchar [note: 'Physical condition of the item upon receipt at the returns facility. Determines restocking eligibility and disposition path.']
  created_timestamp timestamp [note: 'Date and time when this RMA line record was first created in the system. Audit trail for record creation.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts on this line. Ensures proper currency handling in multi-currency operations.']
  disposition_code varchar [note: 'Final disposition instruction for the returned merchandise. Determines the next step in the reverse logistics workflow (restock to inventory, return to vendor, liquidate, destroy, repair, or donate).']
  extended_cost_amount decimal(15,2) [note: 'Total cost value for this line (quantity × unit cost). Used for inventory and cost of goods sold adjustments.']
  extended_retail_amount decimal(15,2) [note: 'Total retail value for this line (quantity × unit retail price). Represents the total refund exposure for this line item.']
  gtin varchar [note: '14-digit Global Trade Item Number for the returned product. International standard for product identification across supply chains.']
  inspection_date date [note: 'Date when the returned item was physically inspected and condition assessed. Key milestone in the returns processing workflow.']
  last_modified_timestamp timestamp [note: 'Date and time when this RMA line record was last updated. Audit trail for tracking changes to return line details.']
  line_number varchar [note: 'Sequential line number within the RMA. Determines the ordering and position of this item in the multi-item return authorization.']
  line_status varchar [note: 'Current processing status of this RMA line item. Tracks the line through the returns workflow from authorization through final disposition. [ENUM-REF-CANDIDATE: AUTHORIZED|RECEIVED|INSPECTED|PROCESSED|RESTOCKED|COMPLETED|CANCELLED — 7 candidates stripped; promote to reference product]']
  liquidation_sale_amount decimal(15,2) [note: 'Amount recovered from selling the returned item through liquidation channels (discount outlets, third-party liquidators, online auctions). Used to calculate net return loss.']
  quantity_authorized varchar [note: 'Number of units authorized for return on this RMA line. Represents the maximum quantity the customer is permitted to return.']
  quantity_received varchar [note: 'Actual number of units physically received back from the customer for this line item. May differ from quantity authorized.']
  refund_amount decimal(15,2) [note: 'Actual amount refunded to the customer for this line item. May differ from extended retail amount due to restocking fees, partial returns, or prorated refunds.']
  restocking_eligible_flag boolean [note: 'Indicates whether the returned item is in suitable condition to be restocked and resold. True if item can return to sellable inventory.']
  restocking_fee_amount decimal(15,2) [note: 'Fee charged to the customer for processing the return of this line item. May be waived based on return reason or customer status.']
  return_reason_code varchar [note: 'Standardized code indicating why the customer is returning this item. Used for root cause analysis and quality improvement initiatives. [ENUM-REF-CANDIDATE: DEFECTIVE|DAMAGED|WRONG_ITEM|NOT_AS_DESCRIBED|CHANGED_MIND|SIZE_FIT|DUPLICATE_ORDER|LATE_DELIVERY|OTHER — 9 candidates stripped; promote to reference product]']
  return_reason_description varchar [note: 'Free-text explanation of the return reason provided by the customer or service representative. Provides additional context beyond the standardized code.']
  rtv_authorization_number varchar [note: 'Vendor-issued authorization number permitting the return of defective or excess merchandise back to the supplier. Required for vendor chargeback processing.']
  sku varchar [note: 'Internal stock keeping unit identifier for the product being returned. Used for inventory tracking and product identification.']
  unit_cost decimal(15,2) [note: 'Cost of goods sold per unit. Used for inventory valuation adjustments and margin analysis on returned merchandise.']
  upc varchar [note: '12-digit Universal Product Code for the returned item. Standard barcode identifier used in North American retail.']
  vendor_credit_amount decimal(15,2) [note: 'Credit amount expected or received from the vendor for this returned item. Used in accounts payable adjustments and vendor chargeback reconciliation.']
  warehouse_location_code varchar [note: 'Code identifying the distribution center or warehouse location where the returned item was received and processed.']

  Note: 'Individual line-item detail within an RMA, representing a single SKU being returned. Captures the SKU, UPC, GTIN, product description, quantity authorized versus quantity received, unit retail price, unit cost, return reason at the line level, condition code upon receipt (new, opened, damaged, defective), restocking eligibility flag, and disposition instruction. Enables granular tracking of each item in a multi-item return authorization.'
}

Table returns.return_request {
  return_request_id varchar [pk, note: 'Unique identifier for the return request. Primary key for the return request entity.']
  header_id varchar [note: 'Identifier of the original order from which items are being returned.']
  location_id varchar [note: 'Identifier of the store location where the customer intends to return the items, if in-store return method is selected.']
  order_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_order. Business justification: Return requests reference specific fulfillment to identify shipping damage, wrong item picked, or carrier issues during pre-authorization. Enables fraud detection based on fulfillment method patterns ']
  order_line_id varchar [note: 'Foreign key linking to order.order_line. Business justification: Line-level return eligibility: return requests are filed per item, requiring line-level return window validation, per-SKU return policy enforcement, and customer service tooling. Existing FK is header']
  pickup_address_id varchar [note: 'Identifier of the address from which the return items should be picked up, if pickup was requested.']
  profile_id varchar [note: 'Identifier of the customer who initiated the return request.']
  return_policy_id varchar [note: 'Foreign key linking to returns.return_policy. Business justification: A return request is evaluated and processed under a specific return policy. The return_request table currently stores return_policy_code as a denormalized string. Adding return_policy_id as a FK to re']
  rma_id varchar [note: 'Foreign key linking to returns.rma. Business justification: Return request is the customer-initiated intent to return merchandise before formal RMA authorization. Once approved, a return_request results in an RMA (formal authorization). Currently, return_reque']
  shipment_id varchar [note: 'Foreign key linking to fulfillment.shipment. Business justification: Return label generation and return eligibility validation require the original shipment\'s carrier service, tracking number, and ship date. Retail customer service workflows use shipment data to auto-g']
  web_session_id varchar [note: 'Foreign key linking to ecommerce.web_session. Business justification: Online return requests initiated via the ecommerce storefront are tied to a web session, enabling return request abandonment analytics, session-based fraud detection, and channel attribution reporting']
  approval_timestamp timestamp [note: 'Date and time when the return request was approved, triggering the generation of an RMA (Return Merchandise Authorization).']
  created_timestamp timestamp [note: 'Timestamp when this return request record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the estimated refund amount (e.g., USD, EUR, GBP).']
  customer_contact_email varchar [note: 'Email address provided by the customer for communication regarding this return request.']
  customer_contact_phone varchar [note: 'Phone number provided by the customer for communication regarding this return request.']
  denial_reason_code varchar [note: 'Standardized code indicating the reason for denial if the return request was rejected (e.g., outside return window, final sale item, missing proof of purchase, item condition not acceptable).']
  denial_reason_description varchar [note: 'Detailed explanation provided to the customer explaining why the return request was denied.']
  denial_timestamp timestamp [note: 'Date and time when the return request was denied, if applicable.']
  estimated_refund_amount decimal(15,2) [note: 'Estimated monetary value of the refund if the return request is approved, calculated based on original purchase price and applicable return policy rules.']
  fraud_flag boolean [note: 'Boolean flag indicating whether this return request has been flagged for potential fraud and requires additional verification before approval.']
  fraud_risk_score decimal(5,2) [note: 'Calculated risk score (0-100) indicating the likelihood that this return request is fraudulent, based on customer history, return patterns, and fraud detection algorithms.']
  is_within_return_window boolean [note: 'Boolean flag indicating whether the return request was submitted within the eligible return window defined by the applicable return policy.']
  last_updated_timestamp timestamp [note: 'Timestamp when this return request record was last modified.']
  original_purchase_date date [note: 'Date when the original order was placed, used to validate return eligibility against return window policies.']
  pickup_requested_flag boolean [note: 'Boolean flag indicating whether the customer has requested carrier pickup of the return items from their location.']
  preferred_resolution_type varchar [note: 'Customer-indicated preference for how they would like the return to be resolved (refund to original payment method, exchange for different item, store credit, or replacement of same item).']
  priority_level varchar [note: 'Priority classification for processing this return request, typically based on customer tier, order value, or issue severity.']
  request_channel varchar [note: 'Channel through which the customer submitted the return request (e-commerce portal, mobile app, call center, in-store associate, chatbot, email).']
  request_number varchar [note: 'Human-readable business identifier for the return request, typically displayed to customers and service representatives. Format: RR followed by 10 digits.']
  request_status varchar [note: 'Current lifecycle status of the return request in the approval workflow.']
  request_timestamp timestamp [note: 'Date and time when the customer initiated the return request. Represents the principal business event timestamp for this transaction.']
  return_method varchar [note: 'Method by which the customer will return the merchandise (carrier pickup, drop-off at designated location, in-store return, mail).']
  return_reason_code varchar [note: 'Standardized code representing the customer-stated reason for the return (e.g., defective, wrong item, size issue, changed mind, damaged in transit).']
  return_reason_description varchar [note: 'Detailed free-text description provided by the customer explaining the reason for the return.']
  return_window_expiry_date date [note: 'Last date by which the return request must be submitted to be eligible under the applicable return policy (typically 30, 60, or 90 days from purchase).']
  review_notes varchar [note: 'Internal notes added by the returns specialist during the review process, documenting decision rationale, policy exceptions, or special handling instructions.']
  sla_response_due_timestamp timestamp [note: 'Target date and time by which the return request must be reviewed and responded to, based on applicable SLA (Service Level Agreement) commitments.']
  source_system_code varchar [note: 'Code identifying the source system from which this return request originated (e.g., Salesforce Service Cloud, e-commerce platform, store POS system).']
  total_items_requested varchar [note: 'Total count of distinct line items included in this return request.']
  total_quantity_requested varchar [note: 'Total quantity of units across all line items requested for return.']

  Note: 'Customer-initiated return request capturing the initial intent to return merchandise before formal RMA authorization. Records the request channel (e-commerce portal, store associate, call center), request timestamp, customer-stated reason, items and quantities requested for return, preferred resolution type (refund, exchange, store credit), and request status (submitted, under review, approved, denied). Serves as the intake record that triggers the RMA authorization workflow.'
}

Table returns.return_receipt {
  return_receipt_id varchar [pk, note: 'Unique identifier for the return receipt record. Primary key.']
  carrier_id varchar [note: 'Identifier of the shipping carrier that delivered the returned merchandise. Applicable for mail-in and shipped returns.']
  dc_facility_id varchar [note: 'Foreign key linking to supplychain.dc_facility. Business justification: Return receipts at DC facilities (vs store locations) require facility tracking for receiving dock scheduling, inspection workflow routing, quality hold processing, and disposition decision execution.']
  goods_receipt_id varchar [note: 'Foreign key linking to inventory.goods_receipt. Business justification: Links return receipt to original inbound receipt for discrepancy analysis, vendor performance scoring, and cost basis validation. Retail operations use this for vendor chargeback processing and qualit']
  header_id varchar [note: 'Identifier of the original sales order from which the returned merchandise originated. Links return to original transaction.']
  inventory_node_id varchar [note: 'Foreign key linking to inventory.inventory_node. Business justification: Return receipts are physically received at specific nodes. Required for receiving workflow orchestration, location-level return volume metrics, staffing planning, and dock door scheduling. Retail oper']
  order_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_order. Business justification: Return receipts must link to original fulfillment for closed-loop cycle time analysis (order→fulfill→return→receipt), reverse logistics SLA measurement, and carrier damage claim validation. Enables co']
  profile_id varchar [note: 'Identifier of the customer who initiated the return. Used for return analytics, fraud detection, and customer service.']
  receiving_location_id varchar [note: 'Identifier of the store, distribution center, or micro-fulfillment center where the returned merchandise was received.']
  rma_id varchar [note: 'Reference to the RMA that authorized this return. Links the physical receipt event to the return authorization.']
  shipment_id varchar [note: 'Foreign key linking to fulfillment.shipment. Business justification: Return receipt reconciliation requires the original outbound shipment to validate carrier charges, confirm what was shipped, and support carrier damage/insurance claims. Retail operations teams run sh']
  stock_position_id varchar [note: 'Foreign key linking to inventory.stock_position. Business justification: When returned goods arrive at a receiving node, warehouse staff must check the current stock_position for that SKU to determine putaway capacity and restocking eligibility. This link supports receivin']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: return_receipt.quantity_unit_of_measure is a denormalized plain string. Normalizing to a UOM FK enables accurate quantity reconciliation in receiving operations — a named retail process where received']
  authorized_quantity decimal(15,3) [note: 'Total quantity of items authorized for return in the original RMA. Used to detect over-returns and under-returns.']
  carrier_tracking_number varchar [note: 'Tracking number from the shipping carrier for mail-in or shipped returns. Used to reconcile carrier delivery events with physical receipt.']
  condition_assessment varchar [note: 'Assessment of the physical condition of the returned merchandise at the time of receipt. Drives disposition decision and restocking eligibility. [ENUM-REF-CANDIDATE: new_unopened|like_new|good|fair|poor|damaged|defective|unsellable — 8 candidates stripped; promote to reference product]']
  created_timestamp timestamp [note: 'Timestamp when this return receipt record was first created in the data platform. Audit trail for data lineage.']
  discrepancy_flag boolean [note: 'Indicates whether a discrepancy was detected between authorized and received items. Triggers exception handling workflows.']
  discrepancy_notes varchar [note: 'Free-text notes describing the nature of the discrepancy. Provides context for exception resolution and audit trail.']
  discrepancy_type varchar [note: 'Classification of the discrepancy detected at receipt. Determines resolution workflow and financial adjustments.']
  disposition_recommendation varchar [note: 'Recommended disposition action for the returned merchandise based on condition, value, and business rules. May be overridden by final disposition decision. [ENUM-REF-CANDIDATE: restock|liquidate|donate|destroy|rtv|repair|pending — 7 candidates stripped; promote to reference product]']
  estimated_recovery_value decimal(15,2) [note: 'Estimated financial recovery value of the returned merchandise based on condition and disposition recommendation. Used for financial planning and shrinkage analysis.']
  inspection_completed_timestamp timestamp [note: 'Date and time when detailed quality inspection was completed. Null if inspection not required or not yet performed.']
  inspection_required_flag boolean [note: 'Indicates whether detailed quality inspection is required before disposition. Triggered by high-value items, electronics, or condition concerns.']
  last_updated_timestamp timestamp [note: 'Timestamp when this return receipt record was last modified in the data platform. Audit trail for change tracking.']
  packaging_condition varchar [note: 'Condition of the product packaging at receipt. Impacts resale value and disposition options.']
  receipt_number varchar [note: 'Business-facing unique receipt number generated when returned merchandise is physically received. Used for tracking and customer communication.']
  receipt_source_system varchar [note: 'Name of the operational system that captured the return receipt event. Supports data lineage and reconciliation.']
  receipt_source_system_code varchar [note: 'Unique identifier of this receipt record in the source operational system. Enables traceability and reconciliation.']
  receipt_status varchar [note: 'Current lifecycle status of the return receipt. Tracks progression from initial receipt through inspection and final disposition decision.']
  receipt_timestamp timestamp [note: 'Date and time when the returned merchandise was physically received at the receiving location. Primary business event timestamp for the receipt.']
  received_quantity decimal(15,3) [note: 'Actual quantity of items physically received at the receiving location. Compared against authorized quantity to flag discrepancies.']
  receiving_location_type varchar [note: 'Type of facility that received the returned merchandise. Determines downstream processing workflows and disposition options.']
  recovery_value_currency_code varchar [note: 'Three-letter ISO 4217 currency code for the estimated recovery value. Supports multi-currency operations.']
  refund_hold_reason varchar [note: 'Reason why customer refund is being held pending resolution. Null or none if refund processed immediately upon receipt.']
  refund_triggered_flag boolean [note: 'Indicates whether the receipt event triggered a customer refund workflow. Links physical receipt to financial refund processing.']
  restocking_eligible_flag boolean [note: 'Indicates whether the returned merchandise is eligible for restocking and resale. Based on condition assessment and business rules.']
  return_method varchar [note: 'Method by which the customer returned the merchandise. Determines receipt workflow and processing requirements.']

  Note: 'Physical or digital receipt record generated when returned merchandise is received at a store, DC, or MFC. Captures the receiving location, receiving associate, receipt timestamp, carrier tracking number (for mail-in returns), actual items and quantities received versus authorized, condition assessment at receipt, discrepancy flags (over-return, under-return, wrong item), and receipt status. Links the physical goods receipt event to the RMA and triggers downstream disposition and refund workflows.'
}

Table returns.disposition {
  disposition_id varchar [pk, note: 'Unique identifier for the disposition record. Primary key for the disposition entity.']
  adjustment_id varchar [note: 'Foreign key linking to inventory.adjustment. Business justification: Every disposition action (restock, destroy, liquidate) triggers an inventory adjustment. Linking disposition to the resulting adjustment record closes the audit trail for shrinkage recovery accounting']
  cost_price_id varchar [note: 'Foreign key linking to pricing.cost_price. Business justification: Disposition decisions (restock vs liquidate vs RTV) require comparing estimated recovery value to original landed cost. Drives financial optimization of returned inventory. Removes denormalized origin']
  dc_facility_id varchar [note: 'Foreign key linking to supplychain.dc_facility. Business justification: Disposition decisions (restock/liquidate/RTV/scrap) execute at specific DC facilities. Tracking the facility is required for inventory movements, warehouse task generation, and GL posting. Replaces de']
  disposition_liquidation_partner_vendor_id varchar [note: 'Identifier of the third-party liquidation partner if disposition type is liquidation. Tracks which liquidator handled the item for recovery value reconciliation.']
  disposition_vendor_id varchar [note: 'Identifier of the vendor to whom the item will be returned if disposition type is return_to_vendor. Used for vendor compliance and credit processing.']
  inventory_node_id varchar [note: 'Foreign key linking to inventory.inventory_node. Business justification: Disposition decisions execute at specific locations (restock at DC, liquidate at warehouse, RTV from store). Needed for location-level recovery rate tracking, disposition capacity planning, and networ']
  inventory_stock_ledger_id varchar [note: 'Foreign key linking to inventory.stock_ledger. Business justification: Return dispositions (restock, liquidate, destroy) generate inventory transactions that should be tracked in the stock ledger. This links returns disposition decisions to inventory accounting. No visib']
  lot_id varchar [note: 'Foreign key linking to inventory.lot. Business justification: Lot-tracked dispositions enable batch-level quality analysis, vendor chargeback validation, and compliance documentation for perishable/regulated goods. Retail operations require lot linkage for vendo']
  outbound_order_id varchar [note: 'Foreign key linking to supplychain.outbound_order. Business justification: RTV and liquidation disposition types trigger outbound_order creation to ship disposed goods from DC to vendor or liquidator. Supply chain operations track which outbound_order executed each dispositi']
  restock_location_id varchar [note: 'Foreign key linking to store.location. Business justification: Disposition decisions route returned goods to a specific store location for restocking. restock_location_code is a denormalized plain-text field on disposition; replacing it with a proper FK to store.']
  return_receipt_id varchar [note: 'Foreign key linking to returns.return_receipt. Business justification: Disposition decisions are made AFTER physical receipt and inspection of returned merchandise. The disposition table currently links to rma_line but has no direct reference to the return_receipt event ']
  rma_line_id varchar [note: 'Reference to the specific return line item that this disposition decision applies to. Links disposition to the originating return merchandise authorization line.']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Disposition records track returned item fate (restock, liquidate, destroy). The plain \'sku\' column is a denormalized string. A proper FK enables recovery value analysis by SKU, vendor return authoriza']
  sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: Recovery rate reporting (actual_recovery_value / original retail price) is a standard returns KPI. Linking disposition to sku_price enables margin recovery analysis by comparing recovery value against']
  stock_position_id varchar [note: 'Foreign key linking to inventory.stock_position. Business justification: Restocking disposition decisions require linking to the exact stock_position being replenished. Drives inventory accuracy reporting, restocking SLA tracking, and on-hand quantity reconciliation after ']
  stock_transfer_id varchar [note: 'Foreign key linking to inventory.stock_transfer. Business justification: Disposition type \'transfer\' (e.g., to liquidation DC, refurbishment center, or alternate node) generates a stock_transfer record. Linking disposition to the resulting transfer provides end-to-end trac']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: disposition.unit_of_measure is a denormalized plain string. Normalizing to a UOM FK enables accurate recovery quantity reporting, vendor return authorization (RTV quantities must be in vendor-agreed U']
  vendor_contract_id varchar [note: 'Foreign key linking to supplier.vendor_contract. Business justification: RTV disposition processing must reference the governing vendor contract to apply correct credit terms, RTV authorization requirements, and return-to-vendor policy. disposition has disposition_vendor_i']
  vendor_item_id varchar [note: 'Foreign key linking to supplier.vendor_item. Business justification: RTV disposition requires the vendor item record to calculate accurate recovery value against vendor cost and to validate vendor pack/case configurations. disposition has disposition_vendor_id and a de']
  actual_recovery_value decimal(15,2) [note: 'Realized financial recovery value after disposition execution. Populated after liquidation sale, vendor credit, or restock completion. Used for variance analysis against estimates.']
  completion_date date [note: 'Date when the disposition action was fully executed (item restocked, shipped to vendor, transferred to liquidator, or destroyed). Used for cycle time measurement.']
  condition_grade varchar [note: 'Quality assessment grade assigned during inspection. A=New/Unopened, B=Like New/Minor Packaging Damage, C=Good/Visible Wear, D=Fair/Functional Defects, F=Unsellable/Damaged. Drives disposition type and recovery value estimation.']
  created_timestamp timestamp [note: 'Timestamp when this disposition record was first created in the system. Used for audit trail and data lineage tracking.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for recovery value amounts. Supports multi-currency operations for global retail operations.']
  decision_date date [note: 'The date when the disposition decision was made by the returns processing team or system. Key timestamp for cycle time analytics.']
  decision_timestamp timestamp [note: 'Precise timestamp when the disposition decision was recorded in the system. Used for audit trail and process timing analysis.']
  defect_code varchar [note: 'Standardized code identifying the specific defect or damage type found during inspection. Used for quality analytics and vendor chargeback justification.']
  disposition_status varchar [note: 'Current lifecycle status of the disposition action. Tracks progress from decision through execution.']
  disposition_type varchar [note: 'The final fate decision for the returned item. Determines the next step in the reverse logistics workflow and impacts inventory valuation and recovery value.']
  estimated_recovery_value decimal(15,2) [note: 'Projected financial recovery value for the item based on disposition type and condition grade. Used for shrinkage forecasting and reverse logistics ROI analysis.']
  inspection_date date [note: 'Date when the returned item was physically inspected and condition grade was assigned. Precedes disposition decision date.']
  is_hazmat boolean [note: 'Flag indicating whether the returned item is classified as hazardous material requiring special disposition handling and compliance with EPA and DOT regulations.']
  is_serialized boolean [note: 'Flag indicating whether the item has a unique serial number requiring individual tracking through disposition process. Common for electronics and high-value goods.']
  modified_timestamp timestamp [note: 'Timestamp when this disposition record was last updated. Tracks changes to disposition decisions or status updates.']
  notes varchar [note: 'Free-text notes from the returns processor providing additional context about the disposition decision, item condition, or special handling requirements.']
  quantity varchar [note: 'Number of units of the SKU being dispositioned under this record. Typically 1 for individual item returns, may be greater for bulk returns.']
  reason_code varchar [note: 'Standardized code indicating the primary reason for the disposition decision. Used for root cause analysis and process improvement.']
  restocking_fee_amount decimal(10,2) [note: 'Dollar amount of restocking fee charged if restocking_fee_applied is true. Contributes to reverse logistics cost recovery.']
  restocking_fee_applied boolean [note: 'Flag indicating whether a restocking fee was charged to the customer for this return. Impacts refund amount and customer satisfaction metrics.']
  rma_number varchar [note: 'The return merchandise authorization number associated with this disposition. Links to the customer-facing return authorization.']
  serial_number varchar [note: 'Unique serial number of the returned item if is_serialized is true. Used for warranty tracking, theft prevention, and individual item lifecycle management.']

  Note: 'Disposition record governing the final fate of each returned item after receipt and inspection. Captures disposition type (restock to sellable inventory, restock to clearance, return to vendor via RTV, liquidation, donation, destruction/write-off), decision date, disposition location, responsible associate, estimated and actual recovery value, and disposition status. Central to reverse logistics cost recovery, shrinkage management, and inventory reintegration decisions. Now also carries condition grade assessment (A-New through F-Unsellable) previously in a separate reference table.'
}

Table returns.refund {
  refund_id varchar [pk, note: 'Primary key for refund']
  header_id varchar [note: 'Reference to the original sales order that is being refunded. Enables traceability to the original purchase transaction.']
  location_id varchar [note: 'Reference to the retail store location where the refund was processed, if applicable. Used for store-level financial reconciliation and performance analysis.']
  original_digital_payment_id varchar [note: 'Foreign key linking to ecommerce.digital_payment. Business justification: Refund-to-original-payment-method routing is a core retail finance process. Linking refund to the originating digital_payment enables payment method validation for refund routing, fraud detection (com']
  payment_id varchar [note: 'Foreign key linking to order.payment. Business justification: Refund-to-original-payment reversal process: finance and payment operations teams must trace each refund back to the original payment instrument to execute card reversals, digital wallet credits, or B']
  payment_method_id decimal(18,2) [note: 'Foreign key linking to customer.payment_method. Business justification: Retail refund processing requires \'refund to original payment method\' — a named PCI-compliance and customer service process. Associates the refund record with the specific tokenized payment instrument']
  pos_terminal_id varchar [note: 'Foreign key linking to store.pos_terminal. Business justification: In-store refunds are executed at a specific POS terminal, which is mandatory for PCI-DSS audit trails, end-of-day cash drawer reconciliation, and terminal-level refund fraud detection. Retail finance ']
  pos_transaction_id varchar [note: 'Foreign key linking to order.pos_transaction. Business justification: In-store refund reconciliation: refunds processed at POS must reference the POS transaction for daily cash drawer reconciliation, store-level refund reporting, and audit trail requirements. Retail fin']
  price_change_id varchar [note: 'Foreign key linking to pricing.price_change. Business justification: Price adjustment refund processing: when a customer requests a refund due to a post-purchase price drop (price protection policy), the refund must reference the triggering price_change record for audi']
  profile_id varchar [note: 'Reference to the customer receiving the refund. Links refund to customer master data for reconciliation and customer lifetime value analysis.']
  promo_redemption_id varchar [note: 'Foreign key linking to promotion.promo_redemption. Business justification: Refund processing must reference original promotional redemption to calculate correct refund amount (excluding promotional discount), update vendor funding obligations, and enforce promotional terms. ']
  return_receipt_id varchar [note: 'Foreign key linking to returns.return_receipt. Business justification: Refunds are triggered by the physical receipt and inspection of returned goods — return_receipt has a refund_triggered_flag and refund_hold_reason indicating it directly initiates refund processing. T']
  return_request_id varchar [note: 'Reference to the parent return transaction that triggered this refund. Links refund to the originating return merchandise authorization (RMA).']
  rma_id varchar [note: 'FK to returns.rma.rma_id — Refund to RMA linkage is required for return financial reconciliation — every refund must trace back to its authorizing RMA for audit and financial controls.']
  sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: Refund audit and price-based refund policy enforcement require linking each refund to the original sku_price record. Enables finance reconciliation reports validating that merchandise_amount matches t']
  actual_settlement_date date [note: 'Actual date when the refund funds were confirmed as settled and available to the customer. Used for SLA compliance measurement and financial reconciliation. Format: yyyy-MM-dd.']
  adjustment_amount decimal(15,2) [note: 'Additional positive or negative adjustment applied to the refund for reasons such as damage, missing components, promotional credits, or goodwill gestures.']
  approved_timestamp timestamp [note: 'Date and time when the refund was approved by authorized personnel or automated business rules. Represents authorization milestone in the refund workflow. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  authorization_code varchar [note: 'Unique authorization or approval code issued by the payment processor confirming the refund transaction was approved. Used for audit trail and dispute resolution.']
  channel varchar [note: 'The customer-facing channel or touchpoint through which the refund was initiated and processed. Enables omnichannel analytics and channel performance measurement.']
  completed_timestamp timestamp [note: 'Date and time when the refund was successfully completed and funds were transferred to the customer. Represents final settlement of the refund transaction. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  created_timestamp timestamp [note: 'System timestamp when this refund record was first created in the database. Used for data lineage and audit trail. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts in this refund transaction. Ensures proper financial reconciliation in multi-currency operations.']
  expected_settlement_date date [note: 'Anticipated date when the refund funds will be available to the customer in their account. Used for customer communication and service level agreement (SLA) tracking. Format: yyyy-MM-dd.']
  fraud_score decimal(5,2) [note: 'Numerical fraud risk score assigned by fraud detection system, typically ranging from 0 to 100. Higher scores indicate higher fraud risk. Used for risk-based decisioning.']
  initiated_timestamp timestamp [note: 'Date and time when the refund transaction was first created or initiated in the system. Marks the beginning of the refund lifecycle. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  is_fraudulent boolean [note: 'Boolean flag indicating whether the refund was identified as fraudulent or suspicious. Used for fraud analytics and loss prevention reporting.']
  merchandise_amount decimal(15,2) [note: 'The gross value of returned merchandise being refunded, before any fees, taxes, or adjustments. Represents the base product value from the original transaction.']
  method varchar [note: 'The financial instrument or mechanism used to issue the refund to the customer. Determines processing workflow and reconciliation requirements.']
  notes varchar [note: 'Free-text notes or comments entered by customer service representatives or system users providing additional context about the refund transaction.']
  payment_processor varchar [note: 'Name of the payment gateway or financial institution processing the refund transaction. Used for reconciliation and troubleshooting payment failures.']
  processed_timestamp timestamp [note: 'Date and time when the refund was submitted to the payment processor for execution. Indicates when the financial transaction was initiated. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  processor_response_code varchar [note: 'Standardized response code returned by the payment processor indicating success, failure, or specific error condition. Used for operational monitoring and troubleshooting.']
  processor_response_message varchar [note: 'Human-readable message from the payment processor providing additional context about the transaction result. Used for customer service and technical support.']
  reason_code varchar [note: 'Standardized code indicating the business reason for issuing the refund. Used for root cause analysis, quality management, and vendor chargeback processing. Format: AAA999.']
  reason_description varchar [note: 'Detailed textual explanation of why the refund was issued. Provides context beyond the standardized reason code for customer service and quality analysis.']
  refund_number varchar [note: 'Human-readable business identifier for the refund transaction. Used for customer communication, customer service lookup, and external reporting. Format: RFN-XXXXXXXXXX.']
  refund_status varchar [note: 'Current lifecycle status of the refund transaction. Tracks progression from initiation through final settlement or failure. Used for operational monitoring and customer service inquiries. [ENUM-REF-CANDIDATE: pending|approved|processing|completed|failed|reversed|cancelled — 7 candidates stripped; promote to reference product]']
  refund_type varchar [note: 'Classification of the refund based on the portion of the original transaction being refunded and any adjustments applied.']
  restocking_fee decimal(15,2) [note: 'Fee deducted from the refund amount to cover costs of processing, inspecting, and restocking returned merchandise. Applied per return policy terms.']
  shipping_amount decimal(15,2) [note: 'The shipping or delivery fee amount being refunded, if applicable per return policy. May be zero if shipping is non-refundable.']
  tax_amount decimal(15,2) [note: 'The sales tax or value-added tax (VAT) amount being refunded to the customer. Must align with original tax calculation and jurisdiction requirements.']
  total_refund_amount decimal(15,2) [note: 'The final net amount refunded to the customer after all fees, taxes, and adjustments. This is the actual monetary value transferred back to the customer.']
  transaction_reference varchar [note: 'External transaction identifier or reference number from the payment processor. Links internal refund record to external payment system for reconciliation.']
  updated_timestamp timestamp [note: 'System timestamp when this refund record was last modified. Used for change tracking and data quality monitoring. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']

  Note: 'Financial refund transaction record representing the monetary reimbursement issued to a customer as resolution of a return. Captures refund method (original payment method, store credit, gift card, check), refund amount, restocking fee deducted, original transaction reference, refund authorization code, processing timestamp, refund status (pending, processed, failed, reversed), and payment processor response. Integrates with financial accounting for accounts payable and revenue reversal under ASC 606.'
}

Table returns.exchange_order {
  exchange_order_id varchar [pk, note: 'Unique identifier for the exchange order. Primary key.']
  fulfillment_node_id varchar [note: 'Reference to the distribution center, store, or fulfillment location from which the replacement item will be shipped.']
  location_id varchar [note: 'Reference to the retail store location where the exchange was initiated or will be fulfilled, if applicable.']
  primary_exchange_header_id varchar [note: 'Reference to the original order from which the returned item originated.']
  profile_id varchar [note: 'Reference to the customer who initiated the exchange.']
  refund_id varchar [note: 'Foreign key linking to returns.refund. Business justification: Exchange orders frequently involve a monetary component — when the replacement item has a different price than the returned item, a partial refund or charge differential is processed. The exchange_ord']
  replacement_fulfillment_order_id varchar [note: 'Foreign key linking to fulfillment.fulfillment_order. Business justification: Exchange processing creates a new fulfillment order for the replacement item. Linking exchange_order to the replacement fulfillment_order enables exchange fulfillment SLA tracking, exchange completion']
  replacement_sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Exchange fulfillment requires direct replacement SKU reference for inventory allocation, ATP (available-to-promise) checking, and like-for-like exchange policy enforcement. Essential for retail exchan']
  replacement_sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: Exchange price differential calculation requires the replacement SKU\'s current sku_price record. Role-prefix \'replacement_\' distinguishes this from the returned item\'s price. price_differential_amount']
  shipping_address_id varchar [note: 'Foreign key linking to customer.address. Business justification: Exchange orders require a shipping address for replacement item delivery. Fulfillment operations depend on this link to route exchange shipments correctly. While exchange_order.profile_id provides ind']
  stock_position_id varchar [note: 'Foreign key linking to inventory.stock_position. Business justification: Exchange order fulfillment requires checking and reserving replacement SKU inventory against a specific stock_position. Links the exchange to the exact inventory position being committed, supporting a']
  created_timestamp timestamp [note: 'Date and time when the exchange order record was first created in the system.']
  exchange_approved_timestamp timestamp [note: 'Date and time when the exchange request was approved by the returns management system or customer service representative.']
  exchange_completed_timestamp timestamp [note: 'Date and time when the entire exchange transaction was finalized, including receipt of returned item and delivery of replacement.']
  exchange_delivered_timestamp timestamp [note: 'Date and time when the replacement item was successfully delivered to the customer.']
  exchange_initiated_date date [note: 'Date when the customer first requested the exchange, typically when the RMA was created.']
  exchange_order_number varchar [note: 'Human-readable business identifier for the exchange order, used for customer communication and tracking.']
  exchange_order_status varchar [note: 'Current lifecycle status of the exchange order in the fulfillment workflow. [ENUM-REF-CANDIDATE: pending|approved|processing|shipped|delivered|completed|cancelled — 7 candidates stripped; promote to reference product]']
  exchange_reason_code varchar [note: 'Standardized code indicating the primary reason the customer requested an exchange rather than a refund.']
  exchange_reason_description varchar [note: 'Free-text description providing additional context about why the customer requested an exchange.']
  exchange_shipped_timestamp timestamp [note: 'Date and time when the replacement item was shipped to the customer.']
  exchange_source_channel varchar [note: 'Channel through which the customer initiated the exchange request.']
  exchange_type varchar [note: 'Classification of the exchange based on the relationship between returned and replacement items.']
  expedited_shipping_flag boolean [note: 'Indicates whether expedited shipping was used for the replacement item delivery.']
  fulfillment_channel varchar [note: 'Method by which the replacement item will be delivered to the customer.']
  last_updated_timestamp timestamp [note: 'Date and time when the exchange order record was most recently modified.']
  price_differential_currency_code varchar [note: 'ISO 4217 three-letter currency code for the price differential amount.']
  refund_amount decimal(15,2) [note: 'Amount to be refunded to the customer if the replacement item costs less than the returned item (downgrade scenario).']
  refund_method varchar [note: 'Method by which any refund amount will be returned to the customer.']
  replacement_quantity varchar [note: 'Number of units of the replacement SKU being sent to the customer.']
  returned_quantity varchar [note: 'Number of units of the returned SKU being sent back by the customer.']
  returned_sku varchar [note: 'SKU of the product being returned by the customer as part of the exchange.']
  shipping_cost_waived_flag boolean [note: 'Indicates whether shipping costs for the replacement item have been waived as a customer service gesture.']
  special_instructions varchar [note: 'Free-text field for any special handling instructions or notes related to the exchange order.']

  Note: 'Exchange order created when a return is resolved via product replacement rather than monetary refund. Captures the originating RMA reference, replacement SKU(s) and quantities, price differential (upgrade or downgrade), exchange order status, fulfillment channel (ship-to-home, in-store pickup, curbside), and the linked replacement order identifier. Enables tracking of exchange fulfillment as a distinct resolution path separate from standard order flow.'
}

Table returns.return_policy {
  return_policy_id varchar [pk, note: 'Unique identifier for the return policy record. Primary key.']
  brand_id varchar [note: 'Foreign key linking to product.product_brand. Business justification: Brand-specific return policies are a named retail process — luxury brands enforce strict no-return rules, private label brands offer extended windows, licensed brands have contractual return restricti']
  cluster_id varchar [note: 'Foreign key linking to store.cluster. Business justification: High-shrinkage or high-fraud store clusters require stricter return policies. Cluster-scoped return policies are a standard retail loss-prevention practice — policy teams assign tighter return windows']
  format_id varchar [note: 'Foreign key linking to store.format. Business justification: Retail return policies are scoped by store format — outlet stores enforce stricter no-return rules than full-price formats. Format-specific policy assignment drives policy selection logic and is a sta']
  item_hierarchy_id varchar [note: 'Foreign key linking to product.item_hierarchy. Business justification: Return policies vary by merchandise category (electronics 30-day vs apparel 90-day vs grocery no-return). Essential for POS policy enforcement, return window calculation, restocking fee application, a']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: Return policies are scoped to specific price lists in retail operations — clearance/markdown price list items have restricted return windows, while full-price list items have standard windows. This li']
  region_id varchar [note: 'Foreign key linking to store.region. Business justification: Regional regulatory compliance (e.g., California consumer protection, EU right-of-return directives) drives region-specific return windows and refund methods. Compliance and legal teams require return']
  segment_id varchar [note: 'Foreign key linking to customer.segment. Business justification: Retail return policies are explicitly differentiated by customer segment (e.g., loyalty members get extended return windows). Normalizing \'customer_segment\' string into a proper FK supports segment-ba']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: SKU-level return policy overrides are a named retail process — hazmat SKUs, age-restricted items, and final-sale products require policies that cannot be expressed at item_hierarchy level alone. Retai']
  accepted_condition varchar [note: 'Required condition of merchandise for return acceptance. Defines whether items must be unopened, unused, or can be returned in any condition.']
  approval_required boolean [note: 'Indicates whether returns under this policy require manager or supervisor approval before processing. Common for high-value items or out-of-window returns.']
  created_by_user varchar [note: 'User ID or system identifier of the person or process that created this return policy record. Used for audit and accountability.']
  created_timestamp timestamp [note: 'Timestamp when this return policy record was first created in the system. Used for audit trail and policy lifecycle tracking.']
  effective_end_date date [note: 'Date when this return policy expires and is no longer applicable to new transactions. Nullable for open-ended policies.']
  effective_start_date date [note: 'Date when this return policy becomes active and applicable to transactions. Policies are not enforced before this date.']
  exchange_allowed boolean [note: 'Indicates whether direct product exchanges (size, color, model) are permitted under this policy without requiring a full return and repurchase.']
  extended_window_days varchar [note: 'Extended return window duration for premium loyalty tier members or special promotional periods. Nullable if no extension applies.']
  holiday_extension_applicable boolean [note: 'Indicates whether this policy includes extended return windows for holiday season purchases (e.g., purchases made in November-December returnable through mid-January).']
  inspection_sla_hours varchar [note: 'Target time in hours for completing merchandise inspection and condition assessment after return receipt. Used for operational SLA measurement.']
  last_modified_by_user varchar [note: 'User ID or system identifier of the person or process that last modified this return policy record. Used for audit and accountability.']
  last_modified_timestamp timestamp [note: 'Timestamp when this return policy record was last updated. Used for audit trail and change tracking.']
  liquidation_eligible boolean [note: 'Indicates whether returned merchandise under this policy can be sent to liquidation channels (discount outlets, bulk resellers) for recovery.']
  non_returnable_item_exceptions varchar [note: 'Comma-separated list of item types or SKU patterns that are explicitly excluded from returns under this policy (e.g., perishables, intimate apparel, custom orders, clearance items).']
  original_packaging_required boolean [note: 'Indicates whether the item must be returned in its original packaging for acceptance. Common for electronics and high-value items.']
  policy_code varchar [note: 'Business identifier for the return policy, used in operational systems and customer communications. Unique alphanumeric code.']
  policy_description varchar [note: 'Detailed text description of the return policy terms and conditions, including any special provisions, exclusions, or customer-facing language.']
  policy_name varchar [note: 'Human-readable name of the return policy (e.g., \'Standard 30-Day Return\', \'Electronics Extended Return\', \'Final Sale No Return\').']
  policy_type varchar [note: 'Classification of the return policy indicating the policy category and applicability scope.']
  policy_url varchar [note: 'Web URL where the full return policy terms are published for customer reference. Required for e-commerce compliance.']
  priority_level varchar [note: 'Priority level for processing returns under this policy. Premium and VIP customers may receive expedited processing.']
  proof_of_purchase_required boolean [note: 'Indicates whether proof of purchase (receipt, order confirmation, transaction lookup) is mandatory for return processing.']
  refund_method varchar [note: 'Method by which refunds are issued under this policy. May restrict refunds to store credit or exchange for certain categories or conditions.']
  refund_processing_sla_hours varchar [note: 'Target time in hours for completing refund processing from return acceptance to funds disbursement. Used for operational SLA measurement.']
  restocking_fee_applicable boolean [note: 'Indicates whether a restocking fee is charged for returns under this policy. Common for high-value electronics and special-order items.']
  restocking_fee_flat_amount decimal(10,2) [note: 'Fixed dollar amount charged as a restocking fee, regardless of purchase price. Nullable if percentage-based or no fee applies.']
  restocking_fee_percent decimal(5,2) [note: 'Percentage of the original purchase price charged as a restocking fee. Nullable if no restocking fee applies. Typical range is 10-25%.']
  restocking_sla_hours varchar [note: 'Target time in hours for restocking accepted returned merchandise back into available inventory. Used for operational SLA measurement.']
  return_policy_status varchar [note: 'Current lifecycle status of the return policy. Only active policies are applied to new transactions.']
  return_shipping_paid_by varchar [note: 'Party responsible for paying return shipping costs. Retailer-paid shipping is common for defective items or retailer errors; customer-paid for buyer remorse.']
  return_window_days varchar [note: 'Number of days from purchase date during which a return is accepted under this policy. Standard retail windows range from 14 to 90 days.']
  rma_auto_approval_enabled boolean [note: 'Indicates whether RMA requests are automatically approved based on policy rules without manual review. Drives automated return authorization logic.']
  store_credit_expiry_days varchar [note: 'Number of days until store credit issued for returns expires. Nullable if store credit does not expire. Subject to state-specific gift card laws.']
  vendor_return_eligible boolean [note: 'Indicates whether merchandise returned under this policy is eligible for Return to Vendor (RTV) processing to recover costs from suppliers.']

  Note: 'Master record defining return policy rules by merchandise category, sales channel, and customer segment. Captures return window duration, restocking fee rules, accepted return conditions, proof-of-purchase requirements, non-returnable item exceptions, channel applicability (in-store, online, BOPIS), loyalty tier overrides (extended windows for premium members), SLA processing targets by return stage, and policy effective/expiry dates. Drives automated RMA authorization logic and operational SLA measurement.'
}

Table returns.store_credit {
  store_credit_id varchar [pk, note: 'Unique identifier for the store credit instrument. Primary key.']
  header_id varchar [note: 'Reference to the original order that was returned and resulted in this store credit issuance. Provides full traceability from purchase through return to credit.']
  location_id varchar [note: 'Reference to the physical store location where the store credit was issued. Null for credits issued through digital channels.']
  original_digital_payment_id varchar [note: 'Foreign key linking to ecommerce.digital_payment. Business justification: When a digital payment is refunded as store credit, tracing store_credit back to the original digital_payment is required for financial reconciliation, fraud detection (store credit issued against fra']
  pos_transaction_id varchar [note: 'Foreign key linking to order.pos_transaction. Business justification: In-store return workflow: store credit issued at POS must reference the originating POS transaction for receipt reprinting, daily cash reconciliation, and loss-prevention audit. Store operations teams']
  profile_id varchar [note: 'Reference to the customer to whom this store credit was issued. Enables customer-level credit balance tracking and redemption history.']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Campaign-level store credit incentives (e.g., holiday return campaigns issuing $10 store credit) require linking issued store_credit to the promo_campaign for marketing budget reconciliation, store cr']
  promo_offer_id varchar [note: 'Foreign key linking to promotion.promo_offer. Business justification: Retailers run \'bonus store credit on return\' promotions (e.g., return any item and receive 20% extra as store credit). The issued store_credit must reference the promo_offer that triggered the bonus f']
  rma_id varchar [note: 'Reference to the originating RMA that triggered this store credit issuance. Links the credit back to the return transaction.']
  barcode varchar [note: 'Machine-readable barcode representation of the store credit code for POS scanning. Supports omnichannel redemption workflows.']
  breakage_estimate_applied_flag boolean [note: 'Indicates whether a breakage revenue estimate (expected non-redemption) has been applied to this store credit for financial reporting purposes under ASC 606.']
  combinable_with_promotions_flag boolean [note: 'Indicates whether the store credit can be combined with other promotional discounts during redemption. Supports pricing and promotion policy enforcement.']
  created_timestamp timestamp [note: 'Timestamp when the store credit record was first created in the system. Supports audit trail and data lineage.']
  credit_code varchar [note: 'Externally-visible unique alphanumeric code printed on the store credit instrument or provided digitally. Used for redemption at POS or e-commerce checkout.']
  credit_type varchar [note: 'Classification of the reason or business context for issuing this store credit. Distinguishes between return-driven credits, promotional incentives, and service recovery gestures.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the store credit monetary values. Supports multi-currency retail operations.']
  escheatment_date date [note: 'Calendar date on which the unredeemed balance must be reported and remitted to the state as unclaimed property. Null if not subject to escheatment.']
  escheatment_eligible_flag boolean [note: 'Indicates whether the unredeemed balance is subject to state escheatment (unclaimed property) laws. Supports regulatory compliance for abandoned store credits.']
  expiration_date date [note: 'Calendar date on which the store credit expires and can no longer be redeemed. Nullable for credits with no expiration policy.']
  issue_date date [note: 'Calendar date on which the store credit was issued to the customer. Marks the start of the credit\'s validity period.']
  issued_amount decimal(15,2) [note: 'Original monetary value of the store credit at the time of issuance. Represents the full stored-value balance before any redemptions.']
  issuing_channel varchar [note: 'The customer-facing channel through which the store credit was issued. Supports omnichannel returns and credit issuance analytics.']
  last_modified_timestamp timestamp [note: 'Timestamp when the store credit record was most recently updated. Supports audit trail and change tracking.']
  last_redemption_date date [note: 'Calendar date of the most recent partial or full redemption transaction. Null if the credit has never been redeemed.']
  notes varchar [note: 'Free-text field for additional context, special instructions, or customer service notes related to the store credit issuance or redemption.']
  pin_code varchar [note: 'Optional security PIN required for redemption of the store credit. Protects against unauthorized use if the credit code is compromised.']
  redemption_channel_restriction varchar [note: 'Policy constraint on where the store credit can be redeemed. Supports business rules for channel-specific credits.']
  remaining_balance decimal(15,2) [note: 'Current unredeemed monetary value available on the store credit. Decreases with each partial redemption until fully redeemed or expired.']
  store_credit_status varchar [note: 'Current lifecycle state of the store credit. Tracks progression from issuance through redemption, expiration, or voiding. [ENUM-REF-CANDIDATE: issued|active|partially_redeemed|fully_redeemed|expired|voided|suspended — 7 candidates stripped; promote to reference product]']
  transferable_flag boolean [note: 'Indicates whether the store credit can be transferred or gifted to another customer. False means the credit is locked to the original recipient.']
  void_date date [note: 'Calendar date on which the store credit was voided. Null if the credit has not been voided.']
  void_reason_code varchar [note: 'Standardized code indicating the reason the store credit was voided. Null if the credit has not been voided.']

  Note: 'Store credit instrument issued as return resolution in lieu of cash or card refund. Functions as a stored-value financial instrument with its own lifecycle: issuance, partial redemption, full redemption, expiration, or voiding. Captures credit code, issued and remaining balance, issue/expiry dates, issuing channel and location, customer and originating RMA references. Integrates with POS and e-commerce systems for omnichannel redemption.'
}

Table supplychain.replenishment_plan {
  replenishment_plan_id varchar [pk, note: 'Unique surrogate identifier for each replenishment plan record in the Silver layer lakehouse. Primary key for the replenishment_plan data product.']
  cluster_id varchar [note: 'Foreign key linking to store.cluster. Business justification: Cluster-level replenishment parameters (safety stock method, reorder points, service level targets) are set at cluster level and applied to member stores. cluster_id on replenishment_plan enables clus']
  cost_price_id varchar [note: 'Foreign key linking to pricing.cost_price. Business justification: Replenishment plans use unit_cost to calculate planned_order_value and min_order_value for OTB (Open-to-Buy) management. Linking to the authoritative cost_price record ensures plans use current landed']
  demand_forecast_id varchar [note: 'Reference to the demand forecast plan from Blue Yonder Demand Planning that drove the generation of this replenishment plan. Enables traceability from replenishment decision back to the underlying demand signal.']
  inventory_node_id varchar [note: 'Reference to the supply chain node (store, Distribution Center (DC), or Micro-Fulfillment Center (MFC)) for which this replenishment plan is generated. Identifies the destination receiving location in the replenishment network.']
  lead_time_agreement_id varchar [note: 'Foreign key linking to supplier.lead_time_agreement. Business justification: Replenishment plans use lead_time_days to calculate order_release_date and planned_receipt_date. The lead_time_agreement is the authoritative source. Direct FK enables \'replenishment accuracy audit\' a']
  location_id varchar [note: 'Foreign key linking to store.location. Business justification: Replenishment plans are generated per store location. A direct store FK enables store-level replenishment performance dashboards, buyer review by store, and service-level target tracking without joini']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Promotional inventory builds are planned against specific campaigns (campaign dates, scope, target units). The existing `promotion_flag` boolean is insufficient — buyers need the campaign_id to size t']
  sku_id varchar [note: 'Reference to the specific SKU (Stock Keeping Unit) for which this replenishment plan is generated. The SKU is the primary product-level identifier used in replenishment planning across stores, DCs, and MFCs.']
  vendor_id varchar [note: 'Reference to the primary supplier responsible for fulfilling this replenishment plan. Links to the supplier master for MOQ enforcement, lead time, and EDI ordering constraints.']
  vendor_item_id varchar [note: 'Foreign key linking to supplier.vendor_item. Business justification: Replenishment plan generation depends on vendor item attributes (unit_cost, case_pack_quantity, MOQ, lead time). Planners need the authoritative vendor_item record to validate plan parameters. \'Replen']
  approved_order_qty decimal(18,4) [note: 'The final order quantity approved by the buyer or auto-approved by the system after MOQ, order multiple, and buyer override adjustments. This is the quantity that will be transmitted to the supplier via EDI or purchase order.']
  buyer_override_flag boolean [note: 'Indicates whether a buyer has manually overridden the system-generated planned order quantity or parameters. True = buyer override applied; False = system-generated values accepted as-is. Supports audit trail for manual interventions.']
  created_timestamp timestamp [note: 'Audit timestamp recording when this replenishment plan record was first persisted in the Silver layer lakehouse. Supports data lineage and audit trail requirements.']
  currency_code varchar [note: 'The three-letter ISO 4217 currency code in which the planned order value and unit cost are expressed (e.g., USD, GBP, EUR). Required for multi-currency retail operations.']
  current_on_hand_qty decimal(18,4) [note: 'The quantity of the SKU physically on hand at the supply node at the time the replenishment plan was generated. Sourced from Manhattan Associates WMS or SAP S/4HANA WM. Used as the starting inventory position for plan calculations.']
  demand_variability_factor decimal(10,6) [note: 'A statistical measure of demand variability (coefficient of variation or standard deviation of demand) used by the planning engine to size safety stock. Higher values indicate more volatile demand and result in larger safety stock buffers.']
  fill_rate_target_pct decimal(5,2) [note: 'The target order fill rate percentage (Fill Rate) for this replenishment plan, representing the percentage of demand that should be fulfilled from available inventory. Used as a supply chain performance KPI (KPI) target for this SKU-node combination.']
  forecasted_demand_qty decimal(18,4) [note: 'The total forecasted demand quantity for the SKU at the supply node over the plan horizon, as generated by Blue Yonder Demand Planning. The primary input to the planned order quantity calculation.']
  min_order_value decimal(18,2) [note: 'The minimum monetary value of a purchase order required by the supplier, expressed in the operating currency. Replenishment plans that do not meet the minimum order value threshold are consolidated or flagged for buyer action.']
  moq decimal(18,4) [note: 'The minimum number of units that must be ordered from the supplier per purchase order line, as enforced by supplier contract terms. Replenishment plans with planned_order_qty below MOQ are rounded up or flagged for buyer review.']
  moq_compliance_flag boolean [note: 'Indicates whether the planned order quantity meets or exceeds the supplier\'s Minimum Order Quantity (MOQ) constraint. True = compliant; False = below MOQ threshold and requires buyer review or order consolidation before release.']
  node_type varchar [note: 'Classifies the type of supply chain node receiving the replenishment. Values: store (retail store), dc (Distribution Center), mfc (Micro-Fulfillment Center), dark_store (fulfillment-only location). Drives replenishment logic and lead time parameters.']
  on_order_qty decimal(18,4) [note: 'The quantity of the SKU already on open purchase orders or in-transit to the supply node at the time of plan generation. Included in the net inventory position calculation to avoid over-ordering.']
  order_multiple decimal(18,4) [note: 'The unit increment in which the SKU must be ordered (e.g., case pack size, pallet quantity). Planned order quantities are rounded up to the nearest order multiple before purchase order generation.']
  order_release_date date [note: 'The date on which the replenishment plan is scheduled to be released as a purchase order to the supplier. Calculated by subtracting lead time from the planned receipt date. Drives the purchasing execution calendar.']
  override_reason_code varchar [note: 'Standardized reason code explaining why a buyer manually overrode the system-generated replenishment plan. Populated only when buyer_override_flag is True. Supports root cause analysis of planning accuracy and buyer behavior patterns.']
  plan_generation_timestamp timestamp [note: 'The date and time when the replenishment plan was generated by the planning engine (Blue Yonder or equivalent). Represents the principal business event timestamp for this transaction. Used for plan freshness assessment and demand signal alignment.']
  plan_horizon_end_date date [note: 'The end date of the planning horizon covered by this replenishment plan. Defines the end of the demand forecast window. Together with plan_horizon_start_date, bounds the coverage period for this plan.']
  plan_horizon_start_date date [note: 'The start date of the planning horizon covered by this replenishment plan. Defines the beginning of the demand forecast window used to generate the planned order quantity.']
  plan_number varchar [note: 'Externally-known business identifier for the replenishment plan, generated by Blue Yonder Demand Planning or SAP S/4HANA MM module. Used for cross-system traceability and supplier communication.']
  plan_status varchar [note: 'Current lifecycle state of the replenishment plan within the planning and execution workflow. Drives automated ordering triggers and buyer review queues. [ENUM-REF-CANDIDATE: draft|proposed|approved|released|in_progress|completed|cancelled — promote to reference product]']
  plan_type varchar [note: 'Categorizes the origin and nature of the replenishment plan. Automated plans are system-generated by Blue Yonder; manual plans are buyer-created; override plans supersede automated recommendations; emergency plans address urgent stockout risk.']
  planned_order_qty decimal(18,4) [note: 'The quantity of units recommended by the planning engine to be ordered for this SKU at the specified supply node. Subject to MOQ and order multiple enforcement before release to purchasing.']
  planned_order_value decimal(18,2) [note: 'The total monetary value of the planned replenishment order, calculated as planned_order_qty multiplied by unit_cost. Used for Open-to-Buy (OTB) budget management and financial planning.']
  planned_receipt_date date [note: 'The expected date on which the replenishment order is planned to be received at the supply node, calculated as the order release date plus supplier lead time. Used for inventory projection and DC scheduling.']
  promotion_flag boolean [note: 'Indicates whether this replenishment plan was generated or adjusted to support a planned promotional event. True = promotion-driven uplift included in forecasted demand; False = baseline replenishment. Links to promotional demand lift in Blue Yonder.']
  reorder_point decimal(18,4) [note: 'The inventory level (in units) at the supply node at which a replenishment order is triggered. Calculated as safety stock plus expected demand during supplier lead time. Core parameter for reorder-point-based replenishment policies.']
  replenishment_method varchar [note: 'The replenishment policy calculation method applied to generate this plan. Min/Max triggers orders when inventory falls below minimum; Reorder Point (ROP) uses statistical triggers; Days of Supply targets coverage duration; Vendor Managed Inventory (VMI) delegates to supplier; Cross-Docking bypasses storage; Direct Store Delivery (DSD) is supplier-direct. [ENUM-REF-CANDIDATE: min_max|reorder_point|days_of_supply|vendor_managed|cross_dock|dsd — promote to reference product]']
  safety_stock_method varchar [note: 'The methodology used to calculate the safety stock quantity. Fixed uses a static buffer; Statistical uses demand variability and lead time variance; Days of Supply targets a coverage duration; Service Level Based derives buffer from the target service level percentage.']
  safety_stock_qty decimal(18,4) [note: 'The buffer stock quantity maintained at the supply node to protect against demand variability and supply uncertainty. Represents the minimum inventory floor below which replenishment is urgently triggered. Also referred to as buffer stock.']
  service_level_target_pct decimal(5,2) [note: 'The target in-stock service level percentage used to calculate safety stock and replenishment parameters. Expressed as a percentage (e.g., 95.00 = 95%). Represents the probability of not experiencing a stockout during the replenishment lead time.']
  source_system_code varchar [note: 'Identifies the operational system of record that generated or last updated this replenishment plan. Supports data lineage and Silver layer provenance tracking. Values: blue_yonder (Blue Yonder Demand Planning), sap_s4hana (SAP S/4HANA MM), orms (Oracle Retail Merchandising System), manual (buyer-created).']
  updated_timestamp timestamp [note: 'Audit timestamp recording when this replenishment plan record was last modified in the Silver layer lakehouse. Tracks buyer overrides, status transitions, and plan revisions.']
  weeks_of_supply_target decimal(5,2) [note: 'The target number of weeks of inventory coverage (Weeks of Supply / WOS) that the replenishment plan aims to achieve at the supply node after order receipt. Used as a planning horizon parameter for days-of-supply replenishment methods.']

  Note: 'Replenishment plans for SKUs across all supply chain nodes (stores, DCs, MFCs), generated by Blue Yonder or equivalent planning engine. Captures planned order quantities, replenishment triggers, reorder points, safety stock levels and policy parameters (calculation method, service level target, demand variability factor), weeks-of-supply targets, plan status, and MOQ enforcement rules (minimum order quantity, order multiples, minimum order value). SSOT for automated replenishment decisions including buffer stock governance and supplier ordering constraints.'
}

Table supplychain.demand_forecast {
  demand_forecast_id varchar [pk, note: 'Unique surrogate identifier for each SKU-level demand forecast record generated by Blue Yonder Demand Planning. Serves as the primary key for this table.']
  cluster_id varchar [note: 'Foreign key linking to store.cluster. Business justification: Cluster-level demand forecasting is standard retail practice — similar stores are grouped for statistical lift and new-item forecasting. A cluster_id FK on demand_forecast enables cluster-level foreca']
  location_id varchar [note: 'Reference to the store, distribution center (DC), or fulfillment node for which the demand forecast applies. Supports store-level and DC-level replenishment planning.']
  price_list_id varchar [note: 'Foreign key linking to pricing.price_list. Business justification: Demand forecasts are channel and price-list specific — forecasted_revenue depends on which price_list was active. Linking demand_forecast to price_list supports price-elasticity modeling, promotional ']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Demand planners link forecasts to specific promo campaigns to measure promotional lift accuracy and calibrate future forecasts. The existing `promotional_lift_units` and `is_promotional_period` flags ']
  sku_id varchar [note: 'Reference to the specific Stock Keeping Unit (SKU) for which the demand forecast is generated. The SKU is the atomic unit of inventory and demand planning in retail.']
  sku_price_id varchar [note: 'Foreign key linking to pricing.sku_price. Business justification: Demand forecasting models consume active retail prices to calculate price-elasticity-adjusted forecasted_revenue and forecasted_units. Demand planners need to know which sku_price was active during th']
  storefront_id varchar [note: 'Foreign key linking to ecommerce.storefront. Business justification: Retail demand planning is channel-specific: ecommerce storefronts (US site, CA site, mobile app) require separate demand forecasts to drive replenishment for their fulfillment nodes. demand_forecast.p']
  baseline_forecast_units decimal(18,4) [note: 'The pure statistical baseline demand forecast in units before any adjustments for promotions, seasonality, or manual overrides. Provides the unadjusted demand signal for comparison against the final consensus forecast.']
  confidence_level_pct decimal(5,2) [note: 'The statistical confidence level (expressed as a percentage, e.g., 95.00) associated with the forecast interval. Indicates the probability that actual demand will fall within the forecast range. Used to set safety stock levels and replenishment buffers.']
  created_timestamp timestamp [note: 'The timestamp when this demand forecast record was first written to the Silver Layer lakehouse. Supports data lineage, audit trails, and incremental load processing.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the forecasted revenue amount (e.g., USD, GBP, EUR). Supports multi-currency retail operations across international markets.']
  data_source_system varchar [note: 'The operational system of record that provided the demand signal inputs used to generate this forecast (e.g., SAP_CAR for POS transaction data, Salesforce_Commerce_Cloud for e-commerce demand, ORMS for inventory positions). Supports data lineage and source system auditability.']
  demand_category varchar [note: 'Classification of the SKU\'s demand pattern used to select the appropriate forecasting model. \'regular\' indicates stable, predictable demand; \'intermittent\' indicates sporadic demand (Croston model); \'lumpy\' indicates irregular high-volume spikes; \'new_item\' indicates insufficient history; \'end_of_life\' indicates declining/discontinuing SKU.']
  forecast_bias decimal(8,4) [note: 'The systematic directional error in the forecast, calculated as the mean of (forecasted units minus actual units) over a rolling period. Positive values indicate over-forecasting (excess inventory risk); negative values indicate under-forecasting (stockout risk). Critical for replenishment safety stock calibration.']
  forecast_generation_timestamp timestamp [note: 'The exact date and time when this forecast record was generated by the Blue Yonder Demand Planning engine. Serves as the principal business event timestamp for the forecast lifecycle and supports version comparison across planning cycles.']
  forecast_horizon_weeks varchar [note: 'The total number of weeks into the future covered by this forecast run, measured from the forecast generation date. Determines the planning horizon for replenishment, Open-to-Buy (OTB), and supply chain optimization.']
  forecast_lower_bound_units decimal(18,4) [note: 'The lower bound of the forecast confidence interval in units at the specified confidence level. Represents the low-demand scenario used for minimum order quantity (MOQ) planning and markdown risk assessment.']
  forecast_period_end_date date [note: 'The last calendar date of the forecast horizon period covered by this record. Together with forecast_period_start_date, defines the time bucket granularity (daily, weekly, monthly).']
  forecast_period_start_date date [note: 'The first calendar date of the forecast horizon period covered by this record. Defines the beginning of the time bucket (day, week, or month) for which demand is forecasted.']
  forecast_run_number varchar [note: 'Identifier for the specific Blue Yonder Demand Planning batch run that generated this forecast record. Enables traceability back to the originating planning cycle and supports audit of forecast lineage.']
  forecast_status varchar [note: 'Current lifecycle state of the demand forecast record. \'draft\' indicates a preliminary run; \'published\' indicates the forecast is active for replenishment; \'approved\' indicates planner sign-off; \'overridden\' indicates a manual adjustment was applied; \'superseded\' indicates a newer run has replaced this record; \'archived\' indicates the record is retained for historical analysis only.']
  forecast_type varchar [note: 'Classification of the demand forecast by its planning purpose. \'baseline\' is the statistical base demand without uplift; \'promotional\' incorporates promotion lift; \'seasonal\' reflects seasonal index adjustments; \'event_driven\' accounts for specific demand events; \'consensus\' is the final agreed forecast used for replenishment and Open-to-Buy (OTB) planning.']
  forecast_upper_bound_units decimal(18,4) [note: 'The upper bound of the forecast confidence interval in units at the specified confidence level. Represents the high-demand scenario used for safety stock and maximum inventory planning to prevent stockouts.']
  forecast_version varchar [note: 'An incrementing integer version number for the forecast record for a given SKU-location-period combination. Enables tracking of forecast revisions across planning cycles and supports comparison of forecast evolution over time.']
  forecasted_revenue decimal(18,2) [note: 'The projected revenue in the operating currency derived from the forecasted units multiplied by the expected selling price for the forecast period. Used in financial planning, Open-to-Buy (OTB) budgeting, and Gross Margin Return on Investment (GMROI) analysis.']
  forecasted_units decimal(18,4) [note: 'The statistical model\'s predicted demand quantity in sellable units for the SKU at the specified location during the forecast period. This is the primary quantitative output of the demand planning engine and drives replenishment order quantities.']
  is_latest_version boolean [note: 'Indicates whether this forecast record is the most current version for the given SKU-location-period combination. True means this record is the active forecast used for replenishment and OTB planning; False means it has been superseded by a newer forecast run.']
  is_new_item boolean [note: 'Indicates whether the SKU is a new item with insufficient sales history for statistical forecasting. When True, the forecast relies on analogous item modeling or planner input rather than historical demand patterns. Relevant for new product launches and assortment introductions.']
  is_override_applied boolean [note: 'Indicates whether a demand planner has manually overridden the statistical forecast for this record. True means the final forecasted_units reflect a planner adjustment; False means the forecast is purely statistical. Critical for measuring forecast bias introduced by manual intervention.']
  is_promotional_period boolean [note: 'Indicates whether the forecast period overlaps with an active promotional event. When True, the promotional_lift_units field is expected to be populated and the forecast incorporates promotion-driven demand uplift.']
  mape decimal(8,4) [note: 'Mean Absolute Percentage Error (MAPE) measuring the accuracy of the statistical forecast against actual sales for the equivalent prior period. Expressed as a decimal (e.g., 0.12 = 12% error). Lower values indicate higher forecast accuracy. Used as the primary KPI for demand planning performance.']
  model_version varchar [note: 'The version identifier of the statistical forecasting model used to generate this forecast record. Supports model governance, reproducibility, and performance tracking across model upgrades in Blue Yonder Demand Planning.']
  otb_impact_flag boolean [note: 'Indicates whether this forecast record has been incorporated into the Open-to-Buy (OTB) financial plan. When True, the forecasted revenue and units are reflected in the merchandise financial plan and buying budget for the relevant period.']
  override_reason_code varchar [note: 'A standardized code indicating the business reason for the planner\'s manual override of the statistical forecast (e.g., new product launch, competitor action, supply constraint, market intelligence). Populated only when is_override_applied is True. [ENUM-REF-CANDIDATE: NEW_PRODUCT|COMPETITOR_ACTION|SUPPLY_CONSTRAINT|MARKET_INTEL|PROMO_CHANGE|STORE_EVENT|WEATHER — promote to reference product]']
  override_units decimal(18,4) [note: 'The manually adjusted demand quantity in units entered by a demand planner to replace or supplement the statistical forecast. Populated only when is_override_applied is True. Enables analysis of planner override magnitude and its impact on forecast accuracy.']
  promotional_lift_units decimal(18,4) [note: 'The incremental demand units attributed to active promotions during the forecast period. Derived from promotion event modeling in Blue Yonder and used to isolate the promotional demand signal from baseline demand for Pricing and Promotions Management analysis.']
  replenishment_recommendation_units decimal(18,4) [note: 'The system-recommended replenishment order quantity in units derived from the demand forecast, current inventory position, safety stock targets, and lead time. Feeds directly into Oracle Retail Merchandising System (ORMS) purchase order generation and Open-to-Buy (OTB) planning.']
  seasonality_index decimal(8,4) [note: 'A multiplicative seasonal index applied to the baseline forecast to account for recurring seasonal demand patterns (e.g., holiday peaks, back-to-school). A value of 1.0 indicates no seasonal adjustment; values above 1.0 indicate above-average seasonal demand.']
  statistical_model_code varchar [note: 'The identifier or code of the statistical forecasting algorithm used by Blue Yonder Demand Planning to generate this forecast (e.g., ARIMA, Holt-Winters exponential smoothing, Croston for intermittent demand, machine learning ensemble). Enables model performance benchmarking and algorithm governance. [ENUM-REF-CANDIDATE: ARIMA|HOLT_WINTERS|CROSTON|ETS|MOVING_AVG|ML_ENSEMBLE|CAUSAL — promote to reference product]']
  time_bucket_granularity varchar [note: 'The temporal granularity of the forecast period covered by this record. \'daily\' is used for short-horizon replenishment; \'weekly\' is the standard planning cadence; \'monthly\' is used for financial and Open-to-Buy (OTB) planning.']
  trend_adjustment_factor decimal(8,4) [note: 'A multiplicative factor representing the long-term demand trend applied to the forecast. Values above 1.0 indicate upward trend; values below 1.0 indicate declining demand trend. Used to capture secular demand shifts beyond seasonal patterns.']
  updated_timestamp timestamp [note: 'The timestamp when this demand forecast record was last modified in the Silver Layer lakehouse, including override applications, accuracy recalculations, or status changes.']
  weeks_of_supply decimal(8,2) [note: 'Weeks of Supply (WOS) — the projected number of weeks the current on-hand inventory will cover demand based on the forecasted units. A key inventory health metric used in replenishment planning to identify stockout risk and excess inventory positions.']
  wmape decimal(8,4) [note: 'Weighted Mean Absolute Percentage Error (WMAPE) measuring forecast accuracy weighted by sales volume, reducing the distortion caused by low-volume SKUs. Expressed as a decimal. Preferred accuracy metric for high-volume retail assortments where MAPE can be misleading.']

  Note: 'SKU-level demand forecast records generated by Blue Yonder Demand Planning. Captures forecasted units, revenue, forecast horizon, statistical model used, override flags, forecast accuracy (MAPE/WMAPE), and demand signals including seasonality, promotions lift, and trend adjustments. Drives replenishment and OTB planning.'
}

Table supplychain.purchase_order {
  purchase_order_id varchar [pk, note: 'Primary key for purchase_order']
  blanket_po_purchase_order_id varchar [note: 'Reference to the parent blanket or framework purchase order from which this release or call-off order was created. Null for standalone standard POs. Enables tracking of spend against blanket agreement limits.']
  dc_facility_id varchar [note: 'Reference to the distribution center or store location designated as the delivery destination for this purchase order. Corresponds to SAP EKKO.WERKS (plant/site).']
  item_hierarchy_id varchar [note: 'Foreign key linking to product.item_hierarchy. Business justification: Retail OTB management and category-level PO reporting require PO headers to link to item_hierarchy. Buyers raise POs against category budgets; \'merchandise_category_code\' is a denormalized category re']
  lead_time_agreement_id varchar [note: 'Foreign key linking to supplier.lead_time_agreement. Business justification: When a PO is created, the applicable lead time agreement governs expected_delivery_date calculation and confirmed_delivery_date setting. \'PO lead time compliance\' reporting requires direct attribution']
  promo_campaign_id varchar [note: 'Foreign key linking to promotion.promo_campaign. Business justification: Incremental promotional POs are issued specifically to support campaign inventory requirements. Linking PO to promo_campaign enables promo ROI reporting (COGS for the campaign vs. revenue lift) and en']
  replenishment_plan_id varchar [note: 'Foreign key linking to supplychain.replenishment_plan. Business justification: In retail supply chain, purchase orders are generated from replenishment plans (Blue Yonder generates the plan, SAP MM creates the PO). Linking purchase_order back to the originating replenishment_pla']
  vendor_id varchar [note: 'Reference to the supplier (vendor) fulfilling this purchase order. Links to the supplier master data product managed in Informatica MDM. Corresponds to SAP EKKO.LIFNR (vendor account number).']
  vendor_promo_agreement_id varchar [note: 'Foreign key linking to promotion.vendor_promo_agreement. Business justification: POs placed under vendor funding agreements must reference the agreement for chargeback reconciliation, vendor funding settlement, and compliance auditing. Retail merchants and AP teams require this li']
  actual_delivery_date date [note: 'The date on which goods were physically received at the destination facility. Populated upon goods receipt posting in SAP (MIGO transaction). Used to calculate supplier on-time delivery performance and lead time actuals.']
  approval_status varchar [note: 'Authorization workflow status indicating whether the purchase order has been approved by the required approvers per the company\'s procurement authorization matrix. Distinct from po_status as it tracks the internal approval gate specifically.']
  approved_timestamp timestamp [note: 'The timestamp when the purchase order received final authorization approval. Captures the precise moment the procurement commitment became binding. Used for approval cycle time analytics and compliance auditing.']
  cancellation_date date [note: 'The date by which the purchase order must be cancelled if goods have not shipped. Also known as the cancel date or cancel-by date in retail procurement. Null if the PO has not been cancelled or does not have a cancellation deadline.']
  company_code varchar [note: 'SAP company code representing the legal entity or business unit issuing the purchase order. Used for financial reporting, P&L allocation, and intercompany reconciliation. Corresponds to SAP EKKO.BUKRS.']
  confirmed_delivery_date date [note: 'The delivery date confirmed by the supplier after PO acknowledgment. May differ from expected_delivery_date if the supplier cannot meet the original requested date. Used to update replenishment plans and manage weeks of supply (WOS).']
  created_timestamp timestamp [note: 'The timestamp when the purchase order record was first created in the source system. Audit trail field for data lineage and compliance. Corresponds to SAP EKKO.AEDAT (creation date) combined with time.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts on this purchase order (e.g., USD, EUR, GBP, CAD). Corresponds to SAP EKKO.WAERS (currency key).']
  discount_amount decimal(18,2) [note: 'Total discount or allowance amount applied to the purchase order by the supplier, including volume discounts, promotional allowances, and trade deals. Reduces the net payable amount. Expressed in the currency specified by currency_code.']
  edi_transmission_status varchar [note: 'Status of the EDI (Electronic Data Interchange) transmission of this purchase order to the supplier. Not Sent = EDI not applicable or not yet initiated; Pending = queued for transmission; Transmitted = EDI 850 PO sent to supplier; Acknowledged = supplier returned EDI 855 acknowledgment; Failed = transmission error; Rejected = supplier rejected the PO via EDI.']
  edi_transmitted_timestamp timestamp [note: 'The timestamp when the purchase order was transmitted to the supplier via EDI (Electronic Data Interchange) as an EDI 850 transaction set. Null if EDI transmission has not occurred. Used for supplier communication SLA tracking.']
  exchange_rate decimal(18,6) [note: 'The foreign currency exchange rate applied to convert the purchase order amounts from the supplier\'s transaction currency to the company\'s functional currency at the time of PO creation. Corresponds to SAP EKKO.WKURS.']
  expected_delivery_date date [note: 'The agreed-upon date by which the supplier is expected to deliver the ordered goods to the designated distribution center or store. Used for supply chain planning, replenishment scheduling, and SLA monitoring. Corresponds to SAP EKET.EINDT (scheduled delivery date).']
  fill_rate_pct decimal(5,2) [note: 'The percentage of ordered units that have been received and fulfilled by the supplier, calculated as (total_received_units / total_ordered_units) * 100. Fill Rate is a key supplier performance KPI measuring order completion. Stored as a pre-computed operational field updated upon each goods receipt.']
  incoterms_code varchar [note: 'International Commercial Terms (Incoterms 2020) code defining the responsibilities of buyer and seller for delivery, risk transfer, and cost allocation (e.g., FOB = Free On Board, DDP = Delivered Duty Paid, CIF = Cost Insurance Freight). Corresponds to SAP EKKO.INCO1. Critical for import/export compliance and logistics cost allocation. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]']
  incoterms_location varchar [note: 'The named place or port associated with the Incoterms code, specifying the exact location where risk and cost transfer between buyer and seller (e.g., \'Port of Los Angeles\' for FOB). Corresponds to SAP EKKO.INCO2.']
  is_cross_dock boolean [note: 'Indicates whether this purchase order is designated for cross-docking at the distribution center, meaning goods will be transferred directly from inbound to outbound without putaway storage. Cross-docking reduces DC handling costs and accelerates store replenishment.']
  is_drop_ship boolean [note: 'Indicates whether this purchase order is a drop ship arrangement where the supplier ships goods directly to the end customer, bypassing the retailer\'s distribution center. Drop ship POs are common in e-commerce and extended aisle assortments.']
  last_updated_timestamp timestamp [note: 'The timestamp when the purchase order record was most recently modified in the source system. Used for incremental data loading, change data capture, and audit compliance.']
  lead_time_days varchar [note: 'The agreed or expected number of days from purchase order placement to goods receipt at the destination facility. Used in replenishment planning, weeks of supply (WOS) calculations, and Blue Yonder demand planning models. Corresponds to supplier lead time in the procurement master data.']
  minimum_order_quantity decimal(18,3) [note: 'The minimum quantity the supplier requires for this purchase order, as defined in the supplier agreement or item master. MOQ (Minimum Order Quantity) constraints drive order sizing decisions in replenishment planning and OTB management.']
  net_payable_amount decimal(18,2) [note: 'The net amount payable to the supplier after applying all discounts, allowances, and adjustments to the gross total order amount. This is the financial commitment recorded in accounts payable. Expressed in the currency specified by currency_code.']
  notes varchar [note: 'Free-text field for buyer notes, special instructions, or remarks associated with the purchase order. May include delivery instructions, quality requirements, or supplier-specific handling notes. Corresponds to SAP EKKO.IHREZ (your reference) or header text.']
  order_date date [note: 'The business date on which the purchase order was officially created and issued. This is the principal real-world event date for the procurement commitment. Corresponds to SAP EKKO.BEDAT (document date).']
  payment_terms_code varchar [note: 'Code representing the agreed payment terms between the retailer and supplier (e.g., NET30, NET60, 2/10NET30 for 2% discount if paid within 10 days). Corresponds to SAP EKKO.ZTERM (terms of payment key). Drives accounts payable scheduling and early payment discount capture.']
  po_number varchar [note: 'Externally-known, human-readable purchase order number assigned by the procurement system (SAP MM or Oracle RMS). Used in EDI transmissions, supplier communications, and receiving workflows. Corresponds to SAP EKKO.EBELN field.']
  po_status varchar [note: 'Current lifecycle state of the purchase order from creation through closure. Draft = created but not submitted; Pending Approval = awaiting authorization; Approved = authorized for transmission; Sent = transmitted to supplier via EDI or portal; Partially Received = some goods received; Received = all goods received; Closed = fully processed and closed; Cancelled = voided. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|sent|partially_received|received|closed|cancelled — promote to reference product]']
  po_type varchar [note: 'Classification of the purchase order by procurement method. Standard = regular replenishment PO; Blanket = open-quantity framework agreement; DSD (Direct Store Delivery) = supplier delivers directly to store; Drop Ship = vendor ships direct to customer; Consignment = inventory owned by supplier until sold; RTV (Return to Vendor) = merchandise returned to supplier. [ENUM-REF-CANDIDATE: standard|blanket|direct_store_delivery|drop_ship|consignment|return_to_vendor — promote to reference product]']
  purchasing_group_code varchar [note: 'Code identifying the buyer group or commodity team responsible for this purchase order within the purchasing organization. Used for spend analytics by category and buyer performance reporting. Corresponds to SAP EKKO.EKGRP.']
  purchasing_org_code varchar [note: 'SAP purchasing organization code representing the organizational unit responsible for procuring goods and services. Defines the legal entity and negotiation authority for the purchase order. Corresponds to SAP EKKO.EKORG.']
  source_system_code varchar [note: 'Identifies the operational system of record from which this purchase order record originated. SAP_MM = SAP S/4HANA Materials Management; ORMS = Oracle Retail Merchandising System; MANUAL = manually entered; EDI = created via EDI inbound processing. Used for data lineage and reconciliation.']
  supplier_po_reference varchar [note: 'The supplier\'s own reference number or acknowledgment number for this purchase order, returned via EDI 855 or supplier portal. Used for cross-referencing in supplier invoices, ASNs (Advance Ship Notices), and dispute resolution.']
  total_order_amount decimal(18,2) [note: 'The gross total monetary value of the purchase order before any adjustments, representing the sum of all line item values. Expressed in the currency specified by currency_code. Used for open-to-buy (OTB) tracking, financial commitments, and accounts payable accruals.']
  total_ordered_units decimal(18,3) [note: 'The total quantity of units ordered across all line items on this purchase order. Used for fill rate calculation, receiving reconciliation, and inventory planning. Expressed in the base unit of measure.']
  total_received_units decimal(18,3) [note: 'The total quantity of units physically received and goods-receipted against this purchase order to date. Used to calculate fill rate (order completion percentage) and identify short shipments or over-deliveries.']

  Note: 'Purchase order header records representing procurement commitments to suppliers, managed in SAP MM or Oracle RMS. Captures PO number, supplier reference, buyer, order and expected delivery dates, total value, currency, payment terms, incoterms, PO type (standard, blanket, DSD), approval status, and EDI transmission status. SSOT for the PO lifecycle from creation through closure.'
}

Table supplychain.po_line {
  po_line_id varchar [pk, note: 'Unique surrogate identifier for each purchase order line item in the Silver Layer lakehouse. Primary key for the po_line data product.']
  cost_price_id varchar [note: 'Foreign key linking to pricing.cost_price. Business justification: Each PO line\'s unit_cost must reconcile against the authoritative cost_price record for that SKU/vendor. Linking po_line to cost_price enables cost variance analysis between ordered cost and standard ']
  dc_facility_id varchar [note: 'Reference to the specific destination location (DC, store, or fulfillment center) where this PO line is to be delivered. Supports multi-destination PO management and DC-to-store allocation.']
  item_hierarchy_id varchar [note: 'Foreign key linking to product.item_hierarchy. Business justification: Open-To-Buy (OTB) budget tracking and category-level purchasing reports require PO lines to link directly to item_hierarchy. Retail buyers manage OTB at category level; \'merchandise_category_code\' is ']
  sku_id varchar [note: 'Reference to the master product record for the item being ordered on this PO line. Links to the product master for full item attributes. [RESOURCE_REFERENCE — TRANSACTION_LINE canonical category]']
  supply_purchase_order_id varchar [note: 'Reference to the parent purchase order header to which this line item belongs. Establishes the header-to-line relationship for PO lifecycle tracking. [HEADER_REFERENCE — TRANSACTION_LINE canonical category]']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: PO receiving accuracy and inventory unit reconciliation require PO lines to reference a validated UOM from the product UOM registry. The plain \'uom\' text column is denormalized and causes mismatches d']
  vendor_id varchar [note: 'Reference to the supplier (vendor) fulfilling this PO line. Enables supplier performance analysis at the line level, including fill rate and lead time compliance.']
  actual_delivery_date date [note: 'The date on which goods for this PO line were physically received at the destination. Used to calculate on-time delivery performance and actual lead time versus committed lead time.']
  allowance_amount decimal(18,4) [note: 'Supplier-granted trade allowance or promotional funding amount applied to this PO line (e.g., off-invoice allowance, scan allowance). Reduces net cost and impacts COGS and GMROI calculations.']
  asn_number varchar [note: 'Supplier-provided Advance Shipment Notice (ASN) number associated with the shipment of this PO line. Enables pre-receipt processing at the DC and cross-referencing with EDI 856 transactions.']
  cancel_date date [note: 'The latest date by which this PO line must be received; if not received by this date, the line is automatically cancelled. Critical for seasonal and fashion merchandise to prevent late deliveries.']
  confirmed_delivery_date date [note: 'The delivery date confirmed by the supplier for this PO line. May differ from the requested delivery date; variance drives lead time compliance KPIs and supplier scorecards.']
  confirmed_qty decimal(18,4) [note: 'Quantity confirmed by the supplier as available and committed for shipment on this PO line. May differ from ordered quantity due to supplier capacity constraints or MOQ adjustments.']
  country_of_origin varchar [note: 'ISO 3166-1 alpha-3 country code indicating the country where the product on this PO line was manufactured or produced. Required for customs declarations, import compliance, and consumer labeling regulations.']
  created_timestamp timestamp [note: 'Timestamp when this PO line record was first created in the system, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Provides audit trail for PO creation and supports data lineage tracking.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the unit cost and extended cost on this PO line (e.g., USD, EUR, GBP). Required for multi-currency supplier contracts and financial consolidation.']
  destination_type varchar [note: 'Type of destination for this PO line shipment. Indicates whether goods are routed to a Distribution Center (DC), direct to store (DSD), cross-docking facility, drop ship to customer, or Micro-Fulfillment Center (MFC).']
  extended_cost decimal(18,4) [note: 'Total cost for this PO line calculated as ordered_qty multiplied by unit_cost. Represents the gross financial commitment for this line item before any allowances or discounts.']
  gtin varchar [note: 'GS1-standard Global Trade Item Number (GTIN) for the product on this PO line. Supports EDI transactions, supplier collaboration, and cross-retailer product identification. May be a GTIN-8, GTIN-12 (UPC), GTIN-13 (EAN), or GTIN-14.']
  incoterms varchar [note: 'ICC Incoterms code defining the delivery terms and transfer of risk/cost responsibility between buyer and supplier for this PO line (e.g., FOB, DDP, CIF). Critical for landed cost calculation and logistics planning. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]']
  invoice_number varchar [note: 'Supplier invoice number associated with this PO line for three-way match processing (PO, receipt, invoice). Links to accounts payable for payment processing and FASB ASC 606 revenue recognition compliance.']
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent modification to this PO line record, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Supports change data capture, audit compliance, and Silver Layer incremental processing.']
  lead_time_days varchar [note: 'Committed supplier lead time in calendar days from PO placement to expected delivery for this line item. Used for replenishment planning, OTB management, and supplier SLA compliance monitoring.']
  line_number varchar [note: 'Sequential line item number within the parent purchase order, used to uniquely identify and order line items within a PO. Corresponds to SAP MM item number (EBELP). [LINE_SEQUENCE — TRANSACTION_LINE canonical category]']
  line_status varchar [note: 'Current workflow status of this PO line item, tracking progression from open through fulfillment or cancellation. Drives replenishment alerts and supplier follow-up actions. [LIFECYCLE_STATUS — TRANSACTION_LINE canonical category]']
  moq decimal(18,4) [note: 'The supplier\'s contractual Minimum Order Quantity (MOQ) for this SKU on this PO line. Used to validate ordered_qty compliance and negotiate order consolidation.']
  moq_compliant boolean [note: 'Indicates whether the ordered quantity on this PO line meets or exceeds the supplier\'s Minimum Order Quantity (MOQ) requirement. Non-compliant lines may incur supplier penalties or require buyer approval.']
  net_cost decimal(18,4) [note: 'Net cost per unit after applying all supplier allowances, discounts, and deductions to the unit cost. Represents the true landed cost basis for COGS and margin calculations.']
  order_uom_qty decimal(18,4) [note: 'Number of base selling units (eaches) contained within one purchase unit of measure. Enables conversion between purchase UOM and retail selling UOM for inventory and sales reporting (e.g., 12 eaches per case).']
  ordered_qty decimal(18,4) [note: 'Total quantity of the SKU ordered on this PO line, expressed in the purchase unit of measure. Represents the buyer\'s original demand signal to the supplier. [LINE_QUANTITY — TRANSACTION_LINE canonical category]']
  otb_consumed decimal(18,4) [note: 'Dollar value of Open to Buy (OTB) budget consumed by this PO line at the time of order placement. Used for merchandise financial planning and budget compliance monitoring.']
  received_qty decimal(18,4) [note: 'Quantity of the SKU physically received and confirmed at the distribution center or store against this PO line. Drives inventory on-hand updates and three-way match for invoice processing.']
  rejection_reason varchar [note: 'Reason code or description for any quantity rejected or returned to vendor (RTV) during receiving for this PO line (e.g., damaged goods, wrong item, quality failure). Supports chargeback processing and supplier compliance management.']
  requested_delivery_date date [note: 'The date by which the retailer requests delivery of this PO line at the destination (DC or store). Used for lead time compliance monitoring and replenishment planning.']
  retail_price decimal(18,4) [note: 'Planned retail selling price (AUR - Average Unit Retail) for this SKU at the time of PO creation. Used for initial margin calculation and GMROI planning at the line level.']
  ship_date date [note: 'Date on which the supplier shipped goods for this PO line, as reported via ASN or EDI 856. Used to calculate in-transit duration and validate supplier shipping compliance.']
  shipped_qty decimal(18,4) [note: 'Quantity of the SKU that the supplier has physically shipped against this PO line, as reported via ASN (Advance Shipment Notice) or EDI 856. Used to calculate in-transit inventory.']
  sku varchar [note: 'Internal retailer-assigned Stock Keeping Unit code identifying the specific product variant (size, color, style) ordered on this line. Used for inventory management and POS reconciliation.']
  vendor_item_number varchar [note: 'Supplier\'s own item number or part number for the product on this PO line. Used in EDI transactions and supplier communications to cross-reference retailer SKU with supplier catalog number.']

  Note: 'Line-item detail for each purchase order. Captures SKU/GTIN, ordered quantity, unit of measure, unit cost, extended cost, confirmed quantity, shipped quantity, received quantity, line status, MOQ compliance flag, and lead-time commitment. Enables granular PO tracking at the SKU level.'
}

Table supplychain.dc_facility {
  dc_facility_id varchar [pk, note: 'Unique identifier for the distribution center or micro-fulfillment center facility. Primary key for the DC facility master record.']
  location_id varchar [note: 'Add column location_id (BIGINT) to store.dc_facility with FK to store.location.location_id because DC facilities have physical addresses and should reference a location. P16: connect_table: store.dc_facility** - add column locat']
  region_id varchar [note: 'Foreign key linking to store.region. Business justification: DC facilities are organizationally owned by retail regions; region_id enables regional supply chain reporting, DC capacity planning by region, and regional director oversight. Replaces denormalized ow']
  address_line_1 varchar [note: 'Primary street address line for the facility (street number, street name, building identifier).']
  address_line_2 varchar [note: 'Secondary address line for additional location details (suite, floor, building name) if applicable.']
  automation_level varchar [note: 'Classification of the facility\'s warehouse automation maturity: manual (labor-intensive), semi-automated (some mechanization), highly automated (extensive robotics and conveyors), or fully automated (lights-out operations).']
  bonded_warehouse_flag boolean [note: 'Indicates whether the facility is a customs-bonded warehouse authorized to store imported goods before duties and taxes are paid, enabling deferred duty payment and re-export options.']
  city varchar [note: 'City or municipality where the facility is located.']
  closed_date date [note: 'Date when the facility was permanently closed or decommissioned. Null for active facilities.']
  country_code varchar [note: 'Three-letter ISO 3166-1 alpha-3 country code where the facility is located (e.g., \'USA\', \'CAN\', \'MEX\').']
  created_timestamp timestamp [note: 'Timestamp when this facility record was first created in the master data system.']
  dock_door_count varchar [note: 'Total number of loading dock doors available for inbound receiving and outbound shipping operations.']
  facility_code varchar [note: 'Business-assigned unique alphanumeric code for the facility used in operational systems, shipping documents, and cross-system integration. Typically 4-12 characters.']
  facility_email_address varchar [note: 'Primary email address for the facility used for operational communications, appointment confirmations, and document exchange.']
  facility_manager_name varchar [note: 'Full name of the facility manager or site director responsible for day-to-day operations and performance.']
  facility_name varchar [note: 'Official business name of the distribution center or fulfillment facility (e.g., \'Northeast Regional DC\', \'Manhattan MFC-01\').']
  facility_phone_number varchar [note: 'Primary contact phone number for the facility used for carrier coordination, supplier communication, and operational inquiries.']
  facility_status varchar [note: 'Current operational lifecycle status of the facility. Active facilities are fully operational; planned facilities are approved but not yet built; under construction facilities are being built; decommissioned facilities are permanently closed; temporarily closed facilities are inactive but may reopen; seasonal facilities operate only during peak periods.']
  facility_type varchar [note: 'Classification of the facility based on its primary operational purpose: regional DC (large-scale distribution), micro-fulfillment center (MFC for rapid e-commerce), dark store (fulfillment-only, no retail), cross-dock hub (transshipment), returns center (reverse logistics), or forward stocking location (FSL).']
  gln varchar [note: 'GS1-issued 13-digit Global Location Number uniquely identifying this facility in global supply chain transactions and EDI exchanges.']
  hazmat_certified_flag boolean [note: 'Indicates whether the facility is certified and equipped to handle, store, and ship hazardous materials in compliance with DOT and OSHA regulations.']
  inbound_dock_door_count varchar [note: 'Number of dock doors dedicated to inbound receiving operations from suppliers and carriers.']
  last_updated_timestamp timestamp [note: 'Timestamp when this facility record was most recently modified in the master data system.']
  latitude decimal(10,7) [note: 'Geographic latitude coordinate of the facility in decimal degrees for mapping, routing, and geospatial analytics.']
  lease_expiration_date date [note: 'Date when the current facility lease agreement expires. Null for owned facilities. Used for lease renewal planning and financial forecasting.']
  longitude decimal(10,7) [note: 'Geographic longitude coordinate of the facility in decimal degrees for mapping, routing, and geospatial analytics.']
  opened_date date [note: 'Date when the facility first became operational and began processing inventory and orders.']
  operating_hours_weekday varchar [note: 'Standard operating hours for the facility on weekdays (Monday-Friday) in format \'HH:MM-HH:MM\' (e.g., \'06:00-22:00\'). Used for appointment scheduling and labor planning.']
  operating_hours_weekend varchar [note: 'Standard operating hours for the facility on weekends (Saturday-Sunday) in format \'HH:MM-HH:MM\'. May differ from weekday hours or indicate closed status.']
  outbound_dock_door_count varchar [note: 'Number of dock doors dedicated to outbound shipping operations to stores, customers, or other facilities.']
  ownership_type varchar [note: 'Indicates whether the facility is owned by the company, leased from a landlord, or operated by a third-party logistics provider (3PL). Impacts financial reporting and operational control.']
  postal_code varchar [note: 'Postal or ZIP code for the facility address used for mail delivery and geographic routing.']
  state_province_code varchar [note: 'Two-letter ISO 3166-2 subdivision code for the state, province, or region (e.g., \'CA\' for California, \'ON\' for Ontario).']
  storage_capacity_cubic_feet decimal(15,2) [note: 'Total volumetric storage capacity of the facility measured in cubic feet, accounting for vertical storage utilization.']
  storage_capacity_pallet_positions varchar [note: 'Maximum number of standard pallet positions available for inventory storage in racking and floor storage.']
  temperature_zone_ambient_flag boolean [note: 'Indicates whether the facility has ambient temperature storage zones (room temperature, non-climate-controlled) for general merchandise.']
  temperature_zone_chilled_flag boolean [note: 'Indicates whether the facility has refrigerated (chilled) storage zones typically maintained at 32-40°F for perishable goods like dairy and produce.']
  temperature_zone_frozen_flag boolean [note: 'Indicates whether the facility has frozen storage zones typically maintained at 0°F or below for frozen foods and ice cream.']
  time_zone varchar [note: 'IANA time zone identifier for the facility location (e.g., \'America/New_York\', \'America/Chicago\') used for scheduling and timestamp normalization.']
  total_square_footage decimal(12,2) [note: 'Total building square footage of the facility including warehouse space, office space, and support areas. Measured in square feet.']
  twenty_four_seven_operation_flag boolean [note: 'Indicates whether the facility operates continuously 24 hours per day, 7 days per week to support high-volume or time-sensitive fulfillment requirements.']
  warehouse_square_footage decimal(12,2) [note: 'Square footage dedicated to warehouse operations including storage, picking, packing, and staging areas. Measured in square feet.']
  wms_instance_code varchar [note: 'Identifier for the Manhattan WMS instance or system deployment that manages this facility\'s warehouse operations. Used for system integration and data routing.']

  Note: 'Master record for each distribution center (DC) and micro-fulfillment center (MFC) operated by Retail. Captures facility type (regional DC, MFC, dark store, cross-dock hub, returns center), physical address, square footage, storage capacity (pallet positions, cubic feet), temperature zones (ambient, chilled, frozen), dock door count, operating hours, facility status (active, planned, decommissioned), owning region, and Manhattan WMS instance assignment. SSOT for DC/MFC identity referenced by all distribution operations including zone layout, dock scheduling, carrier assignments, and performance tracking.'
}

Table supplychain.warehouse_zone {
  warehouse_zone_id varchar [pk, note: 'Unique identifier for the warehouse zone. Primary key for the warehouse zone entity.']
  dc_facility_id varchar [note: 'Reference to the parent distribution center or micro-fulfillment center (MFC) that contains this zone.']
  aisle_range_end varchar [note: 'Ending aisle identifier for the zone, defining the end of the physical aisle range contained within this zone for pick path optimization.']
  aisle_range_start varchar [note: 'Starting aisle identifier for the zone, defining the beginning of the physical aisle range contained within this zone for pick path optimization.']
  automation_type varchar [note: 'Level and type of automation deployed in the zone. ASRS = Automated Storage and Retrieval System, AMR = Autonomous Mobile Robot, AGV = Automated Guided Vehicle. [ENUM-REF-CANDIDATE: manual|conveyor|asrs|shuttle|amr|agv|robotic_pick — 7 candidates stripped; promote to reference product]']
  barcode_scanning_required_flag boolean [note: 'Indicates whether barcode scanning is mandatory for all inventory movements within the zone to ensure location accuracy and inventory integrity.']
  cost_center_code varchar [note: 'Financial cost center code for tracking labor, equipment, and operational expenses associated with the zone for profit and loss (P&L) reporting.']
  created_timestamp timestamp [note: 'Timestamp when the zone record was first created in the warehouse management system, used for audit trail and data lineage.']
  current_occupancy_pct decimal(5,2) [note: 'Current space utilization percentage of the zone, calculated as occupied capacity divided by total capacity, used for capacity management and slotting decisions.']
  cycle_count_frequency varchar [note: 'Scheduled frequency for physical inventory cycle counting within the zone, used for inventory accuracy management and shrinkage control.']
  effective_end_date date [note: 'Date when the zone configuration was deactivated or retired from warehouse operations. Null indicates the zone is currently active.']
  effective_start_date date [note: 'Date when the zone configuration became active and available for warehouse operations.']
  hazmat_certified_flag boolean [note: 'Indicates whether the zone is certified and equipped for storage of hazardous materials per OSHA and DOT regulations.']
  last_cycle_count_date date [note: 'Date of the most recent physical inventory cycle count performed in the zone, used for audit trail and inventory accuracy monitoring.']
  last_updated_timestamp timestamp [note: 'Timestamp when the zone record was most recently modified, used for change tracking and audit trail purposes.']
  location_count varchar [note: 'Total number of individual storage locations (bins, slots, shelves, pallet positions) contained within this zone for granular inventory tracking.']
  next_scheduled_cycle_count_date date [note: 'Planned date for the next physical inventory cycle count in the zone, used for operational planning and resource scheduling.']
  notes varchar [note: 'Free-form text field for additional operational notes, special handling instructions, or configuration details relevant to the zone.']
  pick_method varchar [note: 'Primary order picking methodology used in the zone, determining workflow design and labor productivity metrics.']
  rack_configuration_type varchar [note: 'Type of racking system installed in the zone, determining storage density, accessibility, and material handling equipment requirements.']
  replenishment_priority_rank varchar [note: 'Priority ranking for zone replenishment tasks, with lower numbers indicating higher priority for maintaining forward pick face availability.']
  rfid_enabled_flag boolean [note: 'Indicates whether the zone is equipped with RFID infrastructure for automated inventory tracking and real-time location visibility.']
  security_level varchar [note: 'Security classification of the zone determining access control requirements, used for high-value merchandise, controlled substances, or restricted inventory.']
  slotting_strategy varchar [note: 'Inventory slotting methodology applied to the zone for optimizing pick efficiency, labor productivity, and space utilization.']
  temperature_classification varchar [note: 'Temperature control requirement for the zone, critical for grocery retail operations managing perishable goods and food safety compliance.']
  temperature_max_celsius decimal(5,2) [note: 'Maximum allowable temperature threshold for temperature-controlled zones, measured in degrees Celsius. Used for cold chain monitoring and food safety compliance.']
  temperature_min_celsius decimal(5,2) [note: 'Minimum allowable temperature threshold for temperature-controlled zones, measured in degrees Celsius. Used for cold chain monitoring and food safety compliance.']
  total_capacity_cubic_meters decimal(12,2) [note: 'Total volumetric storage capacity of the zone measured in cubic meters, used for space utilization analysis and capacity planning.']
  total_capacity_pallet_positions varchar [note: 'Total number of standard pallet positions available in the zone, critical for slotting optimization and inventory capacity management.']
  weight_capacity_kg decimal(12,2) [note: 'Maximum weight capacity of the zone in kilograms, constrained by floor loading limits and rack weight ratings for safety compliance.']
  zone_code varchar [note: 'Business identifier code for the zone, used for operational reference and pick path planning within the warehouse management system (WMS).']
  zone_name varchar [note: 'Human-readable name of the zone describing its purpose or location within the facility (e.g., Receiving Dock A, Bulk Storage North, Forward Pick Zone 1, Packing Station B).']
  zone_status varchar [note: 'Current operational status of the zone indicating availability for warehouse operations and inventory placement.']
  zone_type varchar [note: 'Functional classification of the zone indicating its primary operational purpose within the distribution center workflow. [ENUM-REF-CANDIDATE: receiving|bulk_storage|forward_pick|reserve|packing|staging|dispatch|returns|cross_dock — 9 candidates stripped; promote to reference product]']

  Note: 'Defines the complete physical layout hierarchy within a DC or MFC, from zones (receiving, bulk storage, forward pick, packing, staging, dispatch, returns) down to individual storage locations (bin, slot, shelf, pallet position, floor stack). Zone-level attributes include zone code, type, temperature classification (ambient, chilled, frozen), aisle range, rack configuration (selective, drive-in, push-back, flow), automation type (manual, conveyor, AS/RS, shuttle, AMR), and zone capacity metrics. Location-level attributes include location code, aisle, bay, level, position, location type (bulk, pick face, reserve, floor, overflow), weight capacity, cubic capacity, RFID/barcode tag, and current occupancy status. SSOT for all physical space definitions within a facility — supports slotting optimization, pick path planning, capacity management, and location-level inventory tracking within Manhattan WMS.'
}

Table supplychain.inbound_shipment {
  inbound_shipment_id varchar [pk, note: 'Primary key for inbound_shipment']
  carrier_id varchar [note: 'Identifier of the transportation carrier responsible for delivering this shipment. Used for carrier performance tracking and freight audit.']
  lead_time_agreement_id varchar [note: 'Foreign key linking to supplier.lead_time_agreement. Business justification: Lead time compliance reporting compares inbound_shipment actual_arrival_date against the governing lead_time_agreement SLA. Logistics teams run \'LTA compliance\' reports per shipment. Without this FK, ']
  origin_facility_dc_facility_id varchar [note: 'Identifier of the originating facility for inter-facility transfers. Null for supplier-direct shipments.']
  origin_vendor_address_id varchar [note: 'Foreign key linking to supplier.vendor_address. Business justification: Inbound shipments originate from a specific vendor address (ship-from location). Freight audit, customs documentation, and carrier routing all require the authoritative vendor_address record. Role pre']
  po_line_id varchar [note: 'Foreign key linking this ASN line to the specific purchase order line being fulfilled by this shipment.']
  primary_inbound_dc_facility_id varchar [note: 'Identifier of the distribution center or micro-fulfillment center receiving this shipment. Determines facility-specific receiving workflows and capacity planning.']
  purchase_order_id varchar [note: 'Foreign key linking to supplychain.purchase_order. Business justification: An inbound shipment arrives at a DC to fulfill a purchase order. Adding purchase_order_id to inbound_shipment establishes the direct procurement-to-receipt traceability chain. While one shipment can t']
  vendor_id varchar [note: 'Identifier of the supplier or vendor originating this shipment. Links to supplier master data for performance tracking and compliance monitoring.']
  actual_arrival_date date [note: 'Actual date the shipment arrived at the distribution center. Used for on-time delivery performance measurement and carrier scorecarding.']
  actual_arrival_timestamp timestamp [note: 'Precise date and time the shipment actually arrived at the distribution center. Captured by yard management system or gate check-in.']
  actual_carton_count varchar [note: 'Total number of cartons actually received and verified during receiving operations. Compared against expected count for discrepancy resolution.']
  actual_pallet_count varchar [note: 'Total number of pallets actually received during receiving operations. Compared against expected count for variance analysis.']
  actual_weight_kg decimal(12,2) [note: 'Total actual weight of the shipment in kilograms as measured during receiving. Used for freight cost verification and variance analysis.']
  asn_number varchar [note: 'Reference number from the EDI 856 Advance Ship Notice document sent by the supplier prior to shipment arrival. Critical for pre-receiving planning and dock scheduling.']
  bill_of_lading_number varchar [note: 'Legal document number issued by the carrier acknowledging receipt of cargo for shipment. Serves as contract of carriage and receipt.']
  carrier_scac_code varchar [note: 'Four-letter code uniquely identifying the transportation carrier. Standard identifier used in EDI transactions and freight documentation.']
  created_timestamp timestamp [note: 'Date and time when this shipment record was first created in the system. Used for audit trail and data lineage tracking.']
  cross_dock_flag boolean [note: 'Indicates whether this shipment is designated for cross-docking operations, bypassing putaway and moving directly to outbound staging.']
  dock_door_number varchar [note: 'Identifier of the specific dock door assigned for receiving this shipment. Used for yard management and receiving workflow coordination.']
  expected_arrival_date date [note: 'Planned date the shipment is expected to arrive at the distribution center. Used for dock scheduling and labor planning.']
  expected_arrival_timestamp timestamp [note: 'Precise date and time the shipment is expected to arrive at the distribution center. Used for appointment scheduling and dock door allocation.']
  expected_carton_count varchar [note: 'Total number of cartons expected in this shipment as communicated in the ASN. Used for receiving planning and variance detection.']
  expected_cube_m3 decimal(12,3) [note: 'Total expected volume of the shipment in cubic meters. Used for warehouse space planning and transportation capacity optimization.']
  expected_pallet_count varchar [note: 'Total number of pallets expected in this shipment as communicated in the ASN. Used for dock space allocation and material handling equipment planning.']
  expected_weight_kg decimal(12,2) [note: 'Total expected weight of the shipment in kilograms as communicated in the ASN. Used for freight audit and capacity planning.']
  freight_cost_amount decimal(15,2) [note: 'Total freight transportation cost for this inbound shipment. Used for landed cost calculation and freight spend analysis.']
  freight_currency_code varchar [note: 'Three-letter ISO currency code for the freight cost amount. Enables multi-currency freight cost tracking and consolidation.']
  hazmat_flag boolean [note: 'Indicates whether this shipment contains hazardous materials requiring special handling and regulatory compliance. True triggers HAZMAT receiving protocols.']
  last_updated_timestamp timestamp [note: 'Date and time when this shipment record was most recently modified. Used for change tracking and data synchronization.']
  late_arrival_reason_code varchar [note: 'Standardized code explaining the reason for late arrival when on-time arrival flag is false. Used for root cause analysis and carrier accountability.']
  line_status varchar [note: 'Current workflow status of this specific ASN line, tracking progression from open through receiving completion or discrepancy resolution. Distinct from inbound_shipment.shipment_status (header-level) and po_line.line_status (order fulfillment-level).']
  notes varchar [note: 'Free-text field for capturing additional information, special instructions, or exceptions related to this inbound shipment.']
  on_time_arrival_flag boolean [note: 'Indicates whether the shipment arrived within the scheduled appointment window. Used for carrier performance scorecarding and SLA compliance.']
  pro_number varchar [note: 'Carrier-assigned tracking number for the shipment. Used for freight tracking and proof of delivery.']
  received_qty decimal [note: 'Quantity of the SKU physically received and verified at the DC for this PO line on this shipment during the receiving process. Used for three-way match and discrepancy identification. Belongs to the shipment-PO line intersection, not to either parent entity alone.']
  receiving_complete_timestamp timestamp [note: 'Date and time when all receiving operations were completed for this shipment. Marks closure of the receiving process and inventory availability.']
  receiving_start_timestamp timestamp [note: 'Date and time when receiving operations began for this shipment. Marks the start of unloading and inspection activities.']
  seal_number varchar [note: 'Security seal number applied to the trailer or container. Verified at receiving to ensure shipment integrity and prevent tampering.']
  shipment_number varchar [note: 'Business identifier for the inbound shipment, typically referenced in communications with suppliers and carriers. May be system-generated or supplier-provided.']
  shipment_status varchar [note: 'Current lifecycle status of the inbound shipment. Tracks progression from in-transit through receiving completion or cancellation.']
  shipment_type varchar [note: 'Classification of the inbound shipment based on origin and purpose. Determines receiving workflow and handling requirements.']
  shipped_qty decimal [note: 'Quantity of the SKU that the vendor shipped for this specific PO line on this specific inbound shipment, expressed in the purchase unit of measure. Sourced from the EDI 856 ASN line detail. Cannot reside on inbound_shipment (header-level) or po_line (cumulative order-level).']
  temperature_compliant_flag boolean [note: 'Indicates whether the shipment maintained required temperature throughout transit. False triggers quality inspection and potential rejection.']
  temperature_controlled_flag boolean [note: 'Indicates whether this shipment requires temperature-controlled handling for cold chain compliance. True for refrigerated or frozen goods.']
  temperature_max_celsius decimal(5,2) [note: 'Maximum acceptable temperature in Celsius for temperature-controlled shipments. Used for cold chain compliance monitoring.']
  temperature_min_celsius decimal(5,2) [note: 'Minimum acceptable temperature in Celsius for temperature-controlled shipments. Used for cold chain compliance monitoring.']
  temperature_requirement varchar [note: 'Specific temperature range requirement for this shipment. Determines receiving dock assignment and storage location.']
  trailer_number varchar [note: 'Identification number of the trailer or container used to transport the shipment. Critical for yard management and dock door assignment.']

  Note: 'Tracks inbound shipments arriving at a DC or MFC from suppliers, vendors, or inter-facility transfers. Captures ASN (Advance Ship Notice) reference, carrier, trailer number, expected and actual arrival date/time, PO references, total carton and pallet counts, shipment status (in-transit, arrived, receiving, closed), and temperature compliance flag for cold chain shipments. Integrates with EDI 856 ASN feeds and Manhattan WMS receiving workflows. SSOT for all inbound freight visibility at the distribution center level.'
}

Table supplychain.receiving_event {
  receiving_event_id varchar [pk, note: 'Unique identifier for the receiving event. Primary key for this product.']
  carrier_id varchar [note: 'Reference to the carrier that delivered the inbound shipment.']
  dc_facility_id varchar [note: 'Reference to the distribution center where the receiving event occurred.']
  inbound_shipment_id varchar [note: 'Reference to the inbound shipment being received at the dock door.']
  purchase_order_id varchar [note: 'Foreign key linking to supplychain.purchase_order. Business justification: receiving_event currently stores purchase_order_number as a denormalized STRING. This violates normalization — the PO is a first-class entity in this domain. Replacing purchase_order_number with a pro']
  vendor_id varchar [note: 'Reference to the supplier who shipped the goods being received.']
  warehouse_zone_id varchar [note: 'Foreign key linking to supplychain.warehouse_zone. Business justification: A receiving event occurs at a specific dock/receiving zone within the DC. warehouse_zone defines the physical layout including receiving zones. Linking receiving_event to warehouse_zone_id enables zon']
  actual_carton_count varchar [note: 'The actual number of cartons physically received and verified during the receiving event.']
  actual_pallet_count varchar [note: 'The actual number of pallets physically received and verified during the receiving event.']
  actual_unit_quantity varchar [note: 'The total number of individual units (eaches) physically received and verified during the receiving event.']
  advance_ship_notice_number varchar [note: 'The ASN number provided by the supplier, used to match expected shipment details with actual received goods.']
  bill_of_lading_number varchar [note: 'The bill of lading number associated with the inbound shipment, used for carrier reconciliation.']
  carton_variance_count varchar [note: 'The difference between expected and actual carton count (actual minus expected). Positive indicates overage, negative indicates shortage.']
  created_timestamp timestamp [note: 'The timestamp when the receiving event record was first created in the warehouse management system.']
  damage_flag boolean [note: 'Indicates whether any damaged goods were identified during the receiving event.']
  damaged_unit_quantity varchar [note: 'The number of units identified as damaged during the receiving inspection.']
  discrepancy_reason_code varchar [note: 'Code indicating the reason for any discrepancy between expected and actual quantities (e.g., supplier short ship, damaged in transit, incorrect ASN).']
  dock_door_number varchar [note: 'The specific dock door assignment where the inbound shipment was unloaded.']
  expected_carton_count varchar [note: 'The number of cartons expected to be received based on the advance shipment notice or purchase order.']
  expected_pallet_count varchar [note: 'The number of pallets expected to be received based on the advance shipment notice or purchase order.']
  expected_unit_quantity varchar [note: 'The total number of individual units (eaches) expected to be received based on the advance shipment notice or purchase order.']
  hazmat_flag boolean [note: 'Indicates whether the received shipment contains hazardous materials requiring special handling.']
  last_updated_timestamp timestamp [note: 'The timestamp when the receiving event record was last modified in the warehouse management system.']
  overage_flag boolean [note: 'Indicates whether the receiving event resulted in an overage (more units received than expected).']
  pallet_variance_count varchar [note: 'The difference between expected and actual pallet count (actual minus expected). Positive indicates overage, negative indicates shortage.']
  putaway_task_generated_flag boolean [note: 'Indicates whether putaway tasks have been automatically generated in the WMS following the receiving event.']
  quality_inspection_required_flag boolean [note: 'Indicates whether the received goods require quality inspection before being made available for putaway or sale.']
  receiving_event_number varchar [note: 'Business-readable unique identifier for the receiving event, used for tracking and reporting.']
  receiving_notes varchar [note: 'Free-text notes entered by the receiving clerk documenting any observations, issues, or special handling instructions.']
  receiving_status varchar [note: 'Current lifecycle status of the receiving event.']
  receiving_type varchar [note: 'Type of receiving operation: blind receiving (no advance shipment notice), directed receiving (with ASN), cross-dock, return to vendor, or inter-facility transfer.']
  seal_intact_flag boolean [note: 'Indicates whether the security seal was found intact upon arrival. False indicates potential tampering or security breach.']
  seal_number varchar [note: 'The security seal number on the trailer or container, verified during receiving to ensure shipment integrity.']
  shortage_flag boolean [note: 'Indicates whether the receiving event resulted in a shortage (fewer units received than expected).']
  temperature_compliant_flag boolean [note: 'Indicates whether temperature-controlled shipments arrived within the required temperature range.']
  temperature_reading decimal(5,2) [note: 'The actual temperature reading (in Celsius) recorded upon arrival for temperature-controlled shipments.']
  trailer_number varchar [note: 'The trailer or container number of the vehicle that delivered the shipment.']
  unit_variance_quantity varchar [note: 'The difference between expected and actual unit quantity (actual minus expected). Positive indicates overage, negative indicates shortage.']
  unload_duration_minutes varchar [note: 'Total time in minutes taken to unload the shipment, calculated from start to end timestamp.']
  unload_end_timestamp timestamp [note: 'The timestamp when the unloading of the inbound shipment was completed.']
  unload_start_timestamp timestamp [note: 'The timestamp when the unloading of the inbound shipment began at the dock door.']

  Note: 'Captures the physical receiving activity at a DC dock door when inbound shipments are unloaded and verified. Records dock door assignment, unload start/end timestamps, cartons received vs. expected, discrepancy flags (overage, shortage, damage), receiver employee ID, pallet count, and blind vs. directed receiving mode. Each receiving event is tied to an inbound shipment and drives put-away task generation in Manhattan WMS.'
}

Table supplychain.outbound_order {
  outbound_order_id varchar [pk, note: 'Unique identifier for the distribution center outbound order. Primary key for this entity. Role: TRANSACTION_HEADER.']
  carrier_id varchar [note: 'Identifier of the transportation carrier assigned to deliver this outbound order.']
  destination_dc_facility_id varchar [note: 'Identifier of the destination node (store, customer, DC, 3PL facility) receiving this shipment. Polymorphic reference interpreted based on destination_type.']
  destination_location_id varchar [note: 'Foreign key linking to store.location. Business justification: Outbound orders shipping to stores require a store location FK for store-level replenishment tracking, fill-rate reporting by store, and OMS routing. New column destination_location_id (nullable, used']
  primary_outbound_dc_facility_id varchar [note: 'Identifier of the distribution center or micro-fulfillment center (MFC) fulfilling this outbound order.']
  promo_campaign_id varchar [note: 'Reference to the promotional event or campaign driving this outbound order, if applicable. Links fulfillment to promotional planning.']
  replenishment_plan_id varchar [note: 'Reference to the replenishment plan that generated this outbound order. Links execution to planning layer.']
  actual_delivery_date date [note: 'Date when the order was confirmed delivered to the destination. Null until delivery confirmation is received.']
  actual_ship_date date [note: 'Date when the order was actually shipped from the facility. Null until shipment occurs.']
  bill_of_lading_number varchar [note: 'Bill of lading number issued for this shipment. Legal document acknowledging receipt of cargo for shipment.']
  cancellation_reason_code varchar [note: 'Code indicating the reason for order cancellation: inventory unavailable, destination closed, carrier unavailable, customer request, etc. Null if order not cancelled.']
  carrier_service_level varchar [note: 'Transportation service level selected for this shipment: ground (standard), express (expedited), next-day, two-day, same-day, LTL (Less Than Truckload), or FTL (Full Truckload). [ENUM-REF-CANDIDATE: ground|express|next_day|two_day|same_day|ltl|ftl — 7 candidates stripped; promote to reference product]']
  created_timestamp timestamp [note: 'Timestamp when this outbound order record was first created in the warehouse management system. Audit trail for record inception.']
  destination_address_line1 varchar [note: 'Primary street address line for the shipment destination. Required for customer and store deliveries.']
  destination_city varchar [note: 'City name for the shipment destination address.']
  destination_country_code varchar [note: 'Three-letter ISO country code for the shipment destination (e.g., USA, CAN, MEX).']
  destination_postal_code varchar [note: 'Postal or ZIP code for the shipment destination address.']
  destination_state_province varchar [note: 'State or province code for the shipment destination address.']
  destination_type varchar [note: 'Type of destination node receiving this outbound shipment: store (retail location), customer (direct-to-consumer), distribution center (inter-DC transfer), 3PL node (third-party logistics partner), or supplier (return to vendor).']
  dock_door_number varchar [note: 'Outbound dock door number from which this order was loaded for shipment.']
  fill_rate_pct decimal(5,2) [note: 'Percentage of ordered units successfully fulfilled and shipped. Calculated as (shipped units / ordered units) * 100. Key supply chain KPI.']
  is_cross_dock boolean [note: 'Boolean flag indicating whether this order was fulfilled via cross-docking (direct transfer from inbound to outbound without storage).']
  is_drop_ship boolean [note: 'Boolean flag indicating whether this order is fulfilled via drop ship (vendor ships directly to customer, bypassing DC).']
  is_hazmat boolean [note: 'Boolean flag indicating whether this order contains hazardous materials requiring special handling and documentation.']
  is_temperature_controlled boolean [note: 'Boolean flag indicating whether this order requires temperature-controlled transportation (refrigerated or frozen goods).']
  last_updated_timestamp timestamp [note: 'Timestamp when this outbound order record was last modified. Audit trail for record changes.']
  notes varchar [note: 'Free-text notes or special instructions for this outbound order. May include handling instructions, delivery requirements, or operational comments.']
  order_date date [note: 'Date when the outbound order was created in the warehouse management system. Business event timestamp representing order inception.']
  order_number varchar [note: 'Business-facing unique order number assigned to this outbound shipment. Used for tracking and communication with destination nodes.']
  order_status varchar [note: 'Current lifecycle status of the outbound order in the warehouse management workflow. Tracks progression from order creation through final delivery or cancellation. [ENUM-REF-CANDIDATE: draft|released|waved|picking|picked|packing|packed|shipped|in_transit|delivered|closed|cancelled — 12 candidates stripped; promote to reference product]']
  order_type varchar [note: 'Classification of the outbound order indicating the fulfillment purpose: store replenishment (push inventory to stores), e-commerce fulfillment (direct-to-customer), BOPIS (Buy Online Pick Up In Store), ROPIS (Reserve Online Pick Up In Store), inter-DC transfer (distribution center to distribution center), or DSD bypass (Direct Store Delivery bypass).']
  priority_level varchar [note: 'Priority classification for order fulfillment. Critical orders (e.g., stockout replenishment, promotional merchandise) are processed ahead of normal flow.']
  pro_number varchar [note: 'Progressive number assigned by LTL carriers for freight tracking and billing.']
  replenishment_reason_code varchar [note: 'Code indicating the business reason for this replenishment order: stockout prevention, promotional support, seasonal refresh, new item introduction, etc.']
  replenishment_type varchar [note: 'For store replenishment orders: method used to determine replenishment quantities. Push (DC-initiated based on forecast), pull (store-requested), min-max (reorder point triggered), VMI (Vendor Managed Inventory), promotional (event-driven), seasonal (seasonal assortment), or new store (initial stock). [ENUM-REF-CANDIDATE: push|pull|min_max|vmi|promotional|seasonal|new_store — 7 candidates stripped; promote to reference product]']
  requested_ship_date date [note: 'Date by which the order is requested to ship from the distribution center or micro-fulfillment center. Used for planning and wave assignment.']
  required_delivery_date date [note: 'Date by which the order must be delivered to the destination node to meet business commitments or replenishment schedules.']
  temperature_requirement varchar [note: 'Temperature control requirement for this shipment: ambient (room temperature), refrigerated (2-8°C), frozen (below -18°C), or climate-controlled (specific range).']
  total_cartons varchar [note: 'Total number of cartons or cases packed for this outbound order.']
  total_cube_m3 decimal(12,3) [note: 'Total cubic volume of the outbound order in cubic meters. Used for trailer capacity planning and freight optimization.']
  total_lines varchar [note: 'Total number of distinct SKU line items included in this outbound order.']
  total_pallets varchar [note: 'Total number of pallets loaded for this outbound order.']
  total_units varchar [note: 'Total quantity of units (eaches) across all lines in this outbound order.']
  total_weight_kg decimal(12,3) [note: 'Total gross weight of the outbound order in kilograms. Used for carrier selection and freight cost calculation.']
  tracking_number varchar [note: 'Carrier-provided tracking number for this shipment. Used for shipment visibility and proof of delivery.']
  trailer_number varchar [note: 'Identifier of the trailer or container loaded with this outbound order.']

  Note: 'Represents a distribution outbound order directing the DC or MFC to fulfill and ship goods to a destination (store, customer, 3PL node). Captures order type (store replenishment, e-commerce, BOPIS, DSD bypass, inter-DC transfer), destination node, requested ship date, required delivery date, priority level, total lines/units/weight/cube, wave assignment, and order status lifecycle (released, waved, picking, packed, shipped, closed). For store replenishment: captures replenishment type (push, pull, min-max, VMI), replenishment reason, demand planning source reference, and replenishment frequency. Central transactional entity for all DC outbound execution including store replenishment, e-commerce fulfillment, and inter-facility transfers.'
}

Table supplychain.outbound_order_line {
  outbound_order_line_id varchar [pk, note: 'Unique identifier for each line item within an outbound distribution order. Primary key for the outbound order line entity.']
  carrier_id varchar [note: 'Transportation carrier assigned to ship this line item. Links to carrier master for service levels, rates, and performance metrics.']
  cost_price_id varchar [note: 'Foreign key linking to pricing.cost_price. Business justification: Outbound order lines carry unit_cost and extended_cost for DC-to-store inventory transfer valuation. Linking to cost_price enables transfer cost validation, inventory valuation accuracy, and inter-loc']
  dc_facility_id varchar [note: 'Distribution center fulfilling this outbound order line. Links to DC master for facility capacity, operating hours, and carrier relationships.']
  department_id varchar [note: 'Foreign key linking to store.department. Business justification: Outbound order lines represent store replenishment by SKU; linking to store department enables department-level fill-rate reporting, shrinkage analysis, and replenishment performance tracking — a stan']
  outbound_order_id varchar [note: 'Reference to the parent outbound distribution order header. Links this line to its containing order for fulfillment tracking and shipment consolidation.']
  primary_outbound_location_id varchar [note: 'Retail store or fulfillment node receiving this line item. Links to store master for address, capacity, and operational attributes.']
  sku_id varchar [note: 'Reference to the master product record for this line item. Links to product master data for attributes, pricing, and merchandising information.']
  source_location_id varchar [note: 'Warehouse storage location from which this line item was picked. Links to warehouse location master for zone, aisle, and bin tracking.']
  stock_position_id varchar [note: 'Foreign key linking to inventory.stock_position. Business justification: DC allocation management: outbound_order_line allocates specific quantities from a stock_position at the DC. Retail DC planners need to link outbound allocations to the specific stock_position record ']
  uom_id varchar [note: 'Foreign key linking to product.uom. Business justification: Pick/pack accuracy and outbound fulfillment unit reconciliation require outbound order lines to reference a validated UOM. The plain \'unit_of_measure\' text column is denormalized; a FK to product.uom ']
  warehouse_zone_id varchar [note: 'Foreign key linking to supplychain.warehouse_zone. Business justification: Outbound order lines are picked from specific warehouse zones (bulk storage, pick face, refrigerated zone, etc.). Linking outbound_order_line to warehouse_zone_id enables pick zone performance analysi']
  allocated_qty decimal(15,3) [note: 'Quantity of units allocated from available inventory to fulfill this line. May differ from ordered quantity due to stock availability constraints.']
  carton_number varchar [note: 'Shipping carton or container identifier containing this line item. Used for package-level tracking and multi-carton shipment management.']
  created_timestamp timestamp [note: 'Date and time when this outbound order line record was first created in the warehouse management system. Audit trail for order entry and system integration.']
  currency_code varchar [note: 'Three-letter ISO currency code for all monetary amounts on this line. Enables multi-currency operations and financial consolidation.']
  expiry_date date [note: 'Product expiration or best-before date for perishable goods. Drives FEFO (First Expired First Out) picking logic and shelf-life management.']
  extended_cost decimal(18,4) [note: 'Total cost for this line (unit cost multiplied by shipped quantity). Represents inventory value transferred from DC to destination.']
  gtin varchar [note: 'Global trade item number (UPC, EAN, or GTIN-14) for the product. Enables cross-system product identification and EDI transaction processing.']
  handling_instructions varchar [note: 'Special handling requirements or notes for warehouse and carrier personnel. Includes fragile, orientation, stacking, and security instructions.']
  is_hazmat boolean [note: 'Indicates whether this line contains hazardous materials requiring special handling, labeling, and carrier certification per DOT regulations.']
  is_temperature_controlled boolean [note: 'Indicates whether this line requires refrigerated or climate-controlled transportation and storage to maintain product integrity.']
  last_updated_timestamp timestamp [note: 'Date and time of the most recent update to this line record. Tracks status changes, quantity adjustments, and data corrections throughout fulfillment lifecycle.']
  line_number varchar [note: 'Sequential line number within the outbound order. Establishes ordering and uniqueness of line items within a single order document.']
  line_status varchar [note: 'Current fulfillment status of this order line. Tracks progression through warehouse workflow from allocation through shipment or cancellation. [ENUM-REF-CANDIDATE: pending|allocated|picked|packed|shipped|cancelled|short_shipped|backordered — 8 candidates stripped; promote to reference product]']
  lot_number varchar [note: 'Manufacturing lot or batch number for traceability. Critical for product recalls, quality control, and regulatory compliance in food and pharmaceutical retail.']
  ordered_qty decimal(15,3) [note: 'Quantity of units originally requested for this line item. Represents the demand signal from the destination location or customer.']
  original_sku varchar [note: 'Original SKU requested if a substitution was made. Enables demand signal accuracy and substitution pattern analysis for assortment planning.']
  packed_qty decimal(15,3) [note: 'Quantity of units packed into shipping containers for this line. Confirms units staged for outbound shipment and ready for carrier pickup.']
  picked_qty decimal(15,3) [note: 'Actual quantity of units physically picked from warehouse storage locations. Reflects warehouse execution accuracy and inventory availability.']
  serial_number varchar [note: 'Unique serial number for serialized items such as electronics, appliances, or high-value goods. Enables item-level tracking and warranty management.']
  shipped_qty decimal(15,3) [note: 'Final quantity of units shipped to the destination. Used for fill rate calculation, short-ship identification, and invoice reconciliation.']
  short_ship_qty decimal(15,3) [note: 'Quantity variance between ordered and shipped units. Represents unfulfilled demand due to stockouts, damage, or allocation constraints.']
  short_ship_reason_code varchar [note: 'Reason code explaining why this line was short-shipped. Used for root cause analysis, supplier performance tracking, and inventory planning improvement.']
  sku varchar [note: 'Internal stock keeping unit code identifying the specific product variant being shipped. Used for inventory tracking and warehouse operations.']
  substitution_flag boolean [note: 'Indicates whether a substitute product was shipped in place of the originally ordered SKU due to stockout or allocation constraints.']
  temperature_requirement varchar [note: 'Specific temperature control requirement for this line item. Drives carrier selection, routing, and cold chain compliance monitoring.']
  volume_cubic_meters decimal(12,3) [note: 'Total cubic volume of this line item. Used for trailer utilization, storage capacity planning, and dimensional weight pricing.']
  weight_kg decimal(12,3) [note: 'Total weight of this line item in kilograms. Used for freight cost calculation, carrier capacity planning, and load optimization.']

  Note: 'Line-level detail for each SKU within an outbound distribution order. Captures SKU/UPC, ordered quantity, allocated quantity, picked quantity, packed quantity, shipped quantity, unit of measure, lot number, expiry date, storage location sourced from, and line status. Enables granular fulfillment tracking and short-ship identification at the SKU level.'
}

