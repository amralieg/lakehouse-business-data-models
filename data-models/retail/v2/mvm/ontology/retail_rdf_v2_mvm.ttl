# RDFS Schema for Business: Retail

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/retail#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Retail ---
ind:Retail rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Retail' ;
    rdfs:comment 'retail industry enterprise data model.' .

# --- Domain Classes ---
ind:Inventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Inventory' ;
    rdfs:comment 'Manages real-time and historical stock positions across all nodes including stores, DCs, and MFCs. Owns on-hand quantities, SKU-level tracking, shrinkage monitoring, dead stock identification, weeks of supply (WOS), sell-through rates, replenishment triggers, cycle counts, and RFID-based tracking. Supports VMI (Vendor Managed Inventory), inventory valuation (COGS), and real-time inventory visibility for omnichannel fulfillment.' .

ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Customer' ;
    rdfs:comment 'Single source of truth for all customer identity, profiles, households, segments (B2C and B2B), contact information, preferences, and RFM (Recency Frequency Monetary) analytics. Manages customer lifecycle, NPS scores, CLTV (Customer Lifetime Value), CAC (Customer Acquisition Cost), consent/privacy preferences, and omnichannel interaction history. Supports personalized clienteling and customer recognition across POS, e-commerce, and mobile.' .

ind:Product rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Product' ;
    rdfs:comment 'Authoritative catalog of all merchandise including SKUs, UPCs, GTINs, EANs, product hierarchies (department, category, subcategory), attributes, descriptions, images, private label vs. national brands, and assortment depth and breadth classifications. Managed via PIM (Product Information Management) and MDM systems. Supports category management, new item setup, and product lifecycle from introduction to discontinuation.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Order' ;
    rdfs:comment 'Manages omnichannel order lifecycle from cart creation through fulfillment including online orders, in-store POS transactions, BOPIS (Buy Online Pick Up In Store), ROPIS, ship-from-store (SFS), and drop-ship orders. Tracks order headers, line items, payment methods, fulfillment status, delivery tracking, and RMA (Return Merchandise Authorization). Integrates with OMS for end-to-end order orchestration.' .

ind:Store rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Store' ;
    rdfs:comment 'Manages physical retail locations including hypermarkets, department stores, discount outlets, dark stores, and micro-fulfillment centers (MFC). Owns store master records, planograms (POG), gondola and endcap configurations, footfall metrics, comp sales (SSS - Same-Store Sales), visual merchandising standards, POS terminal inventory, and store-level P&L. Supports store operations and omnichannel fulfillment as ship-from-store nodes.' .

ind:Pricing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Pricing' ;
    rdfs:comment 'SSOT for all pricing strategies including EDLP (Everyday Low Price), Hi-Lo pricing, competitive pricing, markdowns, ASP (Average Selling Price), AUR (Average Unit Retail), dynamic pricing rules, price zones, and cost-plus margins. Tracks GMROI (Gross Margin Return on Investment), price change audit trails, and markdown optimization. Integrates with Oracle Retail Price Management (RPM) for enterprise-wide pricing governance.' .

ind:Promotion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Promotion' ;
    rdfs:comment 'Manages promotional campaigns, deals, coupons, rebates, BOGO offers, seasonal sales events, circular ads, and digital promotions across channels. Tracks promotion effectiveness, redemption rates, incremental lift, promotional ROI, and vendor-funded promotion agreements. Distinct from pricing — promotions are time-bound, event-driven incentives. Supports omnichannel promotion execution across POS, e-commerce, and mobile apps.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Authoritative source for supplier and vendor master data including contact information, contracts, compliance certifications, performance scorecards, chargebacks (vendor compliance penalties), RTV (Return to Vendor) processes, EDI integration, MOQ and lead time agreements, and VMI configurations. Manages supplier onboarding, qualification, risk assessment, and ongoing relationship management for national brands, private label manufacturers, and DSD vendors.' .

ind:Ecommerce rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Ecommerce' ;
    rdfs:comment 'Manages digital commerce operations including online storefronts, product catalogs, shopping carts, checkout flows, digital payment processing, session tracking, CTR (Click-Through Rate), CR (Conversion Rate), AOV (Average Order Value), and GMV (Gross Merchandise Value). Tracks digital customer journeys, abandoned carts, and online-to-offline attribution. Integrates with Salesforce Commerce Cloud for unified digital commerce platform.' .

ind:Fulfillment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Fulfillment' ;
    rdfs:comment 'Manages order picking, packing, ship-from-store, BOPIS/ROPIS processing, dark store fulfillment, last-mile delivery execution, carrier selection, route optimization, and fulfillment KPI tracking. Owns the operational execution layer between order capture and customer delivery, including transportation planning and last-mile logistics.' .

ind:Returns rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Returns' ;
    rdfs:comment 'Manages reverse logistics, RMA/RTV processing, restocking workflows, disposition of returned merchandise, refund processing, and return reason analytics. Owns the complete returns lifecycle from customer initiation through final disposition including vendor returns and liquidation.' .

ind:Supplychain rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Supplychain' ;
    rdfs:comment 'Manages end-to-end supply chain planning and execution from demand forecasting through distribution center operations, including facility management, warehouse workflows, inbound/outbound logistics, replenishment planning, purchase order lifecycle, cross-docking, and supply chain performance monitoring.' .

# --- Data Product Classes (Tables) ---
ind:StockPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Position' ;
    rdfs:comment 'Real-time on-hand stock position for every SKU at each inventory node (store, DC, MFC, dark store). Captures on-hand quantity, available-to-promise (ATP), reserved quantity, in-transit quantity, on-order quantity, damaged/quarantine quantity, and velocity indicators. Authoritative SSOT for current inventory levels consumed by omnichannel fulfillment (ATP/promising), replenishment triggers, and store operations. Updated by goods receipts, sales depletions, adjustments, transfers, and reservations.' .

ind:StockLedger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Ledger' ;
    rdfs:comment 'Perpetual inventory ledger capturing every stock movement transaction at the SKU-location-date level. Records receipts, sales depletions, transfers, adjustments, returns, and write-offs with quantity, unit cost (COGS), and extended value. Supports inventory valuation methods (FIFO, WAC, retail method), shrinkage tracking, and financial reconciliation with the general ledger. Authoritative SSOT for inventory value and movement history within the inventory domain.' .

ind:InventoryNode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Inventory Node' ;
    rdfs:comment '[SSOT Owner] Authoritative source for inventory-holding locations (stores, DCs, 3PL nodes). Defines physical attributes, capabilities, and capacity of each node in the inventory network.' .

ind:ReplenishmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Replenishment Order' ;
    rdfs:comment 'Replenishment order records generated by demand planning and replenishment systems to restock SKUs at stores or DCs. Captures order type (auto-replenishment, manual, VMI), source node, destination node, ordered quantity, approved quantity, expected delivery date, lead time, MOQ compliance, and fulfillment status. Tracks the full replenishment lifecycle from trigger (based on reorder_policy thresholds) through receipt at the destination node.' .

ind:CycleCount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Cycle Count' ;
    rdfs:comment 'Scheduled and ad-hoc physical inventory cycle count events at the SKU-location level. Captures count schedule, assigned counter, counted quantity, system quantity at time of count, variance quantity, variance percentage, count status (scheduled, in-progress, completed, reconciled), and approval workflow. Supports shrinkage investigation, inventory accuracy KPIs, and Sarbanes-Oxley inventory controls. Variances exceeding tolerance thresholds generate inventory_adjustment records for reconciliation.' .

ind:Adjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Adjustment' ;
    rdfs:comment 'Records all inventory quantity adjustments at the SKU-location level including shrinkage events, damage write-downs, cycle count corrections, receiving variances, expiry write-offs, and RTVs. Captures adjustment reason category, sub-reason (e.g., shoplifting, employee theft, admin error for shrinkage), adjusted quantity, cost impact, detection method, authorizing user, approval status, and loss prevention case reference where applicable. Feeds the stock_ledger and serves as the SSOT for all non-transactional inventory changes and shrinkage monitoring.' .

ind:StockTransfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Transfer' ;
    rdfs:comment 'Inter-node stock transfer records capturing movement of inventory between stores, DCs, MFCs, and vendor locations. Captures transfer type (store-to-store, DC-to-store, cross-dock, RTV), source node, destination node, SKU, transfer quantity, shipment date, expected receipt date, actual receipt date, carrier, and transfer status. Supports omnichannel fulfillment (ship-from-store) and network balancing.' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Records physical receipt of merchandise at DCs, stores, and MFCs against purchase orders, replenishment orders, or transfer orders. Captures receipt date, receiving node, supplier/source, PO/ASN reference, line-level received/accepted/rejected quantities with discrepancy details (shortage, overage, wrong SKU, damage), unit cost, receipt method (DSD, DC-to-store, cross-dock), quality inspection status, and discrepancy resolution status. Supports receiving workflows, vendor compliance chargebacks, and inventory accuracy at point of induction.' .

ind:Reservation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Reservation' ;
    rdfs:comment 'Records all inventory encumbrances that restrict stock from general availability — including soft-allocations (BOPIS reservation, ship-from-store allocation, e-commerce hold) and hard holds (quality hold, regulatory recall, legal hold, damage hold, price investigation). Captures encumbrance type, SKU, quantity, node, start/expiry timestamps, associated order or case reference, authorizing party, hold reason, authorizing department, release status, and resolution details. Single source of truth for all reserved and held stock, enabling accurate ATP calculation on stock_position.' .

ind:ReorderPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Reorder Policy' ;
    rdfs:comment 'SKU-location level replenishment parameters defining when and how much to reorder. Captures reorder method (min/max, days-of-supply, WOS-based, forecast-driven), reorder point, safety stock, min/max levels, order multiple (MOQ/case pack), lead time, review cycle, supplier preference, and policy effective/expiry dates. Trigger thresholds generate inventory_replenishment_order records when stock_position breaches defined levels. Owned and maintained by replenishment planners; consumed by automated replenishment engines.' .

ind:Lot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Lot' ;
    rdfs:comment 'Master record for inventory lot/batch tracking at the SKU level. Captures lot number, manufacture date, expiry date, supplier lot reference, and quality status. Supports traceability for food safety (FDA FSMA) and recall management.' .

ind:Profile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Profile' ;
    rdfs:comment 'Core customer identity record. Represents a single known individual or organization with master attributes. B2C customers typically have only a profile; B2B relationships additionally use the account entity.' .

ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account' ;
    rdfs:comment 'Optional B2B/wholesale account entity. Exists only for corporate, wholesale, or multi-user business relationships. Most B2C customers do not have an account record; their identity lives solely on the profile.' .

ind:Household rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Household' ;
    rdfs:comment 'Represents a household grouping of one or more customer profiles sharing a residence or economic unit. Enables household-level analytics, marketing, and deduplication across individual profiles.' .

ind:CorporateAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Corporate Account' ;
    rdfs:comment 'B2B corporate customer entity representing business clients such as small businesses, restaurants, and institutional buyers purchasing from Retail. Stores legal business name, tax ID / EIN, DUNS number, industry classification (SIC/NAICS), credit terms, assigned account manager, annual spend tier, contract pricing flag, and parent-subsidiary hierarchy reference. Supports B2B procurement workflows distinct from B2C consumer accounts. Deployed to retail_mvm (MVM) and retail_mvm (ECM) as distinct schemas.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Stores all contact points for a customer profile or corporate account including email addresses, phone numbers, and social handles. Each row represents a single contact method with type (primary email, mobile, work phone, WhatsApp), verification status, opt-in/opt-out flags per channel, verification date, and source system. Supports omnichannel outreach, CRM campaigns via the case management system, and GDPR/CCPA consent enforcement at the contact-method level. Deployed to retail_mvm (MVM) and retail_mvm (ECM) as distinct schemas.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Address' ;
    rdfs:comment 'Customer postal/delivery address with SCD Type 2 versioning for full change history and GDPR audit trails.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Defines market segmentation classifications applied to customer profiles for targeted marketing, personalized pricing, and assortment decisions. Stores segment code, segment name, segment type (RFM tier, demographic, behavioral, psychographic, lifecycle stage, geographic, channel preference, value tier), segment description, qualification criteria summary, membership count, effective date range, auto-refresh flag, owning business unit, and profile-to-segment assignments with effective dates and expiry dates. Enables Retail to execute clienteling strategies, personalized promotions, and differentiated service levels across POS and e-commerce channels. Deployed to retail_mvm (MVM) and retail_mvm (ECM) as distinct schemas.' .

ind:Interaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Interaction' ;
    rdfs:comment 'Records every customer touchpoint, engagement event, and outbound communication across all Retail channels sourced from SAP Customer Activity Repository (CAR) and the case management system. Stores interaction type (POS visit, website session, app open, call center contact, email send/open/click, SMS send/delivery, push notification, chat, clienteling visit, NPS survey response), direction (inbound/outbound), channel, store or digital property, timestamp, duration, outcome, NPS score (when applicable), associated campaign or promotion ID, delivery status and engagement metrics for outbound messages (delivered/opened/clicked/bounced/unsubscribed), and agent/associate ID. This is the single consolidated product for all customer communication and engagement history — foundation for omnichannel interaction timeline, communication audit trail, campaign response tracking, and CLTV modeling. Deployed to retail_mvm (MVM) and retail_mvm (ECM) as distinct schemas.' .

ind:PaymentMethod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'DEPRECATED: Payment method records for customers. This table is superseded by finance.payment_instrument for PCI DSS isolation. Retained as a view/reference for backward compatibility; new integrations should use finance.payment_instrument.' .

ind:Membership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Membership' ;
    rdfs:comment '[References SSOT: loyalty.loyalty_membership] Customer-to-membership assignment linking table. References loyalty.loyalty_membership as the authoritative membership record. Tracks segment-based membership assignments and qualification methods.' .

ind:Sku rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Stock keeping unit - the most granular sellable/stockable item in the product master.' .

ind:ItemHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Item Hierarchy' ;
    rdfs:comment 'Hierarchical classification of products into departments, categories, subcategories, and classes.' .

ind:Attribute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Attribute' ;
    rdfs:comment 'Extended product attributes providing flexible key-value metadata for SKUs.' .

ind:Brand rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Brand' ;
    rdfs:comment '[SSOT Owner] Authoritative source for product brand master data. Defines brand identity, ownership, licensing, and commercial attributes used across merchandising and supply chain.' .

ind:ItemVariant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Item Variant' ;
    rdfs:comment 'Relationships between SKUs representing variants, substitutes, and cross-sell associations.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Regulatory compliance records for products including certifications, hazmat classifications, and safety requirements.' .

ind:ItemBundle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Item Bundle' ;
    rdfs:comment 'Product bundles and kits composed of multiple component SKUs sold together.' .

ind:GtinRegistry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Gtin Registry' ;
    rdfs:comment 'Global Trade Item Number registry maintaining barcode and packaging hierarchy data for all sellable units.' .

ind:Uom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Uom' ;
    rdfs:comment 'Unit of measure master data defining measurement units, conversions, and packaging hierarchies.' .

ind:Assortment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Assortment' ;
    rdfs:comment 'SKU-to-fulfillment-node assignment defining which products are stocked at which locations.' .

ind:Header rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Header' ;
    rdfs:comment 'Core master record for every omnichannel order. Captures order number, channel origin (web, app, call center, marketplace), order date/time, customer reference, fulfillment node reference (FK to store/distribution domain), order status, currency, locale, totals (subtotal, tax, discount, shipping, grand total), OMS reference ID, source system, and audit timestamps. SSOT for order identity and lifecycle. Carrier and fulfillment node masters are owned by peer domains and referenced via cross-domain FK.' .

ind:OrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Order Line' ;
    rdfs:comment '[SSOT Owner] Authoritative source for order line items. Captures what the customer ordered including SKU, quantity, pricing, and tax details. The commercial record of the transaction.' .

ind:PosTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Pos Transaction' ;
    rdfs:comment 'Point-of-Sale transaction record for in-store purchase events at registers. Captures POS terminal ID, register number, cashier/associate ID, store number, transaction date/time, transaction type (sale, return, exchange, void), total tender, tax, discount, loyalty card number, basket metrics (item count, UPT, ATV), and fiscal receipt number. SSOT for brick-and-mortar register transactions. Complements order_header for transactions originating at physical registers rather than digital order flow. Payment tenders linked via the payment product.' .

ind:PosTransactionLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Pos Transaction Line' ;
    rdfs:comment 'Individual line-item detail within a POS transaction. Captures SKU, UPC, EAN, GTIN, item description, quantity sold, unit retail price, extended price, markdown amount, promotion code applied, tax code, tax amount, return reason (if applicable), serial number (for electronics), and weight (for variable-weight items). Supports basket analysis and sell-through rate calculations.' .

ind:Payment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Payment' ;
    rdfs:comment 'Payment tender record capturing each payment instrument applied to an order or POS transaction. Stores payment method type (credit card, debit, gift card, loyalty points, BNPL, cash, digital wallet), masked PAN/token, payment processor reference, authorization code, settlement status (authorized, captured, settled, declined, voided), payment amount, currency, tender sequence for split-tender scenarios, PCI DSS tokenization reference, fraud score, and 3DS authentication result. Supports split-tender where multiple payment methods cover a single order total. Integrates with PCI SSC compliance requirements and payment gateway APIs.' .

ind:Discount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Discount' ;
    rdfs:comment 'Discount and promotion application record at the order header or line level. Captures discount type (coupon, promo code, loyalty reward, markdown, BOGO, clearance, employee discount), discount code, discount amount or percentage, promotion campaign reference, stackability flag, applied-at level (header vs line), and approval status. Enables promotion attribution, markdown tracking, sell-through analysis, and P&L impact per order. Tax calculation attributes (taxable amount adjustment) included where discount affects tax basis.' .

ind:Cancellation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Cancellation' ;
    rdfs:comment 'Order or line-level cancellation event record capturing the full context of why and when an order or individual line was cancelled before shipment. Captures cancellation number, order/line reference, cancellation initiator (customer-initiated via web/app/call-center, system-initiated via OMS rules, fraud-hold auto-cancel, inventory allocation failure), cancellation reason code, cancellation timestamp, cancellation stage (pre-allocation, post-allocation-pre-pick, post-pick-pre-ship), refund eligibility flag, inventory release confirmation, and processing agent/system ID. Distinct from RMA which covers post-shipment returns.' .

ind:Promise rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Promise' ;
    rdfs:comment 'Delivery commitment made to the customer at checkout or order confirmation. Captures promise type (standard, expedited, same-day, next-day), promised delivery window (start/end), calculation source (carrier API, static SLA table, DOM engine), revision history when promises are updated, actual vs promised variance, and SLA breach flag. Enables promise accuracy KPI tracking, customer experience measurement, and carrier performance evaluation.' .

ind:GiftCard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Gift Card' ;
    rdfs:comment 'Master record for gift cards and stored-value instruments sold and redeemed across all channels. Captures card number, card type (physical, digital), initial balance, current balance, activation date, expiry date, and issuing channel.' .

ind:GiftCardTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Gift Card Transaction' ;
    rdfs:comment 'Transactional record of gift card activations, loads, redemptions, balance inquiries, and escheatment events. Captures transaction type, amount, resulting balance, associated order/POS transaction, and channel.' .

ind:Subscription rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Subscription' ;
    rdfs:comment 'Master record for recurring subscription orders (subscribe-and-save, auto-replenishment, meal kit subscriptions). Captures subscription ID, customer, SKU list, delivery frequency, next delivery date, payment method, and subscription status.' .

ind:Location rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Location' ;
    rdfs:comment 'Master record for every physical retail location operated by the business, including hypermarkets, department stores, discount outlets, dark stores, and micro-fulfillment centers (MFCs). Captures store number, banner/brand, format type (hypermarket, department, discount, dark store, MFC), format size band, assortment depth/breadth norms, staffing model type, fulfillment capability flags (BOPIS-capable, ROPIS-capable, SFS-capable, DSD-receiving), trading name, legal entity, opening date, closure date, remodel history, square footage (total and selling), number of floors, parking capacity, operating hours, time zone, locale, climate zone, accessibility certifications, and store lifecycle status. This is the SSOT for all store identity, classification, and format configuration data consumed by inventory, order, workforce, and finance domains.' .

ind:Format rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Format' ;
    rdfs:comment 'Reference classification of retail store formats used across the banner portfolio. Defines format codes and descriptions (hypermarket, superstore, department store, discount outlet, convenience, dark store, MFC, ship-from-store node), typical size bands (sq ft ranges), assortment depth/breadth norms, staffing model type, and fulfillment capability flags (BOPIS-capable, ROPIS-capable, SFS-capable, DSD-receiving). Used to drive operational standards, planogram templates, and omnichannel routing rules.' .

ind:PosTerminal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Pos Terminal' ;
    rdfs:comment 'Master record for every Point-of-Sale (POS) terminal deployed within a store location. Captures terminal ID, lane number, terminal type (staffed checkout lane, self-checkout kiosk, mobile POS, customer service desk, pharmacy register), hardware model, software version, payment acceptance capabilities (EMV chip, NFC/contactless, PIN debit, EBT/SNAP, mobile wallet), peripheral devices (scanner, scale, receipt printer), installation date, last maintenance date, next scheduled maintenance, terminal status (active, offline, maintenance, decommissioned), PCI DSS compliance certification date, and assigned department or zone within the store. Critical for POS transaction reconciliation, shrinkage investigation, lane productivity analysis, and omnichannel payment compliance.' .

ind:Fixture rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Fixture' ;
    rdfs:comment 'Master record for physical store fixtures including gondolas (shelving units), endcaps (end-of-aisle displays), cooler/freezer cases, pegboard panels, display tables, and checkout lane fixtures. Captures fixture ID, fixture type, manufacturer, model number, dimensions (width, height, depth), number of shelves, adjustable shelf flag, refrigeration type (ambient, chilled, frozen), installation date, last refurbishment date, assigned store location, assigned department/zone, and current planogram assignment. Supports visual merchandising planning, maintenance scheduling, and capital asset tracking.' .

ind:Department rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Department' ;
    rdfs:comment 'Master record for departments or selling zones within a store location — the primary sub-location operational unit in retail. Captures department ID, department name, department code, parent store location, floor number, zone coordinates, department type (grocery, apparel, electronics, household, pharmacy, bakery, deli, produce, frozen, health & beauty, seasonal, etc.), selling area (sq ft), number of fixtures, department manager assignment reference, labor budget allocation, and active status. Departments are the fundamental unit for planogram assignment, inventory allocation, staffing schedules, shrinkage attribution, and P&L sub-reporting within a store. Most operational KPIs (sales per sq ft, shrink rate, labor-to-sales ratio) are measured at department level.' .

ind:Cluster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Cluster' ;
    rdfs:comment 'Master record defining store clusters — logical groupings of store locations used for localized assortment planning, zone pricing, promotional targeting, and operational benchmarking. Captures cluster ID, name, type (assortment, pricing zone, demographic, performance tier, climate), clustering methodology (algorithmic, manual override, hybrid), effective date range, member store count, and cluster owner (merchandising, pricing, or operations team). Also owns store-to-cluster membership associations including effective dates and override reasons, supporting many-to-many store-cluster relationships across concurrent clustering schemes.' .

ind:SfsFulfillmentNode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Sfs Fulfillment Node' ;
    rdfs:comment 'Master record designating a store location as a Ship-from-Store (SFS), dark store, or MFC fulfillment node within the omnichannel network. Captures node ID, store location reference, node type, daily fulfillment capacity (orders/day), active picking zones within the store, assigned carrier accounts, same-day/next-day cutoff times, geographic service radius, supported delivery SLAs, and node activation status. This is the SSOT for store-as-fulfillment-node configuration consumed by OMS and fulfillment domains. The fulfillment domain owns execution (pick/pack/ship); this product owns the node capability and capacity definition.' .

ind:ClusterMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Cluster Membership' ;
    rdfs:comment 'This association product represents the membership relationship between store clusters and store locations. It captures the assignment of individual stores to logical clusters used for localized assortment planning, zone pricing, promotional targeting, and operational benchmarking. Each record links one store cluster to one store location with effective dates, primary cluster designation, assignment reason, and status that exist only in the context of this relationship. Supports concurrent membership in multiple overlapping clustering schemes (assortment clusters, pricing zones, demographic clusters, performance tiers, climate zones).. Existence Justification: Store cluster membership is a genuine operational M:N relationship in retail. Retailers actively manage multiple concurrent clustering schemes (assortment clusters, pricing zones, demographic segments, performance tiers, climate zones) where a single store participates in multiple clusters simultaneously, and each cluster contains multiple stores. The relationship has its own lifecycle (effective dates), business rules (primary cluster designation), and operational significance (drives localized merchandising, pricing, and planning decisions).' .

ind:SalesTerritory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Sales Territory' ;
    rdfs:comment 'Master reference table for sales_territory. Referenced by sales_territory_id.' .

ind:Region rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Region' ;
    rdfs:comment 'Master reference table for region. Referenced by region_id.' .

ind:PriceList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price List' ;
    rdfs:comment 'Master record defining named price lists (e.g., EDLP base, Hi-Lo promotional, e-commerce, club member) with effective date ranges, currency, applicable channel, and price zone scope. Serves as the top-level pricing container from which individual SKU prices are derived. Each price list represents a distinct pricing context used in price resolution at POS and e-commerce checkout.' .

ind:PriceZone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price Zone' ;
    rdfs:comment 'Defines geographic or store-cluster pricing zones used to differentiate retail prices by market, region, or competitive environment. Each zone groups stores or fulfillment nodes sharing the same pricing strategy. Includes zone code, name, type (regional, competitive, urban/rural), effective dates, and zone-to-store/node membership assignments with assignment effective dates, expiry dates, assignment reasons, override flags, and historical tracking of zone reassignments.' .

ind:SkuPrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Sku Price' ;
    rdfs:comment 'Authoritative current and historical retail price for each SKU resolved by price list, price zone, and channel. Captures regular retail price (AUR), cost reference, initial markup (IMU), gross margin percentage, price type (EDLP, Hi-Lo, clearance, competitive match), channel type (in-store, e-commerce, mobile app, marketplace, BOPIS), channel price variance and justification, effective date range, priority for multi-list resolution, and approval status. This is the single source of truth for what a customer pays for any SKU in any pricing context — the granular SKU-to-price-list-to-zone-to-channel binding that drives price resolution at POS and across all digital channels.' .

ind:PriceChange rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price Change' ;
    rdfs:comment 'Transactional record of every approved price or cost change event for a SKU. Captures before/after values, change category (retail price change, supplier cost change, landed cost adjustment, freight surcharge), reason code (competitive response, cost increase, seasonal adjustment, clearance initiation, tariff change, contract renegotiation, raw material increase), change type (permanent, temporary, markdown, automated/algorithm-driven), execution mode (manual, batch, real-time), effective/expiry dates, approver, supplier reference (for cost changes), cost change percentage, margin impact assessment, and trigger signal (for automated changes). Provides the single unified audit trail for ALL pricing-relevant changes — retail and cost-side — supporting governance, GMROI analysis, margin recalculation triggers, and regulatory compliance.' .

ind:Markdown rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Markdown' ;
    rdfs:comment 'Manages the full lifecycle of planned and unplanned markdowns and clearance events at the SKU, category, and location level. Captures markdown type (permanent, POS, clearance, end-of-season, end-of-life, dead stock), markdown amount (percentage or absolute), original and marked-down retail price, clearance stage progression (first/second/final reduction with price and sell-through at each stage), sell-through targets and actuals, disposition method (in-store clearance, online clearance, RTV, liquidation), planned and actual exit dates, markdown ROI, clearance initiation and closure dates, and dead stock elimination tracking. Tracks the complete reduction lifecycle from initial markdown through final clearance disposition and exit.' .

ind:CostPrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Cost Price' ;
    rdfs:comment 'Authoritative record of landed cost and COGS for each SKU from each supplier. Includes base cost, freight, duty/tariff, handling charges, total landed cost, cost effective date, cost currency, and cost change reason. Supports cost-plus margin calculations, GMROI tracking, and margin management. This is the buy-side cost record distinct from the sell-side retail price in sku_price.' .

ind:Rule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Rule' ;
    rdfs:comment 'Defines all business logic and constraints governing how prices are calculated, adjusted, and enforced — covering manual policies, batch processes, and real-time algorithm-driven automation. Includes rule type (cost-plus floor, competitive match ceiling, EDLP lock, Hi-Lo swing limit, rounding, dynamic trigger, demand-based, inventory-based, time-of-day), priority, applicable SKU scope, channel (in-store, e-commerce, mobile app), execution mode (manual, batch, real-time/near-real-time), trigger conditions (inventory threshold, demand surge, competitor undercut, time-based, weather, event-driven), adjustment method (percentage, absolute, index-based), min/max price guardrails, effective dates, activation status, algorithm version reference, and override permissions. Serves as the unified policy engine for all pricing governance — from static business rules to real-time algorithmic adjustments.' .

ind:CompetitivePrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Competitive Price' ;
    rdfs:comment 'Observed competitor retail prices for matching SKUs or comparable products. Captures competitor name, store or URL, observed price, observation date, data source (manual survey, third-party feed, web scrape), match confidence score, price gap versus own retail price, price gap trend over time, and recommended response action. Feeds competitive pricing rules and supports Hi-Lo and EDLP strategy calibration, competitive index tracking, and price war early warning.' .

ind:PriceApproval rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price Approval' ;
    rdfs:comment 'Workflow record tracking the approval lifecycle for price change requests, markdowns, and price list activations. Captures requestor, approver hierarchy, approval status (pending, approved, rejected, escalated), approval tier (category manager, merchandise director, VP), timestamps, rejection reason, and references to the governed price change or markdown. Enforces pricing governance controls and audit trails for material price decisions requiring segregation of duties.' .

ind:CostZone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Cost Zone' ;
    rdfs:comment 'Master reference table for cost_zone. Referenced by cost_zone_id.' .

ind:PromoCampaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Promo Campaign' ;
    rdfs:comment 'Master record for a promotional campaign representing a time-bound marketing initiative encompassing both the strategic campaign wrapper and discrete promotional sales events (Flash Sales, Doorbuster Events, Holiday Sales). Captures campaign name, type, start/end dates, event classification, budget, and performance targets.' .

ind:PromoOffer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Promo Offer' ;
    rdfs:comment 'Defines a specific promotional offer within a campaign, representing the actual deal mechanics (BOGO, percent-off, dollar-off, free gift with purchase, bundle deal, threshold discount). Captures offer type, discount value, discount method (percentage vs. fixed), minimum purchase threshold, maximum redemption limit, stackability rules, offer priority, eligible SKUs/categories/product hierarchies (with inclusion/exclusion flags), channel eligibility (POS, e-commerce, mobile, BOPIS), store/store-group scope, digital delivery attributes (targeting segment, personalization, activation trigger) when applicable, effective date range, and jurisdictional compliance flags (e.g., state-level promotional restrictions, EU consumer protection price display requirements). This is the atomic unit of promotion logic executed at POS and e-commerce checkout engines. Encompasses SKU eligibility rules, channel assignments, store assignments, and digital offer mechanics as integral attributes. Supports international compliance by carrying jurisdiction-specific restriction flags that gate offer activation by market.' .

ind:Coupon rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Coupon' ;
    rdfs:comment 'Master record for a coupon instrument issued as part of a promotional campaign. Captures coupon code, barcode/UPC, coupon type (manufacturer, store, digital, paper), face value, discount type, issue channel (circular, app, email, in-store kiosk), expiration date, single-use vs. multi-use flag, maximum redemption count, stackability with other offers, issuing authority (store vs. vendor-funded), and print/digital distribution quantity. Supports both digital wallet coupons and physical paper formats across POS and e-commerce channels. Coupon redemption events are recorded in promo_redemption (the SSOT for all redemption activity).' .

ind:CircularAd rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Circular Ad' ;
    rdfs:comment 'Master record for a printed or digital weekly/seasonal circular advertisement, including both the circular header and its featured item lines. Header captures circular name, edition number, publication date, effective date range, distribution channel (print, digital, email, app), geographic market coverage, page count, and production status. Item lines capture featured SKU, advertised price, promotional price, page number, position on page, feature type (front page, endcap feature, in-book), ad copy headline, image reference, and loss-leader flag. The circular is a key promotional vehicle in retail that drives planned traffic and is directly linked to campaign offers. Supports circular effectiveness analysis by item and planogram alignment with advertised features.' .

ind:Rebate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Rebate' ;
    rdfs:comment 'Master record for a rebate program offered to customers or funded by vendors. Captures rebate name, rebate type (instant rebate, mail-in rebate, vendor-funded rebate), rebate amount or percentage, qualifying purchase conditions, submission deadline, payment method (check, store credit, digital credit), sponsoring vendor, and rebate program status. Supports both consumer-facing rebates and vendor-funded promotional allowances.' .

ind:VendorPromoAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Vendor Promo Agreement' ;
    rdfs:comment 'Master record for a vendor-funded promotional agreement (co-op advertising, promotional allowance, scan-based trading deal). Captures vendor identifier, agreement type (co-op ad, off-invoice allowance, bill-back, scan allowance, new item allowance), agreed funding amount, funding percentage, qualifying conditions (minimum volume, display compliance, ad placement), performance obligations, agreement start/end dates, settlement terms, and agreement status. Distinct from the supplier contract in the supplier domain — this is specifically the promotional funding arrangement that drives vendor chargeback and deduction management. Supports accounts receivable accrual and vendor compliance auditing.' .

ind:PromoRedemption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Promo Redemption' ;
    rdfs:comment 'Transactional record capturing each instance of a promotional offer being applied to a customer transaction at POS or e-commerce checkout. Records offer applied, redemption mechanism (automatic system-triggered, coupon code entry, loyalty auto-apply, cart rule), coupon reference (when coupon-based), transaction reference, store or channel, customer identifier, discount amount granted, redemption timestamp, redemption status (valid, invalid, duplicate, expired), and processing system. Serves as the single source of truth for all promotion redemption activity — including coupon redemptions, automatic BOGO applications, threshold discounts, and bundle deals. Critical for promotional ROI calculation, coupon fraud prevention, vendor chargeback evidence, and real-time redemption limit enforcement.' .

ind:PromoBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Promo Budget' ;
    rdfs:comment 'Master record for the promotional budget allocated to a campaign, promotional event, or category-level promotional plan. Captures total budget amount, budget type (internal marketing, vendor co-op, markdown allowance, clearance reserve), budget owner (department, category, or brand team), planned spend by channel, actual spend to date, committed but unspent amount, remaining budget, budget approval status, fiscal period, and variance threshold for alerts. Supports OTB (Open to Buy) integration, promotional P&L management, and real-time budget consumption monitoring. Distinct from finance domain general ledger — this is the operational promotional spend plan that feeds GL accruals.' .

ind:PromoCalendar rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Promo Calendar' ;
    rdfs:comment 'Master record for the retail promotional calendar defining planned promotional periods, key retail events, blackout dates, and competitive response windows for a fiscal year. Captures period name, period type (weekly ad cycle, seasonal event, holiday, clearance window, competitive response), start/end dates, fiscal week/month/quarter alignment, priority tier, planning lock date, planning status (draft, locked, active, archived), and banner/market applicability for multi-banner retailers. Used by merchandising, marketing, and supply chain teams to coordinate promotional activity, inventory positioning, and circular production timelines. Serves as the shared planning backbone that prevents promotional conflicts and ensures adequate lead time for vendor negotiations and inventory builds. Supports multi-banner coordination by allowing banner-specific or enterprise-wide calendar periods.' .

ind:Vendor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor' ;
    rdfs:comment 'Master record for each supplier/vendor with whom the retailer has a commercial relationship. Contains identity, contact, compliance, and performance attributes. Serves as the root entity for all supplier-domain relationships.' .

ind:VendorContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor Contact' ;
    rdfs:comment 'Contact persons associated with a vendor including account managers, EDI coordinators, compliance contacts, and executive sponsors. Tracks name, title, role type, phone, email, preferred communication channel, and active status. Supports relationship management and escalation workflows.' .

ind:VendorAddress rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor Address' ;
    rdfs:comment 'Physical and mailing addresses for vendors including headquarters, remittance, ship-from, and returns (RTV) addresses. Tracks address type, street, city, state, postal code, country, geo-coordinates, and validation status. Supports procurement, logistics routing, and RTV processing.' .

ind:VendorContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor Contract' ;
    rdfs:comment 'Supplier trading agreements and master vendor contracts including terms and conditions, payment terms, discount structures, exclusivity clauses, private label agreements, and contract validity periods. Tracks contract type (national brand, private label, DSD), effective and expiry dates, auto-renewal flags, and signatory details. Sourced from SAP S/4HANA SD/MM contract management.' .

ind:Chargeback rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Chargeback' ;
    rdfs:comment 'Vendor compliance penalty records issued to suppliers for violations of routing guides, labeling requirements (GS1-128, RFID/EPC), EDI non-compliance, late shipments, fill rate shortfalls, ASN failures, and packaging defects. Tracks chargeback type, violation category, violation date, penalty amount (flat fee or percentage), dispute status, resolution date, recovery method (AP deduction or separate debit memo), and linkage to the originating routing guide rule. Critical for vendor compliance enforcement, cost recovery, and feeds vendor scorecard KPIs. Supports automated penalty calculation and vendor portal notification workflows.' .

ind:VendorScorecard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor Scorecard' ;
    rdfs:comment 'Periodic vendor performance scorecards measuring KPIs including on-time delivery rate, fill rate, EDI compliance rate, invoice accuracy, chargeback frequency, product quality scores, and overall vendor rating. Tracks scoring period, individual KPI values, weighted composite score, tier classification (preferred, approved, probation), and trend vs prior period. Enables strategic vendor relationship management.' .

ind:EdiConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Edi Config' ;
    rdfs:comment 'EDI (Electronic Data Interchange) integration configuration for each trading partner defining connection parameters and supported transaction sets. Captures vendor trading partner ID, ISA/GS qualifiers, supported EDI documents (850, 855, 856, 810, 832, 846), communication protocol (AS2, SFTP, VAN), test vs production status, functional acknowledgment SLA, and compliance thresholds that trigger chargebacks. Manages EDI onboarding lifecycle, ongoing integration health monitoring, and serves as the reference record for edi_transaction processing and error resolution.' .

ind:LeadTimeAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Lead Time Agreement' ;
    rdfs:comment 'Documented lead time and MOQ (Minimum Order Quantity) agreements per vendor and product category or SKU. Captures standard lead time (days), expedited lead time, MOQ units, order increment, pack size, inner pack quantity, and seasonal lead time adjustments. Feeds Blue Yonder demand planning replenishment parameters and OTB calculations.' .

ind:VendorItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor Item' ;
    rdfs:comment 'Vendor-specific item catalog linking vendor part numbers, UPCs, GTINs, and EANs to internal SKUs. Captures vendor item number, vendor pack configuration, case pack quantity, inner pack, pallet TI/HI, unit cost, cost effective date, country of origin, and item status. Includes lead time and MOQ agreements per vendor-item combination: standard lead time (days), expedited lead time, MOQ units, order increment, pack size, inner pack quantity, seasonal lead time adjustments, and category-level defaults. Serves as the cross-reference between vendor catalogs and the internal product master, and feeds Blue Yonder demand planning replenishment parameters and OTB calculations.' .

ind:VendorAllowance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor Allowance' ;
    rdfs:comment 'Vendor-funded trade allowances, co-op advertising funds, slotting fees, promotional funding, and volume rebates negotiated with suppliers. Tracks allowance type (off-invoice, bill-back, scan-based), allowance amount or percentage, qualifying conditions, accrual method, redemption period, and settlement status. Critical for net landed cost and P&L accuracy.' .

ind:Storefront rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Storefront' ;
    rdfs:comment 'Master record for each digital storefront or online channel operated by Retail, including the main e-commerce site, mobile app storefronts, and marketplace presences. Captures storefront identity, locale, currency, domain URL, platform configuration (the e-commerce platform site ID, channel-specific settings, feature flags, theme/template references), launch date, status, supported payment methods, and supported fulfillment modes (BOPIS, ship-to-home, drop-ship). SSOT for digital channel identity and configuration within the e-commerce domain. Domain ownership principle: the ecommerce domain owns digital commerce operations from storefront configuration through checkout completion. Customer identity is owned by the customer domain; post-checkout order lifecycle is owned by the order domain; promotional campaign definitions are owned by the promotion domain; product master data is owned by the product domain.' .

ind:DigitalCatalog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Digital Catalog' ;
    rdfs:comment 'E-commerce product catalog record representing the published, channel-specific view of merchandise available on a given storefront. Tracks which SKUs are active online, digital content completeness (images, descriptions, rich media), SEO metadata (title, meta description, canonical URL), online availability flags, digital-only pricing overrides, and publication status. This is the digital presentation layer — distinct from the master product catalog in the product domain which owns canonical SKU/UPC definitions and the master merchandise hierarchy.' .

ind:WebSession rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Web Session' ;
    rdfs:comment 'Tracks individual visitor sessions on digital storefronts, capturing session start/end timestamps, device type, browser, OS, referral source, UTM parameters, landing page, exit page, page view count, session duration, and whether the session resulted in a cart creation, checkout initiation, or completed order. Supports CTR, CR, and digital journey analytics. High-volume event data — recommend 90-day hot retention with archival to cold storage for historical trend analysis.' .

ind:Cart rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Cart' ;
    rdfs:comment 'Represents a shopping cart instance created during a customer\'s digital session on a storefront. Captures cart creation timestamp, last modified timestamp, cart status (active, abandoned, converted, expired), total item count, subtotal, applied promotion/coupon identifiers, discount amounts, estimated tax, estimated shipping, and the channel/storefront context. Includes digital promotion redemption details: promotion ID, coupon code, discount amount, redemption channel (web, mobile app, email link), redemption status (applied, validated, rejected, reversed), and customer identity reference. SSOT for cart-level data supporting abandoned cart recovery, AOV analysis, and promotion effectiveness measurement within the digital channel. Cart abandonment is determined by timeout or session expiry; recovery workflows are tracked in the abandoned_cart_recovery product.' .

ind:CartItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Cart Item' ;
    rdfs:comment 'Line-item level detail within a shopping cart, capturing the SKU/UPC added, quantity, unit price at time of add, any item-level promotion applied, item status (active, removed, saved-for-later), add-to-cart timestamp, and removal timestamp if applicable. Supports basket analysis, assortment affinity, and abandoned cart item-level recovery workflows.' .

ind:Checkout rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Checkout' ;
    rdfs:comment 'Captures the checkout funnel progression for a cart, recording each checkout step reached (cart review, address entry, shipping selection, payment entry, order review, order placed), step timestamps, step completion flags, abandonment step, selected shipping method, selected fulfillment mode (ship-to-home, BOPIS, ROPIS, drop-ship), and applied gift cards or store credits. Enables CR funnel analysis and checkout abandonment identification. Domain boundary: the checkout lifecycle ends at order placement — the order domain owns all post-placement order lifecycle (confirmation, fulfillment tracking, cancellation, modification). Digital return initiation is handed off to the returns domain.' .

ind:DigitalPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Digital Payment' ;
    rdfs:comment 'Records digital payment transactions processed during online checkout, including payment method type (credit card, debit card, PayPal, BNPL, gift card, store credit, Apple Pay, Google Pay), payment gateway used (Adyen, Stripe, PayPal), authorization code, transaction reference, payment status (authorized, captured, declined, voided, refunded, partially_refunded), payment amount, currency, fraud screening result (pass, review, reject), 3DS authentication status, and PCI DSS tokenization reference. Distinct from in-store POS payment processing. SSOT for digital payment transaction data within the e-commerce channel.' .

ind:ProductReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Product Review' ;
    rdfs:comment 'Customer-submitted product review and rating record on a digital storefront, capturing the SKU reviewed, star rating (1-5), review title, review body text, reviewer display name, verified purchase flag, submission timestamp, moderation status (pending, approved, rejected, flagged), helpful votes count, and syndication source (native, Bazaarvoice, etc.). Supports social proof, product quality signals, and NPS-adjacent sentiment tracking.' .

ind:MarketplaceListing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Marketplace Listing' ;
    rdfs:comment 'Master record for Retail\'s product listings on third-party marketplaces (Amazon, eBay, Walmart Marketplace, Google Shopping), capturing the marketplace platform, marketplace-specific identifier (ASIN, eBay item ID, Walmart item ID), mapped internal SKU/UPC, listing title, listing status (active, suppressed, inactive, out-of-stock), buy-box ownership flag, marketplace price, marketplace fulfillment method (FBM, FBA, WFS), listing quality score, content compliance flags, and last sync timestamp. Supports marketplace channel management, competitive pricing intelligence, and GMV tracking across third-party channels.' .

ind:PromotionBanner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Promotion Banner' ;
    rdfs:comment 'Manages promotional banners and hero images displayed on digital storefronts. Captures banner name, placement zone, creative asset reference, click-through URL, display schedule, and impression/click metrics.' .

ind:FulfillmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Fulfillment Order' ;
    rdfs:comment 'Core operational record representing a fulfillment work order created from a customer order. Tracks the end-to-end execution of picking, packing, and shipping activities for a single order or order subset. Captures fulfillment method (ship-from-store, dark store, DC, BOPIS, ROPIS, drop-ship), assigned fulfillment node, SLA commitment, promised delivery date, current fulfillment status, and carrier assignment. This is the primary entity in the fulfillment domain and the operational counterpart to the order domain\'s order record.' .

ind:FulfillmentLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Fulfillment Line' ;
    rdfs:comment '[References SSOT: order.order_line] Fulfillment execution line tracking pick, pack, and ship progress. References order.order_line as the authoritative commercial line record. Tracks physical fulfillment state and warehouse operations.' .

ind:Shipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Shipment' ;
    rdfs:comment 'Master record for a physical shipment dispatched to a customer or transfer destination. Captures carrier, tracking number, ship date, estimated delivery date, actual delivery date, shipment weight, dimensions, number of packages, ship-from node, ship-to address, service level (ground, 2-day, overnight), and shipment status. Serves as the SSOT for all outbound shipment tracking across channels including e-commerce, BOPIS, and store-to-door.' .

ind:ShipmentPackage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Shipment Package' ;
    rdfs:comment 'Represents an individual physical package or carton within a shipment. Tracks package dimensions, weight, package type (box, poly bag, envelope), seal status, label printed flag, tracking barcode, contents summary, and package-level delivery confirmation. A single shipment may contain multiple packages, each with its own tracking and delivery status.' .

ind:PickTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Pick Task' ;
    rdfs:comment 'Unified operational task record for all fulfillment execution activities including picking, packing, quality checks, and value-added services. Captures task type (pick, pack, QC, VAS), assigned associate, work zone, location (aisle, bay, shelf, packing station), SKU/items, quantity requested vs actual, task method (single, batch, zone, wave), priority, status (assigned, in-progress, completed, exception), start time, completion time, quality check outcome, packing details (station ID, package type, void fill, label applied, packing slip printed), and substitution outcome (original SKU, substituted SKU, customer approval status). Supports wave-based task generation from WMS systems including Manhattan Associates and Blue Yonder. Enables associate productivity tracking, task queue management, and fulfillment throughput analytics across the entire pick-pack-QC workflow.' .

ind:PackTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Pack Task' ;
    rdfs:comment 'Operational task record for the packing station workflow. Captures packer assignment, packing station ID, items packed, package type selected, void fill used, packing slip printed flag, label applied flag, pack start time, pack end time, and quality check status. Tracks the transition from picked items to sealed, labeled packages ready for carrier handoff.' .

ind:Carrier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Carrier' ;
    rdfs:comment 'Master record for carrier and 3PL partners used for outbound shipment execution, encompassing carrier identity, service catalog, and contracted rate cards. Captures carrier name, carrier code, carrier type (parcel, LTL, FTL, last-mile, same-day), SCAC code, EDI/API integration capabilities. Service catalog includes service levels (ground, 2-day, overnight, same-day, BOPIS-ready), transit days by zone, cutoff times, max weight/dimensions, surcharge types, tracking capability, signature required flag, and geographic restrictions. Rate card includes base rates by zone/weight/service, dimensional weight factor, fuel surcharges, residential delivery surcharges, extended area surcharges, negotiated discount percentages, rate effective and expiry dates, and weight breaks. Serves as the single source of truth for all carrier master data, service definitions, and freight cost references within the fulfillment domain. Used in carrier selection logic during fulfillment order routing and freight cost estimation.' .

ind:CarrierService rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Carrier Service' ;
    rdfs:comment 'Defines specific service offerings provided by a carrier, such as ground, 2-day, overnight, same-day, or BOPIS-ready services. Captures service code, service name, transit days, cutoff time, max weight, max dimensions, surcharge types, tracking capability, signature required flag, and geographic restrictions. Used in carrier selection logic during fulfillment order routing.' .

ind:FulfillmentNode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Fulfillment Node' ;
    rdfs:comment '[References SSOT: inventory.inventory_node] Fulfillment-specific node configuration for order routing and execution. References inventory.inventory_node for the authoritative physical location record. Adds fulfillment capabilities like pick capacity and carrier assignments.' .

ind:BopisAppointment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Bopis Appointment' ;
    rdfs:comment 'Tracks BOPIS (Buy Online Pick Up In Store) and ROPIS (Reserve Online Pick Up In Store) customer pickup appointments. Captures order reference, customer name, pickup store/node, appointment window (date and time slot), check-in method (app, kiosk, associate), check-in timestamp, ready-for-pickup notification sent flag, actual pickup timestamp, and appointment status (scheduled, ready, picked-up, expired, cancelled). Enables SLA tracking for BOPIS readiness commitments.' .

ind:DropShipOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Drop Ship Order' ;
    rdfs:comment 'Tracks vendor drop-ship fulfillment orders where the supplier ships directly to the customer on behalf of the retailer. Captures vendor reference, PO number sent to vendor, customer ship-to address, promised ship date, actual ship date, vendor tracking number, drop-ship status (sent-to-vendor, acknowledged, shipped, delivered, exception), and vendor SLA compliance flag. Distinct from standard fulfillment orders — drop-ship bypasses the retailer\'s physical fulfillment nodes entirely.' .

ind:Rma rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Rma' ;
    rdfs:comment 'Return Merchandise Authorization master record representing the formal authorization issued to a customer to return one or more items. Captures the RMA number, originating order reference, customer identity, return channel (in-store, online, BOPIS), authorization date, expiry date, return reason code, return type (refund, exchange, store credit), total expected return value, and current RMA status (pending, authorized, received, closed, denied). Primary master entity for the returns domain and the anchor for all downstream return processing workflows.' .

ind:RmaLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Rma Line' ;
    rdfs:comment 'Individual line-item detail within an RMA, representing a single SKU being returned. Captures the SKU, UPC, GTIN, product description, quantity authorized versus quantity received, unit retail price, unit cost, return reason at the line level, condition code upon receipt (new, opened, damaged, defective), restocking eligibility flag, and disposition instruction. Enables granular tracking of each item in a multi-item return authorization.' .

ind:ReturnRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Return Request' ;
    rdfs:comment 'Customer-initiated return request capturing the initial intent to return merchandise before formal RMA authorization. Records the request channel (e-commerce portal, store associate, call center), request timestamp, customer-stated reason, items and quantities requested for return, preferred resolution type (refund, exchange, store credit), and request status (submitted, under review, approved, denied). Serves as the intake record that triggers the RMA authorization workflow.' .

ind:ReturnReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Return Receipt' ;
    rdfs:comment 'Physical or digital receipt record generated when returned merchandise is received at a store, DC, or MFC. Captures the receiving location, receiving associate, receipt timestamp, carrier tracking number (for mail-in returns), actual items and quantities received versus authorized, condition assessment at receipt, discrepancy flags (over-return, under-return, wrong item), and receipt status. Links the physical goods receipt event to the RMA and triggers downstream disposition and refund workflows.' .

ind:Disposition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Disposition record governing the final fate of each returned item after receipt and inspection. Captures disposition type (restock to sellable inventory, restock to clearance, return to vendor via RTV, liquidation, donation, destruction/write-off), decision date, disposition location, responsible associate, estimated and actual recovery value, and disposition status. Central to reverse logistics cost recovery, shrinkage management, and inventory reintegration decisions. Now also carries condition grade assessment (A-New through F-Unsellable) previously in a separate reference table.' .

ind:Refund rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Refund' ;
    rdfs:comment 'Financial refund transaction record representing the monetary reimbursement issued to a customer as resolution of a return. Captures refund method (original payment method, store credit, gift card, check), refund amount, restocking fee deducted, original transaction reference, refund authorization code, processing timestamp, refund status (pending, processed, failed, reversed), and payment processor response. Integrates with financial accounting for accounts payable and revenue reversal under ASC 606.' .

ind:ExchangeOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Exchange Order' ;
    rdfs:comment 'Exchange order created when a return is resolved via product replacement rather than monetary refund. Captures the originating RMA reference, replacement SKU(s) and quantities, price differential (upgrade or downgrade), exchange order status, fulfillment channel (ship-to-home, in-store pickup, curbside), and the linked replacement order identifier. Enables tracking of exchange fulfillment as a distinct resolution path separate from standard order flow.' .

ind:ReturnPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Return Policy' ;
    rdfs:comment 'Master record defining return policy rules by merchandise category, sales channel, and customer segment. Captures return window duration, restocking fee rules, accepted return conditions, proof-of-purchase requirements, non-returnable item exceptions, channel applicability (in-store, online, BOPIS), loyalty tier overrides (extended windows for premium members), SLA processing targets by return stage, and policy effective/expiry dates. Drives automated RMA authorization logic and operational SLA measurement.' .

ind:StoreCredit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Store Credit' ;
    rdfs:comment 'Store credit instrument issued as return resolution in lieu of cash or card refund. Functions as a stored-value financial instrument with its own lifecycle: issuance, partial redemption, full redemption, expiration, or voiding. Captures credit code, issued and remaining balance, issue/expiry dates, issuing channel and location, customer and originating RMA references. Integrates with POS and e-commerce systems for omnichannel redemption.' .

ind:ReplenishmentPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Replenishment Plan' ;
    rdfs:comment 'Replenishment plans for SKUs across all supply chain nodes (stores, DCs, MFCs), generated by Blue Yonder or equivalent planning engine. Captures planned order quantities, replenishment triggers, reorder points, safety stock levels and policy parameters (calculation method, service level target, demand variability factor), weeks-of-supply targets, plan status, and MOQ enforcement rules (minimum order quantity, order multiples, minimum order value). SSOT for automated replenishment decisions including buffer stock governance and supplier ordering constraints.' .

ind:DemandForecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Demand Forecast' ;
    rdfs:comment 'SKU-level demand forecast records generated by Blue Yonder Demand Planning. Captures forecasted units, revenue, forecast horizon, statistical model used, override flags, forecast accuracy (MAPE/WMAPE), and demand signals including seasonality, promotions lift, and trend adjustments. Drives replenishment and OTB planning.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Purchase order header records representing procurement commitments to suppliers, managed in SAP MM or Oracle RMS. Captures PO number, supplier reference, buyer, order and expected delivery dates, total value, currency, payment terms, incoterms, PO type (standard, blanket, DSD), approval status, and EDI transmission status. SSOT for the PO lifecycle from creation through closure.' .

ind:PoLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Po Line' ;
    rdfs:comment 'Line-item detail for each purchase order. Captures SKU/GTIN, ordered quantity, unit of measure, unit cost, extended cost, confirmed quantity, shipped quantity, received quantity, line status, MOQ compliance flag, and lead-time commitment. Enables granular PO tracking at the SKU level.' .

ind:DcFacility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Dc Facility' ;
    rdfs:comment 'Master record for each distribution center (DC) and micro-fulfillment center (MFC) operated by Retail. Captures facility type (regional DC, MFC, dark store, cross-dock hub, returns center), physical address, square footage, storage capacity (pallet positions, cubic feet), temperature zones (ambient, chilled, frozen), dock door count, operating hours, facility status (active, planned, decommissioned), owning region, and Manhattan WMS instance assignment. SSOT for DC/MFC identity referenced by all distribution operations including zone layout, dock scheduling, carrier assignments, and performance tracking.' .

ind:WarehouseZone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Warehouse Zone' ;
    rdfs:comment 'Defines the complete physical layout hierarchy within a DC or MFC, from zones (receiving, bulk storage, forward pick, packing, staging, dispatch, returns) down to individual storage locations (bin, slot, shelf, pallet position, floor stack). Zone-level attributes include zone code, type, temperature classification (ambient, chilled, frozen), aisle range, rack configuration (selective, drive-in, push-back, flow), automation type (manual, conveyor, AS/RS, shuttle, AMR), and zone capacity metrics. Location-level attributes include location code, aisle, bay, level, position, location type (bulk, pick face, reserve, floor, overflow), weight capacity, cubic capacity, RFID/barcode tag, and current occupancy status. SSOT for all physical space definitions within a facility — supports slotting optimization, pick path planning, capacity management, and location-level inventory tracking within Manhattan WMS.' .

ind:InboundShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Inbound Shipment' ;
    rdfs:comment 'Tracks inbound shipments arriving at a DC or MFC from suppliers, vendors, or inter-facility transfers. Captures ASN (Advance Ship Notice) reference, carrier, trailer number, expected and actual arrival date/time, PO references, total carton and pallet counts, shipment status (in-transit, arrived, receiving, closed), and temperature compliance flag for cold chain shipments. Integrates with EDI 856 ASN feeds and Manhattan WMS receiving workflows. SSOT for all inbound freight visibility at the distribution center level.' .

ind:ReceivingEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Receiving Event' ;
    rdfs:comment 'Captures the physical receiving activity at a DC dock door when inbound shipments are unloaded and verified. Records dock door assignment, unload start/end timestamps, cartons received vs. expected, discrepancy flags (overage, shortage, damage), receiver employee ID, pallet count, and blind vs. directed receiving mode. Each receiving event is tied to an inbound shipment and drives put-away task generation in Manhattan WMS.' .

ind:OutboundOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Outbound Order' ;
    rdfs:comment 'Represents a distribution outbound order directing the DC or MFC to fulfill and ship goods to a destination (store, customer, 3PL node). Captures order type (store replenishment, e-commerce, BOPIS, DSD bypass, inter-DC transfer), destination node, requested ship date, required delivery date, priority level, total lines/units/weight/cube, wave assignment, and order status lifecycle (released, waved, picking, packed, shipped, closed). For store replenishment: captures replenishment type (push, pull, min-max, VMI), replenishment reason, demand planning source reference, and replenishment frequency. Central transactional entity for all DC outbound execution including store replenishment, e-commerce fulfillment, and inter-facility transfers.' .

ind:OutboundOrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Outbound Order Line' ;
    rdfs:comment 'Line-level detail for each SKU within an outbound distribution order. Captures SKU/UPC, ordered quantity, allocated quantity, picked quantity, packed quantity, shipped quantity, unit of measure, lot number, expiry date, storage location sourced from, and line status. Enables granular fulfillment tracking and short-ship identification at the SKU level.' .

ind:CircularAdPlacement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Circular Ad Placement' ;
    rdfs:comment 'This association product represents the Contract between circular_ad and promo_offer. It captures the commercial placement of a specific promotional offer within a specific circular advertisement, including the physical or digital position, feature size, page number, display priority, and vendor funding status for that placement. Each record links one circular_ad to one promo_offer and carries attributes that exist only in the context of that specific placement — a given offer may appear in multiple circulars at different positions and sizes, and a given circular features many offers at distinct locations.. Existence Justification: In retail, a circular advertisement features multiple promotional offers (e.g., a weekly circular may include a BOGO offer on beverages, a percent-off offer on produce, and a dollar-off offer on household goods simultaneously). Conversely, a single promotional offer can be featured across multiple circulars (e.g., a vendor-funded BOGO offer appearing in both the weekly print circular and the digital holiday circular). The placement of an offer within a circular is a recognized commercial transaction — retailers charge vendors for featured ad space, and each placement carries its own page number, position, feature size, and vendor-funding flag that belong to neither the circular nor the offer alone.' .

# --- Attribute Properties ---
ind:stockPositionId rdf:type rdf:Property ;
    rdfs:label 'Stock Position Id' ;
    rdfs:comment 'Unique surrogate identifier for each stock position record representing a SKU-node combination at a point in time. Primary key for the stock_position data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:inventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Inventory Node Id' ;
    rdfs:comment 'Reference to the inventory node (store, Distribution Center (DC), Micro-Fulfillment Center (MFC), or dark store) where this stock position is held. Supports omnichannel fulfillment visibility across all network nodes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:lotId rdf:type rdf:Property ;
    rdfs:label 'Lot Id' ;
    rdfs:comment 'Foreign key linking to inventory.lot. Business justification: stock_position has a batch_number string attribute indicating lot-tracked inventory. Adding lot_id as a proper FK to the lot master record normalizes this relationship, enabling expiry date management' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:reorderPolicyId rdf:type rdf:Property ;
    rdfs:label 'Reorder Policy Id' ;
    rdfs:comment 'Foreign key linking to inventory.reorder_policy. Business justification: A stock position at a SKU-location level is governed by a reorder policy that defines replenishment parameters. Linking stock_position to reorder_policy enables direct comparison of current on-hand qu' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReorderPolicy .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Reference to the SKU (Stock Keeping Unit) for which this stock position is recorded. Links to the product master in the Product Information Management (PIM) system and Informatica MDM golden record.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:skuPriceId rdf:type rdf:Property ;
    rdfs:label 'Sku Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.sku_price. Business justification: Retail inventory valuation (retail method of accounting) requires linking each stock position to its active selling price. Inventory planners and finance teams use this to compute on-hand retail value' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuPrice .

ind:uomId rdf:type rdf:Property ;
    rdfs:label 'Uom Id' ;
    rdfs:comment 'Foreign key linking to product.uom. Business justification: stock_position.unit_of_measure is a denormalized text field. Linking to product.uom enforces valid UOM codes, supports UOM conversion for inventory valuation reports, and ensures consistency with the ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Uom .

ind:availableToPromiseQty rdf:type rdf:Property ;
    rdfs:label 'Available To Promise Qty' ;
    rdfs:comment 'Quantity of the SKU available to commit to new customer orders or fulfillment requests. Calculated as on-hand minus reserved, damaged, and quarantine quantities. Authoritative ATP signal consumed by Salesforce Commerce Cloud for omnichannel order promising (BOPIS, ROPIS, Ship-from-Store).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgDailySalesQty rdf:type rdf:Property ;
    rdfs:label 'Avg Daily Sales Qty' ;
    rdfs:comment 'Rolling average quantity of the SKU sold per day at this node, calculated from SAP Customer Activity Repository (CAR) POS transaction data. Used to compute Weeks of Supply (WOS), reorder point, and safety stock. Input to Blue Yonder Demand Planning forecasts.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Supplier or manufacturer batch/lot number for the current inventory of this SKU at this node. Required for batch-managed products (food, pharmaceuticals, cosmetics) to support FDA recall traceability, CPSC compliance, and Return to Vendor (RTV) processing.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when this stock position record was first created in the Databricks Silver Layer. Supports data lineage, audit trail, and GDPR/CCPA data lifecycle management requirements.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the unit cost and inventory valuation amounts (e.g., USD, GBP, EUR). Supports multi-currency operations across international retail markets.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damagedQty rdf:type rdf:Property ;
    rdfs:label 'Damaged Qty' ;
    rdfs:comment 'Quantity of the SKU identified as damaged, defective, or unsellable at the inventory node. Excluded from Available-to-Promise (ATP) calculations. Tracked for shrinkage reporting, Return to Vendor (RTV) processing, and COGS (Cost of Goods Sold) write-down.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Expiration or best-before date of the current inventory batch for perishable or date-sensitive SKUs (grocery, pharmacy, cosmetics). Used for FEFO (First Expired First Out) rotation, FDA food safety compliance, and proactive markdown or disposal before expiry.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inTransitQty rdf:type rdf:Property ;
    rdfs:label 'In Transit Qty' ;
    rdfs:comment 'Quantity of the SKU currently in transit from a supplier, Distribution Center (DC), or another node and expected to arrive at this inventory node. Sourced from Blue Yonder Demand Planning and SAP S/4HANA WM transfer orders. Used for future ATP projection.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryValuationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Method' ;
    rdfs:comment 'Accounting method used to value this SKU\'s inventory for financial reporting. FIFO (First In First Out), LIFO (Last In First Out), WAC (Weighted Average Cost), standard_cost, or retail_method. Governed by FASB ASC 330 and reported in financial P&L statements.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeadStock rdf:type rdf:Property ;
    rdfs:label 'Is Dead Stock' ;
    rdfs:comment 'Flag indicating whether this SKU at this node is classified as dead stock — unsold, obsolete inventory with no recent sales velocity. True when sell-through rate is zero and weeks of supply exceeds the dead stock threshold. Triggers markdown or clearance actions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRfidTracked rdf:type rdf:Property ;
    rdfs:label 'Is Rfid Tracked' ;
    rdfs:comment 'Indicates whether this SKU at this node is tracked using RFID (Radio Frequency Identification) technology for real-time inventory visibility. True enables automated cycle counts and reduces manual scanning overhead. Relevant for apparel and high-value electronics categories.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVmi rdf:type rdf:Property ;
    rdfs:label 'Is Vmi' ;
    rdfs:comment 'Indicates whether this SKU-node stock position is managed under a Vendor Managed Inventory (VMI) agreement, where the supplier is responsible for maintaining stock levels. When true, replenishment is supplier-initiated via EDI (Electronic Data Interchange) rather than retailer-triggered.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAdjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Adjustment Date' ;
    rdfs:comment 'Date of the most recent manual or system-generated inventory adjustment (positive or negative) for this SKU at this node. Adjustments include shrinkage write-offs, cycle count corrections, and damage write-downs posted in SAP S/4HANA MM.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date of the most recent physical cycle count or inventory audit performed for this SKU at this node. Used to assess on-hand quantity accuracy, identify shrinkage, and schedule next count. Supports OSHA and internal audit compliance for inventory accuracy.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastGoodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Receipt Date' ;
    rdfs:comment 'Date of the most recent goods receipt (inbound delivery) that updated the on-hand quantity for this SKU at this node. Sourced from SAP S/4HANA MM goods receipt postings and Manhattan Associates WMS inbound transactions. Used for freshness and lead time analysis.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSaleDate rdf:type rdf:Property ;
    rdfs:label 'Last Sale Date' ;
    rdfs:comment 'Date of the most recent Point of Sale (POS) or e-commerce sale transaction that depleted stock for this SKU at this node. Sourced from SAP Customer Activity Repository (CAR). Used for dead stock identification, velocity scoring, and markdown trigger analysis.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxStockQty rdf:type rdf:Property ;
    rdfs:label 'Max Stock Qty' ;
    rdfs:comment 'Maximum allowable on-hand quantity for this SKU at this node, used to prevent overstock and optimize shelf/storage capacity. Defined in Oracle Retail Merchandising System (ORMS) and used by replenishment planning to cap order quantities within Open-to-Buy (OTB) constraints.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQty rdf:type rdf:Property ;
    rdfs:label 'On Hand Qty' ;
    rdfs:comment 'Total physical quantity of the SKU currently present at the inventory node, including all stock categories (sellable, reserved, damaged). Sourced from Manhattan Associates WMS goods receipt and adjustment transactions. Core metric for inventory visibility.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onOrderQty rdf:type rdf:Property ;
    rdfs:label 'On Order Qty' ;
    rdfs:comment 'Quantity of the SKU on open purchase orders or replenishment orders placed with suppliers but not yet shipped. Sourced from Oracle Retail Merchandising System (ORMS) purchase order lines. Represents future supply commitment within the Open-to-Buy (OTB) budget.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the stock position record. Active: normal sellable stock; frozen: temporarily locked pending investigation; quarantine: damaged or suspect stock held for quality review; blocked: SAP-blocked stock not available for sale; closed: position deactivated (zero stock, node closed).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Position Timestamp' ;
    rdfs:comment 'The precise date and time at which this stock position snapshot was captured or last updated. Represents the real-world event time of the inventory state. Critical for real-time ATP (Available-to-Promise) accuracy and omnichannel fulfillment SLA compliance.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quarantineQty rdf:type rdf:Property ;
    rdfs:label 'Quarantine Qty' ;
    rdfs:comment 'Quantity of the SKU placed in quarantine pending quality inspection, regulatory hold, or recall investigation. Separate from damaged stock. Relevant for FDA food safety holds, CPSC recall compliance, and supplier quality disputes.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPointQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Qty' ;
    rdfs:comment 'Minimum on-hand quantity threshold at which a replenishment order is automatically triggered for this SKU at this node. Calculated by Blue Yonder Demand Planning based on lead time, demand velocity, and safety stock parameters. Core input to replenishment trigger logic.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentStatus rdf:type rdf:Property ;
    rdfs:label 'Replenishment Status' ;
    rdfs:comment 'Current replenishment workflow status for this SKU-node combination. normal: no action needed; triggered: reorder point breached, order pending; in_progress: replenishment order placed and open; suspended: replenishment paused (e.g., seasonal end, discontinuation); vmi: under Vendor Managed Inventory (VMI) control.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservedQty rdf:type rdf:Property ;
    rdfs:label 'Reserved Qty' ;
    rdfs:comment 'Quantity of the SKU reserved against confirmed customer orders, BOPIS (Buy Online Pick Up In Store), ROPIS (Reserve Online Pick Up In Store), or internal transfer orders. Not available for new ATP commitments until reservation is released or fulfilled.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Qty' ;
    rdfs:comment 'Buffer stock quantity maintained above the reorder point to protect against demand variability and supply lead time uncertainty. Set by Blue Yonder Demand Planning. Prevents stockouts during peak demand or supplier delays.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellThroughRate rdf:type rdf:Property ;
    rdfs:label 'Sell Through Rate' ;
    rdfs:comment 'Percentage of received inventory that has been sold within a defined period, expressed as a decimal (e.g., 0.7500 = 75%). Key performance indicator for assortment efficiency, markdown timing, and dead stock identification. Calculated from SAP Customer Activity Repository (CAR) POS data.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkageQty rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Qty' ;
    rdfs:comment 'Cumulative quantity of inventory loss attributed to shrinkage (theft, administrative error, vendor fraud, or damage) since the last cycle count or physical inventory. Used for shrinkage monitoring, loss prevention analytics, and COGS adjustment reporting.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The native record identifier from the originating operational system (e.g., SAP material document number, Manhattan Associates WMS inventory record ID). Enables traceability back to the system of record for reconciliation, audit, and EDI dispute resolution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Code identifying the operational system of record that originated this stock position record. SAP_S4: SAP S/4HANA; ORMS: Oracle Retail Merchandising System; MAWMS: Manhattan Associates WMS; BYOND: Blue Yonder Demand Planning; SFCC: Salesforce Commerce Cloud; CAR: SAP Customer Activity Repository. Supports data lineage and Master Data Management (MDM) reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Specific storage location, bin, aisle, or zone within the inventory node where this SKU is physically stored. Sourced from Manhattan Associates WMS. Used for pick/pack/ship operations, cycle counts, and planogram (POG) compliance in store operations.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Standard cost per unit of the SKU used for inventory valuation and Cost of Goods Sold (COGS) calculation. Sourced from SAP S/4HANA FI/CO module. Confidential as it reflects supplier pricing and margin strategy. Used for GMROI (Gross Margin Return on Investment) analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upc rdf:type rdf:Property ;
    rdfs:label 'Upc' ;
    rdfs:comment 'Universal Product Code (UPC) or European Article Number (EAN) barcode identifier for the SKU. Used for Point of Sale (POS) scanning, RFID tracking, and GS1-compliant product identification across the supply chain.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this stock position record in the Databricks Silver Layer. Used for incremental data processing, change data capture (CDC), and audit trail compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:velocityBand rdf:type rdf:Property ;
    rdfs:label 'Velocity Band' ;
    rdfs:comment 'ABC/D velocity classification of the SKU at this node based on sales frequency and volume. A: fast-moving (top sellers); B: medium-moving; C: slow-moving; D: very slow or non-moving (dead stock candidate). Used for replenishment prioritization, planogram slotting, and markdown strategy.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeksOfSupply rdf:type rdf:Property ;
    rdfs:label 'Weeks Of Supply' ;
    rdfs:comment 'Number of weeks the current on-hand quantity is projected to last based on the current average weekly sales velocity. Key inventory health metric (WOS) used by merchants and planners to identify overstock, understock, and dead stock situations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockLedgerId rdf:type rdf:Property ;
    rdfs:label 'Stock Ledger Id' ;
    rdfs:comment 'Unique surrogate identifier for each stock ledger transaction record. Primary key for the perpetual inventory ledger at the SKU-location-date level.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLedger .

ind:fulfillmentLineId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Line Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.fulfillment_line. Business justification: Each fulfillment line pick generates a stock ledger entry. Line-level traceability between inventory movements and fulfillment lines is required for short-pick shrinkage detection, COGS allocation per' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentLine .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to inventory.goods_receipt. Business justification: Goods receipts generate stock ledger entries recording the inventory increase at the receiving node. stock_ledger has reference_document_number and reference_document_type string fields that generical' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Reference to the inventory node (store, Distribution Center (DC), Micro-Fulfillment Center (MFC), or dark store) where the stock movement occurred.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:markdownId rdf:type rdf:Property ;
    rdfs:label 'Markdown Id' ;
    rdfs:comment 'Foreign key linking to pricing.markdown. Business justification: Markdown events generate stock ledger entries recording retail value write-downs. Linking stock_ledger to markdown_id allows retail-method accounting systems to reconcile markdown transactions against' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Markdown .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.fulfillment_order. Business justification: Fulfillment orders trigger inventory movement postings (goods issue, pick, ship). Linking stock_ledger to fulfillment_order enables fulfillment-driven inventory movement reporting, COGS reconciliation' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentOrder .

ind:outboundOrderId rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Id' ;
    rdfs:comment 'Foreign key linking to supplychain.outbound_order. Business justification: DC outbound operations: when a DC ships to a store via an outbound_order, stock_ledger entries record the inventory deduction. Retail DC inventory controllers need to trace stock_ledger outbound movem' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundOrder .

ind:priceChangeId rdf:type rdf:Property ;
    rdfs:label 'Price Change Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_change. Business justification: Under the retail inventory method, price change events generate stock ledger entries (retail value write-ups/write-downs). Linking stock_ledger to price_change enables retail accounting systems to tra' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceChange .

ind:promoCampaignId rdf:type rdf:Property ;
    rdfs:label 'Promo Campaign Id' ;
    rdfs:comment 'Foreign key linking to promotion.promo_campaign. Business justification: Promotional lift analysis requires attributing inventory movements (sales, markdowns) to specific campaigns. Enables campaign-level sell-through reporting, promotional shrinkage tracking, and vendor c' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCampaign .

ind:receivingEventId rdf:type rdf:Property ;
    rdfs:label 'Receiving Event Id' ;
    rdfs:comment 'Foreign key linking to supplychain.receiving_event. Business justification: DC receiving operations: when goods are unloaded and received (receiving_event), stock_ledger entries are created to record the inventory movement. Retail DC inventory accountants need to trace every ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReceivingEvent .

ind:reversedTransactionStockLedgerId rdf:type rdf:Property ;
    rdfs:label 'Reversed Transaction Stock Ledger Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original stock_ledger_id that this record reverses. Populated only when reversal_flag = True. Enables bidirectional audit trail linking between original and reversal entries.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLedger .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.shipment. Business justification: Shipment completion triggers goods-issue stock ledger postings. Linking stock_ledger to shipment enables shipment-level inventory cost reconciliation, carrier charge vs. inventory cost variance report' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:stockTransferId rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_transfer. Business justification: Stock transfer movements generate stock ledger entries (debit at source node, credit at destination node). stock_ledger has reference_document_number and reference_document_type string fields that gen' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockTransfer .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Reference to the supplier associated with this stock movement, applicable for receipt and Direct Store Delivery (DSD) transactions. Null for internal transfers and sales depletions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The omnichannel fulfillment channel through which this stock movement was triggered. STORE = in-store POS sale; ECOMMERCE = online order depletion; BOPIS = Buy Online Pick Up In Store; SHIP_FROM_STORE = store-as-fulfillment-center; DC = Distribution Center; MFC = Micro-Fulfillment Center; DARK_STORE = fulfillment-only location. [ENUM-REF-CANDIDATE: STORE|ECOMMERCE|BOPIS|SHIP_FROM_STORE|DC|MFC|DARK_STORE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadStockFlag rdf:type rdf:Property ;
    rdfs:label 'Dead Stock Flag' ;
    rdfs:comment 'Indicates whether this stock movement is associated with dead stock (unsold, obsolete inventory being written off or liquidated). True = dead stock write-off or clearance movement. Supports inventory health reporting and markdown decision-making.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dsdFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Flag' ;
    rdfs:comment 'Indicates whether this receipt transaction was fulfilled via Direct Store Delivery (DSD), where the supplier delivers directly to the store bypassing the Distribution Center (DC). True = DSD transaction. Impacts supply chain routing and vendor compliance tracking.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extendedCost rdf:type rdf:Property ;
    rdfs:label 'Extended Cost' ;
    rdfs:comment 'Total cost value of this stock movement, calculated as movement_quantity multiplied by unit_cost. Represents the financial impact on inventory valuation and feeds the general ledger Cost of Goods Sold (COGS) account. Used for financial reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedRetailValue rdf:type rdf:Property ;
    rdfs:label 'Extended Retail Value' ;
    rdfs:comment 'Total retail value of this stock movement, calculated as movement_quantity multiplied by unit_retail_price. Used in the retail inventory method for inventory valuation and supports gross margin return on investment (GMROI) reporting.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The retail fiscal period (year and period number, e.g., 2024-P01) to which this stock movement is attributed for financial reporting and inventory reconciliation. Supports 4-4-5 and 4-5-4 retail calendar structures.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementQuantity rdf:type rdf:Property ;
    rdfs:label 'Movement Quantity' ;
    rdfs:comment 'The quantity of units moved in this transaction. Positive values indicate stock increases (receipts, returns, transfer-in); negative values indicate stock decreases (sales, write-offs, transfer-out). Expressed in the SKU\'s base unit of measure.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementReasonCode rdf:type rdf:Property ;
    rdfs:label 'Movement Reason Code' ;
    rdfs:comment 'Standardized reason code providing additional context for the stock movement (e.g., VENDOR_RETURN, DAMAGED_GOODS, CYCLE_COUNT_VARIANCE, THEFT_SHRINKAGE, EXPIRED_PRODUCT, PROMOTIONAL_WRITE_DOWN). Supports shrinkage analysis and loss prevention reporting. [ENUM-REF-CANDIDATE: VENDOR_RETURN|DAMAGED_GOODS|CYCLE_COUNT_VARIANCE|THEFT_SHRINKAGE|EXPIRED_PRODUCT|PROMOTIONAL_WRITE_DOWN|CUSTOMER_RETURN|INTER_DC_TRANSFER — promote to reference product]' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for additional context or commentary on this stock movement, entered by warehouse staff, store associates, or system processes (e.g., cycle count discrepancy explanation, damage description, special handling notes). Supports operational investigation and audit.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onHandQuantityAfter rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity After' ;
    rdfs:comment 'The total on-hand inventory quantity for this SKU at this location immediately after this transaction was applied. Represents the running balance of the perpetual inventory ledger and is the authoritative stock position for omnichannel fulfillment visibility.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQuantityBefore rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity Before' ;
    rdfs:comment 'The total on-hand inventory quantity for this SKU at this location immediately before this transaction was applied. Enables point-in-time inventory reconstruction and audit trail validation of the perpetual ledger.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The accounting date on which this stock movement is posted to the general ledger and inventory valuation records. May differ from transaction_timestamp due to cut-off processing, period-end adjustments, or delayed DSD confirmations.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'The source document number from the originating business transaction that triggered this stock movement (e.g., Purchase Order number, Transfer Order number, POS receipt number, Return Merchandise Authorization (RMA) number). Enables end-to-end traceability.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'The type of source document associated with this stock movement (e.g., PURCHASE_ORDER, TRANSFER_ORDER, POS_RECEIPT, RMA = Return Merchandise Authorization, CYCLE_COUNT, WRITE_OFF_ORDER). Enables document-level drill-through for audit and reconciliation.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this stock ledger entry is a reversal (counter-entry) of a previously posted transaction. True = this record reverses a prior movement. Used to identify corrective entries and maintain a clean audit trail for financial reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidTracked rdf:type rdf:Property ;
    rdfs:label 'Rfid Tracked' ;
    rdfs:comment 'Indicates whether this stock movement was captured or validated using Radio Frequency Identification (RFID) technology. True = RFID-confirmed movement. Supports inventory accuracy benchmarking and RFID program performance reporting.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'The unique serial number of the specific inventory unit involved in this transaction. Applicable for high-value electronics, appliances, and serialized items. Supports specific identification costing, warranty tracking, and CPSC recall management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shrinkageFlag rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Flag' ;
    rdfs:comment 'Indicates whether this stock movement represents inventory shrinkage (loss due to theft, damage, administrative error, or vendor fraud). True = shrinkage event. Used for shrinkage monitoring, loss prevention analytics, and CPSC/NRF compliance reporting.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally-known business identifier for this stock movement transaction, sourced from the originating system (e.g., SAP material document number, ORMS transaction reference). Used for cross-system reconciliation and audit tracing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle state of the stock ledger transaction. POSTED = confirmed and applied to on-hand balance; PENDING = awaiting confirmation; REVERSED = corrected by a counter-entry; VOIDED = cancelled before posting; ERROR = failed validation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'The precise real-world date and time when the stock movement event occurred (e.g., POS scan time, receiving dock timestamp, cycle count completion time). This is the principal business event time, distinct from system audit timestamps.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the stock movement event driving this ledger entry. RECEIPT = inbound from supplier or DC; SALE = Point of Sale (POS) depletion; TRANSFER_IN/OUT = inter-location movement; ADJUSTMENT = cycle count correction; RETURN = customer or Return to Vendor (RTV); WRITE_OFF = shrinkage or dead stock removal. [ENUM-REF-CANDIDATE: RECEIPT|SALE|TRANSFER_IN|TRANSFER_OUT|ADJUSTMENT|RETURN|WRITE_OFF|DSD_RECEIPT|MARKDOWN_WRITE_DOWN|CYCLE_COUNT — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Retail Price' ;
    rdfs:comment 'The retail selling price per unit at the time of the transaction. Used for inventory valuation under the retail inventory method and for calculating gross margin. Supports Average Unit Retail (AUR) analytics and sell-through rate calculations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'The inventory costing method applied to this stock movement for financial valuation purposes. FIFO = First In First Out; WAC = Weighted Average Cost; RETAIL_METHOD = retail inventory method; LIFO = Last In First Out (where permitted); SPECIFIC_ID = specific identification for high-value items.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmfFlag rdf:type rdf:Property ;
    rdfs:label 'Vmf Flag' ;
    rdfs:comment 'Indicates whether this stock movement is part of a Vendor Managed Inventory (VMI) arrangement, where the supplier is responsible for maintaining stock levels. True = VMI-managed transaction. Impacts replenishment ownership and supplier performance tracking.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costZoneId rdf:type rdf:Property ;
    rdfs:label 'Cost Zone Id' ;
    rdfs:comment 'Foreign key linking to pricing.cost_zone. Business justification: Inventory nodes are assigned to cost zones that determine landed cost, freight factors, and duty rates applicable to that node. This assignment drives cost_price calculations for replenishment and goo' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostZone .

ind:dcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Dc Facility Id' ;
    rdfs:comment 'Add column dc_facility_id (BIGINT) to supplychain.inventory_node with FK to supplychain.dc_facility.dc_facility_id because inventory nodes at distribution centers should reference the DC facility. P15: connect_table: supplychain.inventory_node*' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:priceZoneId rdf:type rdf:Property ;
    rdfs:label 'Price Zone Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_zone. Business justification: Every retail store/DC node belongs to a price zone that determines which sku_price records are active for that location. Price zone assignment to inventory nodes is fundamental to retail pricing execu' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceZone .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address of the inventory node facility. Used for carrier routing, last-mile delivery coordination, and regulatory filings.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address detail (suite, dock number, building identifier) for the inventory node facility.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City in which the inventory node is located. Used for geographic reporting, tax jurisdiction assignment, and carrier zone mapping.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Calendar date on which the inventory node was permanently closed or decommissioned. Null for active nodes. Used for historical inventory reporting and asset disposal tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the node location. Governs applicable regulatory frameworks (FDA, CPSC, GDPR/CCPA), currency, and customs rules.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountFrequency rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency' ;
    rdfs:comment 'Scheduled frequency at which physical inventory cycle counts are conducted at this node. Drives WMS task scheduling and shrinkage monitoring cadence.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtCode rdf:type rdf:Property ;
    rdfs:label 'District Code' ;
    rdfs:comment 'Internal district code within a region, used for field management span-of-control, district-level KPI reporting, and workforce scheduling via Workday HCM.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorCount rdf:type rdf:Property ;
    rdfs:label 'Dock Door Count' ;
    rdfs:comment 'Number of inbound/outbound dock doors at the node. Determines receiving throughput capacity, inbound appointment scheduling windows, and cross-docking feasibility in Manhattan Associates WMS.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formatCode rdf:type rdf:Property ;
    rdfs:label 'Format Code' ;
    rdfs:comment 'Retail format identifier assigned to the node (e.g., \'HYPERMARKET\', \'DISCOUNT\', \'DEPT_STORE\', \'ECOMM_FC\'). Drives assortment breadth/depth rules in ORMS and planogram (POG) assignments.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gln rdf:type rdf:Property ;
    rdfs:label 'Gln' ;
    rdfs:comment 'GS1-issued 13-digit Global Location Number uniquely identifying this node in the global supply chain. Used in EDI transactions (ASC X12 / EDIFACT), RFID-based receiving, and supplier communications.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBopisEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Bopis Enabled' ;
    rdfs:comment 'Indicates whether the node supports Buy Online Pick Up In Store (BOPIS) fulfillment. Drives order routing logic in the OMS and Salesforce Commerce Cloud checkout flow.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDropShipOrigin rdf:type rdf:Property ;
    rdfs:label 'Is Drop Ship Origin' ;
    rdfs:comment 'Indicates whether this node acts as a drop-ship origin point where a vendor ships directly to the end customer on behalf of the retailer, bypassing DC inventory.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Rfid Enabled' ;
    rdfs:comment 'Indicates whether the node is equipped with RFID infrastructure for real-time inventory tracking, cycle count automation, and shrinkage reduction.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRopisEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Ropis Enabled' ;
    rdfs:comment 'Indicates whether the node supports Reserve Online Pick Up In Store (ROPIS), allowing customers to reserve items online and collect without pre-payment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShipFromStoreEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Ship From Store Enabled' ;
    rdfs:comment 'Indicates whether the node is configured as a Ship-from-Store (SFS) fulfillment center, allowing it to pick, pack, and ship e-commerce orders directly to customers.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVmiEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Vmi Enabled' ;
    rdfs:comment 'Indicates whether this node participates in a Vendor Managed Inventory (VMI) program where the supplier is responsible for maintaining stock levels.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this inventory node master record. Used for change data capture (CDC), MDM synchronization, and Silver Layer incremental processing in Databricks.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'WGS-84 decimal latitude coordinate of the node. Enables geospatial proximity analysis for BOPIS radius calculations, last-mile routing optimization, and store clustering.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'WGS-84 decimal longitude coordinate of the node. Used alongside latitude for geospatial routing, catchment area analysis, and omnichannel fulfillment optimization.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Name of the store manager, DC operations manager, or facility lead responsible for this inventory node. Used for escalation routing, audit accountability, and Workday HCM workforce reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSkuCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Sku Capacity' ;
    rdfs:comment 'Maximum number of distinct SKUs (Stock Keeping Units) the node can actively stock based on shelf slots, bin locations, and planogram (POG) configuration. Used in assortment planning and OTB (Open to Buy) calculations.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the node as maintained in SAP S/4HANA WM and Oracle Retail Merchandising System (ORMS). Used in EDI transactions, purchase orders, and replenishment plans to reference the location. Serves as the BUSINESS_IDENTIFIER (MASTER_RESOURCE canonical category).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable display name of the inventory node (e.g., \'Chicago Midway DC\', \'Store #0421 – Oak Park\'). Used in operational reports, planograms, and WMS screens. Serves as the IDENTITY_LABEL (MASTER_RESOURCE canonical category).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Categorical classification of the inventory-holding location. Drives fulfillment capability rules, replenishment logic, and reporting hierarchies. Valid values: store (retail selling floor), distribution_center (DC), micro_fulfillment_center (MFC), dark_store (fulfillment-only), vendor_managed (VMI location), in_transit (goods in movement). Serves as the CLASSIFICATION_OR_TYPE (MASTER_RESOURCE canonical category).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Calendar date on which the inventory node became operationally active and began receiving or fulfilling inventory. Used for comp sales (SSS) eligibility determination and new-store ramp analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current lifecycle state of the inventory node. Controls whether the node is eligible to receive stock, fulfill orders, or appear in replenishment plans. Serves as the LIFECYCLE_STATUS (MASTER_RESOURCE canonical category).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Legal ownership or operating arrangement for the node facility. Drives lease accounting under FASB ASC 842, asset capitalization rules, and P&L cost allocation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary operational phone number for the inventory node facility. Used for carrier coordination, inbound appointment confirmation, and emergency contact.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the inventory node. Used for carrier zone determination, last-mile delivery routing, and geographic market analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDcNodeCode rdf:type rdf:Property ;
    rdfs:label 'Primary Dc Node Code' ;
    rdfs:comment 'Node code of the primary Distribution Center (DC) that replenishes this node. Used in replenishment routing, inbound appointment scheduling, and supply chain network optimization.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Internal geographic region code grouping nodes for regional P&L reporting, district management, and comp sales (SSS) analysis (e.g., \'MIDWEST\', \'NORTHEAST\', \'WEST_COAST\').' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Replenishment Lead Time Days' ;
    rdfs:comment 'Standard number of days from replenishment order placement to stock receipt at this node. Used by Blue Yonder Demand Planning to calculate reorder points, weeks of supply (WOS), and safety stock levels.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockDays rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Days' ;
    rdfs:comment 'Minimum days of supply maintained as safety stock buffer at this node to protect against demand variability and supply disruptions. Feeds Blue Yonder replenishment planning and WOS calculations.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sellingAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Selling Area Sqft' ;
    rdfs:comment 'Net selling floor area in square feet, excluding back-of-house, receiving docks, and storage. Used for sales-per-square-foot KPI, planogram space allocation, and GMROI analysis.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'ISO 3166-2 state or province code for the node location. Drives sales tax rules, labor law compliance, and regional reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Secondary classification providing finer granularity within node_type (e.g., hypermarket, department_store, discount_outlet, cross_dock_dc, ambient_dc, cold_chain_dc, ship_from_store_hub). [ENUM-REF-CANDIDATE: hypermarket|department_store|discount_outlet|cross_dock_dc|ambient_dc|cold_chain_dc|ship_from_store_hub|ecommerce_fc — promote to reference product]' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Storage temperature classification for the node. Governs which SKU categories (grocery, frozen, pharma) can be stocked and drives cold-chain compliance requirements under FDA food safety regulations.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the node (e.g., \'America/Chicago\'). Critical for accurate timestamp normalization of POS transactions, cycle count scheduling, and SLA window calculations across multi-timezone networks.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStorageCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Total Storage Capacity Sqft' ;
    rdfs:comment 'Total physical storage area of the node measured in square feet. Used for capacity planning, space utilization analysis, and GMROI calculations. Serves as the MEASUREMENT_OR_VALUE (MASTER_RESOURCE canonical category).' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Id' ;
    rdfs:comment 'Unique surrogate identifier for the replenishment order record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplenishmentOrder .

ind:costPriceId rdf:type rdf:Property ;
    rdfs:label 'Cost Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.cost_price. Business justification: Purchase order costing and landed cost validation require linking replenishment orders to contracted vendor cost structures. Enables variance analysis between ordered cost and actual invoice cost, and' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostPrice .

ind:demandForecastId rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Id' ;
    rdfs:comment 'Reference to the demand forecast record that informed the replenishment quantity calculation. Links to the Blue Yonder Demand Planning forecast used to size this order.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandForecast .

ind:destinationNodeInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Node Inventory Node Id' ;
    rdfs:comment 'Reference to the receiving fulfillment node (store, DC, or MFC) where replenished inventory will be delivered. Drives last-mile delivery routing and receiving dock scheduling.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:inboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Inbound Shipment Id' ;
    rdfs:comment 'Foreign key linking to supplychain.inbound_shipment. Business justification: Replenishment order fulfillment tracking: when a vendor ships against a replenishment_order, an inbound_shipment is created. Retail replenishment managers track expected_delivery_date vs. actual_arriv' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundShipment .

ind:leadTimeAgreementId rdf:type rdf:Property ;
    rdfs:label 'Lead Time Agreement Id' ;
    rdfs:comment 'Foreign key linking to supplier.lead_time_agreement. Business justification: Replenishment orders must reference the governing lead time SLA to enable on-time delivery compliance reporting and exception alerting. Retail supply chain teams track whether each order was fulfilled' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeadTimeAgreement .

ind:primaryReplenishmentInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Replenishment Inventory Node Id' ;
    rdfs:comment 'Reference to the originating fulfillment node (Distribution Center, Micro-Fulfillment Center, or supplier location) from which inventory will be shipped. Supports omnichannel inventory routing logic.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Reference to the associated purchase order in SAP S/4HANA MM or Oracle Retail Merchandising System (ORMS) when the replenishment order results in a supplier PO. Nullable for internal DC-to-store transfers.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:replenishmentPlanId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Plan Id' ;
    rdfs:comment 'Foreign key linking to supplychain.replenishment_plan. Business justification: Replenishment execution tracking: a replenishment_order is the execution artifact of a replenishment_plan. Retail buyers and planners need to compare planned vs. actual order quantities and timing. Th' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplenishmentPlan .

ind:vendorContractId rdf:type rdf:Property ;
    rdfs:label 'Vendor Contract Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor_contract. Business justification: Replenishment orders must be placed under an active vendor contract to enforce pricing, MOQ, and payment terms. Retail procurement compliance requires each order to reference the governing contract fo' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorContract .

ind:vendorItemId rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor_item. Business justification: When raising a replenishment order, buyers reference the vendor\'s catalog entry (vendor_item) to confirm pack size, MOQ, and unit cost. This link enables PO accuracy validation and cost capture at ord' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorItem .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The date the replenishment order was physically received and confirmed at the destination node. Compared against expected_delivery_date to measure supplier on-time delivery performance and SLA compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedQuantity rdf:type rdf:Property ;
    rdfs:label 'Approved Quantity' ;
    rdfs:comment 'The quantity confirmed and approved for fulfillment after supplier acceptance, MOQ compliance checks, and buyer review. May differ from ordered_quantity due to supplier constraints or buyer adjustments.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The date and time the replenishment order was approved by the buyer or automatically confirmed by the system. Marks the transition from draft/submitted to approved status in the order lifecycle.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:buyerNotes rdf:type rdf:Property ;
    rdfs:label 'Buyer Notes' ;
    rdfs:comment 'Free-text notes entered by the merchandise buyer or replenishment analyst providing context for manual overrides, special handling instructions, or supplier communication details for this replenishment order.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'The business reason for cancelling the replenishment order. Overstock = destination node already has sufficient inventory; supplier_oos = supplier cannot fulfill; price_discrepancy = cost mismatch; duplicate_order = order already exists; demand_change = forecast revision eliminated need. Nullable for non-cancelled orders.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'The date and time the replenishment order was cancelled, if applicable. Nullable for active or completed orders. Used for supplier chargeback processing and demand planning feedback loops.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'The anticipated date on which the replenishment order is expected to arrive at the destination node, calculated from order_date plus lead_time_days. Used for inventory availability planning and receiving dock scheduling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentChannel rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Channel' ;
    rdfs:comment 'The physical supply chain channel through which this replenishment order will be fulfilled. dc_to_store = Distribution Center to store; supplier_to_store = Direct Store Delivery (DSD); supplier_to_dc = inbound to DC; cross_dock = Cross-Docking without DC storage; dsd = Direct Store Delivery; drop_ship = vendor ships directly to end customer. [ENUM-REF-CANDIDATE: dc_to_store|supplier_to_store|supplier_to_dc|cross_dock|dsd|drop_ship — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergency rdf:type rdf:Property ;
    rdfs:label 'Is Emergency' ;
    rdfs:comment 'Indicates whether this replenishment order was flagged as an emergency order due to an imminent or active out-of-stock situation. Emergency orders bypass standard lead time and approval workflows. True = emergency; False = standard.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'The supplier Lead Time in calendar days from order submission to expected delivery at the destination node. Sourced from SAP S/4HANA MM purchasing info record or Blue Yonder Demand Planning supplier master. Used to calculate expected_delivery_date and Weeks of Supply (WOS).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moq rdf:type rdf:Property ;
    rdfs:label 'Moq' ;
    rdfs:comment 'The Minimum Order Quantity (MOQ) stipulated by the supplier for this SKU at the time the replenishment order was created. Used to validate that ordered_quantity meets supplier contractual requirements. Sourced from SAP S/4HANA MM purchasing info record.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqCompliant rdf:type rdf:Property ;
    rdfs:label 'Moq Compliant' ;
    rdfs:comment 'Indicates whether the ordered_quantity meets or exceeds the supplier\'s Minimum Order Quantity (MOQ) requirement. True = compliant; False = below MOQ threshold, requiring buyer review or override.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The principal business event timestamp — the date and time the replenishment order was created and submitted by the demand planning or replenishment system (Blue Yonder or SAP MM). Distinct from audit timestamps.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally-known business identifier for the replenishment order, sourced from Blue Yonder Demand Planning or SAP S/4HANA MM module. Used for cross-system traceability and supplier communication via EDI.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the replenishment order. Tracks progression from draft creation through approval, shipment, receipt at destination node, and closure. Cancelled indicates the order was voided before fulfillment. [ENUM-REF-CANDIDATE: draft|submitted|approved|in_transit|received|partially_received|cancelled|closed — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of how the replenishment order was triggered. Auto-replenishment is system-generated based on reorder policy thresholds; manual is buyer-initiated; VMI (Vendor Managed Inventory) is supplier-driven; emergency covers urgent out-of-stock situations; cross_dock bypasses DC storage; drop_ship routes directly from vendor to destination. [ENUM-REF-CANDIDATE: auto_replenishment|manual|vmi|emergency|cross_dock|drop_ship — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity of the SKU originally requested in the replenishment order, expressed in the SKU\'s base unit of measure (e.g., each, case, pallet). This is the raw demand signal before supplier approval or MOQ adjustment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to this replenishment order, used to sequence fulfillment and allocate DC resources. Critical = imminent out-of-stock risk; high = elevated demand or promotional support; standard = routine replenishment; low = opportunistic or pre-build.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'The actual quantity of the SKU physically received and confirmed at the destination node. Used to calculate fill rate and identify short shipments. Populated upon goods receipt in Manhattan Associates WMS or SAP S/4HANA WM.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemOrderRef rdf:type rdf:Property ;
    rdfs:label 'Source System Order Ref' ;
    rdfs:comment 'The native order identifier from the originating source system (e.g., SAP MM document number, Blue Yonder order ID, ORMS order number). Enables reverse lookup and reconciliation with the system of record.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderCost rdf:type rdf:Property ;
    rdfs:label 'Total Order Cost' ;
    rdfs:comment 'The total cost of the replenishment order calculated as approved_quantity multiplied by unit_cost. Represents the financial commitment for this replenishment event. Used for Open to Buy (OTB) budget tracking and P&L reporting.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Type' ;
    rdfs:comment 'The mechanism that triggered this replenishment order. reorder_point = on-hand fell below reorder point threshold; min_max = inventory fell below minimum level; days_of_supply = Weeks of Supply (WOS) fell below threshold; manual_override = buyer-initiated; vmi_signal = Vendor Managed Inventory (VMI) supplier signal; promotional = triggered by upcoming promotion event. [ENUM-REF-CANDIDATE: reorder_point|min_max|days_of_supply|manual_override|vmi_signal|promotional — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Id' ;
    rdfs:comment 'Unique system-generated identifier for each cycle count event record at the SKU-location level.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'Reference to the inventory adjustment record created as a result of this cycle count variance exceeding the tolerance threshold. Links the count event to its financial reconciliation record.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:departmentId rdf:type rdf:Property ;
    rdfs:label 'Department Id' ;
    rdfs:comment 'Foreign key linking to store.department. Business justification: Cycle counts are scheduled, executed, and reported by department within a store (e.g., \'count Apparel dept Q2\'). Retail loss prevention and inventory accuracy reporting require department-level cycle ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:warehouseZoneId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Zone Id' ;
    rdfs:comment 'Foreign key linking to supplychain.warehouse_zone. Business justification: DC cycle counting is organized by warehouse_zone — zone managers schedule and execute counts by zone. Linking cycle_count to warehouse_zone enables zone-level count frequency tracking, compliance repo' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseZone .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'ABC classification of the SKU at the time of the cycle count, indicating inventory value and velocity tier. A = high-value/high-velocity; B = medium; C = low-value/low-velocity; D = dead stock. Drives count frequency prioritization.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentGenerated rdf:type rdf:Property ;
    rdfs:label 'Adjustment Generated' ;
    rdfs:comment 'Indicates whether an inventory_adjustment record has been generated from this cycle count variance. When True, the variance has been posted to the inventory ledger for reconciliation.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'The date and time when the cycle count result was reviewed and approved by the designated supervisor or manager, completing the approval workflow.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Count Device Code' ;
    rdfs:comment 'Identifier of the handheld scanner, mobile device, or RFID reader used to perform the physical count. Supports device-level audit trail and equipment calibration tracking.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count End Timestamp' ;
    rdfs:comment 'The precise date and time when the physical counting activity was completed and the count was submitted by the assigned counter.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countFrequency rdf:type rdf:Property ;
    rdfs:label 'Count Frequency' ;
    rdfs:comment 'The scheduled counting frequency for this SKU-location combination, typically driven by ABC classification or velocity. High-velocity A-items are counted more frequently than slow-moving C-items.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNotes rdf:type rdf:Property ;
    rdfs:label 'Count Notes' ;
    rdfs:comment 'Free-text field for the counter or supervisor to record observations, exceptions, or explanations related to the cycle count result (e.g., damaged packaging, items in transit, display stock not included).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNumber rdf:type rdf:Property ;
    rdfs:label 'Count Number' ;
    rdfs:comment 'Externally-known business reference number assigned to the cycle count event, used for cross-system tracking and audit trail. Typically generated by the WMS (e.g., Manhattan Associates) or SAP WM module.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'The precise date and time when the physical counting activity was initiated by the assigned counter. Used for cycle time analysis and labor tracking.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current workflow state of the cycle count event. \'scheduled\' = count is planned but not started; \'in_progress\' = counting is underway; \'completed\' = physical count recorded; \'reconciled\' = variance reviewed and inventory adjustment posted; \'cancelled\' = count was voided.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the cycle count method. \'scheduled\' = routine planned count; \'ad_hoc\' = unplanned triggered count; \'blind\' = counter does not see system quantity; \'directed\' = WMS-directed count task; \'rfid_assisted\' = count performed using Radio Frequency Identification (RFID) technology.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'The actual physical quantity of the SKU observed and recorded by the counter during the cycle count. This is the primary measured outcome of the count event.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planogramLocation rdf:type rdf:Property ;
    rdfs:label 'Planogram Location' ;
    rdfs:comment 'The planogram (POG) shelf position or fixture reference for the SKU at the store location, used to direct the counter to the correct physical location during in-store cycle counts.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountNumber rdf:type rdf:Property ;
    rdfs:label 'Recount Number' ;
    rdfs:comment 'Sequential count of how many times this SKU-location has been recounted within the same cycle count event. First count = 1; first recount = 2; etc. Supports escalation workflows when repeated recounts still show variance.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recountRequired rdf:type rdf:Property ;
    rdfs:label 'Recount Required' ;
    rdfs:comment 'Indicates whether a recount of this SKU-location is required because the variance exceeded the tolerance threshold or the count was flagged for discrepancy. When True, a follow-up count must be performed before reconciliation.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The calendar date on which the cycle count was planned to be performed, as set in the WMS count schedule.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shrinkageCategory rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Category' ;
    rdfs:comment 'Classification of the root cause of inventory shrinkage identified through this cycle count. Populated during the reconciliation phase when a negative variance is confirmed. Supports shrinkage investigation and loss prevention analytics.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageBin rdf:type rdf:Property ;
    rdfs:label 'Storage Bin' ;
    rdfs:comment 'The specific warehouse storage bin, shelf, or slot location within the inventory node where the SKU is physically stored and counted. Granular location identifier used by the WMS for directed counting.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemQuantity rdf:type rdf:Property ;
    rdfs:label 'System Quantity' ;
    rdfs:comment 'The inventory quantity recorded in the Warehouse Management System (WMS) or ERP at the exact time the cycle count was initiated. This is the \'book\' quantity against which the physical count is compared.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerReason rdf:type rdf:Property ;
    rdfs:label 'Trigger Reason' ;
    rdfs:comment 'Business reason that initiated this cycle count. Supports shrinkage investigation and root cause analysis. [ENUM-REF-CANDIDATE: routine|negative_inventory|shrinkage_alert|receiving_discrepancy|customer_complaint|audit_request|rfid_discrepancy — promote to reference product]' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceCost rdf:type rdf:Property ;
    rdfs:label 'Variance Cost' ;
    rdfs:comment 'The monetary value of the inventory variance, calculated as variance_quantity multiplied by the unit cost at time of count. Expressed in the local operating currency. Used for Cost of Goods Sold (COGS) impact assessment and financial reporting.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The variance quantity expressed as a percentage of the system on-hand quantity, calculated as (variance_quantity / system_quantity) * 100. Used to assess inventory accuracy and trigger shrinkage investigations when thresholds are exceeded.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'The difference between the physically counted quantity and the system on-hand quantity (counted_quantity minus system_quantity). A negative value indicates shrinkage or loss; a positive value indicates an overcount or unrecorded receipt.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Tolerance Pct' ;
    rdfs:comment 'The maximum acceptable variance percentage for this SKU-location before a recount or inventory adjustment is triggered. Variances exceeding this threshold generate inventory_adjustment records for reconciliation.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:posTransactionId rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Id' ;
    rdfs:comment 'Foreign key linking to order.pos_transaction. Business justification: Inventory adjustments for shrinkage, damage, or discrepancies are often discovered during POS operations (cashier finds damaged item, customer returns defective product). Linking adjustment to origina' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTransaction .

ind:reversalOfAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Reversal Of Adjustment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original adjustment record that this record is reversing. Populated only for reversal entries to maintain a complete audit trail of corrections. Nullable for original (non-reversal) adjustments.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:adjustedQuantity rdf:type rdf:Property ;
    rdfs:label 'Adjusted Quantity' ;
    rdfs:comment 'The net quantity change applied to on-hand inventory for the SKU at the specified location. Negative values represent inventory reductions (shrinkage, damage, write-offs); positive values represent inventory additions (found stock, receiving corrections). Expressed in the SKU\'s unit of measure.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for the adjustment transaction. Used in audit trails, loss prevention case references, and cross-system reconciliation with SAP S/4HANA and ORMS. Format: ADJ- followed by 10 digits.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current workflow lifecycle state of the adjustment record. Controls whether the adjustment has been applied to the stock ledger. \'posted\' indicates the adjustment has updated on-hand quantities; \'reversed\' indicates a correcting entry was made.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Timestamp' ;
    rdfs:comment 'The principal real-world date and time when the inventory adjustment event occurred (e.g., when shrinkage was detected, when a cycle count discrepancy was identified, when damage was observed). Distinct from system audit timestamps. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Indicates whether the adjustment has been reviewed and approved through the authorization workflow. \'auto_approved\' applies to system-generated adjustments below a defined threshold that bypass manual review. Distinct from adjustment_status which tracks the full posting lifecycle.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpact rdf:type rdf:Property ;
    rdfs:label 'Cost Impact' ;
    rdfs:comment 'Total financial impact of the inventory adjustment on Cost of Goods Sold (COGS), calculated as adjusted_quantity multiplied by unit_cost. Negative values represent write-downs (losses); positive values represent write-ups (gains). Posted to the general ledger via SAP FI/CO integration.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'The merchandise department code associated with the SKU being adjusted, sourced from the product hierarchy in Oracle Retail Merchandising System (ORMS). Enables shrinkage and adjustment reporting by department for category management and P&L analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'The method by which the inventory discrepancy or adjustment need was identified. Supports shrinkage root-cause analysis and RFID (Radio Frequency Identification) program effectiveness measurement. [ENUM-REF-CANDIDATE: cycle_count|physical_inventory|rfid_scan|pos_exception|receiving_audit|system_alert|manual_observation|loss_prevention_investigation — promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isShrinkage rdf:type rdf:Property ;
    rdfs:label 'Is Shrinkage' ;
    rdfs:comment 'Boolean flag indicating whether this adjustment represents a shrinkage event (inventory loss due to theft, damage, administrative error, or vendor fraud). Used to filter and aggregate shrinkage metrics for loss prevention reporting and GMROI (Gross Margin Return on Investment) analysis.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSystemGenerated rdf:type rdf:Property ;
    rdfs:label 'Is System Generated' ;
    rdfs:comment 'Boolean flag indicating whether the adjustment was automatically generated by a system process (e.g., Blue Yonder replenishment system, RFID reconciliation engine, WMS cycle count automation) rather than manually entered by a user.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the inventory node type where the adjustment occurred. Distinguishes between store-level adjustments, Distribution Center (DC) adjustments, Micro-Fulfillment Center (MFC) adjustments, and dark store adjustments for segmented shrinkage and variance reporting.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lpCaseReference rdf:type rdf:Property ;
    rdfs:label 'Lp Case Reference' ;
    rdfs:comment 'Reference number linking this inventory adjustment to an active or closed Loss Prevention (LP) investigation case (e.g., shoplifting incident, employee theft case). Nullable — only populated when the adjustment is associated with a formal LP case in Salesforce Service Cloud or a dedicated LP system.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAfterAdjustment rdf:type rdf:Property ;
    rdfs:label 'Quantity After Adjustment' ;
    rdfs:comment 'The on-hand inventory quantity for the SKU at the location immediately after this adjustment is applied. Derived at posting time and stored for audit trail and stock ledger reconciliation. Expressed in the SKU\'s unit of measure.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityBeforeAdjustment rdf:type rdf:Property ;
    rdfs:label 'Quantity Before Adjustment' ;
    rdfs:comment 'The on-hand inventory quantity for the SKU at the location immediately prior to this adjustment being applied. Captured at the time of adjustment for audit trail completeness and variance analysis. Expressed in the SKU\'s unit of measure.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCategory rdf:type rdf:Property ;
    rdfs:label 'Reason Category' ;
    rdfs:comment 'High-level classification of why the inventory adjustment is being made. Drives reporting buckets for shrinkage monitoring, COGS (Cost of Goods Sold) impact analysis, and loss prevention dashboards. [ENUM-REF-CANDIDATE: shrinkage|damage|cycle_count_correction|receiving_variance|expiry_write_off|rtv|admin_correction|found_stock — promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonSubCategory rdf:type rdf:Property ;
    rdfs:label 'Reason Sub Category' ;
    rdfs:comment 'Granular sub-classification within the reason category providing specific cause detail. Examples for shrinkage: shoplifting, employee theft, administrative error, vendor fraud. Examples for damage: in-transit damage, handling damage, shelf damage. Feeds loss prevention case analysis and shrinkage root-cause reporting. [ENUM-REF-CANDIDATE: shoplifting|employee_theft|admin_error|vendor_fraud|in_transit_damage|handling_damage|shelf_damage|expired|recalled|mis-ship — promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Boolean flag indicating whether this inventory adjustment is associated with a product recall event initiated by the CPSC, FDA, or the retailer. Enables rapid identification and financial quantification of recall-related inventory write-offs.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidTagCount rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Count' ;
    rdfs:comment 'Number of RFID (Radio Frequency Identification) tags scanned during the detection event that triggered this adjustment. Populated only for RFID-based detection methods. Supports RFID program accuracy measurement and tag read-rate analysis.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Source Document Number' ;
    rdfs:comment 'The reference number of the originating source document (e.g., cycle count ID, RTV authorization number, receiving document number, damage report ID). Enables cross-system traceability and audit trail linkage.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Source Document Type' ;
    rdfs:comment 'The type of source business document that triggered or supports this inventory adjustment. Provides traceability back to the originating business process (e.g., cycle count sheet, Return to Vendor (RTV) authorization, receiving document). [ENUM-REF-CANDIDATE: cycle_count|physical_inventory|rtv_authorization|receiving_document|damage_report|expiry_report|pos_exception_report — promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Reference to the logistics carrier or 3PL (Third-Party Logistics) provider responsible for transporting the stock transfer between nodes. Used for carrier performance analytics and SLA compliance reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:orderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Line Id' ;
    rdfs:comment 'Foreign key linking to order.order_line. Business justification: Ship-from-store fulfillment: when an online order line triggers a store-to-customer transfer, the stock_transfer must reference the originating order_line for customer service tracing, SLA compliance ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:primaryStockInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Inventory Node Id' ;
    rdfs:comment 'Identifier of the originating inventory node (store, DC, MFC, or vendor location) from which the stock transfer is dispatched. Supports network balancing and omnichannel fulfillment analytics.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'Calendar date on which the stock transfer was physically received and confirmed at the destination node. Compared against expected_receipt_date to measure carrier and DC performance against SLA targets.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:destinationNodeType rdf:type rdf:Property ;
    rdfs:label 'Destination Node Type' ;
    rdfs:comment 'Classification of the receiving inventory node. STORE: retail store; DC: distribution center; MFC: micro-fulfillment center; VENDOR: supplier location for RTV; DARK_STORE: fulfillment-only location.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Expected Receipt Date' ;
    rdfs:comment 'Planned calendar date by which the stock transfer is expected to arrive at the destination node. Used for replenishment planning, weeks of supply (WOS) calculations, and SLA compliance monitoring.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'Date and time when the stock transfer record was first created in the system, representing the business event of transfer initiation. Serves as the principal business event timestamp for the transfer lifecycle.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Inventory Cost Per Unit' ;
    rdfs:comment 'Cost of Goods Sold (COGS) value per unit for the transferred SKU at time of transfer, used for inventory valuation, GMROI calculations, and financial reporting. Sourced from SAP S/4HANA FI/CO standard cost or moving average cost.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCrossDock rdf:type rdf:Property ;
    rdfs:label 'Is Cross Dock' ;
    rdfs:comment 'Flag indicating whether this stock transfer is executed as a cross-docking (cross-dock) movement, where inventory is transferred directly from inbound to outbound at the DC without putaway storage. Supports DC throughput and flow-through analytics.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShipFromStore rdf:type rdf:Property ;
    rdfs:label 'Is Ship From Store' ;
    rdfs:comment 'Flag indicating whether this stock transfer is part of a ship-from-store (SFS) omnichannel fulfillment flow, where a retail store acts as a fulfillment node dispatching inventory to satisfy an e-commerce or BOPIS order.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVendorManaged rdf:type rdf:Property ;
    rdfs:label 'Is Vendor Managed' ;
    rdfs:comment 'Flag indicating whether this stock transfer is part of a Vendor Managed Inventory (VMI) program, where the supplier initiates and manages the replenishment transfer rather than the retailer\'s internal planning team.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled' ;
    rdfs:comment 'Flag indicating whether this stock transfer was tracked using RFID (Radio Frequency Identification) technology for real-time inventory visibility during transit. Supports RFID-based inventory accuracy programs.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'Calendar date on which the stock transfer was physically dispatched from the source node. Used for lead time calculation, carrier SLA tracking, and inventory in-transit reporting.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceNodeType rdf:type rdf:Property ;
    rdfs:label 'Source Node Type' ;
    rdfs:comment 'Classification of the originating inventory node. STORE: retail store; DC: distribution center; MFC: micro-fulfillment center; VENDOR: supplier location for RTV or DSD; DARK_STORE: fulfillment-only location.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-assigned shipment tracking number for the stock transfer, enabling real-time in-transit visibility and last-mile delivery monitoring. Used for exception management and carrier SLA validation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferCost rdf:type rdf:Property ;
    rdfs:label 'Transfer Cost' ;
    rdfs:comment 'Total logistics cost incurred for executing this stock transfer, including carrier freight charges, handling fees, and any 3PL surcharges. Used for inventory valuation (COGS), P&L allocation, and supply chain cost optimization.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Number' ;
    rdfs:comment 'Externally-known business reference number for the stock transfer, used for tracking and communication across supply chain partners, carriers, and store operations. Sourced from SAP S/4HANA MM transfer order numbering.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferQuantity rdf:type rdf:Property ;
    rdfs:label 'Transfer Quantity' ;
    rdfs:comment 'Number of units of the SKU authorized and dispatched in this stock transfer. Represents the planned transfer quantity as recorded at time of transfer creation.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason Code' ;
    rdfs:comment 'Business reason code explaining why the stock transfer was initiated. REPLENISHMENT: routine inventory restocking; NETWORK_BALANCE: lateral balancing to address overstock/understock; RTV: return to vendor; RECALL: product safety recall per CPSC; DAMAGE_RETURN: return of damaged goods; OMNICHANNEL: ship-from-store or BOPIS fulfillment support.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle state of the stock transfer. DRAFT: initiated but not yet dispatched; IN_TRANSIT: shipment dispatched from source node; RECEIVED: confirmed receipt at destination node; CANCELLED: transfer voided before completion; EXCEPTION: discrepancy or damage reported during transit.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the inter-node inventory movement. DC_TO_STORE: distribution center replenishment to store; STORE_TO_STORE: lateral balancing between stores; STORE_TO_DC: reverse logistics or consolidation; CROSS_DOCK: direct transfer without storage per cross-docking (DSD) model; RTV: Return to Vendor; MFC_TO_STORE: micro-fulfillment center to store for omnichannel fulfillment (ship-from-store).' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Reason code explaining the cause of any quantity variance between dispatched and received units. Used for shrinkage root cause analysis, carrier chargeback (RMA) processing, and inventory reconciliation.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Reference to the specific purchase order line item being received. Enables line-level PO matching, partial receipt tracking, and SKU-level discrepancy analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:vendorPromoAgreementId rdf:type rdf:Property ;
    rdfs:label 'Vendor Promo Agreement Id' ;
    rdfs:comment 'Foreign key linking to promotion.vendor_promo_agreement. Business justification: Vendor promotional agreements specify promotional purchase quantities and delivery obligations. Linking goods receipts to vendor_promo_agreement enables performance obligation tracking, chargeback rec' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorPromoAgreement .

ind:acceptedQty rdf:type rdf:Property ;
    rdfs:label 'Accepted Qty' ;
    rdfs:comment 'Quantity of units accepted into inventory after quality inspection. Excludes rejected, damaged, or wrong-SKU units. This is the quantity inducted into on-hand inventory and used for COGS valuation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackEligible rdf:type rdf:Property ;
    rdfs:label 'Chargeback Eligible' ;
    rdfs:comment 'Indicates whether this goods receipt record has identified discrepancies that qualify for a vendor compliance chargeback. True = chargeback may be issued to supplier; False = no chargeback applicable. Drives the vendor compliance chargeback workflow.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Resolution Status' ;
    rdfs:comment 'Current status of the discrepancy resolution workflow. \'pending\' = discrepancy logged, not yet actioned; \'under_review\' = being investigated with supplier; \'resolved\' = discrepancy closed; \'chargeback_issued\' = vendor compliance chargeback raised; \'waived\' = discrepancy accepted without penalty.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Classification of the primary discrepancy identified during receiving. \'shortage\' = fewer units than expected; \'overage\' = more units than expected; \'wrong_sku\' = incorrect item received; \'damage\' = merchandise physically damaged; \'expired\' = past sell-by or use-by date; \'none\' = no discrepancy. Drives chargeback and resolution workflows.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedQty rdf:type rdf:Property ;
    rdfs:label 'Expected Qty' ;
    rdfs:comment 'Quantity of units expected at the receiving node based on the ASN or replenishment plan. May differ from ordered quantity due to partial shipments or split deliveries. Used for receiving dock planning and discrepancy detection.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'Date on which the quality inspection of received merchandise was completed. Used for compliance reporting, CPSC/FDA audit trails, and receiving cycle time analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderedQty rdf:type rdf:Property ;
    rdfs:label 'Ordered Qty' ;
    rdfs:comment 'Quantity of units originally ordered on the purchase order line. Used as the baseline for receipt variance calculation, fill rate measurement, and vendor compliance scoring.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageQty rdf:type rdf:Property ;
    rdfs:label 'Overage Qty' ;
    rdfs:comment 'Quantity of units received in excess of the ASN or PO expectation (received_qty minus expected_qty when positive). Overages require disposition decisions and may trigger vendor compliance chargebacks.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known purchase order number as referenced on supplier documentation and EDI transactions. Retained for operational readability, vendor communication, and three-way match without requiring a join.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Status of the quality inspection performed on received merchandise. \'not_required\' = inspection waived per supplier agreement; \'pending\' = awaiting inspection; \'passed\' = all units meet quality standards; \'failed\' = units do not meet standards; \'partial_pass\' = some units accepted, some rejected. Drives accepted/rejected quantity split.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Calendar date on which the physical goods receipt was posted. Used for inventory valuation, vendor compliance reporting, and lead time analysis. Aligns with SAP Posting Date (BUDAT) in the MM module.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptMethod rdf:type rdf:Property ;
    rdfs:label 'Receipt Method' ;
    rdfs:comment 'Method by which merchandise was physically received. \'dsd\' = Direct Store Delivery from supplier; \'dc_to_store\' = replenishment from Distribution Center; \'cross_dock\' = direct transfer without storage; \'drop_ship\' = vendor direct-to-customer; \'transfer_order\' = inter-node stock transfer. Drives receiving workflow and inventory valuation logic.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptNotes rdf:type rdf:Property ;
    rdfs:label 'Receipt Notes' ;
    rdfs:comment 'Free-text notes entered by the receiving associate documenting special conditions, discrepancy details, handling instructions, or other observations at the time of receipt. Supports discrepancy investigation and vendor communication.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Externally-known business identifier for the goods receipt document, typically generated by the WMS or ERP upon physical receipt confirmation. Maps to SAP Material Document Number (MBLNR) or Manhattan WMS Receipt Number.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle state of the goods receipt workflow. \'draft\' indicates initiated but not confirmed; \'open\' indicates awaiting physical receipt; \'in_progress\' indicates receiving underway; \'completed\' indicates fully processed and inventory inducted; \'cancelled\' indicates voided; \'on_hold\' indicates paused pending resolution. [ENUM-REF-CANDIDATE: draft|open|in_progress|completed|cancelled|on_hold — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'The principal real-world event timestamp recording when the physical merchandise was received and confirmed at the receiving node (DC, store, or MFC). Distinct from system audit timestamps. Maps to SAP Posting Date/Time in MIGO.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivedQty rdf:type rdf:Property ;
    rdfs:label 'Received Qty' ;
    rdfs:comment 'Total quantity of units physically counted and received at the dock, prior to quality inspection. Includes all units regardless of condition. Used as the gross receipt quantity for inventory induction and discrepancy calculation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingNodeType rdf:type rdf:Property ;
    rdfs:label 'Receiving Node Type' ;
    rdfs:comment 'Classification of the physical location type where goods were received. \'dc\' = Distribution Center; \'store\' = retail store; \'mfc\' = Micro-Fulfillment Center; \'dark_store\' = fulfillment-only location. Determines applicable receiving workflows and inventory induction rules.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedQty rdf:type rdf:Property ;
    rdfs:label 'Rejected Qty' ;
    rdfs:comment 'Quantity of units rejected during quality inspection and not inducted into inventory. Drives Return to Vendor (RTV) processing, vendor compliance chargebacks, and RMA initiation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfidVerified rdf:type rdf:Property ;
    rdfs:label 'Rfid Verified' ;
    rdfs:comment 'Indicates whether the received merchandise was verified using RFID (Radio Frequency Identification) scanning during the receiving process. True = RFID scan confirmed; False = manual or barcode-only verification. Supports inventory accuracy at point of induction.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rtvInitiated rdf:type rdf:Property ;
    rdfs:label 'Rtv Initiated' ;
    rdfs:comment 'Indicates whether a Return to Vendor (RTV) process has been initiated for rejected units from this goods receipt. True = RTV in progress; False = no RTV initiated. Supports reverse logistics and vendor debit memo processing.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortageQty rdf:type rdf:Property ;
    rdfs:label 'Shortage Qty' ;
    rdfs:comment 'Quantity of units short-shipped relative to the ASN or PO expectation (expected_qty minus received_qty when negative). Used for vendor compliance chargeback calculation and fill rate reporting.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReceiptCost rdf:type rdf:Property ;
    rdfs:label 'Total Receipt Cost' ;
    rdfs:comment 'Total cost of accepted merchandise received (accepted_qty × unit_cost). Used for inventory valuation, COGS posting, and financial reconciliation. Classified as confidential due to commercial sensitivity.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservationId rdf:type rdf:Property ;
    rdfs:label 'Reservation Id' ;
    rdfs:comment 'Unique system-generated identifier for each inventory reservation or hold record. Primary key for the reservation data product.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bopisAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Bopis Appointment Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.bopis_appointment. Business justification: BOPIS reservations must be linked to their pickup appointment for SLA tracking, inventory hold expiry management, and customer notification workflows. Retail omnichannel operations require knowing whi' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BopisAppointment .

ind:cartId rdf:type rdf:Property ;
    rdfs:label 'Cart Id' ;
    rdfs:comment 'Foreign key linking to ecommerce.cart. Business justification: Inventory reservations are created from cart items during checkout to hold stock. Tracks cart-to-reservation lifecycle for abandoned cart inventory release and reservation expiry management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cart .

ind:checkoutId rdf:type rdf:Property ;
    rdfs:label 'Checkout Id' ;
    rdfs:comment 'Foreign key linking to ecommerce.checkout. Business justification: Reservations are created during checkout to hold inventory during payment authorization. Links reservation lifecycle to checkout session for payment-hold-release coordination and checkout abandonment ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Checkout .

ind:corporateAccountId rdf:type rdf:Property ;
    rdfs:label 'Corporate Account Id' ;
    rdfs:comment 'Foreign key linking to customer.corporate_account. Business justification: B2B bulk inventory reservation process: corporate accounts reserve large quantities of inventory for business purchases (e.g., corporate gifting, bulk procurement events). This is a distinct operation' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateAccount .

ind:headerId rdf:type rdf:Property ;
    rdfs:label 'Header Id' ;
    rdfs:comment 'Reference to the customer order (OMS order) that triggered this inventory reservation. Populated for BOPIS, ROPIS, ship-from-store, and e-commerce hold encumbrances. Null for non-order-driven holds (quality, legal, regulatory). Links reservation to the order fulfillment lifecycle.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:profileId rdf:type rdf:Property ;
    rdfs:label 'Profile Id' ;
    rdfs:comment 'Foreign key linking to customer.profile. Business justification: Retail omnichannel fulfillment (BOPIS, ship-from-store, curbside pickup) requires tracking which customer profile created each inventory reservation. Essential for customer service, order fulfillment,' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:authorizingDepartment rdf:type rdf:Property ;
    rdfs:label 'Authorizing Department' ;
    rdfs:comment 'Name or code of the business department that authorized the hold (e.g., Quality Assurance, Legal, Compliance, Store Operations, E-Commerce Fulfillment). Supports departmental accountability reporting and hold resolution workflows.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Case Reference Number' ;
    rdfs:comment 'Reference to the service case, quality investigation, legal matter, or regulatory recall case that authorized a hard hold. Populated for quality_hold, legal_hold, regulatory_recall, and damage_hold encumbrance types. Links to Salesforce Service Cloud case management.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:encumbranceType rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Type' ;
    rdfs:comment 'Classifies the nature of the inventory encumbrance. Soft allocations (e.g., BOPIS reservation, ship-from-store allocation, e-commerce hold) are temporary and customer-driven; hard holds (quality hold, regulatory recall, legal hold, damage hold, price investigation) restrict stock from sale pending resolution. [ENUM-REF-CANDIDATE: soft_allocation|hard_hold|quality_hold|regulatory_recall|legal_hold|damage_hold|price_investigation — promote to reference product]' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'Date and time at which the reservation automatically expires if not fulfilled or manually extended. Critical for BOPIS and e-commerce holds where stock must be released back to general availability after a defined window (e.g., 24–48 hours). Null for indefinite holds such as legal or regulatory holds.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Standardized code identifying the specific business reason for the reservation or hold (e.g., BOPIS_ALLOC, SFS_ALLOC, ECOM_HOLD, QA_FAIL, RECALL_CPSC, LEGAL_HOLD, DMG_INBOUND, PRICE_INVEST). Enables operational reporting and root-cause analysis of inventory encumbrances.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Description' ;
    rdfs:comment 'Free-text narrative describing the specific reason for the inventory hold or reservation, providing operational context beyond the structured hold_reason_code. Required for legal holds and regulatory recalls per compliance documentation standards.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecalled rdf:type rdf:Property ;
    rdfs:label 'Is Recalled' ;
    rdfs:comment 'Indicates whether this reservation was created in response to a regulatory product recall (CPSC, FDA, or other governing body). When true, the hold cannot be released without explicit compliance authorization. Supports mandatory recall reporting and quarantine workflows.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseNotes rdf:type rdf:Property ;
    rdfs:label 'Release Notes' ;
    rdfs:comment 'Free-text field capturing resolution details, disposition instructions, or compliance notes recorded at the time of hold release. Required for regulatory recalls and legal holds to document the resolution rationale for audit purposes.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Approval workflow status for releasing a hard hold. \'pending\' — release request submitted awaiting authorization; \'approved\' — release authorized by responsible department; \'rejected\' — release denied, hold remains active; \'auto_released\' — system-triggered release upon expiry or order fulfillment; \'escalated\' — requires senior authorization.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Actual date and time when the reservation was released, cancelled, or converted. Null while the reservation is active. Used for hold duration analysis, SLA compliance reporting, and ATP recalculation upon release.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Externally-visible, human-readable business identifier for the reservation, used in operational communications, order management, and customer-facing references (e.g., BOPIS confirmation codes). Sourced from OMS or WMS upon creation.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationStatus rdf:type rdf:Property ;
    rdfs:label 'Reservation Status' ;
    rdfs:comment 'Current lifecycle state of the inventory reservation. \'active\' — stock is currently encumbered; \'expired\' — reservation lapsed past expiry without fulfillment; \'released\' — hold manually or systematically lifted; \'cancelled\' — reservation voided before fulfillment; \'pending_release\' — awaiting authorization to release; \'converted\' — soft allocation fulfilled and converted to a shipment.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reservation Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) when the inventory encumbrance was created — the principal business event timestamp. For BOPIS/e-commerce holds, this is when the customer completed checkout. For quality/legal holds, this is when the hold was authorized.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Number of units of the SKU encumbered by this reservation. Subtracted from on-hand quantity to derive ATP (Available to Promise) on the stock_position product. Must be positive and not exceed available on-hand at time of reservation creation.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clusterId rdf:type rdf:Property ;
    rdfs:label 'Cluster Id' ;
    rdfs:comment 'Foreign key linking to store.cluster. Business justification: Retail replenishment policies are commonly defined at the store cluster level (e.g., all high-volume urban stores share a reorder policy). Cluster-based replenishment policy assignment is a named reta' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cluster .

ind:itemHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Item Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to product.item_hierarchy. Business justification: Retail replenishment planning sets policies at category/hierarchy level (item_hierarchy.replenishment_method, safety_stock_weeks). A reorder_policy can govern all SKUs in a hierarchy node, enabling ca' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItemHierarchy .

ind:promoCalendarId rdf:type rdf:Property ;
    rdfs:label 'Promo Calendar Id' ;
    rdfs:comment 'Foreign key linking to promotion.promo_calendar. Business justification: Reorder policies are adjusted for promotional periods defined in the promo_calendar (safety stock uplift, lead time compression). Linking reorder_policy to promo_calendar enables promotional replenish' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCalendar .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee identifier of the replenishment planner or manager who approved this reorder policy for activation. Supports governance, audit trail, and accountability for policy parameters.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The calendar date from which this reorder policy becomes active and the replenishment engine begins applying its parameters. Supports time-bound policy management and seasonal policy transitions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAutoReplenishment rdf:type rdf:Property ;
    rdfs:label 'Is Auto Replenishment' ;
    rdfs:comment 'Indicates whether replenishment orders are automatically generated and submitted when the reorder trigger is breached (True), or whether a replenishment planner must manually review and approve the suggested order (False).' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeasonal rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal' ;
    rdfs:comment 'Indicates whether this reorder policy applies seasonal adjustments to replenishment parameters (e.g., elevated safety stock or WOS targets during peak seasons). When True, seasonal override parameters may be applied by the replenishment engine.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'The most recent date on which a replenishment planner reviewed and validated the parameters of this reorder policy. Supports governance and audit of policy maintenance cadence.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Max Stock Quantity' ;
    rdfs:comment 'The maximum allowable on-hand inventory level (in units) for this SKU at this location. Used in min/max reorder method as the upper bound. Replenishment orders are sized to bring stock up to this level without exceeding it.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Stock Quantity' ;
    rdfs:comment 'The minimum allowable on-hand inventory level (in units) for this SKU at this location. Used in min/max reorder method as the lower bound. Stock falling below this level triggers an urgent replenishment order.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'The scheduled date for the next planner review of this reorder policy\'s parameters. Calculated from last_reviewed_date plus the review_cycle_days. Drives planner workqueue prioritization.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderMultiple rdf:type rdf:Property ;
    rdfs:label 'Order Multiple' ;
    rdfs:comment 'The quantity increment in which orders must be placed, reflecting the supplier\'s case pack size or Minimum Order Quantity (MOQ). All replenishment order quantities are rounded up to the nearest multiple of this value to comply with supplier constraints.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Quantity' ;
    rdfs:comment 'The fixed quantity (in units) to order each time a replenishment trigger is activated. Used for fixed_quantity reorder method. For other methods, this field may be null and the order quantity is dynamically calculated.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Business-facing unique alphanumeric code identifying the reorder policy, used by replenishment planners and referenced in automated replenishment engines (e.g., Blue Yonder). Externally visible identifier across systems.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable descriptive name for the reorder policy, used by replenishment planners to identify and manage policies (e.g., \'DC Grocery Min/Max Weekly\', \'Store Electronics WOS-Based\').' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle state of the reorder policy. Controls whether the policy is actively used by the replenishment engine to generate inventory_replenishment_order records. [ENUM-REF-CANDIDATE: active|inactive|draft|pending_approval|expired|suspended — promote to reference product]' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyVersion rdf:type rdf:Property ;
    rdfs:label 'Policy Version' ;
    rdfs:comment 'Incrementing version number for this reorder policy record, incremented each time parameters are materially changed. Supports policy change history tracking and rollback capability for replenishment planners.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reorderMethod rdf:type rdf:Property ;
    rdfs:label 'Reorder Method' ;
    rdfs:comment 'The replenishment calculation method applied by this policy: min_max (reorder when stock falls below minimum, order up to maximum), days_of_supply (maintain a target number of days of inventory), wos_based (Weeks of Supply (WOS) target), forecast_driven (demand forecast from Blue Yonder), fixed_quantity (constant order quantity), vendor_managed (VMI — Vendor Managed Inventory where supplier controls replenishment). [ENUM-REF-CANDIDATE: min_max|days_of_supply|wos_based|forecast_driven|fixed_quantity|vendor_managed — promote to reference product]' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'The on-hand stock level (in units) at which a replenishment order is automatically triggered. When the stock_position in inventory falls at or below this threshold, an inventory_replenishment_order record is generated. Core parameter for min/max and fixed-quantity reorder methods.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewCycleDays rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Days' ;
    rdfs:comment 'The frequency in calendar days at which the replenishment engine evaluates this policy and checks whether a reorder trigger has been breached. Defines the periodic review interval (e.g., daily=1, weekly=7, bi-weekly=14).' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'Buffer stock quantity (in units) maintained above the reorder point to protect against demand variability and supply lead time uncertainty. Prevents stockouts during replenishment cycles. A key input to the reorder point calculation.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetDaysOfSupply rdf:type rdf:Property ;
    rdfs:label 'Target Days Of Supply' ;
    rdfs:comment 'The desired number of days of inventory coverage to maintain at this location for this SKU. Used in days_of_supply reorder method to calculate the replenishment order quantity based on forecasted daily demand.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetWos rdf:type rdf:Property ;
    rdfs:label 'Target Wos' ;
    rdfs:comment 'The desired number of weeks of inventory coverage (Weeks of Supply — WOS) to maintain at this location for this SKU. Used in wos_based reorder method. Replenishment orders are sized to achieve this WOS target based on forecasted weekly demand.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gtinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Gtin Registry Id' ;
    rdfs:comment 'Foreign key linking to product.gtin_registry. Business justification: lot.gtin is a denormalized text field. Lot traceability for recall management (lot.is_recalled, recall_reference_number) requires linking to the authoritative product.gtin_registry for GTIN validation' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GtinRegistry .

ind:parentLotId rdf:type rdf:Property ;
    rdfs:label 'Parent Lot Id' ;
    rdfs:comment 'Self-referencing FK on lot (parent_lot_id)' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Current quantity available for sale or allocation from this lot. Decreases as units are sold or reserved.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bestBeforeDate rdf:type rdf:Property ;
    rdfs:label 'Best Before Date' ;
    rdfs:comment 'Date indicating optimal quality period. Product may still be safe after this date but quality may degrade. Distinct from expiry date.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationCode rdf:type rdf:Property ;
    rdfs:label 'Certification Code' ;
    rdfs:comment 'Product certification or compliance code for the lot. Examples: organic, kosher, halal, fair trade, non-GMO. Supports labeling and marketing claims.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO country code indicating where the product was manufactured or grown. Required for customs and labeling compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoSequence rdf:type rdf:Property ;
    rdfs:label 'Fefo Sequence' ;
    rdfs:comment 'Sequence number for FEFO picking logic. Lower numbers indicate earlier expiry and should be picked first to minimize waste.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Detailed outcome or notes from the quality inspection process. Captures defects, non-conformances, or approval notes.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrivateLabel rdf:type rdf:Property ;
    rdfs:label 'Is Private Label' ;
    rdfs:comment 'Indicates whether this lot is a private label or store brand product. True if private label; false if national brand.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Business identifier for the lot or batch. Human-readable code used for tracking and traceability across the supply chain.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current lifecycle status of the lot. Determines whether the lot is available for sale, held for quality inspection, or restricted. [ENUM-REF-CANDIDATE: available|quarantine|hold|released|expired|recalled|disposed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date when the product lot was manufactured or produced. Critical for shelf life calculation and food safety compliance.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'Quality inspection outcome for the lot. Approved lots are available for sale; rejected lots must be returned or disposed.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Total quantity of units in the lot at receipt. Used for inventory valuation and traceability reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Reference Number' ;
    rdfs:comment 'Official recall case or reference number issued by regulatory authority or manufacturer. Links to recall management system.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Remaining Shelf Life Days' ;
    rdfs:comment 'Number of days remaining until expiry as of the current date. Calculated field used for near-expiry alerts and markdown triggers.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Total shelf life of the product in days from manufacture date to expiry date. Used for aging analysis and markdown planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierLotReference rdf:type rdf:Property ;
    rdfs:label 'Supplier Lot Reference' ;
    rdfs:comment 'Supplier\'s original lot or batch identifier. Used for traceability back to the supplier\'s manufacturing records.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdId rdf:type rdf:Property ;
    rdfs:label 'Household Id' ;
    rdfs:comment 'Identifier linking this customer to a household group for family-level analytics and shared loyalty benefits.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'The channel through which the customer was originally acquired, used for CAC (Customer Acquisition Cost) analysis and channel effectiveness measurement.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date when the customer first engaged with the business, marking the start of the customer lifecycle.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerRole rdf:type rdf:Property ;
    rdfs:label 'Customer Role' ;
    rdfs:comment 'Business relationship role the customer plays. Allowed values: consumer, employee, wholesale_buyer, corporate' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth of the customer, used for age verification, lifecycle marketing, and personalized birthday promotions.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'End date of this record version in the SCD Type-2 history; NULL or 9999-12-31 indicates the current active version.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Start date of this record version in the SCD Type-2 history; the date from which this version of the record is considered active.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for customer communication across all channels including e-commerce, loyalty programs, and promotional campaigns.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Legal entity classification of the customer. Allowed values: individual, organization' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Legal first name or given name of the customer as recorded in the master data management system.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete legal name of the customer, typically concatenated from first, middle, and last name components.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Self-identified gender of the customer, used for personalized merchandising and assortment planning.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Current' ;
    rdfs:comment 'Flag indicating this is the current active version of the profile record.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCurrentFlag rdf:type rdf:Property ;
    rdfs:label 'Is Current Flag' ;
    rdfs:comment 'Indicates whether this is the currently active version of the record in the SCD Type-2 history.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Legal last name or family name of the customer as recorded in the master data management system.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage in the customer lifecycle journey, used for targeted marketing campaigns and retention strategies. [ENUM-REF-CANDIDATE: prospect|new|active|at_risk|dormant|churned|reactivated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyTier rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier' ;
    rdfs:comment 'Current tier level in the loyalty program, determining benefits, discounts, and personalized services.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the household has opted in to receive marketing communications.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdmConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Mdm Confidence Score' ;
    rdfs:comment 'Confidence score (0-100) from the customer master data system indicating the quality and reliability of the golden record match and data completeness.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mdmLastMatchDate rdf:type rdf:Property ;
    rdfs:label 'Mdm Last Match Date' ;
    rdfs:comment 'Timestamp of the last MDM matching and survivorship process execution that updated this golden record.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mdmSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Mdm Source System' ;
    rdfs:comment 'Name of the primary source system that contributed the authoritative data for this golden record (e.g., the retail analytics platform, the e-commerce platform, POS).' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the customer. Nullable field for customers without a middle name.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile phone number used for SMS notifications, mobile app authentication, and last-mile delivery coordination.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the customer\'s nationality or citizenship.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Channel' ;
    rdfs:comment 'Preferred shopping channel for the household (e.g. in_store, online, omnichannel).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Customer\'s preferred method for receiving communications and notifications from the business.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-2 three-letter language code representing the customer\'s preferred language for communication and marketing materials.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current operational status of the customer profile, controlling access to services and transactions across all channels.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Monotonically increasing version number for this record in the SCD Type-2 history.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scdChangeReason rdf:type rdf:Property ;
    rdfs:label 'Scd Change Reason' ;
    rdfs:comment 'Business reason for the change that created this version, supporting GDPR audit trail requirements.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scdChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scd Change Timestamp' ;
    rdfs:comment 'Exact timestamp when this SCD Type-2 version was created, used for change-data-capture reconciliation and GDPR audit trails.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scdChangedBy rdf:type rdf:Property ;
    rdfs:label 'Scd Changed By' ;
    rdfs:comment 'Identifier of the user or system process that triggered this SCD Type-2 version change, supporting GDPR accountability requirements.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version identifier for SCD Type-2 tracking of this record.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Unique identifier for the account. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:billingAddressId rdf:type rdf:Property ;
    rdfs:label 'Billing Address Id' ;
    rdfs:comment 'Reference to the default billing address for this account. Used for invoicing, credit checks, and payment processing. Null if no billing address on file.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:defaultPaymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Default Payment Method Id' ;
    rdfs:comment 'Reference to the customer\'s default payment method for this account (e.g., credit card on file, bank account). Null if no default set. Used for one-click checkout and recurring billing.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:priceListId rdf:type rdf:Property ;
    rdfs:label 'Price List Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_list. Business justification: Retail B2B accounts with contract_pricing_flag, employee_discount_eligible, or loyalty_program_enrolled are assigned specific price lists. Pricing teams and POS systems resolve the correct price list ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:salesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Id' ;
    rdfs:comment 'Foreign key linking to store.sales_territory. Business justification: B2B sales territory management assigns customer accounts to territories for sales rep coverage, quota tracking, and revenue reporting. sales_territory.customer_count implies accounts are territory-sco' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTerritory .

ind:shippingAddressId rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Id' ;
    rdfs:comment 'Reference to the default shipping address for this account. Used for order fulfillment and delivery. Null if no default shipping address set.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-visible unique account number used for customer communication, statements, and customer service lookup. Distinct from internal account_id.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current status of the B2B account: active, suspended, closed, pending_approval. Only active accounts may place wholesale orders.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Type of business account. Values: corporate, wholesale, franchise, reseller.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:b2bPricingFlag rdf:type rdf:Property ;
    rdfs:label 'B2b Pricing Flag' ;
    rdfs:comment 'Always TRUE for account records since accounts exist only for B2B relationships. Retained for backward compatibility with legacy integrations.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'Legal company or organization name for B2B/wholesale accounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum credit extended to this B2B account for net-terms purchasing. NULL for prepay-only accounts.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeeDiscountEligible rdf:type rdf:Property ;
    rdfs:label 'Employee Discount Eligible' ;
    rdfs:comment 'Indicates whether this account is eligible for employee discount pricing. True for employee accounts and authorized family members; false otherwise.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyProgramEnrolled rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Enrolled' ;
    rdfs:comment 'Indicates whether this account is enrolled in the retailer\'s loyalty or rewards program. True if enrolled; false otherwise. Used for loyalty analytics and targeted promotions.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date when the account was most recently suspended. Null if never suspended or currently active. Used for compliance and risk management reporting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Free-text explanation of why the account was suspended (e.g., payment default, fraud investigation, customer request, policy violation). Null if never suspended.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Certificate Number' ;
    rdfs:comment 'Government-issued tax exemption certificate number for tax-exempt accounts. Null for non-exempt accounts. Required for audit and compliance verification.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxExemptExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Expiry Date' ;
    rdfs:comment 'Expiration date of the tax exemption certificate. Null for non-exempt accounts or perpetual exemptions. Used for compliance monitoring and renewal reminders.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether this account is exempt from sales tax (e.g., non-profit organizations, government entities, resellers with valid tax exemption certificates). True if exempt; false otherwise.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageBasketValue rdf:type rdf:Property ;
    rdfs:label 'Average Basket Value' ;
    rdfs:comment 'Average transaction basket value across all household members.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:combinedCltv rdf:type rdf:Property ;
    rdfs:label 'Combined Cltv' ;
    rdfs:comment 'Combined customer lifetime value estimate aggregated across all household members.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'Preferred communication channel for household-level outreach (e.g. email, mail, phone, sms).' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the household has consented to data sharing for analytics purposes.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedIncomeBand rdf:type rdf:Property ;
    rdfs:label 'Estimated Income Band' ;
    rdfs:comment 'Estimated household income bracket used for segmentation (e.g. low, medium, high, affluent).' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalHouseholdCode rdf:type rdf:Property ;
    rdfs:label 'External Household Code' ;
    rdfs:comment 'Identifier for this household in an external system or third-party data provider.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdStatus rdf:type rdf:Property ;
    rdfs:label 'Household Status' ;
    rdfs:comment 'Current lifecycle status of the household record (e.g. active, inactive, merged, dissolved).' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdType rdf:type rdf:Property ;
    rdfs:label 'Household Type' ;
    rdfs:comment 'Classification of the household (e.g. single, family, multi-generational, shared).' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'Most recent purchase date across all household members.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'Display name or surname associated with the household grouping.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'Primary language spoken in the household, used for communication preferences.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Marketing or behavioral segment classification assigned to this household.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Number of individuals (customer profiles) associated with this household.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLoyaltyPoints rdf:type rdf:Property ;
    rdfs:label 'Total Loyalty Points' ;
    rdfs:comment 'Aggregate loyalty points balance across all household members.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPurchaseCount rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Count' ;
    rdfs:comment 'Total number of purchases made by all household members combined.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Total Spend Amount' ;
    rdfs:comment 'Total monetary spend across all household members over the lifetime of the household.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Id' ;
    rdfs:comment 'Reference to the parent corporate account if this account is part of a multi-location or subsidiary hierarchy. Null for standalone accounts or top-level parent accounts. Enables consolidated billing and enterprise-wide reporting.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primaryContactId rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Corporate accounts have a designated primary contact person. Currently, corporate_account stores primary_contact_name, primary_contact_email, primary_contact_phone as denormalized columns. Adding prim' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:accountEstablishedDate rdf:type rdf:Property ;
    rdfs:label 'Account Established Date' ;
    rdfs:comment 'Date when the corporate account was first created in the system. Used to calculate customer tenure and lifetime value metrics.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualSpendTier rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Tier' ;
    rdfs:comment 'Classification of the corporate account based on annual purchase volume. Used to determine discount levels, service priority, and account management resources. Tier_1 = highest spend (>$1M), Tier_5 = lowest spend (<$10K). Tiers recalculated annually.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessEntityType rdf:type rdf:Property ;
    rdfs:label 'Business Entity Type' ;
    rdfs:comment 'Legal structure of the corporate entity. Values: sole_proprietorship, partnership, llc (Limited Liability Company), corporation (C-Corp), s_corp (S-Corporation), non_profit (501c3 or similar), government (public sector entity). [ENUM-REF-CANDIDATE: sole_proprietorship|partnership|llc|corporation|s_corp|non_profit|government — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractPricingFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Pricing Flag' ;
    rdfs:comment 'Indicates whether the corporate account has negotiated contract pricing that overrides standard catalog prices. True = custom pricing agreement in place; False = standard pricing applies.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'Current credit approval status for the corporate account. Determines whether the customer can purchase on credit terms. Values: approved (credit line active), pending (application submitted), declined (credit denied), under_review (periodic credit review in progress), suspended (credit privileges temporarily revoked).' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'Trade name or fictitious business name under which the corporate customer operates, if different from legal name. Used for marketing and customer-facing communications.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit unique identifier assigned by Dun & Bradstreet to establish business credit profile and track commercial credit history. Used for supplier onboarding and credit evaluation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryClassificationNaics rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Naics' ;
    rdfs:comment 'Six-digit code classifying the corporate customer\'s primary industry using the NAICS standard. Provides more granular industry segmentation than SIC for modern business categories.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryClassificationSic rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Sic' ;
    rdfs:comment 'Four-digit code classifying the corporate customer\'s primary industry sector using the U.S. Standard Industrial Classification system. Used for market segmentation and industry analysis.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'Date of the most recent purchase order placed by this corporate account. Used for recency analysis and dormant account identification.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalBusinessName rdf:type rdf:Property ;
    rdfs:label 'Legal Business Name' ;
    rdfs:comment 'The official registered legal name of the corporate entity as it appears on government filings and tax documents. Used for contracts, invoicing, and legal compliance.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Standard payment terms negotiated with the corporate customer. Values: net_30 (payment due 30 days after invoice), net_45, net_60, net_90, due_on_receipt (immediate payment), prepay (payment before shipment), custom (non-standard terms documented separately). [ENUM-REF-CANDIDATE: net_30|net_45|net_60|net_90|due_on_receipt|prepay|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Delivery Method' ;
    rdfs:comment 'Default shipping method preference for corporate orders. Values: standard_ground, expedited, next_day, freight (for large/bulk orders), customer_pickup (will-call).' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Federal tax identification number (EIN) assigned by the IRS for business tax reporting and compliance. Format: XX-XXXXXXX.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Unique identifier for the contact method record. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:bounceCount rdf:type rdf:Property ;
    rdfs:label 'Bounce Count' ;
    rdfs:comment 'The cumulative number of times communication attempts via this contact method have bounced or failed. Used to trigger contact validation workflows and suppress invalid addresses.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentSource rdf:type rdf:Property ;
    rdfs:label 'Consent Source' ;
    rdfs:comment 'The channel or touchpoint where the customer provided consent for this contact method (e.g., web registration, mobile app, POS, call center, in-store signup). Supports consent audit trails. [ENUM-REF-CANDIDATE: web|mobile_app|pos|call_center|email|in_store|third_party — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact method. Active indicates usable for communication; bounced/invalid indicates delivery failure; suppressed indicates customer request or compliance block; pending_verification indicates awaiting confirmation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'The type or category of contact method (e.g., primary email, mobile phone, work phone, WhatsApp, SMS, fax). Determines the channel and priority for omnichannel outreach. [ENUM-REF-CANDIDATE: primary_email|secondary_email|mobile|home_phone|work_phone|whatsapp|sms|fax — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary contact method for the customer. Used to prioritize communication channels in omnichannel campaigns and clienteling.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Boolean flag indicating whether the contact method has been verified (e.g., email verification link clicked, phone number confirmed via OTP). Ensures data quality for marketing and transactional communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the customers preferred language for communications via this contact method (e.g., en, es, fr). Supports personalized omnichannel outreach.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastBounceDate rdf:type rdf:Property ;
    rdfs:label 'Last Bounce Date' ;
    rdfs:comment 'The date of the most recent bounce or delivery failure for this contact method. Nullable if no bounces have occurred.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The timestamp when this contact method record was last updated. Supports change tracking and audit trails.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'The date when this contact method was last successfully used for customer communication (email sent, SMS delivered, call completed). Helps identify stale or inactive contact points.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric ranking indicating the priority order of this contact method relative to other contact methods for the same customer. Lower numbers indicate higher priority. Used for fallback logic in omnichannel campaigns.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:value rdf:type rdf:Property ;
    rdfs:label 'Value' ;
    rdfs:comment 'The actual contact value (email address, phone number, social handle, etc.).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date when the contact method was last verified by the customer. Used to track data freshness and trigger re-verification workflows.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Unique identifier for the address record. Primary key.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active addresses are available for use in orders and shipments.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the address purpose: billing, shipping, store pickup (BOPIS/ROPIS), home, work, or mailing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Special delivery instructions provided by the customer (e.g., gate code, leave at door, ring bell).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPointBarcode rdf:type rdf:Property ;
    rdfs:label 'Delivery Point Barcode' ;
    rdfs:comment 'USPS Delivery Point Barcode (DPBC) or equivalent postal barcode for automated mail sorting and delivery.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultBilling rdf:type rdf:Property ;
    rdfs:label 'Is Default Billing' ;
    rdfs:comment 'Flag indicating whether this address is the default billing address for the customer.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultShipping rdf:type rdf:Property ;
    rdfs:label 'Is Default Shipping' ;
    rdfs:comment 'Flag indicating whether this address is the default shipping destination for the customer.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including street number, street name, and unit/apartment number.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for additional location details such as building name, floor, suite, or department.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:militaryAddressFlag rdf:type rdf:Property ;
    rdfs:label 'Military Address Flag' ;
    rdfs:comment 'Indicates whether the address is a military address (APO/FPO/DPO). Requires special handling for international military mail.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nickname rdf:type rdf:Property ;
    rdfs:label 'Nickname' ;
    rdfs:comment 'Customer-provided friendly name for the address (e.g., Home, Office, Mom\'s House) for easy identification.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poBoxFlag rdf:type rdf:Property ;
    rdfs:label 'Po Box Flag' ;
    rdfs:comment 'Indicates whether the address is a PO Box. Some carriers and products cannot deliver to PO Boxes.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residentialFlag rdf:type rdf:Property ;
    rdfs:label 'Residential Flag' ;
    rdfs:comment 'Indicates whether the address is a residential location (true) or commercial/business location (false). Impacts shipping rates and delivery windows.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardizationFlag rdf:type rdf:Property ;
    rdfs:label 'Standardization Flag' ;
    rdfs:comment 'Indicates whether the address has been standardized to postal service formatting rules (USPS Publication 28, etc.).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction identifier derived from the address, used to determine applicable sales tax rates and rules.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Status of address validation against postal service standards (USPS, Canada Post, etc.). Validated addresses reduce delivery failures.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Timestamp when the address was last verified against postal service databases or address validation services.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Primary key for segment' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:autoRefreshFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Refresh Flag' ;
    rdfs:comment 'Indicates whether customer membership in this segment is automatically recalculated on a scheduled basis (True) or manually managed (False). True for dynamic segments (e.g., RFM tiers recalculated nightly); False for static segments (e.g., one-time campaign lists).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageAov rdf:type rdf:Property ;
    rdfs:label 'Average Aov' ;
    rdfs:comment 'Mean Average Order Value for customers in this segment over the measurement period. Key metric for pricing strategy, promotion design, and basket optimization. Expressed in base currency (USD).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageCltv rdf:type rdf:Property ;
    rdfs:label 'Average Cltv' ;
    rdfs:comment 'Mean Customer Lifetime Value across all customers currently assigned to this segment. Used for segment valuation, investment prioritization, and ROI forecasting. Expressed in base currency (USD).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averagePurchaseFrequency rdf:type rdf:Property ;
    rdfs:label 'Average Purchase Frequency' ;
    rdfs:comment 'Mean number of transactions per customer in this segment over the measurement period (typically 12 months). Used for replenishment forecasting, loyalty program design, and churn prediction.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgBasketSize rdf:type rdf:Property ;
    rdfs:label 'Avg Basket Size' ;
    rdfs:comment 'Average basket size for the segment in the customer domain (avg basket size).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avgTransactionValue rdf:type rdf:Property ;
    rdfs:label 'Avg Transaction Value' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:b2bB2cIndicator rdf:type rdf:Property ;
    rdfs:label 'B2b B2c Indicator' ;
    rdfs:comment 'Indicates whether this segment applies to B2B customers (business accounts, wholesale, corporate), B2C customers (individual consumers), or both. Drives differentiated engagement strategies, pricing models, and service levels.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaOptOutHonoredFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Honored Flag' ;
    rdfs:comment 'Indicates whether this segment respects CCPA \'Do Not Sell My Personal Information\' opt-out requests (True) or is exempt (False, e.g., service-related communications). Ensures compliance for California residents.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:churnRiskScore rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Score' ;
    rdfs:comment 'Aggregate churn risk score for this segment, ranging from 0.00 (no risk) to 100.00 (high risk). Calculated from recency, frequency, and engagement metrics. Drives retention campaign prioritization and at-risk customer interventions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:code rdf:type rdf:Property ;
    rdfs:label 'Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the segment for operational use (e.g., VIP_GOLD, LAPSED_90D, HIGH_VALUE_B2B). Used in marketing campaigns, pricing rules, and POS systems.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed narrative describing the segment\'s defining characteristics, business rationale, and strategic purpose. Includes target customer profile, expected behaviors, and recommended engagement strategies.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountSensitivity rdf:type rdf:Property ;
    rdfs:label 'Discount Sensitivity' ;
    rdfs:comment 'Behavioral classification of segment\'s responsiveness to promotional pricing. High: primarily purchases on promotion (Hi-Lo shoppers). Medium: balanced full-price and promotional purchases. Low: primarily full-price purchases (EDLP preference or premium segment).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Required Flag' ;
    rdfs:comment 'Indicates whether explicit customer consent is required under GDPR for marketing communications to this segment (True) or whether legitimate interest or other legal basis applies (False). Ensures regulatory compliance for EU customers.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Geographic boundary or region to which this segment applies (e.g., \'USA\', \'Northeast Region\', \'Urban Markets\', \'Global\'). Supports localized segmentation strategies and regional campaign targeting. Use ISO 3166-1 alpha-3 country codes where applicable.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'Date and time when segment membership was last recalculated and customer assignments were updated. Critical for data freshness validation and SLA monitoring.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxRfmScore rdf:type rdf:Property ;
    rdfs:label 'Max Rfm Score' ;
    rdfs:comment 'Maximum RFM composite score for customer assignment to this segment (if segment_type is rfm_tier). Defines the upper bound of the RFM tier. Null for non-RFM segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:membershipCount rdf:type rdf:Property ;
    rdfs:label 'Membership Count' ;
    rdfs:comment 'Current count of customers assigned to this segment. Updated periodically based on auto-refresh schedule. Used for segment sizing, campaign planning, and capacity forecasting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minRfmScore rdf:type rdf:Property ;
    rdfs:label 'Min Rfm Score' ;
    rdfs:comment 'Minimum RFM composite score required for customer assignment to this segment (if segment_type is rfm_tier). RFM scores typically range from 3 (lowest: 1-1-1) to 15 (highest: 5-5-5). Null for non-RFM segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Average Net Promoter Score for customers in this segment, ranging from -100.00 (all detractors) to +100.00 (all promoters). Measures customer satisfaction, loyalty, and likelihood to recommend. Used for segment health monitoring and experience improvement prioritization.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:owningBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Owning Business Unit' ;
    rdfs:comment 'Name of the business unit or department responsible for defining, maintaining, and governing this segment (e.g., \'Marketing Analytics\', \'Customer Insights\', \'Loyalty Program Management\'). Establishes accountability for segment quality and usage.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Service and engagement priority level assigned to this segment. Platinum: highest CLTV, white-glove service. Gold: high-value, priority support. Silver: mid-value, standard service. Bronze: emerging value. Standard: baseline service. Drives clienteling strategies and resource allocation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCriteria rdf:type rdf:Property ;
    rdfs:label 'Qualification Criteria' ;
    rdfs:comment 'Summary of the business rules and thresholds used to assign customers to this segment (e.g., \'Purchased in last 30 days AND total spend > $5000 in last 12 months\', \'RFM Score >= 9\', \'Age 25-34 AND lives in urban area\'). Human-readable representation of the segmentation logic.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'Cadence at which segment membership is recalculated for auto-refresh segments. Daily: high-velocity behavioral segments. Weekly: standard RFM tiers. Monthly: demographic or lifecycle segments. Quarterly: strategic value tiers. On-Demand: manual trigger only.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment definition. Active: in production use for customer assignment and campaigns. Inactive: temporarily suspended, no new assignments. Archived: retired, historical reference only. Draft: under development, not yet released.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segmentation methodology applied. RFM Tier: Recency, Frequency, Monetary analysis. Demographic: age, gender, income. Behavioral: purchase patterns, product affinity. Psychographic: lifestyle, values. Lifecycle Stage: new, active, at-risk, lapsed. Geographic: region, climate zone. Channel Preference: omnichannel, e-commerce-only, store-only. Value Tier: CLTV-based stratification. [ENUM-REF-CANDIDATE: rfm_tier|demographic|behavioral|psychographic|lifecycle_stage|geographic|channel_preference|value_tier — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarketingChannel rdf:type rdf:Property ;
    rdfs:label 'Target Marketing Channel' ;
    rdfs:comment 'Primary communication channel recommended for engaging customers in this segment. Aligns segment strategy with channel preference and regulatory consent. All Channels: omnichannel engagement strategy. [ENUM-REF-CANDIDATE: email|sms|push_notification|direct_mail|in_store|call_center|social_media|all_channels — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Unique identifier for the customer interaction event. Primary key.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmaId rdf:type rdf:Property ;
    rdfs:label 'Rma Id' ;
    rdfs:comment 'Foreign key linking to returns.rma. Business justification: Customer service operations log interactions (calls, chats, emails) against specific RMAs — a named retail customer service process. Enables RMA-level interaction history reporting, SLA tracking, and ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rma .

ind:browser rdf:type rdf:Property ;
    rdfs:label 'Browser' ;
    rdfs:comment 'The web browser used by the customer during this interaction (e.g., Chrome, Safari, Firefox, Edge). Applicable for web-based interactions. Null for non-web interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'The delivery and engagement status for outbound communication interactions (email, SMS, push notification). Indicates whether the message was delivered, opened, clicked, bounced, or failed. Null for inbound or non-message interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'The type of device used by the customer during this interaction (e.g., desktop, mobile, tablet, kiosk, POS terminal). Applicable for digital and in-store interactions. Null if device type is unknown.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalProperty rdf:type rdf:Property ;
    rdfs:label 'Digital Property' ;
    rdfs:comment 'The specific digital asset or platform where the interaction occurred (e.g., main website, mobile app, partner site, social media platform name). Applicable for digital interactions. Null for in-store interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the interaction was initiated by the customer (inbound) or by Retail (outbound).' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'The length of the interaction in seconds. Applicable for sessions, calls, chats, and visits. Null for instantaneous events (e.g., email send, SMS send).' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emailClickedFlag rdf:type rdf:Property ;
    rdfs:label 'Email Clicked Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer clicked a link within an outbound email. Applicable only for email interactions. Null for non-email interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailOpenedFlag rdf:type rdf:Property ;
    rdfs:label 'Email Opened Flag' ;
    rdfs:comment 'Boolean flag indicating whether an outbound email was opened by the customer. Applicable only for email interactions. Null for non-email interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'The latitude coordinate of the customer location at the time of this interaction, if available. Applicable for mobile app interactions with location services enabled. Null if location data is unavailable.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'The longitude coordinate of the customer location at the time of this interaction, if available. Applicable for mobile app interactions with location services enabled. Null if location data is unavailable.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'The date and time when the interaction event occurred. This is the business event timestamp (when the customer engaged), distinct from record audit timestamps.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'The category of customer touchpoint or engagement event. Defines the nature of the interaction (e.g., POS visit, website session, app open, call center contact, email send, SMS send, push notification, chat, clienteling visit, NPS survey response). [ENUM-REF-CANDIDATE: pos_visit|website_session|mobile_app_open|call_center_contact|email_campaign|sms_campaign|push_notification|live_chat|clienteling_visit|nps_survey|social_media_engagement|kiosk_interaction|video_call|in_store_event — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'The IP address of the customer device during this interaction. Applicable for digital interactions. Null for in-store interactions. May be considered PII in some jurisdictions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landingPageUrl rdf:type rdf:Property ;
    rdfs:label 'Landing Page Url' ;
    rdfs:comment 'The URL of the first page visited by the customer during this interaction session. Applicable for web-based interactions. Null for non-web interactions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'The operating system of the device used during this interaction (e.g., Windows, macOS, iOS, Android). Applicable for digital interactions. Null for non-digital interactions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'The result or resolution status of the interaction (e.g., completed, abandoned, escalated, resolved, converted, bounced, unsubscribed). [ENUM-REF-CANDIDATE: completed|abandoned|escalated|resolved|converted|bounced|unsubscribed|pending|transferred|no_response — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerUrl rdf:type rdf:Property ;
    rdfs:label 'Referrer Url' ;
    rdfs:comment 'The URL of the page or source that referred the customer to this interaction (e.g., search engine, social media, email link). Applicable for web-based interactions. Null for non-web interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'A numeric score representing the sentiment or emotional tone of the interaction, derived from text analytics or voice analytics. Scale typically -1.0 (negative) to +1.0 (positive). Null if sentiment analysis was not performed.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:smsDeliveredFlag rdf:type rdf:Property ;
    rdfs:label 'Sms Delivered Flag' ;
    rdfs:comment 'Boolean flag indicating whether an outbound SMS message was successfully delivered to the customer. Applicable only for SMS interactions. Null for non-SMS interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'A brief subject or title describing the purpose or topic of the interaction (e.g., product inquiry, order status check, complaint, feedback). Applicable for call center contacts, service cases, and clienteling visits. Null for automated or non-subject-based interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unsubscribedFlag rdf:type rdf:Property ;
    rdfs:label 'Unsubscribed Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer unsubscribed from communications as a result of this interaction. Applicable for outbound communication interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Payment Method Id' ;
    rdfs:comment 'Primary key for payment_method' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:binNumber rdf:type rdf:Property ;
    rdfs:label 'Bin Number' ;
    rdfs:comment 'First six digits of the card number (Bank Identification Number). Used for card type identification, fraud detection, and routing. Not considered sensitive under PCI DSS.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bnplProvider rdf:type rdf:Property ;
    rdfs:label 'Bnpl Provider' ;
    rdfs:comment 'Buy-now-pay-later provider. Free-form string; common values include: klarna, affirm, afterpay, zip, sezzle.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardBrand rdf:type rdf:Property ;
    rdfs:label 'Card Brand' ;
    rdfs:comment 'Brand of the payment card; common values include visa, mastercard, amex, discover.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardCountryCode rdf:type rdf:Property ;
    rdfs:label 'Card Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the country where the card was issued. Derived from BIN lookup. Used for fraud detection and international transaction processing.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'Full name of the cardholder. PII-sensitive; masked in non-production environments. Canonical source now in finance.payment_instrument.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentChannel rdf:type rdf:Property ;
    rdfs:label 'Consent Channel' ;
    rdfs:comment 'Channel through which the customer provided consent to store this payment method (web, mobile app, POS, call center, in-store). Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Timestamp when the customer provided consent to store this payment method. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deactivatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivated Timestamp' ;
    rdfs:comment 'Timestamp when this payment method was deactivated. Null if the payment method is still active. Used for lifecycle tracking and compliance reporting.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'Reason why the payment method was deactivated. Used for customer service, fraud analysis, and operational reporting.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalWalletProvider rdf:type rdf:Property ;
    rdfs:label 'Digital Wallet Provider' ;
    rdfs:comment 'Digital wallet provider. Free-form string; common values include: apple_pay, google_pay, paypal, samsung_pay, venmo.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryMonth rdf:type rdf:Property ;
    rdfs:label 'Expiry Month' ;
    rdfs:comment 'Expiration month of the payment card (1-12). Used to validate card validity at checkout and trigger proactive customer notifications for expiring cards.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryYear rdf:type rdf:Property ;
    rdfs:label 'Expiry Year' ;
    rdfs:comment 'Expiration year of the payment card (four-digit year). Used to validate card validity at checkout and trigger proactive customer notifications for expiring cards.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:giftCardBalance rdf:type rdf:Property ;
    rdfs:label 'Gift Card Balance' ;
    rdfs:comment 'Current balance remaining on the gift card. Updated after each transaction. Applicable only when payment_method_type is gift_card.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftCardNumber rdf:type rdf:Property ;
    rdfs:label 'Gift Card Number' ;
    rdfs:comment 'Tokenized or masked gift card number. Applicable only when payment_method_type is gift_card. Used for gift card balance inquiries and redemption.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Flag indicating whether this payment method is currently active and available for use. Inactive methods are retained for historical transaction reference but cannot be used for new purchases.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Flag indicating whether this is the customers default payment method for one-click checkout and recurring purchases. Only one payment method per customer should be marked as default.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingBank rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank' ;
    rdfs:comment 'Name of the bank or financial institution that issued the payment card. Used for transaction routing and fraud detection.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFourDigits rdf:type rdf:Property ;
    rdfs:label 'Last Four Digits' ;
    rdfs:comment 'Last four digits of the card number for customer recognition and display purposes. Used in clienteling and checkout confirmation screens.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Payment Method Type' ;
    rdfs:comment 'Type of payment method. Allowed values: credit_card, debit_card, wallet, gift_card, store_credit, bnpl.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessor rdf:type rdf:Property ;
    rdfs:label 'Payment Processor' ;
    rdfs:comment 'Name of the payment processor or gateway used to process transactions with this payment method (e.g., Stripe, Adyen, Braintree, Cybersource). Used for transaction routing and reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDigitalWalletAccountReference rdf:type rdf:Property ;
    rdfs:label 'Primary Digital Wallet Account Reference' ;
    rdfs:comment 'Tokenized identifier for the digital wallet account. Used for digital wallet transactions and reconciliation.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processorToken rdf:type rdf:Property ;
    rdfs:label 'Processor Token' ;
    rdfs:comment 'Payment processor-specific token for this payment method. Used for transaction processing and vault management.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCreditBalance rdf:type rdf:Property ;
    rdfs:label 'Store Credit Balance' ;
    rdfs:comment 'Current balance of store credit available to the customer. Typically issued from returns or promotional campaigns. Applicable only when payment_method_type is store_credit.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:token rdf:type rdf:Property ;
    rdfs:label 'Token' ;
    rdfs:comment 'PCI DSS compliant tokenized reference to the payment instrument. No raw PAN (Primary Account Number) is stored. Token is used for recurring purchases and one-click checkout.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Total number of times this payment method has been used for transactions. Used for RFM analytics and customer behavior analysis.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of payment method verification (e.g., AVS check, CVV verification, micro-deposit confirmation). Used for fraud prevention and risk management.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walletProvider rdf:type rdf:Property ;
    rdfs:label 'Wallet Provider' ;
    rdfs:comment 'Digital wallet provider; common values include apple_pay, google_pay, paypal.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipId rdf:type rdf:Property ;
    rdfs:label 'Membership Id' ;
    rdfs:comment 'Primary key for customer_membership' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Id' ;
    rdfs:comment 'Foreign key linking to the segment definition to which this profile is assigned' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:assignmentConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Assignment Confidence Score' ;
    rdfs:comment 'Confidence score (0.00-100.00) indicating the strength of this customer\'s qualification for this segment. For rule-based assignments, reflects how strongly the customer meets qualification criteria. For ML-based assignments, reflects model prediction confidence. Used for prioritizing marketing outreach and identifying borderline members.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'Mechanism by which this customer was assigned to this segment. AutoRefresh: automatically assigned via scheduled segment refresh process. ManualOverride: manually assigned by business user overriding qualification rules. RuleEngine: assigned via real-time rule evaluation. MLModel: assigned via predictive model scoring. BulkImport: assigned via batch data load.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerMembershipStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Membership Status' ;
    rdfs:comment 'Current operational status of this segment membership. Active: customer currently qualifies and membership is in effect. Expired: membership ended due to disqualification or time-based expiry. Suspended: temporarily inactive due to business rules. PendingQualification: awaiting next refresh cycle to confirm eligibility.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date when this customer profile exited this segment or the membership was terminated. Null for currently active memberships. Used for churn analysis and segment tenure calculations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fee rdf:type rdf:Property ;
    rdfs:label 'Fee' ;
    rdfs:comment 'The membership fee of the customer membership.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastQualificationCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Qualification Check Date' ;
    rdfs:comment 'Timestamp of the most recent evaluation of this customer\'s eligibility for this segment. Updated during auto-refresh cycles or manual re-qualification checks. Used for audit trails and determining when next qualification check is due.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manualOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Manual Override Flag' ;
    rdfs:comment 'Boolean flag indicating whether this membership was manually assigned by a business user, overriding automated qualification rules. True: manual override in effect, customer may not meet standard qualification criteria. False: standard rule-based or automated assignment. Used for governance and audit purposes.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text explanation provided by business user when manual_override_flag is true. Documents business justification for overriding automated qualification rules (e.g., \'VIP customer per executive request\', \'Strategic account exception\', \'Retention offer\'). Null when no override is in effect.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalRate rdf:type rdf:Property ;
    rdfs:label 'Renewal Rate' ;
    rdfs:comment 'The renewal rate of the customer membership.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date when this customer profile was assigned to this segment and the membership became active. Used for lifecycle tracking and historical analysis of segment transitions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:brandId rdf:type rdf:Property ;
    rdfs:label 'Brand Id' ;
    rdfs:comment 'Foreign key linking to product.product_brand. Business justification: Every SKU belongs to exactly one brand (national brand or private label). product_brand is the SSOT for brand master data in this domain. The sku table has private_label_flag as a denormalized indicat' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:ageRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Age Restriction Flag' ;
    rdfs:comment 'Indicates if age restriction applies to this SKU' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

