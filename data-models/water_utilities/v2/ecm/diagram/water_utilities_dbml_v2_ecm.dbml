Table metering.metering_meter {
  metering_meter_id varchar [pk, note: 'Primary key for meter']
  asset_meter_id varchar [note: 'Canonical single-source-of-truth reference to asset.asset_meter (asset_meter_id); this entity defers authoritative attribute values to that master entity.']
  fixed_asset_id varchar [note: 'Foreign key linking to finance.fixed_asset. Business justification: Water meters are capital assets requiring fixed asset accounting for depreciation, asset retirement obligations, and GASB compliance. Meter populations represent significant utility plant investment r']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Each installed meter corresponds to a material master record for procurement, inventory management, warranty tracking, and cost allocation. Procurement teams order meters by material number; warehouse']
  meter_size_type_id varchar [note: 'Foreign key linking to metering.meter_size_type. Business justification: Meter size and type combinations are standardized configurations defined in the meter_size_type reference table. The metering_meter table currently stores meter_size_inches and meter_type as denormali']
  registry_id varchar [note: 'Foreign key linking to asset.asset_registry. Business justification: Meters are capital assets requiring lifecycle management, depreciation tracking, condition assessment, and regulatory compliance (GASB 34). Water utilities track meters in asset registries for replace']
  accuracy_class varchar [note: 'AWWA accuracy class']
  accuracy_pct decimal(8,4)
  acquisition_cost decimal(18,2) [note: 'Original acquisition cost']
  ami_capable boolean [note: 'Whether AMI capable']
  ami_compatible boolean [note: 'Whether meter is AMI compatible']
  ami_enabled_flag boolean
  awwa_class varchar [note: 'AWWA meter class']
  body_material varchar [note: 'Meter body material (bronze, cast_iron, stainless, plastic)']
  communication_protocol varchar [note: 'Communication protocol (pulse, encoder, digital)']
  connection_type varchar [note: 'Connection type (threaded, flanged, compression)']
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp
  current_read_value decimal(15,3)
  current_status varchar [note: 'Current status (in_service, in_stock, retired, failed, testing)']
  data_quality_flag boolean [note: 'True when record passed data validation.']
  expected_life_years varchar [note: 'Expected useful life in years']
  firmware_version varchar [note: 'Current firmware version if electronic']
  first_install_date date
  flow_direction varchar [note: 'Direction of flow measurement']
  flow_units varchar [note: 'flow units for metering_meter']
  initial_read decimal(18,4) [note: 'Initial register reading.']
  initial_read_value decimal(15,3)
  install_date date
  installation_count varchar [note: 'Number of times meter has been installed']
  is_active boolean
  is_ami boolean [note: 'Whether meter is AMI-enabled.']
  is_ami_enabled boolean
  is_compound boolean [note: 'Whether this is a compound meter']
  is_smart_meter boolean
  last_calibration_date date [note: 'Date of last calibration']
  last_modified_timestamp timestamp
  last_read_value double
  last_test_accuracy_pct decimal(6,2) [note: 'Last test accuracy percentage']
  last_test_date date [note: 'Date of last accuracy test']
  latitude decimal(10,7) [note: 'GPS latitude of meter location']
  lead_free_certified boolean [note: 'Whether lead-free certified']
  lid_type varchar [note: 'Meter lid type']
  longitude decimal(10,7) [note: 'GPS longitude of meter location']
  low_flow_insert_size decimal(4,2) [note: 'Low flow insert size for compound meters']
  manufacture_date date [note: 'Date of manufacture']
  manufacturer varchar
  max_flow_rate_gpm decimal(10,2) [note: 'Maximum flow rate in GPM']
  measurement_technology varchar
  measurement_unit varchar
  meter_age_years varchar [note: 'Age of meter in years']
  meter_class varchar [note: 'Meter accuracy class']
  meter_model varchar [note: 'meter model for metering_meter']
  meter_number varchar
  meter_serial_number varchar [note: 'Manufacturer serial number.']
  meter_size varchar
  meter_size_inches varchar
  meter_status varchar
  meter_technology varchar [note: 'Meter technology']
  meter_type varchar
  min_flow_rate_gpm decimal(10,4) [note: 'Minimum flow rate in GPM']
  model varchar [note: 'Meter model']
  model_number varchar
  notes varchar [note: 'Meter notes']
  nsf_certified boolean [note: 'Whether NSF certified']
  number_of_dials varchar [note: 'Number of dials on register']
  operating_pressure_max_psi decimal(6,2) [note: 'Maximum operating pressure in PSI']
  pit_or_vault varchar [note: 'Installation location type (pit, vault, indoor, outdoor)']
  pit_type varchar [note: 'Meter pit type']
  purchase_cost decimal(18,2) [note: 'Purchase cost']
  purchase_date date [note: 'Date of purchase']
  record_status varchar
  register_count varchar
  register_dials varchar
  register_multiplier decimal(10,4) [note: 'Register multiplier']
  register_type varchar [note: 'Register type (straight, round)']
  register_unit varchar [note: 'Register unit of measure (gallons, cubic_feet, liters)']
  register_unit_of_measure varchar [note: 'Unit of measure on register']
  register_units varchar [note: 'Register units (gallons, cubic feet)']
  removal_date date [note: 'Date meter was removed']
  retirement_date date
  salvage_value decimal(18,2) [note: 'Estimated salvage value']
  serial_number varchar
  size_inches decimal(4,2) [note: 'Meter size in inches']
  temperature_max_f decimal(5,1) [note: 'Maximum operating temperature in F']
  test_due_date date [note: 'Next test due date']
  total_volume_through decimal(18,2) [note: 'Total volume through meter']
  total_volume_through_meter decimal(18,2) [note: 'Total volume through meter']
  unit_of_measure varchar
  units_of_measure varchar
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp']
  warranty_expiration_date date [note: 'Warranty expiration date']

  Note: 'Master inventory record for every physical meter device deployed across the water and wastewater service territory. Captures meter make, model, size, type (AMI/AMR/manual), serial number, manufacturer, installation date, current status, register type, pulse output factor, maximum flow rate (GPM), meter generation, and communication module type. Includes bulk/compound meters, fire service meters, and all residential/commercial/industrial meter classes. Serves as the authoritative SSOT for meter device identity and specifications within the metering domain.'
}

Table metering.installation {
  installation_id varchar [pk, note: 'Primary key for installation']
