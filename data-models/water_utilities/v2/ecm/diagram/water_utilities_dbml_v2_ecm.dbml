  last_goods_receipt_date date [note: 'Date of last goods receipt.']
  last_modified_timestamp timestamp [note: 'Last modification timestamp.']
  last_physical_inventory_date date [note: 'Date of last physical count.']
  last_stock_adjustment_date date [note: 'Date of last stock adjustment.']
  lead_time_days varchar [note: 'Replenishment lead time.']
  material_description varchar [note: 'Material description.']
