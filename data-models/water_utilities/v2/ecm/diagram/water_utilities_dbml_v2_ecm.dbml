  qc_batch_id varchar
  reviewer_employee_id varchar
  validation_validator_employee_id varchar
  accepted_results_count varchar
  batch_code varchar [note: 'External or legacy code used to reference the batch in laboratory systems.']
  batch_description varchar [note: 'Free‑form text describing the purpose, scope, or special notes for the batch.']
  batch_end_timestamp timestamp [note: 'Date‑time when the batch processing completed.']
  batch_name varchar [note: 'Human‑readable name assigned to the batch for easy identification.']
  batch_number varchar
  batch_start_timestamp timestamp [note: 'Date‑time when the batch processing began.']
  batch_status varchar
  batch_type varchar [note: 'Category describing the purpose of the batch.']
  batch_version varchar [note: 'Version number of the batch definition, incremented on revisions.']
  comments varchar [note: 'Additional remarks or observations recorded by the analyst.']
  created_timestamp timestamp [note: 'Timestamp when the batch record was first created in the system.']
  location_code varchar [note: 'Code of the facility or laboratory where the batch was performed.']
  method_used varchar [note: 'Standard method or protocol applied to the samples in the batch.']
  modified_timestamp timestamp
  notes varchar
  operator_name varchar [note: 'Name of the certified analyst who oversaw the batch execution.']
  qualified_results_count varchar
  quality_flag boolean [note: 'Overall quality assessment result for the batch.']
  regulatory_program varchar
  rejected_results_count varchar
  result_count varchar
  results_accepted_count varchar
  results_rejected_count varchar
  total_results_count varchar
  total_samples varchar [note: 'Number of individual samples included in the batch.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the batch record.']
  validation_batch_status varchar [note: 'Current lifecycle status of the batch.']
  validation_criteria varchar
  validation_date date
  validation_end_timestamp timestamp
  validation_findings varchar
  validation_level varchar
  validation_result varchar [note: 'Final outcome of the batch validation process.']
  validation_start_timestamp timestamp
  validation_status varchar

  Note: 'Master reference table for validation_batch. Referenced by validation_batch_id.'
}

Table laboratory.pt_provider {
  pt_provider_id varchar [pk, note: 'Primary key for pt_provider']
  parent_pt_provider_id varchar [note: 'Self-referencing FK on pt_provider (parent_pt_provider_id)']
  vendor_id varchar
  accreditation_body varchar [note: 'Organization that issued the accreditation.']
  accreditation_effective_date date [note: 'Date when the accreditation became effective.']
  accreditation_expiration_date date [note: 'Date when the accreditation expires.']
  accreditation_number varchar [note: 'Identifier of the accreditation granted to the provider.']
  accreditation_status varchar [note: 'Current status of the provider\'s accreditation.']
  accrediting_body varchar
  address_line1 varchar [note: 'First line of the provider\'s mailing address.']
  address_line2 varchar [note: 'Second line of the provider\'s mailing address (optional).']
  address_line_1 varchar
  annual_cost_usd decimal(12,2)
  approved_analyte_scope varchar
  available_matrices varchar
  available_programs varchar
  bank_account_number varchar [note: 'Bank account used for payments to the provider.']
  city varchar [note: 'City component of the provider\'s address.']
  classification varchar [note: 'Business classification used for segmentation and compliance.']
