Table service.offering {
  offering_id varchar [pk, note: 'Unique identifier for the service offering. Primary key for the offering product.']
  wtp_facility_id varchar [note: 'Foreign key linking to treatment.facility. Business justification: Service offerings may be facility-specific (e.g., recycled water from specific reclamation facility, different water quality tiers based on treatment level). Needed for tariff design where rate struct']
  ami_enabled_flag boolean [note: 'Indicates whether this offering requires or supports Advanced Metering Infrastructure (AMI) for automated meter reading and real-time consumption monitoring. True = AMI required or available; False = manual or Automatic Meter Reading (AMR) only.']
  auto_renewal_flag boolean [note: 'Indicates whether the service contract automatically renews at the end of the contract term. True = auto-renews unless customer cancels; False = requires explicit renewal. Null if not applicable.']
  backflow_prevention_required_flag boolean [note: 'Indicates whether backflow prevention devices are required for this offering to protect the public water supply from contamination. True = backflow prevention required (common for commercial, industrial, and recycled water services); False = not required.']
  base_rate_amount decimal(15,2) [note: 'Fixed monthly or periodic base charge for the service offering, independent of consumption. Covers fixed costs such as meter maintenance, billing, and infrastructure access. Expressed in local currency (USD for U.S. utilities).']
  billing_cycle_code varchar [note: 'Code identifying the billing cycle or schedule applicable to this offering. Examples: MNTH (monthly), QRTR (quarterly), BIMON (bi-monthly). Aligns with Oracle Utilities Customer Care and Billing (CC&B) billing cycle configuration.']
  capacity_charge decimal(15,2) [note: 'Fee for reserving system capacity or infrastructure access, common in industrial and municipal bulk water agreements. May be based on meter size, peak demand, or contracted volume. Also known as a demand charge or readiness-to-serve charge.']
  connection_fee decimal(15,2) [note: 'One-time fee charged to establish a new service connection, including meter installation, service line connection, and administrative setup. May vary by customer class and service type.']
  conservation_program_eligible_flag boolean [note: 'Indicates whether customers enrolled in this offering are eligible for water conservation programs, rebates, or incentives (e.g., low-flow fixture rebates, landscape conversion incentives). True = eligible; False = not eligible.']
  contract_term_months varchar [note: 'Standard contract duration in months for this offering. Common for commercial, industrial, and municipal agreements. Null for month-to-month residential service.']
  created_timestamp timestamp [note: 'Timestamp when this offering record was first created in the system. Used for audit trail and data lineage tracking.']
  customer_class varchar [note: 'Customer segment or class to which this offering applies. Determines rate structure, service level expectations, and regulatory treatment. Residential = single-family and multi-family homes; Commercial = businesses and offices; Industrial = manufacturing and heavy water users; Municipal = government facilities; Agricultural = farms and irrigation; Institutional = schools, hospitals, non-profits.']
  delivery_mode varchar [note: 'Method by which the service is delivered and billed. Metered = consumption-based billing via Advanced Metering Infrastructure (AMI) or Automatic Meter Reading (AMR); Unmetered = fixed-rate service without consumption measurement; Flat rate = fixed periodic charge regardless of usage; Seasonal = service active only during specific periods; Temporary = short-term service for construction or events; Emergency = contingency supply during outages or disasters.']
  deposit_amount decimal(15,2) [note: 'Standard security deposit amount required for new customers. May vary based on estimated usage, customer class, or credit assessment. Null if no deposit is required.']
  deposit_required_flag boolean [note: 'Indicates whether a security deposit is required for new customers enrolling in this offering. True = deposit required; False = no deposit. Deposit policies vary by customer class and credit history.']
  effective_date date
  effective_end_date date [note: 'Date on which the offering is no longer available for new customer enrollment. Null for open-ended offerings. Existing customers may continue under grandfathered terms.']
  effective_start_date date [note: 'Date on which the offering becomes available for customer enrollment and billing. Aligns with regulatory approval and operational readiness.']
  end_date date
  expiration_date date
  fire_protection_service_flag boolean [note: 'Indicates whether this offering includes dedicated fire protection service (e.g., fire hydrant access, private fire line). True = fire protection included; False = potable water or wastewater service only.']
  flow_capacity_gpm decimal(12,2) [note: 'Maximum sustained flow rate in Gallons per Minute (GPM) that the utility can deliver for this offering under normal conditions. Relevant for fire protection, industrial, and bulk water services. Null for standard residential metered service.']
  is_active boolean
  last_modified_timestamp timestamp
  late_payment_penalty_percent decimal(5,2) [note: 'Percentage penalty applied to overdue balances after the payment due date. Subject to Public Utilities Commission regulations. Null if no late fee applies.']
  lifecycle_status varchar [note: 'Current state of the offering in its lifecycle. Active = available for new customer enrollment; Inactive = temporarily unavailable; Pending approval = awaiting regulatory or internal approval; Suspended = on hold due to operational or regulatory issues; Retired = no longer offered to new customers; Grandfathered = legacy offering maintained only for existing customers under prior tariff terms.']
  meter_size_required_inches decimal(5,2) [note: 'Standard meter size in inches required or recommended for this offering based on expected flow and customer class. Common sizes: 0.625 (5/8 inch), 0.75 (3/4 inch), 1.0, 1.5, 2.0, 3.0, 4.0, 6.0, 8.0 inches. Null for unmetered service.']
  minimum_monthly_charge decimal(15,2) [note: 'Minimum amount a customer will be billed each billing period, regardless of consumption. Ensures cost recovery for fixed infrastructure and service availability. Null if no minimum applies.']
  modified_by_user varchar [note: 'User ID or system account that last modified this offering record. Used for audit trail and accountability.']
  modified_timestamp timestamp [note: 'Timestamp when this offering record was last modified. Used for audit trail, change tracking, and data synchronization.']
  offering_code varchar [note: 'Externally-known unique code for the service offering used in billing systems, tariff schedules, and customer communications. Examples: WTR-RES-01, WWC-COM-02, RCW-IND-01.']
  offering_description varchar [note: 'Detailed description of the service offering including scope, delivery specifications, and any special conditions or limitations. Used in customer agreements and regulatory filings.']
  offering_name varchar [note: 'Human-readable name of the service offering as presented to customers and in regulatory tariff filings. Examples: Residential Potable Water Service, Commercial Wastewater Collection, Industrial Recycled Water Supply.']
  offering_status varchar
  offering_type varchar
  pressure_range_psi_max varchar [note: 'Maximum water pressure in PSI at the customer service connection under normal operating conditions. Excessive pressure may require Pressure Reducing Valve (PRV) installation. Null for wastewater or non-pressurized services.']
  pressure_range_psi_min varchar [note: 'Minimum water pressure in PSI guaranteed at the customer service connection under normal operating conditions. Part of service delivery specifications. Null for wastewater or non-pressurized services.']
  rate_structure_type decimal(18,6) [note: 'Pricing model applied to the offering. Uniform = single rate for all consumption; Tiered = increasing or decreasing rates by consumption block (e.g., conservation pricing); Seasonal = rates vary by season (summer vs. winter); Time of use = rates vary by time of day or peak demand periods; Demand-based = charges based on peak flow or capacity reservation.']
  regulatory_approval_date date [note: 'Date on which the offering and its associated rate structure received regulatory approval from the Public Utilities Commission or other governing authority. Required for compliance with rate case documentation and audit trails.']
  service_type varchar [note: 'Primary category of water or wastewater service provided. Potable water = treated drinking water supply; Wastewater collection = sanitary sewer service; Recycled water = reclaimed water for non-potable uses; Fire protection = dedicated fire suppression service; Bulk water = wholesale or large-volume supply; Stormwater = stormwater management and drainage.']
  sla_response_time_hours varchar [note: 'Maximum time in hours within which the utility commits to respond to service requests, outages, or quality complaints for this offering. Part of the contractual Service Level Agreement (SLA). Null if no formal SLA applies.']
  sla_restoration_time_hours decimal(18,6) [note: 'Maximum time in hours within which the utility commits to restore service following an outage or interruption for this offering. Part of the contractual Service Level Agreement (SLA). Null if no formal SLA applies.']
  termination_notice_days varchar [note: 'Number of days advance notice required for customer to terminate or discontinue service. Common for commercial and industrial contracts. Null for standard residential service.']
  volumetric_rate_amount decimal(15,4) [note: 'Per-unit charge for water or wastewater service based on consumption volume. Typically expressed in dollars per thousand gallons ($/kgal) or dollars per hundred cubic feet ($/CCF). Null for unmetered or flat-rate offerings.']
  volumetric_rate_unit decimal(18,6) [note: 'Unit of measure for volumetric billing. kgal = thousand gallons; CCF = hundred cubic feet; gallon = individual gallon; cubic meter = m³ (common in international contexts); acre-foot = volume unit for large agricultural or municipal contracts.']
  water_quality_standard varchar [note: 'Applicable water quality standard or regulatory compliance framework for this offering. Examples: Safe Drinking Water Act (SDWA) Primary Standards, Recycled Water Quality Standards (Title 22 California), Industrial Discharge Permit Limits. Null for non-water offerings (e.g., wastewater collection).']

  Note: 'Master catalog of all water and wastewater service offerings available to customers, including potable water supply, wastewater collection, recycled water, fire protection, irrigation, and bulk water services. Defines the canonical service type, delivery mode, applicable customer classes (residential, commercial, industrial, municipal), regulatory tariff reference, connection fee schedule, service tier options, and lifecycle status. This is the SSOT for what Water Utilities offers in the market and the anchor entity for rate schedules, SLAs, and service agreements.'
}

Table service.service_rate_schedule {
  service_rate_schedule_id varchar [pk, note: 'Unique identifier for the service_rate_schedule data product (auto-inserted pre-linking).']
  finance_rate_case_id varchar [note: 'Foreign key linking to finance.rate_case. Business justification: Rate schedules are approved through rate case proceedings. Essential for tracking regulatory approval, effective dates, and revenue requirement allocation across customer classes. Required for PUC com']
  offering_id varchar [note: 'Foreign key linking to service.offering. Business justification: Service rate schedules define approved tariff rate structures for specific service offerings. Currently has rate_case_id but missing the offering link. Rate schedules must be tied to the offerings the']
  service_class_id varchar [note: 'Foreign key linking to service.service_class. Business justification: Rate schedules are applied by customer service class (residential, commercial, industrial, etc.). Each rate schedule should specify which service class it applies to. This is a standard water utility ']
  service_rate_case_id varchar
  tariff_id varchar [note: 'Foreign key linking to service.tariff. Business justification: Rate schedules implement approved regulatory tariffs. In water utilities, tariffs are filed with and approved by the Public Utilities Commission, then rate schedules operationalize those tariffs. serv']
  territory_id varchar [note: 'Foreign key linking to service.territory. Business justification: Rate schedules can vary by geographic territory due to different franchise agreements, cost structures, or regulatory jurisdictions. Water utilities often have territory-specific rate schedules. This ']
  annual_revenue_estimate decimal(18,2) [note: 'Estimated annual revenue']
  approval_date date
  approved_by varchar [note: 'Approving authority']
  approved_by_authority varchar
  approved_by_board_date date [note: 'Date approved by governing board']
  approved_by_puc_flag boolean
  average_bill_amount decimal(18,2) [note: 'Average monthly bill amount']
  base_charge decimal(18,2) [note: 'Base/fixed charge']
  base_charge_amount decimal(18,2)
  base_charge_frequency varchar [note: 'Base charge frequency']
  base_charge_unit varchar [note: 'Base charge unit (per_month, per_meter, per_connection)']
  base_charge_usd decimal(18,2)
  base_rate decimal(18,2) [note: 'Base rate']
  base_rate_amount decimal(18,2) [note: 'Base rate amount.']
  billing_frequency varchar [note: 'Billing frequency for the rate schedule.']
  billing_rate_schedule_id decimal(18,6) [note: 'References the single source of truth master record in billing.billing_rate_schedule']
  conservation_surcharge_rate decimal(10,4) [note: 'Conservation surcharge rate']
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp [note: 'Record creation timestamp']
  currency_code varchar
  customer_class varchar [note: 'Customer class']
  customer_count varchar [note: 'Number of customers on schedule']
  data_quality_flag boolean [note: 'True when record passed data validation.']
  demand_charge_amount decimal(18,2) [note: 'Demand charge if applicable']
  drought_surcharge_applicable boolean [note: 'Whether drought surcharge applicable']
  drought_surcharge_pct decimal(5,2) [note: 'Drought surcharge percentage']
  effective_date date
  effective_end_date date
  effective_start_date date
  expiration_date date
  included_volume decimal(12,2) [note: 'Volume included in base charge']
  infrastructure_surcharge decimal(18,2) [note: 'Infrastructure surcharge amount']
  is_active boolean [note: 'Whether the schedule is active.']
  is_tiered boolean
  last_modified_timestamp timestamp
  minimum_bill_amount decimal(18,2) [note: 'Minimum bill amount']
  minimum_charge decimal(18,2) [note: 'Minimum charge']
  minimum_charge_amount decimal(18,2) [note: 'Minimum monthly charge']
  minimum_charge_usd decimal(18,2)
  notes varchar [note: 'Schedule notes']
  number_of_tiers varchar [note: 'Number of rate tiers']
  public_hearing_date date [note: 'Date of public hearing']
  rate_amount decimal(18,2)
  rate_class varchar
  rate_schedule_code varchar
  rate_schedule_name varchar
  rate_schedule_number varchar [note: 'Rate schedule reference number.']
  rate_schedule_status varchar
  rate_schedule_type varchar
  rate_status varchar
  rate_structure varchar [note: 'Rate structure type.']
  rate_structure_type varchar
  rate_type varchar
  rate_unit varchar [note: 'Rate unit']
  record_status varchar
  regulatory_approval_date date [note: 'Date of regulatory approval']
  regulatory_docket_number varchar [note: 'Regulatory docket number']
  regulatory_fee decimal(18,2) [note: 'Regulatory fee amount']
  resolution_number varchar [note: 'Approving resolution number']
  revenue_target decimal(18,2) [note: 'Target revenue from this schedule']
  schedule_code varchar
  schedule_description varchar [note: 'Description of rate schedule']
  schedule_name varchar
  schedule_number varchar [note: 'Rate schedule number.']
  schedule_status varchar
  schedule_type varchar [note: 'Type of rate schedule']
  seasonal_adjustment boolean [note: 'Whether seasonal adjustment applies']
  seasonal_adjustment_factor decimal(5,2) [note: 'Seasonal rate adjustment factor']
  seasonal_factor_summer decimal(6,4) [note: 'Summer seasonal adjustment factor']
  seasonal_factor_winter decimal(6,4) [note: 'Winter seasonal adjustment factor']
  service_rate_schedule_status varchar
  service_ssot_billing_rate_schedule_ref_id decimal(18,6) [note: 'Canonical single-source-of-truth reference to billing.billing_rate_schedule (billing_rate_schedule_id); this entity defers authoritative attribute values to that master entity.']
  service_type varchar [note: 'Service type (water, sewer)']
  tier_1_limit decimal(12,2) [note: 'Tier 1 upper limit']
  tier_1_rate decimal(12,6) [note: 'Tier 1 volumetric rate']
  tier_1_threshold_gallons varchar
  tier_2_limit decimal(12,2) [note: 'Tier 2 upper limit']
  tier_2_rate decimal(12,6) [note: 'Tier 2 volumetric rate']
  tier_2_threshold_gallons varchar
  tier_3_limit decimal(12,2) [note: 'Tier 3 upper limit']
  tier_3_rate decimal(12,6) [note: 'Tier 3 volumetric rate']
  tier_count varchar [note: 'Number of rate tiers']
  tier_structure varchar [note: 'Tier structure type']
  tier_structure_flag boolean
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp']
  volumetric_rate decimal(12,6) [note: 'Volumetric rate per unit']
  volumetric_rate_amount decimal(18,4)
  volumetric_rate_per_unit decimal(18,6)
  volumetric_rate_tier_1 decimal(18,6)
  volumetric_rate_tier_2 decimal(18,6)
  volumetric_rate_tier_3 decimal(18,6)
  volumetric_rate_usd decimal(18,4)
  volumetric_unit varchar [note: 'Volumetric unit (CCF, gallons)']

  Note: 'Defines the approved tariff rate structures for each service offering, including tiered volumetric rates (with tier thresholds, unit prices, and tier sequences), flat fees, demand charges, seasonal rate adjustments, and minimum charges. Captures the rate case approval date, effective and expiration dates, regulatory authority, rate code, applicable customer class, and billing unit of measure. Tier definitions (inclining block, declining block, uniform) are maintained as structured components within each schedule. Supports rate case modeling and regulatory tariff compliance. Aligned with Oracle CC&B rate schedule configuration. [SSOT: Canonical rate schedule definition; billing.billing_rate_schedule references this as SSOT]'
}

Table service.territory {
  territory_id varchar [pk, note: 'Unique identifier for the service territory. Primary key.']
  acquisition_date date [note: 'Date when the utility acquired this service territory through purchase, merger, or regulatory transfer from another provider.']
  area_square_miles decimal(12,4) [note: 'Total geographic area of the service territory measured in square miles.']
  average_daily_demand_mgd decimal(12,4) [note: 'Average daily water demand for the territory measured in million gallons per day, used for capacity planning and regulatory reporting.']
  boundary_description varchar [note: 'Textual description of the territory boundary using legal descriptions, street names, or geographic landmarks.']
  commercial_customer_count varchar [note: 'Number of commercial customer accounts within the territory.']
  country_code varchar [note: 'Three-letter ISO country code where the territory is located (e.g., \'USA\').']
  county_name varchar [note: 'Primary county in which the service territory is located, used for regulatory reporting and jurisdictional analysis.']
  created_timestamp timestamp [note: 'Timestamp when this service territory record was first created in the system.']
  customer_count varchar [note: 'Total number of active customer accounts (service connections) within the territory.']
  effective_end_date date [note: 'Date when the utility\'s authorization to serve this territory expires or was terminated. Null for active territories with no expiration.']
  effective_start_date date [note: 'Date when the utility began providing service in this territory or when the current franchise agreement became effective.']
  emergency_contact_phone varchar [note: 'Primary emergency contact phone number for service issues or outages in this territory, published to customers and regulatory agencies.']
  franchise_agreement_number varchar [note: 'Identifier of the regulatory franchise agreement or certificate of public convenience and necessity (CPCN) authorizing service in this territory.']
  franchise_expiration_date date [note: 'Date when the current franchise agreement or certificate expires and requires renewal or renegotiation.']
  gis_boundary_reference varchar [note: 'Reference identifier or feature class name in Esri ArcGIS for the polygon geometry defining the territory boundary.']
  industrial_customer_count varchar [note: 'Number of industrial customer accounts within the territory.']
  is_active boolean
  last_modified_timestamp timestamp [note: 'Timestamp when this service territory record was last updated in the system.']
  notes varchar [note: 'Free-form notes capturing special conditions, historical context, or operational considerations for this service territory.']
  npdes_permit_jurisdiction varchar [note: 'Regulatory authority responsible for wastewater discharge permits under the Clean Water Act (CWA) in this territory.']
  operating_division_code varchar [note: 'Internal code identifying the utility\'s operating division or business unit responsible for service delivery in this territory.']
  peak_daily_demand_mgd decimal(12,4) [note: 'Peak daily water demand for the territory measured in million gallons per day, used for infrastructure sizing and emergency planning.']
  population_served varchar [note: 'Estimated total population residing within the service territory, used for regulatory reporting and capacity planning.']
  potable_water_service_flag boolean [note: 'Indicates whether the utility provides potable (drinking) water service within this territory.']
  predecessor_utility_name varchar [note: 'Name of the previous utility that served this territory before acquisition or transfer, used for historical data lineage.']
  primacy_agency_jurisdiction varchar [note: 'State or federal agency with primary regulatory authority over drinking water quality in this territory (e.g., \'California State Water Resources Control Board\').']
  rate_zone_code decimal(18,6) [note: 'Code identifying the rate zone or pricing district applicable to customers in this territory.']
  recycled_water_service_flag boolean [note: 'Indicates whether the utility provides recycled (reclaimed) water service for non-potable uses within this territory.']
  regulatory_authority_name varchar [note: 'Name of the state or local regulatory body with jurisdiction over rates and service quality in this territory (e.g., \'California Public Utilities Commission\').']
  residential_customer_count varchar [note: 'Number of residential customer accounts within the territory.']
  service_center_location varchar [note: 'Name or identifier of the primary service center or operations facility serving this territory.']
  service_classification varchar [note: 'Geographic and demographic classification of the territory, used for rate design and infrastructure planning.']
  state_code varchar [note: 'Two-letter U.S. state code where the territory is located (e.g., \'CA\', \'TX\', \'NY\').']
  stormwater_service_flag boolean [note: 'Indicates whether the utility provides stormwater management service within this territory.']
  tariff_schedule_reference varchar [note: 'Reference to the applicable rate tariff schedule approved by the regulatory authority for this territory.']
  territory_code varchar [note: 'Externally-known unique code identifying the service territory, used in regulatory filings and franchise agreements.']
  territory_name varchar [note: 'Human-readable name of the service territory (e.g., \'Downtown District\', \'North County Service Area\').']
  territory_status varchar [note: 'Current operational status of the service territory in the utility\'s service portfolio.']
  territory_type varchar [note: 'Classification of the service territory based on regulatory authorization and service delivery model.']
  time_zone varchar [note: 'IANA time zone identifier for the territory (e.g., \'America/Los_Angeles\'), used for operational scheduling and SCADA data timestamping.']
  wastewater_service_flag boolean [note: 'Indicates whether the utility provides wastewater collection and treatment service within this territory.']

  Note: 'Defines the geographic service territories and franchise areas within which Water Utilities is authorized to provide water and wastewater services. Includes territory boundaries (GIS polygon references via Esri ArcGIS), regulatory franchise agreement identifiers, applicable state primacy agency jurisdiction, service type coverage (potable, wastewater, recycled), and territory classification (urban, suburban, rural). Supports tariff applicability and regulatory reporting.'
}

Table service.service_class {
  service_class_id varchar [pk, note: 'Unique identifier for the service class record. Primary key.']
  offering_id varchar [note: 'Foreign key linking to service.offering. Business justification: Service classes define rate structures and customer classifications that are applied to specific offerings. The offering.customer_class field references service_class.class_code, establishing a busine']
  asset_class_id varchar [note: 'Canonical single-source-of-truth reference to asset.asset_class (asset_class_id); this entity defers authoritative attribute values to that master entity.']
  average_monthly_consumption_gallons decimal(15,2) [note: 'Typical average monthly water consumption in gallons for accounts in this service class. Used for rate modeling and demand forecasting.']
  awwa_classification_code varchar [note: 'Standard classification code from AWWA M1 Manual used for industry benchmarking and best practice alignment.']
  backflow_prevention_required boolean [note: 'Indicates whether backflow prevention devices are required for accounts in this service class to protect the public water supply from contamination.']
  billing_cycle_type varchar [note: 'Standard billing frequency for accounts in this service class (e.g., monthly, bimonthly, quarterly). Determines meter reading and invoice generation schedules.']
  class_code varchar [note: 'Short alphanumeric code uniquely identifying the service class (e.g., RSF for Residential Single-Family, COM for Commercial, IND for Industrial). Used in billing systems and regulatory reports.']
  class_description varchar [note: 'Detailed description of the service class, including eligibility criteria, typical usage characteristics, and any special conditions or restrictions.']
  class_name varchar [note: 'Full descriptive name of the service class (e.g., Residential Single-Family, Commercial, Industrial, Irrigation, Fire Protection, Municipal, Wholesale).']
  class_type varchar [note: 'High-level category of the service class used for grouping and analysis. Aligns with regulatory reporting categories. [ENUM-REF-CANDIDATE: residential|commercial|industrial|irrigation|fire_protection|municipal|wholesale|other — 8 candidates stripped; promote to reference product]']
  conservation_program_eligible boolean [note: 'Indicates whether accounts in this service class are eligible for water conservation programs, rebates, or incentives.']
  consumption_tier_structure varchar [note: 'Type of rate structure applied to consumption for this class (e.g., flat rate, tiered/block rates, seasonal rates, time-of-use rates).']
  contract_term_months varchar [note: 'Standard contract term length in months for accounts in this service class. Applicable primarily to wholesale and large industrial customers.']
  created_timestamp timestamp [note: 'Timestamp when this service class record was first created in the system.']
  deposit_requirement_amount decimal(10,2) [note: 'Standard security deposit amount required for new accounts in this service class. May vary based on credit risk and consumption history.']
  disconnection_policy varchar [note: 'Policy governing service disconnection for non-payment for this class (e.g., standard, protected for vulnerable populations, restricted for essential services).']
  drought_surcharge_applicable decimal(18,2) [note: 'Indicates whether drought surcharges or emergency water use restrictions apply to this service class during water shortage conditions.']
  effective_end_date date [note: 'Date when this service class definition expires or was superseded. Null for currently active classes.']
  effective_start_date date [note: 'Date when this service class definition became or will become effective for billing and account assignment.']
  fire_flow_requirement_gpm varchar [note: 'Minimum fire flow capacity requirement in gallons per minute (GPM) for properties served under this class. Applicable primarily to commercial, industrial, and fire protection classes.']
  is_active boolean
  late_payment_penalty_rate decimal(5,2) [note: 'Percentage rate applied to overdue balances for accounts in this service class. Subject to regulatory limits.']
  meter_size_range varchar [note: 'Typical or allowable range of meter sizes (in inches) for accounts in this service class (e.g., 5/8-inch to 1-inch for residential, 2-inch to 6-inch for commercial).']
  minimum_charge_applicable decimal(18,2) [note: 'Indicates whether a minimum monthly or periodic charge applies to accounts in this service class, regardless of consumption.']
  modified_by varchar [note: 'User identifier or system account that last modified this service class record.']
  modified_timestamp timestamp [note: 'Timestamp when this service class record was last modified.']
  notes varchar [note: 'Additional notes, special conditions, or administrative comments regarding this service class.']
  peak_demand_factor decimal(5,2) [note: 'Multiplier representing the ratio of peak demand to average demand for this service class. Used in capacity planning and infrastructure sizing.']
  pressure_requirement_psi varchar [note: 'Minimum service pressure requirement in pounds per square inch (PSI) for accounts in this service class. Ensures adequate pressure for intended use.']
  puc_approval_date date [note: 'Date when the Public Utilities Commission approved this service class and its associated rate structure. Required for regulated utilities.']
  puc_filing_reference varchar [note: 'Reference number or identifier of the PUC rate case filing or tariff document that established or modified this service class.']
  rate_schedule_group decimal(18,6) [note: 'Identifier of the rate schedule group applicable to this service class. Links the class to specific rate structures and tariff schedules for billing purposes.']
  regulatory_reporting_category varchar [note: 'Classification code used for regulatory compliance reporting to state and federal agencies (e.g., EPA, PUC). Maps service class to required reporting categories.']
  renewal_notification_days varchar [note: 'Number of days advance notice required before contract renewal or rate changes for this service class.']
  seasonal_rate_applicable decimal(18,6) [note: 'Indicates whether seasonal rate variations (e.g., higher summer rates for irrigation) apply to this service class.']
  service_asset_class_id varchar [note: 'References the single source of truth record in asset.asset_class']
  service_class_description varchar
  service_class_status varchar [note: 'Current lifecycle status of the service class. Active classes are available for new account assignments; deprecated classes are phased out but may have existing accounts.']
  service_level_agreement_tier varchar [note: 'Service level tier defining response times, service restoration priorities, and quality commitments for this class (e.g., standard, priority, premium, critical).']
  service_type varchar
  tariff_classification varchar [note: 'Official tariff classification as filed with and approved by the Public Utilities Commission. Used for rate case modeling and tariff compliance.']
  water_quality_monitoring_frequency varchar [note: 'Required frequency of water quality monitoring or testing for accounts in this service class. More stringent for industrial and high-risk classes.']
  created_by varchar [note: 'User identifier or system account that created this service class record.']

  Note: 'Reference classification of customer service classes used for rate application and regulatory reporting, such as Residential Single-Family, Residential Multi-Family, Commercial, Industrial, Irrigation, Fire Protection, Municipal, and Wholesale. Each class carries a class code, description, applicable rate schedule group, billing cycle type, and regulatory reporting category. Aligned with PUC tariff classification and AWWA customer class standards.'
}

Table service.agreement {
  agreement_id varchar [pk, note: 'Unique identifier for the service agreement. Primary key for this entity representing the contractual relationship between Water Utilities and a customer account.']
  asset_meter_id varchar [note: 'Foreign key linking to asset.asset_meter. Business justification: Agreements must specify which asset meter (not just metering domain meter) is used for billing to track meter maintenance history, calibration status, and replacement schedules. Critical for revenue a']
  compliance_permit_id varchar [note: 'Foreign key linking to compliance.compliance_permit. Business justification: Industrial and commercial service agreements require compliance permits (NPDES, discharge permits). Utility tracks permit governing each agreement for regulatory reporting, billing validation, and dis']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Service delivery operations are cost-accounted by department/cost center for rate-making cost-of-service studies, overhead allocation, and performance analysis. Direct operational cost tracking requir']
  customer_account_id varchar [note: 'Reference to the customer account that holds this service agreement. Links to the customer billing account in Oracle CC&B.']
  dma_id varchar [note: 'Foreign key linking to distribution.dma. Business justification: Service agreements need DMA context for NRW cost allocation, water loss recovery charges, zone-specific service terms, and consumption baseline establishment. Enables DMA-level revenue and loss accoun']
  fund_id varchar [note: 'Foreign key linking to finance.fund. Business justification: Service agreements generate revenue to specific utility funds (water fund, wastewater fund). Essential for fund accounting, GASB reporting, and rate case revenue tracking. Water utilities require fund']
  metering_meter_id varchar [note: 'Reference to the water or wastewater meter installed at the service point for consumption measurement. Links to AMI (Advanced Metering Infrastructure) or AMR (Automatic Meter Reading) systems.']
  pressure_zone_id varchar [note: 'Foreign key linking to distribution.pressure_zone. Business justification: Service agreements specify pressure guarantees (sla_response_time, pressure_range_psi) that must reference actual pressure zones for SLA compliance verification, hydraulic capacity validation, and ser']
  service_class_id varchar [note: 'Foreign key linking to service.service_class. Business justification: Each service agreement is assigned to a specific service class which determines rate schedule applicability, billing cycle, and regulatory reporting. The service_class STRING attribute should be norma']
  service_offering_id varchar [note: 'Reference to the specific service offering (water, wastewater, reclaimed water, stormwater) that this agreement covers. Links to the service catalog.']
  agreement_number varchar [note: 'Externally visible unique business identifier for the service agreement. Used in customer communications, billing statements, and regulatory reporting.']
  agreement_status varchar [note: 'Current lifecycle status of the service agreement. Active agreements are billed and serviced; suspended agreements are temporarily halted; terminated agreements are closed.']
  auto_pay_enabled boolean [note: 'Indicates whether automatic payment is enabled for this service agreement. When true, invoices are automatically paid from the customers designated payment method.']
  auto_renewal_enabled boolean [note: 'Indicates whether the service agreement automatically renews at the end of the contract term. When false, agreement requires explicit renewal action.']
  backflow_prevention_required boolean [note: 'Indicates whether backflow prevention device installation and annual testing is required for this service agreement per SDWA (Safe Drinking Water Act) cross-connection control requirements.']
  billing_cycle_code varchar [note: 'Code identifying the billing cycle schedule for this agreement (e.g., monthly, bi-monthly, quarterly). Determines meter reading and invoice generation timing.']
  budget_billing_enabled decimal(18,2) [note: 'Indicates whether the customer is enrolled in budget billing program, which averages annual usage into equal monthly payments to reduce seasonal bill variation.']
  contract_term_months varchar [note: 'Duration of the service agreement contract in months. Used for minimum commitment periods and early termination fee calculations.']
  created_by_user varchar [note: 'Identifier of the system user or process that created this service agreement record. Used for audit and accountability purposes.']
  created_timestamp timestamp [note: 'Timestamp when this service agreement record was first created in the system. Used for audit trail and data lineage tracking.']
  deposit_amount decimal(12,2) [note: 'Dollar amount of security deposit required and held for this service agreement. Based on credit assessment and service class. Refundable upon agreement termination.']
  deposit_status decimal(18,2) [note: 'Current status of the security deposit for this agreement. Tracks whether deposit is required, currently held, waived based on credit, or refunded.']
  end_date date [note: 'Date when the service agreement terminates or is scheduled to terminate. Null for open-ended agreements. Used for final billing and account closure.']
  external_reference_code varchar [note: 'External system identifier for this service agreement in legacy or third-party systems. Used for cross-system reconciliation and data migration tracking.']
  fire_protection_service_flag boolean [note: 'Indicates whether this agreement includes fire protection service (private fire lines, sprinkler systems), which typically carries fixed monthly charges regardless of usage.']
  industrial_user_permit_required boolean [note: 'Indicates whether this service agreement requires an Industrial User Permit for wastewater discharge per NPDES (National Pollutant Discharge Elimination System) pretreatment program requirements.']
  irrigation_service_flag boolean [note: 'Indicates whether this agreement includes irrigation or outdoor water service, which may be billed separately or subject to seasonal rates and wastewater exemptions.']
  last_modified_by_user varchar [note: 'Identifier of the system user or process that last modified this service agreement record. Used for change audit and accountability.']
  last_modified_timestamp timestamp [note: 'Timestamp when this service agreement record was last updated. Used for change tracking and data synchronization across systems.']
  low_income_assistance_eligible boolean [note: 'Indicates whether this service agreement qualifies for low-income customer assistance programs, rate discounts, or payment plans per regulatory requirements.']
  minimum_usage_commitment_gallons decimal(15,2) [note: 'Minimum water usage volume (in gallons) that the customer commits to consume per billing period. Common for commercial and industrial agreements. Used for minimum charge calculations.']
  paperless_billing_enabled boolean [note: 'Indicates whether the customer has opted for electronic billing instead of paper invoices. Supports environmental sustainability initiatives.']
  rate_schedule_code decimal(18,6) [note: 'Code identifying the tariff rate schedule applied to this service agreement. Determines pricing structure, billing frequency, and charge calculations per approved rate case.']
  renewal_date date [note: 'Date when the service agreement is scheduled for renewal or renegotiation. Applicable for fixed-term contracts with renewal provisions.']
  senior_citizen_discount_eligible boolean [note: 'Indicates whether this service agreement qualifies for senior citizen rate discounts or special programs as defined by utility tariff.']
  sla_response_time_hours varchar [note: 'Contractually committed maximum response time in hours for service requests and emergency calls. Varies by service class and agreement type.']
  sla_restoration_time_hours decimal(18,6) [note: 'Contractually committed maximum time in hours to restore service after an outage or interruption. Critical for commercial and industrial customers.']
  source_system_code varchar [note: 'Code identifying the operational system of record from which this service agreement data originated. Supports data lineage and multi-system integration scenarios.']
  special_conditions varchar [note: 'Free-text field capturing any special contractual conditions, exceptions, or custom terms negotiated for this service agreement. Examples include seasonal rate adjustments, volume discounts, or regulatory exemptions.']
  start_date date [note: 'Date when the service agreement becomes effective and service delivery begins. Used for billing proration and regulatory compliance reporting.']
  termination_date date [note: 'Actual date when the service agreement was terminated. Used for final billing, deposit refund processing, and regulatory reporting.']
  termination_reason_code varchar [note: 'Standardized code indicating the reason for service agreement termination. Examples include customer move-out, non-payment, property demolition, or service transfer.']

  Note: 'Represents the active contractual relationship between Water Utilities and a customer account for a specific service offering at a service location. Captures agreement start and end dates, contracted service class, applicable rate schedule, minimum usage commitments, deposit requirements, special conditions, and agreement status. This is the SSOT for what service a customer account is enrolled in. Aligned with Oracle CC&B service agreement entity.'
}

Table service.point {
  point_id varchar [pk, note: 'Unique identifier for the service point. Primary key for the service point entity representing the physical location where utility service is delivered.']
  agreement_id varchar [note: 'Reference to the active service agreement contract that governs service delivery at this service point. Links the physical service point to the commercial customer relationship.']
  compliance_permit_id varchar [note: 'Foreign key linking to compliance.compliance_permit. Business justification: Service points (especially industrial discharge points) are directly tied to NPDES permits. Permits specify discharge locations; utility must map permit-to-service-point for DMR reporting, compliance ']
  dma_id varchar [note: 'Foreign key linking to distribution.dma. Business justification: Service points require DMA assignment for NRW analysis, consumption pattern tracking, leak detection planning, and zone-level service analytics. Replaces denormalized dma_code with proper FK enabling ']
  metering_meter_id varchar [note: 'Reference to the metering device currently installed at this service point for consumption measurement. Links to the asset registry meter record.']
  premise_id varchar [note: 'Reference to the premise (property or parcel) where this service point is located. A premise may contain multiple service points (e.g., separate water and wastewater connections).']
  pressure_zone_id varchar [note: 'Foreign key linking to distribution.pressure_zone. Business justification: Service points must reference pressure zones for hydraulic design validation, pressure guarantee compliance in SLAs, and service adequacy verification. Replaces denormalized pressure_zone_code with pr']
  registry_id varchar [note: 'Foreign key linking to asset.asset_registry. Business justification: Service points are physical infrastructure assets (service lines, curb stops, connections) requiring maintenance tracking, condition assessment, and replacement planning. Field crews need asset histor']
  service_class_id varchar [note: 'Foreign key linking to service.service_class. Business justification: Service points are classified by customer class (residential, commercial, industrial) which determines rate schedule, meter size requirements, and service level agreements. The customer_class STRING a']
  territory_id varchar [note: 'Foreign key linking to service.territory. Business justification: Service points (delivery locations) are geographically located within service territories. point has latitude, longitude, and address fields, which place it within a territory boundary. This FK establ']
  wtp_facility_id varchar [note: 'Foreign key linking to treatment.facility. Business justification: Service points receive water from specific treatment facilities - critical for water quality tracking (CT compliance, turbidity, chlorine residual), pressure zone management, and responding to custome']
  activation_date date [note: 'Date when service delivery was first activated at this service point, marking the beginning of billable service. May differ from installation date if there was a delay between physical installation and service turn-on.']
  ami_enabled boolean [note: 'Indicates whether this service point is equipped with Advanced Metering Infrastructure for automated remote meter reading and real-time consumption monitoring. True if AMI meter is installed; false for manual read meters.']
  backflow_device_type varchar [note: 'Type of backflow prevention device installed at this service point. RPZ is Reduced Pressure Zone; DCVA is Double Check Valve Assembly; PVB is Pressure Vacuum Breaker; AG is Air Gap; none indicates no device required; unknown indicates status not verified.']
  backflow_prevention_required boolean [note: 'Indicates whether a backflow prevention device is required at this service point based on hazard assessment and cross-connection control regulations. True if backflow prevention is mandated; false otherwise.']
  connection_material varchar [note: 'Material composition of the service line connecting the distribution main to the customer premises. Critical for Lead and Copper Rule Revisions (LCRR) compliance and service line inventory reporting. [ENUM-REF-CANDIDATE: copper|pvc|hdpe|galvanized_steel|lead|ductile_iron|pex|unknown — 8 candidates stripped; promote to reference product]']
  connection_size_inches decimal(5,2) [note: 'Diameter of the service connection pipe in inches, representing the physical capacity of the service line connecting the distribution main to the customer premises. Common sizes include 0.75, 1.0, 1.5, 2.0, 3.0, 4.0, 6.0, 8.0 inches.']
  created_by_user varchar [note: 'User identifier of the person or system process that created this service point record. Used for audit trail and accountability.']
  created_timestamp timestamp [note: 'Timestamp when this service point record was first created in the system. Used for audit trail and data lineage tracking.']
  curb_stop_location varchar [note: 'Description of the physical location of the curb stop valve (service shutoff valve) for this service point. Used by field crews for service disconnection and emergency shutoff.']
  disconnection_date date [note: 'Date when service was disconnected or terminated at this service point. Null if service is currently active.']
  elevation_feet decimal(8,2) [note: 'Ground elevation of the service point location in feet above mean sea level. Used for hydraulic modeling to calculate static pressure and pressure zone assignment.']
  estimated_daily_demand_gallons decimal(12,2) [note: 'Estimated average daily water demand at this service point in gallons, used for hydraulic modeling and capacity planning. Derived from historical consumption patterns or engineering estimates for new connections.']
  fire_service_indicator boolean [note: 'Indicates whether this service point includes fire protection service (fire sprinkler system or fire hydrant connection). True if fire service is provided; false for domestic-only service.']
  gis_feature_code varchar [note: 'Unique identifier linking this service point to its corresponding feature in the Esri ArcGIS utility network model. Enables spatial analysis and network tracing.']
  installation_date date [note: 'Date when the service point connection was physically installed and commissioned for service delivery. Used for asset age tracking and depreciation calculations.']
  last_inspection_date date [note: 'Date of the most recent field inspection or verification of this service point. Used for compliance tracking and preventive maintenance scheduling.']
  latitude decimal(10,7) [note: 'Geographic latitude coordinate of the service point location in decimal degrees, typically captured from Esri ArcGIS spatial data. Used for GIS mapping, network modeling, and spatial analytics.']
  longitude decimal(10,7) [note: 'Geographic longitude coordinate of the service point location in decimal degrees, typically captured from Esri ArcGIS spatial data. Used for GIS mapping, network modeling, and spatial analytics.']
  modified_by_user varchar [note: 'User identifier of the person or system process that last modified this service point record. Used for audit trail and accountability.']
  modified_timestamp timestamp [note: 'Timestamp when this service point record was last modified in the system. Used for audit trail and change tracking.']
  ownership_type varchar [note: 'Ownership responsibility for the service line infrastructure. Utility-owned indicates the utility maintains the entire service line; customer-owned indicates customer responsibility; shared indicates split ownership at a defined point (typically property line or curb stop).']
  peak_demand_gpm decimal(10,2) [note: 'Estimated peak instantaneous demand at this service point in gallons per minute, used for service line sizing and pressure analysis in hydraulic models.']
  point_name varchar
  point_status varchar
  point_type varchar
  rate_schedule_code decimal(18,6) [note: 'Identifier for the tariff rate schedule applied to this service point for billing purposes. Rate schedules define the pricing structure including base charges, volumetric rates, and tier thresholds.']
  route_code varchar [note: 'Identifier for the meter reading or field service route to which this service point is assigned. Used for scheduling meter reading, field inspections, and maintenance activities.']
  service_address_line1 varchar [note: 'Primary street address line of the physical location where service is delivered. Includes street number, street name, and street type.']
  service_address_line2 varchar [note: 'Secondary address line for apartment number, suite, unit, building, or other location qualifier at the service point address.']
  service_city varchar [note: 'City or municipality name where the service point is located.']
  service_country_code varchar [note: 'Three-letter ISO 3166-1 alpha-3 country code where the service point is located (e.g., USA, CAN, MEX).']
  service_point_description varchar [note: 'Free-text description providing additional context about the service point location, special characteristics, or access instructions for field personnel.']
  service_point_number varchar [note: 'Externally-known business identifier for the service point, typically displayed on customer bills and used in customer service interactions. Unique across the utility service territory.']
  service_point_status varchar [note: 'Current operational status of the service point in its lifecycle. Active indicates service is being delivered; inactive indicates no current service; suspended indicates temporary service hold; pending_activation indicates awaiting turn-on; disconnected indicates service terminated; abandoned indicates permanently retired.']
  service_postal_code varchar [note: 'ZIP code or postal code of the service point location, supporting 5-digit or 9-digit (ZIP+4) formats.']
  service_state varchar [note: 'Two-letter state or province code where the service point is located, following USPS state abbreviation standards.']
  service_type varchar [note: 'Type of utility service delivered at this service point. Potable water is drinking water distribution; wastewater is sanitary sewer collection; recycled water is reclaimed water for irrigation or industrial use; stormwater is surface water drainage; combined is combined sewer system.']

  Note: 'Represents the physical location where a utility service is delivered to a customer, corresponding to a metered connection point on the distribution or wastewater network. Captures the service point address, GIS coordinates (Esri ArcGIS), service type (potable water, wastewater, recycled water), connection size (pipe diameter in inches), pressure zone, DMA assignment, and active status. Links the commercial service agreement to the physical network infrastructure.'
}

Table service.connection_application {
  connection_application_id varchar [pk, note: 'Unique identifier for the connection application record. Primary key.']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Connection applications requiring infrastructure upgrades (main extensions, pump station capacity, treatment plant expansion) trigger or are bundled into CIP projects. Applicants and customer service ']
  connection_customer_account_id varchar [note: 'Identifier of the customer account associated with this connection application. Links to the customer master record.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Connection activities (engineering review, field inspection, installation) are cost-accounted by department for rate-making, cost recovery analysis, and connection fee justification. Essential for rat']
  dma_id varchar [note: 'Foreign key linking to distribution.dma. Business justification: New connections must be assigned to DMAs for capacity planning, NRW impact assessment, metering infrastructure planning, and zone-level demand forecasting. Essential for evaluating capacity_available ']
  employee_id varchar [note: 'Name or identifier of the staff member or team assigned to review and process the connection application.']
  location_id varchar [note: 'Foreign key linking to asset.asset_location. Business justification: New connection applications require infrastructure capacity assessment at specific asset locations (pump stations, pressure zones, treatment facilities). Engineering reviews check available capacity, ']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Connection applications specify required materials (meter size/type, service line diameter, backflow device model) that must be validated against material master for availability, lead time, NSF/AWWA ']
  meter_size_type_id varchar [note: 'Foreign key linking to metering.meter_size_type. Business justification: Connection applications specify required meter size based on estimated demand (GPM). Engineering review validates sizing against meter_size_type specifications (max flow, pressure rating, accuracy cla']
  offering_id varchar [note: 'Foreign key linking to service.offering. Business justification: Connection applications request a specific service offering from the catalog. connection_application currently has requested_service_type as a STRING field, which should be normalized to reference the']
  payment_id varchar [note: 'Foreign key linking to billing.payment. Business justification: Connection applications require upfront fee payment (application fee, connection fee, capacity charge) before approval. New service application processing depends on verifying payment receipt and clea']
  pressure_zone_id varchar [note: 'Foreign key linking to distribution.pressure_zone. Business justification: New connection applications require pressure zone assignment for hydraulic capacity verification, infrastructure adequacy assessment, and pressure guarantee feasibility before approval. Critical for c']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: New connection applications must comply with regulatory requirements (backflow prevention, cross-connection control, capacity standards, water quality). Application review process validates against ap']
  territory_id varchar [note: 'Foreign key linking to service.service_territory. Business justification: Connection applications are submitted for service within a specific franchise territory. The service_address fields are application-specific and should be retained, but a FK to service_territory is ne']
  work_order_id varchar [note: 'Identifier of the work order created to execute the physical connection installation. Links to the work order management system.']
  ami_enabled boolean [note: 'Indicates whether the connection will be equipped with Advanced Metering Infrastructure (AMI) for automated meter reading and real-time monitoring.']
  applicant_email varchar [note: 'Primary email address of the applicant for correspondence and notifications regarding the connection application.']
  applicant_name varchar [note: 'Full legal name of the individual or organization applying for the service connection.']
  applicant_phone varchar [note: 'Primary contact phone number of the applicant for communication regarding the connection application.']
  application_date date [note: 'Date when the connection application was formally submitted by the applicant.']
  application_fee_amount decimal(10,2) [note: 'Fee charged for processing the connection application, in USD.']
  application_number varchar [note: 'Externally-visible unique application number assigned to the connection request. Format: CA-YYYYNNNN.']
  application_status varchar [note: 'Current lifecycle status of the connection application in the approval workflow. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|on_hold|completed|cancelled — 8 candidates stripped; promote to reference product]']
  application_type varchar [note: 'Type of service connection application: new connection, service upgrade, disconnection, transfer of service, reconnection, or temporary service.']
  approval_date date [note: 'Date when the connection application was officially approved by the utility.']
  capacity_available boolean [note: 'Indicates whether sufficient system capacity (pressure, flow, treatment capacity) is available to serve the requested connection without infrastructure upgrades.']
  capacity_charge_amount decimal(10,2) [note: 'System development or capacity charge assessed to fund infrastructure expansion to serve the new connection, in USD.']
  completion_date date [note: 'Date when the physical service connection was completed and the service was activated.']
  connection_application_status varchar
  connection_fee_amount decimal(10,2) [note: 'One-time connection or tap fee assessed for establishing the new service connection, in USD.']
  connection_size_inches decimal(5,2) [note: 'Diameter of the requested service connection in inches (e.g., 0.75, 1.0, 1.5, 2.0). Critical for capacity planning and meter sizing.']
  created_timestamp timestamp [note: 'Timestamp when the connection application record was first created in the system.']
  estimated_flow_demand_gpm decimal(10,2) [note: 'Estimated peak flow demand in gallons per minute (GPM) for the requested service connection. Used for hydraulic modeling and capacity verification.']
  infrastructure_upgrade_required boolean [note: 'Indicates whether main extensions, pump station upgrades, or other infrastructure improvements are required to serve the connection.']
  meter_size_requested decimal(4,2)
  meter_type_requested varchar [note: 'Type or model of water meter requested or recommended for the connection (e.g., positive displacement, turbine, compound, electromagnetic).']
  modified_timestamp timestamp [note: 'Timestamp when the connection application record was last modified or updated.']
  notes varchar [note: 'Free-text notes and comments regarding the connection application, including special requirements, site conditions, or coordination details.']
  number_of_units varchar [note: 'Number of dwelling units, commercial units, or service points at the property (e.g., apartments in a multi-family building).']
  payment_status decimal(18,2) [note: 'Status of fee payment for the connection application: unpaid, partially paid, fully paid, waived, or refunded.']
  property_type varchar [note: 'Classification of the property requesting service: residential, commercial, industrial, institutional, agricultural, or mixed-use.']
  rejection_date date [note: 'Date when the connection application was rejected or denied by the utility.']
  rejection_reason varchar [note: 'Detailed explanation of why the connection application was rejected (e.g., insufficient capacity, incomplete documentation, non-compliance with standards).']
  requested_service_date date [note: 'Date by which the applicant requests the service connection to be activated or completed.']
  service_address_line1 varchar [note: 'Primary street address line where the water or wastewater service connection is requested.']
  service_address_line2 varchar [note: 'Secondary address line (apartment, suite, unit number) for the service location.']
  service_city varchar [note: 'City or municipality where the service connection is requested.']
  service_latitude decimal(10,7) [note: 'Geographic latitude coordinate of the service connection location for GIS mapping and network planning.']
  service_longitude decimal(10,7) [note: 'Geographic longitude coordinate of the service connection location for GIS mapping and network planning.']
  service_postal_code varchar [note: 'Postal or ZIP code for the service address.']
  service_state varchar [note: 'Two-letter state or province code where the service connection is requested.']
  service_type varchar
  technical_review_date date [note: 'Date when the technical feasibility and capacity review of the connection application was completed.']
  total_fees_assessed decimal(10,2) [note: 'Total of all fees assessed for the connection application (application fee, connection fee, capacity charge, and any other charges), in USD.']

  Note: 'Tracks customer applications for new service connections, service upgrades, disconnections, and transfers. Captures application date, requested service type, service address, applicant details, connection size requested, estimated flow demand (GPM), application status, review milestones, fees assessed, and approval or rejection details. Supports the new service onboarding workflow and capacity planning. Aligned with Microsoft Dynamics 365 field service request intake.'
}

Table service.order {
  order_id varchar [pk, note: 'Unique identifier for the service order. Primary key for the service order entity.']
  agreement_id varchar [note: 'Foreign key linking to service.service_agreement. Business justification: Service orders (turn-on, turn-off, meter change, maintenance) are performed in the context of a service agreement. Adding service_agreement_id FK establishes the agreement context for the service orde']
  assigned_crew_id varchar [note: 'Reference to the field crew or work team assigned to perform the service order.']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Service orders for new connections or upgrades may be contingent on CIP project completion (e.g., service available after main extension project completes). Customer service and field operations need ']
  connection_application_id varchar [note: 'Foreign key linking to service.connection_application. Business justification: Service orders are often generated from approved connection applications (new service installations, upgrades). Adding connection_application_id FK tracks the originating application that triggered th']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Field service operations (meter reads, turn-ons, repairs) are tracked by cost center for labor cost allocation, overhead rate calculation, and rate case cost-of-service studies. Direct operational cos']
  created_by_user_employee_id varchar [note: 'System user identifier of the person or process that created the service order record.']
  dma_id varchar [note: 'Foreign key linking to distribution.dma. Business justification: Service orders require DMA assignment for operational planning, NRW event correlation (service work causing leaks), zone-based work scheduling, and DMA-level service activity tracking. Essential for c']
  employee_id varchar [note: 'Reference to the individual field technician assigned to perform the service order.']
  material_requisition_id varchar [note: 'Foreign key linking to supply.material_requisition. Business justification: Field service orders (meter replacements, service line repairs, new connections) trigger material requisitions to pull inventory from warehouse. Critical for work order planning, inventory allocation,']
  modified_by_user_employee_id varchar [note: 'System user identifier of the person or process that last modified the service order record.']
  order_customer_account_id varchar [note: 'Reference to the customer account associated with this service order.']
  point_id varchar [note: 'Reference to the physical service delivery point (meter location) where the field activity will be performed.']
  premise_id varchar [note: 'Reference to the premise (property/location) where the service order activity will occur.']
  pressure_zone_id varchar [note: 'Foreign key linking to distribution.pressure_zone. Business justification: Service orders (connect/disconnect/repair) need pressure zone context for crew routing optimization, pressure impact assessment during isolation events, service restoration verification, and zone-base']
  primary_order_created_by_user_employee_id varchar [note: 'System user identifier of the person or process that created the service order record.']
  primary_order_metering_meter_id varchar [note: 'Serial number or identifier of the meter removed during a meter exchange service order.']
  registry_id varchar [note: 'Foreign key linking to asset.asset_registry. Business justification: Service orders (meter installation, valve operation, service line repair) target specific assets requiring maintenance history, condition data, and warranty information. Field technicians need asset s']
  sla_definition_id varchar [note: 'Foreign key linking to service.sla_definition. Business justification: Service orders are executed according to defined SLA standards. order currently has sla_target_hours, sla_actual_hours, and sla_met_flag. The target hours should be derived from sla_definition rather ']
  tertiary_order_modified_by_user_employee_id varchar [note: 'System user identifier of the person or process that last modified the service order record.']
  wtp_facility_id varchar [note: 'Foreign key linking to treatment.facility. Business justification: Service orders (new connections, reconnections) require verification that source facility can meet pressure/flow requirements and that water quality meets standards at time of service. Operations team']
  actual_end_time timestamp [note: 'Actual date and time when the field crew completed the service order activity.']
  actual_start_time timestamp [note: 'Actual date and time when the field crew began performing the service order activity.']
  appointment_window_end timestamp [note: 'End of the time window communicated to the customer for the service order appointment.']
  appointment_window_start timestamp [note: 'Beginning of the time window communicated to the customer for the service order appointment.']
  billable_flag boolean [note: 'Indicates whether the service order activity is billable to the customer account.']
  cancellation_reason varchar [note: 'Explanation for why the service order was cancelled, if applicable.']
  completed_date date
  completion_date date [note: 'Date when the service order was marked as completed in the system.']
  created_timestamp timestamp [note: 'Date and time when the service order record was first created in the system.']
  customer_contact_name varchar [note: 'Name of the customer contact person for this service order, used for appointment confirmation and access coordination.']
  customer_contact_phone varchar [note: 'Phone number of the customer contact person for appointment confirmation and field crew communication.']
  gps_latitude decimal(10,7) [note: 'Geographic latitude coordinate of the service location, used for crew dispatch and asset tracking.']
  gps_longitude decimal(10,7) [note: 'Geographic longitude coordinate of the service location, used for crew dispatch and asset tracking.']
  meter_reading_unit varchar [note: 'Unit of measure for the meter reading value captured during the service order.']
  meter_reading_value decimal(12,3) [note: 'Final meter reading captured during the service order activity, measured in appropriate units (gallons, cubic meters, etc.).']
  modified_timestamp timestamp [note: 'Date and time when the service order record was last modified in the system.']
  order_date date
  order_number varchar [note: 'Externally visible business identifier for the service order, used for customer communication and field crew reference.']
  order_status varchar [note: 'Current lifecycle status of the service order in the field service workflow. [ENUM-REF-CANDIDATE: draft|scheduled|dispatched|in_progress|completed|cancelled|on_hold — 7 candidates stripped; promote to reference product]']
  order_type varchar [note: 'Classification of the service order activity. Defines the nature of field work to be performed. [ENUM-REF-CANDIDATE: turn_on|turn_off|reconnection|meter_set|meter_exchange|service_upgrade|final_read|leak_investigation — 8 candidates stripped; promote to reference product]']
  outcome_code varchar [note: 'Standardized code indicating the final outcome or result of the service order execution.']
  priority varchar [note: 'Priority level assigned to the service order, determining dispatch sequence and response time requirements.']
  requested_date date [note: 'Date when the customer or system requested the service order to be performed.']
  scheduled_date date [note: 'Date when the field crew is scheduled to perform the service order activity.']
  scheduled_end_time timestamp [note: 'Planned date and time when the field crew is expected to complete the service order activity.']
  scheduled_start_time timestamp [note: 'Precise date and time when the field crew is scheduled to begin the service order activity.']
  service_address varchar [note: 'Full street address where the field service activity will be performed. Used for crew dispatch and navigation.']
  service_fee_amount decimal(10,2) [note: 'Monetary charge assessed to the customer for the service order activity, in US dollars.']
  sla_actual_hours decimal(6,2) [note: 'Actual number of hours elapsed from order creation to completion, used for SLA compliance tracking.']
  sla_met_flag boolean [note: 'Indicates whether the service order was completed within the target SLA timeframe.']
  special_instructions varchar [note: 'Additional instructions or notes for the field crew regarding access, safety, or customer requirements.']
  work_performed_description varchar [note: 'Detailed narrative description of the work actually performed by the field crew, including any findings or issues encountered.']

  Note: 'Operational work orders issued to field crews for service-related activities including new service turn-ons, turn-offs, reconnections after non-payment, meter sets, service upgrades, and final reads. Captures order type, scheduled date, completion date, assigned crew, service point reference, work performed, and outcome status. Distinct from asset maintenance work orders (owned by asset domain). Aligned with Oracle CC&B field activity and Microsoft Dynamics 365 field service.'
}

Table service.sla_definition {
  sla_definition_id varchar [pk, note: 'Unique identifier for the service level agreement definition record.']
  service_class_id varchar [note: 'Foreign key linking to service.service_class. Business justification: Service level agreements vary by customer service class, with different response time targets and compliance requirements for residential vs. commercial vs. industrial customers. The service_class STR']
  service_offering_id varchar [note: 'Reference to the service offering or service class to which this SLA applies.']
  tariff_id varchar [note: 'Foreign key linking to service.tariff. Business justification: SLA definitions are documented in tariff filings and are subject to regulatory approval. The tariff_reference STRING attribute should be normalized to a FK to tariff, allowing JOIN to retrieve tariff_']
  approval_authority varchar [note: 'Regulatory body or internal authority that approved this SLA definition, such as Public Utilities Commission, State Primacy Agency, or internal executive committee.']
  approval_date date [note: 'Date on which this SLA definition was approved by the Public Utilities Commission or internal governance authority.']
  compliance_percentage decimal(5,2) [note: 'Required percentage of time or occurrences that the SLA target must be met to maintain compliance, expressed as a percentage (e.g., 99.5% for high-availability commitments).']
  created_timestamp timestamp [note: 'Timestamp when this SLA definition record was first created in the system.']
  effective_end_date date [note: 'Date on which this SLA definition expires or is superseded by a new version. Null indicates the SLA is currently active with no defined end date.']
  effective_start_date date [note: 'Date on which this SLA definition becomes effective and enforceable, typically aligned with rate case approval or tariff filing effective date.']
  escalation_procedure varchar [note: 'Defined escalation path or procedure to be followed when the SLA is breached, including management notification, regulatory reporting, and customer communication steps.']
  exclusion_conditions varchar [note: 'Conditions or circumstances under which the SLA does not apply or is temporarily suspended, such as force majeure events, natural disasters, regulatory-mandated shutdowns, or customer-requested service interruptions.']
  geographic_scope varchar [note: 'Geographic area or service territory to which this SLA applies: system-wide across all service areas, specific district, pressure zone, District Metered Area (DMA), or specific customer location.']
  is_active boolean
  last_modified_timestamp timestamp [note: 'Timestamp when this SLA definition record was last updated or modified.']
  maximum_value decimal(18,4) [note: 'Maximum acceptable value for the SLA metric, above which the SLA is considered breached. Applicable for metrics with upper bounds such as Maximum Contaminant Level (MCL), turbidity (NTU), or response time.']
  measurement_frequency varchar [note: 'Frequency at which the SLA metric is measured or evaluated: continuous monitoring via SCADA, periodic sampling, or event-based measurement triggered by specific conditions. [ENUM-REF-CANDIDATE: continuous|hourly|daily|weekly|monthly|quarterly|annual|event_based — 8 candidates stripped; promote to reference product]']
  metric_name varchar [note: 'Specific metric or parameter being measured for this SLA, such as \'Outage Response Time\', \'Service Restoration Time\', \'Minimum Water Pressure (PSI)\', \'Maximum Turbidity (NTU)\', \'pH Range\', \'Maximum Contaminant Level (MCL)\', or \'Notification Time\'.']
  minimum_value decimal(18,4) [note: 'Minimum acceptable value for the SLA metric, below which the SLA is considered breached. Applicable for metrics with lower bounds such as minimum water pressure (PSI) or minimum pH.']
  notes varchar [note: 'Additional notes, comments, or clarifications regarding the SLA definition, including historical context, implementation guidance, or special considerations.']
  notification_method varchar [note: 'Communication channels required for customer or regulatory notification, such as email, SMS, phone call, postal mail, public notice, website posting, or media announcement. Multiple methods may be specified.']
  notification_requirement varchar [note: 'Timeframe within which customers or regulatory agencies must be notified of an SLA breach or service issue, such as immediate notification for water quality violations or 24-hour notice for planned outages.']
  penalty_amount decimal(15,2) [note: 'Monetary value of the penalty, credit, or rebate applied per SLA breach, expressed in the utility\'s operating currency.']
  penalty_calculation_method varchar [note: 'Method used to calculate the penalty or credit: fixed amount per breach, per occurrence, per hour of non-compliance, per day, percentage of customer bill, or tiered based on severity or duration.']
  penalty_type varchar [note: 'Type of penalty or consequence applied when the SLA is breached: customer credit, service rebate, regulatory fine, escalation to management, or no penalty.']
  regulatory_basis varchar [note: 'Legal or regulatory framework that mandates or informs this SLA commitment, such as Safe Drinking Water Act (SDWA), state primacy agency rules, Public Utilities Commission orders, or American Water Works Association (AWWA) standards.']
  reporting_requirement varchar [note: 'Frequency and type of reporting required for SLA compliance monitoring, such as monthly performance reports to the Public Utilities Commission, quarterly customer reports, or annual Consumer Confidence Report (CCR) inclusion.']
  sla_code varchar [note: 'Business identifier code for the SLA definition, used for external reference and regulatory tariff filings.']
  sla_definition_description varchar [note: 'Detailed description of the SLA commitment, including the business purpose, customer benefit, and operational context.']
  sla_definition_status varchar [note: 'Current lifecycle status of the SLA definition: active and enforceable, inactive, pending regulatory approval, superseded by a newer version, or temporarily suspended.']
  sla_name varchar [note: 'Human-readable name of the SLA definition, describing the commitment or guarantee.']
  sla_type varchar [note: 'Category of SLA commitment: response time for outage acknowledgment, restoration time for service recovery, water quality guarantee parameters, pressure guarantee thresholds, customer notification requirements, or system availability targets.']
  target_resolution_hours decimal(8,2)
  target_response_hours decimal(8,2)
  target_value decimal(18,4) [note: 'Numeric target or threshold value for the SLA metric, representing the committed performance level or guarantee.']
  unit_of_measure varchar [note: 'Unit of measurement for the SLA metric, such as \'minutes\', \'hours\', \'PSI (Pounds per Square Inch)\', \'NTU (Nephelometric Turbidity Units)\', \'mg/L\', \'pH units\', or \'percent\'.']

  Note: 'Defines the service level agreements applicable to each service offering or service class, including response time commitments for outages, restoration time targets, water quality guarantee parameters, pressure guarantee thresholds (PSI), and customer notification requirements. Captures SLA type, metric name, target value, measurement unit, regulatory basis (SDWA, state rules), and penalty or credit terms for non-compliance. Supports regulatory tariff compliance and customer service commitments.'
}

Table service.tariff {
  tariff_id varchar [pk, note: 'Unique identifier for the regulatory tariff filing record. Primary key.']
  finance_rate_case_id varchar [note: 'Foreign key linking to finance.rate_case. Business justification: Tariffs are the direct regulatory output of rate case proceedings. Every tariff must reference the rate case docket that established it. Core regulatory compliance relationship for PUC/PSC reporting a']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Tariffs must comply with regulatory requirements (rate structure mandates, affordability requirements, conservation pricing rules). Tariff filings reference compliance with state/federal mandates. Lin']
  service_class_id varchar [note: 'Foreign key linking to service.service_class. Business justification: Tariff filings are class-specific, with separate rate schedules and regulatory approvals for each customer class. The customer_class STRING attribute should be normalized to a FK to service_class, all']
  superseded_tariff_id varchar [note: 'Reference to the prior tariff that this tariff replaces. Establishes the lineage of rate changes and enables historical rate analysis.']
  territory_id varchar [note: 'Foreign key linking to service.service_territory. Business justification: Tariffs apply to specific service territories and franchise areas. Currently service_territory is a STRING field describing where the tariff applies. Should be FK to service_territory for referential ']
  adjustment_clause_flag boolean [note: 'Indicates whether the tariff includes automatic adjustment clauses or riders that allow for rate changes without a full rate case. Common adjustment clauses include purchased water adjustment clauses (PWAC), infrastructure surcharges, and cost recovery mechanisms for specific capital programs.']
  approval_date date [note: 'The date on which the regulatory authority formally approved the tariff filing. This date may differ from the effective date due to statutory notice periods or phased implementation.']
  approval_order_number varchar [note: 'The official order or docket number issued by the regulatory authority approving this tariff. This reference links the tariff to the formal regulatory decision and provides traceability to the rate case proceeding.']
  base_rate_amount decimal(15,4) [note: 'The foundational rate component approved by the regulatory authority, typically expressed as a fixed monthly charge or per-unit volumetric rate. This is the core revenue component before adjustments, surcharges, or riders.']
  billing_frequency varchar [note: 'The standard billing cycle for customers under this tariff. Defines how often charges are calculated and invoices are issued.']
  conservation_rate_flag boolean [note: 'Indicates whether the tariff incorporates conservation-oriented rate design features such as increasing block rates, seasonal pricing, or water budget-based rates intended to promote efficient water use.']
  cost_of_service_study_reference decimal(18,2) [note: 'Reference to the cost-of-service study or rate design analysis that supports the tariff rates. This study allocates utility costs to customer classes and justifies the rate structure to the regulatory authority.']
  created_timestamp timestamp [note: 'The date and time when this tariff record was first created in the system. Supports audit trail and data lineage tracking.']
  currency_code varchar [note: 'The three-letter ISO 4217 currency code in which tariff rates and charges are denominated. For U.S. water utilities, this is typically USD.']
  document_url varchar [note: 'The web address or document management system link to the official tariff filing document, including all schedules, exhibits, and supporting materials. Provides direct access to the complete regulatory record.']
  effective_date date [note: 'The date on which the tariff becomes binding and enforceable. Rates and terms specified in the tariff apply to all qualifying service from this date forward.']
  expiration_date date [note: 'The date on which the tariff ceases to be in force, if applicable. Null for tariffs that remain active until superseded by a subsequent filing.']
  filing_date date [note: 'The date on which the tariff was officially filed with the Public Utilities Commission or state regulatory authority. This date triggers statutory review periods and notice requirements.']
  hearing_date date [note: 'The date of the public hearing or evidentiary proceeding held by the regulatory authority to review the tariff filing. Null if no hearing was required or held.']
  last_modified_timestamp timestamp [note: 'The date and time when this tariff record was most recently updated. Supports change tracking and audit compliance.']
  low_income_assistance_flag boolean [note: 'Indicates whether the tariff includes provisions for low-income customer assistance programs, such as lifeline rates, bill discounts, or affordability programs mandated or approved by the regulatory authority.']
  minimum_charge_amount decimal(15,4) [note: 'The minimum monthly or periodic charge that applies regardless of consumption. Ensures cost recovery for fixed infrastructure and customer service costs.']
  notes varchar [note: 'Free-form text field for additional context, clarifications, or special conditions related to the tariff. May include notes on implementation, transition provisions, or regulatory stipulations.']
  public_notice_date date [note: 'The date on which public notice of the tariff filing was provided to customers and stakeholders, as required by regulatory statute. Public notice periods allow for customer comment and intervention in rate proceedings.']
  rate_base_amount decimal(18,2) [note: 'The net investment in utility plant and working capital upon which the utility is allowed to earn a return. Rate base is calculated as gross plant in service less accumulated depreciation plus working capital allowances.']
  rate_of_return_percent decimal(5,4) [note: 'The allowed rate of return on rate base approved by the regulatory authority. Expressed as a decimal percentage (e.g., 0.0725 for 7.25%). This is the weighted average cost of capital (WACC) the utility is permitted to earn.']
  rate_schedule_reference decimal(18,6) [note: 'Reference to the detailed rate schedule document or section number within the tariff filing that specifies the complete pricing structure, including block tiers, surcharges, and adjustments.']
  rate_structure_type decimal(18,6) [note: 'The pricing methodology employed by the tariff. Flat rates charge a fixed amount regardless of usage, uniform rates charge a constant per-unit price, declining block rates decrease with higher usage tiers, increasing block rates increase with higher usage tiers to promote conservation, seasonal rates vary by time of year, and time-of-use rates vary by time of day or demand period.']
  regulatory_authority varchar [note: 'The name of the Public Utilities Commission, state regulatory agency, or other governing body that has jurisdiction over this tariff filing. Examples include State Public Service Commission, Public Utilities Commission, or Department of Public Utilities.']
  revenue_requirement_amount decimal(18,2) [note: 'The total annual revenue requirement approved by the regulatory authority for the utility under this tariff. This is the aggregate revenue the utility is authorized to collect to cover operating expenses, capital costs, and allowed return on investment.']
  service_rules_reference varchar [note: 'Reference to the service rules, terms, and conditions document or section number within the tariff filing that governs service delivery, customer obligations, disconnection policies, and dispute resolution procedures.']
  tariff_code varchar
  tariff_description varchar [note: 'A detailed narrative description of the tariff, including its purpose, scope, applicability, and key terms. This field captures the regulatory intent and business context of the tariff.']
  tariff_name varchar [note: 'The official name or title of the tariff as it appears in regulatory filings and customer communications.']
  tariff_number varchar [note: 'The official regulatory tariff number assigned by the Public Utilities Commission or state regulatory authority. This is the externally-known identifier used in all regulatory filings and rate case proceedings.']
  tariff_status varchar [note: 'Current lifecycle status of the tariff filing. Draft indicates internal preparation, filed means submitted to the regulator, pending approval is under regulatory review, approved means accepted by the commission, active is currently in force, suspended is temporarily halted, superseded is replaced by a newer tariff, and withdrawn is retracted before approval. [ENUM-REF-CANDIDATE: draft|filed|pending_approval|approved|active|suspended|superseded|withdrawn — 8 candidates stripped; promote to reference product]']
  tariff_type varchar [note: 'Classification of the tariff based on the customer segment and service arrangement it governs. General service tariffs apply to standard retail customers, special contracts cover negotiated agreements with large users, wholesale tariffs govern bulk water sales to other utilities, and industrial/municipal/residential/commercial designate specific customer classes. [ENUM-REF-CANDIDATE: general_service|special_contract|wholesale|industrial|municipal|residential|commercial — 7 candidates stripped; promote to reference product]']

  Note: 'Master record of regulatory tariff filings and associated rate case proceedings with the Public Utilities Commission or state regulatory authority. Captures the full lifecycle from rate case filing (test year, requested revenue requirement, hearing dates, intervenor parties) through approval (final order, approved revenue requirement) to the effective tariff (tariff number, effective date, tariff type, incorporated rate schedules and service rules). This is the regulatory anchor for all rate and service term compliance, linking rate case proceedings to their resulting approved pricing structures. Supports financial planning, regulatory compliance, and rate modeling.'
}

Table service.service_rate_case {
  service_rate_case_id varchar [pk, note: 'Unique identifier for the service_rate_case data product (auto-inserted pre-linking).']
  finance_rate_case_id varchar [note: 'Canonical single-source-of-truth reference to finance.finance_rate_case (finance_rate_case_id); this entity defers authoritative attribute values to that master entity.']
  regulatory_agency_id varchar [note: 'Regulatory agency overseeing the case']
  service_class_id varchar [note: 'Foreign key linking to service.service_class. Business justification: Rate case proceedings can be class-specific (e.g., residential rate case, industrial rate case) or apply to all classes. This FK allows rate cases to be scoped to specific customer service classes whe']
  territory_id varchar [note: 'Foreign key linking to service.territory. Business justification: Rate case proceedings can be territory-specific or system-wide. Water utilities often file rate cases for specific franchise areas or service territories. This FK allows rate cases to be scoped to the']
  affordability_ratio_pct decimal(6,2) [note: 'Affordability ratio (water bill / median income)']
  approved_increase_pct decimal(8,4)
  approved_increase_percentage decimal(5,2) [note: 'Approved percentage increase']
  approved_percentage decimal(5,2)
  approved_rate_increase_pct decimal(6,2)
  approved_revenue_amount decimal(18,2) [note: 'Approved additional revenue amount']
  approved_revenue_increase decimal(18,2) [note: 'Approved revenue increase']
  approved_revenue_increase_amount decimal(18,2)
  approved_revenue_increase_pct decimal(8,4) [note: 'Approved revenue increase percentage']
  approved_revenue_increase_usd decimal(18,2)
  approved_revenue_requirement decimal(18,2) [note: 'Approved revenue requirement']
  authorized_roe_pct decimal(6,4) [note: 'Authorized return on equity percentage']
  capital_structure_equity_pct decimal(6,4) [note: 'Equity component of capital structure']
  case_name varchar [note: 'Rate case name']
  case_number varchar
  case_status varchar
  case_title varchar [note: 'Title of the rate case']
  case_type varchar [note: 'Type of rate case']
  cost_of_capital_pct decimal(6,4) [note: 'Cost of capital percentage']
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp [note: 'Record creation timestamp']
  currency_code varchar [note: 'Currency code']
  current_revenue_requirement decimal(18,2) [note: 'Current revenue requirement']
  customer_impact_avg_monthly decimal(18,2) [note: 'Average monthly customer impact']
  customer_impact_avg_monthly_usd decimal(18,2) [note: 'Average monthly bill impact in USD']
  data_quality_flag boolean [note: 'True when record passed data validation.']
  decision_date date
  depreciation_expense decimal(18,2) [note: 'Depreciation expense']
  docket_number varchar [note: 'Regulatory docket number']
  effective_date date [note: 'Date new rates become effective']
  filed_date date [note: 'Date filed.']
  filing_date date
  hearing_date date [note: 'Hearing date']
  implementation_date date [note: 'Implementation date']
  intervenor_count varchar [note: 'Number of intervenors in the case']
  intervenors varchar [note: 'List of intervenors']
  is_active boolean
  is_approved boolean
  is_closed boolean [note: 'Whether the rate case is closed.']
  last_modified_timestamp timestamp
  notes varchar [note: 'Case notes']
  operating_expense decimal(18,2) [note: 'Operating expense']
  phase_in_flag boolean [note: 'Whether rate increase is phased in']
  phase_in_periods varchar [note: 'Number of phase-in periods']
  phase_in_required boolean [note: 'Whether phase-in required']
  phase_in_schedule varchar [note: 'Phase-in schedule if applicable']
  proposed_revenue_requirement decimal(18,2) [note: 'Proposed revenue requirement']
  public_comment_deadline date [note: 'Deadline for public comments']
  public_comment_period_end date [note: 'Public comment period end date']
  public_hearing_count varchar
  public_hearing_date date [note: 'Date of public hearing']
  rate_base decimal(18,2) [note: 'Rate base amount']
  rate_base_amount decimal(18,2) [note: 'Utility rate base amount']
  rate_base_usd decimal(18,2) [note: 'Approved rate base in USD']
  rate_case_name varchar
  rate_case_number varchar
  rate_case_status varchar
  rate_case_type varchar
  rate_consultant varchar
  record_status varchar
  regulatory_agency varchar [note: 'Regulatory agency']
  regulatory_authority varchar
  regulatory_authority_name varchar
  regulatory_body varchar
  regulatory_commission varchar [note: 'Regulatory commission/PUC name']
  requested_increase_pct decimal(8,4)
  requested_increase_percentage decimal(5,2) [note: 'Requested percentage increase']
  requested_percentage decimal(5,2)
  requested_rate_increase_pct decimal(6,2)
  requested_revenue_amount decimal(18,2) [note: 'Requested additional revenue amount']
  requested_revenue_increase decimal(18,2) [note: 'Requested revenue increase']
  requested_revenue_increase_amount decimal(18,2)
  requested_revenue_increase_pct decimal(8,4) [note: 'Requested revenue increase percentage']
  requested_revenue_increase_usd decimal(18,2)
  return_on_equity_pct decimal(6,4) [note: 'Authorized return on equity']
  revenue_requirement varchar
  revenue_requirement_usd decimal(18,2)
  service_rate_case_description varchar [note: 'Description of the rate case']
  service_rate_case_status varchar [note: 'Case status (filed, under review, hearing, decided, closed)']
  test_year varchar
  test_year_end date [note: 'End of the test year']
  test_year_end_date date [note: 'Test year end']
  test_year_start date [note: 'Start of the test year used in the filing']
  test_year_start_date date [note: 'Test year start']
  total_cost decimal(18,2)
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp']

  Note: 'Tracks the lifecycle of regulatory rate case proceedings filed with the Public Utilities Commission or state regulatory authority to adjust water and wastewater service rates. Captures filing date, test year, requested revenue requirement, approved revenue requirement, rate case status, hearing dates, intervenor parties, final order date, and the resulting approved tariff reference. Supports financial planning, regulatory compliance, and rate modeling. [SSOT: governed by finance.finance_rate_case] [DEPRECATED: Single source of truth is finance.finance_rate_case]'
}

Table service.special_contract {
  special_contract_id varchar [pk, note: 'Unique identifier for the special contract record. Primary key.']
  agreement_id varchar [note: 'Foreign key linking to service.service_agreement. Business justification: Special contracts are negotiated agreements that extend or modify standard service agreements. Currently has customer_account_id but missing the service_agreement link. Special contracts should refere']
  billing_account_id varchar [note: 'Foreign key linking to billing.billing_account. Business justification: Special contracts (large industrial users, negotiated rates) require dedicated billing accounts with custom rate structures. Contract billing administration depends on linking the contract to the bill']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Large industrial or municipal customers under special contracts often have dedicated infrastructure projects (dedicated treatment capacity, private mains, interconnections). Contract compliance, capit']
  customer_account_id varchar [note: 'Reference to the large industrial, municipal, or wholesale customer party under this special contract.']
  finance_rate_case_id varchar [note: 'Foreign key linking to finance.rate_case. Business justification: Special contracts require rate case approval or tariff deviation justification. Links negotiated rates to regulatory proceedings for PUC compliance, cost-of-service justification, and audit trails. Re']
  fund_id varchar [note: 'Foreign key linking to finance.fund. Business justification: Special contracts (large industrial users) require dedicated fund accounting for revenue tracking, regulatory reporting, and rate case revenue requirement analysis. Essential for wholesale/industrial ']
  pretreatment_iup_id varchar [note: 'Foreign key linking to compliance.pretreatment_iup. Business justification: Special contracts for industrial users reference their IUP (Industrial User Permit). Contract terms (volume, discharge limits, pricing) must align with pretreatment permit conditions. Links billing, s']
  territory_id varchar
  amendment_count varchar [note: 'Total number of amendments or modifications made to the original contract.']
  auto_renewal_flag boolean [note: 'Indicates whether the contract automatically renews at the end of its term unless either party provides notice of termination.']
  base_rate_per_unit decimal(12,4) [note: 'Negotiated base rate per unit of water (typically per thousand gallons or per cubic meter) under the special contract.']
  billing_cycle varchar [note: 'Frequency at which the customer is billed under the special contract: monthly, quarterly, annual, or custom.']
  contract_document_reference varchar [note: 'Reference identifier or file path to the signed contract document stored in the document management system.']
  contract_duration_months decimal(18,6) [note: 'Total duration of the contract term expressed in months, used for renewal planning and rate case modeling.']
  contract_name varchar [note: 'Descriptive name or title of the special contract for business reference and reporting.']
  contract_number varchar [note: 'Externally-known unique business identifier for the special contract, used in regulatory filings and customer correspondence.']
  contract_signed_date date [note: 'Date when the contract was executed and signed by all parties.']
  contract_status varchar [note: 'Current lifecycle status of the special contract indicating its operational state and regulatory approval status. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|terminated|expired|renewed — 7 candidates stripped; promote to reference product]']
  contract_type varchar [note: 'Classification of the special contract indicating the nature of the agreement: industrial user, wholesale, intergovernmental, municipal, bulk supply, or special rate.']
  contract_value_total decimal(15,2) [note: 'Estimated total monetary value of the contract over its full term, used for financial planning and revenue forecasting.']
  contracted_volume_gallons decimal(18,4)
  created_timestamp timestamp [note: 'Timestamp when this special contract record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts in this contract. Typically USD for U.S. water utilities.']
  demand_charge_amount decimal(12,2) [note: 'Fixed monthly or periodic demand charge assessed to reserve capacity for the customer, independent of actual consumption.']
  discharge_limit_bod_mg_per_l decimal(10,3) [note: 'Maximum allowable BOD concentration in wastewater discharge under the special contract, measured in mg/L.']
  discharge_limit_tss_mg_per_l decimal(10,3) [note: 'Maximum allowable TSS concentration in wastewater discharge under the special contract, measured in mg/L.']
  effective_date date
  effective_end_date date [note: 'Date when the special contract terms expire or terminate. Nullable for open-ended contracts subject to renewal.']
  effective_start_date date [note: 'Date when the special contract terms become binding and enforceable.']
  expiration_date date
  iup_compliance_required_flag boolean [note: 'Indicates whether the customer is required to maintain an Industrial User Permit (IUP) and comply with pretreatment requirements as a condition of the contract.']
  last_amendment_date date [note: 'Date of the most recent amendment or modification to the contract terms.']
  last_modified_timestamp timestamp [note: 'Timestamp when this special contract record was last updated in the system.']
  maximum_volume_limit_mgd decimal(12,4) [note: 'Maximum daily water volume (in MGD) that the utility agrees to supply under the contract, defining capacity allocation limits.']
  minimum_volume_commitment_mgd decimal(12,4) [note: 'Minimum daily water volume (in MGD) that the customer commits to purchase under the contract, used for capacity planning and revenue forecasting.']
  negotiated_rate_structure decimal(18,6) [note: 'Type of rate structure negotiated in the special contract: flat rate, tiered volume, demand charge, time-of-use, seasonal, or custom.']
  notice_period_days varchar [note: 'Number of days advance notice required by either party to terminate or modify the contract.']
  payment_terms_days decimal(18,2) [note: 'Number of days from invoice date within which payment is due under the contract terms.']
  penalty_for_over_consumption decimal(12,2) [note: 'Financial penalty or surcharge assessed if the customer exceeds the maximum volume limit, typically expressed as a per-unit overage charge.']
  penalty_for_under_consumption decimal(12,2) [note: 'Financial penalty assessed if the customer fails to meet the minimum volume commitment, typically expressed as a fixed amount or per-unit shortfall charge.']
  pretreatment_requirements varchar [note: 'Detailed description of wastewater pretreatment requirements the customer must meet, including discharge limits for BOD, COD, TSS, TDS, pH, FOG, and other pollutants.']
  rate_per_unit decimal(18,6)
  regulatory_approval_date date [note: 'Date when the regulatory authority approved the special contract for execution.']
  regulatory_approval_status varchar [note: 'Status of regulatory approval from the Public Utilities Commission or other governing body for this special contract.']
  regulatory_filing_reference varchar [note: 'Reference number or docket number assigned by the regulatory authority for the special contract filing.']
  renewal_terms varchar [note: 'Textual description of contract renewal terms, including automatic renewal provisions, notice periods, and renegotiation conditions.']
  signatory_name varchar [note: 'Name of the authorized representative who signed the contract on behalf of the customer.']
  signatory_title varchar [note: 'Job title or position of the authorized representative who signed the contract on behalf of the customer.']
  sla_response_time_hours varchar [note: 'Maximum response time in hours guaranteed under the SLA for service requests or outage notifications.']
  sla_uptime_percentage decimal(5,2) [note: 'Guaranteed service uptime percentage under the SLA, typically expressed as a percentage (e.g., 99.50 for 99.5% uptime).']
  special_conditions varchar [note: 'Free-text field capturing any additional special conditions, covenants, or obligations unique to this contract, such as infrastructure contributions, service level guarantees, or operational constraints.']
  special_contract_status varchar
  tariff_deviation_justification varchar [note: 'Business and regulatory justification for deviating from standard published tariff terms, required for regulatory approval.']

  Note: 'Records negotiated special service contracts with large industrial, municipal, or wholesale customers that deviate from standard tariff terms. Captures contract type (industrial user, wholesale, intergovernmental), negotiated rate terms, minimum volume commitments (MGD), demand charge structure, contract duration, renewal terms, special conditions (IUP compliance, pretreatment requirements), and regulatory approval status. Distinct from standard service agreements governed by published tariffs.'
}

Table service.conservation_program {
  conservation_program_id varchar [pk, note: 'Unique identifier for the water conservation program record. Primary key.']
  fund_id varchar [note: 'Foreign key linking to finance.fund. Business justification: Conservation programs are funded by designated utility funds (often rate-funded conservation funds or restricted funds). Essential for budget tracking, expenditure authorization, and regulatory report']
  grant_id varchar [note: 'Foreign key linking to finance.grant. Business justification: Many conservation programs are grant-funded (state/federal water efficiency grants, EPA WaterSense). Grant expenditure tracking required for compliance, drawdown requests, and single audit reporting. ']
  program_manager_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Conservation programs in water utilities have designated employee program managers responsible for execution, budget, enrollment, and regulatory reporting. Links employee accountability to program per']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Conservation programs are often mandated by regulatory requirements (drought response orders, demand management mandates, water use efficiency standards). Program design, targets, and reporting tied t']
  territory_id varchar [note: 'Foreign key linking to service.service_territory. Business justification: Conservation programs are often territory-specific with territory-level water savings targets and regulatory mandates. Adding this link enables territory-based program management and reporting.']
  actual_participant_count varchar [note: 'Current count of customers or accounts enrolled and participating in the conservation program.']
  actual_water_savings_gallons varchar [note: 'Measured or estimated cumulative water savings achieved by the program to date, in gallons.']
  budget_amount decimal(18,2)
  budget_expended_to_date date [note: 'Cumulative amount of program budget spent as of the last reporting period, in US dollars.']
  conservation_program_description varchar
  conservation_program_status varchar
  contact_email varchar [note: 'Primary email address for customer inquiries and program communications.']
  contact_phone varchar [note: 'Primary phone number for customer inquiries and program support.']
  created_by_user varchar [note: 'User ID or name of the person who created the conservation program record.']
  created_timestamp timestamp [note: 'Timestamp when the conservation program record was first created in the system.']
  customer_class_applicability varchar [note: 'Customer class segments eligible to participate in this conservation program.']
  eligibility_criteria varchar [note: 'Detailed requirements and conditions that customers must meet to participate in the conservation program, including customer class, service type, meter size, and usage thresholds.']
  end_date date
  enrollment_end_date date [note: 'Date when customer enrollment or application for the program closes. Null for open enrollment programs.']
  enrollment_start_date date [note: 'Date when customer enrollment or application for the program opens.']
  funding_source varchar [note: 'Source of funds supporting the conservation program, such as operating budget, capital improvement program, state grants, or federal funding.']
  incentive_amount decimal(15,2) [note: 'Fixed monetary value of the incentive provided per qualifying customer or installation, in US dollars.']
  incentive_type varchar [note: 'Type of financial or non-financial incentive offered to customers participating in the program.']
  incentive_unit varchar [note: 'Unit of measure for calculating and distributing the incentive to program participants.']
  last_modified_by_user varchar [note: 'User ID or name of the person who last modified the conservation program record.']
  last_modified_timestamp timestamp [note: 'Timestamp when the conservation program record was last updated.']
  last_reported_date date [note: 'Date of the most recent performance report submitted for this conservation program.']
  marketing_campaign_code varchar [note: 'Code linking the conservation program to specific marketing and outreach campaigns for tracking effectiveness.']
  maximum_incentive_per_customer decimal(15,2) [note: 'Cap on the total incentive amount a single customer can receive under this program during the program period, in US dollars.']
  performance_metric_definition varchar [note: 'Description of the key performance indicators (KPIs) used to measure program success, such as gallons saved per dollar spent or participation rate.']
  program_category varchar [note: 'Target sector or application area for the conservation program.']
  program_code varchar [note: 'Unique business identifier code for the conservation program, used for external reference and reporting.']
  program_description varchar [note: 'Detailed description of the conservation program objectives, activities, and benefits to customers and the utility.']
  program_end_date date [note: 'Date when the conservation program concludes and no new participants are accepted. Null for ongoing programs.']
  program_name varchar [note: 'Full descriptive name of the conservation program as presented to customers and in regulatory filings.']
  program_notes varchar [note: 'Additional free-text notes, comments, or special instructions related to the conservation program administration and operations.']
  program_start_date date [note: 'Date when the conservation program becomes active and customers can begin participating.']
  program_status varchar [note: 'Current lifecycle status of the conservation program.']
  program_type varchar [note: 'Classification of the conservation program by delivery mechanism and approach. [ENUM-REF-CANDIDATE: rebate|tiered_pricing|water_audit|drought_surcharge|education|restriction|incentive — 7 candidates stripped; promote to reference product]']
  program_website_url varchar [note: 'Web address where customers can find detailed program information, eligibility requirements, and application forms.']
  regulatory_approval_date date [note: 'Date when the conservation program received regulatory approval from the governing authority.']
  regulatory_approval_number varchar [note: 'Approval or permit number issued by the state Public Utilities Commission or environmental agency authorizing the program.']
  regulatory_mandate_flag boolean [note: 'Indicates whether the conservation program is required by state or federal regulation (True) or is voluntary (False).']
  regulatory_mandate_reference varchar [note: 'Citation or reference to the specific regulation, statute, or executive order requiring or authorizing the conservation program.']
  reporting_frequency varchar [note: 'Frequency at which program performance and results are reported to regulatory agencies and utility management.']
  start_date date
  target_participant_count varchar [note: 'Goal for the number of customers or accounts participating in the conservation program.']
  target_savings_gallons decimal(18,4)
  target_water_savings_gallons varchar [note: 'Projected total water savings goal for the program over its duration, measured in gallons.']
  tariff_reference varchar [note: 'Reference to the utility tariff schedule or rate case filing that includes this conservation program.']
  total_program_budget decimal(15,2) [note: 'Total allocated budget for the conservation program over its entire duration, in US dollars.']

  Note: 'Master catalog of customer programs including water conservation programs (rebates, tiered pricing incentives, water audits, drought surcharges), demand management programs, and customer affordability/assistance programs (lifeline rates, PIPP, bill discounts, emergency assistance). Captures program name, program type, eligibility criteria (including income thresholds for affordability programs), incentive or benefit structure, funding source, program period, target outcomes, enrollment tracking, and regulatory mandate reference. Supports AWWA water efficiency goals, state conservation mandates, and regulatory affordability requirements.'
}

Table service.affordability_plan {
  affordability_plan_id varchar [pk, note: 'Unique identifier for the affordability plan. Primary key.']
  fund_id varchar [note: 'Foreign key linking to finance.fund. Business justification: Low-income assistance programs are funded by designated funds (rate-funded assistance funds or restricted funds). Essential for subsidy accounting, budget tracking, and regulatory reporting of afforda']
  service_class_id varchar [note: 'Foreign key linking to service.service_class. Business justification: Affordability plans apply to specific customer service classes. Currently customer_class_applicability is a STRING, but this should be a FK to service_class for referential integrity and to enable cla']
  territory_id varchar [note: 'Foreign key linking to service.territory. Business justification: Affordability and low-income assistance programs can be territory-specific, as different jurisdictions may have different regulatory mandates, funding sources, or eligibility criteria. This FK allows ']
  application_process_description varchar [note: 'Description of the process customers must follow to apply for enrollment in this affordability plan, including required documentation and submission channels.']
  auto_enrollment_flag boolean [note: 'Indicates whether eligible customers are automatically enrolled in this affordability plan based on participation in other assistance programs (e.g., SNAP, Medicaid, LIHEAP). True if auto-enrollment is enabled, false if customers must apply.']
  contact_email varchar [note: 'Email address customers can use to request information about this affordability plan or submit application inquiries.']
  contact_phone varchar [note: 'Phone number customers can call for information about this affordability plan, application assistance, or enrollment status inquiries.']
  created_by_user varchar [note: 'Username or identifier of the system user who created this affordability plan record.']
  created_timestamp timestamp [note: 'Timestamp when this affordability plan record was first created in the system.']
  current_enrollment_count varchar [note: 'Current number of customers actively enrolled in this affordability plan. Updated periodically to reflect enrollment changes.']
  discount_fixed_amount decimal(15,2) [note: 'Fixed dollar credit amount applied to the customer\'s bill per billing cycle when the discount type is fixed amount. Null if discount type is not fixed amount.']
  discount_percentage decimal(5,2) [note: 'Percentage discount applied to the customer\'s water and/or wastewater bill when the discount type is percentage-based. Null if discount type is not percentage.']
  discount_type varchar [note: 'The mechanism by which the affordability benefit is applied: percentage (percent off total bill), fixed amount (dollar credit per billing cycle), rate reduction (lower volumetric or base rate), bill cap (maximum bill amount), or usage credit (free gallons or cubic meters).']
  effective_end_date date [note: 'Date on which this affordability plan expires or is discontinued. Null if the plan has no scheduled end date.']
  effective_start_date date [note: 'Date on which this affordability plan becomes active and available for customer enrollment.']
  eligibility_income_threshold_amount decimal(15,2) [note: 'Maximum annual household income amount (in local currency) that qualifies a customer for enrollment in this affordability plan. Typically expressed as a percentage of Federal Poverty Level (FPL) or Area Median Income (AMI).']
  eligibility_income_threshold_basis varchar [note: 'The reference standard used to determine income eligibility: federal poverty level (FPL percentage), area median income (AMI percentage), state median income (SMI percentage), or fixed amount (absolute dollar threshold).']
  eligibility_income_threshold_percent decimal(5,2) [note: 'Percentage of the income threshold basis (e.g., 150% of FPL, 80% of AMI) used to determine customer eligibility for the affordability plan.']
  enrollment_capacity varchar [note: 'Maximum number of customers who can be enrolled in this affordability plan at any given time. Null if no enrollment cap applies.']
  funding_source varchar [note: 'Primary source of funding for the affordability plan: utility revenue (general operating funds), rate surcharge (dedicated customer charge), municipal subsidy (city/county budget), state grant, federal grant, private donation, or cross subsidy (higher-income customer rates). [ENUM-REF-CANDIDATE: utility_revenue|rate_surcharge|municipal_subsidy|state_grant|federal_grant|private_donation|cross_subsidy — 7 candidates stripped; promote to reference product]']
  last_modified_by_user varchar [note: 'Username or identifier of the system user who last modified this affordability plan record.']
  last_modified_timestamp timestamp [note: 'Timestamp when this affordability plan record was last updated in the system.']
  maximum_benefit_amount decimal(15,2) [note: 'Maximum total dollar benefit a customer can receive per billing cycle or per enrollment period under this affordability plan. Null if no cap applies.']
  maximum_benefit_duration_months decimal(18,6) [note: 'Maximum number of months a customer can remain enrolled in this affordability plan before re-certification or plan expiration. Null if no duration limit applies.']
  notes varchar [note: 'Additional notes, comments, or special instructions related to this affordability plan, including program changes, temporary modifications, or administrative remarks.']
  partner_program_name varchar [note: 'Name of external assistance program(s) used for auto-enrollment eligibility verification (e.g., SNAP, Medicaid, LIHEAP, TANF). Null if auto-enrollment is not enabled.']
  plan_code varchar [note: 'Unique business identifier code for the affordability plan, used for external reference and reporting.']
  plan_description varchar [note: 'Detailed description of the affordability plan, including objectives, benefits, and terms of assistance provided to eligible customers.']
  plan_name varchar [note: 'Full descriptive name of the affordability plan (e.g., Lifeline Rate Program, Low-Income Assistance Plan, Percentage of Income Payment Plan).']
  plan_status varchar [note: 'Current lifecycle status of the affordability plan: active (accepting enrollments), inactive (not currently offered), suspended (temporarily paused), pending approval (awaiting regulatory approval), expired (past end date), or discontinued (permanently retired).']
  plan_type varchar [note: 'Classification of the affordability plan structure: lifeline rate (reduced base rate), percentage of income (PIPP - bill capped at income percentage), fixed discount (flat dollar or percentage reduction), tiered discount (graduated by income level), emergency assistance (one-time aid), or crisis voucher (short-term relief).']
  program_website_url varchar [note: 'Web address where customers can find detailed information about this affordability plan, download application forms, and access eligibility guidelines.']
  recertification_frequency_months varchar [note: 'Number of months between required recertification events for customers enrolled in this affordability plan. Null if recertification is not required.']
  recertification_required_flag boolean [note: 'Indicates whether customers must periodically recertify their eligibility to continue receiving benefits under this affordability plan. True if recertification is required, false otherwise.']
  regulatory_approval_date date [note: 'Date on which the regulatory authority approved this affordability plan for implementation. Null if not applicable.']
  regulatory_approval_number varchar [note: 'Official approval or docket number issued by the regulatory authority authorizing this affordability plan. Null if not applicable.']
  regulatory_authority varchar [note: 'Name of the regulatory body or legislative authority that mandates or oversees this affordability plan (e.g., State Public Utilities Commission, City Council Ordinance). Null if plan is voluntary.']
  regulatory_mandate_flag boolean [note: 'Indicates whether this affordability plan is mandated by state or local regulation, or is a voluntary utility program. True if mandated, false if voluntary.']
  required_documentation varchar [note: 'List of documents customers must provide to verify eligibility for this affordability plan (e.g., proof of income, tax returns, benefit award letters, utility bills).']
  service_type_applicability varchar [note: 'Specifies which utility services are covered by this affordability plan: water only, wastewater only, water and wastewater combined, stormwater, or all services.']
  waitlist_enabled_flag boolean [note: 'Indicates whether a waitlist is maintained for customers when enrollment capacity is reached. True if waitlist is enabled, false otherwise.']

  Note: 'Defines the low-income customer assistance and affordability programs available, including lifeline rates, percentage-of-income payment plans (PIPP), bill discount programs, and emergency assistance funds. Captures plan name, eligibility income thresholds, discount percentage or fixed credit amount, maximum benefit duration, funding source, regulatory mandate, and enrollment capacity. Supports equitable access to essential water services and regulatory affordability requirements.'
}

Table service.bulk_water_agreement {
  bulk_water_agreement_id varchar [pk, note: 'Unique identifier for the bulk water supply agreement. Primary key for the bulk water agreement entity.']
  billing_account_id varchar [note: 'Foreign key linking to billing.billing_account. Business justification: Bulk water agreements (wholesale customers, neighboring utilities) require billing accounts for invoicing contracted volumes. Wholesale billing operations depend on linking the agreement to the accoun']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Bulk water agreements (wholesale supply to neighboring utilities) often require dedicated infrastructure projects (interconnections, booster stations, dedicated pipelines). Contract performance monito']
  compliance_permit_id varchar [note: 'Foreign key linking to compliance.compliance_permit. Business justification: Bulk water agreements require water withdrawal permits or inter-jurisdictional transfer permits. Utility tracks regulatory approval for wholesale water transactions, ensuring compliance with permitted']
  customer_account_id varchar
  delivery_point_asset_registry_id varchar [note: 'Foreign key linking to asset.asset_registry. Business justification: Wholesale delivery points are physical assets (interconnection vaults, master meters, pressure control stations) requiring maintenance, inspection, and emergency response planning. Operations teams ne']
  dma_id varchar [note: 'Foreign key linking to distribution.dma. Business justification: Bulk water delivery points need DMA assignment for wholesale flow monitoring, NRW accounting (separating wholesale from retail losses), zone-level demand forecasting, and contracted_volume_mgd verific']
  finance_rate_case_id varchar [note: 'Foreign key linking to finance.rate_case. Business justification: Bulk water rates are established through rate case proceedings. Regulatory approval required for wholesale pricing. Links wholesale rate structure to rate case docket for PUC compliance and cost-of-se']
  fund_id varchar [note: 'Foreign key linking to finance.fund. Business justification: Bulk water sales revenue flows to specific utility funds. Essential for wholesale revenue accounting, interfund transfers, and GASB reporting. Water utilities track wholesale vs. retail revenue by fun']
  metering_meter_id varchar [note: 'Unique identifier of the meter installed at the delivery point to measure bulk water volumes for billing and compliance purposes. Links to asset management system.']
  pressure_zone_id varchar [note: 'Foreign key linking to distribution.pressure_zone. Business justification: Bulk delivery points must reference pressure zones for hydraulic capacity verification, delivery_pressure_psi guarantee compliance, system impact analysis, and zone-level demand accounting. Critical f']
  procurement_contract_id varchar [note: 'Foreign key linking to supply.procurement_contract. Business justification: Bulk water sale agreements to neighboring utilities often have associated procurement contracts for treatment chemicals, power, or infrastructure maintenance that are cost-allocated to the bulk water ']
  territory_id varchar [note: 'Foreign key linking to service.service_territory. Business justification: Bulk water agreements are delivered within specific service territories. The delivery_point_description and coordinates indicate a geographic location that should be tied to a service territory for fr']
  wtp_facility_id varchar [note: 'Foreign key linking to treatment.facility. Business justification: Wholesale water agreements specify which treatment facility supplies the bulk water - essential for capacity planning, contract compliance verification (volume/quality commitments), and cost allocatio']
  agreement_number varchar [note: 'Externally-known unique business identifier for the bulk water agreement, used in contracts, invoices, and regulatory filings.']
  agreement_status varchar [note: 'Current lifecycle status of the bulk water agreement: draft (under negotiation), pending approval (awaiting regulatory or board approval), active (in force), suspended (temporarily halted), terminated (ended before expiration), or expired (reached end date).']
  agreement_type varchar [note: 'Classification of the bulk water agreement based on the nature of service: wholesale supply (ongoing large-volume delivery), bulk purchase (one-time or periodic large purchases), emergency interconnection (backup supply during outages), seasonal supply (peak demand periods), treatment services (wastewater treatment for another utility), or wastewater discharge (acceptance of wastewater flows).']
  auto_renewal_flag boolean [note: 'Indicates whether the agreement automatically renews at the end of the contract term unless either party provides termination notice. True if auto-renewal applies, False otherwise.']
  base_rate_per_thousand_gallons decimal(12,4) [note: 'Base volumetric rate charged per thousand gallons of water delivered or wastewater treated under the agreement. Null if pricing is not volumetric.']
  billing_frequency varchar [note: 'Frequency at which invoices are issued to the counterparty for bulk water supply or treatment services: monthly, quarterly, or annual.']
  bulk_water_agreement_status varchar
  capacity_charge_annual decimal(15,2) [note: 'Annual capacity reservation charge paid by the purchasing party to reserve a specific volume of supply or treatment capacity, independent of actual usage. Null if no capacity charge applies.']
  contract_term_years varchar [note: 'Duration of the agreement in years from effective start date to effective end date. Null for open-ended agreements.']
  contracted_volume_mgd decimal(12,4) [note: 'The contracted daily volume of water supply or wastewater treatment capacity in Million Gallons per Day (MGD). Represents the baseline or maximum daily volume agreed upon in the contract.']
  counterparty_contact_email varchar [note: 'Primary email address for the counterparty contact person for agreement communications and notifications.']
  counterparty_contact_name varchar [note: 'Primary contact person name at the counterparty organization for agreement administration and operational coordination.']
  counterparty_contact_phone varchar [note: 'Primary phone number for the counterparty contact person for operational coordination and emergency notifications.']
  counterparty_name varchar [note: 'Legal name of the wholesale customer or supplying utility party to the agreement (e.g., neighboring municipality, regional water authority, industrial facility).']
  counterparty_type varchar [note: 'Classification of the counterparty organization: municipality, water district, industrial customer, commercial customer, government agency, or neighboring utility.']
  created_by_user varchar [note: 'User ID or username of the person who created the bulk water agreement record in the system.']
  created_timestamp timestamp [note: 'Timestamp when the bulk water agreement record was first created in the system.']
  delivery_point_description varchar [note: 'Textual description of the physical location where water is delivered or wastewater is received, including interconnection point, meter location, or facility name.']
  delivery_point_latitude decimal(10,7) [note: 'Geographic latitude coordinate of the delivery or acceptance point for GIS mapping and asset management integration.']
  delivery_point_longitude decimal(10,7) [note: 'Geographic longitude coordinate of the delivery or acceptance point for GIS mapping and asset management integration.']
  delivery_pressure_psi_max decimal(6,2) [note: 'Maximum allowable delivery pressure in Pounds per Square Inch (PSI) at the interconnection point to prevent damage to the receiving utilitys infrastructure.']
  delivery_pressure_psi_min decimal(6,2) [note: 'Minimum required delivery pressure in Pounds per Square Inch (PSI) at the interconnection point to meet the purchasing utilitys distribution system requirements.']
  effective_date date
  effective_end_date date [note: 'Date when the bulk water agreement expires or terminates. Null for open-ended agreements or those with automatic renewal provisions.']
  effective_start_date date [note: 'Date when the bulk water agreement becomes legally binding and service delivery or acceptance obligations commence.']
  emergency_supply_provision_flag boolean [note: 'Indicates whether the agreement includes provisions for emergency water supply during outages, droughts, or infrastructure failures. True if emergency provisions exist, False otherwise.']
  emergency_supply_terms varchar [note: 'Detailed description of emergency supply terms, including trigger conditions, maximum emergency volume, duration limits, and emergency pricing. Null if no emergency provisions exist.']
  expiration_date date
  intergovernmental_agreement_flag boolean [note: 'Indicates whether this is an intergovernmental agreement between two public entities (municipalities, water districts, government agencies), which may have special legal status and exemptions. True if intergovernmental, False otherwise.']
  late_payment_penalty_percent decimal(5,2) [note: 'Percentage penalty applied to overdue balances for late payment, expressed as an annual percentage rate or per-period rate as specified in the agreement.']
  metering_responsibility varchar [note: 'Party responsible for installation, maintenance, and calibration of metering equipment at the delivery point: supplier, purchaser, or shared responsibility.']
  minimum_take_or_pay_volume decimal(18,4)
  minimum_take_volume_mgd decimal(12,4) [note: 'Minimum daily volume in Million Gallons per Day (MGD) that the purchasing party is obligated to take or pay for under take-or-pay provisions. Null if no minimum take obligation exists.']
  modified_by_user varchar [note: 'User ID or username of the person who last modified the bulk water agreement record in the system.']
  modified_timestamp timestamp [note: 'Timestamp when the bulk water agreement record was last modified in the system.']
  notes varchar [note: 'Free-text field for additional notes, special provisions, historical context, or operational considerations related to the bulk water agreement.']
  payment_terms_days decimal(18,2) [note: 'Number of days from invoice date within which payment is due from the counterparty.']
  peak_volume_mgd decimal(12,4) [note: 'Maximum allowable daily volume in Million Gallons per Day (MGD) that can be delivered or accepted under the agreement, representing peak capacity limits.']
  pricing_structure_type varchar [note: 'Type of pricing mechanism used in the agreement: flat rate (fixed monthly/annual charge), volumetric (per-gallon charge), tiered (volume-based tiers), demand charge (capacity reservation fee), take-or-pay (minimum volume commitment), or cost-plus (cost recovery plus margin).']
  rate_escalation_clause decimal(18,6) [note: 'Description of the rate escalation mechanism in the agreement, such as annual CPI adjustment, fixed percentage increase, or cost-of-service pass-through provisions.']
  rate_per_thousand_gallons decimal(18,6)
  regulatory_approval_date date [note: 'Date when the regulatory authority formally approved the bulk water agreement and its terms.']
  regulatory_approval_number varchar [note: 'Unique identifier or docket number assigned by the regulatory authority when approving the bulk water agreement and its rate structure.']
  regulatory_authority varchar [note: 'Name of the regulatory body or Public Utilities Commission that has jurisdiction over the agreement and must approve rates and terms (e.g., state PUC, EPA regional office, primacy agency).']
  renewal_term_years varchar [note: 'Duration in years of each automatic renewal period if auto-renewal provisions apply. Null if no auto-renewal.']
  take_or_pay_provision_flag boolean [note: 'Indicates whether the agreement includes a take-or-pay provision requiring the purchasing party to pay for a minimum volume regardless of actual usage. True if take-or-pay applies, False otherwise.']
  termination_notice_days varchar [note: 'Number of days advance notice required by either party to terminate or not renew the agreement.']
  water_quality_standard varchar [note: 'Reference to the water quality specifications that delivered water must meet, typically citing EPA Safe Drinking Water Act (SDWA) standards, state primacy agency requirements, or specific contractual quality parameters (e.g., turbidity NTU limits, disinfectant residual, MCL compliance).']

  Note: 'Records negotiated special service agreements with large industrial, municipal, wholesale, or intergovernmental customers that deviate from standard published tariff terms. Covers wholesale bulk water supply, industrial user contracts, intergovernmental agreements, and special pricing arrangements. Captures agreement parties, contract type, negotiated rate terms, volume commitments (MGD), demand charge structure, delivery specifications (pressure, quality), take-or-pay provisions, contract duration, renewal terms, special conditions (IUP compliance, pretreatment requirements), emergency supply terms, and regulatory approval status. Distinct from standard retail service agreements governed by published tariffs.'
}

Table service.offering_territory_availability {
  offering_territory_availability_id varchar [pk, note: 'Unique identifier for this offering-territory availability record. Primary key.']
  offering_id varchar [note: 'Foreign key linking to the service offering being made available in this territory']
  territory_id varchar [note: 'Foreign key linking to the service territory where this offering is available']
  availability_status varchar [note: 'Current operational status of this offering within this territory. Available = open for new enrollments; Suspended = temporarily unavailable due to capacity or regulatory issues; Pending_Approval = awaiting regulatory authorization; Discontinued = no longer offered; Restricted = available only to specific customer classes.']
  capacity_reserved_mgd decimal(12,4) [note: 'Amount of system capacity in million gallons per day reserved or allocated for this offering within this territory. Used for capacity planning and to ensure infrastructure can support the offering\'s demand.']
  created_timestamp timestamp [note: 'Timestamp when this availability record was created in the system.']
  effective_date date
  effective_end_date date [note: 'Date when this offering was discontinued or became unavailable in this specific territory. Null indicates ongoing availability. Territory-specific discontinuation may occur due to franchise agreement changes or regulatory decisions.']
  effective_start_date date [note: 'Date when this offering became available for customer enrollment within this specific territory. This is territory-specific and may differ from the offering\'s global effective_start_date due to phased rollouts or territory-specific regulatory approvals.']
  end_date date
  franchise_authorization_date date [note: 'Date when the regulatory authority or franchise agreement authorized the utility to provide this specific offering within this territory. Critical for regulatory compliance and audit trails.']
  is_active boolean
  marketing_launch_date date [note: 'Date when marketing and customer outreach for this offering began in this territory. May differ from effective_start_date due to phased rollout strategies.']
  priority_service_flag boolean [note: 'Indicates whether this offering receives priority deployment or enhanced service levels in this territory, often due to regulatory mandates, environmental justice requirements, or infrastructure investment priorities.']
  regulatory_approval_reference varchar [note: 'Reference to the territory-specific regulatory approval, rate case docket, or Public Utilities Commission order authorizing this offering in this territory. May differ from the offering\'s global tariff_reference when territory-specific approvals are required.']
  territory_specific_rate_adjustment decimal(15,4) [note: 'Multiplier or adjustment factor applied to the offering\'s base rates for this specific territory. Used when regulatory authorities approve territory-specific rate variations due to infrastructure costs, population density, or other geographic factors. 1.0 = no adjustment.']
  updated_timestamp timestamp [note: 'Timestamp when this availability record was last modified.']

  Note: 'This association product represents the availability and authorization of specific water and wastewater service offerings within defined geographic service territories. It captures the regulatory approval, rate adjustments, and lifecycle management of which offerings are available in which territories. Each record links one offering to one service_territory with attributes that exist only in the context of this territory-specific availability, including territory-specific rate adjustments, franchise authorization dates, and availability status that cannot be stored on either the offering or territory alone.. Existence Justification: Water utilities operate service offerings across multiple geographic territories, each with distinct franchise agreements, regulatory approvals, and rate structures. A single offering (e.g., potable water supply) is made available in multiple territories (Downtown District, North County, etc.), and each territory offers multiple service types (potable, wastewater, recycled water). The utility actively manages which offerings are available in which territories, with territory-specific rate adjustments, regulatory authorizations, and lifecycle states that cannot be stored on either the offering or territory entity alone.'
}

Table service.service_program_enrollment {
  service_program_enrollment_id varchar [pk, note: 'Unique identifier for the program enrollment record. Primary key.']
  agreement_id varchar [note: 'Reference to the service agreement associated with this enrollment.']
  customer_account_id varchar
  offering_id varchar
  primary_service_program_conservation_program_id varchar [note: 'Reference to the conservation, assistance, or demand management program.']
  service_account_billing_account_id varchar [note: 'Foreign key linking to the billing account enrolled in the conservation program']
  application_date date [note: 'Date when the customer submitted their application to enroll in this conservation program.']
  approval_date date [note: 'Date when the enrollment application was approved by program administrators.']
  auto_renewal_flag boolean [note: 'Indicates whether the enrollment automatically renews at the end of the term.']
  baseline_consumption_gallons decimal(15,2) [note: 'Customer water consumption baseline measured in gallons prior to program enrollment. Used to calculate savings.']
  baseline_period_end_date date [note: 'End date of the baseline measurement period used to establish pre-program consumption.']
  baseline_period_start_date date [note: 'Start date of the baseline measurement period used to establish pre-program consumption.']
  cancellation_date date [note: 'Date when the enrollment was cancelled or terminated.']
  cancellation_reason_code varchar [note: 'Standardized code indicating the reason for enrollment cancellation. [ENUM-REF-CANDIDATE: customer_request|non_compliance|program_ended|moved|ineligible|duplicate|other — promote to reference product]']
  cancellation_reason_description varchar [note: 'Detailed explanation of why the enrollment was cancelled.']
  completion_date date [note: 'Date when the customer successfully completed all program requirements.']
  created_by_user varchar [note: 'Username or identifier of the user who created this enrollment record.']
  created_timestamp timestamp [note: 'Timestamp when this enrollment record was first created in the system.']
  customer_program_enrollment_id varchar [note: 'Canonical single-source-of-truth reference to customer.customer_program_enrollment (customer_program_enrollment_id); this entity defers authoritative attribute values to that master entity.']
  effective_end_date date [note: 'Date when the program enrollment ends or is scheduled to end. Nullable for open-ended enrollments.']
  effective_start_date date [note: 'Date when the program enrollment becomes active and benefits begin.']
  eligibility_verification_date date [note: 'Date when customer eligibility was verified.']
  eligibility_verified_date date [note: 'Date when the utility verified that this billing account met the eligibility criteria for this conservation program.']
  eligibility_verified_flag boolean [note: 'Indicates whether customer eligibility for the program has been verified (e.g., income verification for assistance programs).']
  enrollment_channel varchar [note: 'Channel through which the customer enrolled in the program (online portal, phone, mail, in-person, mobile app, agent-assisted).']
  enrollment_date date [note: 'Date when the billing account enrolled in this conservation program. Identified in detection phase as relationship data.']
  enrollment_end_date date [note: 'Date when the billing account completed or withdrew from this conservation program enrollment. Null for active enrollments.']
  enrollment_number varchar [note: 'Business-facing unique enrollment reference number for tracking and customer communication.']
  enrollment_status varchar [note: 'Current lifecycle status of this enrollment (active, pending, completed, withdrawn, suspended). Identified in detection phase as program_status relationship data.']
  expiration_date date
  incentive_amount_approved decimal(15,2) [note: 'Total monetary incentive amount approved for this enrollment in USD. Includes rebates, credits, or financial assistance.']
  incentive_amount_paid decimal(15,2) [note: 'Actual monetary incentive amount paid to the customer in USD.']
  incentive_amount_received decimal(15,2) [note: 'Total monetary incentive amount paid to this billing account for participation in this specific conservation program. Identified in detection phase as relationship data.']
  incentive_payment_date date [note: 'Date when the incentive payment was issued to the customer.']
  incentive_payment_method decimal(18,2) [note: 'Method used to deliver the incentive payment to the customer.']
  last_modified_by_user varchar [note: 'Username or identifier of the user who last modified this enrollment record.']
  last_modified_timestamp timestamp [note: 'Timestamp when this enrollment record was last updated.']
  notes varchar [note: 'Free-text notes capturing additional context, special circumstances, or administrative comments about the enrollment.']
  participation_level varchar
  program_enrollment_number varchar [note: 'Unique identifier for this program enrollment record. Primary key.']
  program_term_months varchar [note: 'Duration of the program enrollment commitment measured in months.']
  regulatory_program_code varchar [note: 'Code identifying the regulatory program category for compliance reporting (e.g., state-mandated conservation, drought response).']
  regulatory_reporting_flag boolean [note: 'Indicates whether this enrollment must be included in regulatory conservation compliance reporting.']
  service_customer_program_enrollment_id varchar [note: 'Foreign key to single source of truth customer.customer_program_enrollment']
  service_program_enrollment_status varchar
  updated_timestamp timestamp
  verification_date date [note: 'Date when program compliance or completion was verified by utility staff or third-party auditor.']
  verification_status varchar [note: 'Status of the verification process for program compliance and savings achievement.']
  verified_by_user varchar [note: 'Username or identifier of the staff member or auditor who performed the verification.']
  water_savings_achieved varchar [note: 'Measured water savings in gallons achieved by this billing account through participation in this specific conservation program. Identified in detection phase as relationship data.']
  water_savings_actual_gallons decimal(15,2) [note: 'Actual water savings achieved through this enrollment measured in gallons. Calculated from meter reading analysis or engineering estimates.']
  water_savings_calculation_method varchar [note: 'Methodology used to calculate actual water savings (e.g., meter-based analysis, engineering estimate, deemed savings).']
  water_savings_target_gallons decimal(15,2) [note: 'Target water savings goal for this enrollment measured in gallons. Used for conservation program performance tracking.']

  Note: 'This association product represents the enrollment relationship between a billing account and a conservation program. It captures the participation of a customer account in a specific water conservation program, tracking enrollment lifecycle, incentive payments received, and water savings achieved. Each record links one billing account to one conservation program with attributes that exist only in the context of this enrollment relationship.. Existence Justification: In water utility operations, billing accounts (customers) can simultaneously enroll in multiple conservation programs (toilet rebate, irrigation audit, rain barrel incentive, drought surcharge programs), and each conservation program serves many billing accounts. The utility actively manages these enrollments as operational business entities, tracking enrollment lifecycle, processing incentive payments, measuring water savings per account-program combination, and verifying eligibility. This is not an analytical correlation but an operational business process where enrollment records are created, updated, and closed by program administrators. [SSOT: Canonical program enrollment; customer.customer_program_enrollment references this as SSOT] [SSOT: governed by customer.customer_program_enrollment] [DEPRECATED: Single source of truth is customer.customer_program_enrollment]'
}

Table service.program_material_eligibility {
  program_material_eligibility_id varchar [pk, note: 'Unique identifier for this program-material eligibility record. Primary key.']
  conservation_program_id varchar [note: 'Foreign key linking to the conservation program offering the rebate or incentive']
  material_master_id varchar [note: 'Foreign key linking to the eligible material, fixture, or device']
  approval_date date [note: 'Date when this material was approved for eligibility under this conservation program by program management or regulatory authority.']
  created_timestamp timestamp
  eligibility_end_date date [note: 'Date when rebates for this material under this program expire. May differ from program end date if materials are phased out early.']
  eligibility_start_date date [note: 'Date when rebates for this material under this program become effective. May differ from program start date if materials are added mid-program.']
  eligibility_status varchar [note: 'Current status of this material\'s eligibility under this program: Active (accepting claims), Suspended (temporarily unavailable), Expired (no longer eligible), Pending (awaiting approval).']
  eligible_quantity_limit varchar [note: 'Maximum number of units of this material that a customer can claim rebates for under this program (e.g., max 2 high-efficiency toilets per household).']
  is_active boolean
  max_quantity_per_customer varchar
  minimum_efficiency_rating varchar [note: 'Required efficiency certification or rating for this material to qualify (e.g., WaterSense certified, EPA WaterSense, ENERGY STAR). Specific to this program-material combination.']
  program_enrollment_date date [note: 'Date when this material became available for customer enrollment and rebate claims under this program.']
  rebate_amount decimal(15,2) [note: 'Specific rebate or incentive amount offered for this material under this program. May differ from the program\'s default incentive_amount based on material type or efficiency rating.']
  total_rebate_amount_paid decimal(15,2) [note: 'Cumulative dollar amount paid in rebates for this material under this program. Used for budget tracking against program allocation.']
  total_rebates_issued varchar [note: 'Cumulative count of rebates issued for this material under this program to date. Used for budget tracking and program evaluation.']

  Note: 'This association product represents the eligibility relationship between conservation programs and materials. It captures which materials (fixtures, devices, equipment) are eligible for rebates or incentives under specific conservation programs. Each record links one conservation program to one eligible material with program-specific rebate amounts, quantity limits, and eligibility periods that exist only in the context of this program-material combination.. Existence Justification: Conservation programs in water utilities offer rebates and incentives for multiple eligible materials (high-efficiency toilets, smart irrigation controllers, low-flow fixtures, etc.). Each material can be eligible under multiple programs simultaneously (e.g., a WaterSense toilet may qualify for both a general water efficiency program and a low-income assistance program). The utility actively manages this eligibility catalog, setting program-specific rebate amounts, quantity limits, and eligibility periods for each program-material combination to support customer enrollment and budget tracking.'
}

