  facility_status varchar [note: 'Operational status']
  facility_type varchar [note: 'Type of facility (WTP, WWTP, etc.)']
  last_major_upgrade_date date [note: 'Last major upgrade date']
  latitude decimal(10,7) [note: 'GIS latitude coordinate']
  longitude decimal(10,7) [note: 'GIS longitude coordinate']
  operator_certification_class_required varchar [note: 'Required operator certification class']
  permit_number varchar [note: 'Regulatory permit number']
  permitted_capacity_mgd decimal(12,4) [note: 'Permitted capacity in MGD']
  pfas_treatment_capable_flag boolean [note: 'PFAS treatment capability flag']
  pfas_treatment_technology varchar [note: 'PFAS treatment technology type']
  population_served varchar [note: 'Population served']
  postal_code varchar [note: 'Postal code']
  pwsid varchar [note: 'Public Water System ID']
  regulatory_agency_code varchar [note: 'Regulatory agency code']
  scada_system_type varchar [note: 'SCADA system type']
  service_connections_count varchar [note: 'Number of service connections']
  source_water_type varchar [note: 'Source water type']
  state_code varchar [note: 'State code']
  treatment_technology_primary varchar [note: 'Primary treatment technology']
  treatment_technology_secondary varchar [note: 'Secondary treatment technology']
  updated_timestamp timestamp [note: 'Record update timestamp']

  Note: 'Water treatment facility master record capturing design capacity, treatment technology, PFAS capability, regulatory classification, and operational status.'
}

