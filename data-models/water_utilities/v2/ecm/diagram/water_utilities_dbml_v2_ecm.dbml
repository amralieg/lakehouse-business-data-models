  daily_capacity_samples varchar [note: 'Maximum number of samples the provider can process per day.']
  data_sharing_agreement_flag boolean [note: 'Indicates whether a data‑sharing agreement is in place (true) or not (false).']
  effective_date date [note: 'Date when the provider relationship became effective.']
  expiration_date date [note: 'Date when the provider relationship ends or is scheduled for review.']
  external_reference_code varchar [note: 'Identifier used for the provider in external source systems.']
  insurance_coverage_amount decimal(12,2) [note: 'Monetary limit of the provider\'s liability insurance.']
  is_active_flag boolean
  legal_name varchar [note: 'Legal registered name of the provider entity.']
  liability_limit_amount decimal(12,2) [note: 'Maximum financial liability the provider assumes under contract.']
  modified_timestamp timestamp
  notes varchar [note: 'Free‑form notes or comments about the provider.']
  payment_terms decimal(18,2) [note: 'Standard payment terms agreed with the provider.']
  postal_code varchar [note: 'Postal/ZIP code of the provider\'s address.']
  primary_contact_email varchar [note: 'Email address of the primary contact.']
  primary_contact_name varchar [note: 'Full name of the primary point‑of‑contact for the provider.']
  primary_contact_phone varchar [note: 'Telephone number of the primary contact.']
  provider_code varchar [note: 'External reference code assigned to the provider by the utility.']
  provider_name varchar
  provider_status varchar
  provider_type varchar [note: 'Category describing the nature of the provider.']
  pt_provider_name varchar [note: 'Common name of the laboratory service provider.']
  pt_provider_status varchar [note: 'Current lifecycle status of the provider relationship.']
  quality_certification varchar [note: 'Quality management certifications held by the provider.']
  service_area varchar [note: 'Geographic region(s) where the provider delivers services.']
  short_name varchar [note: 'Abbreviated name used for reporting and UI displays.']
  specialties varchar [note: 'Comma‑separated list of analytical test types the provider offers.']
  state_province varchar [note: 'State or province of the provider\'s address.']
  tax_number decimal(18,2) [note: 'Government‑issued tax identifier for the provider.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the provider record.']
  website_url varchar [note: 'Public website address of the provider.']

  Note: 'Master reference table for pt_provider. Referenced by pt_provider_id.'
}

Table compliance.compliance_permit {
  compliance_permit_id varchar [pk, note: 'Primary key for the compliance permit record.']
  facility_id varchar [note: 'FK to the treatment facility covered by this permit.']
  fund_id varchar [note: 'FK to the finance fund associated with permit compliance costs.']
  regulatory_agency_id varchar [note: 'FK to regulatory agency']
  regulatory_requirement_id varchar [note: 'FK to the governing regulatory requirement, providing the parallel US/EU/other reference path.']
  responsible_operator_employee_id varchar [note: 'FK to the employee designated as responsible operator for this permit.']
  sampling_plan_id varchar [note: 'FK to the laboratory sampling plan required by this permit.']
  water_system_id varchar [note: 'Public Water System identifier.']
  administrative_record_url varchar [note: 'URL to the administrative record for this permit.']
  annual_fee_amount decimal(18,2) [note: 'Annual permit fee amount.']
  compliance_schedule_flag boolean [note: 'Whether permit includes a compliance schedule']
  compliance_status varchar [note: 'Overall compliance status (Compliant, Non-Compliant, Under Review).']
  contact_email varchar [note: 'Contact email for permit correspondence']
  contact_person_name varchar [note: 'Primary contact person for the permit']
  contact_phone varchar [note: 'Contact phone for permit correspondence']
  created_timestamp timestamp [note: 'Timestamp when the record was created.']
  effective_date date [note: 'Date the permit becomes effective.']
  eu_directive_basis varchar [note: 'EU directive forming the legal basis for this permit (e.g. DWD 2020/2184 Article 11, WFD 2000/60/EC Article 11, UWWTD 91/271/EEC Article 4).']
  eu_reference_path varchar [note: 'EU reference path: Drinking Water Directive 2020/2184; REACH; WFD; UWWTD citation chain.']
  expiration_date date [note: 'Date the permit expires.']
  fee_due_date date [note: 'Due date for the annual permit fee.']
  issue_date date
  issuing_agency varchar [note: 'Name of the regulatory agency that issued the permit.']
  issuing_authority varchar [note: 'Agency that issued the permit.']
  jurisdiction varchar [note: 'Regulatory jurisdiction (Federal, State, EU, Regional). Allowed regions: US,EU,OTHER.']
  jurisdiction_code varchar [note: 'Regulatory jurisdiction under which this permit is issued (US_FEDERAL, US_STATE, EU_MEMBER_STATE, EU_COMMISSION, OTHER). Enables multi-jurisdictional permit tracking.']
  jurisdiction_permit_type varchar [note: 'Jurisdiction-specific permit type classification (e.g. US: Individual/General NPDES; EU: Environmental Permit / Abstraction License).']
  jurisdiction_region varchar [note: 'Regulatory region code (US, EU, OTHER) under which this permit was issued. Enables multi-jurisdictional permit tracking for US EPA/state permits and EU Water Framework Directive authorizations.']
  last_inspection_date date [note: 'Date of the most recent regulatory inspection.']
  last_modified_timestamp timestamp [note: 'Timestamp when the record was last modified.']
  latitude decimal(10,7)
  longitude decimal(10,7)
  major_minor_classification varchar
  major_minor_flag boolean [note: 'Whether classified as major or minor permit']
  modification_date date [note: 'Date of the most recent permit modification.']
  modification_reason varchar [note: 'Reason for the most recent permit modification.']
  next_inspection_date date [note: 'Scheduled date for the next regulatory inspection.']
  notes varchar [note: 'Additional notes about the permit.']
  other_reference_path varchar [note: 'Other national/regional regulatory reference path.']
  permit_description varchar [note: 'Detailed description of the permit scope and coverage.']
  permit_holder varchar
  permit_number varchar [note: 'Official permit number assigned by the regulatory agency.']
  permit_program varchar
  permit_status varchar [note: 'Current status of the permit (Active, Expired, Pending Renewal, Revoked).']
  permit_type varchar [note: 'Type of permit (NPDES, SDWA, Air, Stormwater, Pretreatment).']
  permitted_flow_mgd decimal(12,4) [note: 'Maximum permitted flow in million gallons per day.']
  permittee_name varchar
  population_served varchar [note: 'Population served under this permit.']
  public_notification_required_flag boolean
  receiving_water_body varchar [note: 'Name of the receiving water body for discharge permits.']
  regulatory_framework varchar [note: 'Applicable regulatory framework for the region (US=EPA/AWWA/NPDWR/UCMR/NPDES; EU=Drinking Water Directive 2020/2184; REACH; Water Framework Directive; Urban Wastewater Treatment Directive; OTHER=Other national/regional frameworks).']
  regulatory_program varchar [note: 'Regulatory program under which permit is issued']
  regulatory_region varchar [note: 'Allowed regions: US,EU,OTHER.']
  regulatory_region_code varchar [note: 'ISO region code identifying the jurisdiction under which this permit was issued (US, EU, OTHER). Supports parallel US NPDES / EU UWWTD permit structures.']
  renewal_application_date date [note: 'Date the renewal application was submitted.']
  renewal_date date
  renewal_due_date date [note: 'Deadline for submitting the renewal application.']
  special_conditions_description varchar [note: 'Description of any special conditions attached to the permit.']
  special_conditions_flag boolean [note: 'Indicates whether the permit has special conditions.']
  updated_timestamp timestamp [note: 'Record last update timestamp']
  us_reference_path varchar [note: 'US reference path: EPA/AWWA/NPDWR/UCMR/NPDES citation chain.']
  watershed_name varchar [note: 'Name of the watershed associated with this permit.']

  Note: 'Master record for all regulatory permits held by the utility including NPDES, SDWA, air quality, and state-level permits with full lifecycle tracking. [SSOT: Canonical permit record; project.project_permit and treatment.treatment_permit reference this as SSOT]'
}

Table compliance.permit_condition {
  permit_condition_id varchar [pk, note: 'Primary key for the permit condition record.']
  analyte_id varchar [note: 'FK to the laboratory analyte being monitored.']
  compliance_permit_id varchar [note: 'FK to permit']
  test_method_id varchar [note: 'FK to the required analytical test method.']
  treatment_permit_id varchar [note: 'FK to the treatment permit this condition belongs to.']
  analytical_method varchar [note: 'Required analytical method for compliance monitoring.']
  compliance_due_date date [note: 'Due date']
  compliance_evaluation_method varchar [note: 'Method used to evaluate compliance with this condition.']
  compliance_schedule_flag boolean [note: 'Indicates if a compliance schedule applies to this condition.']
  compliance_schedule_milestone varchar [note: 'Milestone description for compliance schedule.']
  compliance_status varchar [note: 'Status']
  condition_number varchar [note: 'Unique condition number within the permit.']
  condition_status varchar [note: 'Current status of the condition (Active, Superseded, Expired).']
  condition_text varchar [note: 'Full text of the permit condition.']
  condition_type varchar [note: 'Type of condition (Effluent Limit, Monitoring, Reporting, Narrative).']
  created_timestamp timestamp [note: 'Timestamp when the record was created.']
  detection_limit_requirement decimal(18,6) [note: 'Required method detection limit for the parameter.']
  effective_date date [note: 'Date the condition becomes effective.']
  enforcement_priority varchar [note: 'Priority level for enforcement of this condition.']
  expiration_date date [note: 'Date the condition expires.']
  limit_type varchar [note: 'Type of limit (Daily Max, Monthly Avg, Instantaneous Max).']
  mixing_zone_allowed_flag boolean [note: 'Indicates if a mixing zone is allowed for this parameter.']
  mixing_zone_description varchar [note: 'Description of the allowed mixing zone.']
  modification_date date [note: 'Date of the most recent modification.']
  modification_reason varchar [note: 'Reason for the modification.']
  monitoring_frequency varchar [note: 'Required monitoring frequency (Daily, Weekly, Monthly, Quarterly).']
  monitoring_location varchar [note: 'Required monitoring location for this condition.']
  notes varchar [note: 'Additional notes about the condition.']
  numeric_limit decimal(18,6) [note: 'Numeric limit value for the parameter.']
  parameter_code varchar [note: 'EPA parameter code for the monitored parameter.']
  public_notification_required_flag boolean [note: 'Indicates if public notification is required upon violation.']
  quality_assurance_requirement varchar [note: 'Quality assurance requirements for monitoring.']
  receiving_water_body varchar [note: 'Receiving water body for this condition.']
  record_retention_period_days varchar [note: 'Required record retention period in days.']
  regulatory_basis varchar [note: 'Regulatory basis for the condition (technology-based, water quality-based).']
  reporting_frequency varchar [note: 'Required reporting frequency.']
  sample_type varchar [note: 'Required sample type (Grab, Composite, Continuous).']
  seasonal_period varchar [note: 'Seasonal period if limits vary by season.']
  seasonal_variation_flag boolean [note: 'Indicates if limits vary by season.']
  technology_requirement varchar [note: 'Required treatment technology for this condition.']
  unit_of_measure varchar [note: 'Unit of measure for the numeric limit.']
  updated_timestamp timestamp [note: 'Timestamp when the record was last updated.']
  violation_threshold decimal(18,6) [note: 'Threshold value that triggers a violation.']
  water_quality_standard_basis varchar [note: 'Water quality standard basis for the limit.']

  Note: 'Individual conditions, limits, and monitoring requirements attached to a compliance permit including numeric limits, monitoring frequencies, and reporting requirements.'
}

Table compliance.regulatory_requirement {
  regulatory_requirement_id varchar [pk, note: 'Primary key.']
  analyte_id varchar [note: 'FK to the analyte this requirement governs.']
  regulatory_agency_id varchar [note: 'FK to agency']
  required_position_id varchar [note: 'FK to the position required for compliance.']
  test_method_id varchar [note: 'FK to the approved test method.']
  applicable_facility_type varchar [note: 'Facility types to which this requirement applies.']
  applicable_system_size varchar [note: 'System size categories to which this applies.']
  ccr_reporting_required boolean [note: 'Whether CCR reporting is required.']
  compliance_deadline date [note: 'Deadline for achieving compliance.']
  compliance_status varchar [note: 'Current compliance status.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  effective_date date [note: 'Date the requirement becomes effective.']
  enforcement_priority varchar [note: 'Priority level for enforcement.']
  eu_directive_reference varchar [note: 'Reference to applicable EU directive (e.g. Drinking Water Directive 2020/2184, REACH Regulation EC 1907/2006, Water Framework Directive 2000/60/EC, Urban Wastewater Treatment Directive 91/271/EEC).']
  eu_parametric_value decimal(18,6) [note: 'EU parametric value (equivalent to US MCL) as defined in DWD 2020/2184 Annex I for drinking water parameters.']
  eu_parametric_value_unit varchar [note: 'Unit of measure for the EU parametric value (e.g. ug/L, mg/L, Bq/L).']
  eu_reference_path varchar [note: 'EU reference path: Drinking Water Directive 2020/2184; REACH; WFD; UWWTD citation chain.']
  eu_regulatory_framework varchar [note: 'EU framework reference path (e.g. Drinking Water Directive 2020/2184,REACH,Water Framework Directive,Urban Wastewater Treatment Directive). REACH restriction targets broader PFAS class, not individual compounds; WFD defines surface-water status differently']
  internal_policy_reference varchar [note: 'Reference to internal policy implementing this requirement.']
  international_standard_reference varchar [note: 'Reference to WHO guidelines or other international standards applicable beyond US/EU jurisdictions.']
  is_active boolean [note: 'Whether the requirement is currently active.']
  issuing_authority varchar [note: 'Authority that issued the requirement.']
  jurisdiction varchar [note: 'Regulatory jurisdiction (US-Federal, US-State, EU, UK, other). Allowed regions: US,EU,OTHER.']
  jurisdiction_code varchar
  jurisdiction_country_code varchar [note: 'Country code for the jurisdiction (US, EU, FR, UK, DE).']
  jurisdiction_effective_date date [note: 'Date from which this regulatory requirement becomes effective in the specified jurisdiction, supporting phased international rollouts.']
  last_compliance_assessment_date date [note: 'Date of last compliance assessment.']
  last_modified_timestamp timestamp [note: 'Last modification timestamp.']
  mcl_unit varchar [note: 'Unit of measure for the MCL value.']
  mcl_value decimal(18,6) [note: 'Maximum Contaminant Level value.']
  mclg_unit varchar [note: 'Unit of measure for the MCLG value.']
  mclg_value decimal(18,6) [note: 'Maximum Contaminant Level Goal value.']
  monitoring_frequency varchar [note: 'Required monitoring frequency.']
  next_compliance_review_date date [note: 'Date of next scheduled compliance review.']
  notes varchar [note: 'Additional notes.']
  other_reference_path varchar [note: 'Other national/regional regulatory reference path.']
  penalty_description varchar [note: 'Description of penalties for non-compliance.']
  public_notification_required boolean [note: 'Whether public notification is required upon violation.']
  reach_pfas_class_scope_flag boolean [note: 'True when requirement reflects REACH restriction of the broader PFAS class rather than individual compounds.']
  region_code varchar [note: 'ISO-style region code: US|EU|FR|UK|DE']
  regulation_url varchar [note: 'URL to the regulation text.']
  regulatory_citation varchar [note: 'Formal citation of the regulation.']
  regulatory_framework varchar [note: 'Applicable regulatory framework for the region (US=EPA/AWWA/NPDWR/UCMR/NPDES; EU=Drinking Water Directive 2020/2184; REACH; Water Framework Directive; Urban Wastewater Treatment Directive; OTHER=Other national/regional frameworks).']
  regulatory_program varchar [note: 'Regulatory program (NPDWR, NPDES, UCMR, EU-DWD, REACH).']
  regulatory_region varchar [note: 'Allowed regions: US,EU,OTHER.']
  regulatory_region_code varchar [note: 'ISO region code identifying the regulatory jurisdiction (US, EU, OTHER) under which this requirement applies. Enables parallel US/EU/other regulatory reference paths.']
  reporting_frequency varchar [note: 'Required reporting frequency.']
  requirement_category varchar [note: 'Category of the requirement.']
  requirement_code varchar [note: 'Unique code for the requirement.']
  requirement_description varchar [note: 'Detailed description of the requirement.']
  requirement_name varchar [note: 'Requirement name']
  requirement_text varchar [note: 'Full text']
  requirement_title varchar [note: 'Title of the requirement.']
  responsible_department varchar [note: 'Department responsible for compliance.']
  revision_date date [note: 'Date of the most recent revision.']
  superseded_requirement_code varchar [note: 'Code of the requirement this supersedes.']
  treatment_technique_description varchar [note: 'Description of required treatment technique.']
  us_reference_path varchar [note: 'US reference path: EPA/AWWA/NPDWR/UCMR/NPDES citation chain.']
  us_regulatory_framework varchar [note: 'US framework reference path (e.g. EPA,AWWA,NPDWR,UCMR,NPDES).']
  wfd_surface_water_status_basis varchar [note: 'Water Framework Directive surface-water status classification basis (differs from US determination).']

  Note: 'Master catalog of regulatory requirements from federal, state, and international authorities including SDWA NPDWR, NPDES, EU DWD 2020/2184, and state primacy rules with jurisdiction dimension for multi-region support.'
}

Table compliance.obligation {
  obligation_id varchar [pk, note: 'Primary key.']
  assigned_employee_id varchar [note: 'FK to assigned employee.']
  compliance_permit_id varchar [note: 'FK to the compliance permit.']
  cost_center_id varchar [note: 'FK to cost center.']
  facility_id varchar [note: 'FK to facility.']
  finance_budget_id varchar [note: 'FK to budget.']
  regulatory_requirement_id varchar [note: 'FK to regulatory requirement.']
  sampling_plan_id varchar [note: 'FK to sampling plan.']
  vendor_id varchar [note: 'FK to vendor.']
  actual_cost decimal(18,2) [note: 'Actual cost incurred.']
  actual_effort_hours decimal(10,2) [note: 'Actual effort in hours.']
  completed_by varchar [note: 'Person who completed the obligation.']
  completion_date date [note: 'Date the obligation was completed.']
  completion_timestamp timestamp [note: 'Timestamp of completion.']
  contact_email varchar [note: 'Contact email for the obligation.']
  contact_person varchar [note: 'Contact person name.']
  contact_phone varchar [note: 'Contact phone number.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  due_date date [note: 'Due date for the obligation.']
  effective_end_date date [note: 'End of effective period.']
  effective_start_date date [note: 'Start of effective period.']
  escalation_required boolean [note: 'Whether escalation is required.']
  estimated_cost decimal(18,2) [note: 'Estimated cost.']
  estimated_effort_hours decimal(10,2) [note: 'Estimated effort in hours.']
  evidence_of_fulfillment varchar [note: 'Evidence that the obligation was fulfilled.']
  is_critical_path boolean [note: 'Whether this is on the critical path.']
  last_modified_by varchar [note: 'User who last modified.']
  last_modified_timestamp timestamp [note: 'Last modification timestamp.']
  notes varchar [note: 'Additional notes.']
  obligation_description varchar [note: 'Detailed description.']
  obligation_number varchar [note: 'Unique obligation number.']
  obligation_status varchar [note: 'Current status.']
  obligation_type varchar [note: 'Type of obligation.']
  priority_level varchar [note: 'Priority level.']
  recurrence_interval varchar [note: 'Recurrence interval in days.']
  recurrence_pattern varchar [note: 'Recurrence pattern description.']
  regulatory_authority varchar [note: 'Regulatory authority.']
  regulatory_citation varchar [note: 'Regulatory citation.']
  responsible_department varchar [note: 'Responsible department.']
  responsible_party varchar [note: 'Responsible party.']
  risk_category varchar [note: 'Risk category.']
  submission_confirmation_number varchar [note: 'Confirmation number from submission.']
  submission_method varchar [note: 'Method of submission.']
  text varchar [note: 'Obligation text']
  title varchar [note: 'Obligation title.']
  created_by varchar [note: 'User who created the record.']

  Note: 'Trackable compliance obligations derived from permits, regulations, and enforcement actions with due dates, responsible parties, and fulfillment evidence.'
}

Table compliance.dmr {
  dmr_id varchar [pk, note: 'Primary key.']
  compliance_permit_id varchar [note: 'FK to compliance permit.']
  cost_center_id varchar [note: 'FK to cost center.']
  facility_id varchar [note: 'FK to facility.']
  original_dmr_id varchar [note: 'Self-referential FK for resubmissions.']
  outfall_id varchar [note: 'FK to outfall.']
  regulatory_requirement_id varchar [note: 'FK to the governing regulatory requirement, providing the parallel US/EU/other reference path.']
  regulatory_submission_id varchar [note: 'FK to regulatory submission.']
  acknowledgment_date date [note: 'Date agency acknowledged receipt.']
  certification_date date [note: 'Date the DMR was certified.']
  certification_statement varchar [note: 'Certification statement text.']
  certifying_official_name varchar [note: 'Name of certifying official.']
  certifying_official_title varchar [note: 'Title of certifying official.']
  comments varchar [note: 'Comments on the DMR.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  dmr_number varchar [note: 'Unique DMR number.']
  eu_reference_path varchar [note: 'EU reference path: Drinking Water Directive 2020/2184; REACH; WFD; UWWTD citation chain.']
  eu_reporting_obligation_code varchar [note: 'EU-specific reporting obligation identifier (e.g. UWWTD Art 15, WFD Art 5 characterisation) when regulatory_region_code is EU. NULL for US.']
  exceedance_count varchar [note: 'Number of exceedances in this DMR.']
  jurisdiction varchar [note: 'Jurisdiction flavor for this record. Allowed: US,EU,OTHER.']
  jurisdiction_code varchar [note: 'Regulatory jurisdiction for this DMR submission (US_EPA, US_STATE, EU_MEMBER_STATE, OTHER). EU equivalent is the UWWTD Article 15 reporting or WFD River Basin Management Plan reporting.']
  jurisdiction_region varchar [note: 'Regulatory region code (US, EU, OTHER) for this discharge monitoring report. US uses EPA DMR format; EU uses equivalent reporting under Urban Wastewater Treatment Directive or Water Framework Directive.']
  late_submission_flag boolean [note: 'Whether the DMR was submitted late.']
  modified_by varchar [note: 'User who last modified.']
  modified_timestamp timestamp [note: 'Last modification timestamp.']
  monitoring_location_code varchar [note: 'Monitoring location code.']
  no_discharge_flag boolean [note: 'Whether there was no discharge during the period.']
  no_discharge_reason varchar [note: 'Reason for no discharge.']
  noncompliance_flag boolean [note: 'Whether noncompliance was reported.']
  other_reference_path varchar [note: 'Other national/regional regulatory reference path.']
  preparer_email varchar [note: 'Email of the preparer.']
  preparer_name varchar [note: 'Name of the preparer.']
  preparer_phone varchar [note: 'Phone of the preparer.']
  preparer_title varchar [note: 'Title of the preparer.']
  regulatory_authority varchar [note: 'Regulatory authority receiving the DMR.']
  regulatory_framework varchar [note: 'Applicable regulatory framework for the region (US=EPA/AWWA/NPDWR/UCMR/NPDES; EU=Drinking Water Directive 2020/2184; REACH; Water Framework Directive; Urban Wastewater Treatment Directive; OTHER=Other national/regional frameworks).']
  regulatory_region varchar [note: 'Top-level regulatory region (US, EU, OTHER). Determines whether NPDES DMR format or EU UWWTD/WFD reporting format applies. Allowed regions: US,EU,OTHER.']
  regulatory_region_code varchar [note: 'ISO region code identifying the jurisdiction for this discharge monitoring report (US, EU, OTHER). US uses EPA DMR; EU uses UWWTD Art 15 reporting.']
  rejection_reason varchar [note: 'Reason for rejection if applicable.']
  reporting_frequency varchar [note: 'Reporting frequency.']
  reporting_period_end date [note: 'Period end']
  reporting_period_end_date date [note: 'End of reporting period.']
  reporting_period_start date [note: 'Period start']
  reporting_period_start_date date [note: 'Start of reporting period.']
  resubmission_flag boolean [note: 'Whether this is a resubmission.']
  state_agency_name varchar [note: 'State agency name.']
  submission_date date [note: 'Date submitted.']
  submission_due_date date [note: 'Due date for submission.']
  submission_method varchar [note: 'Method of submission.']
  submission_status varchar [note: 'Current submission status.']
  us_reference_path varchar [note: 'US reference path: EPA/AWWA/NPDWR/UCMR/NPDES citation chain.']
  created_by varchar [note: 'User who created the record.']

  Note: 'Discharge Monitoring Report submissions to regulatory agencies containing monitoring data, certification, and compliance status for NPDES permits.'
}

Table compliance.dmr_result {
  dmr_result_id varchar [pk, note: 'Primary key.']
  compliance_permit_id varchar [note: 'FK to compliance permit.']
  dmr_employee_id varchar [note: 'FK to employee who collected sample.']
  dmr_id varchar [note: 'FK to DMR']
  dmr_modified_by_user_employee_id varchar [note: 'FK to employee who modified.']
  dmr_submission_id varchar [note: 'FK to DMR submission.']
  finished_water_production_id varchar [note: 'FK to finished water production.']
  lab_sample_id varchar [note: 'FK to lab sample.']
  laboratory_id varchar [note: 'FK to laboratory.']
  outfall_id varchar [note: 'FK to outfall.']
  treatment_chemical_material_master_id varchar [note: 'FK to material master for treatment chemical.']
  analysis_date date [note: 'Date of analysis.']
  analytical_method varchar [note: 'Analytical method used.']
  compliance_status varchar [note: 'Compliance status for this result.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  data_quality_flag boolean [note: 'Data quality flag.']
  detection_limit decimal(18,6) [note: 'Method detection limit.']
  enforcement_action_required boolean [note: 'Whether enforcement action is required.']
  exceedance_flag boolean [note: 'Whether the result exceeds the limit.']
  exceedance_percentage decimal(8,4) [note: 'Percentage by which the limit was exceeded.']
  limit_value decimal(18,6) [note: 'Limit value']
  measured_value decimal(18,6) [note: 'Measured value']
  measurement_frequency varchar [note: 'Measurement frequency.']
  measurement_value decimal(18,6) [note: 'Measured value.']
  modified_timestamp timestamp [note: 'Last modification timestamp.']
  monitoring_location_code varchar [note: 'Monitoring location code.']
  nodi_code varchar [note: 'No Data Indicator code.']
  number_of_exceedances varchar [note: 'Number of exceedances.']
  number_of_samples varchar [note: 'Number of samples collected.']
  parameter_code varchar [note: 'EPA parameter code.']
  parameter_name varchar [note: 'Parameter name.']
  permit_limit_type varchar [note: 'Type of permit limit.']
  permit_limit_value decimal(18,6) [note: 'Permit limit value.']
  qa_qc_notes varchar [note: 'QA/QC notes.']
  qualifier_code varchar [note: 'Result qualifier code.']
  quantification_limit decimal(18,6) [note: 'Quantification limit.']
  reporting_period_end_date date [note: 'End of reporting period.']
  reporting_period_start_date date [note: 'Start of reporting period.']
  sample_collection_date date [note: 'Date sample was collected.']
  sample_collection_time timestamp [note: 'Time sample was collected.']
  sample_type varchar [note: 'Type of sample.']
  statistical_base varchar [note: 'Statistical base for the result.']
  submission_timestamp timestamp [note: 'Timestamp of submission.']
  submitted_to_regulator_flag boolean [note: 'Whether submitted to regulator.']
  unit_of_measure varchar [note: 'Unit of measure.']
  violation_category varchar [note: 'Category of violation if applicable.']

  Note: 'Individual parameter results within a DMR submission including measured values, permit limits, compliance status, and QA/QC information.'
}

Table compliance.mor {
  mor_id varchar [pk, note: 'Unique identifier for the Monthly Operating Report record.']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Monthly operating reports document operational changes due to capital projects (new treatment process online, capacity increase, process modifications). Required for explaining operational variations ']
  coagulant_material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Monthly Operating Reports document specific coagulant products used (alum, ferric chloride) which must link to material master for regulatory traceability and NSF/ANSI 60 compliance verification.']
  mor_facility_id varchar [note: 'FK to facility']
  mor_wtp_facility_id varchar [note: 'Identifier of the water treatment plant facility for which this MOR is submitted.']
  preparer_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Monthly Operating Reports must be prepared by licensed operators. Links MOR to specific employee for license verification, training tracking, and regulatory audit trail. Replaces denormalized preparer']
  regulatory_requirement_id varchar [note: 'FK to the governing regulatory requirement, providing the parallel US/EU/other reference path.']
  regulatory_submission_id varchar [note: 'Foreign key linking to compliance.regulatory_submission. Business justification: The Monthly Operating Report (MOR) is a recurring regulatory submission to the state primacy agency. The mor table tracks submission_date and submission_method, which are submission metadata that belo']
  sampling_location_id varchar [note: 'Foreign key linking to laboratory.sampling_location. Business justification: Monthly Operating Reports aggregate treatment performance data from specific sampling locations (raw water intake, finished water, distribution system). Essential for correlating operational data with']
  agency_response_date date [note: 'Date on which the state primacy agency responded to or acknowledged the submitted MOR.']
  agency_response_received boolean [note: 'Indicates whether a response or acknowledgment was received from the state primacy agency after submission.']
  alkalinity_avg_mg_l decimal(10,3) [note: 'Average alkalinity of finished water during the reporting month.']
  average_daily_flow_mgd decimal(12,4) [note: 'Average daily flow rate of treated water produced during the reporting month.']
  certification_date date [note: 'The date on which the certified operator signed and certified the MOR.']
  certification_status varchar [note: 'Current status of the MOR in the certification and submission workflow.']
  certifier_license_number varchar [note: 'State-issued water treatment operator license number of the certifying operator.']
  certifier_name varchar [note: 'Full name of the certified operator who reviewed and certified the accuracy of the MOR.']
  coagulant_dosage_avg_mg_l decimal(10,3) [note: 'Average coagulant dosage applied during the reporting month.']
  compliance_status varchar [note: 'Compliance status']
  created_timestamp timestamp [note: 'Timestamp when this MOR record was first created in the system.']
  ct_compliance_status varchar [note: 'Indicates whether the achieved CT value met or exceeded the required CT value for the reporting month.']
  ct_value_achieved decimal(12,3) [note: 'Calculated CT value (disinfectant concentration multiplied by contact time) achieved for pathogen inactivation during the reporting month.']
  ct_value_required decimal(12,3) [note: 'Regulatory CT value required for adequate pathogen inactivation based on water temperature and pH.']
  disinfectant_residual_avg_mg_l decimal(10,3) [note: 'Average disinfectant residual concentration in the distribution system during the reporting month.']
  disinfectant_residual_min_mg_l decimal(10,3) [note: 'Minimum disinfectant residual concentration recorded in the distribution system during the reporting month.']
  disinfectant_type varchar [note: 'Primary disinfection method used at the treatment plant during the reporting month.']
  eu_operational_monitoring_type varchar [note: 'EU DWD 2020/2184 operational monitoring classification (e.g. Group A parameters, Group B parameters, risk-based monitoring) when regulatory_region_code is EU.']
  eu_reference_path varchar [note: 'EU reference path: Drinking Water Directive 2020/2184; REACH; WFD; UWWTD citation chain.']
  finished_water_turbidity_avg_ntu decimal(10,3) [note: 'Average turbidity of finished treated water leaving the plant during the reporting month.']
  finished_water_turbidity_max_ntu decimal(10,3) [note: 'Maximum turbidity of finished treated water recorded during the reporting month.']
  fluoride_avg_mg_l decimal(10,3) [note: 'Average fluoride concentration in finished water during the reporting month.']
  jurisdiction varchar [note: 'Jurisdiction flavor for this record. Allowed: US,EU,OTHER.']
  jurisdiction_code varchar [note: 'Regulatory jurisdiction for this MOR submission (US_STATE, US_EPA, EU_MEMBER_STATE, OTHER). EU equivalent is DWD 2020/2184 Article 13 operational monitoring report.']
  jurisdiction_region varchar [note: 'Regulatory region code (US, EU, OTHER) for this monthly operating report. US uses state primacy agency MOR format; EU uses equivalent operational reporting under Drinking Water Directive 2020/2184.']
  modified_timestamp timestamp [note: 'Timestamp when this MOR record was last modified.']
  operational_events_count decimal(18,6) [note: 'Number of significant operational events (equipment failures, process upsets, maintenance shutdowns) recorded during the reporting month.']
  operational_events_description decimal(18,6) [note: 'Narrative description of significant operational events that occurred during the reporting month.']
  other_reference_path varchar [note: 'Other national/regional regulatory reference path.']
  peak_daily_flow_mgd decimal(12,4) [note: 'Maximum daily flow rate of treated water produced during the reporting month.']
  ph_avg decimal(5,2) [note: 'Average pH level of finished water during the reporting month.']
  preparer_license_number varchar [note: 'State-issued water treatment operator license number of the preparer.']
  preparer_title varchar [note: 'Job title or role of the individual who prepared the MOR.']
  raw_water_turbidity_avg_ntu decimal(10,3) [note: 'Average turbidity of raw source water entering the treatment plant during the reporting month.']
  raw_water_turbidity_max_ntu decimal(10,3) [note: 'Maximum turbidity of raw source water recorded during the reporting month.']
  regulatory_framework varchar [note: 'Applicable regulatory framework for the region (US=EPA/AWWA/NPDWR/UCMR/NPDES; EU=Drinking Water Directive 2020/2184; REACH; Water Framework Directive; Urban Wastewater Treatment Directive; OTHER=Other national/regional frameworks).']
  regulatory_region varchar [note: 'Top-level regulatory region (US, EU, OTHER). Determines whether US state MOR format or EU DWD operational monitoring format applies. Allowed regions: US,EU,OTHER.']
  regulatory_region_code varchar [note: 'ISO region code identifying the jurisdiction for this monthly operating report (US, EU, OTHER). US uses state primacy agency MOR; EU uses DWD 2020/2184 operational monitoring.']
  report_number varchar [note: 'Externally-known unique report number assigned by the state primacy agency or internal tracking system.']
  reporting_month date [note: 'The calendar month for which this MOR documents water treatment plant operations.']
  reporting_period_end date [note: 'Period end']
  reporting_period_start date [note: 'Period start']
  reporting_year varchar [note: 'The calendar year for which this MOR is submitted.']
  source_water_type varchar [note: 'Primary type of source water used by the treatment plant during the reporting month.']
  submission_date date [note: 'Submission date']
  submission_status varchar [note: 'Status']
  total_production_mg decimal(12,4) [note: 'Total production']
  total_water_produced_mgd decimal(12,4) [note: 'Total volume of treated water produced by the WTP during the reporting month, measured in million gallons per day.']
  turbidity_compliance_status varchar [note: 'Indicates whether turbidity levels met regulatory Maximum Contaminant Level (MCL) requirements during the reporting month.']
  us_reference_path varchar [note: 'US reference path: EPA/AWWA/NPDWR/UCMR/NPDES citation chain.']
  violations_count varchar [note: 'Number of regulatory violations (MCL exceedances, monitoring failures, reporting failures) recorded during the reporting month.']
  violations_description varchar [note: 'Narrative description of regulatory violations that occurred during the reporting month.']

  Note: 'Monthly Operating Report (MOR) submitted to the state primacy agency documenting drinking water treatment plant operations, including treatment process performance, chemical dosing, CT (Contact Time for Disinfection) calculations, turbidity (NTU) compliance, disinfection residuals, source water quality, and operational events. Tracks the WTP facility, reporting month, preparer, submission date, certification status, and key operational parameters required by the state drinking water program under SDWA.'
}

Table compliance.compliance_violation {
  compliance_violation_id varchar [pk, note: 'Primary key.']
  compliance_permit_id varchar [note: 'FK to the permit that was violated.']
  discovered_by_employee_id varchar [note: 'FK to employee who discovered the violation.']
  facility_id varchar [note: 'FK to the facility where the violation occurred.']
  regulatory_requirement_id varchar [note: 'FK to the regulatory requirement violated.']
  test_result_id varchar [note: 'FK to the test result that triggered the violation.']
  affected_population varchar [note: 'Estimated population affected by the violation']
  agency_notification_date date [note: 'Date agency was notified.']
  compliance_period_begin date [note: 'Start of the compliance monitoring period']
  compliance_period_begin_date date [note: 'Start of the compliance monitoring period']
  compliance_period_end date [note: 'End of the compliance monitoring period']
  compliance_period_end_date date [note: 'End of the compliance monitoring period']
  compliance_violation_description varchar [note: 'Narrative description of the violation.']
  contaminant_code varchar [note: 'EPA contaminant code associated with the violation']
  contaminant_name varchar [note: 'Name of the contaminant involved.']
  corrective_action_completed_date date [note: 'Date corrective action was completed']
  corrective_action_description varchar [note: 'Description of corrective action taken.']
  corrective_action_due_date date [note: 'Deadline for completing corrective action']
  corrective_action_required varchar [note: 'Whether corrective action is required']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  detection_date date [note: 'Date the violation was detected']
  discovered_date date
  discovery_date date [note: 'Date the violation was discovered.']
  enforcement_action_flag boolean [note: 'Whether enforcement action was taken.']
  enforcement_action_pending boolean [note: 'Whether enforcement action is pending']
  enforcement_action_required boolean [note: 'Enforcement required']
  enforcement_action_taken boolean [note: 'Whether formal enforcement action was taken']
  health_based_flag boolean [note: 'Whether this is a health-based violation']
  health_effects_statement varchar [note: 'Health effects statement.']
  is_health_based boolean [note: 'Whether the violation is health-based (vs. non-health-based).']
  is_public_notification_required boolean [note: 'Whether public notification is required.']
  jurisdiction varchar [note: 'Jurisdiction']
  last_modified_timestamp timestamp [note: 'Last modification timestamp.']
  limit_value decimal(18,6) [note: 'Regulatory limit value.']
  mcl_value decimal(18,6) [note: 'Maximum Contaminant Level that was exceeded']
  measured_value decimal(18,6) [note: 'Measured value that triggered the violation.']
  modified_timestamp timestamp [note: 'Record last modification timestamp']
  notes varchar [note: 'Additional notes.']
  notification_tier varchar
  parameter_name varchar
  penalty_amount decimal(18,2) [note: 'Penalty amount assessed.']
  penalty_amount_usd decimal(18,2) [note: 'Monetary penalty assessed in USD']
  population_affected varchar [note: 'Number of people affected.']
  primacy_agency_code varchar [note: 'Code of the primacy agency with jurisdiction']
  public_notification_date date [note: 'Date public notification was issued.']
  public_notification_issued_date date [note: 'Date public notification was issued']
  public_notification_required boolean [note: 'Whether public notification is required.']
  public_notification_required_flag boolean
  pwsid varchar [note: 'Public Water System ID associated with the violation']
  regulation_citation varchar [note: 'Regulatory citation breached.']
  regulatory_agency_notified_date date [note: 'Date the regulatory agency was notified']
  regulatory_citation varchar [note: 'Regulatory citation.']
  regulatory_limit decimal(18,6)
  regulatory_limit_value decimal(18,6) [note: 'The applicable regulatory limit that was exceeded']
  regulatory_standard varchar
  reported_date date
  reported_to_epa_date date [note: 'Date violation was reported to EPA']
  reported_to_state_date date [note: 'Date violation was reported to the state primacy agency']
  resolution_date date [note: 'Date the violation was resolved.']
  resolution_status varchar [note: 'Current resolution status.']
  resolved_date date [note: 'Date the violation was resolved.']
  return_to_compliance_date date [note: 'Date returned to compliance.']
  root_cause varchar [note: 'Root cause analysis.']
  rtc_date date [note: 'Date the system returned to compliance']
  rule_code varchar [note: 'Regulatory rule code (e.g., SWTR, LCR, TCR, DBP)']
  rule_name varchar [note: 'Full name of the regulatory rule violated.']
  sdwis_violation_number varchar [note: 'Violation ID in the Safe Drinking Water Information System.']
  severity varchar [note: 'Severity classification of the violation.']
  severity_level varchar [note: 'Severity level (Tier 1, Tier 2, Tier 3).']
  unit_of_measure varchar [note: 'Unit of measure.']
  updated_timestamp timestamp [note: 'Record last update timestamp']
  violation_begin_date date [note: 'Date the violation period began']
  violation_category varchar [note: 'Category of violation.']
  violation_date date [note: 'Date the violation occurred.']
  violation_description varchar
  violation_end_date date [note: 'Date the violation period ended']
  violation_number varchar [note: 'Unique violation tracking number.']
  violation_severity varchar
  violation_status varchar [note: 'Current status (Open, Resolved, Under Review).']
  violation_type varchar [note: 'Type of violation (MCL, Monitoring, Treatment Technique, Reporting).']

  Note: 'Records of regulatory violations including MCL exceedances, monitoring violations, treatment technique violations, and reporting violations with severity, root cause, and resolution tracking. [SSOT: Canonical violation record; treatment.treatment_violation references this as SSOT]'
}

Table compliance.enforcement_action {
  enforcement_action_id varchar [pk, note: 'Unique identifier for the enforcement action record. Primary key.']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Enforcement actions (consent decrees, administrative orders) mandate capital projects with specific completion deadlines. Tracking this link is essential for compliance schedule management, regulatory']
  compliance_permit_id varchar [note: 'Reference to the permit under which the violation and enforcement action occurred (NPDES permit, drinking water permit, IUP, etc.).']
  compliance_violation_id varchar [note: 'Reference to the primary violation record that triggered this enforcement action. Links to the violation tracking system.']
  facility_id varchar [note: 'Reference to the water treatment plant (WTP), wastewater treatment plant (WWTP), or other facility subject to the enforcement action.']
  lab_sample_id varchar [note: 'Foreign key linking to laboratory.lab_sample. Business justification: Enforcement actions often reference specific samples as evidence (e.g., NOVs citing sample collection dates). Legal defensibility requires chain of custody from enforcement action back to physical sam']
  regulatory_agency_id varchar [note: 'FK to agency']
  remediation_vendor_id varchar [note: 'Foreign key linking to supply.vendor. Business justification: Enforcement actions often require specialized vendor services (engineering studies, equipment upgrades, environmental consulting) to achieve compliance. Tracks vendor responsible for remediation work.']
  responsible_manager_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Enforcement actions require designated management oversight for response coordination, legal liaison, and board reporting. Links to employee for accountability tracking and workload management. Replac']
  action_date date [note: 'Action date']
  action_number varchar [note: 'Official enforcement action number or case number assigned by the regulatory agency (EPA, state primacy agency, NPDES authority). This is the externally-known identifier used in all regulatory correspondence and legal documents.']
  action_status varchar [note: 'Current lifecycle status of the enforcement action. Tracks progression from issuance through utility response, negotiation, and final resolution.']
  action_summary varchar [note: 'Brief summary of the enforcement action, including the nature of the violation, regulatory basis, and key requirements. Provides context for reporting and management review.']
  action_type varchar [note: 'Type of formal enforcement action initiated by the regulatory agency. Includes Notice of Violation (NOV), Administrative Order (AO), Consent Order, Compliance Schedule, civil penalty assessment, or criminal referral.']
  appeal_filed_flag boolean [note: 'Indicates whether the utility filed a formal appeal or contested the enforcement action through administrative or judicial proceedings.']
  appeal_filing_date date [note: 'Date the utility filed its appeal or petition for review. Null if no appeal was filed.']
  board_notification_date date [note: 'Date the utility\'s Board of Directors or governing body was notified of the enforcement action. Tracks governance and executive oversight requirements.']
  civil_penalty_amount decimal(15,2) [note: 'Monetary penalty amount assessed by the regulatory agency in U.S. dollars. Null if no civil penalty was imposed.']
  compliance_schedule_final_deadline date [note: 'Final deadline by which all corrective actions and compliance milestones must be completed. Null if no compliance schedule is required.']
  compliance_schedule_required_flag boolean [note: 'Indicates whether the enforcement action includes a formal compliance schedule with milestones and deadlines for corrective actions.']
  corrective_action_required boolean [note: 'Description of the corrective actions required by the enforcement action. May include operational changes, infrastructure upgrades, process improvements, or enhanced monitoring.']
  created_timestamp timestamp [note: 'Timestamp when this enforcement action record was first created in the system. Audit trail for data lineage.']
  document_reference_number varchar [note: 'Internal document management system reference number for the enforcement action file. Links to stored correspondence, legal documents, and supporting materials.']
  issue_date date [note: 'Date the enforcement action was officially issued or signed by the regulatory agency. This is the principal business event timestamp for the enforcement action lifecycle.']
  issuing_agency varchar [note: 'Name of the regulatory agency that issued the enforcement action (e.g., U.S. Environmental Protection Agency, State Department of Environmental Quality, Regional Water Quality Control Board).']
  issuing_agency_region varchar [note: 'Regional office, district, or jurisdiction of the issuing agency (e.g., EPA Region 5, Northwest Regional Office). Identifies the specific regulatory authority within the agency structure.']
  last_modified_timestamp timestamp [note: 'Timestamp when this enforcement action record was last updated. Audit trail for change tracking.']
  legal_counsel_assigned varchar [note: 'Name of the internal or external legal counsel assigned to manage the utility\'s response to the enforcement action. Business-confidential information.']
  legal_firm_name varchar [note: 'Name of the external law firm representing the utility, if external counsel is engaged. Null if handled internally.']
  modified_by_user varchar [note: 'User ID or name of the person who last modified this enforcement action record. Audit trail for accountability.']
  notes varchar [note: 'Free-text notes capturing additional context, internal discussions, negotiation history, or other relevant information not captured in structured fields.']
  penalty_amount decimal(18,2) [note: 'Penalty amount']
  penalty_paid_amount decimal(15,2) [note: 'Actual amount paid by the utility toward the civil penalty. May differ from assessed amount due to negotiated settlements or payment plans.']
  penalty_payment_date date [note: 'Date the civil penalty payment was made to the regulatory agency. Tracks compliance with payment deadlines.']
  public_notice_date date [note: 'Date public notice of the enforcement action was issued. Null if public notice is not required.']
  public_notice_required_flag boolean [note: 'Indicates whether the enforcement action requires public notification under regulatory or consent order terms. Drives public communication and transparency obligations.']
  received_date date [note: 'Date the utility officially received the enforcement action notice. Used to calculate response deadlines and compliance timelines.']
  regulatory_citation varchar [note: 'Specific regulatory statute, rule, or permit condition cited in the enforcement action (e.g., Clean Water Act Section 301, 40 CFR 122.41, NPDES Permit Condition III.A.1). Identifies the legal basis for the enforcement.']
  resolution_date date [note: 'Date the enforcement action was formally resolved or closed. Indicates completion of all required corrective actions, penalty payments, and regulatory obligations.']
  resolution_outcome varchar [note: 'Final outcome of the enforcement action. Indicates how the action was resolved (compliance achieved, consent order executed, penalty paid, dismissed, or under appeal).']
  response_due_date date [note: 'Deadline by which the utility must submit a formal response to the enforcement action. Typically specified in the enforcement notice or calculated based on regulatory timelines.']
  response_submitted_date date [note: 'Date the utility submitted its formal response to the enforcement action. Tracks compliance with response deadlines.']
  sep_description varchar [note: 'Description of the Supplemental Environmental Project (SEP) agreed to as part of the enforcement settlement. Null if no SEP is included.']
  sep_estimated_cost decimal(15,2) [note: 'Estimated cost of the Supplemental Environmental Project (SEP) in U.S. dollars. Used to calculate penalty offsets and track SEP investment.']
  supplemental_environmental_project_flag boolean [note: 'Indicates whether the enforcement action includes a Supplemental Environmental Project (SEP) as part of the settlement. SEPs are environmentally beneficial projects that go beyond compliance requirements and may offset civil penalties.']

  Note: 'Formal enforcement action initiated by a regulatory agency (EPA, state primacy agency, NPDES authority) against the utility in response to violations, including Notices of Violation (NOVs), Administrative Orders (AOs), Consent Orders, Compliance Schedules, civil penalties, and criminal referrals. Tracks the issuing agency, action type, associated violations, compliance schedule milestones, penalty amounts, response deadlines, legal counsel assigned, and resolution outcome. Drives the utility\'s formal regulatory response process.'
}

Table compliance.compliance_public_notification {
  compliance_public_notification_id varchar [pk, note: 'Unique identifier for the public notification record. Primary key.']
  ccr_id varchar [note: 'Foreign key linking to compliance.ccr. Business justification: SDWA requires that public notifications for MCL violations be included in the annual Consumer Confidence Report (CCR). The public_notification table tracks individual notifications, and the ccr table ']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Public notifications about violations include corrective action project information ("Utility is constructing new filtration plant to address turbidity violations"). Required for public transparency a']
  compliance_approved_by_user_employee_id varchar [note: 'Identifier of the utility manager or compliance officer who approved the public notification for distribution.']
  compliance_employee_id varchar [note: 'Identifier of the utility staff member who prepared the public notification content and documentation.']
  compliance_violation_id varchar [note: 'Reference to the specific water quality or treatment technique violation that triggered this public notification requirement.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Public notification costs (printing, mailing, advertising) are tracked to cost centers for regulatory compliance budgeting and demonstrating compliance expenditures in rate cases.']
  primary_compliance_employee_id varchar [note: 'Identifier of the utility staff member who prepared the public notification content and documentation.']
  test_result_id varchar [note: 'Foreign key linking to laboratory.test_result. Business justification: Public notifications cite specific test results that triggered the notice (e.g., MCL exceedance). Regulatory transparency requirement mandates direct link from public notice to laboratory result for c']
  affected_customer_count varchar [note: 'Total number of customer accounts or service connections in the affected service area that must receive the public notification.']
  affected_service_area varchar [note: 'Geographic description or identifier of the service area, distribution zone, or District Metered Area (DMA) affected by the violation and subject to the public notification.']
  approval_timestamp timestamp [note: 'Date and time when the public notification was approved for distribution by the responsible manager or compliance officer.']
  certification_number varchar [note: 'Tracking number or reference identifier assigned by the primacy agency upon receipt of the public notification certification submission.']
  certification_submitted_date date [note: 'Date on which the certification of public notification completion was submitted to the state primacy agency, as required by SDWA regulations.']
  contact_email_address varchar [note: 'Email address provided in the public notification for customers to contact the utility for additional information.']
  contact_person_name varchar [note: 'Name of the utility contact person provided in the public notification for customers to obtain additional information about the violation and corrective actions.']
  contact_phone_number varchar [note: 'Phone number provided in the public notification for customers to contact the utility for additional information.']
  contaminant_name varchar [note: 'Name of the specific contaminant or parameter that exceeded regulatory limits or was subject to the violation (e.g., Total Coliform, Lead, Copper, Trihalomethanes (THM), Haloacetic Acids (HAA5), Nitrate, PFAS).']
  corrective_action_description varchar [note: 'Description of the corrective actions being taken by the water utility to address the violation and prevent recurrence, as required to be included in the public notification.']
  created_timestamp timestamp [note: 'Date and time when this public notification record was first created in the system.']
  deadline_met_flag boolean [note: 'Boolean indicator of whether the public notification was completed within the regulatory deadline. True if deadline was met, False if deadline was missed.']
  distribution_completion_date date [note: 'Date on which the public notification distribution was completed to all affected customers and required public channels.']
  distribution_cost_amount decimal(15,2) [note: 'Total cost incurred for distributing the public notification, including printing, postage, media advertising, and other distribution expenses.']
  distribution_start_date date [note: 'Date on which the public notification distribution began to affected customers and the public.']
  health_effects_language varchar [note: 'Mandatory health effects language as prescribed by EPA for the specific contaminant or violation type, describing potential health risks to consumers.']
  mcl_value decimal(18,6) [note: 'The regulatory Maximum Contaminant Level (MCL) threshold that was exceeded, expressed in the appropriate unit of measure (mg/L, ug/L, pCi/L, NTU, etc.).']
  measured_value decimal(18,6) [note: 'The actual measured value of the contaminant that triggered the violation, expressed in the same unit of measure as the MCL.']
  media_outlet_list varchar [note: 'List of media outlets (newspapers, radio stations, television stations) to which the public notification was distributed for broadcast or publication, as required for Tier 1 notifications.']
  modified_timestamp timestamp [note: 'Date and time when this public notification record was last modified or updated.']
  notes varchar [note: 'Additional notes, comments, or special circumstances related to the public notification process, distribution challenges, or customer feedback.']
  notification_content varchar [note: 'Full text of the public notification message as distributed to customers, including mandatory elements: description of violation, potential health effects, population at risk, corrective actions, and contact information.']
  notification_date date [note: 'Notification date']
  notification_language varchar [note: 'Primary language(s) in which the notification was issued to ensure accessibility for the affected population. May include multiple languages based on community demographics.']
  notification_method varchar [note: 'Method(s) used to deliver the public notification to affected customers and the public. May include multiple methods such as bill insert, direct mail, hand delivery, posting, newspaper publication, broadcast media (radio/TV), website posting, social media, or email. [ENUM-REF-CANDIDATE: Bill Insert|Direct Mail|Hand Delivery|Posted Notice|Newspaper|Radio|Television|Website|Social Media|Email|Press Release — promote to reference product]']
  notification_number varchar [note: 'Business identifier for the public notification, typically formatted as PN-YYYY-NNNNNN for tracking and regulatory submission purposes.']
  notification_status varchar [note: 'Current lifecycle status of the public notification: Draft (being prepared), Pending Approval (awaiting management review), Approved (ready for distribution), Distributed (sent to customers), Certified (submitted to primacy agency), or Closed (violation resolved and notification cycle complete).']
  notification_text varchar [note: 'Notification text']
  notification_tier varchar [note: 'Classification of notification urgency and timeline as defined by EPA: Tier 1 (immediate, within 24 hours for acute health risks), Tier 2 (within 30 days for less urgent violations), Tier 3 (annual notice via Consumer Confidence Report for monitoring or reporting violations).']
  population_at_risk varchar [note: 'Population at risk']
  primacy_agency_acknowledgment_date date [note: 'Date on which the state primacy agency acknowledged receipt and acceptance of the public notification certification.']
  primacy_agency_name varchar [note: 'Name of the state or tribal primacy agency to which the public notification certification and documentation must be submitted (e.g., State Department of Environmental Quality, State Health Department).']
  public_meeting_date date [note: 'Date on which the public meeting was held to discuss the violation with affected customers and community stakeholders.']
  public_meeting_held_flag boolean [note: 'Boolean indicator of whether a public meeting was held to discuss the violation and corrective actions with affected customers and community stakeholders. True if meeting was held.']
  regulatory_deadline_date date [note: 'The regulatory deadline by which the public notification must be completed based on the notification tier: 24 hours for Tier 1, 30 days for Tier 2, or annual CCR publication for Tier 3.']
  repeat_notification_frequency varchar [note: 'Frequency at which repeat public notifications must be issued for ongoing violations, as specified by the notification tier and primacy agency requirements.']
  repeat_notification_required_flag boolean [note: 'Boolean indicator of whether repeat public notifications are required for ongoing violations. True if repeat notifications must be issued at specified intervals until the violation is resolved.']
  unit_of_measure varchar [note: 'Unit of measure for the contaminant level: milligrams per liter (mg/L), micrograms per liter (ug/L), picocuries per liter (pCi/L), Nephelometric Turbidity Units (NTU), Most Probable Number per 100 milliliters (MPN/100mL), or Colony Forming Units per 100 milliliters (CFU/100mL).']
  violation_date date [note: 'The date on which the violation occurred or was first identified through water quality testing or monitoring.']
  violation_type varchar [note: 'Category of the violation that triggered the notification: Maximum Contaminant Level (MCL) exceedance, Maximum Contaminant Level Goal (MCLG) exceedance, Treatment Technique violation, Monitoring violation, or Reporting violation.']
  website_posting_url varchar [note: 'URL of the utility website page where the public notification was posted for public access and transparency.']

  Note: 'Record of public notifications issued to customers and the public as required by SDWA when MCL violations, treatment technique violations, or other health-based violations occur. Tracks the notification type (Tier 1 immediate, Tier 2 within 30 days, Tier 3 annual), associated violation, affected service area, notification method (bill insert, direct mail, media, website), distribution date, number of customers notified, regulatory submission confirmation, and certification to the state primacy agency. [SSOT: Canonical public notification; quality.quality_public_notification references this as SSOT]'
}

Table compliance.ccr {
  ccr_id varchar [pk, note: 'Unique identifier for the Consumer Confidence Report record. Primary key.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Consumer Confidence Report preparation, printing, and distribution costs are tracked to cost centers for regulatory compliance budgeting and cost allocation.']
  facility_id varchar [note: 'FK to facility']
  prepared_by_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Consumer Confidence Reports require designated preparer for regulatory compliance and quality assurance. Links to employee for training verification, workload tracking, and audit trail of who compiled']
  regulatory_submission_id varchar [note: 'Foreign key linking to compliance.regulatory_submission. Business justification: The Consumer Confidence Report (CCR) is an annual regulatory submission required by SDWA. The ccr table tracks certification_submitted_date, certification_method, and state_certification_number, which']
  sampling_location_id varchar [note: 'Foreign key linking to laboratory.sampling_location. Business justification: Consumer Confidence Reports summarize monitoring data by location (source water, entry points, distribution system). Annual reporting requirement needs direct link to sampling locations for automated ']
  additional_languages varchar [note: 'List of additional languages in which CCR information or translations were provided to serve non-English speaking customers. Pipe-separated list (e.g., Spanish|Chinese|Vietnamese).']
  board_meeting_info varchar [note: 'Information about public meetings where customers can participate in decisions affecting drinking water quality, including meeting times, locations, and how to attend. Required CCR content for community water systems.']
  ccr_status varchar [note: 'Status']
  compliance_status varchar [note: 'Overall compliance status of this CCR with EPA and state requirements. Compliant indicates all requirements met. Non-compliant indicates violations. Pending review indicates state review in progress.']
  contact_email varchar [note: 'Email address for customer inquiries about the Consumer Confidence Report and water quality information.']
  contact_name varchar [note: 'Name of the water system contact person for customer questions about the CCR. Required CCR content per EPA rule.']
  contact_phone varchar [note: 'Phone number for customer inquiries about the Consumer Confidence Report and water quality information. Required CCR content per EPA rule.']
  contaminant_detection_count varchar [note: 'Total number of regulated contaminants detected in the water system during the report year. All detected contaminants must be reported in the CCR regardless of whether they exceed Maximum Contaminant Levels (MCL).']
  copper_90th_percentile_ppm decimal(10,3) [note: '90th percentile value for copper in parts per million from tap water sampling. Action level is 1.3 PPM. Required reporting for systems that conducted lead and copper monitoring.']
  created_timestamp timestamp [note: 'Timestamp when this CCR record was first created in the system. Part of audit trail for regulatory compliance tracking.']
  delivery_method varchar [note: 'Primary method used to deliver this CCR to customers. Mail is direct postal delivery. Electronic includes email and online posting. Hand delivery for small systems. Newspaper publication for certain systems. Combination indicates multiple methods used.']
  disinfection_byproduct_monitoring_flag boolean [note: 'Indicates whether disinfection byproduct monitoring for Total Trihalomethanes (THM) and Haloacetic Acids (HAA5) was conducted during the report year. True if monitoring was performed.']
  distribution_method varchar [note: 'Distribution method']
  document_file_path varchar [note: 'File system path or document management system location where the published CCR PDF or document is stored for archival and retrieval purposes.']
  educational_information_included_flag boolean [note: 'Indicates whether mandatory educational information about contaminants and health effects was included in the CCR. Required content includes information about immunocompromised persons, sources of contamination, and EPA Safe Drinking Water Hotline.']
  electronic_delivery_count varchar [note: 'Number of customers who received the CCR electronically via email or online portal access. Systems must obtain customer consent for electronic delivery.']
  language_accessibility_flag boolean [note: 'Indicates whether the CCR includes information in languages other than English to serve non-English speaking populations. Systems must provide multilingual outreach when a significant portion of the population speaks another language.']
  lead_90th_percentile_ppb decimal(10,3) [note: '90th percentile value for lead in parts per billion from tap water sampling. Action level is 15 PPB. Required reporting for systems that conducted lead and copper monitoring.']
  lead_copper_monitoring_flag boolean [note: 'Indicates whether lead and copper monitoring was conducted during the report year per Lead and Copper Rule Revisions (LCRR) requirements. True if monitoring was performed.']
  mailed_count varchar [note: 'Number of physical CCR copies mailed to customers. Used to document delivery compliance and calculate distribution costs.']
  mcl_exceedance_flag boolean [note: 'Indicates whether any detected contaminants exceeded their Maximum Contaminant Level during the report year. True if any MCL exceedances occurred.']
  modified_by varchar [note: 'User ID or name of the person who last modified this CCR record. Part of audit trail for regulatory compliance tracking.']
  modified_timestamp timestamp [note: 'Timestamp when this CCR record was last modified. Part of audit trail for regulatory compliance tracking.']
  notes varchar [note: 'Additional notes or comments about this Consumer Confidence Report, including internal documentation of special circumstances, state feedback, or customer inquiries.']
  population_served varchar [note: 'Total number of people served by this water system during the report year. Used to determine CCR delivery requirements and system classification.']
  publication_date date [note: 'Date on which this Consumer Confidence Report was published and made available to customers. Must be by July 1 of the year following the report year.']
  pws_code varchar [note: 'EPA-assigned Public Water System identification number. Format: two-letter state code followed by seven digits (e.g., CA1234567). Links this CCR to the specific water system.']
  report_year varchar [note: 'Calendar year for which this Consumer Confidence Report covers water quality data and compliance information. CCRs must be published annually by July 1 of the following year.']
  reporting_year varchar [note: 'Reporting year']
  service_area_description varchar [note: 'Geographic description of the area served by this water system, including municipalities, counties, or districts covered by this CCR.']
  source_water_description varchar [note: 'Detailed description of the source water including specific water bodies, aquifers, wells, or treatment plant intake locations. Required CCR content per EPA rule.']
  source_water_type varchar [note: 'Classification of the primary source water for this system. Surface water includes rivers, lakes, and reservoirs. Groundwater includes wells and aquifers. GWUDI is groundwater under direct influence of surface water. Mixed indicates multiple source types.']
  special_notice_required_flag boolean [note: 'Indicates whether special public notice was required due to violations or other circumstances. Systems with certain violations must include additional notification language in the CCR.']
  special_notice_text varchar [note: 'Text of any special public notice included in the CCR due to violations, variances, exemptions, or other circumstances requiring additional customer notification.']
  system_name varchar [note: 'Official name of the public water system issuing this Consumer Confidence Report.']
  violation_included_flag boolean [note: 'Indicates whether this CCR includes reporting of any Maximum Contaminant Level (MCL), Maximum Residual Disinfectant Level (MRDL), treatment technique, or monitoring violations during the report year. True if violations are reported.']
  violation_summary varchar [note: 'Summary description of any water quality violations, treatment technique violations, or monitoring violations that occurred during the report year. Must include health effects language and corrective actions taken.']
  website_url varchar [note: 'Web address where the Consumer Confidence Report is posted for public access. Required for systems serving more than 100,000 people.']
  created_by varchar [note: 'User ID or name of the person who created this CCR record. Part of audit trail for regulatory compliance tracking.']

  Note: 'Consumer Confidence Report (CCR) — the annual water quality report required by SDWA that utilities must deliver to all customers, documenting source water information, detected contaminants, MCL comparisons, health effects language, and system information. Tracks the report year, service area covered, publication date, delivery method (mailed, electronic, website), certification submission to the state, detected contaminant summary, and compliance with EPA CCR Rule requirements. Authoritative record of annual CCR publication compliance.'
}

Table compliance.regulatory_inspection {
  regulatory_inspection_id varchar [pk, note: 'Unique identifier for the regulatory inspection record. Primary key.']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Regulatory inspections during construction verify permit compliance and design standards adherence. Inspectors reference the project for context, and inspection findings may require project scope modi']
  compliance_permit_id varchar [note: 'Identifier of the permit under which the inspection was conducted (NPDES, IUP, state primacy permit).']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Inspection preparation and response activities are tracked to cost centers for cost recovery and rate case support. Essential for documenting regulatory compliance costs.']
  enforcement_action_id varchar [note: 'Identifier linking to the enforcement action record if formal enforcement was initiated.']
  facility_id varchar [note: 'Identifier of the water or wastewater facility that was inspected (WTP, WWTP, pumping station, etc.).']
  inspection_report_document_id varchar [note: 'Identifier linking to the stored inspection report document in the document management system.']
  lab_accreditation_id varchar [note: 'Foreign key linking to laboratory.lab_accreditation. Business justification: Regulatory inspections verify laboratory accreditation status and scope. Direct link enables inspectors to validate that laboratory is accredited for methods used in compliance monitoring, supports re']
  process_unit_id varchar [note: 'Foreign key linking to treatment.process_unit. Business justification: Sanitary surveys and compliance inspections evaluate specific treatment process units for regulatory compliance. Business process: regulatory inspections where state inspectors assess individual treat']
  regulatory_agency_id varchar [note: 'FK to agency']
  utility_representative_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Regulatory inspections require utility representative present during site visit. Links to employee for scheduling, certification verification, and follow-up coordination. Replaces denormalized utility']
  corrective_action_due_date date [note: 'Deadline by which all required corrective actions must be completed and verified.']
  corrective_action_required_flag boolean [note: 'Indicates whether corrective actions are required by the utility in response to inspection findings.']
  corrective_action_summary varchar [note: 'Summary of the corrective actions required to address deficiencies and achieve compliance.']
  created_timestamp timestamp [note: 'Timestamp when this inspection record was first created in the compliance management system.']
  deficiency_count varchar [note: 'Total number of deficiencies or non-compliance items identified during the inspection.']
  enforcement_action_flag boolean [note: 'Indicates whether formal enforcement action (administrative order, consent decree, penalty) was initiated as a result of this inspection.']
  findings_summary varchar [note: 'High-level summary of the inspection findings, deficiencies identified, and overall compliance status.']
  follow_up_inspection_required_flag boolean [note: 'Indicates whether a follow-up inspection by the regulatory agency is required to verify corrective action completion.']
  follow_up_inspection_scheduled_date date [note: 'Scheduled date for the follow-up inspection if required.']
  inspecting_agency varchar [note: 'Name of the regulatory body or agency that conducted the inspection (EPA, state primacy agency, local health department, etc.).']
  inspection_date date [note: 'Date on which the regulatory inspection was conducted at the facility.']
  inspection_end_time timestamp [note: 'Timestamp when the on-site inspection activity concluded.']
  inspection_notes varchar [note: 'Internal notes and observations recorded by utility staff during or after the inspection for follow-up and documentation purposes.']
  inspection_number varchar [note: 'Externally-known unique identifier or reference number assigned by the regulatory agency for this inspection.']
  inspection_report_received_date date [note: 'Date on which the utility received the official inspection report from the regulatory agency.']
  inspection_report_status varchar [note: 'Current status of the official inspection report (draft, final, under review, accepted, disputed).']
  inspection_scope varchar [note: 'Description of the areas, processes, or systems covered during the inspection (e.g., treatment processes, discharge monitoring, pretreatment program, laboratory practices).']
  inspection_start_time timestamp [note: 'Timestamp when the on-site inspection activity began.']
  inspection_status varchar [note: 'Current lifecycle status of the inspection (scheduled, in progress, completed, report pending, closed, cancelled).']
  inspection_type varchar [note: 'Classification of the inspection activity (sanitary survey, compliance inspection, pretreatment audit, NPDES inspection, routine inspection, follow-up inspection, complaint investigation). [ENUM-REF-CANDIDATE: sanitary_survey|compliance_inspection|pretreatment_audit|npdes_inspection|routine_inspection|follow_up_inspection|complaint_investigation — 7 candidates stripped; promote to reference product]']
  inspector_contact_email varchar [note: 'Email address of the lead inspector for official correspondence.']
  inspector_contact_phone varchar [note: 'Phone number of the lead inspector for follow-up communication.']
  inspector_name varchar [note: 'Full name of the lead inspector or compliance officer who conducted the inspection.']
  inspector_title varchar [note: 'Job title or role of the lead inspector (e.g., Environmental Compliance Officer, Sanitary Survey Specialist).']
  last_modified_timestamp timestamp [note: 'Timestamp when this inspection record was last updated or modified.']
  response_due_date date [note: 'Deadline by which the utility must submit a formal response or corrective action plan to the regulatory agency.']
  significant_deficiency_classification varchar [note: 'Classification or category of the significant deficiency if identified (e.g., treatment process failure, monitoring inadequacy, operational deficiency).']
  significant_deficiency_flag boolean [note: 'Indicates whether any significant deficiencies (as defined by SDWA) were identified that could affect water quality or public health.']
  utility_representative_title varchar [note: 'Job title of the utility representative who coordinated the inspection (e.g., Compliance Manager, Plant Superintendent).']
  violation_identified_flag boolean [note: 'Indicates whether any regulatory violations (SDWA, CWA, NPDES permit) were formally identified during the inspection.']

  Note: 'Record of regulatory inspections and audits conducted by EPA, state primacy agencies, or other regulatory bodies at utility facilities. Tracks the inspection type (sanitary survey, compliance inspection, pretreatment audit, NPDES inspection), inspecting agency, facility inspected, inspection date, inspector name, findings and deficiencies identified, significant deficiency classifications, required corrective actions, response deadlines, and final inspection report status. Drives post-inspection corrective action tracking.'
}

Table compliance.inspection_finding {
  inspection_finding_id varchar [pk, note: 'Unique identifier for the inspection finding record. Primary key.']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Inspection findings during project construction require corrective action within project scope. Links findings to the project for resolution tracking, change order justification, and demonstrating com']
  enforcement_action_id varchar [note: 'Reference to the formal enforcement action record associated with this finding, if enforcement was initiated.']
  inspection_affected_asset_registry_id varchar [note: 'Reference to the specific asset, equipment, or infrastructure component directly related to this finding, if applicable.']
  inspection_event_id varchar [note: 'Reference to the parent regulatory inspection or sanitary survey event during which this finding was identified.']
  inspection_registry_id varchar [note: 'Reference to the specific asset, equipment, or infrastructure component directly related to this finding, if applicable.']
  lab_sample_id varchar [note: 'Foreign key linking to laboratory.lab_sample. Business justification: Inspection findings may reference specific samples with quality issues (e.g., holding time violations, preservation failures). Audit trail requirement links regulatory findings to physical samples for']
  previous_finding_inspection_finding_id varchar [note: 'Reference to the prior inspection finding record if this is a recurrence of a previously documented deficiency.']
  process_unit_id varchar [note: 'Foreign key linking to treatment.process_unit. Business justification: Inspection findings identify deficiencies in specific treatment processes requiring corrective action. Business process: inspection follow-up where findings (inadequate baffling, insufficient contact ']
  regulatory_inspection_id varchar [note: 'Foreign key linking to compliance.regulatory_inspection. Business justification: Inspection findings can originate from two types of inspections: asset inspections (tracked in compliance.inspection_event) and regulatory compliance inspections (tracked in compliance.regulatory_inspectio']
  responsible_employee_id varchar [note: 'Reference to the employee record of the individual assigned primary responsibility for corrective action implementation.']
  test_method_id varchar [note: 'Foreign key linking to laboratory.test_method. Business justification: Inspection findings often cite method compliance issues (e.g., unapproved method, expired accreditation). Direct link to test method enables targeted corrective actions and tracks method-specific comp']
  work_order_id varchar [note: 'Reference to the maintenance or capital work order created to execute the corrective action for this finding.']
  actual_cost decimal(15,2) [note: 'Actual financial cost in U.S. dollars (USD) incurred to implement the corrective action and resolve the finding.']
  affected_system varchar [note: 'The water or wastewater system, process, facility, or operational area affected by this finding (e.g., Water Treatment Plant (WTP) Filtration, Distribution Network Zone 3, Wastewater Treatment Plant (WWTP) Primary Clarifier, Laboratory Quality Assurance/Quality Control (QA/QC)).']
  corrective_action_deadline date [note: 'Regulatory deadline or target date by which the corrective action must be completed to achieve compliance.']
  corrective_action_required boolean [note: 'Corrective action required']
  correspondence_reference varchar [note: 'Reference number or identifier for official regulatory correspondence, letters, or communications related to this finding (e.g., EPA Notice of Violation (NOV) number, State Agency Letter Reference).']
  created_timestamp timestamp [note: 'Timestamp when this inspection finding record was first created in the system.']
  due_date date [note: 'Due date']
  enforcement_action_required boolean [note: 'Indicates whether this finding triggered or requires formal enforcement action (administrative order, consent decree, penalty assessment, or other regulatory enforcement mechanism).']
  estimated_cost decimal(15,2) [note: 'Estimated financial cost in U.S. dollars (USD) to implement the required corrective action and resolve the finding.']
  finding_category varchar [note: 'Classification of the finding severity and regulatory significance. Significant deficiency indicates a failure or deficiency in treatment, distribution, or monitoring that could adversely affect water quality or public health.']
  finding_number varchar [note: 'Sequential or structured identifier assigned to this finding within the inspection event (e.g., F-001, 2023-INS-12-F03).']
  finding_text varchar [note: 'Finding text']
  finding_type varchar [note: 'Specific type or nature of the finding (e.g., treatment process deficiency, monitoring inadequacy, recordkeeping failure, operational practice issue, infrastructure condition).']
  identified_date date [note: 'Date on which the finding was identified during the inspection or sanitary survey.']
  inspection_finding_description varchar [note: 'Detailed narrative description of the non-conformance, deficiency, or observation identified during the inspection, including specific conditions observed and context.']
  inspector_agency varchar [note: 'Regulatory agency or organization that conducted the inspection (e.g., U.S. Environmental Protection Agency (EPA), State Department of Environmental Quality, County Health Department).']
  inspector_name varchar [note: 'Name of the regulatory inspector or auditor who identified and documented this finding.']
  last_modified_by varchar [note: 'Username or identifier of the system user who last modified this inspection finding record.']
  last_modified_timestamp timestamp [note: 'Timestamp when this inspection finding record was last updated or modified.']
  location_description varchar [note: 'Physical location or geographic description where the finding was observed (e.g., Building 2 Chemical Feed Room, Main Street Pump Station, Laboratory Sample Storage Area).']
  notes varchar [note: 'Additional notes, comments, or contextual information related to the finding, corrective action, or resolution process.']
  public_health_impact varchar [note: 'Assessment of the actual or potential impact of this finding on public health and drinking water safety.']
  recurrence_flag boolean [note: 'Indicates whether this finding is a recurrence of a previously identified and supposedly corrected deficiency, suggesting systemic or persistent compliance issues.']
  regulatory_citation varchar [note: 'Specific federal, state, or local regulation, code section, or permit condition that is the basis for this finding (e.g., 40 CFR 141.21, State Primacy Code Section 12.3.4, NPDES Permit Condition IV.A.2).']
  required_corrective_action varchar [note: 'Detailed description of the corrective action, remediation, or improvement required to address and resolve the finding, as specified by the inspector or regulatory authority.']
  resolution_date date [note: 'Date on which the corrective action was completed and the finding was resolved to the satisfaction of the regulatory authority.']
  resolution_description varchar [note: 'Detailed narrative describing the corrective actions taken, remediation steps implemented, and evidence demonstrating resolution of the finding.']
  resolution_status varchar [note: 'Current status of the finding in the corrective action lifecycle, tracking progress from identification through closure.']
  responsible_party varchar [note: 'Name or title of the individual, department, or organizational unit assigned responsibility for implementing the corrective action (e.g., Operations Manager, Maintenance Supervisor, Laboratory Director).']
  risk_level varchar [note: 'Assessment of the potential risk to public health, environmental quality, or regulatory compliance posed by this finding if not corrected.']
  severity varchar [note: 'Severity']
  verification_date date [note: 'Date on which the corrective action was verified and confirmed by the regulatory authority or internal quality assurance team.']
  verification_method varchar [note: 'Method or process used to verify and confirm that the corrective action was effective and the finding has been satisfactorily resolved (e.g., follow-up inspection, photographic evidence, laboratory test results, operational data review).']
  verified_by varchar [note: 'Name or title of the individual or agency that verified the corrective action and confirmed resolution of the finding.']
  created_by varchar [note: 'Username or identifier of the system user who created this inspection finding record.']

  Note: 'Individual deficiency or finding identified during a regulatory inspection or sanitary survey, including the finding category (significant deficiency, minor deficiency, recommendation), regulatory citation, description of the non-conformance, affected system or process, required corrective action, corrective action deadline, responsible party, and resolution status. Enables systematic tracking of all inspection findings through to closure and provides evidence for regulatory follow-up correspondence.'
}

Table compliance.compliance_corrective_action {
  compliance_corrective_action_id varchar [pk, note: 'Unique identifier for the corrective action record. Primary key.']
  assigned_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Corrective actions must be assigned to specific employees for completion tracking and accountability. Supports workload management, deadline monitoring, and regulatory reporting of corrective action s']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Regulatory violations trigger capital improvement projects (consent decree requiring new treatment capacity, enforcement action mandating infrastructure upgrades). Corrective actions reference the imp']
  compliance_violation_id varchar [note: 'FK to violation']
  encumbrance_id varchar [note: 'Foreign key linking to finance.encumbrance. Business justification: Corrective action contracts create encumbrances against budgets when purchase orders or contracts are issued. Standard governmental accounting practice for commitment tracking.']
  enforcement_action_id varchar [note: 'Reference to the enforcement action that mandated this corrective action, if applicable.']
  finance_budget_id varchar [note: 'Foreign key linking to finance.budget. Business justification: Corrective actions require budget allocation for implementation (equipment, consulting, construction). Essential for capital and operating budget planning and tracking compliance-driven expenditures.']
  inspection_finding_id varchar [note: 'Reference to the inspection finding that identified the compliance gap requiring corrective action.']
  overflow_event_id varchar [note: 'Foreign key linking to compliance.overflow_event. Business justification: Corrective actions can be triggered by SSO/CSO overflow events. The overflow_event table has text fields for corrective_action_taken and preventive_action_planned, but no structured link to the correc']
  purchase_order_id varchar [note: 'Foreign key linking to supply.purchase_order. Business justification: Corrective actions requiring equipment, materials, or services are procured via purchase orders. Links compliance remediation to procurement for cost tracking and completion verification.']
  treatment_violation_id varchar [note: 'Foreign key linking to treatment.treatment_violation. Business justification: Corrective actions respond to treatment violations requiring resolution. Business process: violation resolution workflows where compliance-tracked corrective actions (equipment repairs, process adjust']
  vendor_id varchar [note: 'Foreign key linking to supply.vendor. Business justification: Corrective actions frequently engage vendors for specialized services, equipment supply, or consulting to resolve violations. Tracks vendor accountability for compliance restoration.']
  action_description varchar [note: 'Detailed description of the corrective action to be taken, including specific tasks, procedures, and deliverables required to address the compliance gap.']
  action_number varchar [note: 'Business identifier for the corrective action, typically formatted as a human-readable reference number for tracking and reporting.']
  action_status varchar [note: 'Current lifecycle status of the corrective action, tracking progress from planning through completion and verification.']
  action_title varchar [note: 'Brief descriptive title summarizing the corrective action for quick identification and reporting.']
  actual_completion_date date [note: 'Actual date when the corrective action was fully implemented and completed, used to track compliance with regulatory deadlines.']
  actual_cost decimal(15,2) [note: 'Actual financial cost incurred to implement the corrective action, tracked for budget management and regulatory reporting.']
  actual_start_date date [note: 'Actual date when implementation of the corrective action commenced.']
  agency_notification_date date [note: 'Date when the regulatory agency was formally notified of the corrective action plan or completion, fulfilling reporting requirements.']
  agency_notification_method varchar [note: 'Method used to notify the regulatory agency of the corrective action, such as formal letter, email, portal submission, phone, or in-person meeting.']
  agency_response varchar [note: 'Summary of the regulatory agencys response to the corrective action notification, including any feedback, approval, or additional requirements.']
  closure_notes varchar [note: 'Final notes documenting the closure of the corrective action, including lessons learned and recommendations for future compliance management.']
  completion_date date [note: 'Completion date']
  created_timestamp timestamp [note: 'Timestamp when the corrective action record was first created in the system, establishing the audit trail.']
  due_date date [note: 'Due date']
  effectiveness_review_date date [note: 'Scheduled date for follow-up review to assess the long-term effectiveness of the corrective action and any preventive measures.']
  effectiveness_review_outcome varchar [note: 'Summary of the effectiveness review findings, documenting whether the corrective action achieved sustained compliance improvement.']
  estimated_cost decimal(15,2) [note: 'Estimated financial cost to implement the corrective action, including labor, materials, equipment, and any third-party services.']
  last_modified_timestamp timestamp [note: 'Timestamp when the corrective action record was last updated, supporting audit trail and change tracking requirements.']
  planned_completion_date date [note: 'Target date by which the corrective action must be fully implemented and completed, often driven by regulatory deadlines or consent decree requirements.']
  planned_start_date date [note: 'Scheduled date when implementation of the corrective action is planned to begin.']
  preventive_action_description varchar [note: 'Description of preventive measures implemented to address systemic issues and prevent future occurrences of similar compliance gaps.']
  preventive_action_implemented boolean [note: 'Indicates whether preventive actions were implemented to prevent recurrence of the compliance gap or violation.']
  priority_level varchar [note: 'Priority classification indicating the urgency and importance of the corrective action based on risk, regulatory requirements, and potential impact.']
  regulatory_agency_notified boolean [note: 'Indicates whether the relevant regulatory agency (EPA, state primacy agency, etc.) was notified of the corrective action as required by enforcement orders or consent decrees.']
  responsible_department varchar [note: 'Name of the department or organizational unit responsible for implementing and completing the corrective action.']
  responsible_individual varchar [note: 'Name of the individual assigned accountability for ensuring the corrective action is completed on time and meets all requirements.']
  root_cause_analysis varchar [note: 'Documented analysis identifying the underlying root cause(s) of the compliance gap or violation, supporting effective corrective action design.']
  supporting_evidence_location varchar [note: 'File path, document management system reference, or physical location where supporting evidence and documentation for the corrective action is stored for audit trail purposes.']
  triggering_event_description varchar [note: 'Narrative description of the specific event or condition that triggered the need for corrective action, providing context for the compliance response.']
  triggering_event_type varchar [note: 'Classification of the event that initiated this corrective action, such as regulatory violation, enforcement action, inspection finding, internal audit, self-disclosure, or customer complaint.']
  verification_date date [note: 'Date when the corrective action was verified as complete and effective through the specified verification method.']
  verification_method varchar [note: 'Method used to verify that the corrective action was implemented effectively and achieved the intended compliance outcome, such as internal audit, third-party audit, regulatory inspection, documentation review, testing, or monitoring.']
  verification_notes varchar [note: 'Detailed notes documenting the verification process, findings, and any additional observations regarding the effectiveness of the corrective action.']
  verification_status varchar [note: 'Status of the verification process indicating whether the corrective action has been confirmed as effective in addressing the compliance gap.']

  Note: 'Formal corrective action plan or individual corrective action item initiated in response to a regulatory violation, enforcement action, inspection finding (including sanitary survey significant deficiencies), or internal compliance gap. Tracks the triggering event type and reference, corrective action description, priority classification, responsible department and individual, planned and actual completion dates, interim milestones, verification method, supporting evidence documentation, cost estimate, regulatory agency notification requirements, and closure approval. Provides the auditable trail demonstrating the utility\'s good-faith compliance response and is the primary artifact reviewed during follow-up inspections. [SSOT: Canonical corrective action; laboratory and quality corrective actions reference this as SSOT]'
}

Table compliance.regulatory_submission {
  regulatory_submission_id varchar [pk, note: 'Unique identifier for the regulatory submission record. Primary key.']
  compliance_permit_id varchar [note: 'Reference to the permit under which this submission is being made (NPDES permit, IUP, state discharge permit, etc.).']
  consulting_vendor_id varchar [note: 'Foreign key linking to supply.vendor. Business justification: Regulatory submissions (permit applications, engineering reports, compliance plans) often prepared by consulting vendors. Tracks vendor responsibility for submission quality and timeliness.']
  facility_id varchar [note: 'Reference to the water or wastewater facility (WTP, WWTP, pumping station, etc.) that this submission pertains to.']
  lab_work_order_id varchar [note: 'Foreign key linking to laboratory.lab_work_order. Business justification: Regulatory submissions (DMRs, MORs, compliance reports) often fulfill laboratory work orders for compliance monitoring. Direct link tracks regulatory deliverable completion and enables cost allocation']
  original_submission_regulatory_submission_id varchar [note: 'Reference to the original submission record if this submission is a correction, amendment, or resubmission.']
  primary_regulatory_submitter_employee_id varchar [note: 'Reference to the employee who prepared and submitted the regulatory report.']
  regulatory_agency_id varchar [note: 'Reference to the regulatory agency receiving this submission (EPA, state primacy agency, local health department, etc.).']
  acknowledgment_received_date date [note: 'The date on which the regulatory agency acknowledged receipt of the submission (via NetDMR confirmation, email reply, or other means).']
  acknowledgment_reference_number varchar [note: 'The confirmation or tracking number provided by the regulatory agency upon receipt of the submission.']
  agency_comments varchar [note: 'Comments, feedback, or instructions provided by the regulatory agency regarding the submission.']
  agency_response_date date [note: 'The date on which the regulatory agency provided a formal response, feedback, or determination regarding the submission.']
  agency_response_type varchar [note: 'The type of response or action taken by the regulatory agency in response to the submission.']
  amendment_reason varchar [note: 'Explanation of why the submission was amended or corrected, including the nature of the error or omission in the original submission.']
  certification_date date [note: 'The date on which the certifying official signed and certified the submission.']
  created_timestamp timestamp [note: 'The timestamp when this regulatory submission record was first created in the system.']
  due_date date [note: 'The regulatory deadline by which this submission must be filed to remain in compliance.']
  exceedance_count varchar [note: 'The number of parameter exceedances (values above permit limits but not necessarily violations) reported in this submission.']
  is_amendment boolean [note: 'Indicates whether this submission is an amendment or correction to a previously submitted report.']
  is_late_submission boolean [note: 'Indicates whether the submission was filed after the regulatory due date, which may trigger enforcement action or violation notices.']
  last_modified_timestamp timestamp [note: 'The timestamp when this regulatory submission record was last updated or modified.']
  noncompliance_explanation varchar [note: 'Narrative explanation provided by the utility for any violations, exceedances, or non-compliance events reported in the submission, including corrective actions taken or planned.']
  public_notice_date date [note: 'The date on which public notification was issued, if required.']
  public_notice_required boolean [note: 'Indicates whether this submission requires public notification (e.g., CCR publication, SSO public notice, boil water advisory).']
  reporting_period_end_date date [note: 'The ending date of the time period covered by this regulatory submission.']
  reporting_period_start_date date [note: 'The beginning date of the time period covered by this regulatory submission.']
  resubmission_required boolean [note: 'Indicates whether the regulatory agency has requested a corrected or amended resubmission of the report.']
  submission_date date [note: 'The date on which the regulatory submission was formally submitted to the regulatory agency. This is the principal business event timestamp for the submission.']
  submission_file_format varchar [note: 'The file format or media type of the submitted report.']
  submission_file_path varchar [note: 'The file system path or document management system reference to the submitted report document (PDF, XML, CSV, etc.).']
  submission_method varchar [note: 'The method or channel used to submit the report to the regulatory agency. NetDMR is the EPA electronic discharge monitoring reporting system.']
  submission_notes varchar [note: 'Internal notes, comments, or additional context regarding the preparation, submission, or follow-up actions for this regulatory submission.']
  submission_number varchar [note: 'Business identifier or tracking number assigned to the regulatory submission, often used for external reference and correspondence with regulatory agencies.']
  submission_status varchar [note: 'Current lifecycle status of the regulatory submission indicating its progress through the submission and review workflow.']
  submission_type varchar [note: 'Category of regulatory submission. DMR = Discharge Monitoring Report, MOR = Monthly Operating Report, CCR = Consumer Confidence Report, SSO = Sanitary Sewer Overflow, CSO = Combined Sewer Overflow, PFAS = Per- and Polyfluoroalkyl Substances, LCRR = Lead and Copper Rule Revisions. [ENUM-REF-CANDIDATE: DMR|MOR|CCR|SSO_notification|CSO_notification|pretreatment_report|annual_report|PFAS_report|LCRR_inventory|permit_application|variance_request|other — promote to reference product]']
  violation_count varchar [note: 'The number of permit limit violations or non-compliance events reported in this submission.']

  Note: 'Master record of all formal regulatory submissions made by the utility to regulatory agencies, serving as the single audit trail for submission compliance. Covers DMR submissions (via NetDMR), MOR submissions, CCR certifications, annual compliance reports, pretreatment program reports, SSO/CSO notifications, PFAS reporting, LCRR service line inventory submissions, and Lead Service Line Replacement (LSLR) progress reports. Tracks submission type, receiving agency, submission date, submission method (NetDMR, state portal, paper, email), reporting period, submitter, certifying official, certification status, acknowledgment receipt, late submission flags, and resubmission history. Enables monitoring of submission timeliness — a key compliance metric tracked by state primacy agencies.'
}

Table compliance.regulatory_correspondence {
  regulatory_correspondence_id varchar [pk, note: 'Unique identifier for the regulatory correspondence record. Primary key.']
  compliance_permit_id varchar [note: 'Foreign key reference to the permit record associated with this correspondence, if applicable (e.g., NPDES permit, IUP, state primacy agency permit).']
  compliance_violation_id varchar [note: 'Foreign key reference to the violation record associated with this correspondence, if applicable (e.g., response to Notice of Violation (NOV), enforcement action correspondence).']
  enforcement_action_id varchar [note: 'Foreign key linking to compliance.enforcement_action. Business justification: Regulatory correspondence can be about enforcement actions (notices of violation, consent orders, penalty assessments, compliance agreements). The regulatory_correspondence table has enforcement_actio']
  facility_id varchar [note: 'Foreign key reference to the facility (Water Treatment Plant (WTP), Wastewater Treatment Plant (WWTP), pumping station, etc.) that is the subject of the correspondence.']
  overflow_event_id varchar [note: 'Foreign key linking to compliance.overflow_event. Business justification: SSO/CSO events require regulatory notification and often generate correspondence with EPA or state agencies. The overflow_event table tracks regulatory_notification_date and regulatory_agency_notified']
  regulatory_agency_id varchar [note: 'FK to agency']
  regulatory_inspection_id varchar [note: 'Foreign key linking to compliance.regulatory_inspection. Business justification: Regulatory inspections generate correspondence including inspection reports, responses to findings, and follow-up communications. The regulatory_correspondence table currently links to permit, violati']
  utility_contact_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Regulatory correspondence requires designated utility contact for continuity and accountability. Links to employee for contact information, response tracking, and workload management. Replaces denorma']
  agency_contact_email varchar [note: 'Email address of the agency contact person for follow-up communication.']
  agency_contact_name varchar [note: 'Name of the regulatory agency representative or contact person who authored or is responsible for the correspondence.']
  agency_contact_phone varchar [note: 'Phone number of the agency contact person for direct communication.']
  agency_contact_title varchar [note: 'Job title or position of the agency contact person (e.g., Compliance Officer, Regional Administrator, Program Manager).']
  confidential_flag boolean [note: 'Indicates whether the correspondence contains confidential business information (CBI) or trade secrets that are protected from public disclosure (True/False).']
  correspondence_date date [note: 'Date the correspondence was sent (for outgoing) or received (for incoming). This is the principal business event timestamp for the correspondence.']
  correspondence_number varchar [note: 'Business identifier or reference number assigned to the correspondence for tracking and filing purposes. May follow agency or internal numbering conventions.']
  correspondence_status varchar [note: 'Current lifecycle status of the correspondence record (e.g., active, closed, archived, under review).']
  correspondence_text varchar [note: 'Text']
  correspondence_type varchar [note: 'Classification of the correspondence document type (e.g., letter, notice, response to Notice of Violation (NOV), request for information, variance application, waiver request, extension request, agency response, inspection report, technical memorandum). [ENUM-REF-CANDIDATE: letter|notice|response|request_for_information|variance_application|waiver_request|extension_request|nov_response|agency_response|inspection_report|technical_memorandum — 11 candidates stripped; promote to reference product]']
  created_timestamp timestamp [note: 'Timestamp when the correspondence record was first created in the system.']
  direction varchar [note: 'Indicates whether the correspondence is incoming (received from regulatory agency) or outgoing (sent by the utility to regulatory agency).']
  disposition_date date [note: 'Date on which the correspondence record is eligible for disposition (archival or destruction) per records retention policy. Null if not yet determined.']
  document_format varchar [note: 'Format of the correspondence document (e.g., PDF, DOCX, email, paper, other).']
  document_reference varchar [note: 'Reference identifier, file path, or URL to the stored correspondence document (e.g., document management system reference, SharePoint path, network drive location).']
  enforcement_action_flag boolean [note: 'Indicates whether the correspondence is related to a regulatory enforcement action (e.g., Notice of Violation (NOV), consent decree, administrative order) (True/False).']
  last_modified_timestamp timestamp [note: 'Timestamp when the correspondence record was last updated or modified.']
  notes varchar [note: 'Free-text field for internal notes, comments, or additional context regarding the correspondence, follow-up actions, or related discussions.']
  priority varchar [note: 'Priority level assigned to the correspondence based on urgency, regulatory significance, or potential enforcement implications (e.g., low, medium, high, critical).']
  public_disclosure_required_flag boolean [note: 'Indicates whether the correspondence or its content must be disclosed to the public (e.g., as part of Consumer Confidence Report (CCR), public notice, or Freedom of Information Act (FOIA) request) (True/False).']
  received_date date [note: 'Date the incoming correspondence was officially received and logged by the utility. Null for outgoing correspondence.']
  regulatory_agency varchar [note: 'Name of the regulatory agency involved in the correspondence (e.g., U.S. Environmental Protection Agency (EPA), State Drinking Water Program, State Department of Environmental Quality, Public Utilities Commission).']
  regulatory_program varchar [note: 'The regulatory program or framework to which the correspondence pertains (e.g., Safe Drinking Water Act (SDWA), Clean Water Act (CWA), National Pollutant Discharge Elimination System (NPDES), Industrial User Permit (IUP), Consumer Confidence Report (CCR), Lead and Copper Rule Revisions (LCRR), Disinfection Byproduct (DBP) Rule, Groundwater Rule, Surface Water Treatment Rule). [ENUM-REF-CANDIDATE: sdwa|cwa|npdes|iup|ccr|lcrr|dbp|groundwater_rule|surface_water_treatment_rule|other — 10 candidates stripped; promote to reference product]']
  response_deadline_date date [note: 'Date by which the utility must submit a response to the regulatory agency, if a response is required. Null if no response deadline applies.']
  response_required_flag boolean [note: 'Indicates whether a formal response from the utility is required for this correspondence (True/False).']
  response_status varchar [note: 'Current status of the utility\'s response to the correspondence (e.g., not required, pending, in progress, submitted, accepted by agency, rejected by agency, overdue). [ENUM-REF-CANDIDATE: not_required|pending|in_progress|submitted|accepted|rejected|overdue — 7 candidates stripped; promote to reference product]']
  response_submitted_date date [note: 'Date the utility submitted its response to the regulatory agency. Null if no response has been submitted or is not required.']
  retention_period_years varchar [note: 'Number of years the correspondence record must be retained per regulatory or internal records retention policy.']
  sent_date date [note: 'Date the outgoing correspondence was officially sent or transmitted by the utility. Null for incoming correspondence.']
  subject varchar [note: 'Subject line or title of the correspondence describing the primary topic or purpose.']
  summary varchar [note: 'Brief summary or abstract of the correspondence content, key points, and any actions requested or required.']
  utility_contact_title varchar [note: 'Job title or position of the utility contact person (e.g., Compliance Manager, Director of Operations, Environmental Manager).']

  Note: 'Record of all formal written correspondence exchanged between the utility and regulatory agencies, including letters, notices, responses to NOVs, requests for extensions, variance applications, waiver requests, and agency responses. Tracks the correspondence type, direction (incoming/outgoing), agency, contact person, date sent or received, subject matter, associated permit or violation, response deadline, and document reference. Maintains the complete regulatory communication audit trail.'
}

Table compliance.pretreatment_iup {
  pretreatment_iup_id varchar [pk, note: 'Unique identifier for the Industrial User Permit record in the pretreatment program.']
  ar_transaction_id varchar [note: 'Foreign key linking to finance.ar_transaction. Business justification: Industrial user permit fees generate AR transactions for billing and collection. Direct revenue link essential for pretreatment program cost recovery and accounts receivable management.']
  coordinator_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Federal pretreatment regulations require designated coordinator for each industrial user permit. Links to employee for certification verification, workload tracking, and regulatory accountability. Rep']
  industrial_user_id varchar [note: 'Reference to the industrial user (customer/facility) to whom this permit is issued.']
  pretreatment_equipment_vendor_id varchar [note: 'Foreign key linking to supply.vendor. Business justification: Industrial user permits reference vendors providing pretreatment equipment or monitoring services. Essential for tracking approved vendors and equipment compliance with categorical standards.']
  sampling_location_id varchar [note: 'Foreign key linking to laboratory.sampling_location. Business justification: Industrial user permits specify sampling locations for compliance monitoring (e.g., pretreatment system effluent). Pretreatment program requirement links permit to physical sampling point, eliminates ']
  average_daily_flow_mgd decimal(12,4) [note: 'The average permitted daily wastewater discharge flow rate from the industrial user, measured in Million Gallons per Day (MGD).']
  bmp_requirements varchar [note: 'Description of the Best Management Practices (BMPs) the industrial user must implement to minimize pollutant discharge and ensure compliance.']
  compliance_status varchar [note: 'Current compliance status of the industrial user with permit discharge limits and reporting requirements: Compliant, Non-Compliant, Significant Non-Compliance (SNC), or Under Review.']
  created_timestamp timestamp [note: 'The timestamp when this Industrial User Permit record was first created in the system.']
  discharge_point_latitude decimal(10,7) [note: 'The geographic latitude coordinate of the industrial users discharge point to the sewer system.']
  discharge_point_longitude decimal(10,7) [note: 'The geographic longitude coordinate of the industrial users discharge point to the sewer system.']
  effective_date date [note: 'The date on which the Industrial User Permit becomes legally effective and enforceable.']
  enforcement_action_pending boolean [note: 'Indicates whether there is an active enforcement action (notice of violation, administrative order, consent decree, or legal action) pending against the industrial user.']
  expiration_date date [note: 'The date on which the Industrial User Permit expires and must be renewed or reissued.']
  facility_address varchar [note: 'The physical street address of the industrial facility discharging to the municipal sewer system.']
  facility_city varchar [note: 'The city where the industrial facility is located.']
  facility_name varchar [note: 'The legal or trade name of the industrial facility covered by this permit.']
  facility_postal_code varchar [note: 'The postal or ZIP code of the industrial facility location.']
  facility_state varchar [note: 'The state or province where the industrial facility is located.']
  inspection_frequency varchar [note: 'The frequency at which the utility must conduct on-site inspections of the industrial users facility and pretreatment equipment.']
  issuance_date date [note: 'The date on which the permit was officially issued by the utility to the industrial user.']
  last_compliance_assessment_date date [note: 'The date of the most recent compliance assessment or evaluation conducted by the utility for this industrial user.']
  last_inspection_date date [note: 'The date of the most recent on-site inspection conducted by the utility at the industrial users facility.']
  last_modified_timestamp timestamp [note: 'The timestamp when this Industrial User Permit record was last updated or modified in the system.']
  last_renewal_date date [note: 'The date of the most recent permit renewal or modification.']
  maximum_daily_flow_mgd decimal(12,4) [note: 'The maximum permitted daily wastewater discharge flow rate from the industrial user to the municipal sewer system, measured in Million Gallons per Day (MGD).']
  monitoring_frequency varchar [note: 'The required frequency at which the industrial user must sample and analyze wastewater discharge for compliance with permit limits.']
  naics_code varchar [note: 'The six-digit NAICS code classifying the industrial users business sector and activity.']
  next_report_due_date date [note: 'The date by which the industrial user must submit the next compliance monitoring report to the utility.']
  notes varchar [note: 'Additional notes, comments, or observations related to the Industrial User Permit, compliance history, or facility operations.']
  permit_conditions varchar [note: 'Detailed text of special conditions, requirements, or restrictions imposed on the industrial user as part of this permit.']
  permit_number varchar [note: 'The externally-known unique permit number assigned to the industrial user by the utility under the NPDES pretreatment program.']
  permit_status varchar [note: 'Current lifecycle status of the Industrial User Permit: Active, Expired, Suspended, Revoked, Pending Renewal, or Terminated.']
  permit_type varchar [note: 'Type of Industrial User Permit: Individual (facility-specific), General (standard conditions for a category), or Conditional (temporary or limited scope).']
  pretreatment_required boolean [note: 'Indicates whether the industrial user is required to pretreat wastewater before discharge to the municipal sewer system.']
  pretreatment_technology_description varchar [note: 'Description of the pretreatment technologies and processes the industrial user must employ to meet discharge limits (e.g., pH adjustment, oil-water separation, metals precipitation).']
  reporting_frequency varchar [note: 'The required frequency at which the industrial user must submit compliance monitoring reports to the utility.']
  sic_code varchar [note: 'The four-digit SIC code classifying the industrial users primary business activity and process type.']
  siu_classification varchar [note: 'Classification of the industrial user under the pretreatment program: Significant Industrial User (SIU), Categorical Industrial User (CIU), Non-Significant Categorical User (NSCIU), or Non-Categorical User.']
  slug_control_plan_approval_date date [note: 'The date on which the utilitys pretreatment coordinator approved the industrial users slug discharge control plan.']
  slug_control_plan_required boolean [note: 'Indicates whether the industrial user is required to develop and maintain a slug discharge control plan to prevent accidental or intentional spills.']

  Note: 'Industrial User Permit (IUP) issued by the utility\'s pretreatment program to significant industrial users (SIUs) and categorical industrial users (CIUs), authorizing discharge of industrial wastewater to the publicly owned treatment works (POTW). Tracks the industrial user identity, SIC/NAICS code, permit number, categorical standards applicable (40 CFR 400-471), permitted discharge limits by pollutant (metals, BOD, TSS, FOG, pH), self-monitoring requirements, reporting schedule (semi-annual compliance reports), best management practices (BMPs), slug control plan requirements, permit effective and expiration dates, compliance status, and enforcement history. Supports the utility\'s federally-mandated pretreatment program administration under 40 CFR Part 403.'
}

Table compliance.industrial_user {
  industrial_user_id varchar [pk, note: 'Unique identifier for the industrial user record in the pretreatment program registry. Primary key.']
  approved_service_vendor_id varchar [note: 'Foreign key linking to supply.vendor. Business justification: Industrial users have approved vendors for pretreatment system maintenance, monitoring, and sampling. Tracks vendor qualifications and service agreements for pretreatment program compliance.']
  compliance_permit_id varchar [note: 'Foreign key reference to the Industrial User Permit (IUP) assigned to this industrial user under the pretreatment program.']
  coordinator_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Each industrial user requires assigned pretreatment coordinator for compliance monitoring, sampling coordination, and regulatory reporting. Links to employee for workload management and certification ']
  organization_id varchar [note: 'FK to organization']
  sampling_plan_id varchar [note: 'Foreign key linking to laboratory.sampling_plan. Business justification: Industrial users follow specific sampling plans for permit compliance (frequency, parameters, methods). Pretreatment oversight requires direct link from industrial user to their assigned sampling plan']
  annual_certification_due_date date [note: 'Due date for the industrial user\'s annual certification of compliance with applicable pretreatment standards.']
  baseline_monitoring_report_date date [note: 'Date the Baseline Monitoring Report (BMR) was submitted by the industrial user.']
  baseline_monitoring_report_submitted boolean [note: 'Indicates whether the industrial user has submitted the required Baseline Monitoring Report (BMR) for categorical users.']
  categorical_standard_applicable boolean [note: 'Indicates whether the industrial user is subject to EPA categorical pretreatment standards for a specific industry category.']
  categorical_standard_reference varchar [note: 'Citation of the specific EPA categorical pretreatment standard applicable to this industrial user (e.g., 40 CFR Part 433 for Metal Finishing).']
  city varchar [note: 'City where the industrial facility is located.']
  class varchar [note: 'User class']
  classification varchar [note: 'Classification of the industrial user under the pretreatment program: Significant Industrial User (SIU), Categorical Industrial User (CIU), Non-Significant Industrial User, or Exempt.']
  compliance_status varchar [note: 'Current compliance status of the industrial user with respect to pretreatment standards and permit conditions.']
  contact_person_email varchar [note: 'Email address of the primary contact person for pretreatment program correspondence and reporting.']
  contact_person_name varchar [note: 'Full name of the primary contact person at the industrial facility responsible for pretreatment program compliance.']
  contact_person_phone varchar [note: 'Primary phone number of the contact person at the industrial facility.']
  contact_person_title varchar [note: 'Job title or role of the primary contact person at the industrial facility.']
  created_timestamp timestamp [note: 'Timestamp when this industrial user record was first created in the system.']
  discharge_connection_point decimal(18,2) [note: 'Identifier or description of the physical connection point where the industrial user discharges wastewater into the utility\'s collection system (e.g., manhole ID, GPS coordinates).']
  enforcement_action_pending boolean [note: 'Indicates whether an enforcement action (administrative order, civil penalty, consent decree) is currently pending against this industrial user.']
  estimated_discharge_volume_gpd decimal(12,2) [note: 'Estimated average daily wastewater discharge volume from the industrial facility in gallons per day (GPD).']
  facility_address_line1 varchar [note: 'Primary street address of the industrial facility discharging to the wastewater collection system.']
  facility_address_line2 varchar [note: 'Secondary address information (suite, building, floor) for the industrial facility.']
  facility_name varchar [note: 'Legal or trade name of the industrial or commercial facility subject to pretreatment requirements.']
  inspection_frequency varchar [note: 'Required frequency of compliance inspections for this industrial user as specified in the IUP or local pretreatment ordinance.']
  is_active boolean [note: 'Indicates whether the industrial user is currently active in the pretreatment program registry. False if the facility has closed or is no longer discharging.']
  last_inspection_date date [note: 'Date of the most recent compliance inspection conducted at the industrial facility.']
  last_modified_timestamp timestamp [note: 'Timestamp when this industrial user record was last updated.']
  last_sampling_date date [note: 'Date of the most recent wastewater discharge sampling event for this industrial user.']
  last_violation_date date [note: 'Date of the most recent documented violation of pretreatment standards or permit limits by this industrial user.']
  naics_code varchar [note: 'Six-digit NAICS code identifying the primary industrial activity of the facility, replacing SIC in modern classifications.']
  next_inspection_due_date date [note: 'Scheduled date for the next compliance inspection of the industrial user.']
  notes varchar [note: 'Free-text field for additional notes, comments, or special conditions related to this industrial user.']
  pollutants_of_concern varchar [note: 'Comma-separated list of key pollutants of concern discharged by this industrial user (e.g., Fats Oils and Grease (FOG), heavy metals, Biochemical Oxygen Demand (BOD), Total Suspended Solids (TSS), pH).']
  postal_code varchar [note: 'ZIP or postal code for the industrial facility address.']
  pretreatment_system_description varchar [note: 'Description of the on-site pretreatment system, including technology type (e.g., oil-water separator, pH adjustment, metals precipitation).']
  pretreatment_system_installed boolean [note: 'Indicates whether the industrial user has installed on-site pretreatment equipment to reduce pollutant concentrations before discharge.']
  sampling_frequency varchar [note: 'Required frequency of wastewater discharge sampling for this industrial user as specified in the IUP.']
  sic_code varchar [note: 'Four-digit Standard Industrial Classification code identifying the primary industrial activity of the facility.']
  significant_user_flag boolean [note: 'Significant user flag']
  slug_discharge_notification_required decimal(18,2) [note: 'Indicates whether the industrial user is required to notify the utility immediately of any slug discharge or accidental spill that could cause interference or pass-through.']
  state varchar [note: 'State or province where the industrial facility is located.']
  termination_date date [note: 'Date the industrial user ceased operations or was removed from the pretreatment program registry.']
  violation_count_last_12_months varchar [note: 'Total number of documented violations by this industrial user in the past 12 months.']
  zero_discharge_certification decimal(18,2) [note: 'Indicates whether the industrial user has certified that they have no process wastewater discharge (zero discharge facility).']

  Note: 'Master record of industrial and commercial users subject to the utility\'s pretreatment program, including Significant Industrial Users (SIUs), Categorical Industrial Users (CIUs), and non-significant industrial users. Tracks the business name, facility address, SIC/NAICS code, industrial user classification, assigned IUP, discharge connection point, estimated discharge volume (GPD), key pollutants of concern (FOG, heavy metals, BOD, TSS), inspection frequency, and compliance history. Authoritative registry for pretreatment program management.'
}

Table compliance.overflow_event {
  overflow_event_id varchar [pk, note: 'Primary key.']
  compliance_permit_id varchar [note: 'FK to compliance permit.']
  compliance_public_notification_id varchar [note: 'FK to public notification issued.']
  facility_id varchar [note: 'FK to facility.']
  manhole_id varchar [note: 'Identifier of the manhole where overflow occurred']
  pressure_zone_id varchar [note: 'FK to pressure zone.']
  registry_id varchar [note: 'FK to asset registry.']
  reported_by_employee_id varchar [note: 'FK to reporting employee.']
  affected_customers_count varchar [note: 'Number of customers affected']
  affected_service_connections varchar [note: 'Number of service connections affected.']
  affected_zones varchar [note: 'Service zones affected by the overflow.']
  agency_notification_date date [note: 'Date agency was notified.']
  agency_notification_method varchar [note: 'Method of agency notification.']
  agency_report_date date
  cause varchar [note: 'Identified cause of the overflow.']
  cause_category varchar [note: 'Category of cause (Blockage, Capacity, Equipment Failure, I&I).']
  cause_description varchar [note: 'Detailed cause description.']
  cleanup_completed_date date [note: 'Date cleanup activities were completed']
  cleanup_completed_flag boolean [note: 'Whether cleanup was completed.']
  cleanup_completed_timestamp timestamp [note: 'Timestamp when cleanup was completed.']
  cleanup_completion_date date [note: 'Date cleanup was completed.']
  cleanup_cost_amount decimal(18,2)
  cleanup_method varchar [note: 'Method used for cleanup (vacuum, lime, disinfection).']
  containment_method varchar [note: 'Method used to contain the overflow (vacuum, bypass pumping, sandbagging)']
  corrective_action_description varchar [note: 'Description of corrective actions taken']
  corrective_action_taken varchar [note: 'Corrective action taken.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  discharge_location varchar [note: 'Description of where the overflow discharged']
  duration_hours decimal(10,2) [note: 'Duration in hours.']
  duration_minutes varchar
  end_time timestamp [note: 'end time for overflow_event']
  end_timestamp timestamp [note: 'End time of the overflow.']
  environmental_impact_assessment varchar [note: 'Assessment of environmental impact from the overflow']
  estimated_volume_gallons decimal(18,2) [note: 'Estimated overflow volume in gallons.']
  event_category varchar
  event_cause varchar [note: 'Root cause of the overflow (blockage, capacity, pump failure, I&I, power failure)']
  event_date date
  event_end_timestamp timestamp [note: 'End time of the overflow event.']
  event_number varchar [note: 'Unique event tracking number.']
  event_start_timestamp timestamp [note: 'Start time of the overflow event.']
  event_status varchar [note: 'Current status of the event.']
  event_type varchar [note: 'Type of overflow (SSO, CSO).']
  expected_restoration_at timestamp [note: 'Expected restoration timestamp.']
  is_recurring_location boolean [note: 'Whether this location has had previous overflow events.']
  is_reportable boolean [note: 'Whether the event is regulatorily reportable.']
  last_modified_timestamp timestamp [note: 'Last modification timestamp.']
  latitude decimal(10,7) [note: 'Latitude of overflow location.']
  location_description varchar [note: 'Location description.']
  longitude decimal(10,7) [note: 'Longitude of overflow location.']
  modified_timestamp timestamp [note: 'Record last modification timestamp']
  notes varchar [note: 'Additional notes.']
  notification_date date
  npdes_permit_number varchar [note: 'NPDES permit number applicable to the overflow']
  overflow_cause varchar [note: 'Root cause (BLOCKAGE, CAPACITY, EQUIPMENT_FAILURE, POWER_FAILURE, INFILTRATION, STORM)']
  overflow_event_number varchar [note: 'Unique tracking number for the overflow event']
  overflow_location varchar
  overflow_status varchar [note: 'Current status (ACTIVE, CONTAINED, RESOLVED, REPORTED)']
  overflow_type varchar [note: 'Type of overflow (SSO, CSO, BYPASS, BLENDING)']
  overflow_volume_gallons decimal(18,2)
  population_at_risk varchar [note: 'Population at risk from the overflow.']
  previous_event_count varchar [note: 'Number of previous overflow events at this location.']
  public_contact_occurred boolean [note: 'Whether public contact with overflow occurred.']
  public_notification_date date [note: 'Date public notification was issued']
  public_notification_issued boolean [note: 'Whether public notification was issued.']
  public_notification_required boolean
  public_notified_flag boolean [note: 'public notified flag for overflow_event']
  rainfall_duration_hours decimal(8,2) [note: 'Duration of rainfall event in hours']
  rainfall_inches decimal(6,2) [note: 'Rainfall amount during event.']
  reached_storm_drain boolean [note: 'Whether the overflow reached a storm drain.']
  reached_surface_water boolean [note: 'Whether overflow reached surface water.']
  reached_waters_flag boolean [note: 'Whether overflow reached waters of the state']
  reached_waters_of_state boolean [note: 'Whether overflow reached waters of the state']
  receiving_water_body varchar [note: 'Receiving water body impacted.']
  receiving_water_impacted boolean
  recurrence_prevention_plan varchar [note: 'Plan to prevent recurrence of the overflow']
  regulatory_report_date date [note: 'Date the event was reported to regulators']
  regulatory_report_required boolean [note: 'Whether regulatory reporting is required']
  regulatory_report_submitted varchar [note: 'Whether regulatory report was submitted']
  regulatory_report_submitted_date date [note: 'Date the regulatory report was submitted']
  regulatory_reportable_flag boolean [note: 'regulatory reportable flag for overflow_event']
  regulatory_reported boolean [note: 'Whether the event has been reported to regulators']
  regulatory_reporting_required boolean
  reportable_flag boolean [note: 'Whether the event is regulatorily reportable.']
  reported_date date
  reported_to_agency_flag boolean
  reporting_deadline date
  response_time_minutes varchar [note: 'Time in minutes from detection to crew arrival']
  root_cause_analysis_completed boolean [note: 'Whether root cause analysis has been completed']
  severity_level varchar [note: 'Severity classification (Category 1-5 or minor/major/catastrophic)']
  start_time timestamp [note: 'start time for overflow_event']
  start_timestamp timestamp [note: 'Start time of the overflow.']
  updated_timestamp timestamp [note: 'Record last update timestamp']
  volume_gallons decimal(18,2) [note: 'volume gallons for overflow_event']
  volume_recovered_gallons decimal(18,2) [note: 'Volume recovered.']
  weather_condition varchar [note: 'Weather conditions during the event']

  Note: 'Sanitary sewer overflow (SSO) and combined sewer overflow (CSO) events with volume, duration, cause, receiving water impact, and public notification tracking.'
}

Table compliance.compliance_schedule {
  compliance_schedule_id varchar [pk, note: 'Unique identifier for the compliance schedule record. Primary key.']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Compliance schedules (consent decree milestones, enforcement order deadlines) are directly tied to CIP project delivery dates. Regulatory agencies track project completion as compliance milestones. Es']
  compliance_permit_id varchar [note: 'Reference to the permit associated with this compliance schedule, if the schedule is tied to a specific permit condition rather than an enforcement action.']
  enforcement_action_id varchar [note: 'Reference to the enforcement action or consent order that established this compliance schedule.']
  finance_budget_id varchar [note: 'Foreign key linking to finance.budget. Business justification: Compliance schedules require multi-year budget commitments for milestone completion. Critical for long-term financial planning and tracking progress against consent decree or enforcement order require']
  obligation_id varchar [note: 'Foreign key linking to compliance.compliance_obligation. Business justification: Compliance schedules are created to fulfill specific compliance obligations. The compliance_schedule table already links to regulatory_requirement (the general requirement) and enforcement_action (if ']
  registry_id varchar [note: 'Foreign key linking to asset.asset_registry. Business justification: Compliance schedules mandate specific asset upgrades/installations (e.g., consent order requiring new filtration by deadline). Links schedule milestones to capital projects and asset commissioning, tr']
  regulatory_requirement_id varchar [note: 'Reference to the specific regulatory requirement or permit condition that is the subject of this compliance schedule.']
  responsible_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Compliance schedules require designated responsible party for milestone tracking and regulatory reporting. Links to employee for accountability, workload management, and contact information. Replaces ']
  sampling_plan_id varchar [note: 'Foreign key linking to laboratory.sampling_plan. Business justification: Compliance schedules (consent orders, administrative orders) often include sampling plan implementation as milestones. Direct link tracks schedule fulfillment and enables automated milestone completio']
  actual_total_cost decimal(15,2) [note: 'Actual total cost incurred to date in executing the compliance schedule, including all capital and operating expenditures.']
  completion_date date [note: 'Completion date']
  compliance_schedule_status varchar [note: 'Status']
  created_timestamp timestamp [note: 'Timestamp when this compliance schedule record was first created in the system.']
  document_url varchar [note: 'URL or file path to the official compliance schedule document, consent order, or administrative order that formally establishes the schedule and its milestones.']
  due_date date [note: 'Due date']
  effective_date date [note: 'Date on which the compliance schedule becomes effective and the utility is obligated to begin executing the scheduled milestones.']
  estimated_total_cost decimal(15,2) [note: 'Estimated total cost to complete all milestones and achieve full compliance under this schedule, including capital expenditures (CAPEX) and operating expenditures (OPEX).']
  extension_approval_date date [note: 'Date on which the regulatory authority formally approved the extension request.']
  extension_approved_flag boolean [note: 'Indicates whether the regulatory authority approved the requested extension to the compliance schedule.']
  extension_justification varchar [note: 'Detailed explanation or justification provided by the utility for requesting an extension to the compliance schedule, including any unforeseen circumstances, technical challenges, or resource constraints.']
  extension_request_date date [note: 'Date on which the utility submitted a formal request to extend the compliance schedule deadlines.']
  extension_requested_flag boolean [note: 'Indicates whether the utility has requested an extension to the compliance schedule deadlines.']
  final_compliance_deadline date [note: 'The ultimate deadline by which the utility must achieve full compliance with the regulatory requirement or permit condition. This is the final milestone in the schedule.']
  funding_source varchar [note: 'Source of funding for the compliance schedule activities (e.g., rate revenue, bond proceeds, state revolving fund loan, grant, Capital Improvement Program (CIP) budget).']
  issuing_authority varchar [note: 'Name of the regulatory agency or authority that issued or approved the compliance schedule (e.g., EPA Region, State Primacy Agency, local environmental department).']
  jurisdiction varchar [note: 'Geographic or administrative jurisdiction of the regulatory authority overseeing this compliance schedule (e.g., state, county, EPA region).']
  last_modified_by varchar [note: 'Username or identifier of the user who last modified this compliance schedule record.']
  last_modified_timestamp timestamp [note: 'Timestamp when this compliance schedule record was last modified or updated.']
  last_status_update_date date [note: 'Date of the most recent status update or progress report submitted to the regulatory authority regarding the compliance schedule.']
  milestone_count varchar [note: 'Total number of milestones defined within this compliance schedule. Milestones are typically tracked in a separate related table.']
  milestone_description varchar [note: 'Milestone description']
  milestones_completed_count varchar [note: 'Number of milestones that have been completed as of the current date. Used to track progress toward full compliance.']
  milestones_overdue_count varchar [note: 'Number of milestones that are past their due date and have not been completed. Indicates potential non-compliance with the schedule.']
  next_status_update_due_date date [note: 'Date by which the next status update or progress report is due to be submitted to the regulatory authority.']
  notes varchar [note: 'Additional notes, comments, or context regarding the compliance schedule, including any special conditions, challenges, or coordination requirements.']
  on_schedule_flag boolean [note: 'Indicates whether the compliance schedule is currently on track to meet all milestone deadlines and the final compliance deadline. False if any milestones are overdue or at risk.']
  original_final_deadline date [note: 'The original final compliance deadline as initially agreed upon, preserved for audit and tracking purposes even if the schedule is later extended.']
  overall_completion_percentage decimal(5,2) [note: 'Percentage of the compliance schedule that has been completed, calculated as (milestones_completed_count / milestone_count) * 100. Provides a high-level progress indicator.']
  public_notification_date date [note: 'Date on which the utility provided public notification regarding the compliance schedule, if required.']
  public_notification_required_flag boolean [note: 'Indicates whether the utility is required to provide public notification regarding the compliance schedule, such as inclusion in the Consumer Confidence Report (CCR) or public notices.']
  regulatory_correspondence_count varchar [note: 'Number of formal correspondence items (letters, emails, reports) exchanged between the utility and the regulatory authority regarding this compliance schedule.']
  responsible_department varchar [note: 'Name of the internal department or business unit responsible for executing the compliance schedule and ensuring all milestones are met (e.g., Operations and Maintenance (O&M), Engineering, Environmental Compliance).']
  schedule_description varchar [note: 'Detailed description of the compliance schedule, including the nature of the non-compliance, the corrective actions required, and the overall scope of work to achieve compliance.']
  schedule_name varchar [note: 'Descriptive name or title of the compliance schedule, summarizing the primary compliance objective or requirement being addressed.']
  schedule_number varchar [note: 'Business identifier or reference number for the compliance schedule, often assigned by the regulatory agency or utility for tracking purposes.']
  schedule_status varchar [note: 'Current lifecycle status of the compliance schedule. Indicates whether the schedule is in draft, actively being executed, completed, extended, terminated, or suspended. [ENUM-REF-CANDIDATE: draft|active|in_progress|completed|extended|terminated|suspended — 7 candidates stripped; promote to reference product]']
  schedule_type varchar [note: 'Classification of the compliance schedule based on its legal or regulatory origin (e.g., consent order, administrative order, permit condition, settlement agreement, voluntary schedule).']
  created_by varchar [note: 'Username or identifier of the user who created this compliance schedule record.']

  Note: 'Formal compliance schedule agreed upon between the utility and a regulatory agency, typically as part of an enforcement action or consent order, establishing milestone dates for achieving compliance with a regulatory requirement or permit condition. Tracks the schedule name, associated enforcement action or permit, regulatory agency, milestone descriptions and due dates, milestone completion status, extension requests, and final compliance deadline. Provides the structured roadmap for returning to compliance.'
}

Table compliance.regulatory_agency {
  regulatory_agency_id varchar [pk, note: 'Unique identifier for the regulatory agency record. Primary key.']
  parent_regulatory_agency_id varchar [note: 'Self-referencing FK on regulatory_agency (parent_regulatory_agency_id)']
  parent_regulatory_agency_id_legacy varchar [note: 'Reference to the parent or umbrella agency if this agency is a regional office, division, or sub-agency (e.g., EPA Region 5 parent is EPA). Null if this is a top-level agency.']
  primary_liaison_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Each regulatory agency relationship requires designated utility liaison for communication continuity, relationship management, and coordination of submissions and inspections. Links to employee for wo']
  additional_programs_administered varchar [note: 'Comma-separated list of additional regulatory programs or statutes administered by this agency that apply to the utility (e.g., IUP, FOG, SSO, LCRR).']
  address_line1 varchar [note: 'Primary street address line for the regulatory agency headquarters or regional office.']
  address_line2 varchar [note: 'Secondary address line for suite, floor, or building information.']
  address_line_1 varchar [note: 'First line of the agency\'s physical mailing address (street number and name).']
  address_line_2 varchar [note: 'Second line of the agency\'s physical mailing address (suite, floor, building, etc.). Nullable.']
  agency_acronym varchar
  agency_code varchar [note: 'Short alphanumeric code uniquely identifying the regulatory agency within the utility\'s systems (e.g., EPA_R5, STATE_DNR, PUC_WI).']
  agency_level varchar
  agency_main_email varchar [note: 'General inquiry or main email address for the regulatory agency.']
  agency_main_phone varchar [note: 'Main switchboard or general inquiry phone number for the regulatory agency.']
  agency_name varchar [note: 'Full legal name of the regulatory agency or governing body (e.g., U.S. Environmental Protection Agency Region 5, Wisconsin Department of Natural Resources).']
  agency_short_name varchar [note: 'Abbreviated or commonly used name for the agency (e.g., EPA Region 5, WI DNR, OSHA).']
  agency_status varchar [note: 'Current operational status of the regulatory agency (active, inactive, merged, dissolved).']
  agency_type varchar [note: 'Classification of the regulatory agency by its primary regulatory focus (environmental, health, safety, rate regulatory, labor, quality standards, other). [ENUM-REF-CANDIDATE: environmental|health|safety|rate_regulatory|labor|quality_standards|other — 7 candidates stripped; promote to reference product]']
  agency_website_url varchar [note: 'Official website URL for the regulatory agency.']
  business_hours varchar [note: 'Standard business hours of operation for the regulatory agency office (e.g., Monday-Friday 8:00 AM - 5:00 PM PST).']
  city varchar [note: 'City name for the agency\'s physical mailing address.']
  contact_email varchar
  contact_name varchar [note: 'Contact name']
  contact_phone varchar
  country_code varchar [note: 'Three-letter ISO country code for the agency\'s physical mailing address (e.g., USA, CAN, MEX).']
  created_timestamp timestamp [note: 'Timestamp when this regulatory agency record was first created in the system.']
  effective_date date [note: 'Date when this agency\'s jurisdiction or regulatory authority over the utility became effective.']
  emergency_contact_phone varchar [note: '24-hour emergency contact phone number for reporting spills, violations, or urgent compliance matters.']
  enforcement_authority_level varchar [note: 'Level of enforcement authority this agency holds over the utility (primary, delegated, advisory, none). Primary indicates direct enforcement power; delegated indicates authority granted by a higher-level agency; advisory indicates no direct enforcement.']
  eu_directive_scope varchar [note: 'Comma-separated list of EU directives this agency administers (DWD_2020_2184, REACH, WFD_2000_60, UWWTD_91_271).']
  eu_member_state varchar [note: 'For EU-region agencies, the EU member state code (e.g. DE, FR, NL). NULL for non-EU agencies.']
  eu_member_state_code varchar [note: 'ISO 3166-1 alpha-2 code for EU member state where this agency has competent authority (e.g. DE, FR, NL). NULL for non-EU agencies.']
  eu_reference_path varchar [note: 'EU reference path: Drinking Water Directive 2020/2184; REACH; WFD; UWWTD citation chain.']
  eu_regulatory_framework varchar [note: 'EU directives administered (e.g. Drinking Water Directive 2020/2184,REACH,Water Framework Directive,Urban Wastewater Treatment Directive). REACH restriction targets broader PFAS class, not individual compounds; WFD defines surface-water status differently']
  fax_number varchar [note: 'Fax number for document submission to the regulatory agency, if applicable.']
  inspection_frequency_months varchar [note: 'Typical frequency in months at which this regulatory agency conducts inspections of utility facilities under its jurisdiction.']
  inspection_frequency_typical varchar [note: 'Typical frequency at which this agency conducts inspections or audits of utility facilities (annual, biennial, triennial, as-needed, risk-based).']
  international_agency_flag boolean [note: 'True for non-US (EU/FR/UK/DE) regulatory agencies.']
  is_active boolean
  jurisdiction varchar [note: 'Geographic or administrative jurisdiction of the regulatory agency (e.g., United States, California, Los Angeles County).']
  jurisdiction_code varchar [note: 'Jurisdiction code']
  jurisdiction_geographic_area varchar [note: 'Geographic area or service territory over which the agency has regulatory authority (e.g., EPA Region 5 covers IL, IN, MI, MN, OH, WI; or specific county/municipality names).']
  jurisdiction_level varchar [note: 'The governmental level at which the agency operates (federal, state, regional, local, international).']
  last_inspection_date date [note: 'Date of the most recent inspection conducted by this regulatory agency at any utility facility.']
  last_modified_timestamp timestamp [note: 'Timestamp when this regulatory agency record was last updated or modified.']
  notes varchar [note: 'Free-text field for additional notes, special instructions, or context about the regulatory agency relationship.']
  notification_deadline_hours varchar [note: 'Standard number of hours within which the utility must notify this agency of reportable incidents or violations (e.g., 24 hours for SSO events).']
  npdes_authority_flag boolean [note: 'Indicates whether this agency has authority to issue and enforce NPDES permits under the Clean Water Act. True if authorized, False otherwise.']
  other_reference_path varchar [note: 'Other national/regional regulatory reference path.']
  postal_code varchar [note: 'Postal or ZIP code for the agency\'s physical mailing address.']
  pretreatment_authority_flag boolean [note: 'Indicates whether this agency has authority to oversee industrial pretreatment programs. True if authorized, False otherwise.']
  primacy_agency_flag boolean [note: 'Indicates whether this agency has primacy authority for Safe Drinking Water Act (SDWA) enforcement in its jurisdiction. True if primacy agency, False otherwise.']
  primacy_status varchar [note: 'Indicates whether this agency is a primacy agency under the Safe Drinking Water Act (SDWA) or Clean Water Act (CWA), meaning it has been delegated primary enforcement authority by EPA (primacy_agency, non_primacy, not_applicable).']
  primary_contact_email varchar [note: 'Primary email address for the agency contact.']
  primary_contact_name varchar [note: 'Full name of the primary contact person at the agency for utility compliance matters.']
  primary_contact_phone varchar [note: 'Primary telephone number for the agency contact.']
  primary_contact_title varchar [note: 'Job title or role of the primary contact person at the agency.']
  primary_program varchar
  primary_regulatory_program varchar [note: 'The main regulatory program or statute administered by this agency relevant to water utilities (e.g., SDWA, CWA, NPDES, OSHA, Rate Regulation).']
  region_code varchar [note: 'Regional designation or code if the agency operates within a specific region (e.g., EPA Region 9, Water Board Region 4).']
  regulatory_framework varchar [note: 'Applicable regulatory framework for the region (US=EPA/AWWA/NPDWR/UCMR/NPDES; EU=Drinking Water Directive 2020/2184; REACH; Water Framework Directive; Urban Wastewater Treatment Directive; OTHER=Other national/regional frameworks).']
  regulatory_program varchar [note: 'Primary regulatory program or framework administered by the agency (e.g., NPDES, SDWA Primacy, Pretreatment, Lead and Copper Rule).']
  regulatory_region varchar [note: 'Regulatory region Allowed regions: US,EU,OTHER.']
  regulatory_region_code varchar [note: 'ISO region code identifying the jurisdiction this agency operates in (US, EU, OTHER). Enables multi-jurisdictional regulatory agency modeling.']
  reporting_frequency_default varchar [note: 'Default or most common reporting frequency required by this agency for compliance reports (monthly, quarterly, semi-annual, annual, event-driven, as-required).']
  reporting_system_name varchar [note: 'Name of the electronic reporting system used by the agency (e.g., NetDMR, SDWIS, state-specific portal).']
  secondary_contact_phone varchar [note: 'Secondary or alternate telephone number for the regulatory agency.']
  state varchar [note: 'Two-letter state or province code where the regulatory agency office is located.']
  state_province varchar [note: 'Two-letter state or province code for the agency\'s physical mailing address (e.g., WI, IL, CA).']
  submission_credentials_reference varchar [note: 'Reference identifier or location for stored login credentials or API keys used to access the agency\'s submission portal. Should reference a secure credential vault, not store actual credentials.']
  submission_portal_name varchar [note: 'Name of the online submission portal or system (e.g., NetDMR, State Environmental Portal, OSHA Injury Tracking Application).']
  submission_portal_url varchar [note: 'URL for the online portal or system used to submit compliance reports, permits, or other regulatory documents to this agency (e.g., NetDMR, state e-reporting system).']
  termination_date date [note: 'Date when this agency\'s jurisdiction or regulatory authority over the utility ended or will end. Null if still active.']
  us_reference_path varchar [note: 'US reference path: EPA/AWWA/NPDWR/UCMR/NPDES citation chain.']
  us_regulatory_framework varchar [note: 'US frameworks administered (e.g. EPA,AWWA,NPDWR,UCMR,NPDES).']
  website_url varchar [note: 'Official website URL for the regulatory agency.']

  Note: 'Master reference table for regulatory_agency. Referenced by: compliance.regulatory_submission.regulatory_agency_id, treatment.mor_submission.regulatory_agency_id, treatment.treatment_permit.regulatory_agency_id, treatment.treatment_violation.regulatory_agency_id'
}

Table compliance.permit_vendor_service {
  permit_vendor_service_id varchar [pk, note: 'Primary key.']
  compliance_permit_id varchar [note: 'FK to compliance permit.']
  procurement_contract_id varchar [note: 'FK to procurement contract.']
  vendor_id varchar [note: 'FK to vendor.']
  amount_spent decimal(18,2) [note: 'Amount spent to date.']
  contract_amount decimal(18,2) [note: 'Contract amount.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  deliverables_description varchar [note: 'Description of deliverables.']
  end_date date [note: 'Service end date.']
  last_modified_timestamp timestamp [note: 'Last modification timestamp.']
  notes varchar [note: 'Additional notes.']
  performance_rating varchar [note: 'Vendor performance rating.']
  service_cost decimal(18,2) [note: 'Service cost']
  service_description varchar [note: 'Description of the service.']
  service_end_date date
  service_start_date date
  service_status varchar [note: 'Current status of the service.']
  service_type varchar [note: 'Type of service (Consulting, Monitoring, Reporting, Lab).']
  start_date date [note: 'Service start date.']

  Note: 'Vendor services contracted to support permit compliance including consulting, monitoring, and reporting services.'
}

Table compliance.material_compliance_certification {
  material_compliance_certification_id varchar [pk, note: 'Primary key.']
  compliance_permit_id varchar
  material_master_id varchar [note: 'FK to material master.']
  vendor_id varchar [note: 'FK to vendor.']
  application_use varchar [note: 'Intended application use.']
  certification_date date [note: 'Certification date']
  certification_number varchar [note: 'Certification number.']
  certification_standard varchar
  certification_status varchar [note: 'Current status (Active, Expired, Revoked).']
  certification_type varchar [note: 'Type of certification (NSF 60, NSF 61, AWWA).']
  certifying_body varchar [note: 'Organization that issued the certification.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  document_url varchar [note: 'URL to certification document.']
  effective_date date [note: 'Certification effective date.']
  expiration_date date [note: 'Certification expiration date.']
  issue_date date
  last_modified_timestamp timestamp [note: 'Last modification timestamp.']
  maximum_use_level varchar [note: 'Maximum use level per certification.']
  notes varchar [note: 'Additional notes.']
  nsf_certified_flag boolean
  product_name varchar [note: 'Name of the certified product.']

  Note: 'Certifications that materials and chemicals used in water treatment meet NSF/ANSI 60/61 and other regulatory standards.'
}

Table compliance.permit_grant_allocation {
  permit_grant_allocation_id varchar [pk, note: 'Primary key.']
  cip_project_id varchar [note: 'FK to CIP project.']
  compliance_permit_id varchar [note: 'FK to compliance permit.']
  grant_id varchar [note: 'FK to grant.']
  allocated_amount decimal(18,2)
  allocation_amount decimal(18,2) [note: 'Amount allocated.']
  allocation_date date
  allocation_percentage decimal(5,2)
  allocation_purpose varchar [note: 'Purpose of the allocation.']
  allocation_status varchar [note: 'Current status.']
  amount_expended decimal(18,2) [note: 'Amount expended to date.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  effective_date date [note: 'Effective date.']
  expiration_date date [note: 'Expiration date.']
  fiscal_year varchar
  last_modified_timestamp timestamp [note: 'Last modification timestamp.']
  notes varchar [note: 'Additional notes.']

  Note: 'Allocation of grant funding to permit compliance activities including SRF loans and EPA grants for compliance improvements.'
}

Table compliance.crew_assignment {
  crew_assignment_id varchar [pk, note: 'Primary key.']
  compliance_corrective_action_id varchar [note: 'FK to corrective action']
  compliance_permit_id varchar [note: 'FK to compliance permit.']
  compliance_schedule_id varchar
  crew_employee_id varchar
  crew_id varchar [note: 'FK to crew.']
  crew_supervisor_employee_id varchar
  enforcement_action_id varchar
  facility_id varchar [note: 'FK to facility.']
  obligation_id varchar [note: 'FK to obligation.']
  actual_hours decimal(8,2) [note: 'Actual hours spent.']
  assignment_date date
  assignment_status varchar [note: 'Current status.']
  assignment_type varchar [note: 'Type of assignment (Inspection, Sampling, Corrective Action).']
  completion_date date [note: 'Actual completion date.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  end_date date
  estimated_hours decimal(8,2) [note: 'Estimated hours for the assignment.']
  last_modified_timestamp timestamp [note: 'Last modification timestamp.']
  notes varchar [note: 'Additional notes.']
  priority varchar [note: 'Priority level.']
  scheduled_date date [note: 'Scheduled date for the assignment.']
  start_date date
  task_description varchar

  Note: 'Assignment of workforce crews to compliance-related activities including inspections, sampling, and corrective action implementation.'
}

Table workforce.employee {
  employee_id varchar [pk, note: 'Unique identifier for the employee record.']
  supervisor_employee_id varchar [note: 'FK to the employee record of this employee\'s direct supervisor.']
  cdl_class varchar [note: 'Commercial driver license class held by the employee.']
  cdl_expiration_date date [note: 'Expiration date of the employee\'s commercial driver license.']
  cdl_license_number varchar [note: 'Commercial driver license number.']
  confined_space_certified_flag boolean [note: 'Indicates whether the employee is certified for confined space entry.']
  cost_center decimal(18,2) [note: 'Cost center code to which the employee\'s labor is charged.']
  created_timestamp timestamp [note: 'Timestamp when the employee record was created.']
  department_code varchar [note: 'Code identifying the department the employee belongs to.']
  department_name varchar [note: 'Name of the department the employee belongs to.']
  email_address varchar [note: 'Employee\'s work email address.']
  emergency_contact_name varchar [note: 'Name of the employee\'s emergency contact.']
  emergency_contact_phone varchar [note: 'Phone number of the employee\'s emergency contact.']
  emergency_contact_relationship varchar [note: 'Relationship of the emergency contact to the employee.']
  employment_status varchar [note: 'Current employment status (active, terminated, on leave, retired).']
  employment_type varchar [note: 'Type of employment (full-time, part-time, seasonal, contract).']
  first_name varchar [note: 'Employee\'s first (given) name.']
  hazmat_certified_flag boolean [note: 'Indicates whether the employee holds hazardous materials certification.']
  hire_date date [note: 'Date the employee was hired.']
  job_classification varchar [note: 'Job classification code for the employee\'s role.']
  job_title varchar [note: 'Official job title of the employee.']
  last_name varchar [note: 'Employee\'s last (family) name.']
  middle_name varchar [note: 'Employee\'s middle name.']
  modified_timestamp timestamp [note: 'Timestamp when the employee record was last modified.']
  operator_license_class varchar [note: 'Class of the operator license held (e.g., Class A, B, C, D).']
  operator_license_expiration_date date [note: 'Expiration date of the operator license.']
  operator_license_issue_date date [note: 'Date the operator license was issued.']
  operator_license_number varchar [note: 'State-issued operator license number.']
  operator_license_type varchar [note: 'Type of operator license (water treatment, water distribution, wastewater).']
  osha_training_current_flag boolean [note: 'Indicates whether the employee\'s OSHA safety training is current.']
  pay_grade varchar [note: 'Pay grade level assigned to the employee.']
  personnel_number varchar [note: 'Unique personnel number assigned by HR system.']
  phone_number varchar [note: 'Employee\'s work phone number.']
  shift_assignment varchar [note: 'Default shift assignment for the employee.']
  termination_date date [note: 'Date the employee\'s employment was terminated.']
  termination_reason varchar [note: 'Reason for employment termination.']
  union_local varchar [note: 'Union local number if the employee is a union member.']
  union_membership_flag boolean [note: 'Indicates whether the employee is a union member.']
  work_location_code varchar [note: 'Code identifying the employee\'s primary work location.']

  Note: 'Water utility employee master record containing personnel information, certifications, employment details, and operational qualifications for treatment plant operators, field technicians, and administrative staff.'
}

Table workforce.operator_license {
  operator_license_id varchar [pk, note: 'Unique identifier for the operator license record.']
  employee_id varchar [note: 'FK to the employee holding this license.']
  primary_assignment_facility_id varchar [note: 'FK to the treatment facility where this operator is primarily assigned.']
  backup_operator_flag boolean [note: 'Indicates if this operator serves as a backup/relief operator.']
  continuing_education_hours_completed decimal(5,2) [note: 'Continuing education hours completed in the current renewal cycle.']
  continuing_education_hours_required decimal(5,2) [note: 'Continuing education hours required for license renewal.']
  created_timestamp timestamp [note: 'Timestamp when the record was created.']
  exam_date date [note: 'Date the operator certification exam was taken.']
  exam_score decimal(5,2) [note: 'Score achieved on the certification exam.']
  expiration_date date [note: 'Date the license expires.']
  facility_classification_authorized varchar [note: 'Maximum facility classification this license authorizes the operator to run.']
  issue_date date [note: 'Date the license was originally issued.']
  issuing_agency_name varchar [note: 'Name of the state agency that issued the license.']
  issuing_state varchar [note: 'State that issued the operator license.']
  license_document_url varchar [note: 'URL to the scanned license document.']
  license_grade varchar [note: 'Grade/level of the operator license (e.g., I, II, III, IV).']
  license_number varchar [note: 'State-assigned license number.']
  license_status varchar [note: 'Current status of the license (active, expired, suspended, revoked).']
  license_type varchar [note: 'Type of operator license (water treatment, water distribution, wastewater treatment, wastewater collection).']
  license_verification_date date [note: 'Date the license was last verified with the issuing agency.']
  license_verification_method varchar [note: 'Method used to verify the license (online, phone, letter).']
  notes varchar [note: 'Free-text notes about the license.']
  operator_in_responsible_charge_flag boolean [note: 'Indicates if this operator is designated as Operator in Responsible Charge.']
  reciprocity_state varchar [note: 'State from which reciprocity was granted, if applicable.']
  renewal_application_submitted_date date [note: 'Date the renewal application was submitted.']
  renewal_date date [note: 'Date the license was last renewed.']
  renewal_fee_amount decimal(10,2) [note: 'Fee amount paid for license renewal.']
  renewal_fee_paid_date date [note: 'Date the renewal fee was paid.']
  renewal_notification_sent_date date [note: 'Date a renewal reminder notification was sent.']
  revocation_date date [note: 'Date the license was revoked, if applicable.']
  revocation_reason varchar [note: 'Reason for license revocation.']
  suspension_end_date date [note: 'End date of a license suspension period.']
  suspension_reason varchar [note: 'Reason for license suspension.']
  suspension_start_date date [note: 'Start date of a license suspension period.']
  updated_timestamp timestamp [note: 'Timestamp when the record was last updated.']

  Note: 'State-issued operator licenses for water treatment, water distribution, and wastewater treatment operations, tracking license grades, renewal cycles, continuing education requirements, and regulatory compliance.'
}

Table workforce.certification {
  certification_id varchar [pk, note: 'Unique identifier for the certification record.']
  employee_id varchar [note: 'FK to the employee holding this certification.']
  attachment_url varchar [note: 'URL to the scanned certification document.']
  certificate_number varchar [note: 'Unique certificate number assigned by the certifying body.']
  certification_name varchar [note: 'Name of the certification.']
  certification_status varchar [note: 'Current status (active, expired, suspended, revoked).']
  certification_type varchar [note: 'Type/category of certification (safety, technical, management).']
  certifying_body varchar [note: 'Organization that issued the certification.']
  ceu_earned decimal(5,2) [note: 'Continuing education units earned toward this certification.']
  ceu_required decimal(5,2) [note: 'Continuing education units required for renewal.']
  cost_amount decimal(18,2) [note: 'Cost paid for obtaining or renewing the certification.']
  cost_currency_code decimal(18,2) [note: 'Currency code for the cost amount.']
  created_timestamp timestamp [note: 'Timestamp when the record was created.']
  expiration_date date [note: 'Date the certification expires.']
  is_mandatory boolean [note: 'Indicates if this certification is mandatory for the employee\'s position.']
  is_regulatory_required boolean [note: 'Indicates if this certification is required by regulation.']
  issue_date date [note: 'Date the certification was issued.']
  modified_timestamp timestamp [note: 'Timestamp when the record was last modified.']
  notes varchar [note: 'Free-text notes about the certification.']
  reimbursement_status varchar [note: 'Status of employer reimbursement for certification costs.']
  renewal_date date [note: 'Date the certification was last renewed.']
  training_completion_date date [note: 'Date the required training was completed.']
  training_hours decimal(6,2) [note: 'Total training hours completed for this certification.']
  training_provider varchar [note: 'Organization that provided the training.']
  verification_date date [note: 'Date the certification was last verified.']
  verification_status varchar [note: 'Status of certification verification (verified, pending, failed).']

  Note: 'Professional certifications held by utility employees including safety certifications, technical certifications, and industry credentials beyond state operator licenses.'
}

Table workforce.training_course {
  training_course_id varchar [pk, note: 'Unique identifier for the training course.']
  course_owner_employee_id varchar [note: 'FK to the employee responsible for maintaining this course.']
  training_approved_provider_vendor_id varchar [note: 'FK to the approved vendor providing this course.']
  training_vendor_id varchar [note: 'FK to the vendor delivering the course.']
  accessibility_accommodations varchar [note: 'Available accessibility accommodations for the course.']
  assessment_required_flag boolean [note: 'Indicates if a post-course assessment is required.']
  certification_awarded varchar [note: 'Certification awarded upon successful completion.']
  ceu_credits decimal(5,2) [note: 'Continuing education units awarded for completion.']
  cmms_system_flag boolean [note: 'Indicates if this is CMMS system training.']
  cost_per_participant decimal(10,2) [note: 'Cost per participant for the course.']
  course_category varchar [note: 'Category of the course (safety, technical, regulatory, professional development).']
  course_code varchar [note: 'Unique code identifying the course.']
  course_description varchar [note: 'Detailed description of the course content and objectives.']
  course_materials_url varchar [note: 'URL to course materials and resources.']
  course_status varchar [note: 'Current status of the course (active, retired, under review).']
  course_title varchar [note: 'Title of the training course.']
  created_timestamp timestamp [note: 'Timestamp when the course record was created.']
  delivery_method varchar [note: 'Method of course delivery (classroom, online, hands-on, blended).']
  duration_hours decimal(6,2) [note: 'Total duration of the course in hours.']
  effective_end_date date [note: 'Date the course is no longer available.']
  effective_start_date date [note: 'Date the course becomes available.']
  gis_system_flag boolean [note: 'Indicates if this is GIS system training.']
  language varchar [note: 'Language in which the course is delivered.']
  last_content_review_date date [note: 'Date the course content was last reviewed.']
  maximum_enrollment varchar [note: 'Maximum number of participants per session.']
  modified_timestamp timestamp [note: 'Timestamp when the course record was last modified.']
  next_review_due_date date [note: 'Date the next content review is due.']
  passing_score_percentage decimal(5,2) [note: 'Minimum passing score percentage for the assessment.']
  prerequisite_courses varchar [note: 'List of prerequisite course codes.']
  regulatory_authority varchar [note: 'Regulatory authority mandating this training.']
  regulatory_mandate_flag boolean [note: 'Indicates if this course is mandated by regulation.']
  required_frequency_months varchar [note: 'Frequency in months at which this training must be repeated.']
  safety_training_flag boolean [note: 'Indicates if this is a safety training course.']
  scada_system_flag boolean [note: 'Indicates if this is SCADA system training.']
  target_audience varchar [note: 'Intended audience for the course.']
  vendor_contract_number varchar [note: 'Contract number with the training vendor.']

  Note: 'Catalog of training courses available to utility employees including regulatory-mandated safety training, operator certification preparation, SCADA/GIS system training, and professional development courses.'
}

Table workforce.training_record {
  training_record_id varchar [pk, note: 'Unique identifier for the training record.']
  cost_center_id varchar [note: 'FK to the cost center charged for this training.']
  employee_id varchar [note: 'FK to the employee who completed the training.']
  training_course_id varchar [note: 'FK to the training course completed.']
  approval_date date [note: 'Date the training was approved by supervisor.']
  approved_by varchar [note: 'Name of the person who approved the training.']
  assessment_method varchar [note: 'Method used to assess competency (written exam, practical, observation).']
  attendance_percentage decimal(5,2) [note: 'Percentage of course sessions attended.']
  certification_expiration_date date [note: 'Expiration date of any certification earned.']
  certification_issued varchar [note: 'Certification issued upon completion.']
  ceu_credits_earned decimal(6,2) [note: 'Continuing education units earned.']
  comments varchar [note: 'Additional comments about the training.']
  completion_date date [note: 'Date the training was completed.']
  cost_amount decimal(12,2) [note: 'Actual cost of the training for this employee.']
  cost_currency_code varchar [note: 'Currency code for the cost amount.']
  course_code varchar [note: 'Code of the course completed.']
  course_name varchar [note: 'Name of the course completed.']
  created_timestamp timestamp [note: 'Timestamp when the record was created.']
  delivery_method varchar [note: 'How the training was delivered (classroom, online, OJT).']
  enrollment_date date [note: 'Date the employee enrolled in the training.']
  funding_source varchar [note: 'Source of funding for the training.']
  instructor_name varchar [note: 'Name of the instructor.']
  is_compliance_required boolean [note: 'Indicates if this training is required for compliance.']
  is_regulatory_required boolean [note: 'Indicates if this training is required by regulation.']
  modified_timestamp timestamp [note: 'Timestamp when the record was last modified.']
  score decimal(5,2) [note: 'Assessment score achieved.']
  start_date date [note: 'Date the training started.']
  training_category varchar [note: 'Category of training (safety, technical, regulatory).']
  training_hours decimal(6,2) [note: 'Total hours spent in training.']
  training_location varchar [note: 'Location where the training took place.']
  training_materials_provided boolean [note: 'Indicates if training materials were provided.']
  training_provider varchar [note: 'Organization that provided the training.']
  training_result varchar [note: 'Result of the training (pass, fail, incomplete).']
  training_status varchar [note: 'Current status (enrolled, in progress, completed, cancelled).']
  training_type varchar [note: 'Type of training (initial, refresher, recertification).']

  Note: 'Individual employee training completion records tracking enrollment, attendance, assessment scores, CEU credits earned, and compliance status for regulatory-required and elective training.'
}

Table workforce.shift_assignment {
  shift_assignment_id varchar [pk, note: 'Unique identifier for the shift assignment.']
  crew_assignment_id varchar [note: 'FK to the crew assignment record.']
  facility_id varchar [note: 'FK to the facility where the shift is worked.']
  metering_dma_zone_id varchar [note: 'FK to the metering DMA zone for field assignments.']
  primary_shift_employee_id varchar [note: 'FK to the primary employee on this shift.']
  shift_approved_by_employee_id varchar [note: 'FK to the employee who approved this shift assignment.']
  shift_employee_id varchar [note: 'FK to the employee assigned to this shift.']
  shift_modified_by_user_employee_id varchar [note: 'FK to the employee who last modified this record.']
  shift_schedule_id varchar [note: 'FK to the shift schedule this assignment belongs to.']
  shift_supervisor_employee_id varchar [note: 'FK to the supervising employee for this shift.']
  swap_request_id varchar [note: 'FK to the swap request if this assignment resulted from a swap.']
  tertiary_shift_supervisor_employee_id varchar [note: 'FK to the tertiary shift supervisor.']
  warehouse_location_id varchar [note: 'FK to the warehouse location for material pickup.']
  work_order_id varchar [note: 'FK to the work order associated with this shift.']
  absence_notes varchar [note: 'Notes regarding any absence during the shift.']
  absence_reason varchar [note: 'Reason for absence if the employee did not work the shift.']
  actual_end_timestamp timestamp [note: 'Actual timestamp when the shift ended.']
  actual_hours decimal(5,2) [note: 'Actual hours worked during the shift.']
  actual_start_timestamp timestamp [note: 'Actual timestamp when the shift started.']
  approved_timestamp timestamp [note: 'Timestamp when the assignment was approved.']
  assigned_date date [note: 'Date the shift was assigned.']
  assignment_notes varchar [note: 'Notes about the shift assignment.']
  assignment_number varchar [note: 'Unique assignment number.']
  assignment_status varchar [note: 'Status of the assignment (scheduled, in progress, completed, cancelled).']
  certification_required varchar [note: 'Certifications required for this shift assignment.']
  certification_verified_flag boolean [note: 'Indicates if required certifications were verified.']
  cost_center_code varchar [note: 'Cost center code for labor charging.']
  created_timestamp timestamp [note: 'Timestamp when the record was created.']
  emergency_callout_flag boolean [note: 'Indicates if this is an emergency callout shift.']
  labor_cost_amount decimal(12,2) [note: 'Total labor cost for this shift assignment.']
  labor_cost_currency_code varchar [note: 'Currency code for the labor cost.']
  modified_timestamp timestamp [note: 'Timestamp when the record was last modified.']
  on_call_flag boolean [note: 'Indicates if this is an on-call shift.']
  overtime_flag boolean [note: 'Indicates if overtime was worked.']
  overtime_hours decimal(5,2) [note: 'Number of overtime hours worked.']
  project_code varchar [note: 'Project code for labor allocation.']
  scheduled_hours decimal(5,2) [note: 'Number of hours scheduled for this shift.']
  shift_end_timestamp timestamp [note: 'Scheduled end timestamp for the shift.']
  shift_role varchar [note: 'Role the employee fills during this shift.']
  shift_start_timestamp timestamp [note: 'Scheduled start timestamp for the shift.']
  shift_type varchar [note: 'Type of shift (day, night, swing, weekend).']

  Note: 'Individual shift assignments linking employees to specific shifts, facilities, and crews, tracking actual hours worked, overtime, on-call status, and labor costs for water utility operations.'
}

Table workforce.crew {
  crew_id varchar [pk, note: 'Unique identifier for the crew.']
  cost_center_id varchar [note: 'FK to the cost center for this crew\'s labor.']
  crew_employee_id varchar [note: 'FK to an employee assigned to this crew.']
  crew_last_modified_by_user_employee_id varchar [note: 'FK to the user who last modified the record.']
  crew_service_area_territory_id varchar [note: 'FK to the service territory this crew covers.']
  crew_territory_id varchar [note: 'FK to the territory assigned to this crew.']
  location_id varchar [note: 'FK to the crew\'s home base location.']
  primary_crew_employee_id varchar [note: 'FK to the crew lead employee.']
  registry_id varchar [note: 'FK to the asset registry for crew equipment.']
  warehouse_location_id varchar [note: 'FK to the warehouse where the crew picks up materials.']
  average_response_time_minutes decimal(8,2) [note: 'Average response time in minutes for this crew.']
  certification_level varchar [note: 'Highest certification level held by crew members.']
  confined_space_certified boolean [note: 'Indicates if the crew is certified for confined space entry.']
  created_timestamp timestamp [note: 'Timestamp when the crew record was created.']
  crew_code varchar [note: 'Unique code identifying the crew.']
  crew_name varchar [note: 'Name of the crew.']
  crew_status varchar [note: 'Current status of the crew (active, inactive, on standby).']
  crew_type varchar [note: 'Type of crew (maintenance, construction, emergency, meter reading).']
  effective_end_date date [note: 'Date the crew was deactivated.']
  effective_start_date date [note: 'Date the crew became active.']
  emergency_response_qualified boolean [note: 'Indicates if the crew is qualified for emergency response.']
  equipment_inventory_complete boolean [note: 'Indicates if the crew\'s equipment inventory is complete.']
  excavation_certified boolean [note: 'Indicates if the crew is certified for excavation work.']
  gps_tracking_enabled boolean [note: 'Indicates if GPS tracking is enabled for this crew.']
  hazmat_certified boolean [note: 'Indicates if the crew is hazmat certified.']
  hourly_labor_rate decimal(10,2) [note: 'Blended hourly labor rate for the crew.']
  last_modified_timestamp timestamp [note: 'Timestamp when the record was last modified.']
  last_safety_training_date date [note: 'Date of the crew\'s last safety training.']
  mobile_device_code varchar [note: 'Code for the crew\'s mobile device.']
  notes varchar [note: 'Free-text notes about the crew.']
  overtime_eligible boolean [note: 'Indicates if the crew is eligible for overtime.']
  safety_incident_count_ytd varchar [note: 'Number of safety incidents year-to-date.']
  shift_schedule varchar [note: 'Default shift schedule for the crew.']
  size varchar [note: 'Number of members in the crew.']
  union_affiliation varchar [note: 'Union affiliation of the crew members.']
  vehicle_code varchar [note: 'Code for the crew\'s assigned vehicle.']
  work_orders_completed_ytd varchar [note: 'Number of work orders completed year-to-date.']

  Note: 'Work crews composed of utility employees assigned to field operations, maintenance, construction, and emergency response activities across the water and wastewater systems.'
}

Table workforce.labor_timesheet {
  labor_timesheet_id varchar [pk, note: 'Unique identifier for the timesheet entry.']
  cip_project_id varchar [note: 'FK to the CIP project if labor is charged to capital.']
  cost_center_id varchar [note: 'FK to the cost center for labor allocation.']
  general_ledger_id varchar [note: 'FK to the GL account for labor posting.']
  labor_employee_id varchar [note: 'FK to the employee who worked the hours.']
  primary_labor_employee_id varchar [note: 'FK to the primary labor employee.']
  work_order_id varchar [note: 'FK to the work order the labor is charged against.']
  activity_type varchar [note: 'Type of activity performed (maintenance, operations, construction).']
  approval_status varchar [note: 'Status of timesheet approval (pending, approved, rejected).']
  approval_timestamp timestamp [note: 'Timestamp when the timesheet was approved.']
  billable_flag boolean [note: 'Indicates if the labor is billable.']
  call_out_hours decimal(8,2) [note: 'Hours worked on emergency call-outs.']
  created_timestamp timestamp [note: 'Timestamp when the record was created.']
  crew_assignment varchar [note: 'Crew the employee was assigned to.']
  equipment_used varchar [note: 'Equipment used during the work.']
  hours_worked decimal(8,2) [note: 'Total hours worked.']
  labor_cost decimal(12,2) [note: 'Calculated labor cost for this entry.']
  labor_rate decimal(10,2) [note: 'Hourly labor rate applied.']
  modified_timestamp timestamp [note: 'Timestamp when the record was last modified.']
  notes varchar [note: 'Free-text notes about the work performed.']
  overtime_hours decimal(8,2) [note: 'Overtime hours worked.']
  pay_code varchar [note: 'Pay code for payroll processing.']
  payroll_period varchar [note: 'Payroll period this entry belongs to.']
  regular_hours decimal(8,2) [note: 'Regular (non-overtime) hours worked.']
  safety_incident_flag boolean [note: 'Indicates if a safety incident occurred during this work.']
  shift_type varchar [note: 'Type of shift worked.']
  standby_hours decimal(8,2) [note: 'Hours on standby.']
  submission_timestamp timestamp [note: 'Timestamp when the timesheet was submitted.']
  task_description varchar [note: 'Description of the task performed.']
  timesheet_date date [note: 'Date the work was performed.']
  training_hours decimal(8,2) [note: 'Hours spent in training.']
  work_location varchar [note: 'Location where the work was performed.']

  Note: 'Daily labor timesheet entries recording hours worked by utility employees against work orders, projects, cost centers, and general ledger accounts for payroll processing and cost allocation.'
}

Table workforce.position {
  position_id varchar [pk, note: 'Unique identifier for the position.']
  cost_center_id varchar [note: 'FK to the cost center funding this position.']
  facility_id varchar [note: 'FK to the facility where this position is located.']
  position_department_org_unit_id varchar [note: 'FK to the department org unit.']
  position_org_unit_id varchar [note: 'FK to the organizational unit this position belongs to.']
  supervisor_position_id varchar [note: 'FK to the supervisory position above this one.']
  approval_date date [note: 'Date the position was approved.']
  approved_by varchar [note: 'Name of the person who approved the position.']
  bargaining_unit varchar [note: 'Bargaining unit the position belongs to.']
  created_timestamp timestamp [note: 'Timestamp when the position was created.']
  effective_end_date date [note: 'Date the position is no longer active.']
  effective_start_date date [note: 'Date the position becomes active.']
  flsa_status varchar [note: 'Fair Labor Standards Act status (exempt, non-exempt).']
  fte_count decimal(5,2) [note: 'Full-time equivalent count for this position.']
  job_code varchar [note: 'Job classification code.']
  last_modified_timestamp timestamp [note: 'Timestamp when the position was last modified.']
  organizational_level varchar [note: 'Level in the organizational hierarchy.']
  pay_grade varchar [note: 'Pay grade assigned to this position.']
  pay_range_maximum decimal(12,2) [note: 'Maximum salary for this position.']
  pay_range_minimum decimal(12,2) [note: 'Minimum salary for this position.']
  position_code varchar [note: 'Unique code for the position.']
  position_description varchar [note: 'Detailed description of the position.']
  position_status varchar [note: 'Current status (active, frozen, abolished).']
  position_type varchar [note: 'Type of position (permanent, temporary, seasonal).']
  required_certifications varchar [note: 'Certifications required for this position.']
  required_operator_license_grade varchar [note: 'Minimum operator license grade required.']
  requires_cdl boolean [note: 'Indicates if a CDL is required.']
  requires_confined_space_entry boolean [note: 'Indicates if confined space entry certification is required.']
  requires_on_call boolean [note: 'Indicates if on-call duty is required.']
  safety_sensitive boolean [note: 'Indicates if this is a safety-sensitive position.']
  shift_rotation_required boolean [note: 'Indicates if shift rotation is required.']
  succession_criticality varchar [note: 'Criticality rating for succession planning.']
  title varchar [note: 'Official title of the position.']
  union_classification varchar [note: 'Union classification for the position.']

  Note: 'Authorized positions within the utility organization defining job requirements, pay grades, required certifications, operator license grades, and organizational placement for workforce planning.'
}

Table workforce.org_unit {
  org_unit_id varchar [pk, note: 'Unique identifier for the organizational unit.']
  cost_center_id varchar [note: 'FK to the cost center for this org unit.']
  facility_location_id varchar [note: 'FK to the physical location of this org unit.']
  manager_employee_id varchar [note: 'FK to the employee managing this org unit.']
  parent_org_unit_id varchar [note: 'FK to the parent organizational unit.']
  address_line_1 varchar [note: 'First line of the org unit\'s address.']
  address_line_2 varchar [note: 'Second line of the org unit\'s address.']
  budget_amount_annual decimal(18,2) [note: 'Annual budget amount for the org unit.']
  budget_fiscal_year varchar [note: 'Fiscal year for the budget amount.']
  certification_required_flag boolean [note: 'Indicates if certifications are required for staff in this unit.']
  city varchar [note: 'City where the org unit is located.']
  country_code varchar [note: 'Country code for the org unit location.']
  created_timestamp timestamp [note: 'Timestamp when the record was created.']
  effective_end_date date [note: 'Date the org unit is deactivated.']
  effective_start_date date [note: 'Date the org unit became active.']
  email_address varchar [note: 'Contact email for the org unit.']
  fax_number varchar [note: 'Fax number for the org unit.']
  functional_area varchar [note: 'Functional area (operations, engineering, finance, customer service).']
  headcount_actual varchar [note: 'Current actual headcount.']
  headcount_authorized varchar [note: 'Authorized headcount for the org unit.']
  hierarchy_level varchar [note: 'Level in the organizational hierarchy.']
  modified_timestamp timestamp [note: 'Timestamp when the record was last modified.']
  operates_24_7 boolean [note: 'Indicates if the org unit operates 24/7.']
  org_unit_description varchar [note: 'Description of the organizational unit.']
  phone_number varchar [note: 'Contact phone number for the org unit.']
  postal_code varchar [note: 'Postal/ZIP code.']
  regulatory_oversight_agency varchar [note: 'Regulatory agency with oversight of this unit.']
  safety_sensitive_flag boolean [note: 'Indicates if the org unit performs safety-sensitive work.']
  shift_schedule_type varchar [note: 'Type of shift schedule used.']
  state_province varchar [note: 'State or province.']
  union_representation boolean [note: 'Indicates if the org unit has union representation.']
  unit_code varchar [note: 'Unique code for the org unit.']
  unit_name varchar [note: 'Name of the organizational unit.']
  unit_short_name varchar [note: 'Abbreviated name of the org unit.']
  unit_status varchar [note: 'Current status (active, inactive, reorganizing).']
  unit_type varchar [note: 'Type of organizational unit (division, department, section, team).']

  Note: 'Organizational units representing departments, divisions, and sections within the water utility including treatment operations, distribution, customer service, engineering, and administration.'
}

Table workforce.safety_incident {
  safety_incident_id varchar [pk, note: 'Unique identifier for the safety incident.']
  cost_center_id varchar [note: 'FK to the cost center where the incident occurred.']
  facility_id varchar [note: 'FK to the facility where the incident occurred.']
  primary_safety_employee_id varchar [note: 'FK to the primary safety officer.']
  process_unit_id varchar [note: 'FK to the process unit involved.']
  registry_id varchar [note: 'FK to the asset involved in the incident.']
  safety_employee_id varchar [note: 'FK to the employee involved in the incident.']
  tertiary_safety_reported_by_employee_id varchar [note: 'FK to the employee who reported the incident.']
  work_order_id varchar [note: 'FK to the work order being performed when the incident occurred.']
  body_part_affected varchar [note: 'Body part affected by the injury.']
  corrective_action_completed_date date [note: 'Date corrective action was completed.']
  corrective_action_description varchar [note: 'Description of corrective actions taken.']
  corrective_action_due_date date [note: 'Due date for corrective action.']
  corrective_action_required_flag boolean [note: 'Indicates if corrective action is required.']
  created_timestamp timestamp [note: 'Timestamp when the record was created.']
  days_away_from_work varchar [note: 'Number of days away from work due to the incident.']
  days_of_restricted_duty varchar [note: 'Number of days on restricted duty.']
  department varchar [note: 'Department where the incident occurred.']
  environmental_release_flag boolean [note: 'Indicates if an environmental release occurred.']
  environmental_release_volume decimal(12,2) [note: 'Volume of environmental release in gallons.']
  field_location_description varchar [note: 'Description of the field location.']
  gis_latitude decimal(10,7) [note: 'GPS latitude of the incident location.']
  gis_longitude decimal(10,7) [note: 'GPS longitude of the incident location.']
  incident_date date [note: 'Date the incident occurred.']
  incident_description varchar [note: 'Detailed description of the incident.']
  incident_number varchar [note: 'Unique incident tracking number.']
  incident_time timestamp [note: 'Time the incident occurred.']
  incident_type varchar [note: 'Type of incident (injury, near-miss, property damage, vehicle).']
  injury_nature varchar [note: 'Nature of the injury (laceration, strain, fracture).']
  injury_severity varchar [note: 'Severity of the injury (minor, moderate, severe, fatal).']
  investigation_completed_date date [note: 'Date the investigation was completed.']
  investigation_status varchar [note: 'Status of the investigation.']
  job_title varchar [note: 'Job title of the affected employee.']
  last_modified_timestamp timestamp [note: 'Timestamp when the record was last modified.']
  location_type varchar [note: 'Type of location (plant, field, office, vehicle).']
  osha_log_reference varchar [note: 'Reference to the OSHA 300 log entry.']
  osha_recordable_flag boolean [note: 'Indicates if the incident is OSHA recordable.']
  property_damage_amount decimal(15,2) [note: 'Estimated property damage amount.']
  regulatory_notification_date date [note: 'Date regulatory agencies were notified.']
  regulatory_notification_required_flag boolean [note: 'Indicates if regulatory notification is required.']
  reported_date date [note: 'Date the incident was reported.']
  root_cause_category varchar [note: 'Category of root cause (human error, equipment failure, procedure).']
  root_cause_description varchar [note: 'Detailed description of the root cause.']
  supervisor_name varchar [note: 'Name of the supervisor at the time of incident.']
  vehicle_code varchar [note: 'Code of the vehicle involved, if applicable.']
  witness_count varchar [note: 'Number of witnesses to the incident.']

  Note: 'Safety incidents occurring at utility facilities and field locations including injuries, near-misses, property damage, environmental releases, and vehicle accidents with OSHA reporting and root cause analysis.'
}

Table workforce.leave_request {
  leave_request_id varchar [pk, note: 'Unique identifier for the leave request.']
  leave_employee_id varchar [note: 'FK to the employee requesting leave.']
  primary_leave_employee_id varchar [note: 'FK to the primary leave approver.']
  tertiary_leave_backup_employee_id varchar [note: 'FK to the backup employee covering during leave.']
  work_location_id varchar [note: 'FK to the work location affected by the leave.']
  accrual_balance_after decimal(8,2) [note: 'Leave accrual balance after this request.']
  accrual_balance_before decimal(8,2) [note: 'Leave accrual balance before this request.']
  advance_notice_days varchar [note: 'Number of days advance notice provided.']
  approval_timestamp timestamp [note: 'Timestamp when the request was approved or denied.']
  approved_end_date date [note: 'Approved end date of leave.']
  approved_start_date date [note: 'Approved start date of leave.']
  attachment_url varchar [note: 'URL to supporting documentation.']
  certification_received boolean [note: 'Indicates if medical certification was received.']
  certification_received_date date [note: 'Date medical certification was received.']
  certification_required boolean [note: 'Indicates if medical certification is required.']
  cost_center_code varchar [note: 'Cost center code for the leave.']
  coverage_plan varchar [note: 'Plan for shift coverage during the leave.']
  created_timestamp timestamp [note: 'Timestamp when the request was created.']
  denial_reason varchar [note: 'Reason for denial if the request was denied.']
  fmla_case_number varchar [note: 'FMLA case number if applicable.']
  hours_approved decimal(8,2) [note: 'Number of leave hours approved.']
  hours_requested decimal(8,2) [note: 'Number of leave hours requested.']
  is_emergency_leave boolean [note: 'Indicates if this is an emergency leave request.']
  is_fmla_eligible boolean [note: 'Indicates if the leave qualifies under FMLA.']
  is_paid boolean [note: 'Indicates if the leave is paid.']
  leave_subtype varchar [note: 'Subtype of leave (e.g., personal sick, family sick).']
  leave_type varchar [note: 'Type of leave (vacation, sick, FMLA, bereavement, jury duty).']
  modified_timestamp timestamp [note: 'Timestamp when the record was last modified.']
  notes varchar [note: 'Additional notes about the leave request.']
  payroll_period varchar [note: 'Payroll period affected by the leave.']
  request_number varchar [note: 'Unique request tracking number.']
  request_status varchar [note: 'Status of the request (pending, approved, denied, cancelled).']
  request_submission_timestamp timestamp [note: 'Timestamp when the request was submitted.']
  requested_end_date date [note: 'Requested end date of leave.']
  requested_start_date date [note: 'Requested start date of leave.']
  shift_coverage_impact varchar [note: 'Assessment of impact on shift coverage.']

  Note: 'Employee leave requests including vacation, sick leave, FMLA, bereavement, and other leave types with approval workflows, accrual balance tracking, and shift coverage impact assessment.'
}

Table workforce.performance_review {
  performance_review_id varchar [pk, note: 'Unique identifier for the performance review.']
  cost_center_id varchar [note: 'FK to the cost center of the reviewed employee.']
  primary_performance_employee_id varchar [note: 'FK to the employee being reviewed.']
  reviewer_employee_id varchar [note: 'FK to the employee conducting the review.']
  areas_for_improvement varchar [note: 'Areas identified for improvement.']
  created_timestamp timestamp [note: 'Timestamp when the review was created.']
  customer_service_rating varchar [note: 'Rating for customer service performance.']
  customer_service_score decimal(5,2) [note: 'Numeric score for customer service.']
  development_plan_notes varchar [note: 'Notes on the employee\'s development plan.']
  employee_acknowledgment_date date [note: 'Date the employee acknowledged the review.']
  employee_acknowledgment_status varchar [note: 'Status of employee acknowledgment.']
  employee_comments varchar [note: 'Comments from the employee.']
  goal_achievement_rating varchar [note: 'Rating for goal achievement.']
  goal_achievement_score decimal(5,2) [note: 'Numeric score for goal achievement.']
  merit_increase_percentage decimal(5,2) [note: 'Recommended merit increase percentage.']
  merit_increase_recommended_flag boolean [note: 'Indicates if a merit increase is recommended.']
  modified_timestamp timestamp [note: 'Timestamp when the review was last modified.']
  next_review_due_date date [note: 'Date the next review is due.']
  overall_rating varchar [note: 'Overall performance rating.']
  overall_rating_score decimal(5,2) [note: 'Numeric overall performance score.']
  promotion_recommended_flag boolean [note: 'Indicates if a promotion is recommended.']
  regulatory_knowledge_rating varchar [note: 'Rating for regulatory knowledge.']
  regulatory_knowledge_score decimal(5,2) [note: 'Numeric score for regulatory knowledge.']
  review_date date [note: 'Date the review was conducted.']
  review_document_url varchar [note: 'URL to the review document.']
  review_period_end_date date [note: 'End date of the review period.']
  review_period_start_date date [note: 'Start date of the review period.']
  review_status varchar [note: 'Status of the review (draft, submitted, acknowledged, finalized).']
  review_type varchar [note: 'Type of review (annual, probationary, mid-year, special).']
  reviewer_comments varchar [note: 'Comments from the reviewer.']
  safety_compliance_rating varchar [note: 'Rating for safety compliance.']
  safety_compliance_score decimal(5,2) [note: 'Numeric score for safety compliance.']
  strengths_summary varchar [note: 'Summary of employee strengths.']
  succession_planning_candidate_flag boolean [note: 'Indicates if the employee is a succession planning candidate.']
  teamwork_rating varchar [note: 'Rating for teamwork.']
  teamwork_score decimal(5,2) [note: 'Numeric score for teamwork.']
  technical_skills_rating varchar [note: 'Rating for technical skills.']
  technical_skills_score decimal(5,2) [note: 'Numeric score for technical skills.']

  Note: 'Annual and periodic performance reviews for utility employees evaluating technical skills, safety compliance, regulatory knowledge, customer service, teamwork, and goal achievement with merit increase recommendations.'
}

Table workforce.field_service_dispatch {
  field_service_dispatch_id varchar [pk, note: 'Unique identifier for the dispatch record.']
  assigned_crew_id varchar [note: 'FK to the crew assigned to this dispatch.']
  customer_account_id varchar [note: 'FK to the customer account for this service call.']
  field_asset_registry_id varchar [note: 'FK to the asset being serviced.']
  field_employee_id varchar [note: 'FK to the assigned technician.']
  field_registry_id varchar [note: 'FK to the asset registry.']
  pickup_warehouse_location_id varchar [note: 'FK to the warehouse for material pickup.']
  primary_field_employee_id varchar [note: 'FK to the primary field technician.']
  work_order_id varchar [note: 'FK to the associated work order.']
  wtp_facility_id varchar [note: 'FK to the treatment facility if applicable.']
  actual_arrival_datetime timestamp [note: 'Actual arrival timestamp at the service location.']
  actual_departure_datetime timestamp [note: 'Actual departure timestamp from the service location.']
  actual_duration_hours decimal(5,2) [note: 'Actual duration of the service call in hours.']
  cancellation_datetime timestamp [note: 'Timestamp when the dispatch was cancelled.']
  cancellation_reason varchar [note: 'Reason for cancellation.']
  completion_datetime timestamp [note: 'Timestamp when the service was completed.']
  created_timestamp timestamp [note: 'Timestamp when the dispatch was created.']
  customer_contact_name varchar [note: 'Name of the customer contact.']
  customer_contact_phone varchar [note: 'Phone number of the customer contact.']
  dispatch_datetime timestamp [note: 'Timestamp when the dispatch was issued.']
  dispatch_number varchar [note: 'Unique dispatch tracking number.']
  dispatch_status varchar [note: 'Current status (pending, dispatched, en route, on site, completed).']
  dispatch_type varchar [note: 'Type of dispatch (service call, emergency, scheduled, meter).']
  dispatcher_notes varchar [note: 'Notes from the dispatcher.']
  dma_zone_code varchar [note: 'District metered area zone code.']
  equipment_required varchar [note: 'Equipment required for the service call.']
  estimated_duration_hours decimal(5,2) [note: 'Estimated duration in hours.']
  estimated_travel_time_minutes varchar [note: 'Estimated travel time in minutes.']
  modified_timestamp timestamp [note: 'Timestamp when the record was last modified.']
  priority_level varchar [note: 'Priority level (emergency, urgent, routine, low).']
  safety_requirements varchar [note: 'Safety requirements for the service call.']
  scheduled_arrival_end_datetime timestamp [note: 'End of the scheduled arrival window.']
  scheduled_arrival_start_datetime timestamp [note: 'Start of the scheduled arrival window.']
  service_address_line1 varchar [note: 'First line of the service address.']
  service_address_line2 varchar [note: 'Second line of the service address.']
  service_city varchar [note: 'City of the service location.']
  service_latitude decimal(10,7) [note: 'GPS latitude of the service location.']
  service_longitude decimal(10,7) [note: 'GPS longitude of the service location.']
  service_postal_code varchar [note: 'Postal code of the service location.']
  service_state varchar [note: 'State of the service location.']
  service_territory_code varchar [note: 'Service territory code.']
  sla_actual_response_minutes varchar [note: 'Actual response time in minutes.']
  sla_compliance_flag boolean [note: 'Indicates if the SLA was met.']
  sla_target_response_minutes varchar [note: 'Target response time per SLA in minutes.']
  technician_notes varchar [note: 'Notes from the field technician.']

  Note: 'Field service dispatch records assigning technicians and crews to customer service calls, meter work, main breaks, valve operations, and other field activities with scheduling, routing, and SLA tracking.'
}

Table workforce.labor_relations_case {
  labor_relations_case_id varchar [pk, note: 'Unique identifier for the labor relations case.']
  employee_id varchar [note: 'FK to the employee involved in the case.']
  arbitration_date date [note: 'Date of arbitration hearing if applicable.']
  arbitration_outcome varchar [note: 'Outcome of arbitration (sustained, denied, settled).']
  arbitration_required boolean
  arbitration_required_flag boolean
  arbitrator_name varchar
  case_category varchar [note: 'Category of the case (grievance, disciplinary, arbitration, ULP).']
  case_date date
  case_description varchar [note: 'Detailed description of the case.']
  case_number varchar [note: 'Unique case tracking number.']
  case_priority varchar [note: 'Priority level of the case.']
  case_status varchar [note: 'Current status (open, under review, hearing scheduled, closed).']
  case_type varchar [note: 'Type of labor relations case.']
  closed_date date [note: 'Date the case was closed.']
  contract_article_reference varchar [note: 'Reference to the collective bargaining agreement article.']
  corrective_action_taken varchar [note: 'Corrective action taken as a result of the case.']
  created_timestamp timestamp [note: 'Timestamp when the case was created.']
  department varchar [note: 'Department involved in the case.']
  filed_date date [note: 'Date the case was filed.']
  filing_date date
  financial_impact_amount decimal(18,2) [note: 'Financial impact or settlement amount.']
  grievance_description varchar
  grievance_level varchar
  grievance_step varchar [note: 'Current step in the grievance process.']
  hearing_date date [note: 'Date of the hearing.']
  management_representative varchar [note: 'Name of the management representative.']
  modified_timestamp timestamp [note: 'Timestamp when the case was last modified.']
  notes varchar [note: 'Additional case notes.']
  resolution_date date [note: 'Date the case was resolved.']
  resolution_description varchar [note: 'Description of the resolution.']
  resolution_type varchar
  response_due_date date
  settlement_amount decimal(18,2) [note: 'Settlement amount if applicable.']
  union_local varchar [note: 'Union local involved in the case.']
  union_name varchar
  union_representative varchar [note: 'Name of the union representative.']
  updated_timestamp timestamp

  Note: 'Labor relations cases including grievances, disciplinary actions, arbitrations, unfair labor practice charges, and contract disputes between the utility and employee unions or individual employees.'
}

Table workforce.shift_schedule {
  shift_schedule_id varchar [pk, note: 'Unique identifier for the shift schedule.']
  previous_shift_schedule_id varchar [note: 'FK to the previous version of this shift schedule.']
  break_duration_minutes varchar [note: 'Duration of breaks in minutes.']
  effective_from date [note: 'Date the schedule becomes effective.']
  effective_until date [note: 'Date the schedule expires.']
  is_paid_shift boolean [note: 'Indicates if this is a paid shift.']
  labor_category varchar [note: 'Labor category for the shift.']
  max_employees varchar [note: 'Maximum number of employees on this shift.']
  min_employees varchar [note: 'Minimum number of employees required.']
  notes varchar [note: 'Additional notes about the schedule.']
  osha_compliant boolean [note: 'Indicates if the schedule is OSHA compliant.']
  pay_rate_per_hour decimal(10,2) [note: 'Hourly pay rate for this shift.']
  record_audit_created timestamp [note: 'Audit timestamp when the record was created.']
  record_audit_updated timestamp [note: 'Audit timestamp when the record was last updated.']
  schedule_code varchar [note: 'Unique code for the shift schedule.']
  schedule_name varchar [note: 'Name of the shift schedule.']
  schedule_type varchar [note: 'Type of schedule (fixed, rotating, on-call, split).']
  shift_duration_minutes varchar [note: 'Duration of the shift in minutes.']
  shift_end_time timestamp [note: 'Scheduled end time of the shift.']
  shift_group varchar [note: 'Group designation for the shift.']
  shift_location varchar [note: 'Location where the shift is worked.']
  shift_pattern_code varchar [note: 'Code for the shift rotation pattern.']
  shift_schedule_description varchar [note: 'Description of the shift schedule.']
  shift_schedule_status varchar [note: 'Current status of the schedule (active, inactive, draft).']
  shift_start_time timestamp [note: 'Scheduled start time of the shift.']
  timezone varchar [note: 'Timezone for the shift times.']
  updated_by varchar [note: 'User who last updated the schedule.']
  work_day varchar [note: 'Day of the week for this shift.']
  created_by varchar [note: 'User who created the schedule.']

  Note: 'Shift schedule definitions for water utility operations including treatment plant shifts, field crew schedules, on-call rotations, and emergency response coverage patterns.'
}

Table workforce.swap_request {
  swap_request_id varchar [pk, note: 'Unique identifier for the swap request.']
  approver_employee_id varchar [note: 'FK to the employee who approves the swap.']
  location_id varchar [note: 'FK to the work location for the swap.']
  original_swap_request_id varchar [note: 'FK to the original swap request if this is a counter-swap.']
  swap_employee_id varchar [note: 'FK to the employee requesting the swap.']
  target_employee_id varchar [note: 'FK to the employee being asked to swap.']
  approval_timestamp timestamp [note: 'Timestamp when the swap was approved.']
  created_timestamp timestamp [note: 'Timestamp when the request was created.']
  effective_date date [note: 'Date the swap takes effect.']
  hours_swapped decimal(5,2) [note: 'Number of hours being swapped.']
  notes varchar [note: 'Additional notes about the swap.']
  overtime_flag boolean [note: 'Indicates if the swap results in overtime.']
  reason_code varchar [note: 'Code for the reason for the swap.']
  reason_description varchar [note: 'Description of the reason for the swap.']
  request_number varchar [note: 'Unique request tracking number.']
  request_timestamp timestamp [note: 'Timestamp when the request was made.']
  shift_end_time timestamp [note: 'End time of the shift being swapped.']
  shift_start_time timestamp [note: 'Start time of the shift being swapped.']
  swap_request_status varchar [note: 'Status of the swap request (pending, approved, denied, cancelled).']
  swap_type varchar [note: 'Type of swap (full shift, partial, on-call).']
  updated_timestamp timestamp [note: 'Timestamp when the request was last updated.']

  Note: 'Shift swap requests between employees allowing operators and field staff to exchange scheduled shifts with approval workflows and overtime impact assessment.'
}

Table supply.vendor {
  vendor_id varchar [pk, note: 'Unique surrogate key for the vendor record.']
  address_line1 varchar [note: 'Primary street address of the vendor.']
  address_line2 varchar [note: 'Secondary address line (suite, unit, etc.).']
  approved_by varchar [note: 'Name of the person who approved the vendor.']
  approved_date date [note: 'Date the vendor was approved for use.']
  city varchar [note: 'City of the vendor address.']
  classification varchar [note: 'Classification category (e.g., chemical supplier, contractor, consultant).']
  country_code varchar [note: 'ISO country code of the vendor address.']
  created_timestamp timestamp [note: 'Timestamp when the vendor record was created.']
  currency_code varchar [note: 'Default transaction currency for the vendor.']
  diversity_certification varchar [note: 'Diversity certification type held by the vendor.']
  duns_number varchar [note: 'Dun & Bradstreet unique identifier.']
  email_address varchar [note: 'Primary email address for the vendor organization.']
  fax_number varchar [note: 'Fax number for the vendor.']
  insurance_certificate_on_file_flag boolean [note: 'Indicates whether a current insurance certificate is on file.']
  insurance_expiration_date date [note: 'Expiration date of the vendor insurance certificate.']
  last_purchase_date date [note: 'Date of the most recent purchase from this vendor.']
  minority_owned_flag boolean [note: 'Indicates if the vendor is minority-owned.']
  modified_timestamp timestamp [note: 'Timestamp of the last modification to the vendor record.']
  name_short varchar [note: 'Abbreviated name for the vendor.']
  notes varchar [note: 'Free-text notes about the vendor.']
  payment_method varchar [note: 'Preferred payment method (check, ACH, wire).']
  payment_terms varchar [note: 'Standard payment terms (e.g., Net 30, Net 45).']
  performance_rating varchar [note: 'Current overall performance rating of the vendor.']
  phone_number varchar [note: 'Primary phone number for the vendor.']
  postal_code varchar [note: 'Postal/ZIP code of the vendor address.']
  primary_contact_email varchar [note: 'Email of the primary contact person at the vendor.']
  primary_contact_name varchar [note: 'Name of the primary contact person at the vendor.']
  primary_contact_phone varchar [note: 'Phone number of the primary contact person.']
  primary_contact_title varchar [note: 'Job title of the primary contact person.']
  small_business_flag boolean [note: 'Indicates if the vendor qualifies as a small business.']
  state_province varchar [note: 'State or province of the vendor address.']
  tax_identifier varchar [note: 'Federal tax identification number (EIN/TIN).']
  vendor_name varchar [note: 'Full legal name of the vendor.']
  vendor_number varchar [note: 'Business-assigned vendor number.']
  vendor_status varchar [note: 'Current status (active, inactive, suspended, blocked).']
  vendor_type varchar [note: 'Type of vendor (supplier, contractor, consultant, utility).']
  w9_on_file_flag boolean [note: 'Indicates whether a W-9 form is on file.']
  website_url varchar [note: 'Vendor website URL.']
  woman_owned_flag boolean [note: 'Indicates if the vendor is woman-owned.']

  Note: 'Master record for suppliers and service providers engaged by the utility for materials, chemicals, equipment, and professional services.'
}

Table supply.material_master {
  material_master_id varchar [pk, note: 'Unique surrogate key for the material master record.']
  material_facility_id varchar [note: 'Primary facility associated with this material.']
  material_wtp_facility_id varchar [note: 'Water treatment plant facility using this material.']
  vendor_id varchar [note: 'Preferred vendor for this material.']
  abc_indicator varchar [note: 'ABC classification for inventory prioritization.']
  base_unit_of_measure varchar [note: 'Base unit of measure for the material.']
  batch_managed_flag boolean [note: 'Indicates if the material is managed in batches.']
  cas_number varchar [note: 'Chemical Abstracts Service registry number.']
  created_date date [note: 'Date the material master was created.']
  critical_spare_flag boolean [note: 'Indicates if this is a critical spare part.']
  discontinued_date date [note: 'Date the material was discontinued.']
  hazardous_material_flag boolean [note: 'Indicates if the material is classified as hazardous.']
  hazmat_class varchar [note: 'DOT hazardous material classification.']
  issue_unit_of_measure varchar [note: 'Unit of measure used when issuing material.']
  last_modified_date date [note: 'Date of last modification.']
  lead_time_days varchar [note: 'Standard procurement lead time in days.']
  manufacturer_name varchar [note: 'Name of the manufacturer.']
  manufacturer_part_number varchar [note: 'Manufacturer part number.']
  material_description varchar [note: 'Full description of the material.']
  material_group varchar [note: 'Grouping category for the material.']
  material_number varchar [note: 'Business-assigned material number.']
  material_status varchar [note: 'Current status (active, obsolete, discontinued).']
  material_type varchar [note: 'Type classification (chemical, spare part, consumable, equipment).']
  maximum_stock_quantity decimal(15,3) [note: 'Maximum stock level for the material.']
  minimum_remaining_shelf_life_days varchar [note: 'Minimum remaining shelf life required at receipt.']
  moving_average_price decimal(15,2) [note: 'Current moving average price per unit.']
  notes varchar [note: 'Free-text notes about the material.']
  price_unit varchar [note: 'Number of units the price refers to.']
  procurement_type varchar [note: 'Procurement type (external, internal, both).']
  purchase_unit_of_measure varchar [note: 'Unit of measure used for purchasing.']
  reorder_point decimal(15,3) [note: 'Stock level that triggers reorder.']
  safety_stock_quantity decimal(15,3) [note: 'Minimum safety stock quantity.']
  serialized_flag boolean [note: 'Indicates if the material is serialized.']
  shelf_life_days varchar [note: 'Total shelf life in days.']
  short_description varchar [note: 'Short description of the material.']
  standard_price decimal(15,2) [note: 'Standard price per unit.']
  storage_condition varchar [note: 'Required storage conditions.']
  storage_location_code varchar [note: 'Default storage location code.']
  un_number varchar [note: 'United Nations hazmat identification number.']
  valuation_class varchar [note: 'Valuation class for accounting purposes.']

  Note: 'Central catalog of all materials, chemicals, spare parts, and consumables procured and stocked by the utility.'
}

Table supply.purchase_requisition {
  purchase_requisition_id varchar [pk, note: 'Unique surrogate key.']
  approver_employee_id varchar [note: 'Employee who approved the requisition.']
  cip_project_id varchar [note: 'Associated capital improvement project.']
  cost_center_id varchar [note: 'Cost center to be charged.']
  finance_budget_id varchar [note: 'Budget line funding this requisition.']
  fund_id varchar [note: 'Fund to be charged.']
  general_ledger_id varchar [note: 'GL account for the requisition.']
  material_master_id varchar [note: 'Material being requisitioned.']
  primary_purchase_requisitioner_employee_id varchar [note: 'Employee who created the requisition.']
  account_assignment_category varchar [note: 'Account assignment category code.']
  approval_date date [note: 'Date the requisition was approved.']
  asset_number varchar [note: 'Fixed asset number if capital purchase.']
  contract_number varchar [note: 'Reference contract number.']
  created_timestamp timestamp [note: 'Timestamp when the requisition was created.']
  currency_code varchar [note: 'Currency for the requisition.']
  estimated_total_value decimal(15,2) [note: 'Estimated total value of the requisition.']
  estimated_unit_price decimal(15,2) [note: 'Estimated price per unit.']
  last_modified_timestamp timestamp [note: 'Timestamp of last modification.']
  notes varchar [note: 'Free-text notes.']
  priority_code varchar [note: 'Priority level of the requisition.']
  purchase_order_number varchar [note: 'Resulting PO number once converted.']
  purchasing_group varchar [note: 'Purchasing group responsible.']
  purchasing_organization varchar [note: 'Purchasing organization code.']
  quantity_requested decimal(15,3) [note: 'Quantity of material requested.']
  rejection_reason varchar [note: 'Reason for rejection if applicable.']
  requesting_plant_code varchar [note: 'Plant code of the requesting location.']
  requesting_storage_location varchar [note: 'Storage location requesting the material.']
  required_delivery_date date [note: 'Date by which delivery is required.']
  requisition_date date [note: 'Date the requisition was submitted.']
  requisition_number varchar [note: 'Business-assigned requisition number.']
  requisition_status varchar [note: 'Current status (draft, pending, approved, rejected, converted).']
  requisition_type varchar [note: 'Type of requisition (standard, blanket, emergency).']
  requisitioner_name varchar [note: 'Name of the person who created the requisition.']
  source_system_code varchar [note: 'Source system identifier.']
  unit_of_measure varchar [note: 'Unit of measure for the requested quantity.']
  vendor_code varchar [note: 'Suggested vendor code.']
  work_order_number varchar [note: 'Associated work order number.']

  Note: 'Internal request to procure materials or services, initiating the procurement workflow.'
}

Table supply.purchase_order {
  purchase_order_id varchar [pk, note: 'Unique surrogate key.']
  cip_project_id varchar [note: 'Associated capital improvement project.']
  cost_center_id varchar [note: 'Cost center charged.']
  finance_budget_id varchar [note: 'Budget funding this PO.']
  fund_id varchar [note: 'Fund charged.']
  general_ledger_id varchar [note: 'GL account.']
  procurement_category_id varchar [note: 'Procurement category.']
  procurement_contract_id varchar [note: 'Associated contract.']
  purchase_requisition_id varchar [note: 'Originating requisition.']
  ship_to_warehouse_location_id varchar [note: 'Delivery warehouse location.']
  vendor_id varchar [note: 'Vendor fulfilling the order.']
  approval_date date [note: 'Date the PO was approved.']
  approval_status varchar [note: 'Approval workflow status.']
  approved_by varchar [note: 'Name of approver.']
  buyer_email varchar [note: 'Email of the buyer.']
  buyer_name varchar [note: 'Name of the buyer.']
  buyer_phone varchar [note: 'Phone of the buyer.']
  created_timestamp timestamp [note: 'Timestamp when PO was created.']
  currency_code varchar [note: 'Transaction currency.']
  delivery_address_line1 varchar [note: 'Delivery address line 1.']
  delivery_address_line2 varchar [note: 'Delivery address line 2.']
  delivery_city varchar [note: 'Delivery city.']
  delivery_country_code varchar [note: 'Delivery country code.']
  delivery_postal_code varchar [note: 'Delivery postal code.']
  delivery_state varchar [note: 'Delivery state.']
  freight_amount decimal(18,2) [note: 'Freight charges.']
  incoterms varchar [note: 'International commercial terms.']
  is_capital_purchase boolean [note: 'Indicates if this is a capital purchase.']
  last_modified_timestamp timestamp [note: 'Timestamp of last modification.']
  notes varchar [note: 'Free-text notes.']
  payment_terms varchar [note: 'Payment terms.']
  po_date date [note: 'Date the PO was issued.']
  po_number varchar [note: 'Business-assigned PO number.']
  po_status varchar [note: 'Current PO status.']
  po_type varchar [note: 'Type of purchase order.']
  promised_delivery_date date [note: 'Vendor-promised delivery date.']
  requested_delivery_date date [note: 'Requested delivery date.']
  requestor_name varchar [note: 'Name of the requestor.']
  tax_amount decimal(18,2) [note: 'Tax amount.']
  total_amount decimal(18,2) [note: 'Total PO amount before tax.']
  total_amount_with_tax decimal(18,2) [note: 'Total PO amount including tax.']
  vendor_site_code varchar [note: 'Vendor site code.']
  wbs_element varchar [note: 'Work breakdown structure element.']

  Note: 'Formal commitment to a vendor for the purchase of materials or services at agreed terms.'
}

Table supply.po_line_item {
  po_line_item_id varchar [pk, note: 'Unique surrogate key.']
  cost_center_id varchar [note: 'Cost center.']
  fund_id varchar [note: 'Fund.']
  general_ledger_id varchar [note: 'GL account.']
  po_material_master_id varchar [note: 'Material ordered.']
  primary_po_material_master_id varchar [note: 'Primary material reference.']
  purchase_order_id varchar [note: 'Parent purchase order.']
  purchase_requisition_id varchar [note: 'Originating requisition.']
  account_assignment_category varchar [note: 'Account assignment category.']
  asset_number varchar [note: 'Fixed asset number.']
  confirmation_control_key varchar [note: 'Confirmation control key.']
  created_timestamp timestamp [note: 'Creation timestamp.']
  currency_code varchar [note: 'Line item currency.']
  deletion_indicator boolean [note: 'Indicates if line is marked for deletion.']
  delivery_date date [note: 'Expected delivery date.']
  delivery_status varchar [note: 'Delivery status.']
  goods_receipt_indicator boolean [note: 'Indicates if GR is required.']
  goods_receipt_quantity decimal(15,3) [note: 'Quantity received.']
  invoice_quantity decimal(15,3) [note: 'Quantity invoiced.']
  invoice_receipt_indicator boolean [note: 'Indicates if invoice verification is required.']
  item_category varchar [note: 'Line item category.']
  last_modified_timestamp timestamp [note: 'Last modification timestamp.']
  line_number varchar [note: 'Sequential line number on the PO.']
  manufacturer_part_number varchar [note: 'Manufacturer part number.']
  material_group varchar [note: 'Material group.']
  material_number varchar [note: 'Material number.']
  net_order_value decimal(15,2) [note: 'Net value of the line.']
  net_price decimal(15,2) [note: 'Net price per unit.']
  over_delivery_tolerance_percent decimal(5,2) [note: 'Over-delivery tolerance percentage.']
  plant_code varchar [note: 'Receiving plant code.']
  price_unit varchar [note: 'Price unit quantity.']
  purchase_requisition_item varchar [note: 'Requisition item number.']
  purchasing_group varchar [note: 'Purchasing group.']
  quantity_ordered decimal(15,3) [note: 'Quantity ordered.']
  requisitioner_name varchar [note: 'Name of requisitioner.']
  short_text varchar [note: 'Short description of the line item.']
  storage_location varchar [note: 'Storage location.']
  tax_code varchar [note: 'Tax code.']
  under_delivery_tolerance_percent decimal(5,2) [note: 'Under-delivery tolerance percentage.']
  unit_of_measure varchar [note: 'Unit of measure.']
  vendor_material_number varchar [note: 'Vendor material number.']
  wbs_element varchar [note: 'WBS element.']

  Note: 'Individual line item on a purchase order specifying material, quantity, price, and delivery details.'
}

Table supply.goods_receipt {
  goods_receipt_id varchar [pk, note: 'Unique surrogate key.']
  facility_id varchar [note: 'Receiving facility.']
  general_ledger_id varchar [note: 'GL account.']
  goods_employee_id varchar [note: 'Employee who processed the receipt.']
  goods_material_master_id varchar [note: 'Material received.']
  goods_material_material_master_id varchar [note: 'Alternate material reference.']
  po_line_item_id varchar [note: 'PO line item being received against.']
  purchase_order_id varchar [note: 'Purchase order.']
  receiving_personnel_employee_id varchar [note: 'Receiving personnel employee reference.']
  vendor_id varchar [note: 'Vendor who shipped.']
  warehouse_location_id varchar [note: 'Receiving warehouse.']
  batch_number varchar [note: 'Batch number of received material.']
  created_by_user varchar [note: 'User who created the GR.']
  created_timestamp timestamp [note: 'Creation timestamp.']
  currency_code varchar [note: 'Currency.']
  delivery_condition varchar [note: 'Condition of delivery.']
  delivery_note_number varchar [note: 'Vendor delivery note number.']
  delivery_notes varchar [note: 'Notes about the delivery.']
  gr_document_date date [note: 'Document date.']
  gr_document_number varchar [note: 'Goods receipt document number.']
  gr_posting_date date [note: 'Posting date.']
  gr_status varchar [note: 'Status of the goods receipt.']
  inspection_lot_number varchar [note: 'Quality inspection lot number.']
  invoice_verification_date date [note: 'Date invoice was verified against GR.']
  last_modified_by_user varchar [note: 'User who last modified.']
  last_modified_timestamp timestamp [note: 'Last modification timestamp.']
  material_document_year varchar [note: 'Fiscal year of material document.']
  movement_type varchar [note: 'Inventory movement type code.']
  quality_inspection_required_flag boolean [note: 'Indicates if QC inspection is required.']
  received_quantity decimal(15,3) [note: 'Quantity received.']
  receiving_personnel_name varchar [note: 'Name of receiving personnel.']
  reversal_date date [note: 'Date of reversal if applicable.']
  reversal_document_number varchar [note: 'Reversal document number.']
  reversal_indicator boolean [note: 'Indicates if this GR has been reversed.']
  reversal_reason_code varchar [note: 'Reason code for reversal.']
  special_stock_indicator varchar [note: 'Special stock indicator.']
  stock_type varchar [note: 'Type of stock (unrestricted, blocked, QI).']
  three_way_match_status varchar [note: 'Status of PO/GR/Invoice three-way match.']
  total_amount decimal(15,2) [note: 'Total monetary value of goods received.']
  unit_of_measure varchar [note: 'Unit of measure.']
  unit_price decimal(15,2) [note: 'Unit price at receipt.']
  unloading_point varchar [note: 'Physical unloading point.']
  valuation_type varchar [note: 'Valuation type.']
  vendor_batch_number varchar [note: 'Vendor batch number.']

  Note: 'Record of physical receipt of materials at a warehouse or facility against a purchase order.'
}

Table supply.inventory_stock {
  inventory_stock_id varchar [pk, note: 'Unique surrogate key.']
  inventory_facility_id varchar [note: 'Facility.']
