  Note: 'General ledger account master for chart of accounts, fund accounting, and financial reporting.'
}

Table finance.fund {
  fund_id varchar [pk, note: 'Primary key']
  budget_controlled_flag boolean [note: 'Whether fund requires budget']
  created_timestamp timestamp [note: 'Record creation timestamp']
  effective_end_date date [note: 'Date fund was closed']
  effective_start_date date [note: 'Date fund became effective']
  encumbrance_flag boolean [note: 'Whether fund supports encumbrances']
  fund_category varchar [note: 'General, Special Revenue, Capital Projects, Debt Service, Enterprise, Internal Service']
  fund_code varchar [note: 'Fund code']
  fund_name varchar [note: 'Fund name']
  fund_type varchar [note: 'Governmental, Proprietary, Fiduciary']
  gasb_54_classification varchar [note: 'Nonspendable, Restricted, Committed, Assigned, Unassigned']
  is_active boolean [note: 'Whether fund is active']
  legal_authority varchar [note: 'Legal authority establishing fund']
  restricted_purpose varchar [note: 'Purpose for which fund is restricted']
  updated_timestamp timestamp [note: 'Record update timestamp']

  Note: 'Fund master for governmental fund accounting per GASB 34.'
