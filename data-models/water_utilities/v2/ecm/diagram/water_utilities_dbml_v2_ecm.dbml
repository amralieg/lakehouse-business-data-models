  wire_run_length_ft decimal(8,2) [note: 'Wire run length in feet for remote read']
  work_order_number varchar [note: 'Associated work order number']

  Note: 'Tracks the physical installation of a meter at a service location, linking a specific meter device to a service address and customer account. Records installation date, installer ID, work order reference, meter position (pit, vault, curb box), setter size, service line material, lock/seal number, initial register reading at installation, and removal date when replaced. Maintains the full history of which meter served which location over time, supporting NRW analysis and billing continuity.'
}

Table metering.ami_endpoint {
  ami_endpoint_id varchar [pk, note: 'Unique identifier for the AMI/AMR communication endpoint device. Primary key for the endpoint registry.']
  ami_network_collector_id varchar [note: 'Reference to the FlexNet collector or gateway device that receives transmissions from this endpoint. Part of the AMI network infrastructure.']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: AMI endpoint deployments are capital projects requiring tracking for warranty management, project performance metrics, capital cost allocation, and grant reporting. Utilities must trace each endpoint ']
  dma_id varchar [note: 'Reference to the District Metered Area that this endpoint belongs to. Used for water loss analysis and pressure zone management.']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: AMI endpoints are procured materials with manufacturer part numbers, tracked in inventory for deployment, warranty management, and spare parts planning. Procurement orders endpoints by material number']
  metering_meter_id varchar [note: 'Reference to the physical water meter that this AMI endpoint is attached to. An endpoint may be replaced independently of the meter.']
  registry_id varchar [note: 'Foreign key linking to asset.asset_registry. Business justification: AMI endpoints are capital assets with acquisition cost, useful life, warranty, and cybersecurity compliance requirements. Utilities track these separately from meters for technology refresh cycles, FC']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: AMI deployment may be mandated by regulatory requirements for conservation tracking, demand management, and drought response capabilities. Real process: complying with state mandates for AMI deploymen']
  battery_expected_life_years decimal(4,1) [note: 'Manufacturer-specified expected battery life in years under normal operating conditions. Typically 15-20 years for AMI endpoints.']
  battery_install_date date [note: 'Date when the battery was installed or last replaced in the endpoint device. Used to calculate expected battery life remaining.']
  battery_level_percent decimal(5,2) [note: 'Current battery charge level as a percentage. Critical for battery-powered endpoints to schedule replacement before failure.']
  commissioning_date date [note: 'Date when the endpoint was successfully commissioned and began transmitting data to the AMI system. May differ from installation date.']
  communication_frequency_minutes varchar [note: 'Configured interval in minutes between endpoint transmissions. Typical values: 15, 30, 60 minutes for hourly reads; 1440 for daily reads.']
  communication_protocol varchar [note: 'Network communication protocol used by the endpoint. RF (Radio Frequency) for FlexNet, Cellular for 4G/5G, LoRaWAN for low-power wide-area, NB-IoT for narrowband cellular.']
  created_timestamp timestamp [note: 'Timestamp when this endpoint record was first created in the system. Used for audit trail and data lineage.']
  data_retention_days varchar [note: 'Number of days of interval consumption data stored locally on the endpoint device before being overwritten. Typically 35-45 days.']
  decommission_date date [note: 'Date when the endpoint was removed from service or deactivated. Null for active endpoints.']
  decommission_reason varchar [note: 'Reason for endpoint decommissioning (e.g., meter replacement, device failure, service disconnection, upgrade to new technology).']
  encryption_algorithm varchar [note: 'Cryptographic algorithm used to secure communications between endpoint and collector. AES-128 or AES-256 for encrypted devices.']
  encryption_key_version varchar [note: 'Version identifier for the encryption key currently provisioned on the endpoint. Used for secure communication and key rotation management.']
  endpoint_serial_number varchar [note: 'Manufacturer-assigned unique serial number for the AMI/AMR endpoint device. Used for warranty tracking and device identification.']
  endpoint_type varchar [note: 'Type of AMI/AMR communication device. ERT (Encoder Receiver Transmitter) for drive-by reading, MXU (Meter Transmit Unit) for fixed network, iPerl for integrated smart meter, Orion for cellular endpoint, Ally for water meter module.']
  firmware_version varchar [note: 'Current firmware version installed on the endpoint device. Critical for security patches and feature updates.']
  geographic_latitude decimal(10,7) [note: 'Latitude coordinate of the endpoint installation location in decimal degrees. Used for GIS mapping and network planning.']
  geographic_longitude decimal(10,7) [note: 'Longitude coordinate of the endpoint installation location in decimal degrees. Used for GIS mapping and network planning.']
  installation_date date [note: 'Date when the AMI endpoint was installed and activated in the field. Used for warranty tracking and lifecycle management.']
  installation_technician varchar [note: 'Name or identifier of the technician who installed the endpoint device. Used for quality tracking and accountability.']
  ip_address varchar [note: 'IP address assigned to the endpoint device for cellular or IP-based communication protocols. Null for RF-only devices.']
  last_communication_timestamp timestamp [note: 'Timestamp of the most recent successful communication received from this endpoint. Used to identify non-communicating devices.']
  last_firmware_update_date date [note: 'Date when the endpoint firmware was last updated. Critical for security patch tracking and compliance.']
  last_modified_timestamp timestamp [note: 'Timestamp when this endpoint record was last updated. Used for change tracking and audit trail.']
  leak_alert_threshold_gpm decimal(8,3) [note: 'Continuous flow threshold in gallons per minute that triggers a leak alert. Typically 0.01 to 0.5 GPM for residential meters.']
  leak_detection_enabled_flag boolean [note: 'Indicates whether continuous leak detection monitoring is enabled on this endpoint. True if enabled, False if disabled.']
  mac_address varchar [note: 'Unique hardware address assigned to the endpoint network interface. Used for device authentication and network routing.']
  network_node_code varchar [note: 'Identifier for the network node or collector that this endpoint communicates with in the AMI network topology.']
  notes varchar [note: 'Free-form text field for additional notes, special instructions, or historical information about the endpoint device.']
  operational_status decimal(18,6) [note: 'Current operational status of the endpoint device. Active indicates normal operation, Failed indicates communication or device failure.']
  read_interval_seconds varchar [note: 'Interval in seconds at which the endpoint records consumption data internally. Typical values: 900 (15 min), 3600 (hourly), 86400 (daily).']
  reverse_flow_detected_flag boolean [note: 'Indicates whether reverse flow has been detected by the endpoint. True if reverse flow detected, False otherwise. May indicate backflow or meter installation error.']
  signal_quality_indicator varchar [note: 'Qualitative assessment of communication signal quality. Derived from signal strength and packet success rate.']
  signal_strength_dbm decimal(5,2) [note: 'Most recent radio signal strength measurement in dBm. Indicates communication quality between endpoint and collector. Typical range -110 to -50 dBm.']
  tamper_detected_timestamp timestamp [note: 'Timestamp when the most recent tamper event was detected by the endpoint. Null if no tamper has been detected.']
  tamper_status varchar [note: 'Current tamper detection status reported by the endpoint. Alerts to potential theft, fraud, or unauthorized access.']
  warranty_expiration_date date [note: 'Date when the manufacturer warranty for the endpoint device expires. Used for replacement planning and cost recovery.']

  Note: 'Master record for each AMI/AMR communication endpoint device (encoder/receiver/transmitter unit) associated with a meter, and the fixed-network collector infrastructure (base stations, repeaters, mobile collectors) that enables automated reading across the service territory. Captures endpoint serial number, device type, firmware version, network node assignment, signal strength, battery level, last communication timestamp, encryption key version, tamper status, collector assignment, collector location, coverage area, and backhaul connection type. Distinct from the meter itself — one meter may have its endpoint replaced independently.'
}

Table metering.read {
  read_id varchar [pk, note: 'Primary key for read']
  ami_endpoint_id varchar [note: 'Foreign key linking to metering.ami_endpoint. Business justification: For AMI/AMR reads, the read is captured by a specific AMI endpoint device. This links the read event to the communication endpoint that transmitted the data. Manual reads would have NULL ami_endpoint_']
  employee_id varchar [note: 'ID of meter reader']
  meter_installation_id varchar [note: 'Foreign key linking to metering.installation. Business justification: A meter read is captured for a specific meter installation (a meter deployed at a location), not just an abstract meter device. Reads are tied to the installation context (location, service point). Th']
  read_route_id varchar [note: 'Foreign key linking to metering.read_route. Business justification: Meter reads are collected along defined read routes (for manual, walk-by, or drive-by reading operations). Each read should reference which route it was collected on for operational tracking and route']
  reader_employee_id varchar [note: 'Employee who performed the read']
  average_daily_consumption decimal(12,4) [note: 'Average daily consumption']
  average_daily_usage decimal(12,4) [note: 'Average daily usage for the period']
  battery_voltage decimal(4,2) [note: 'Endpoint battery voltage']
  billed_date date [note: 'Date read was billed']
  billed_flag boolean [note: 'Whether read has been billed']
  billing_cycle_code varchar
  billing_period varchar [note: 'Billing period identifier']
  billing_period_end date [note: 'End of billing period for this read']
  billing_period_end_date date [note: 'End of billing period for this read']
  billing_period_start date [note: 'Start of billing period for this read']
  billing_period_start_date date [note: 'Start of billing period for this read']
  consumption double
  consumption_unit varchar [note: 'Unit of consumption (gallons, cubic feet, liters)']
  consumption_units varchar [note: 'Units of consumption']
  consumption_value decimal(14,2) [note: 'Calculated consumption since last read']
  consumption_variance_pct decimal(8,2) [note: 'Variance from historical average percent']
  continuous_flow_days varchar [note: 'Number of continuous flow days']
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp
  current_reading decimal(14,2) [note: 'Current meter reading']
  daily_average decimal(12,4) [note: 'Daily average consumption']
  daily_average_consumption decimal(12,2) [note: 'Average daily consumption']
  data_quality_flag boolean
  days_in_period varchar [note: 'Days in read period']
  days_since_last_read varchar [note: 'Number of days since previous read']
  estimated_flag boolean [note: 'Whether read was estimated']
  estimation_method varchar [note: 'Method used for estimation']
  estimation_reason varchar [note: 'Reason for estimation']
  exception_code varchar [note: 'Exception code if any']
  exception_description varchar
  high_low_flag varchar [note: 'Flag indicating abnormally high or low consumption']
  ingestion_timestamp timestamp
  is_billed boolean [note: 'Whether the read has been billed.']
  is_estimated boolean [note: 'Whether the read was estimated.']
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  latitude decimal(10,7) [note: 'Read location latitude']
  leak_flag boolean [note: 'Whether continuous flow indicates a possible leak']
  longitude decimal(11,7) [note: 'Read location longitude']
  method varchar
  no_flow_days varchar [note: 'Number of no-flow days']
  notes varchar [note: 'Read notes']
  previous_read_value decimal(14,2) [note: 'Previous meter read value']
  previous_reading decimal(14,2) [note: 'Previous register reading']
  quality_code varchar
  quality_flag boolean
  read_date date
  read_exception_code varchar [note: 'Exception code if applicable']
  read_status varchar
  read_timestamp timestamp
  read_type varchar
  reader_employee_id_manual varchar [note: 'Manual reader employee identifier']
  reader_notes varchar [note: 'Reader notes']
  record_status varchar
  register_reading decimal(14,2) [note: 'Register reading value']
  reverse_flow_flag boolean [note: 'Whether reverse flow was detected']
  rollover_flag boolean [note: 'Whether register rollover occurred']
  sequence_number varchar [note: 'Sequence number within route']
  signal_strength_dbm decimal(6,2) [note: 'AMI signal strength in dBm']
  source varchar [note: 'read source for read']
  tamper_flag boolean [note: 'Whether tamper was detected']
  unit_of_measure varchar [note: 'Unit of measure.']
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp.']
  validated_flag boolean
  validation_code varchar [note: 'Validation code']
  validation_status varchar [note: 'Validation status']
  validation_timestamp timestamp
  value double
  zero_consumption_flag boolean [note: 'Whether zero consumption']

  Note: 'Individual meter reading record capturing the register value at a specific point in time for a given meter installation. Stores read date and time, read value (gallons or CCF), read type (AMI automated, AMR drive-by, manual field read, estimated), read source system, reader employee ID (for manual reads), read quality flag, exception code, and whether the read was used for billing. The authoritative transactional record for all meter reads feeding the Oracle CC&B billing cycle.'
}

Table metering.interval_consumption {
  interval_consumption_id varchar [pk, note: 'Unique identifier for each interval consumption record. Primary key for the interval consumption data product.']
  ami_endpoint_id varchar [note: 'Unique identifier for the AMI endpoint device that transmitted this interval data. Corresponds to the Sensus FlexNet endpoint serial number or device identifier.']
  ami_network_collector_id varchar [note: 'Identifier for the AMI collector (gateway) that received this interval reading from the endpoint. Used for network topology analysis and troubleshooting.']
  billing_cycle_id varchar [note: 'Reference to the billing cycle during which this interval occurred. Used to aggregate interval data for billing purposes and time-of-use rate calculations.']
  dma_id varchar [note: 'Reference to the District Metered Area where this meter is located. Used for Non-Revenue Water (NRW) analysis, pressure zone management, and distribution network optimization.']
  meter_installation_id varchar [note: 'Reference to the specific meter installation that generated this interval reading. Links to the meter installation registry in the metering domain.']
  revenue_accrual_general_ledger_id varchar [note: 'Foreign key linking to finance.general_ledger. Business justification: AMI interval data enables real-time revenue accrual accounting. Utilities must map interval consumption to GL accounts for unbilled revenue accrual at period-end, supporting accurate financial close p']
  alarm_code varchar [note: 'Code indicating any alarm condition detected during this interval. Examples include leak alarm, burst alarm, backflow alarm, low battery alarm, or communication failure alarm. Empty if no alarm condition exists.']
  battery_voltage decimal(5,2) [note: 'The battery voltage of the AMI endpoint device at the time of this reading, measured in volts. Used to monitor endpoint health and predict battery replacement needs.']
  consumption_volume_gallons decimal(18,3) [note: 'The total volume of water consumed during this interval, measured in gallons. This is the primary consumption metric used for billing, leak detection, and demand analysis.']
  data_quality_indicator varchar [note: 'Indicates the quality and reliability of this interval reading. Valid readings are directly measured; estimated readings are interpolated due to communication gaps; suspect readings show anomalies; missing indicates no data received; tampered indicates potential meter tampering; overflow indicates meter register overflow.']
  estimated_method varchar [note: 'The method used to estimate this interval reading if data was missing or invalid. None indicates actual measured data. Other values indicate the estimation algorithm applied.']
  flow_rate_gpm decimal(12,3) [note: 'The average flow rate during the interval, measured in gallons per minute. Calculated as consumption volume divided by interval duration. Used for leak detection and high-flow alerting.']
  gap_flag boolean [note: 'Boolean flag indicating whether this interval represents a data gap that was filled by estimation or interpolation. True indicates the reading is estimated due to missing data transmission.']
  high_usage_flag boolean [note: 'Boolean flag indicating whether this interval exceeded the high-usage threshold for this meter installation. True indicates consumption significantly above normal patterns, potentially indicating irrigation, filling pools, or abnormal usage.']
  interval_duration_minutes decimal(18,6) [note: 'The length of the consumption interval in minutes. Typically 15, 30, or 60 minutes for AMI systems. Used to normalize consumption rates and identify irregular interval lengths.']
  interval_end_timestamp timestamp [note: 'The precise date and time when the consumption interval ended. Represents the end of the measurement period for this interval reading.']
  interval_start_timestamp timestamp [note: 'The precise date and time when the consumption interval began. Represents the beginning of the measurement period for this interval reading.']
  leak_detection_flag boolean [note: 'Boolean flag indicating whether this interval triggered a potential leak alert based on continuous low-flow patterns. True indicates sustained consumption suggesting a possible leak.']
  notes varchar [note: 'Free-text notes or comments regarding this interval reading. Used to document anomalies, manual adjustments, or special circumstances affecting this reading.']
  pressure_psi decimal(6,2) [note: 'The water pressure at the meter location during this interval, measured in pounds per square inch. Available from advanced AMI endpoints with integrated pressure sensors. Used for distribution network monitoring and pressure zone analysis.']
  processed_timestamp timestamp [note: 'The date and time when this interval reading was processed and loaded into the data warehouse. Used for data pipeline monitoring and audit trails.']
  pulse_increment_gallons decimal(10,6) [note: 'The volume of water represented by each pulse from the meter encoder, measured in gallons. Varies by meter size and type. Used to convert pulse counts to consumption volumes.']
  raw_pulse_count varchar [note: 'The raw cumulative pulse count from the meter encoder at the end of this interval. Each pulse represents a fixed volume increment. Used for data validation and troubleshooting.']
  received_timestamp timestamp [note: 'The date and time when this interval reading was received by the AMI head-end system. Used to calculate transmission latency and identify delayed readings.']
  reverse_flow_flag boolean [note: 'Boolean flag indicating whether reverse flow was detected during this interval. True indicates water flowing backward through the meter, which may indicate backflow, meter installation issues, or tampering.']
  signal_strength_dbm varchar [note: 'The radio signal strength of the AMI endpoint transmission, measured in dBm. Used to assess communication quality and identify endpoints with poor connectivity.']
  tamper_event_code varchar [note: 'Code indicating the type of tamper event detected during this interval, if any. Examples include magnetic interference, tilt detection, removal detection, or reverse flow. Empty if no tamper event detected.']
  temperature_fahrenheit decimal(5,2) [note: 'The ambient temperature at the meter location during this interval, measured in degrees Fahrenheit. Some AMI endpoints include temperature sensors for freeze detection and consumption correlation analysis.']
  transmission_retry_count varchar [note: 'The number of transmission attempts required to successfully deliver this interval reading to the AMI collector. Higher retry counts indicate communication challenges.']
  validation_status varchar [note: 'The current validation status of this interval reading. Pending indicates awaiting validation; validated indicates passed all quality checks; rejected indicates failed validation; under review indicates manual review required.']
  validation_timestamp timestamp [note: 'The date and time when this interval reading was validated or rejected. Used for audit trails and data quality reporting.']
  zero_consumption_flag boolean [note: 'Boolean flag indicating whether zero consumption was recorded during this interval. True indicates no water usage, which may be normal for vacant properties or may indicate meter malfunction.']

  Note: 'High-frequency interval consumption data collected from AMI endpoints, typically at 15-minute or hourly intervals. Stores meter installation reference, interval start and end timestamps, consumption volume (gallons), flow rate (GPM), data quality indicator, gap flag, and raw pulse count. Sourced from the AMI head-end system and time-series data historian. Enables leak detection, high-usage alerting, time-of-use analysis, and demand forecasting at sub-daily granularity.'
}

Table metering.consumption_profile {
  consumption_profile_id varchar [pk, note: 'Unique identifier for the consumption profile record. Primary key for this billing-grade consumption summary.']
  agreement_id varchar [note: 'Foreign key linking to service.service_agreement. Business justification: Consumption profiles drive billing calculations and must link to service agreement to apply correct rate schedule, customer class, tier structure, and contract terms. Essential for revenue cycle opera']
  consumption_employee_id varchar [note: 'User identifier of the system or person who validated this consumption profile. Used for audit trail and quality assurance.']
  consumption_validated_by_user_employee_id varchar [note: 'User identifier of the system or person who validated this consumption profile. Used for audit trail and quality assurance.']
  customer_account_id varchar [note: 'Foreign key linking to customer.customer_account. Business justification: Consumption profiles drive customer billing. Essential for revenue calculation, rate application, tier determination, and customer portal display. Links metered usage to the account responsible for pa']
  meter_installation_id varchar [note: 'Reference to the specific meter installation point for which this consumption profile is calculated. Links to the physical meter deployment at a service address.']
  premise_id varchar [note: 'Foreign key linking to customer.premise. Business justification: Consumption tied to premises for demand forecasting and capacity planning. Essential for infrastructure investment decisions, peak demand analysis by building type, and water use efficiency benchmarki']
  revenue_general_ledger_id varchar [note: 'Foreign key linking to finance.general_ledger. Business justification: Water consumption billing requires GL account mapping for revenue recognition and financial statement preparation. Consumption profiles drive revenue postings to specific GL accounts (water sales reve']
  service_address_id varchar [note: 'Foreign key linking to customer.service_address. Business justification: Consumption occurs at specific service addresses. Required for geographic usage analysis, conservation program targeting, leak correlation with location characteristics, and regulatory reporting by se']
  adjustment_amount_gallons decimal(18,2) [note: 'Volume adjustment in gallons applied to the raw consumption data. May reflect leak adjustments, meter accuracy corrections, or billing dispute resolutions. Zero if no adjustment applied.']
  adjustment_reason varchar [note: 'Free-text explanation of why a consumption adjustment was applied. Null if no adjustment. Used for audit trail and customer communication.']
  average_daily_usage_gpd decimal(18,2) [note: 'Average daily water consumption in gallons per day (GPD) calculated by dividing total consumption by billing period days. Used for trend analysis and customer benchmarking.']
  billing_handoff_timestamp timestamp [note: 'Date and time when this consumption profile was transmitted to Oracle CC&B for invoice generation. Null if not yet handed off to billing.']
  billing_period_days varchar [note: 'Total number of calendar days in the billing period. Used to normalize consumption for comparison across periods of different lengths.']
  billing_period_end_date date [note: 'The last date of the billing period covered by this consumption profile. Defines the end of the consumption measurement window.']
  billing_period_start_date date [note: 'The first date of the billing period covered by this consumption profile. Defines the beginning of the consumption measurement window.']
  consumption_status varchar [note: 'Current validation status of the consumption data. Indicates whether the consumption is based on actual reads, estimates, or has been adjusted. Only validated or final records are used for billing.']
  consumption_tier varchar [note: 'Classification of consumption volume into rate tiers for tiered pricing structures. Determines applicable rate schedule and conservation incentives.']
  consumption_variance_percent decimal(5,2) [note: 'Percentage change in consumption compared to prior period. Positive values indicate increased usage; negative values indicate decreased usage. Used to trigger high-usage alerts.']
  created_timestamp timestamp [note: 'Date and time when this consumption profile record was first created in the system. Used for audit trail and data lineage tracking.']
  customer_class varchar [note: 'Classification of the customer account for rate structure and consumption analysis purposes. Determines applicable rate schedules and regulatory reporting categories.']
  data_quality_score decimal(5,2) [note: 'Composite score (0-100) representing the quality and reliability of the consumption data. Based on read method, completeness of interval data, validation checks passed, and absence of anomalies. Higher scores indicate higher confidence.']
  estimated_read_reason varchar [note: 'Reason code explaining why consumption was estimated rather than based on actual meter read. Null if consumption is based on actual read.']
  high_usage_alert_flag boolean [note: 'Indicates whether consumption exceeded predefined thresholds triggering a high-usage alert. Used for proactive customer outreach and potential billing dispute prevention.']
  interval_data_available_flag boolean [note: 'Indicates whether granular interval consumption data (typically hourly) is available from AMI system for this billing period. True if AMI data exists; false if only aggregated reads are available.']
  last_modified_timestamp timestamp [note: 'Date and time when this consumption profile record was last updated. Used for change tracking and audit trail.']
  leak_detected_flag boolean [note: 'Indicates whether a potential leak was detected during the billing period based on continuous flow patterns or minimum night flow analysis. Triggers customer notification and field investigation.']
  meter_size_inches decimal(5,2) [note: 'Physical diameter of the meter in inches. Determines flow capacity and accuracy range. Common sizes include 0.625, 0.75, 1.0, 1.5, 2.0, 3.0, 4.0, 6.0, 8.0 inches.']
  meter_technology varchar [note: 'Technology type of the meter used for this consumption measurement. Determines data granularity, accuracy, and communication capabilities.']
  minimum_night_flow_gpm decimal(18,4) [note: 'Minimum flow rate in gallons per minute (GPM) observed during overnight hours (typically 2 AM - 4 AM). Used for leak detection and continuous-use identification in AMI systems.']
  notes varchar [note: 'Free-text field for additional comments, special circumstances, or operational notes related to this consumption profile. Used for exception documentation and customer service reference.']
  nrw_contribution_gallons decimal(18,2) [note: 'Estimated volume of consumption that contributes to Non-Revenue Water (NRW) or Unaccounted-for Water (UFW) calculations. Includes unbilled authorized consumption and apparent losses.']
  peak_day_consumption_gallons decimal(18,2) [note: 'Maximum single-day water consumption in gallons during the billing period. Identifies peak demand events and potential high-usage anomalies.']
  peak_day_date date [note: 'The date on which the peak day consumption occurred. Used for correlation with weather events, holidays, or operational anomalies.']
  prior_period_consumption_gallons decimal(18,2) [note: 'Total consumption in gallons from the immediately preceding billing period. Used for period-over-period variance analysis and trend detection.']
  prior_year_consumption_gallons decimal(18,2) [note: 'Total consumption in gallons from the same billing period in the prior year. Used for year-over-year comparison and seasonal trend analysis.']
  read_method varchar [note: 'Method by which the meter reading was obtained. AMI (Advanced Metering Infrastructure) provides interval data; AMR (Automatic Meter Reading) provides periodic reads; manual and self-reads are less frequent.']
  reverse_flow_detected_flag boolean [note: 'Indicates whether reverse flow was detected by the meter during the billing period. May indicate backflow condition, meter installation error, or tampering requiring immediate investigation.']
  seasonal_factor decimal(5,4) [note: 'Multiplier representing expected seasonal variation in consumption for this customer class and service type. Used for forecasting and anomaly detection. 1.0 = average; >1.0 = high season; <1.0 = low season.']
  service_type varchar [note: 'Type of water service provided at this meter installation. Determines applicable quality standards, pricing, and regulatory requirements.']
  total_consumption_ccf decimal(18,2) [note: 'Total water consumption for the billing period measured in CCF (hundred cubic feet). Standard billing unit for many water utilities. 1 CCF = 748 gallons.']
  total_consumption_gallons decimal(18,2) [note: 'Total water consumption for the billing period measured in gallons. Aggregated from validated interval reads or manual meter reads.']
  validation_timestamp timestamp [note: 'Date and time when the consumption profile was validated and approved for billing handoff to Oracle CC&B. Represents the point at which the record became billing-grade.']
  weather_normalized_consumption_gallons decimal(18,2) [note: 'Consumption adjusted for weather variations using heating/cooling degree days or precipitation data. Used for fair year-over-year comparisons and conservation program evaluation.']
  zero_consumption_flag boolean [note: 'Indicates whether zero consumption was recorded for the billing period. May indicate vacant property, meter malfunction, or frozen meter requiring investigation.']

  Note: 'Aggregated daily and monthly consumption summary per meter installation, derived from interval data and validated meter reads. Stores billing period consumption (CCF or gallons), average daily usage (GPD), peak day demand, minimum night flow, consumption tier classification, and comparison to prior period and prior year. Serves as the authoritative consumption record for billing handoff and NRW/UFW analysis. Distinct from raw interval_consumption — this is the validated, billing-grade record.'
}

Table metering.leak_detection_event {
  leak_detection_event_id varchar [pk, note: 'Unique identifier for the leak detection event record. Primary key.']
  billing_adjustment_id varchar [note: 'Reference to the billing adjustment record created for this leak event, if applicable. Links to billing adjustment transaction.']
  customer_account_id varchar [note: 'Foreign key linking to customer.customer_account. Business justification: Leak events require customer notification and may trigger billing adjustments. Essential for customer service outreach, high-bill investigations, assistance program eligibility, and tracking notificat']
  dma_id varchar [note: 'Reference to the District Metered Area where the leak was detected. Used for geographic analysis and NRW reduction program targeting.']
  leak_ami_device_ami_endpoint_id varchar [note: 'Reference to the AMI device (Sensus FlexNet endpoint or similar) that generated the interval data used for leak detection. Links to AMI device registry.']
  leak_ami_endpoint_id varchar [note: 'Reference to the AMI device (Sensus FlexNet endpoint or similar) that generated the interval data used for leak detection. Links to AMI device registry.']
  leak_employee_id varchar [note: 'User identifier of the system user or automated process that created this leak detection event record. Used for audit and accountability.']
  leak_last_modified_by_user_employee_id varchar [note: 'User identifier of the system user who last modified this leak detection event record. Used for audit and accountability.']
  meter_installation_id varchar [note: 'Reference to the meter installation where the leak was detected. Links to the meter installation registry.']
  premise_id varchar [note: 'Foreign key linking to customer.premise. Business justification: Leaks occur at premises and may indicate infrastructure issues. Required for correlating leak frequency with premise characteristics, prioritizing premise-level infrastructure upgrades, and tracking p']
  primary_leak_employee_id varchar [note: 'User identifier of the system user or automated process that created this leak detection event record. Used for audit and accountability.']
  regulatory_correspondence_id varchar [note: 'Foreign key linking to compliance.regulatory_correspondence. Business justification: Significant leak events trigger regulatory notification requirements under water loss control programs and infrastructure compliance mandates. Real process: notifying primacy agencies of major leak ev']
  service_address_id varchar [note: 'Reference to the service address where the leak was detected. Links to customer service location registry.']
  work_order_id varchar [note: 'Reference to the work order created to investigate or repair the detected leak. Links to asset management work order system.']
  alert_severity varchar [note: 'Severity classification of the leak event based on estimated volume, duration, and potential impact. Used to prioritize response and customer outreach.']
  billing_adjustment_eligible_flag boolean [note: 'Boolean indicator whether this leak event qualifies for a customer billing adjustment under utility leak adjustment policy. True indicates eligibility for adjustment consideration.']
  confidence_score decimal(5,2) [note: 'Algorithmic confidence score (0-100) indicating the likelihood that the detected anomaly represents a true leak. Higher scores indicate greater confidence in detection accuracy.']
  continuous_flow_flag boolean [note: 'Boolean indicator that the leak was detected through continuous flow analysis (flow detected 24 hours without interruption). True indicates continuous flow was the detection trigger.']
  created_timestamp timestamp [note: 'Timestamp when this leak detection event record was first created in the system. Used for audit trail and data lineage tracking.']
  customer_notification_date date [note: 'Date when the customer was notified about the detected leak event. Used for tracking notification timeliness and customer service metrics.']
  customer_notified_flag boolean [note: 'Boolean indicator whether the customer has been notified of the detected leak event. True indicates notification has been sent.']
  detection_algorithm_version varchar [note: 'Version identifier of the leak detection algorithm or software that identified this event. Used for algorithm performance tracking and continuous improvement.']
  detection_method varchar [note: 'Method or technique used to identify the leak event. Indicates whether detection was automated (AMI interval analysis, continuous flow flag, minimum night flow anomaly) or manual (acoustic sensor, field inspection, customer report).']
  detection_timestamp timestamp [note: 'Date and time when the leak was first detected by the AMI system or monitoring algorithm. Principal business event timestamp for this event.']
  estimated_leak_volume_gallons_per_day decimal(12,2) [note: 'Estimated daily water loss volume attributed to the detected leak, measured in gallons per day. Calculated from interval consumption data or continuous flow analysis.']
  estimated_total_loss_gallons decimal(12,2) [note: 'Total estimated water loss volume from leak start to resolution, measured in gallons. Calculated as leak volume per day multiplied by duration. Contributes to Non-Revenue Water (NRW) and Unaccounted-for Water (UFW) metrics.']
  flow_threshold_value decimal(10,4) [note: 'The flow rate threshold value (in gallons per minute or GPM) that was exceeded to trigger the leak detection alert. Used for continuous flow and threshold-based detection methods.']
  investigation_notes varchar [note: 'Free-text field for field technician or customer service representative notes regarding leak investigation, customer interaction, or resolution details.']
  last_modified_timestamp timestamp [note: 'Timestamp when this leak detection event record was last updated. Used for audit trail and change tracking.']
  leak_duration_hours decimal(10,2) [note: 'Estimated or measured duration of the leak event from detection timestamp to resolution or current time if unresolved, measured in hours.']
  leak_location_description varchar [note: 'Textual description of the suspected or confirmed leak location (e.g., service line, toilet, irrigation system, water heater). Provides context for leak source and repair scope.']
  leak_status varchar [note: 'Current lifecycle status of the leak detection event. Tracks progression from initial detection through investigation, customer notification, and resolution.']
  leak_type varchar [note: 'Classification of the leak by type or source. Helps categorize leak patterns and target customer education programs. [ENUM-REF-CANDIDATE: service_line|meter|toilet|faucet|irrigation|water_heater|pool|unknown — 8 candidates stripped; promote to reference product]']
  minimum_night_flow_anomaly_flag boolean [note: 'Boolean indicator that the leak was detected through minimum night flow analysis showing abnormal consumption during low-usage hours (typically 2 AM - 4 AM). True indicates MNF anomaly detection.']
  notification_method varchar [note: 'Communication channel used to notify the customer about the leak event. Tracks preferred and actual notification delivery method.']
  resolution_date date [note: 'Date when the leak event was resolved or closed. Used to calculate response time and track Non-Revenue Water (NRW) reduction program effectiveness.']
  resolution_outcome varchar [note: 'Final outcome or resolution status of the leak detection event. Indicates whether the leak was confirmed and repaired, determined to be a false positive, or remains pending.']

  Note: 'Records all detected consumption anomaly events including suspected leaks, high usage alerts, continuous flow conditions, backflow indicators, and threshold exceedance alerts identified through AMI interval data analysis or monitoring rules. Captures event type (leak, high usage, continuous flow, backflow, threshold exceedance), detection timestamp, meter installation reference, detection method, threshold and actual values, percentage over threshold, estimated volume impact, alert severity, alert status (open, notified, resolved, dismissed), notification history, customer contact log, and resolution outcome. Supports NRW reduction programs, customer notification workflows, proactive service management, and customer service case creation.'
}

Table metering.high_usage_alert {
  high_usage_alert_id varchar [pk, note: 'Unique identifier for the high usage alert record. Primary key.']
  alert_rule_id varchar [note: 'Reference to the business rule or threshold configuration that triggered this alert. Links to alert rule definition for audit and tuning purposes.']
  customer_account_id varchar [note: 'Foreign key linking to customer.customer_account. Business justification: High usage alerts notify account holders to prevent bill shock. Core customer service function requiring account contact information, notification preferences, and alert history tracking for customer ']
  high_ami_device_ami_endpoint_id varchar [note: 'Unique identifier of the AMI endpoint device (Sensus FlexNet or similar) that generated the consumption data triggering this alert. Used for device diagnostics and data quality validation.']
  high_ami_endpoint_id varchar [note: 'Unique identifier of the AMI endpoint device (Sensus FlexNet or similar) that generated the consumption data triggering this alert. Used for device diagnostics and data quality validation.']
  investigation_assigned_to_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: High usage alert investigation assignment to customer service or field technicians is core operational workflow. Enables workload tracking, SLA compliance monitoring, and employee performance metrics.']
  meter_installation_id varchar [note: 'Reference to the meter installation that triggered this high usage alert. Links to the specific meter deployment at a service location.']
  order_id varchar [note: 'Reference to the field service order created to investigate or resolve this alert. Links to work order management system. Null if no service order created.']
  premise_id varchar [note: 'Foreign key linking to customer.premise. Business justification: High usage alerts analyzed by premise type for pattern detection. Required for identifying systemic issues by building type, seasonal usage anomalies, and targeting conservation messaging to specific ']
  service_address_id varchar [note: 'Foreign key linking to customer.service_address. Business justification: High usage alerts tied to physical locations for field investigation. Essential for dispatching field crews, correlating alerts with address characteristics, and geographic pattern analysis for leak d']
  actual_consumption_unit varchar [note: 'Unit of measure for the actual consumption value. Gallons, cubic feet, and cubic meters represent volume; GPM (Gallons per Minute) and MGD (Million Gallons per Day) represent flow rate.']
  actual_consumption_value decimal(18,4) [note: 'The measured consumption value during the detection period that triggered the alert. Represents the actual usage that exceeded the threshold.']
  alert_generated_timestamp timestamp [note: 'Date and time when the alert was generated by the Advanced Metering Infrastructure (AMI) or analytics system. Represents the moment the threshold breach was detected.']
  alert_number varchar [note: 'Business-facing unique alert number used for tracking and customer communication. Format: HUA-XXXXXXXXXX.']
  alert_severity varchar [note: 'Severity classification of the alert based on variance magnitude and potential impact. Low indicates minor variance; medium indicates moderate concern; high indicates significant issue requiring prompt attention; critical indicates emergency condition requiring immediate response.']
  alert_status varchar [note: 'Current lifecycle status of the alert. Open indicates newly generated; notified means customer has been contacted; acknowledged means customer confirmed receipt; investigating indicates active review; resolved means issue addressed; dismissed means no action required; false positive indicates erroneous alert. [ENUM-REF-CANDIDATE: open|notified|acknowledged|investigating|resolved|dismissed|false_positive — 7 candidates stripped; promote to reference product]']
  alert_type varchar [note: 'Classification of the high usage alert based on consumption pattern analysis. High consumption indicates volume exceeds baseline; continuous flow suggests uninterrupted usage; backflow suspected indicates reverse flow detection; leak detected flags potential infrastructure failure; abnormal pattern identifies irregular usage; threshold exceeded indicates absolute limit breach.']
  baseline_consumption_value decimal(18,4) [note: 'Historical average or expected consumption value used as the comparison baseline for this alert. May be calculated from seasonal norms, customer history, or similar account profiles.']
  baseline_period_days varchar [note: 'Number of days used to calculate the baseline consumption value. Typical values include 30, 60, 90, or 365 days depending on seasonality and data availability.']
  created_timestamp timestamp [note: 'Date and time when this alert record was first created in the system. Used for audit trail and data lineage.']
  customer_acknowledged_timestamp timestamp [note: 'Date and time when the customer acknowledged receipt and awareness of this alert. Null if customer has not acknowledged.']
  customer_notified_flag boolean [note: 'Indicates whether the customer has been notified about this high usage alert. True means notification sent; False means no notification sent yet.']
  data_source varchar [note: 'Source system or method that provided the consumption data used to generate this alert. AMI interval data represents 15-minute or hourly reads; AMI daily read represents once-per-day automated read; manual read represents field technician reading; estimated read represents calculated value; SCADA flow data represents distribution network monitoring; analytics engine represents derived calculation.']
  detection_period_end_timestamp timestamp [note: 'End of the time window during which the high usage condition was detected. Used to define the consumption analysis interval.']
  detection_period_start_timestamp timestamp [note: 'Beginning of the time window during which the high usage condition was detected. Used to define the consumption analysis interval.']
  estimated_revenue_impact_amount decimal(12,2) [note: 'Estimated financial impact of the high usage condition, representing potential lost revenue or customer billing adjustment. Positive values indicate revenue at risk; negative values indicate customer credits issued. Null if not calculated.']
  estimated_water_loss_gallons decimal(18,2) [note: 'Estimated volume of water lost or wasted due to the condition that triggered this alert, measured in gallons. Used for Non-Revenue Water (NRW) and Unaccounted-for Water (UFW) analysis. Null if not applicable or not calculated.']
  first_notification_timestamp timestamp [note: 'Date and time when the first customer notification was sent for this alert. Null if customer has not been notified.']
  investigation_started_timestamp timestamp [note: 'Date and time when investigation of this alert began. Null if investigation has not started.']
  last_modified_timestamp timestamp [note: 'Date and time when this alert record was most recently updated. Used for audit trail and change tracking.']
  modified_by_user varchar [note: 'Username or identifier of the system user or automated process that last modified this alert record. Used for audit trail and accountability.']
  notification_count varchar [note: 'Total number of notification attempts made to the customer regarding this alert. Includes all channels and retries.']
  notification_method varchar [note: 'Primary communication channel used to notify the customer about this alert. Email, SMS, and mobile app represent digital channels; phone call represents voice contact; postal mail represents physical correspondence; customer portal represents self-service access; none indicates no notification sent. [ENUM-REF-CANDIDATE: email|sms|phone_call|postal_mail|mobile_app|customer_portal|none — 7 candidates stripped; promote to reference product]']
  resolution_category varchar [note: 'Classification of the root cause or resolution outcome for this alert. Customer leak repaired indicates customer-side plumbing issue fixed; utility leak repaired indicates utility infrastructure issue fixed; meter malfunction indicates faulty meter; seasonal usage indicates expected variance; customer behavior change indicates legitimate usage increase; irrigation system and pool filling indicate specific high-volume activities; construction activity indicates temporary usage spike; false alarm indicates erroneous alert; other indicates miscellaneous resolution. [ENUM-REF-CANDIDATE: customer_leak_repaired|utility_leak_repaired|meter_malfunction|seasonal_usage|customer_behavior_change|irrigation_system|pool_filling|construction_activity|false_alarm|other — 10 candidates stripped; promote to reference product]']
  resolution_notes varchar [note: 'Free-text narrative describing the investigation findings, actions taken, and resolution details for this alert. Provides context for future reference and audit trail.']
  resolution_timestamp timestamp [note: 'Date and time when this alert was resolved or closed. Null if alert remains open or under investigation.']
  service_order_created_flag boolean [note: 'Indicates whether a field service order was created in response to this alert. True means service order generated; False means no service order created.']
  suppression_flag boolean [note: 'Indicates whether this alert was suppressed from customer notification due to business rules (e.g., customer opted out, account in dispute, recent similar alert). True means suppressed; False means not suppressed.']
  suppression_reason varchar [note: 'Explanation of why this alert was suppressed from customer notification. Null if alert was not suppressed.']
  threshold_unit varchar [note: 'Unit of measure for the threshold value. Gallons and cubic feet/meters represent volume; GPM (Gallons per Minute) and MGD (Million Gallons per Day) represent flow rate; percent represents variance from baseline.']
  threshold_value decimal(18,4) [note: 'The defined limit or baseline value that was exceeded to trigger this alert. May represent absolute volume, flow rate, or percentage variance depending on alert configuration.']
  variance_percentage decimal(8,2) [note: 'Percentage by which actual consumption exceeded the threshold value. Calculated as ((actual - threshold) / threshold) * 100. Positive values indicate over-threshold conditions.']

  Note: 'Operational alert record generated when a meter\'s consumption exceeds a defined threshold relative to historical baseline, seasonal norms, or absolute volume limits. Stores alert generation timestamp, meter installation reference, alert type (high consumption, continuous flow, backflow suspected), threshold value, actual consumption value, percentage over threshold, alert status (open, notified, resolved, dismissed), customer contact attempt log, and resolution notes. Feeds customer service workflows in Microsoft Dynamics 365.'
}

Table metering.accuracy_test {
  accuracy_test_id varchar [pk, note: 'Primary key for accuracy_test']
  accuracy_technician_employee_id varchar [note: 'Employee who performed the test']
  accuracy_tested_by_employee_id varchar
  meter_installation_id varchar [note: 'Foreign key linking to metering.installation. Business justification: Accuracy tests can be performed in the field (in-situ testing) at a specific meter installation, or in a lab/bench setting. For field tests, this FK links the test to the installation location. This F']
  metering_meter_id varchar [note: 'Foreign key linking to metering.metering_meter. Business justification: Accuracy tests are performed on physical meter devices to assess measurement accuracy and compliance with standards. Each test record must reference which specific meter was tested. FK named metering_']
  acceptance_threshold_pct decimal(6,2) [note: 'Accuracy threshold for pass/fail determination']
  accuracy_high_flow_percent decimal(6,2)
  accuracy_low_flow_percent decimal(6,2)
  accuracy_mid_flow_percent decimal(6,2)
  accuracy_pct decimal(8,4)
  accuracy_percent decimal(7,4)
  accuracy_percentage decimal(7,4) [note: 'Measured accuracy percentage.']
  accuracy_threshold_pct decimal(5,2) [note: 'Accuracy threshold for pass/fail']
  actual_volume decimal(14,4) [note: 'Actual volume passed through meter']
  adjustment_factor decimal(8,6) [note: 'Adjustment factor applied']
  adjustment_made boolean [note: 'Whether adjustment was made']
  awwa_standard_used varchar [note: 'AWWA standard used for test']
  calibration_certificate_number varchar
  composite_accuracy_percent decimal(6,2) [note: 'Weighted composite accuracy']
  corrective_action_taken varchar [note: 'Corrective action taken if meter failed']
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp
  customer_present boolean [note: 'Whether customer was present']
  data_quality_flag boolean [note: 'True when record passed data validation.']
  disposition varchar [note: 'Meter disposition (return to service, scrap, etc.)']
  high_flow_accuracy decimal(7,4) [note: 'High flow accuracy percentage.']
  high_flow_accuracy_pct decimal(8,4) [note: 'Accuracy at high flow rate']
  high_flow_accuracy_percent decimal(6,2) [note: 'Accuracy at high flow rate']
  high_flow_rate_gpm decimal(10,4) [note: 'High flow test rate']
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  low_flow_accuracy decimal(7,4) [note: 'Low flow accuracy percentage.']
  low_flow_accuracy_pct decimal(8,4) [note: 'Accuracy at low flow rate']
  low_flow_accuracy_percent decimal(6,2) [note: 'Accuracy at low flow rate']
  low_flow_rate_gpm decimal(10,4) [note: 'Low flow test rate']
  measured_volume decimal(14,4) [note: 'Volume measured by the meter during test']
  medium_flow_accuracy_pct decimal(8,4) [note: 'Accuracy at medium flow rate']
  medium_flow_accuracy_percent decimal(6,2) [note: 'Accuracy at medium flow rate']
  medium_flow_rate_gpm decimal(10,4) [note: 'Medium flow test rate']
  mid_flow_accuracy decimal(7,4) [note: 'Mid flow accuracy percentage.']
  mid_flow_accuracy_pct decimal(8,4)
  mid_flow_rate_gpm decimal(8,4) [note: 'Medium flow test rate in GPM']
  notes varchar [note: 'Test notes']
  pass_fail_flag boolean
  pass_fail_result varchar
  pass_fail_status varchar [note: 'Whether the meter passed or failed the test']
  pass_flag boolean [note: 'Whether meter passed']
  pass_threshold_percent decimal(5,2) [note: 'Minimum accuracy to pass']
  passed boolean [note: 'Whether the meter passed.']
  passed_flag boolean
  post_adjustment_accuracy_pct decimal(6,2) [note: 'Accuracy after adjustment']
  post_repair_accuracy_pct decimal(6,3) [note: 'Accuracy after repair']
  post_test_read decimal(14,2) [note: 'Meter reading after test']
  post_test_reading decimal(14,2) [note: 'Meter reading after test']
  pre_test_read decimal(14,2) [note: 'Meter reading before test']
  pre_test_reading decimal(14,2) [note: 'Meter reading before test']
  record_status varchar
  repair_description varchar [note: 'Description of repair']
  repair_performed boolean [note: 'Whether repair was performed']
  repair_required boolean [note: 'Whether repair is required']
  replacement_recommended boolean [note: 'Whether replacement recommended']
  replacement_recommended_flag boolean [note: 'Whether replacement is recommended based on results']
  technician_name varchar [note: 'Name of technician']
  technician_notes varchar [note: 'Technician notes']
  test_bench_calibration_date date [note: 'Test bench calibration date']
  test_bench_code varchar [note: 'Identifier of the test bench used']
  test_date date
  test_equipment_code varchar
  test_facility varchar
  test_flow_rate decimal(12,4)
  test_flow_rate_gpm decimal(10,4) [note: 'Flow rate during test in GPM']
  test_location varchar [note: 'Test location (field, shop)']
  test_method varchar
  test_notes varchar [note: 'Notes from the accuracy test']
  test_number varchar [note: 'Unique test number']
  test_reason varchar [note: 'Reason for test (scheduled, complaint, replacement, new)']
  test_result varchar
  test_standard varchar
  test_status varchar [note: 'Test status']
  test_type varchar [note: 'Type of test (low flow, medium flow, high flow, full range)']
  test_volume_gallons decimal(10,4) [note: 'Volume used in test']
  tested_by varchar
  tolerance_percent decimal(7,4)
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp.']
  water_temperature_f decimal(6,2) [note: 'Water temperature during test']
  weighted_accuracy_pct decimal(8,4) [note: 'AWWA weighted accuracy percentage']
  weighted_accuracy_percent decimal(6,2)

  Note: 'Records meter assessment activities including accuracy testing (bench test, in-situ, field test per AWWA M6 standards) and physical field inspections (condition assessment, seal verification, pit/vault inspection, AMI antenna check). Captures assessment date, meter installation reference, assessment type, technician ID, test results (accuracy percentages at low/intermediate/high flow rates for tests; condition ratings and observations for inspections), pass/fail determination, photographic evidence reference, and recommended action. Supports meter replacement program decisions and proactive asset management.'
}

Table metering.replacement_program {
  replacement_program_id varchar [pk, note: 'Primary key for replacement_program']
  asset_class_id varchar [note: 'Foreign key linking to asset.asset_class. Business justification: Replacement programs target specific asset classes (e.g., residential meters aged 15+ years). Program eligibility, prioritization, and budget forecasting depend on asset class characteristics like use']
  meter_size_type_id varchar [note: 'Foreign key linking to metering.meter_size_type. Business justification: Meter replacement programs are often targeted at specific meter sizes or types (e.g., \'replace all 5/8-inch meters over 15 years old\' or \'replace all non-AMI 3/4-inch meters\'). This FK links the progr']
  program_manager_employee_id varchar
  territory_id varchar [note: 'Service territory for this program']
  accuracy_threshold_pct decimal(6,2) [note: 'Accuracy threshold for replacement']
  actual_completion_date date [note: 'Actual completion date']
  actual_cost decimal(18,2)
  actual_cost_usd decimal(18,2)
  age_threshold_years varchar [note: 'Age threshold for replacement']
  ami_upgrade_flag boolean [note: 'Whether program includes AMI upgrade']
  annual_budget decimal(18,2) [note: 'Annual program budget']
  annual_budget_amount decimal(18,2) [note: 'Annual budget allocation']
  annual_target varchar [note: 'Annual replacement target']
  budget_amount decimal(18,2)
  budget_amount_usd varchar
  budget_spent decimal(18,2) [note: 'Budget spent to date']
  budget_total decimal(18,2) [note: 'Total program budget']
  budget_usd decimal(18,2)
  completed_count varchar [note: 'Completed count']
  completed_meter_count varchar [note: 'Number of meters replaced']
  completed_replacement_count varchar [note: 'Number of replacements completed']
  completion_pct decimal(10,4)
  completion_percent decimal(7,4)
  contractor_name varchar [note: 'Contractor performing replacements']
  cost_per_replacement decimal(18,2) [note: 'Average cost per replacement']
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp [note: 'Record creation timestamp']
  data_quality_flag boolean [note: 'True when record passed data validation.']
  end_date date
  estimated_revenue_recovery_usd decimal(18,2) [note: 'Estimated annual revenue recovery from replacements']
  expected_water_recovery_pct decimal(6,2) [note: 'Expected water recovery percentage']
  funding_source varchar [note: 'Source of funding']
  is_active boolean [note: 'Whether the program is active.']
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  max_meter_age_years varchar [note: 'Maximum meter age triggering replacement']
  meters_replaced_count varchar [note: 'Number of meters replaced to date']
  meters_replaced_to_date varchar [note: 'Number of meters replaced to date']
  min_accuracy_threshold_percent decimal(5,2) [note: 'Minimum accuracy before replacement']
  notes varchar [note: 'Program notes']
  planned_completion_date date [note: 'Planned completion date']
  priority_criteria varchar [note: 'Criteria for prioritizing replacements']
  priority_level varchar
  priority_method varchar [note: 'Method for prioritizing replacements']
  priority_ranking varchar [note: 'Priority ranking among programs']
  priority_ranking_method varchar [note: 'Method used to prioritize replacements']
  priority_zones varchar [note: 'Priority zones for replacement']
  program_budget_usd decimal(18,2) [note: 'Total program budget in USD']
  program_code varchar [note: 'Unique program code']
  program_description varchar [note: 'Description of the program']
  program_end_date date
  program_name varchar
  program_start_date date
  program_status varchar
  program_type varchar [note: 'Type of program (age-based, accuracy-based, AMI upgrade)']
  record_status varchar
  replaced_count varchar
  replaced_meter_count varchar
  replacement_criteria varchar [note: 'Criteria for selecting meters (age, accuracy, technology)']
  replacement_meter_type varchar [note: 'Type of replacement meter']
  replacement_program_status varchar [note: 'Program status (planning, active, completed, suspended)']
  selection_criteria varchar [note: 'Meter selection criteria']
  spent_amount decimal(18,2) [note: 'Amount spent to date']
  spent_to_date decimal(18,2) [note: 'Amount spent to date']
  spent_to_date_usd decimal(18,2) [note: 'Amount spent to date in USD']
  start_date date
  target_accuracy_threshold_pct decimal(6,2) [note: 'Accuracy threshold triggering replacement']
  target_completion_date date
  target_count varchar
  target_meter_age_years varchar [note: 'Target meter age threshold in years']
  target_meter_count varchar [note: 'Target number of meters to replace']
  target_meter_types varchar [note: 'Meter types targeted for replacement']
  target_replacement_count varchar [note: 'Target number of meters to replace']
  total_budget decimal(18,2) [note: 'Total program budget']
  total_meters_planned varchar
  total_meters_replaced varchar
  total_meters_targeted varchar [note: 'Total number of meters targeted for replacement']
  unit_cost_per_meter decimal(18,2) [note: 'Average cost per meter replacement']
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp']

  Note: 'Defines and tracks meter replacement programs and campaigns, including age-based replacement cycles, accuracy-based replacement triggers, and AMI retrofit programs. Stores program name, program type (age-based, accuracy-based, AMI upgrade, LCRR lead service line), target meter population criteria (age threshold, meter size, meter type, geographic zone), program start and end dates, target count, completion count, budget allocation, and program status. Links to individual replacement work orders executed through IBM Maximo.'
}

Table metering.replacement_order {
  replacement_order_id varchar [pk, note: 'Primary key for replacement_order']
  accuracy_test_id varchar [note: 'Foreign key linking to metering.accuracy_test. Business justification: replacement_order captures old_meter_accuracy_test_result as a scalar value but lacks FK to the actual accuracy_test record that triggered the replacement. Meter replacements are often driven by faile']
  material_requisition_id varchar [note: 'Foreign key linking to supply.material_requisition. Business justification: Replacement orders trigger material requisitions to pull meter stock from warehouse for installation crews. Work order execution requires reservation/requisition of specific meter inventory, linking f']
  purchase_order_id varchar [note: 'Foreign key linking to supply.purchase_order. Business justification: Meter replacement programs generate bulk purchase orders for new meter inventory. Replacement program execution triggers procurement of meters in planned quantities, linking program planning to procur']
  replacement_assigned_to_employee_id varchar
  replacement_completed_by_employee_id varchar
  replacement_new_metering_meter_id varchar [note: 'New meter installed']
  replacement_old_metering_meter_id varchar [note: 'Foreign key linking to metering.metering_meter. Business justification: A replacement order replaces an existing (old) meter with a new meter. This FK tracks which physical meter device was removed/replaced. This is the first of two FKs to metering_meter (old and new), re']
  replacement_program_id varchar [note: 'Foreign key linking to metering.replacement_program. Business justification: Replacement orders are often executed as part of a structured replacement program or campaign (age-based, accuracy-based, technology upgrade). This FK links individual replacement work orders to their']
  replacement_technician_employee_id varchar [note: 'Technician performing replacement']
  work_order_id varchar [note: 'Foreign key linking to asset.work_order. Business justification: Each meter replacement is executed via work order that schedules crews, tracks labor/materials, manages old meter disposal, and closes out capital projects. Standard utility field service workflow lin']
  access_issue boolean [note: 'Whether access issue was encountered']
  access_issue_description varchar [note: 'Description of access issue']
  access_issues boolean [note: 'Whether access issues occurred']
  access_notes varchar [note: 'Access issue notes']
  actual_cost decimal(18,2) [note: 'Actual replacement cost.']
  actual_cost_usd decimal(18,2)
  appointment_window varchar [note: 'Scheduled appointment window']
  completed_date date [note: 'Actual completion date']
  completion_date date
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp
  customer_notification_date date [note: 'Date customer was notified']
  customer_notified boolean [note: 'Whether customer was notified']
  customer_present boolean [note: 'Whether customer was present']
  data_quality_flag boolean [note: 'True when record passed data validation.']
  estimated_cost decimal(18,2) [note: 'Estimated replacement cost.']
  estimated_cost_usd decimal(18,2)
  final_read varchar
  final_read_value decimal(15,3) [note: 'Final read on old meter']
  initial_read_value decimal(15,3) [note: 'Initial read on new meter']
  is_complete boolean
  is_completed boolean [note: 'Whether replacement is complete.']
  is_emergency boolean
  labor_cost decimal(18,2) [note: 'Labor cost']
  labor_hours decimal(6,2) [note: 'Labor hours for replacement']
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  material_cost decimal(18,2) [note: 'Material cost']
  meter_cost decimal(18,2) [note: 'Cost of new meter']
  new_meter_initial_reading decimal(14,2) [note: 'Initial reading on new meter']
  new_meter_number varchar [note: 'Serial number of new meter']
  new_meter_read decimal(15,3)
  new_meter_reading decimal(14,2) [note: 'Initial reading on new meter']
  new_meter_serial_number varchar [note: 'New meter serial number']
  notes varchar [note: 'Order notes']
  old_meter_final_reading decimal(14,2) [note: 'Final reading on old meter']
  old_meter_number varchar
  old_meter_read decimal(15,3)
  old_meter_reading decimal(14,2) [note: 'Final reading on old meter']
  order_date date
  order_number varchar
  order_status varchar
  order_type varchar
  pit_condition varchar [note: 'Meter pit condition']
  pit_condition_noted varchar [note: 'Pit condition noted']
  pit_repair_needed boolean [note: 'Whether pit repair is needed']
  pit_repairs_needed boolean [note: 'Whether pit repairs needed']
  priority varchar
  priority_level varchar
  reason_code varchar [note: 'Replacement reason code']
  record_status varchar
  replacement_reason varchar [note: 'Reason for replacement']
  scheduled_date date
  technician_name varchar [note: 'Name of technician']
  technician_notes varchar [note: 'Technician notes']
  total_cost decimal(18,2) [note: 'Total replacement cost']
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp']

  Note: 'Individual work order record for the physical replacement of a meter at a service location, executed as part of a replacement program or triggered by accuracy failure, damage, or customer request. Captures replacement program reference, scheduled date, completion date, old meter ID, new meter ID, technician ID, reason for replacement, old meter final read, new meter initial read, service interruption duration, and Maximo work order number. Bridges the metering domain with the asset and workforce domains.'
}

Table metering.metering_dma_zone {
  metering_dma_zone_id varchar [pk, note: 'Unique identifier for the District Metered Area zone. Primary key for the DMA zone master record.']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: DMA establishment and reconfiguration are capital projects involving valve installations, boundary meter installations, and hydraulic modeling. Required for NRW program capital investment tracking, re']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: DMAs are operational cost centers for budget allocation, O&M expense tracking, and capital investment planning. Utilities manage DMA-level budgets, analyze cost per connection, and allocate labor/mate']
  metering_backup_zone_meter_installation_id varchar [note: 'Foreign key reference to a secondary or backup zone meter installation for redundancy. Used when primary zone meter is offline or for validation of primary meter readings.']
  metering_prv_installation_id varchar [note: 'Foreign key reference to the primary Pressure Reducing Valve installation serving this DMA zone. PRVs control inlet pressure to reduce leakage and pipe stress.']
  metering_zone_meter_installation_id varchar [note: 'Foreign key reference to the primary zone meter installation that measures total inflow to the DMA. This meter is the authoritative source for DMA-level consumption and water balance calculations.']
  pressure_zone_id varchar [note: 'Foreign key reference to the pressure zone within which this DMA operates. Pressure zones define hydraulic boundaries based on elevation and pump station service areas.']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: DMAs are established to meet regulatory requirements for pressure management, leak detection frequency, and water loss control programs. Real process: designing and operating DMAs per state water loss']
  territory_id varchar [note: 'Foreign key linking to service.service_territory. Business justification: DMAs are geographic subdivisions within service territories for NRW management and hydraulic modeling. Operations teams need territory link for franchise jurisdiction, regulatory reporting boundaries,']
  actual_nrw_percentage decimal(5,2) [note: 'Most recent calculated Non-Revenue Water percentage for this DMA zone based on water balance analysis. Updated monthly or quarterly from metering and billing data.']
  average_age_of_mains_years varchar [note: 'Average age in years of distribution mains within the DMA zone. Correlates with leak frequency and helps prioritize pipe replacement programs.']
  average_pressure_psi decimal(6,2) [note: 'Average operating pressure within the DMA zone measured in pounds per square inch. Critical for pressure management and leak reduction programs.']
  created_timestamp timestamp [note: 'Timestamp when this DMA zone record was first created in the system. Used for audit trail and data lineage tracking.']
  decommissioned_date date [note: 'Date when the DMA zone was decommissioned or merged into another zone. Null for active zones. Used for historical record keeping and network reconfiguration tracking.']
  dma_code varchar [note: 'Business identifier code for the DMA zone used in operational systems, SCADA displays, and reporting. Typically alphanumeric and unique across the distribution network.']
  dma_name varchar [note: 'Human-readable name of the DMA zone, often reflecting geographic location or neighborhood served (e.g., \'Downtown West DMA\', \'Industrial Park Zone 3\').']
  dma_type varchar [note: 'Classification of the DMA zone based on predominant customer type and land use. Drives consumption pattern analysis and NRW benchmarking.']
  established_date date [note: 'Date when the DMA zone was officially established and zone metering began. Used for calculating age of DMA program and historical trend analysis.']
  gis_boundary_reference varchar [note: 'Reference identifier to the GIS polygon feature representing the geographic boundary of the DMA zone in the Esri ArcGIS system. Used for spatial analysis and mapping.']
  hydraulic_model_reference varchar [note: 'Reference identifier to the DMA zone representation in the Innovyze InfoWater hydraulic model. Used for pressure analysis, fire flow testing, and capital planning.']
  infrastructure_leakage_index decimal(6,3) [note: 'Ratio of current annual real losses to unavoidable annual real losses. ILI values below 2.0 indicate good performance; above 4.0 indicates poor performance requiring intervention.']
  isolation_valve_count varchar [note: 'Number of isolation valves that define the hydraulic boundary of the DMA zone. Used for operational planning and boundary integrity verification.']
  last_leak_detection_date date [note: 'Date of the most recent active leak detection survey conducted in this DMA zone. Used to schedule next survey and track compliance with leak detection programs.']
  last_modified_timestamp timestamp [note: 'Timestamp when this DMA zone record was last updated. Used for change tracking and data quality monitoring.']
  leak_detection_frequency_days varchar [note: 'Target frequency in days for conducting active leak detection surveys within this DMA zone. High-loss zones are surveyed more frequently.']
  metering_dma_zone_description varchar [note: 'Detailed description of the DMA zone including boundaries, key landmarks, and operational notes. Used for field crew reference and planning.']
  metering_dma_zone_status varchar [note: 'Current operational status of the DMA zone. Active zones are monitored for NRW; inactive or planned zones are not yet operational.']
  minimum_night_flow_gpm decimal(10,2) [note: 'Minimum flow rate measured during night hours (typically 2-4 AM) when legitimate consumption is lowest. Key indicator for leak detection and NRW analysis measured in gallons per minute.']
  notes varchar [note: 'Free-text field for operational notes, special conditions, historical context, or other relevant information about the DMA zone not captured in structured fields.']
  predominant_pipe_material varchar [note: 'Most common pipe material type within the DMA zone. Influences leak rates, corrosion risk, and maintenance strategies. [ENUM-REF-CANDIDATE: cast_iron|ductile_iron|pvc|hdpe|steel|concrete|asbestos_cement|copper — 8 candidates stripped; promote to reference product]']
  responsible_operations_team decimal(18,6) [note: 'Name or identifier of the operations team or district responsible for maintenance and leak response within this DMA zone. Used for work order routing and accountability.']
  scada_monitoring_enabled boolean [note: 'Indicates whether the DMA zone meter is connected to the SCADA system for real-time flow and pressure monitoring. True enables automated alerts for abnormal conditions.']
  scada_tag_reference varchar [note: 'SCADA system tag identifier for the primary zone meter flow point in OSIsoft PI Historian. Used to retrieve real-time and historical flow data for water balance analysis.']
  service_connection_count varchar [note: 'Total number of active service connections (meters) within the DMA zone. Used as denominator in per-connection NRW calculations and for sizing analysis.']
  target_nrw_percentage decimal(5,2) [note: 'Target or goal for Non-Revenue Water as a percentage of total inflow for this DMA zone. Used for performance monitoring and loss reduction program planning.']
  total_pipe_length_miles decimal(10,2) [note: 'Total length of distribution mains within the DMA zone measured in miles. Used for calculating NRW per mile of main and infrastructure density metrics.']
  ufw_gallons_per_connection_per_day decimal(10,2) [note: 'Unaccounted-for Water volume normalized per service connection per day. Key performance indicator for leak detection prioritization and DMA performance benchmarking.']

  Note: 'Master record for each District Metered Area (DMA) — a hydraulically isolated zone of the distribution network bounded by closed valves and monitored by zone meters for water balance analysis. Stores DMA code, name, geographic boundary reference, zone meter installation IDs, service connection count, pipe length, pressure zone reference, and operational status. The authoritative reference for DMA topology used in NRW/UFW water balance calculations, pressure management, and leakage targeting.'
}

Table metering.metering_nrw_water_balance {
  metering_nrw_water_balance_id varchar [pk, note: 'Unique identifier for the metering_nrw_water_balance data product (auto-inserted pre-linking).']
  metering_dma_zone_id varchar [note: 'Foreign key linking to metering.metering_dma_zone. Business justification: Non-Revenue Water (NRW) water balance calculations are performed for specific District Metered Areas (DMAs) to quantify water losses within a hydraulically isolated zone. Each water balance record mus']
  nrw_loss_general_ledger_id varchar [note: 'Foreign key linking to finance.general_ledger. Business justification: Non-revenue water losses must be recorded in specific GL accounts for regulatory compliance, rate case justification, and financial transparency. NRW water balance calculations drive loss accounting e']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: NRW programs must comply with specific regulatory requirements for water loss control targets, infrastructure leakage index thresholds, and audit methodology standards. Real process: tracking complian']
  regulatory_submission_id varchar [note: 'Foreign key linking to compliance.regulatory_submission. Business justification: Non-revenue water audits are mandatory regulatory submissions under AWWA M36 standards and state water loss control programs. Real process: annual water audit submission to state agencies per regulato']
  territory_id varchar [note: 'Foreign key linking to service.service_territory. Business justification: NRW water balance calculations (AWWA M36 methodology) are performed at service territory level for regulatory reporting to state primacy agencies and rate case cost-of-service studies. Territory link ']
  apparent_loss_mg decimal(18,4)
  apparent_losses decimal(18,4) [note: 'Apparent (commercial) losses.']
  apparent_losses_gallons decimal(18,2)
  apparent_losses_mg decimal(18,4) [note: 'Apparent losses (meter inaccuracy, theft)']
  apparent_losses_ml decimal(18,4)
  audit_date date [note: 'Date of audit']
  authorized_consumption decimal(18,2)
  authorized_consumption_mg decimal(18,4) [note: 'Total authorized consumption']
  average_operating_pressure_psi decimal(6,2) [note: 'Average operating pressure in PSI']
  awwa_audit_grade varchar [note: 'AWWA audit grade']
  balance_period varchar [note: 'Water balance period identifier']
  balance_period_end date [note: 'Water balance period end.']
  balance_period_end_date date
  balance_period_start date [note: 'Water balance period start.']
  balance_period_start_date date
  billed_authorized_consumption decimal(18,4) [note: 'Billed authorized consumption.']
  billed_authorized_consumption_gallons decimal(18,2)
  billed_authorized_consumption_ml decimal(18,4)
  billed_consumption varchar
  billed_consumption_mg varchar [note: 'Billed authorized consumption']
  billed_metered_consumption_mg decimal(18,4) [note: 'Billed metered consumption']
  billed_unmetered_consumption_mg decimal(18,4) [note: 'Billed unmetered consumption']
  billed_volume double
  billed_volume_mg decimal(18,4)
  calculation_method varchar [note: 'Calculation methodology used']
  carl_mg_per_day decimal(12,4) [note: 'Current Annual Real Losses per day']
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp
  current_annual_real_losses_gal_conn_day decimal(10,2) [note: 'CARL in gallons per connection per day']
  current_annual_real_losses_mg decimal(18,4) [note: 'CARL in million gallons']
  data_handling_errors_mg decimal(14,4) [note: 'Losses due to data handling errors']
  data_quality_flag boolean [note: 'True when record passed data validation.']
  data_quality_score decimal(5,2)
  data_validity_score varchar [note: 'AWWA data validity score']
  distribution_nrw_water_balance_id decimal(18,2) [note: 'Canonical single-source-of-truth reference to distribution.distribution_nrw_water_balance (distribution_nrw_water_balance_id); this entity defers authoritative attribute values to that master entity.']
  financial_loss_usd decimal(18,2)
  ili_ratio decimal(8,4)
  ili_value decimal(8,4) [note: 'Infrastructure Leakage Index']
  infrastructure_leakage_index decimal(8,4) [note: 'Infrastructure Leakage Index (ILI)']
  input_volume double
  input_volume_mg decimal(18,4)
  is_audited boolean [note: 'Whether balance has been audited']
  is_validated boolean
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  loss_value decimal(18,2)
  meter_accuracy_adjustment_mg decimal(18,4) [note: 'Meter accuracy adjustment']
  meter_inaccuracy_mg decimal(14,4) [note: 'Losses due to meter inaccuracy']
  meter_inaccuracy_volume_mg decimal(18,4) [note: 'Volume attributed to meter inaccuracy']
  metering_distribution_nrw_water_balance_id decimal(18,2) [note: 'References the single source of truth record in distribution.distribution_nrw_water_balance']
  non_revenue_water_gallons decimal(18,2)
  non_revenue_water_mg decimal(18,4) [note: 'Total non-revenue water']
  non_revenue_water_ml decimal(18,4)
  non_revenue_water_percent decimal(5,2)
  non_revenue_water_percentage decimal(7,4) [note: 'Non-revenue water percentage.']
  non_revenue_water_volume decimal(18,4) [note: 'Non-revenue water volume.']
  notes varchar [note: 'Balance notes']
  nrw_cost decimal(18,2)
  nrw_pct decimal(8,4)
  nrw_percent decimal(10,4) [note: 'Non-revenue water percent']
  nrw_percentage decimal(6,2) [note: 'NRW as percentage of system input']
  nrw_volume double
  nrw_volume_mg varchar [note: 'Non-revenue water volume']
  number_of_connections varchar [note: 'Number of service connections in zone']
  period_end date
  period_end_date date [note: 'Period end date']
  period_start date
  period_start_date date [note: 'Period start date']
  real_loss_mg decimal(18,4)
  real_losses decimal(18,4) [note: 'Real (physical) losses.']
  real_losses_gallons decimal(18,2)
  real_losses_mg decimal(18,4) [note: 'Real losses (leakage)']
  real_losses_ml decimal(18,4)
  record_status varchar
  reporting_month varchar [note: 'Reporting month']
  reporting_year varchar [note: 'Reporting year']
  ssot_source_domain varchar [note: 'SSOT owner is distribution domain']
  system_input_volume decimal(18,4) [note: 'Total system input volume.']
  system_input_volume_gallons decimal(18,2)
  system_input_volume_mg decimal(18,4) [note: 'Total system input volume in MG']
  system_input_volume_ml decimal(18,4)
  total_main_length_miles decimal(10,2) [note: 'Total main length in miles']
  uarl_mg_per_day decimal(12,4) [note: 'Unavoidable Annual Real Losses per day']
  unauthorized_consumption_mg decimal(14,4) [note: 'Unauthorized consumption volume']
  unavoidable_annual_real_losses decimal(14,4) [note: 'UARL in MG']
  unavoidable_annual_real_losses_mg decimal(18,4) [note: 'UARL in million gallons']
  unbilled_authorized_consumption decimal(18,4) [note: 'Unbilled authorized consumption.']
  unbilled_authorized_consumption_gallons decimal(18,2)
  unbilled_authorized_consumption_ml decimal(18,4)
  unbilled_consumption varchar
  unbilled_consumption_mg decimal(18,4)
  unbilled_metered_consumption_mg decimal(18,4) [note: 'Unbilled metered consumption']
  unbilled_unmetered_consumption_mg decimal(18,4) [note: 'Unbilled unmetered consumption']
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp.']
  water_loss_cost decimal(18,2) [note: 'Estimated cost of water loss.']
  water_loss_percent decimal(8,4)
  water_loss_percentage varchar
  water_losses decimal(18,2)
  water_losses_mg decimal(18,4) [note: 'Total water losses']

  Note: 'Periodic (monthly/annual) water balance record for a DMA zone or system-wide, quantifying Non-Revenue Water (NRW) and Unaccounted-for Water (UFW) per the IWA/AWWA water audit methodology (M36 manual). Stores period start and end dates, system input volume (MGD), authorized consumption (billed metered, billed unmetered, unbilled metered, unbilled unmetered), water losses (apparent losses from meter inaccuracy and unauthorized consumption; real losses from leakage), NRW volume, NRW percentage, Infrastructure Leakage Index (ILI), and audit confidence grade. Feeds regulatory reporting, capital planning, and performance benchmarking. [SSOT: governed by distribution.distribution_nrw_water_balance] [DEPRECATED: Single source of truth is distribution.distribution_nrw_water_balance]'
}

Table metering.tamper_event {
  tamper_event_id varchar [pk, note: 'Primary key for tamper_event']
  ami_endpoint_id varchar [note: 'Foreign key linking to metering.ami_endpoint. Business justification: Tamper events are often detected by AMI endpoints through tamper detection sensors and transmitted as alerts. This FK links the tamper event to the AMI endpoint that detected and reported the tamperin']
  billing_adjustment_id varchar [note: 'Foreign key linking to billing.adjustment. Business justification: Tamper events trigger billing adjustments for estimated unbilled consumption during tamper period per revenue protection policies and regulatory requirements. Direct link supports tamper-to-cash workf']
  customer_account_id varchar [note: 'Affected customer account']
  meter_installation_id varchar [note: 'Foreign key linking to metering.installation. Business justification: Tamper events (meter tampering, unauthorized bypass, interference) occur at a specific meter installation location. This FK links the tamper event to the physical installation where tampering was dete']
  tamper_assigned_to_employee_id varchar
  tamper_investigator_employee_id varchar [note: 'Employee investigating']
  work_order_id varchar [note: 'Foreign key linking to asset.work_order. Business justification: Tamper events trigger field investigations and potential enforcement actions dispatched via work orders. Utilities track investigation findings, customer contact, and resolution through work order sys']
  back_billing_amount decimal(18,2) [note: 'Back-billing amount assessed']
  backbill_amount decimal(18,2) [note: 'Amount of backbill if applicable']
  confirmed_tamper boolean [note: 'Whether tamper was confirmed']
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp
  customer_contact_date date [note: 'Date customer was contacted']
  customer_contacted boolean [note: 'Whether customer was contacted']
  customer_explanation varchar [note: 'Customer explanation if provided']
  customer_response varchar [note: 'Customer response']
  data_quality_flag boolean [note: 'True when record passed data validation.']
  detected_timestamp timestamp
  detection_date date [note: 'Date tamper was detected']
  detection_method varchar [note: 'Method of detection (AMI alert, field inspection)']
  detection_timestamp timestamp [note: 'Timestamp tamper was detected']
  estimated_end_date date [note: 'Estimated end date of tampering']
  estimated_loss decimal(18,2)
  estimated_loss_amount decimal(12,2)
  estimated_loss_gallons decimal(12,2)
  estimated_loss_revenue decimal(18,2)
  estimated_lost_revenue varchar
  estimated_lost_volume decimal(18,4) [note: 'Estimated lost water volume.']
  estimated_revenue_loss decimal(18,2) [note: 'Estimated revenue loss.']
  estimated_revenue_loss_amount decimal(12,2)
  estimated_revenue_loss_usd decimal(18,2)
  estimated_revenue_lost decimal(18,2) [note: 'Estimated revenue lost']
  estimated_start_date date [note: 'Estimated start date of tampering']
  estimated_theft_period_days varchar [note: 'Estimated period of theft in days']
  estimated_theft_value decimal(18,2) [note: 'Estimated value of theft']
  estimated_theft_volume decimal(14,2) [note: 'Estimated volume of theft']
  estimated_unbilled_volume decimal(18,4)
  estimated_volume_loss_gallons decimal(12,2) [note: 'Estimated water volume lost']
  estimated_volume_lost_gal decimal(14,2) [note: 'Estimated volume lost to tampering']
  estimated_volume_lost_gallons decimal(14,2) [note: 'Estimated volume of unmetered water']
  event_date date
  event_number varchar [note: 'Unique tamper event number']
  event_severity varchar
  event_status varchar
  event_timestamp timestamp
  event_type varchar [note: 'Type of tamper event']
  evidence_collected boolean [note: 'Whether evidence was collected']
  evidence_description varchar [note: 'Description of evidence found']
  investigation_date date [note: 'Date of investigation']
  investigation_findings varchar [note: 'Investigation findings']
  investigation_notes varchar
  investigation_outcome varchar
  investigation_required boolean
  investigation_required_flag boolean
  investigation_status varchar
  investigator_name varchar [note: 'Name of investigator']
  is_confirmed boolean [note: 'Whether tamper was confirmed.']
  is_confirmed_theft boolean [note: 'Whether confirmed as water theft']
  is_resolved boolean
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  law_enforcement_notified boolean [note: 'Whether law enforcement notified']
  law_enforcement_notified_flag boolean [note: 'Whether law enforcement was notified']
  notes varchar [note: 'Event notes']
  penalty_amount decimal(18,2) [note: 'Penalty amount assessed']
  penalty_assessed decimal(18,2) [note: 'Penalty amount assessed']
  photo_url varchar [note: 'URL to evidence photo']
  photos_taken boolean [note: 'Whether photos were taken']
  police_report_number varchar [note: 'Police report number']
  record_status varchar
  referred_to_legal boolean [note: 'Whether referred to legal']
  resolution_action varchar [note: 'Action taken to resolve']
  resolution_date date [note: 'Date of resolution']
  resolution_notes varchar
  resolution_type varchar [note: 'Type of resolution']
  resolved_date date [note: 'Date the event was resolved.']
  resolved_flag boolean [note: 'Whether resolved']
  severity varchar
  severity_level varchar [note: 'Severity level']
  tamper_description varchar
  tamper_detected_timestamp timestamp
  tamper_event_number varchar [note: 'Unique tamper event identifier']
  tamper_severity varchar
  tamper_status varchar
  tamper_type varchar
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp']

  Note: 'Records detected meter tampering, unauthorized bypass, or meter interference events identified through AMI tamper flags, field inspection, or billing anomaly investigation. Captures detection date, meter installation reference, tamper type (magnetic tamper, reverse flow, physical bypass, broken seal, unauthorized removal), detection source (AMI flag, field inspection, billing review), estimated unbilled consumption volume, investigation status, enforcement action taken, and revenue recovery amount. Supports revenue protection and regulatory compliance.'
}

Table metering.read_exception {
  read_exception_id varchar [pk, note: 'Unique identifier for the meter read exception record.']
  ami_endpoint_id varchar [note: 'Foreign key linking to metering.ami_endpoint. Business justification: For AMI read exceptions (communication failures, signal strength issues, battery failures), this FK links the exception to the specific AMI endpoint experiencing the issue. Should be nullable for manu']
  assigned_to_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Read exception investigation requires field technician assignment for resolution. Core operational workflow for meter reading quality control. Column \'assigned_to\' currently stores employee identifier']
  billing_cycle_id varchar [note: 'Reference to the billing cycle during which the exception occurred.']
  customer_account_id varchar [note: 'Foreign key linking to customer.customer_account. Business justification: Read exceptions affect billing accuracy and require customer notification. Essential for billing hold management, estimated bill communication, customer dispute resolution, and tracking exception impa']
  main_break_id varchar [note: 'Foreign key linking to distribution.main_break. Business justification: Read exceptions (communication failures, no-reads) may result from main breaks causing power outages or infrastructure damage. Root cause analysis for meter communication issues requires checking if d']
  meter_installation_id varchar [note: 'Reference to the meter installation where the exception occurred.']
  read_id varchar [note: 'Foreign key linking to metering.read. Business justification: Read exceptions are anomalies detected during meter read processing (communication failures, variance exceptions, validation failures). Each exception record should reference the specific read that tr']
  read_route_id varchar [note: 'Foreign key linking to metering.read_route. Business justification: read_exception tracks meter read anomalies that require investigation. Exceptions occur during route reading operations and should reference which route the exception occurred on. This enables route-l']
  service_address_id varchar [note: 'Foreign key linking to customer.service_address. Business justification: Read exceptions tied to locations for field resolution. Required for dispatching meter readers, identifying access issues, correlating exceptions with address characteristics like obstructions, and op']
  validation_rule_id varchar [note: 'Identifier of the automated validation rule that triggered the exception when exception source is validation_rule.']
  work_order_id varchar [note: 'Reference to the work order created for field investigation or meter replacement when field visit is required.']
  battery_status varchar [note: 'Battery health status of the Advanced Metering Infrastructure (AMI) endpoint device at time of exception.']
  billing_hold_flag boolean [note: 'Indicator that billing has been placed on hold for this meter installation until the exception is resolved.']
  communication_failure_reason varchar [note: 'Detailed reason for Advanced Metering Infrastructure (AMI) or Automatic Meter Reading (AMR) communication failure when exception type is communication_failure.']
  corrected_read_value decimal(15,3) [note: 'Corrected meter reading value after manual investigation or re-read, used for billing when resolution action is read_corrected.']
  created_timestamp timestamp [note: 'Timestamp when the exception record was first created in the system.']
  current_read_value decimal(15,3) [note: 'Current meter register reading value that triggered the exception, measured in gallons or cubic feet depending on meter configuration.']
  customer_notification_sent boolean [note: 'Indicator that the customer was notified about the read exception and potential billing impact.']
  estimated_read_value decimal(15,3) [note: 'Estimated consumption value used for billing when actual read cannot be obtained, calculated based on historical usage patterns.']
  estimation_method varchar [note: 'Method used to calculate estimated read value when actual read is unavailable (e.g., historical average, seasonal adjustment, similar customer profile).']
  exception_code varchar [note: 'System-generated code identifying the specific exception condition. Aligns with Oracle CC&B exception code catalog.']
  exception_date date [note: 'Date when the meter read exception was detected or occurred.']
  exception_source varchar [note: 'Source system or process that detected and reported the meter read exception.']
  exception_status varchar [note: 'Current workflow status of the exception investigation and resolution process.']
  exception_timestamp timestamp [note: 'Precise timestamp when the exception was detected by the Advanced Metering Infrastructure (AMI) or Automatic Meter Reading (AMR) system.']
  exception_type varchar [note: 'Classification of the meter read exception condition requiring investigation or manual resolution before billing.']
  expected_consumption decimal(15,3) [note: 'Expected consumption value based on historical usage patterns, used for variance analysis and exception detection.']
  field_visit_required boolean [note: 'Indicator that a field technician visit is required to physically inspect the meter or resolve the exception.']
  last_modified_timestamp timestamp [note: 'Timestamp when the exception record was last updated.']
  leak_detection_flag boolean [note: 'Indicator that continuous flow or abnormal usage pattern suggesting a leak was detected during the read period.']
  notification_date date [note: 'Date when customer notification was sent regarding the meter read exception.']
  prior_read_value decimal(15,3) [note: 'Previous valid meter register reading value before the exception occurred, measured in gallons or cubic feet depending on meter configuration.']
  priority_level varchar [note: 'Priority assigned to the exception for resolution workflow, based on exception type, customer class, and business impact.']
  register_overflow_flag boolean [note: 'Indicator that the meter register has exceeded its maximum capacity and rolled over to zero.']
  resolution_action varchar [note: 'Action taken to resolve the meter read exception before billing can proceed.']
  resolution_date date [note: 'Date when the exception was resolved and the read was approved for billing.']
  resolution_notes varchar [note: 'Free-text notes documenting the investigation findings, actions taken, and rationale for the resolution decision.']
  resolution_timestamp timestamp [note: 'Precise timestamp when the exception was resolved and approved for billing.']
  resolved_by varchar [note: 'User ID of the person who resolved the exception and approved the read for billing.']
  reverse_flow_flag boolean [note: 'Indicator that reverse water flow through the meter was detected, potentially indicating meter tampering or backflow condition.']
  signal_strength varchar [note: 'Radio signal strength indicator for Advanced Metering Infrastructure (AMI) communication at time of exception, measured in decibels (dBm).']
  variance_amount decimal(15,3) [note: 'Absolute difference between current and prior read values, measured in gallons or cubic feet.']
  variance_percentage decimal(7,4) [note: 'Percentage variance between current and prior read values, used to identify high/low read anomalies.']

  Note: 'Tracks meter read exceptions and anomalies that require investigation or manual resolution before a read can be used for billing. Stores exception date, meter installation reference, exception type (no read, high read, low read, reverse read, estimated read, communication failure, register overflow), exception code, prior read value, current read value, variance percentage, resolution action (re-read, estimate accepted, read corrected, meter replaced), resolved by, and resolution date. Interfaces with Oracle CC&B exception management workflow.'
}

Table metering.read_route {
  read_route_id varchar [pk, note: 'Primary key for read_route']
  assigned_reader_employee_id varchar [note: 'Employee assigned to read this route']
  billing_cycle_id varchar [note: 'Associated billing cycle']
  dma_id varchar [note: 'FK to district metered area']
  employee_id varchar [note: 'Assigned meter reader ID']
  territory_id varchar [note: 'FK to service territory']
  active_flag boolean [note: 'Whether the route is currently active']
  assigned_reader varchar [note: 'Assigned meter reader name']
  average_read_success_pct decimal(5,2) [note: 'Average read success rate']
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp
  cycle_code varchar
  data_quality_flag boolean [note: 'True when record passed data validation.']
  ending_address varchar [note: 'Route ending address']
  estimated_duration_hours decimal(6,2) [note: 'Estimated time to complete route in hours']
  estimated_duration_min varchar
  estimated_duration_minutes varchar [note: 'Estimated duration minutes']
  estimated_read_hours decimal(8,2)
  estimated_read_minutes varchar
  estimated_read_time_hours decimal(6,2) [note: 'Estimated time to read route']
  geographic_area varchar [note: 'Geographic area covered']
  hazard_notes varchar [note: 'Hazard notes for route']
  hazards_noted varchar [note: 'Hazards noted on route']
  is_active boolean [note: 'Whether route is active']
  last_completion_pct decimal(5,2) [note: 'Completion percentage on last read']
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  last_read_date date [note: 'Date the route was last read']
  meter_count varchar
  next_read_date date [note: 'Next scheduled read date']
  next_scheduled_read_date date [note: 'Next scheduled read date']
  notes varchar [note: 'Route notes']
  read_cycle varchar [note: 'Billing read cycle for the route.']
  read_cycle_days varchar
  read_frequency varchar [note: 'Frequency of reads (monthly, bi-monthly, quarterly)']
  read_frequency_days varchar
  read_method varchar
  read_sequence varchar [note: 'Read sequence order']
  read_sequence_count varchar
  read_sequence_method varchar
  read_sequence_order varchar
  record_status varchar
  route_code varchar
  route_distance_miles decimal(8,2) [note: 'Total route distance']
  route_name varchar
  route_number varchar [note: 'Read route number.']
  route_sequence varchar [note: 'Route sequence number']
  route_status varchar
  route_type varchar [note: 'Type of route (walk, drive-by, AMI)']
  scheduled_read_day varchar [note: 'Scheduled day of month for reading']
  seasonal_end_month varchar [note: 'Seasonal end month']
  seasonal_flag boolean [note: 'Whether route is seasonal']
  seasonal_start_month varchar [note: 'Seasonal start month']
  sequence_method varchar [note: 'Method for sequencing stops']
  sequence_optimized boolean [note: 'Whether route sequence is optimized']
  sequence_order varchar
  special_instructions varchar [note: 'Special reading instructions']
  starting_address varchar [note: 'Route starting address']
  total_route_miles decimal(8,2) [note: 'Total route distance in miles']
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp']
  zip_code varchar [note: 'Primary ZIP code for route']

  Note: 'Defines meter reading routes for AMR drive-by, walk-by, or manual reading operations, organizing meter installations into logical geographic sequences for field reader efficiency. Stores route code, name, assigned reader, read frequency, estimated read date, meter count, geographic area, sequence order, and active status. Used by field operations scheduling and coordinates with billing cycle management for timely consumption data delivery.'
}

Table metering.metering_complaint {
  metering_complaint_id varchar [pk, note: 'Primary key for complaint']
  accuracy_test_id varchar [note: 'Foreign key linking to metering.accuracy_test. Business justification: metering_complaint tracks customer disputes about meter accuracy and captures meter_test_ordered_flag, meter_test_date, meter_test_result, meter_accuracy_percent but lacks FK to the actual accuracy_te']
  customer_account_id varchar [note: 'Customer who filed complaint']
  customer_complaint_id varchar [note: 'Canonical single-source-of-truth reference to customer.customer_complaint (customer_complaint_id); this entity defers authoritative attribute values to that master entity.']
  meter_installation_id varchar [note: 'Foreign key linking to metering.installation. Business justification: Customer complaints about metering (high bill complaints, meter accuracy disputes, read disputes) are specific to a meter installation at a service address. This FK links the complaint to the installa']
  metering_assigned_employee_id varchar [note: 'Employee assigned to investigate']
  read_id varchar [note: 'Foreign key linking to metering.read. Business justification: Many metering complaints reference a specific disputed meter read (e.g., \'the read on my January bill is wrong\'). This FK links the complaint to the specific read being disputed. Should be nullable fo']
  work_order_id varchar [note: 'Foreign key linking to asset.work_order. Business justification: Customer complaints about meters (high bills, suspected leaks, accuracy concerns) are investigated via work orders. Standard utility customer service workflow linking complaint intake to field resolut']
  adjustment_amount decimal(18,2) [note: 'Recommended adjustment amount']
  adjustment_recommended boolean [note: 'Whether adjustment recommended']
  assigned_date date [note: 'Date assigned for investigation']
  assigned_to varchar [note: 'Assigned technician/team']
  billing_adjustment_amount decimal(18,2) [note: 'Billing adjustment amount if applicable']
  billing_impact_flag boolean [note: 'Whether complaint has billing impact']
  complaint_category varchar
  complaint_date date
  complaint_description varchar [note: 'Detailed complaint description']
  complaint_number varchar
  complaint_source varchar [note: 'Source of complaint (phone, web, walk-in)']
  complaint_status varchar
  complaint_type varchar
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp
  customer_name varchar [note: 'Customer name']
  customer_notified_date date
  customer_phone varchar [note: 'Customer phone number']
  customer_satisfaction_rating varchar [note: 'Customer satisfaction score']
  customer_satisfied boolean [note: 'Whether customer was satisfied']
  data_quality_flag boolean [note: 'True when record passed data validation.']
  days_to_resolve varchar [note: 'Number of days to resolve']
  disputed_amount decimal(18,2) [note: 'Amount in dispute']
  disputed_amount_usd decimal(18,2)
  disputed_consumption decimal(14,2) [note: 'Consumption in dispute']
  escalated boolean [note: 'Whether complaint was escalated']
  escalated_flag boolean [note: 'Whether complaint was escalated']
  escalation_reason varchar [note: 'Reason for escalation']
  field_visit_required_flag boolean [note: 'Whether field visit is needed']
  investigation_date date [note: 'Date of investigation']
  investigation_findings varchar [note: 'Investigation findings']
  investigation_required boolean [note: 'Whether investigation required']
  is_escalated boolean
  is_resolved boolean [note: 'Whether complaint is resolved.']
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  meter_test_requested boolean [note: 'Whether meter test was requested']
  meter_test_required boolean [note: 'Whether meter test required']
  meter_test_result varchar [note: 'Meter test result']
  meter_tested boolean [note: 'Whether meter was tested']
  metering_complaint_description varchar [note: 'Complaint description.']
  notes varchar [note: 'Complaint notes']
  priority varchar [note: 'Complaint priority.']
  priority_level varchar [note: 'Priority level']
  received_date date [note: 'Date complaint received.']
  received_method varchar [note: 'How complaint was received (phone, email, web, walk_in)']
  record_status varchar
  reported_by_name varchar
  reported_by_phone varchar
  reported_date date [note: 'Reported date']
  reported_timestamp timestamp
  resolution varchar [note: 'Resolution summary.']
  resolution_action varchar
  resolution_date date
  resolution_description varchar [note: 'Resolution description']
  resolution_notes varchar
  resolution_type varchar [note: 'Type of resolution']
  resolved_date date [note: 'Date complaint resolved.']
  root_cause varchar [note: 'Identified root cause']
  service_address varchar [note: 'Service address related to complaint']
  ssot_source_domain varchar [note: 'SSOT owner is customer domain']
  test_result_accuracy_pct decimal(6,3) [note: 'Accuracy test result if tested']
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp']

  Note: 'Records customer-initiated complaints and disputes related to metering, including high bill complaints, meter accuracy disputes, estimated bill objections, and AMI data concerns. Captures complaint date, customer account reference, meter installation reference, complaint type, complaint description, consumption period in dispute, disputed amount, investigation assigned to, investigation findings, resolution type (meter test ordered, read corrected, bill adjusted, complaint dismissed), resolution date, and customer satisfaction outcome. Interfaces with Microsoft Dynamics 365 CRM case management. [SSOT: governed by customer.customer_complaint] [DEPRECATED: Single source of truth is customer.customer_complaint]'
}

Table metering.meter_field_inspection {
  meter_field_inspection_id varchar [pk, note: 'Unique identifier for the meter field inspection record. Primary key.']
  ami_endpoint_id varchar [note: 'Foreign key linking to metering.ami_endpoint. Business justification: meter_field_inspection records physical inspection of meter installations and captures AMI endpoint condition attributes (ami_endpoint_condition, ami_antenna_condition, ami_signal_strength_dbm, ami_ba']
  follow_up_work_order_id varchar [note: 'Reference to the follow-up work order created in IBM Maximo based on the inspection findings and recommended actions.']
  inspector_employee_id varchar [note: 'Reference to the employee who performed the field inspection. Links to workforce employee record.']
  material_requisition_id varchar [note: 'Foreign key linking to supply.material_requisition. Business justification: Field inspections identify needed materials (repair parts, replacement registers, seals) and generate material requisitions. Inspector identifies failed component during inspection, creates requisitio']
  meter_installation_id varchar [note: 'Reference to the meter installation being inspected. Links to the meter installation record in the metering domain.']
  premise_id varchar [note: 'Foreign key linking to customer.premise. Business justification: Inspections verify premise-level meter conditions and infrastructure. Required for correlating inspection findings with premise characteristics, prioritizing premise upgrades, and tracking compliance ']
  service_address_id varchar [note: 'Foreign key linking to customer.service_address. Business justification: Field inspections occur at service addresses. Essential for inspection routing, GPS navigation, verifying physical location matches records, and coordinating customer access for vault/pit inspections ']
  service_line_id varchar [note: 'Foreign key linking to distribution.service_line. Business justification: LCRR compliance requires visual verification of service line material during meter field inspections. Inspectors document service line condition, material type, and leak evidence. Links inspection fin']
  ami_antenna_condition varchar [note: 'Condition of the AMI endpoint antenna: intact, damaged, missing, or corroded. Critical for radio frequency communication performance.']
  ami_battery_voltage decimal(5,2) [note: 'Battery voltage of the AMI endpoint measured during the field inspection, used to predict remaining battery life and schedule replacements.']
  ami_endpoint_condition varchar [note: 'Physical condition assessment of the AMI endpoint device: excellent, good, fair, poor, missing, or damaged. Evaluates antenna, housing, and mounting integrity.']
  ami_signal_strength_dbm decimal(6,2) [note: 'Signal strength of the AMI endpoint measured in decibels-milliwatts (dBm) during the field inspection, used to assess communication quality.']
  created_timestamp timestamp [note: 'Timestamp when the inspection record was first created in the system.']
  gps_accuracy_meters decimal(6,2) [note: 'GPS coordinate accuracy measured in meters, indicating the precision of the location capture during the field inspection.']
  gps_latitude decimal(10,7) [note: 'GPS latitude coordinate captured during the field inspection, used to verify meter location and update GIS records.']
  gps_longitude decimal(10,7) [note: 'GPS longitude coordinate captured during the field inspection, used to verify meter location and update GIS records.']
  inspection_date date [note: 'Date when the field inspection was performed.']
  inspection_duration_minutes decimal(18,6) [note: 'Duration of the field inspection in minutes, used for workforce productivity analysis and route optimization.']
  inspection_notes varchar [note: 'Free-text notes and observations recorded by the inspector during the field inspection, capturing additional details not covered by structured fields.']
  inspection_number varchar [note: 'Unique business identifier for the field inspection, typically generated by the CMMS or field service system.']
  inspection_status varchar [note: 'Current lifecycle status of the inspection: scheduled, in progress, completed, cancelled, failed, or pending review.']
  inspection_timestamp timestamp [note: 'Precise date and time when the field inspection was performed, including time zone information.']
  inspection_type varchar [note: 'Classification of the inspection purpose: routine scheduled inspection, complaint-driven investigation, post-repair verification, pre-replacement assessment, accuracy verification, leak investigation, tamper investigation, high usage investigation, AMI endpoint physical check, or regulatory compliance inspection. [ENUM-REF-CANDIDATE: routine|complaint_driven|post_repair|pre_replacement|accuracy_verification|leak_investigation|tamper_investigation|high_usage_investigation|ami_endpoint_check|regulatory_compliance — 10 candidates stripped; promote to reference product]']
  inspector_name varchar [note: 'Full name of the inspector who performed the field inspection.']
  last_modified_timestamp timestamp [note: 'Timestamp when the inspection record was last modified in the system.']
  leak_description varchar [note: 'Detailed description of any leak detected during the inspection, including location, severity, and estimated flow rate if observable.']
  leak_detected_flag boolean [note: 'Indicates whether a leak was detected at the meter installation during the field inspection, including meter body leaks, connection leaks, or service line leaks.']
  meter_condition_rating varchar [note: 'Overall condition assessment of the meter based on visual inspection: excellent, good, fair, poor, or failed. Used for asset health scoring and replacement prioritization.']
  obstruction_description varchar [note: 'Detailed description of any obstructions noted during the inspection that prevent or hinder meter access.']
  obstruction_noted_flag boolean [note: 'Indicates whether any obstructions were noted that prevent or hinder access to the meter installation, such as landscaping, vehicles, structures, or locked gates.']
  photo_count varchar [note: 'Number of photographs captured during the field inspection for documentation and evidence purposes.']
  photo_evidence_reference varchar [note: 'Reference identifier or file path to photographic evidence captured during the field inspection, stored in the document management system.']
  pit_debris_present_flag boolean [note: 'Indicates whether debris, sediment, or foreign objects are present in the meter pit or vault that may interfere with meter operation or access.']
  pit_vault_condition varchar [note: 'Condition assessment of the meter pit or vault: excellent, good, fair, poor, or hazardous. Includes evaluation of structural integrity, water intrusion, and safety hazards.']
  pit_water_present_flag boolean [note: 'Indicates whether standing water is present in the meter pit or vault, which may indicate drainage issues, leaks, or groundwater infiltration.']
  priority_level varchar [note: 'Priority level assigned to any follow-up action required based on inspection findings: critical, high, medium, or low.']
  recommended_action varchar [note: 'Inspector\'s recommended action based on the field inspection findings: none, monitor, repair, replace, clean, recalibrate, investigate, upgrade AMI endpoint, or seal replacement. [ENUM-REF-CANDIDATE: none|monitor|repair|replace|clean|recalibrate|investigate|upgrade_ami|seal_replacement — 9 candidates stripped; promote to reference product]']
  register_readable_flag boolean [note: 'Indicates whether the meter register is readable and visible during the inspection. False may indicate fogging, damage, or obstruction.']
  register_reading decimal(15,3) [note: 'Current register reading captured during the field inspection, measured in gallons or cubic feet depending on meter configuration.']
  register_unit_of_measure varchar [note: 'Unit of measure for the register reading: gallons, cubic feet, or cubic meters.']
  seal_intact_flag boolean [note: 'Indicates whether the meter seal is intact and unbroken. False indicates potential tampering or unauthorized access requiring investigation.']
  seal_number_verified varchar [note: 'Seal number observed during the inspection, used to verify against the installation record and detect unauthorized seal replacement.']
  tamper_description varchar [note: 'Detailed description of any tampering evidence observed during the inspection, used for revenue protection investigations.']
  tamper_evidence_flag boolean [note: 'Indicates whether evidence of tampering was observed during the inspection, such as broken seals, unauthorized modifications, bypass piping, or meter reversal.']

  Note: 'Records field inspection visits to meter installations for condition assessment, seal verification, pit/vault inspection, and AMI endpoint physical check. Captures inspection date, meter installation reference, inspector employee ID, inspection type (routine, complaint-driven, post-repair, pre-replacement), meter condition rating, pit/vault condition, seal intact flag, AMI antenna condition, obstructions noted, photographic evidence reference, recommended action, and follow-up work order reference in IBM Maximo. Supports proactive asset management and revenue protection.'
}

Table metering.ami_network_collector {
  ami_network_collector_id varchar [pk, note: 'Unique identifier for the AMI network collector device. Primary key for the collector registry.']
  ami_asset_registry_id varchar [note: 'Reference to the asset registry entry for this collector device in the CMMS (IBM Maximo). Links AMI network data to enterprise asset management for maintenance scheduling, depreciation, and lifecycle tracking.']
  ami_registry_id varchar [note: 'Reference to the asset registry entry for this collector device in the CMMS (IBM Maximo). Links AMI network data to enterprise asset management for maintenance scheduling, depreciation, and lifecycle tracking.']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Network collectors installed as AMI infrastructure projects require project linkage for warranty management, project performance evaluation, capital cost allocation, and asset capitalization. Critical']
  dma_id varchar [note: 'Identifier of the district metered area that this collector primarily serves. Used for aligning AMI network topology with hydraulic zones for non-revenue water analysis.']
  fixed_asset_id varchar [note: 'Foreign key linking to finance.fixed_asset. Business justification: AMI collectors are capitalized infrastructure assets requiring fixed asset register inclusion for depreciation, net book value tracking, and GASB capital asset reporting. Each collector has acquisitio']
  installation_work_order_id varchar [note: 'Reference to the work order that authorized and documented the installation of this collector device. Used for audit trail and cost tracking.']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Network collectors are capital assets procured as materials, tracked for inventory, installation work orders, warranty, and spare parts management. Procurement orders collectors by material number; wa']
  backhaul_connection_type varchar [note: 'Type of wide-area network connection used to transmit collected meter data from the collector to the central AMI head-end system. Cellular and fiber are most common for fixed base stations.']
  backhaul_provider varchar [note: 'Name of the telecommunications carrier or internet service provider supplying the backhaul connection for this collector. Used for vendor management and service level agreement tracking.']
  battery_backup_flag boolean [note: 'Indicates whether the collector device has battery backup power to maintain operation during AC power outages. True if battery backup is installed and functional.']
  city varchar [note: 'City or municipality where the collector device is installed.']
  collector_identifier varchar [note: 'Externally-known unique identifier or serial number assigned to the collector device by the manufacturer or utility. Used for field operations and inventory tracking.']
  collector_type varchar [note: 'Classification of the collector device based on its deployment mode and function within the AMI network topology. Fixed base stations are permanently installed, mobile collectors are vehicle-mounted for drive-by reading, and repeaters extend network coverage.']
  communication_protocol varchar [note: 'Radio frequency communication protocol used by the collector to communicate with AMI endpoints. FlexNet is the Sensus proprietary protocol; other protocols may be used in hybrid deployments.']
  country_code varchar [note: 'Three-letter ISO country code for the collector installation location.']
  coverage_radius_miles decimal(6,2) [note: 'Estimated radio frequency coverage radius in miles for the collector device. Defines the geographic area within which AMI endpoints can communicate with this collector. Used for network planning and coverage gap analysis.']
  created_timestamp timestamp [note: 'Timestamp when this collector record was first created in the AMI system. Used for data lineage and audit purposes.']
  decommission_date date [note: 'Date when the collector device was removed from service or retired from the AMI network. Null for active collectors.']
  elevation_feet decimal(8,2) [note: 'Elevation above sea level in feet where the collector device is installed. Critical for tower-mounted collectors and radio frequency propagation modeling.']
  endpoint_capacity varchar [note: 'Maximum number of AMI endpoints that this collector device can support based on manufacturer specifications and network design. Used for capacity planning and network expansion.']
  endpoint_count varchar [note: 'Current number of AMI endpoints (meters) actively registered and communicating through this collector. Used for load balancing and capacity planning.']
  firmware_update_date date [note: 'Date when the collector firmware was last updated. Used for tracking patch compliance and planning future updates.']
  firmware_version varchar [note: 'Current firmware version installed on the collector device. Critical for security patch management, feature availability, and troubleshooting. Format varies by manufacturer.']
  frequency_mhz decimal(8,3) [note: 'Radio frequency in megahertz on which the collector operates. Common frequencies include 900 MHz and 450 MHz bands. Critical for regulatory compliance and interference management.']
  gis_latitude decimal(10,7) [note: 'Latitude coordinate of the collector device location in decimal degrees. Used for GIS mapping, coverage analysis, and network topology visualization in ArcGIS.']
  gis_longitude decimal(11,7) [note: 'Longitude coordinate of the collector device location in decimal degrees. Used for GIS mapping, coverage analysis, and network topology visualization in ArcGIS.']
  health_status varchar [note: 'Overall health assessment of the collector device based on communication frequency, signal quality, error rates, and diagnostic metrics. Healthy indicates normal operation; degraded indicates performance issues; critical indicates imminent failure risk; offline indicates no communication.']
  installation_date date [note: 'Date when the collector device was physically installed and commissioned in the field. Used for asset lifecycle tracking and warranty management.']
  installation_timestamp timestamp [note: 'Precise timestamp when the collector device was activated and began communicating with the AMI network. Provides exact commissioning time for audit and troubleshooting purposes.']
  ip_address varchar [note: 'IP address assigned to the collector device for network communication and remote management. May be static or dynamic depending on backhaul configuration.']
  last_communication_timestamp timestamp [note: 'Timestamp of the most recent successful communication between the collector and the AMI head-end system. Used for health monitoring and outage detection.']
  last_modified_timestamp timestamp [note: 'Timestamp when this collector record was most recently updated. Used for change tracking and data quality monitoring.']
  mac_address varchar [note: 'Hardware MAC address of the collector device network interface. Used for device authentication and network management.']
  notes varchar [note: 'Free-form text field for operational notes, special instructions, site access details, or historical information about the collector device. Used by field technicians and network engineers.']
  operational_status decimal(18,6) [note: 'Current operational state of the collector device in the AMI network. Active collectors are in service and communicating with endpoints; inactive collectors are installed but not operational; maintenance indicates scheduled or unscheduled service; decommissioned collectors are retired from service.']
  physical_address_line1 varchar [note: 'Primary street address line where the collector device is physically installed. Used for field service dispatch and asset location management.']
  physical_address_line2 varchar [note: 'Secondary address line for additional location details such as building, suite, or tower designation.']
  postal_code varchar [note: 'Postal or ZIP code for the collector installation location.']
  power_source varchar [note: 'Primary power source for the collector device. AC mains is typical for fixed base stations; solar and battery are used for remote or mobile installations.']
  service_territory_code varchar [note: 'Code identifying the utility service territory or operating region where the collector is deployed. Used for multi-jurisdiction utilities and regional reporting.']
  signal_strength_dbm decimal(6,2) [note: 'Most recent backhaul signal strength measurement in dBm. Used for diagnosing connectivity issues and optimizing network performance. Typical range is -50 dBm (excellent) to -110 dBm (poor).']
  state_province varchar [note: 'State or province code where the collector device is located. Typically two-letter abbreviation for US states.']

  Note: 'Master record for each AMI fixed network collector (base station, tower-mounted receiver, or mobile collector) in the Sensus FlexNet infrastructure. Stores collector ID, collector type (fixed base station, mobile collector, repeater), physical location (address and GIS coordinates), coverage radius, number of endpoints served, communication protocol, backhaul connection type (cellular, fiber, DSL), installation date, firmware version, and operational status. Defines the AMI network topology that enables automated meter reading across the service territory.'
}

Table metering.meter_size_type {
  meter_size_type_id varchar [pk, note: 'Unique identifier for the meter size and type combination. Primary key for the reference table.']
  primary_replacement_meter_size_type_id varchar [note: 'Reference to the successor meter size and type that replaces this obsolete configuration. Null if no replacement defined.']
  accuracy_class varchar [note: 'AWWA or ISO accuracy classification for meters of this size (e.g., AWWA Class I, Class II; ISO R160, R250). Defines expected measurement precision and testing requirements.']
  accuracy_percentage_low_flow decimal(5,2) [note: 'Expected measurement accuracy as a percentage at the minimum detectable flow rate. Critical for NRW analysis.']
  accuracy_percentage_normal_flow decimal(5,2) [note: 'Expected measurement accuracy as a percentage at normal operating flow rate.']
  active_flag boolean [note: 'Indicates whether this meter size and type is currently approved for new installations in the utility service territory.']
  ami_compatible_flag boolean [note: 'Indicates whether this meter size and type can be equipped with AMI endpoints for remote reading and interval data collection.']
  amr_compatible_flag boolean [note: 'Indicates whether this meter size and type can be equipped with AMR endpoints for drive-by or walk-by reading.']
  average_unit_cost_usd decimal(10,2) [note: 'Average procurement cost in United States Dollars (USD) for a meter of this size including hardware but excluding installation labor. Used for budgeting and capital planning.']
  awwa_standard_code varchar [note: 'Applicable AWWA standard governing this meter size and type (e.g., C700, C701, C702, C706, C708, C710, C713).']
  connection_type varchar [note: 'Standard connection method for meters of this size (threaded, flanged, compression, saddle, direct bury). Determines installation requirements and compatibility.']
  created_timestamp timestamp [note: 'Timestamp when this meter size and type record was first created in the system.']
  display_name varchar [note: 'Human-readable display name for the meter size (e.g., \'5/8 inch\', \'3/4 inch\', \'1 inch\', \'2 inch\'). Used in user interfaces, reports, and customer communications.']
  effective_date date [note: 'Date when this meter size and type was approved for use in the utility service territory.']
  effective_end_date date [note: 'Date when this meter size type was discontinued or superseded. Null for currently active meter size types. Used for phase-out planning and historical analysis.']
  effective_start_date date [note: 'Date when this meter size type became available for use in the utility\'s meter inventory. Supports historical tracking and version control.']
  expected_service_life_years varchar [note: 'Typical operational lifespan in years before meter replacement is recommended due to accuracy degradation.']
  flange_standard varchar [note: 'Flange specification for flanged connections (e.g., ANSI Class 125, ANSI Class 250). Applicable to larger meter sizes requiring bolted connections.']
  installation_labor_hours decimal(5,2) [note: 'Typical labor hours required to install or replace a meter of this size. Used for work order planning, crew scheduling, and cost estimation.']
  installation_orientation varchar [note: 'Required or recommended installation orientation for accurate measurement (horizontal, vertical, or any orientation).']
  last_modified_timestamp timestamp [note: 'Timestamp when this meter size and type record was last updated.']
  lead_free_certified_flag boolean [note: 'Indicates whether this meter size and type meets lead-free certification requirements under the Safe Drinking Water Act and LCRR.']
  length_inches decimal(6,2) [note: 'Overall length of the meter body in inches. Critical for vault and pit sizing during installation.']
  max_continuous_flow_gpm decimal(10,2) [note: 'Maximum flow rate in gallons per minute that the meter can sustain continuously without damage or accuracy degradation.']
  max_registered_flow_gpm decimal(10,2) [note: 'Peak flow rate in gallons per minute that the meter can register accurately for short durations.']
  maximum_flow_rate_gpm decimal(10,3) [note: 'Maximum continuous flow rate in gallons per minute (GPM) for meters of this size. Defines the upper capacity limit for safe and accurate operation.']
  maximum_intermittent_flow_rate_gpm decimal(10,3) [note: 'Maximum short-duration or peak flow rate in gallons per minute (GPM) that the meter can handle without damage. Used for surge and peak demand scenarios.']
  measurement_class varchar [note: 'AWWA accuracy classification (Class I through Class IV). Higher classes indicate greater accuracy at low flow rates.']
  meter_size_inches decimal(5,3) [note: 'Nominal diameter of the meter in inches. Standard sizes include 5/8, 3/4, 1, 1.5, 2, 3, 4, 6, 8, 10, 12 inches per AWWA standards.']
  meter_size_type_description varchar [note: 'Detailed description of the meter size type including typical applications, customer classes, and usage characteristics (e.g., \'Standard residential meter for single-family homes\').']
  meter_size_type_status varchar [note: 'Current lifecycle status of this meter size type in the reference catalog (active, inactive, obsolete, pending approval). Controls availability for new installations.']
  meter_type varchar [note: 'Technology classification of the water meter. Defines the measurement principle used to register flow.']
  min_detectable_flow_gpm decimal(10,4) [note: 'Lowest flow rate in gallons per minute that the meter can detect and register. Critical for leak detection and low-flow accuracy.']
  minimum_flow_rate_gpm decimal(10,3) [note: 'Minimum measurable flow rate in gallons per minute (GPM) for meters of this size. Defines the lower accuracy threshold for consumption measurement.']
  normal_operating_flow_gpm decimal(10,2) [note: 'Typical sustained flow rate in gallons per minute for which the meter is optimally designed. Used for meter sizing and selection.']
  normal_operating_flow_rate_gpm decimal(10,3) [note: 'Typical or recommended operating flow rate in gallons per minute (GPM) for optimal meter accuracy and longevity. Used for sizing and capacity planning.']
  notes varchar [note: 'Additional technical notes, installation guidance, or special considerations for this meter size and type.']
  nsf_61_certified_flag boolean [note: 'Indicates whether this meter is certified to NSF/ANSI Standard 61 for drinking water system components.']
  obsolete_date date [note: 'Date when this meter size and type was discontinued or phased out for new installations. Null if still active.']
  pressure_loss_at_max_flow_psi decimal(6,2) [note: 'Expected pressure loss in pounds per square inch (PSI) across the meter at maximum continuous flow rate. Critical for hydraulic modeling and system pressure management.']
  pressure_rating_psi varchar [note: 'Maximum working pressure in pounds per square inch that the meter can withstand without failure.']
  register_capacity_gallons varchar [note: 'Maximum cumulative volume in gallons that the meter register can display before rolling over. Important for billing cycle planning and register overflow detection.']
  register_type varchar [note: 'Type of register used to display consumption. Mechanical for analog dials, electronic for digital displays, encoder for AMI/AMR integration.']
  service_connection_type varchar [note: 'Standard connection method for installing this meter size (threaded, flanged, or compression fitting).']
  size_code varchar [note: 'Short alphanumeric code representing the meter size (e.g., 5/8, 3/4, 1, 1.5, 2, 3, 4, 6, 8, 10, 12). Used as a lookup key in operational systems.']
  size_inches decimal(5,3) [note: 'Nominal diameter of the meter in inches (e.g., 0.625 for 5/8 inch, 0.75 for 3/4 inch, 1.0, 1.5, 2.0, etc.). Primary measurement for meter sizing and capacity planning.']
  size_millimeters decimal(6,2) [note: 'Nominal diameter of the meter in millimeters (e.g., 15mm, 20mm, 25mm, 40mm, 50mm, etc.). Used for international standards compliance and metric system reporting.']
  sort_order varchar [note: 'Numeric value controlling the display sequence of meter sizes in user interfaces and reports (typically ordered from smallest to largest).']
  straight_pipe_downstream_inches varchar [note: 'Minimum length of straight pipe required downstream of the meter in inches to ensure accurate flow measurement.']
  straight_pipe_upstream_inches varchar [note: 'Minimum length of straight pipe required upstream of the meter in inches to ensure accurate flow measurement.']
  temperature_rating_fahrenheit_max varchar [note: 'Maximum water temperature in Fahrenheit at which the meter maintains accuracy and structural integrity.']
  temperature_rating_fahrenheit_min varchar [note: 'Minimum water temperature in Fahrenheit at which the meter maintains accuracy and structural integrity.']
  testing_frequency_years varchar [note: 'Recommended interval in years between accuracy testing and calibration per regulatory and utility standards.']
  thread_standard varchar [note: 'Thread specification for threaded connections (e.g., NPT, BSPT, AWWA). Ensures compatibility with service line fittings and meter setters.']
  typical_application varchar [note: 'Standard use case for this meter size and type (e.g., single-family residential, multi-family residential, commercial, industrial, fire service, irrigation).']
  typical_customer_class varchar [note: 'Primary customer class typically served by this meter size (residential, commercial, industrial, institutional, agricultural, municipal). Used for rate structure and billing configuration.']
  typical_service_life_years varchar [note: 'Expected operational service life in years for meters of this size under normal operating conditions. Used for asset replacement planning and depreciation schedules.']
  weight_pounds decimal(8,2) [note: 'Approximate weight of the meter in pounds. Used for logistics, installation planning, and safety assessments.']

  Note: 'Master reference table for meter_size_type. '
}

Table metering.endpoint_procurement {
  endpoint_procurement_id varchar [pk, note: 'Primary key for the endpoint_procurement association']
  ami_endpoint_id varchar [note: 'Foreign key linking to the AMI endpoint device that was procured from this vendor']
  goods_receipt_id varchar [note: 'FK to goods receipt']
  purchase_order_id varchar [note: 'FK to purchase order']
  vendor_id varchar [note: 'Foreign key linking to the vendor who supplied this AMI endpoint']
  acceptance_test_passed_flag boolean [note: 'Indicates whether the endpoint passed incoming acceptance testing.']
  actual_delivery_date date [note: 'Actual delivery date of the endpoints.']
  batch_number varchar [note: 'Manufacturing batch number for traceability.']
  battery_life_years varchar [note: 'Expected battery life in years']
  buy_america_compliant boolean [note: 'Whether endpoint meets Buy America requirements']
  certification_standard varchar [note: 'Certification standard met by the endpoint (e.g., FCC, CE)']
  communication_protocol varchar [note: 'Communication protocol of endpoints']
  country_of_origin varchar [note: 'Country where endpoint was manufactured']
  data_transmission_interval_min varchar [note: 'Data transmission interval in minutes']
  defect_count varchar [note: 'Number of defective units found']
  delivery_date date [note: 'Actual delivery date']
  encryption_supported boolean [note: 'Whether encryption is supported']
  endpoint_manufacturer varchar [note: 'Manufacturer of the AMI endpoint.']
  endpoint_model varchar [note: 'Model of the AMI endpoint']
  expected_delivery_date date [note: 'Expected delivery date for the procurement order.']
  expected_lifespan_years varchar [note: 'Expected lifespan of the endpoint in years']
  extended_warranty_end_date date [note: 'End date of extended warranty']
  extended_warranty_purchased boolean [note: 'Whether extended warranty was purchased']
  firmware_version varchar [note: 'Firmware version at procurement']
  inspection_date date [note: 'Date of receiving inspection']
  inspection_passed_flag boolean [note: 'Indicates if receiving inspection passed']
  ip_rating varchar [note: 'Ingress protection rating']
  lead_time_days varchar [note: 'Number of days from order to delivery.']
  maintenance_contract_flag boolean [note: 'Whether maintenance contract is in place']
  manufacturer_name varchar [note: 'Name of endpoint manufacturer']
  model_number varchar [note: 'Manufacturer model number of the endpoint.']
  network_compatibility varchar [note: 'Network compatibility specification']
  notes varchar [note: 'Additional procurement notes.']
  procurement_date date [note: 'Date when this endpoint was procured from this vendor. Used for tracking procurement history.']
  procurement_order_number varchar [note: 'Purchase order number associated with this procurement transaction.']
  procurement_status varchar [note: 'Current status of the procurement (e.g., ordered, shipped, received, deployed).']
  purchase_price decimal(12,2) [note: 'Price paid to this vendor for this specific endpoint device. Explicitly identified in detection phase relationship data.']
  quantity_ordered varchar [note: 'Number of endpoints ordered']
  quantity_received varchar [note: 'Number of endpoints received']
  receiving_date date [note: 'Date the endpoints were received at the warehouse.']
  receiving_location varchar [note: 'Location where endpoints were received']
  return_authorization_number varchar [note: 'RMA number for defective returns']
  rohs_compliant boolean [note: 'Whether endpoint is RoHS compliant']
  signal_strength_dbm decimal(6,2) [note: 'Minimum signal strength in dBm']
  spare_parts_included boolean [note: 'Whether spare parts were included in procurement']
  support_contract_number varchar [note: 'Vendor-assigned support contract identifier for technical support escalation. Explicitly identified in detection phase relationship data.']
  tamper_detection_capable boolean [note: 'Indicates if endpoint has tamper detection capability']
  temperature_range_max_f decimal(6,2) [note: 'Maximum operating temperature in Fahrenheit']
  temperature_range_min_f decimal(6,2) [note: 'Minimum operating temperature in Fahrenheit']
  total_cost decimal(18,2) [note: 'Total cost of the endpoint procurement.']
  ul_listing_number varchar [note: 'UL listing number if applicable']
  unit_cost decimal(12,2) [note: 'Cost per endpoint unit']
  vendor_part_number varchar [note: 'Vendor-specific part number or SKU for this endpoint model. Used for reordering and warranty claims. Explicitly identified in detection phase relationship data.']
  warranty_end_date date [note: 'Date when the vendor warranty coverage expires for this endpoint. Explicitly identified in detection phase relationship data.']
  warranty_start_date date [note: 'Date when the vendor warranty coverage begins for this endpoint. Explicitly identified in detection phase relationship data.']

  Note: 'This association product represents the procurement relationship between AMI endpoints and vendors. It captures vendor-specific procurement details for each endpoint device, including warranty terms, purchase pricing, vendor part numbers, and support contract information. Each record links one AMI endpoint to one vendor with attributes that exist only in the context of this procurement relationship.. Existence Justification: In water utility operations, AMI endpoints can be procured from multiple vendors over their lifecycle (original manufacturer, replacement parts distributor, warranty service provider), and each vendor supplies multiple endpoint devices across the utility\'s service territory. The utility actively manages vendor-specific procurement records for warranty claims, technical support escalation, and replacement part sourcing, with each vendor relationship carrying distinct warranty terms, pricing, part numbers, and support contracts.'
}

Table metering.meter_procurement {
  meter_procurement_id varchar [pk, note: 'Unique identifier for this meter-vendor procurement record. Primary key.']
  goods_receipt_id varchar [note: 'FK to goods receipt']
  meter_size_type_id varchar [note: 'Foreign key linking to metering.meter_size_type. Business justification: meter_procurement represents the procurement relationship between physical meters and vendors. Each procurement is for a specific meter size/type (e.g., 5/8-inch residential, 2-inch commercial). Addin']
  metering_meter_id varchar [note: 'Foreign key linking to the physical meter device in the metering domain']
  purchase_order_id varchar [note: 'FK to purchase order']
  vendor_id varchar [note: 'Foreign key linking to the vendor/supplier in the supply domain']
  acceptance_test_passed_flag boolean [note: 'Whether acceptance testing was passed']
  accuracy_class varchar [note: 'Accuracy class per AWWA standards']
  actual_delivery_date date [note: 'Actual delivery date of the meters.']
  ami_compatible boolean [note: 'Whether meter is AMI compatible']
  awwa_standard varchar [note: 'AWWA standard compliance (e.g., C700, C708)']
  batch_number varchar [note: 'Manufacturing batch number for traceability.']
  buy_america_compliant boolean [note: 'Whether meter meets Buy America requirements']
  calibration_certificate_number varchar [note: 'Factory calibration certificate number']
  connection_type varchar [note: 'Connection type (flanged, threaded, etc.)']
  country_of_origin varchar [note: 'Country where meter was manufactured']
  created_timestamp timestamp [note: 'Timestamp when the procurement record was created.']
  defect_count varchar [note: 'Number of defective meters found']
  delivery_date date [note: 'Actual delivery date']
  expected_delivery_date date [note: 'Expected delivery date for the meter order.']
  expected_lifespan_years varchar [note: 'Expected operational lifespan of the meter in years.']
  extended_warranty_end_date date [note: 'End date of extended warranty']
  extended_warranty_purchased boolean [note: 'Whether extended warranty was purchased']
  flow_range_max_gpm decimal(10,4) [note: 'Maximum flow rate in gallons per minute']
  flow_range_min_gpm decimal(10,4) [note: 'Minimum flow rate in gallons per minute']
  freeze_protection_rating varchar [note: 'Freeze protection rating of the meter']
  high_flow_accuracy_pct decimal(5,2) [note: 'Accuracy percentage at high flow rates']
  inspection_date date [note: 'Date of receiving inspection']
  inspection_passed_flag boolean [note: 'Indicates if receiving inspection passed']
  lead_free_certified boolean [note: 'Whether meter is certified lead-free']
  lead_time_days varchar [note: 'Standard lead time in days for this vendor to deliver this meter model. Used for procurement planning and emergency replacement sourcing.']
  low_flow_accuracy_pct decimal(5,2) [note: 'Accuracy percentage at low flow rates']
  manufacturer_name varchar [note: 'Name of meter manufacturer']
  meter_manufacturer varchar [note: 'Name of the meter manufacturer.']
  meter_model varchar [note: 'Model of the meter']
  meter_technology varchar [note: 'Technology type of meter (positive displacement, ultrasonic, etc.)']
  notes varchar [note: 'Additional procurement notes.']
  nsf_61_certified boolean [note: 'Whether meter is NSF 61 certified for drinking water']
  nsf_certification varchar [note: 'NSF certification level for potable water contact']
  pressure_rating_psi decimal(8,2) [note: 'Maximum pressure rating in PSI']
  procurement_status varchar [note: 'Current status of this meter-vendor procurement relationship: Active (current source), Discontinued (no longer available), Preferred (primary supplier), Backup (secondary source), Under_Review (being evaluated).']
  purchase_date date [note: 'The date this specific meter was purchased from this vendor. Used for warranty period calculation and procurement history tracking.']
  purchase_price decimal [note: 'The unit price paid to this vendor for this meter at time of purchase. Enables cost analysis and vendor price comparison for competitive bidding.']
  quantity_ordered varchar [note: 'Number of meters ordered']
  quantity_received varchar [note: 'Number of meters received']
  receiving_date date [note: 'Date the meters were received at the warehouse.']
  receiving_location varchar [note: 'Location where meters were received']
  register_type varchar [note: 'Type of register (mechanical, electronic)']
  return_authorization_number varchar [note: 'RMA number for defective returns']
  spare_parts_kit_included boolean [note: 'Whether spare parts kit was included']
  test_report_number varchar [note: 'Factory test report number']
  total_cost decimal(18,2) [note: 'Total cost of the meter procurement.']
  vendor_part_number varchar [note: 'The vendor-specific part number or SKU for this meter model as cataloged by this particular vendor. Critical for procurement orders and warranty claims.']
  warranty_end_date date [note: 'The date warranty coverage expires for this meter from this vendor. Critical for warranty claim eligibility and maintenance planning.']
  warranty_start_date date [note: 'The date warranty coverage begins for this meter from this vendor. May differ from purchase date based on installation or activation terms.']

  Note: 'This association product represents the procurement relationship between physical meter devices and their suppliers. It captures vendor-specific procurement terms, pricing, warranty coverage, and part numbers for each meter-vendor combination. Each record links one meter to one vendor with attributes that exist only in the context of this procurement relationship, enabling competitive bidding analysis, warranty claim processing, and multi-source supply chain management.. Existence Justification: Water utilities procure the same meter models from multiple approved vendors through competitive bidding, regional supplier networks, and backup sourcing strategies. Each meter-vendor combination has distinct procurement terms including vendor-specific part numbers, negotiated pricing, warranty coverage periods, and lead times. The utility actively manages these procurement relationships to optimize costs, ensure supply chain resilience, and process warranty claims.'
}

Table metering.alert_rule {
  alert_rule_id varchar [pk, note: 'Primary key for alert_rule']
  escalation_alert_rule_id varchar [note: 'Self-referencing FK on alert_rule (escalation_alert_rule_id)']
  alert_rule_description varchar [note: 'Detailed description of the purpose and logic of the alert rule.']
  alert_rule_name varchar [note: 'Descriptive name of the alert rule.']
  alert_rule_status varchar [note: 'Current lifecycle status of the alert rule.']
  condition_operator varchar [note: 'Comparison operator used in the rule condition.']
  created_timestamp timestamp [note: 'Timestamp when the alert rule record was created.']
  effective_from date [note: 'Date from which the alert rule becomes effective.']
  effective_until date [note: 'Date after which the alert rule is no longer effective (nullable).']
  enabled_flag boolean [note: 'Indicates whether the alert rule is active.']
  escalation_level varchar [note: 'Numeric level indicating escalation hierarchy for the alert.']
  evaluation_frequency_minutes varchar [note: 'How often the rule is evaluated, in minutes.']
  is_system_rule boolean [note: 'Indicates if the rule is a built-in system rule.']
  last_evaluated_timestamp timestamp [note: 'Timestamp of the most recent evaluation of the rule.']
  last_triggered_timestamp timestamp [note: 'Timestamp when the rule last generated an alert.']
  metric_name varchar [note: 'Name of the metric or measurement the rule evaluates (e.g., flow_rate, pressure).']
  notification_channel varchar [note: 'Channel(s) used to deliver alert notifications.']
  owner varchar [note: 'Identifier of the person or team responsible for the rule.']
  rule_category varchar [note: 'High-level category of the alert rule.']
  rule_type varchar [note: 'Specifies the type of logic the rule uses.']
  severity varchar [note: 'Severity level assigned to alerts generated by this rule.']
  tags varchar [note: 'Optional free-form tags for categorization.']
  threshold_value decimal(12,4) [note: 'Numeric threshold value that triggers the alert.']
  unit_of_measure varchar [note: 'Unit of measure for the threshold value.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the alert rule.']

  Note: 'Master reference table for alert_rule. Referenced by alert_rule_id.'
}

Table metering.validation_rule {
  validation_rule_id varchar [pk, note: 'Primary key for validation_rule']
  parent_validation_rule_id varchar [note: 'Self-referencing FK on validation_rule (parent_validation_rule_id)']
  applicable_entity varchar [note: 'Entity or domain to which the rule applies.']
  condition_expression varchar [note: 'Logical expression evaluated to enforce the rule (e.g., SQL‑like or DSL).']
  created_timestamp timestamp [note: 'Timestamp when the rule record was first created.']
  effective_from date [note: 'Date when the rule becomes effective.']
  effective_until date [note: 'Date when the rule expires (null if indefinite).']
  is_active boolean [note: 'Indicates whether the rule is currently active.']
  notes varchar [note: 'Free‑form field for any supplemental information about the rule.']
  rule_category varchar [note: 'Broad category indicating the type of rule.']
  rule_description varchar [note: 'Detailed description of the rule logic and purpose.']
  rule_name varchar [note: 'Human‑readable name of the validation rule.']
  severity varchar [note: 'Severity level indicating impact of rule violation.']
  threshold_unit varchar [note: 'Unit of measure for the threshold value.']
  threshold_value decimal(10,2) [note: 'Numeric threshold used by the rule when applicable.']
  updated_by varchar [note: 'Identifier of the user or system that last updated the rule.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the rule record.']
  created_by varchar [note: 'Identifier of the user or system that created the rule.']

  Note: 'Master reference table for validation_rule. Referenced by validation_rule_id.'
}

Table asset.registry {
  registry_id varchar [pk, note: 'Unique surrogate primary key for each physical infrastructure asset record in the enterprise asset registry. This is the authoritative SSOT identifier that IBM Maximo Asset Management and SAP Plant Maintenance (PM) equipment master synchronize against.']
  asset_class_id varchar [note: 'Foreign key linking to asset.asset_class. Business justification: Registry stores asset classification as a free‑text field; linking to the asset_class taxonomy enables consistent classification and removes the redundant string column.']
  created_by_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Asset record creation audit trail for data quality accountability, asset management program metrics, and regulatory compliance documentation.']
  facility_id varchar [note: 'Reference to the facility or site where the asset is physically located (e.g., Water Treatment Plant, Wastewater Treatment Plant, pump station, reservoir). Links the asset to its parent facility for geographic and operational grouping in GIS and CMMS.']
  location_id varchar [note: 'Foreign key linking to asset.location. Business justification: Registry currently has no explicit location reference; adding a foreign key to location allows assets to be tied to a physical site and supports location‑based reporting.']
  parent_asset_registry_id varchar [note: 'Self-referencing identifier pointing to the parent asset in the asset hierarchy (e.g., a pump impeller\'s parent is the pump assembly; the pump assembly\'s parent is the pump station). Enables parent-child asset hierarchy navigation for maintenance cost roll-up and condition assessment aggregation. Null for top-level assets.']
  procurement_contract_id varchar [note: 'Foreign key linking to supply.procurement_contract. Business justification: Critical assets (SCADA systems, treatment equipment, pump stations) often have long-term service/maintenance contracts. Links enable contract compliance tracking, SLA monitoring, preventive maintenanc']
  acquisition_cost decimal(18,2) [note: 'Original purchase or construction cost of the asset in US dollars at the time of acquisition. Represents the capitalized cost basis used for depreciation calculations and fixed asset register reporting. Sourced from SAP FI/CO asset accounting module. Required for GASB Statement No. 34 infrastructure asset reporting.']
  asset_category varchar [note: 'Operational domain category indicating which business process area the asset belongs to (e.g., water_treatment for WTP equipment, wastewater_treatment for WWTP equipment, distribution for pipes and valves in the distribution network, collection for sewer infrastructure, metering for AMI/AMR devices). [ENUM-REF-CANDIDATE: water_treatment|wastewater_treatment|distribution|collection|metering|electrical|mechanical|civil|vehicle|instrumentation_control — 10 candidates stripped; promote to reference product]']
  asset_name varchar [note: 'Human-readable name or short description of the asset (e.g., \'Raw Water Pump No. 3\', \'Influent Gate Valve 12-inch\', \'Chlorine Contact Basin Filter 2\'). Used as the primary display label in CMMS, GIS, and reporting interfaces.']
  asset_tag varchar [note: 'Physical asset tag number (barcode, QR code, or RFID label) affixed to the asset in the field. Used by field technicians for asset identification during inspections, maintenance, and inventory audits. Corresponds to the Maximo asset tag field.']
  asset_type varchar [note: 'Sub-classification within the asset class providing more granular categorization (e.g., Centrifugal Pump, Gate Valve, Ductile Iron Pipe, AMI Smart Meter). Aligns with IBM Maximo asset type and SAP PM equipment category for maintenance planning and spare parts management.']
  capacity_unit varchar [note: 'Unit of measure for the rated_capacity field. Common units include GPM (Gallons per Minute) for pumps, MGD (Million Gallons per Day) for treatment processes, gallons for storage tanks, kW for electrical equipment, and PSI (Pounds per Square Inch) for pressure vessels. [ENUM-REF-CANDIDATE: GPM|MGD|gallons|kW|kVA|HP|PSI|NTU|mg_L — 9 candidates stripped; promote to reference product]']
  condition_assessment_date date [note: 'Date of the most recent formal condition assessment performed on the asset. Used to determine assessment currency and schedule the next inspection cycle. Condition assessments may be visual inspections, CCTV surveys, vibration analysis, or other diagnostic methods.']
  condition_grade varchar [note: 'Standardized condition rating of the asset based on the most recent condition assessment, using a 1-5 scale where 1=Excellent/New, 2=Good, 3=Fair, 4=Poor, 5=Very Poor/Failed. Aligned with AWWA and WEF condition assessment frameworks. Drives maintenance prioritization and renewal planning.']
  created_timestamp timestamp [note: 'Timestamp when the asset record was first created in the enterprise asset registry. Provides audit trail for record provenance and data lineage tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  criticality_rating varchar [note: 'Risk-based criticality classification of the asset based on consequence of failure analysis (CoFA). \'critical\' assets have the highest consequence of failure impacting public health, regulatory compliance, or major service disruption. Used to prioritize maintenance resources, Capital Improvement Program (CIP) investments, and emergency response planning. Aligned with AWWA risk and resilience assessment methodology.']
  decommission_date date [note: 'Date the asset was permanently decommissioned, retired, or removed from service. Null for active assets. Used for asset lifecycle reporting, fixed asset register reconciliation, and Capital Improvement Program (CIP) tracking. Triggers write-off in SAP FI/CO fixed asset module.']
  diameter_mm decimal(10,2) [note: 'Nominal diameter of the asset in millimeters. For pipes and valves, this is the internal bore diameter. For pumps, this is the discharge diameter. Used for hydraulic capacity calculations, spare parts specification, and network modeling in Innovyze InfoWater.']
  elevation_m decimal(10,3) [note: 'Elevation of the asset above mean sea level in meters. Critical for hydraulic modeling, pressure zone assignment, and gravity-fed system design. Used in Innovyze InfoWater hydraulic models and Esri ArcGIS 3D network analysis.']
  expected_useful_life_years varchar [note: 'The estimated total useful life of the asset in years as defined by engineering standards, manufacturer specifications, or utility policy. Used for depreciation calculations, Capital Improvement Program (CIP) planning, and asset renewal forecasting. Aligns with GASB Statement No. 34 infrastructure reporting requirements.']
  functional_location varchar [note: 'Hierarchical functional location code representing the physical or functional position of the asset within the utility\'s infrastructure (e.g., WTP-PUMP-STATION-01-PUMP-03). Mirrors the SAP PM Functional Location (FLOC) structure and IBM Maximo Location field. Used for structured asset hierarchy navigation and maintenance cost allocation.']
  gis_feature_code varchar [note: 'The unique feature identifier for this asset in the Esri ArcGIS geographic information system. Enables spatial queries, network tracing, and hydraulic model integration via Innovyze InfoWater. Used for field crew navigation and infrastructure mapping.']
  installation_date date [note: 'Date the asset was physically installed and placed into service at its current location. Used as the baseline for age calculations, depreciation schedules, warranty period tracking, and remaining useful life (RUL) estimation. Sourced from IBM Maximo installation date field.']
  is_lead_service_line boolean [note: 'Indicates whether this asset is a lead service line or contains lead components. Critical for compliance with the EPA Lead and Copper Rule Revisions (LCRR) which requires utilities to inventory and replace lead service lines. True = confirmed lead service line; False = non-lead or unknown.']
  last_maintenance_date date [note: 'Date of the most recently completed maintenance activity (preventive or corrective) performed on this asset. Used to calculate maintenance intervals, identify overdue assets, and support compliance reporting for regulatory-mandated maintenance activities.']
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent update to the asset record in the enterprise asset registry. Used for change tracking, data synchronization with IBM Maximo and SAP PM, and audit trail maintenance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  latitude decimal(10,7) [note: 'Geographic latitude coordinate of the asset location in decimal degrees (WGS84 datum). Used for GIS mapping, field crew navigation, spatial analysis, and hydraulic network modeling in Innovyze InfoWater. Sourced from Esri ArcGIS asset layer.']
  longitude decimal(10,7) [note: 'Geographic longitude coordinate of the asset location in decimal degrees (WGS84 datum). Used for GIS mapping, field crew navigation, spatial analysis, and hydraulic network modeling in Innovyze InfoWater. Sourced from Esri ArcGIS asset layer.']
  maintenance_strategy decimal(18,6) [note: 'The primary maintenance approach applied to this asset as defined in the Computerized Maintenance Management System (CMMS). \'preventive\' indicates time-based scheduled maintenance; \'predictive\' indicates condition-monitoring-based maintenance; \'condition_based\' indicates maintenance triggered by condition thresholds; \'run_to_failure\' is applied to non-critical, easily replaceable assets.']
  manufacture_date date [note: 'Date the asset was manufactured by the OEM. May differ from installation date for assets stored in inventory before deployment. Used for age-based condition assessment and manufacturer warranty calculations.']
  manufacturer varchar [note: 'Name of the original equipment manufacturer (OEM) of the asset (e.g., Xylem, Grundfos, Flowserve, Siemens, ABB). Used for warranty management, spare parts procurement, and vendor performance analysis. Sourced from IBM Maximo manufacturer field.']
  maximo_asset_num varchar [note: 'The asset number as assigned and maintained in IBM Maximo Asset Management (CMMS). This is the operational cross-reference key used by maintenance crews and work order management. Must be unique within the Maximo instance.']
  model_num varchar [note: 'Manufacturer\'s model or product number for the asset (e.g., \'LF 3196 STX\', \'NK 65-200\'). Used for spare parts identification, technical documentation retrieval, and procurement of replacement units. Sourced from IBM Maximo model field.']
  next_maintenance_date date [note: 'Date on which the next scheduled preventive maintenance activity is due for this asset. Derived from the PM schedule and last maintenance date. Used for maintenance planning, resource scheduling, and compliance tracking in IBM Maximo.']
  operational_status decimal(18,6) [note: 'Current operational lifecycle state of the asset. \'in_service\' indicates the asset is active and performing its intended function. \'standby\' indicates the asset is available but not currently operating. \'out_of_service\' indicates the asset is temporarily removed from service for maintenance or repair. \'decommissioned\' indicates permanent retirement. Drives maintenance scheduling and regulatory reporting.']
  pipe_material varchar [note: 'Material composition of the asset (e.g., Ductile Iron, PVC, HDPE, Cast Iron, Concrete, Stainless Steel, Copper). Critical for corrosion risk assessment, Lead and Copper Rule Revisions (LCRR) compliance, Cured-in-Place Pipe (CIPP) rehabilitation planning, and remaining useful life estimation. Applicable primarily to pipe and fitting assets.']
  pm_schedule_id varchar [note: 'Reference to the preventive maintenance schedule record in IBM Maximo that governs recurring maintenance activities for this asset. Links the asset to its O&M (Operations and Maintenance) task plans, frequencies, and resource requirements.']
  power_rating_kw decimal(10,2) [note: 'Nameplate power rating of the asset in kilowatts (kW). Applicable to pumps, blowers, motors, generators, and other electrical equipment. Used for energy consumption analysis, Variable Frequency Drive (VFD) sizing, electrical load planning, and OPEX budgeting.']
  pressure_zone varchar [note: 'The hydraulic pressure zone or District Metered Area (DMA) in which the asset is located. Used for pressure management, Non-Revenue Water (NRW) analysis, and distribution network operations. Aligns with Innovyze InfoWater zone definitions and GIS pressure zone polygons.']
  rated_capacity decimal(18,4) [note: 'The manufacturer-rated operational capacity of the asset expressed in the appropriate unit of measure (see capacity_unit field). For pumps: Gallons per Minute (GPM); for treatment units: Million Gallons per Day (MGD); for tanks: gallons. Used for capacity planning, hydraulic modeling, and performance benchmarking.']
  regulatory_asset_code varchar [note: 'Asset identifier assigned by a regulatory authority (e.g., state drinking water program, EPA) for compliance tracking and reporting purposes. Used in regulatory submissions such as the Consumer Confidence Report (CCR), Discharge Monitoring Report (DMR), and NPDES permit compliance documentation.']
  replacement_cost decimal(18,2) [note: 'Current estimated cost to replace the asset with a new equivalent unit in US dollars. Updated periodically based on market pricing and engineering estimates. Used for Capital Improvement Program (CIP) budgeting, insurance valuation, and risk-based asset management decision-making.']
  sap_equipment_num varchar [note: 'The equipment number assigned in SAP Plant Maintenance (PM) module. Used for integration with SAP FI/CO for depreciation, CAPEX/OPEX tracking, and maintenance cost postings. Enables bidirectional synchronization between SAP PM and the asset registry.']
  scada_tag varchar [note: 'The Supervisory Control and Data Acquisition (SCADA) tag name used to identify this asset\'s data point(s) in the OSIsoft PI Historian system. Enables linkage between the physical asset registry and real-time operational data streams for performance monitoring, alarm management, and predictive maintenance analytics.']
  serial_num varchar [note: 'Unique serial number assigned by the manufacturer to this specific asset unit. Used for warranty claims, recall tracking, and precise asset identification when multiple identical units exist. Sourced from IBM Maximo serial number field.']
  warranty_expiry_date date [note: 'Date on which the manufacturer\'s warranty for the asset expires. Used to trigger warranty claim processes before expiry and to transition maintenance responsibility from warranty to O&M budget. Sourced from IBM Maximo warranty end date.']

  Note: 'Master record for every physical infrastructure asset owned or operated by the utility, including WTP/WWTP equipment, pipes, pumps, valves, electrical systems, meters, and vehicles. Captures asset identity, classification, installation details, location (GIS coordinates), manufacturer, model, serial number, asset tag, parent-child hierarchy, operational status, and lifecycle dates. This is the authoritative SSOT for all physical assets — the IBM Maximo asset master and SAP PM equipment master both synchronize to this record.'
}

Table asset.asset_class {
  asset_class_id varchar [pk, note: 'Unique surrogate identifier for the asset class record in the enterprise asset management system. Primary key for the asset_class reference taxonomy. [ROLE: REFERENCE_LOOKUP — this entity is a reference taxonomy/classification table defining the hierarchy of utility asset types; per-role minimums are exempt, but MASTER_RESOURCE categories are applied for completeness given the entity carries rich business metadata beyond a simple code list.]']
  asset_service_class_id varchar [note: 'Foreign key linking this duplicate entity to the single source of truth in service.service_class']
  created_by_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Asset class definition authorship for configuration management, subject matter expert identification, and asset hierarchy governance.']
  ami_applicable boolean [note: 'Indicates whether assets of this class are part of the AMI/AMR metering infrastructure managed via the Sensus FlexNet AMI Platform. True for smart meters and communication endpoints; False for all other asset classes.']
  asset_domain varchar [note: 'Operational domain to which this asset class primarily belongs within the utility (e.g., Water Treatment, Water Distribution, Wastewater Collection, Wastewater Treatment, Metering, Fleet, Facilities, Cross-Domain). Drives domain-specific maintenance strategies and regulatory reporting alignment. [ENUM-REF-CANDIDATE: Water Treatment|Water Distribution|Wastewater Collection|Wastewater Treatment|Metering|Fleet|Facilities|Cross-Domain — promote to reference product]']
  capex_threshold_usd decimal(15,2) [note: 'Minimum acquisition or renewal cost in USD above which expenditures on assets of this class are capitalized as CAPEX rather than expensed as OPEX. Aligned with GAAP/GASB capitalization policies and SAP FI/CO asset accounting rules.']
  cip_program_category varchar [note: 'CIP program category under which capital renewal projects for assets of this class are budgeted and tracked. Aligns with the utility\'s multi-year CIP planning structure in SAP PS and financial reporting to the Public Utilities Commission. [ENUM-REF-CANDIDATE: Water Supply|Water Treatment|Water Distribution|Wastewater Collection|Wastewater Treatment|Metering|Facilities|Fleet|Cross-Program — promote to reference product]']
  class_code varchar [note: 'Short alphanumeric code uniquely identifying the asset class within the enterprise taxonomy (e.g., MECH-PUMP, ELEC-TRANS, CIVIL-PIPE). Used as the externally-known business identifier in IBM Maximo, SAP PM, and GIS integrations.']
  class_description varchar [note: 'Detailed narrative description of the asset class, including its functional role within water or wastewater operations, typical installation context, and distinguishing characteristics from adjacent classes.']
  class_name varchar [note: 'Human-readable name of the asset class (e.g., \'Centrifugal Pump\', \'Distribution Main Pipe\', \'UV Disinfection Unit\'). Used in reports, work orders, and CAPEX planning documents.']
  class_status varchar [note: 'Current lifecycle status of the asset class record within the reference taxonomy. \'Active\' classes are available for new asset registrations; \'Deprecated\' classes are retained for historical assets but cannot be assigned to new assets.']
  condition_assessment_method varchar [note: 'Default method used to assess the physical condition of assets in this class. CIPP and pipe assets typically use CCTV; rotating equipment uses vibration analysis; distribution mains may use acoustic leak detection. Drives field inspection work order types in Maximo. [ENUM-REF-CANDIDATE: Visual Inspection|CCTV|Acoustic Leak Detection|Vibration Analysis|Ultrasonic Testing|Hydraulic Testing|SCADA Monitoring|Not Applicable — promote to reference product]']
  consequence_of_failure varchar [note: 'Primary category of consequence if assets of this class fail. Drives risk-based maintenance prioritization and emergency response planning. [ENUM-REF-CANDIDATE: Service Interruption|Public Health Risk|Environmental Non-Compliance|Safety Hazard|Financial Loss|Reputational — promote to reference product]']
  created_timestamp timestamp [note: 'Timestamp when this asset class record was first created in the enterprise data platform. Supports audit trail and data lineage requirements.']
  criticality_tier varchar [note: 'Default criticality tier classification for assets of this class based on consequence of failure analysis. Critical assets (e.g., primary WTP pumps, transmission mains) receive highest maintenance priority and fastest response SLAs.']
  criticality_weight decimal(5,2) [note: 'Numeric weighting factor (typically 0.00–10.00) applied to assets of this class during criticality assessment scoring. Higher values indicate greater consequence of failure on service delivery, public health, or regulatory compliance. Used in risk-based asset prioritization per ISO 55001.']
  depreciation_method varchar [note: 'Default accounting depreciation method applied to assets of this class for financial reporting purposes. Straight-Line is most common for utility infrastructure. Aligned with GAAP/GASB requirements for municipal utility financial statements. [ENUM-REF-CANDIDATE: Straight-Line|Declining Balance|Units of Production|Sum-of-Years-Digits|Modified Accelerated Cost Recovery — promote to reference product]']
  effective_date date [note: 'Date from which this asset class definition became effective and available for use in asset registrations. Supports temporal validity tracking of the reference taxonomy.']
  environmental_risk_flag boolean [note: 'Indicates whether failure of assets in this class poses a direct environmental risk requiring regulatory notification (e.g., SSO, CSO, chemical spill, NPDES permit exceedance). True triggers mandatory environmental incident reporting workflows.']
  gis_feature_class varchar [note: 'Corresponding feature class name in Esri ArcGIS geodatabase for assets of this class (e.g., \'wDistributionMain\', \'wValve\', \'wPump\'). Enables spatial analysis, network modeling in Innovyze InfoWater, and GIS-CMMS integration for field crew dispatch.']
  gl_account_code varchar [note: 'Default General Ledger account code in SAP FI/CO to which asset acquisitions, depreciation, and disposals for this class are posted. Ensures consistent financial reporting and CAPEX/OPEX tracking across the utility.']
  hierarchy_level varchar [note: 'Numeric depth of this class within the classification hierarchy (1 = top-level category, 2 = sub-category, 3 = class, 4 = sub-class). Drives roll-up aggregation logic in CAPEX planning and maintenance reporting.']
  inspection_frequency_days varchar [note: 'Default interval in calendar days between mandatory regulatory or condition inspections for assets of this class. Distinct from PM frequency — this is driven by regulatory compliance requirements (e.g., EPA, state primacy agency mandates) rather than maintenance strategy.']
  iso_55001_aligned boolean [note: 'Indicates whether the maintenance strategy, criticality assessment, and lifecycle management approach for this asset class have been formally aligned with ISO 55001 Asset Management System requirements. Used for ISO certification audit evidence.']
  last_updated_timestamp timestamp [note: 'Timestamp when this asset class record was most recently modified in the enterprise data platform. Used for change tracking, data synchronization with source systems (Maximo, SAP), and audit compliance.']
  lcrr_applicable boolean [note: 'Indicates whether assets of this class are subject to EPA Lead and Copper Rule Revisions (LCRR) compliance requirements, such as lead service line inventory and replacement tracking. Applicable to service lines, connectors, and plumbing components.']
  maintenance_strategy decimal(18,6) [note: 'Default O&M maintenance strategy applied to assets of this class in IBM Maximo CMMS. Drives automatic PM schedule generation. Preventive and Condition-Based strategies are typical for critical water infrastructure; Run-to-Failure may apply to low-criticality ancillary assets.']
  material_standard varchar [note: 'Default material specification or construction standard applicable to assets of this class (e.g., \'AWWA C900 PVC\', \'AWWA C200 Steel\', \'ASTM A536 Ductile Iron\', \'HDPE ASTM D3035\'). Used in procurement specifications and asset registry for infrastructure renewal planning.']
  maximo_class_code varchar [note: 'Corresponding asset class identifier in IBM Maximo Asset Management CMMS. Used for bidirectional synchronization between the Silver Layer lakehouse and Maximo for work order generation, PM scheduling, and asset lifecycle management.']
  mean_time_between_failures_days decimal(10,2) [note: 'Industry benchmark mean time between failures in days for assets of this class, used as a baseline for reliability-centered maintenance planning and failure probability modeling. Sourced from AWWA reliability benchmarks and historical Maximo work order data.']
  mean_time_to_repair_hours decimal(8,2) [note: 'Industry benchmark mean time to repair in hours for assets of this class, used for SLA setting, crew resource planning, and service restoration time estimation. Sourced from AWWA benchmarks and historical Maximo corrective work order durations.']
  number_sap varchar [note: 'Corresponding asset class number in SAP FI/CO Asset Accounting module (transaction AS02/AS03). Enables direct cross-reference between the enterprise data lakehouse and the SAP ERP system of record for financial reconciliation.']
  pm_frequency_days varchar [note: 'Default interval in calendar days between scheduled preventive maintenance activities for assets of this class. Used by IBM Maximo PM scheduling engine to auto-generate work orders. Overridable at the individual asset level.']
  primary_category varchar [note: 'Top-level classification grouping for the asset class aligned with standard utility asset taxonomy: Mechanical (pumps, blowers, mixers), Electrical (transformers, switchgear), Civil (pipes, structures, tanks), Instrumentation (sensors, meters, SCADA RTUs), Vehicle (fleet), Information Technology, or Other. [ENUM-REF-CANDIDATE: Mechanical|Electrical|Civil|Instrumentation|Vehicle|Information Technology|Other — promote to reference product]']
  regulatory_standard_ref varchar [note: 'Primary regulatory standard or code applicable to assets of this class (e.g., \'SDWA Section 1412\', \'NPDES Permit\', \'AWWA C900\', \'ASME B31.3\'). Drives compliance inspection scheduling and regulatory reporting requirements in DMR/MOR submissions.']
  renewal_strategy decimal(18,6) [note: 'Default end-of-life renewal strategy for assets of this class used in CIP planning. CIPP (Cured-in-Place Pipe) and trenchless methods are common for buried pipe rehabilitation; rotating equipment typically follows Replace-in-Kind or Upgrade strategies.']
  retirement_date date [note: 'Date on which this asset class was retired or deprecated from the active taxonomy. Null for currently active classes. Retained for historical asset records that were registered under this class prior to retirement.']
  safety_classification varchar [note: 'Primary safety hazard classification for work activities on assets of this class. Drives OSHA-compliant safety permit requirements (e.g., confined space entry permits, lockout/tagout procedures) when generating work orders in Maximo.']
  salvage_value_pct decimal(5,2) [note: 'Default residual/salvage value expressed as a percentage of original acquisition cost at end of useful life for assets in this class. Used in depreciation calculations and asset disposal planning within SAP FI/CO.']
  scada_monitored boolean [note: 'Indicates whether assets of this class are typically monitored via SCADA (Supervisory Control and Data Acquisition) systems integrated with OSIsoft PI Historian. True for pumps, valves, flow meters, and treatment equipment; False for passive civil assets such as buried pipes.']
  size_unit_of_measure varchar [note: 'Standard unit of measure used to express the principal sizing attribute for assets of this class (e.g., \'inches\' for pipe diameter, \'HP\' for pump motor horsepower, \'kVA\' for transformer capacity, \'GPM\' for flow capacity). Ensures consistent sizing data entry across the asset registry. [ENUM-REF-CANDIDATE: inches|mm|feet|meters|kVA|HP|kW|GPM|MGD|gallons|cubic feet — promote to reference product]']
  spare_parts_required boolean [note: 'Indicates whether assets of this class typically require dedicated spare parts inventory to be maintained in the storeroom (SAP MM / Maximo Inventory). True for critical rotating equipment and instrumentation; False for passive civil assets.']
  useful_life_years varchar [note: 'Default expected useful life in years for assets belonging to this class, used as the baseline for depreciation schedules, CAPEX renewal planning, and CIP prioritization. Can be overridden at the individual asset level.']
  work_order_type_default varchar [note: 'Default work order type generated in IBM Maximo for assets of this class when a maintenance event is triggered. Drives labor planning, cost coding, and CAPEX vs OPEX classification of maintenance expenditures.']

  Note: 'Reference taxonomy defining the classification hierarchy for utility assets (e.g., Mechanical, Electrical, Civil, Instrumentation, Vehicle). Each class carries default useful life, depreciation method, maintenance strategy, criticality weighting rules, and applicable regulatory standards. Used to drive preventive maintenance scheduling, CAPEX planning, and ISO 55001 asset management framework alignment. [SSOT: Canonical asset classification taxonomy; service.service_class references this as SSOT] [SSOT: governed by service.service_class] [DEPRECATED: Single source of truth is service.service_class]'
}

Table asset.location {
  location_id varchar [pk, note: 'Unique identifier for the asset location record. Primary key.']
  created_by_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Location record creation tracking for GIS data quality accountability, spatial data governance, and facility management program metrics.']
  facility_id varchar [note: 'Reference to the top-level facility (WTP, WWTP, pump station) where this location resides.']
  parent_location_id varchar [note: 'Reference to the parent location in the hierarchical location structure (e.g., a room\'s parent is a floor, a floor\'s parent is a building).']
  access_restrictions varchar [note: 'Description of physical or security access restrictions for the location (e.g., \'Restricted - Badge Required\', \'Public Access\', \'Confined Space\').']
  address_line_1 varchar [note: 'Primary street address of the location. Organizational contact data classified as confidential.']
  address_line_2 varchar [note: 'Secondary address information (suite, unit, building number). Organizational contact data classified as confidential.']
  area_square_feet decimal(12,2) [note: 'Physical area of the location in square feet, used for space planning and asset density analysis.']
  capacity_rating decimal(15,2) [note: 'Rated capacity of the location for asset storage or operational throughput (e.g., MGD for treatment facilities, gallons for storage tanks).']
  capacity_unit varchar [note: 'Unit of measure for the capacity rating (e.g., Million Gallons per Day (MGD), Gallons per Minute (GPM), gallons, cubic meters).']
  city varchar [note: 'City or municipality where the location is situated.']
  country_code varchar [note: 'Three-letter ISO country code (e.g., \'USA\', \'CAN\', \'MEX\').']
  created_timestamp timestamp [note: 'Timestamp when the location record was first created in the system.']
  dma_zone varchar [note: 'District Metered Area zone identifier for water distribution network segmentation and Non-Revenue Water (NRW) analysis.']
  effective_end_date date [note: 'Date when the location was decommissioned or removed from active service (null for active locations).']
  effective_start_date date [note: 'Date when the location became operational or was added to the asset registry.']
  elevation_ft decimal(10,2) [note: 'Elevation above sea level in feet, used for hydraulic modeling and pressure zone analysis.']
  environmental_conditions varchar [note: 'Description of environmental conditions at the location (e.g., \'Indoor Climate Controlled\', \'Outdoor Exposed\', \'Wet Environment\', \'Corrosive Atmosphere\').']
  floor_level varchar [note: 'Floor or level number within a building (e.g., 1 for ground floor, 2 for second floor, -1 for basement).']
  gis_feature_code varchar [note: 'Unique feature identifier in the Esri ArcGIS system for spatial data integration and network topology analysis.']
  hazard_classification varchar [note: 'Safety hazard classification for the location (e.g., \'Confined Space\', \'High Voltage\', \'Chemical Storage\', \'None\').']
  last_modified_timestamp timestamp [note: 'Timestamp when the location record was last updated or modified.']
  latitude decimal(10,7) [note: 'Geographic latitude coordinate in decimal degrees for GIS integration with Esri ArcGIS.']
  location_code varchar [note: 'Business identifier code for the location, used for operational reference and integration with IBM Maximo CMMS and SAP PM systems.']
  location_description varchar [note: 'Detailed description of the location, including physical characteristics, purpose, and operational context.']
  location_name varchar [note: 'Human-readable name of the asset location (e.g., \'Main Street Pump Station\', \'North WTP Filter Building\').']
  location_status varchar [note: 'Current operational status of the location in its lifecycle.']
  location_type varchar [note: 'Classification of the location type within the asset hierarchy.']
  longitude decimal(10,7) [note: 'Geographic longitude coordinate in decimal degrees for GIS integration with Esri ArcGIS.']
  maximo_location_code varchar [note: 'Location identifier in IBM Maximo CMMS for work order management and maintenance routing integration.']
  notes varchar [note: 'Additional notes or comments about the location for operational reference and maintenance planning.']
  postal_code varchar [note: 'ZIP or postal code for the location. Organizational contact data classified as confidential.']
  pressure_zone varchar [note: 'Pressure zone designation for hydraulic modeling and distribution network operations, typically defined by elevation and Pressure Reducing Valve (PRV) boundaries.']
  regulatory_jurisdiction varchar [note: 'Regulatory jurisdiction or primacy agency responsible for oversight (e.g., state EPA, local health department).']
  room_number varchar [note: 'Room or space identifier within a floor or building (e.g., \'Room 101\', \'Electrical Vault A\').']
  sap_functional_location varchar [note: 'SAP PM functional location code for asset hierarchy and maintenance planning integration.']
  scada_integration_flag boolean [note: 'Indicates whether the location is integrated with SCADA systems (OSIsoft PI Historian) for real-time monitoring and control.']
  service_territory varchar [note: 'Service territory or jurisdiction code defining the geographic area served by the utility.']
  spatial_reference_code varchar [note: 'Coordinate system reference identifier (EPSG code) used for GIS spatial data (e.g., \'EPSG:4326\' for WGS 84).']
  state_province varchar [note: 'Two-letter state or province code (e.g., \'CA\', \'TX\', \'NY\').']
  watershed varchar [note: 'Watershed or drainage basin identifier for regulatory reporting and environmental compliance under the Clean Water Act (CWA).']

  Note: 'Hierarchical location registry defining where assets are physically installed or stored — from service territory down to facility, building, floor, room, and GIS coordinate. Supports Esri ArcGIS integration with spatial reference data (latitude, longitude, elevation, DMA zone, pressure zone, watershed). Enables location-based maintenance routing, network topology analysis, and regulatory reporting by geographic jurisdiction.'
}

Table asset.condition_assessment {
  condition_assessment_id varchar [pk, note: 'Unique identifier for the condition assessment record. Primary key.']
  analytical_result_id varchar [note: 'Foreign key linking to quality.analytical_result. Business justification: Condition assessments for pipes, coatings, and linings often reference supporting lab analysis results (corrosion testing, material integrity tests). Real business need: linking physical asset conditi']
  condition_approved_by_employee_id varchar [note: 'Reference to the manager or authority who approved the assessment and recommended actions.']
  condition_asset_registry_id varchar [note: 'Reference to the infrastructure asset being assessed (pipe, pump, valve, treatment equipment, vehicle, etc.).']
  condition_employee_id varchar [note: 'Reference to the employee or contractor who performed the condition assessment.']
  condition_registry_id varchar [note: 'Reference to the infrastructure asset being assessed (pipe, pump, valve, treatment equipment, vehicle, etc.).']
  condition_reviewed_by_employee_id varchar [note: 'Reference to the supervisor or engineer who reviewed and validated the assessment findings.']
  gis_location_id varchar [note: 'Reference to the asset location in the Geographic Information System (GIS), enabling spatial analysis and mapping of condition assessment results.']
  lab_sample_id varchar [note: 'Foreign key linking to laboratory.lab_sample. Business justification: Condition assessments routinely require laboratory analysis of pipe scale, corrosion products, coating degradation, and material samples. Essential for determining remaining useful life and failure ro']
  primary_condition_employee_id varchar [note: 'Reference to the employee or contractor who performed the condition assessment.']
  tertiary_condition_approved_by_employee_id varchar [note: 'Reference to the manager or authority who approved the assessment and recommended actions.']
  work_order_id varchar [note: 'Reference to the work order under which this condition assessment was performed, if applicable.']
  approved_date date [note: 'Date when the assessment was formally approved by management.']
  assessment_date date [note: 'The date on which the condition assessment was performed in the field.']
  assessment_interval_months varchar [note: 'Standard inspection frequency interval in months for this asset type and condition grade.']
  assessment_method varchar [note: 'The inspection or testing method used to assess asset condition. Common methods include visual inspection, Closed-Circuit Television (CCTV) for pipes, acoustic leak detection, vibration analysis for rotating equipment, ultrasonic thickness measurement for corrosion, infrared thermography for electrical systems, and various hydraulic testing methods. [ENUM-REF-CANDIDATE: visual|cctv|acoustic|vibration_analysis|ultrasonic_thickness|infrared_thermography|dye_testing|smoke_testing|pressure_testing|flow_testing|electrical_testing|corrosion_survey — 12 candidates stripped; promote to reference product]']
  assessment_number varchar [note: 'Business identifier for the condition assessment, typically generated by the Computerized Maintenance Management System (CMMS) or inspection system.']
  assessment_status varchar [note: 'Current workflow status of the condition assessment record: scheduled, in progress, completed (field work done), reviewed (technical review complete), approved (management sign-off), or cancelled.']
  assessment_timestamp timestamp [note: 'Precise date and time when the condition assessment was completed, including time zone information.']
  assessment_type varchar [note: 'Classification of the assessment purpose: routine scheduled inspection, preventive maintenance assessment, reactive inspection following an incident, condition-based monitoring, regulatory compliance inspection, pre-failure investigation, post-repair verification, or new asset commissioning. [ENUM-REF-CANDIDATE: routine|preventive|reactive|condition_based|regulatory|pre_failure|post_repair|commissioning — 8 candidates stripped; promote to reference product]']
  compliance_standard varchar [note: 'Specific regulatory standard, code, or requirement that this assessment addresses (e.g., SDWA Section 1433, AWWA C651, NFPA 25).']
  condition_grade varchar [note: 'Standardized condition rating on a 1-5 scale per American Water Works Association (AWWA) and Water Research Foundation (WRF) standards, where 1 = Excellent/New, 2 = Good/Minor Defects, 3 = Fair/Moderate Defects, 4 = Poor/Significant Defects, 5 = Very Poor/Critical/Imminent Failure.']
  created_timestamp timestamp [note: 'System timestamp when this condition assessment record was first created in the Computerized Maintenance Management System (CMMS).']
  critical_defect_count varchar [note: 'Number of critical or high-severity defects requiring immediate attention or corrective action.']
  criticality_rating varchar [note: 'Business criticality classification of the asset based on consequence of failure analysis, considering service impact, public health risk, environmental impact, and financial exposure.']
  defect_count varchar [note: 'Total number of defects, anomalies, or non-conformances identified during the condition assessment.']
  defect_description varchar [note: 'Detailed narrative description of defects, damage, deterioration, or performance issues observed during the assessment.']
  environmental_conditions varchar [note: 'Environmental factors that may affect assessment results or asset condition (e.g., soil conditions, groundwater level, chemical exposure, temperature extremes).']
  estimated_repair_cost decimal(15,2) [note: 'Preliminary cost estimate for recommended repair or rehabilitation work, used for Capital Expenditure (CAPEX) and Operating Expenditure (OPEX) planning.']
  estimated_replacement_cost decimal(15,2) [note: 'Estimated cost to fully replace the asset with equivalent new equipment or infrastructure.']
  failure_probability decimal(5,4) [note: 'Statistical probability (0.0000 to 1.0000) of asset failure within the next planning period, calculated from condition data, age, and historical failure rates.']
  inspection_equipment_used varchar [note: 'Description of specialized equipment, instruments, or tools used during the assessment (e.g., CCTV crawler, ultrasonic thickness gauge, vibration analyzer, acoustic leak detector).']
  inspector_certification varchar [note: 'Professional certifications held by the inspector relevant to the assessment method (e.g., NASSCO PACP/MACP/LACP for pipeline inspection, ASNT Level II for ultrasonic testing, thermography certification).']
  inspector_name varchar [note: 'Full name of the inspector or technician who conducted the assessment.']
  latitude decimal(10,8) [note: 'Geographic latitude coordinate (decimal degrees) of the assessment location.']
  longitude decimal(11,8) [note: 'Geographic longitude coordinate (decimal degrees) of the assessment location.']
  modified_timestamp timestamp [note: 'System timestamp when this condition assessment record was last updated.']
  next_assessment_due_date date [note: 'Scheduled date for the next condition assessment based on asset criticality, condition grade, and inspection frequency requirements.']
  notes varchar [note: 'Additional observations, comments, or contextual information recorded by the inspector during the assessment.']
  performance_score decimal(5,2) [note: 'Quantitative score (0-100 scale) representing the operational performance and efficiency of the asset relative to design specifications.']
  recommended_action varchar [note: 'Recommended intervention strategy based on assessment findings: continue monitoring, schedule repair, plan rehabilitation, schedule replacement, no action required, or emergency repair needed.']
  recommended_action_priority varchar [note: 'Priority level for the recommended intervention: immediate (0-30 days), urgent (1-6 months), high (6-12 months), medium (1-3 years), low (3+ years).']
  regulatory_compliance_flag boolean [note: 'Indicates whether this assessment was performed to satisfy regulatory inspection requirements from Environmental Protection Agency (EPA), state primacy agencies, or other governing bodies.']
  remaining_useful_life_years decimal(6,2) [note: 'Estimated number of years the asset can continue to operate before requiring major rehabilitation or replacement, based on current condition and deterioration rate.']
  reviewed_date date [note: 'Date when the assessment was reviewed and validated by a supervisor or subject matter expert.']
  risk_score decimal(6,2) [note: 'Composite risk score calculated as the product of failure probability and consequence of failure, used to prioritize asset renewal and Capital Improvement Program (CIP) planning.']
  structural_integrity_score decimal(5,2) [note: 'Quantitative score (0-100 scale) representing the structural soundness of the asset based on inspection findings. Higher scores indicate better structural condition.']
  weather_conditions varchar [note: 'Weather conditions at the time of assessment, relevant for outdoor inspections and certain testing methods.']

  Note: 'Records the results of all formal assessments and inspections performed on infrastructure assets, encompassing both scored condition evaluations (condition grade 1-5 per AWWA/WRF standards, structural integrity score, remaining useful life estimate, failure probability) and regulatory/compliance inspections (EPA, state primacy agency, OSHA requirements). Captures assessment date, type (condition-scoring, regulatory-compliance, routine-operational, post-incident, pre-commissioning), method (visual, CCTV, acoustic, vibration analysis, ultrasonic thickness, leak detection), inspector identity and certification, checklist/protocol used, pass/fail outcome, deficiencies identified, corrective action required flag, recommended intervention, and regulatory permit reference. A single unified record for any event where an asset is formally evaluated — whether for condition scoring, compliance verification, or operational readiness. Drives asset renewal prioritization, CIP planning, regulatory inspection compliance tracking, and OSHA safety audit evidence. Integrates with IBM Maximo inspection records and supports EPA/state primacy agency reporting requirements.'
}

Table asset.criticality_rating {
  criticality_rating_id varchar [pk, note: 'Unique identifier for the criticality rating record. Primary key for the criticality rating entity.']
  criticality_asset_registry_id varchar [note: 'Reference to the physical asset being evaluated for criticality. Links to the asset registry in IBM Maximo CMMS.']
  criticality_registry_id varchar [note: 'Reference to the physical asset being evaluated for criticality. Links to the asset registry in IBM Maximo CMMS.']
  approval_date date [note: 'Date when this criticality rating was formally approved for operational use. Supports audit trail and governance compliance.']
  approved_by varchar [note: 'Name or identifier of the person or role that approved this criticality rating for operational use. Supports governance and accountability for asset management decisions.']
  assessment_date date [note: 'The date when the criticality assessment was performed. Distinct from the effective date; tracks when the analysis was conducted.']
  assessment_performed_by varchar [note: 'Name or identifier of the person, team, or system that performed the criticality assessment. Supports audit trail and accountability for rating decisions.']
  capital_renewal_priority_rank varchar [note: 'Relative priority ranking for capital renewal or replacement within the asset portfolio. Lower numbers indicate higher priority. Derived from criticality tier and overall risk score.']
  cip_eligibility_flag boolean [note: 'Indicates whether this asset is eligible for inclusion in the Capital Improvement Program based on its criticality rating and condition. True if eligible for CIP funding consideration.']
  consequence_of_failure_score decimal(5,2) [note: 'Quantitative score representing the business, operational, safety, environmental, and regulatory impact if the asset fails. Typically scaled 1-100 or 1-10 depending on methodology.']
  created_timestamp timestamp [note: 'Timestamp when this criticality rating record was first created in the system. Supports data lineage and audit trail requirements.']
  criticality_tier varchar [note: 'Categorical classification of asset criticality derived from the overall risk score. Determines maintenance frequency, inspection intervals, and capital renewal priority.']
  customer_impact_count varchar [note: 'Estimated number of customers or service connections that would be affected by failure of this asset. Used to quantify consequence of failure for distribution and collection system assets.']
  environmental_impact_flag boolean [note: 'Indicates whether failure of this asset would result in environmental harm such as discharge of untreated wastewater, contamination of water sources, or SSO/CSO events. True if environmental impact is likely.']
  financial_impact_amount decimal(15,2) [note: 'Estimated financial consequence of asset failure including emergency repair costs, lost revenue, regulatory fines, and liability claims. Expressed in USD.']
  inspection_frequency_days varchar [note: 'Recommended interval in days between routine inspections based on the criticality tier. Critical assets require more frequent inspection than low-criticality assets.']
  last_modified_timestamp timestamp [note: 'Timestamp when this criticality rating record was last updated. Supports change tracking and audit trail requirements.']
  likelihood_of_failure_score decimal(5,2) [note: 'Quantitative score representing the probability of asset failure based on age, condition, maintenance history, and operating environment. Typically scaled 1-100 or 1-10 depending on methodology.']
  methodology_version varchar [note: 'Version identifier of the criticality assessment methodology used to calculate this rating. Enables tracking of methodology changes over time and ensures consistent application across asset portfolio.']
  next_review_date date [note: 'Scheduled date for the next criticality reassessment. Critical assets typically require more frequent review cycles than low-criticality assets.']
  notes varchar [note: 'Free-text notes documenting special considerations, assumptions, or qualitative factors that influenced the criticality rating. Supports transparency and knowledge transfer.']
  overall_risk_score decimal(7,2) [note: 'Composite risk score calculated from Consequence of Failure and Likelihood of Failure scores. Typically computed as CoF × LoF. Used to rank assets for maintenance and capital investment prioritization.']
  preventive_maintenance_frequency_days varchar [note: 'Recommended interval in days between preventive maintenance activities based on the criticality tier. Critical assets require more frequent PM than low-criticality assets.']
  public_health_impact_flag boolean [note: 'Indicates whether failure of this asset would pose a direct threat to public health through loss of water supply, water quality degradation, or exposure to contaminants. True if public health risk exists.']
  rating_effective_date date [note: 'The date from which this criticality rating becomes effective and is used for maintenance prioritization and capital planning decisions.']
  rating_expiration_date date [note: 'The date when this criticality rating expires and must be reassessed. Nullable for ratings without a defined review cycle.']
  rating_status varchar [note: 'Current lifecycle status of the criticality rating record. Active ratings are used for operational decisions; superseded ratings are retained for historical analysis.']
  redundancy_available_flag boolean [note: 'Indicates whether backup or redundant assets are available to maintain service if this asset fails. True if redundancy exists, False if asset is a single point of failure.']
  regulatory_consequence_flag boolean [note: 'Indicates whether failure of this asset would result in regulatory non-compliance, permit violations, or mandatory reporting under SDWA, CWA, or NPDES. True if regulatory consequences exist.']
  review_frequency_months varchar [note: 'Standard interval in months between criticality reassessments for this asset. Typically shorter for critical assets and longer for low-criticality assets.']
  safety_impact_flag boolean [note: 'Indicates whether failure of this asset would create safety hazards for employees, contractors, or the public (e.g., chemical release, electrical hazard, structural collapse). True if safety risk exists.']
  service_disruption_duration_hours decimal(8,2) [note: 'Estimated duration in hours that service would be disrupted if this asset fails, accounting for repair time, parts availability, and system restoration procedures.']

  Note: 'Stores the criticality evaluation for each asset, capturing consequence of failure (CoF) score, likelihood of failure (LoF) score, overall risk score, criticality tier (Critical/High/Medium/Low), redundancy availability, customer impact count, regulatory consequence flag, and the methodology version used. Criticality ratings drive maintenance prioritization, inspection frequency, and capital renewal sequencing per ISO 55001 and AWWA asset management best practices.'
}

Table asset.work_order {
  work_order_id varchar [pk, note: 'Unique identifier for the work order record. Primary key.']
  billing_account_id varchar [note: 'Foreign key linking to billing.billing_account. Business justification: Work orders performed for specific customer accounts (service calls, meter work, customer-requested repairs) require account linkage. Required for customer work history tracking, account-specific main']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Work orders charge costs to departmental cost centers (treatment plants, pump stations, distribution zones) for budget tracking, variance analysis, and operational cost allocation required for utility']
  crew_id varchar [note: 'Reference to the maintenance crew or work group assigned to perform the work.']
  enforcement_action_id varchar [note: 'Foreign key linking to compliance.enforcement_action. Business justification: Enforcement actions (consent orders, administrative orders) mandate specific remediation work with deadlines. Work orders must reference enforcement actions to track compliance schedule milestones, re']
  general_ledger_id varchar [note: 'Foreign key linking to finance.general_ledger. Business justification: Work orders post labor, material, and overhead costs to specific GL accounts for financial reporting, rate case cost-of-service studies, and GASB compliance. Essential for integrating maintenance cost']
  job_plan_id varchar [note: 'Foreign key linking to asset.job_plan. Business justification: Work orders frequently execute standardized job plans that define task sequences, labor requirements, materials, and safety procedures. This is a standard CMMS pattern (IBM Maximo, SAP PM). Job plan p']
  location_id varchar [note: 'Reference to the functional location or site where the work is performed (Water Treatment Plant (WTP), Wastewater Treatment Plant (WWTP), pump station, District Metered Area (DMA)).']
  pm_schedule_id varchar [note: 'Reference to the preventive maintenance schedule or route that generated this work order, if applicable.']
  reported_by_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Work order origination tracking distinguishes internal employee-reported issues from customer complaints, critical for root cause analysis and employee engagement metrics. Removes denormalized reporte']
  service_address_id varchar [note: 'Foreign key linking to customer.service_address. Business justification: Work orders require service address for crew dispatch, customer contact, access instructions, and completion documentation. Essential for field operations, customer communication, and GIS-based work o']
  work_asset_registry_id varchar [note: 'Reference to the physical asset (pipe, pump, valve, treatment equipment, vehicle) that is the subject of this work order.']
  work_registry_id varchar [note: 'Reference to the physical asset (pipe, pump, valve, treatment equipment, vehicle) that is the subject of this work order.']
  actual_cost decimal(15,2) [note: 'Total actual cost incurred for the work order, including labor, materials, contractor services, and overhead allocations.']
  actual_finish_timestamp timestamp [note: 'Actual date and time when work execution was completed in the field.']
  actual_labor_hours decimal(10,2) [note: 'Total labor hours actually expended on the work order, captured from time sheets and labor transactions.']
  actual_start_timestamp timestamp [note: 'Actual date and time when work execution began in the field.']
  approved_by varchar [note: 'Name or identifier of the supervisor or manager who approved the work order for execution or closure.']
  assigned_to varchar [note: 'Name or identifier of the technician, crew, or contractor assigned to execute the work order.']
  cause_code varchar [note: 'Standardized code identifying the root cause of the failure (e.g., corrosion, age, improper operation, design defect).']
  closed_timestamp timestamp [note: 'Date and time when the work order was formally closed and moved to historical status.']
  completion_notes varchar [note: 'Detailed narrative entered by the technician upon work completion, documenting findings, actions taken, parts replaced, and any follow-up recommendations.']
  created_timestamp timestamp [note: 'Date and time when the work order record was first created in the Computerized Maintenance Management System (CMMS).']
  downtime_duration_hours decimal(10,2) [note: 'Total hours the asset was out of service or unavailable due to this maintenance activity, critical for calculating Mean Time Between Failures (MTBF) and Mean Time To Repair (MTTR) Key Performance Indicators (KPIs).']
  estimated_cost decimal(15,2) [note: 'Planned total cost for the work order including labor, materials, and services, used for budgeting and Capital Expenditure (CAPEX) / Operating Expenditure (OPEX) planning.']
  estimated_labor_hours decimal(10,2) [note: 'Planned total labor hours required to complete the work order, used for resource planning and scheduling.']
  failure_code varchar [note: 'Standardized code identifying the type of failure or problem that triggered the work order (e.g., leak, blockage, electrical fault, mechanical wear).']
  modified_timestamp timestamp [note: 'Date and time when the work order record was last updated or modified.']
  permit_required boolean [note: 'Indicates whether regulatory permits (confined space entry, hot work, excavation, discharge) are required before work can commence.']
  priority varchar [note: 'Business priority level indicating urgency and impact of the work order on operations, safety, and regulatory compliance.']
  regulatory_compliance_flag boolean [note: 'Indicates whether this work order is driven by regulatory compliance requirements (Safe Drinking Water Act (SDWA), Clean Water Act (CWA), National Pollutant Discharge Elimination System (NPDES), Lead and Copper Rule Revisions (LCRR)).']
  remedy_code varchar [note: 'Standardized code identifying the corrective action taken to resolve the failure (e.g., repair, replace, adjust, clean).']
  reported_date date [note: 'Date when the work need was first reported or identified.']
  safety_plan_required boolean [note: 'Indicates whether a formal safety plan, Job Safety Analysis (JSA), or Occupational Safety and Health Administration (OSHA) compliance documentation is required for this work order.']
  scheduled_finish_date date [note: 'Planned date when work is scheduled to be completed.']
  scheduled_start_date date [note: 'Planned date when work is scheduled to begin.']
  source varchar [note: 'Origin or trigger that created the work order (preventive maintenance schedule, Supervisory Control and Data Acquisition (SCADA) alarm, customer complaint, inspection finding, operator observation, predictive analytics model, regulatory mandate). [ENUM-REF-CANDIDATE: pm_schedule|scada_alarm|customer_complaint|inspection|operator_round|predictive_analytics|regulatory_requirement — 7 candidates stripped; promote to reference product]']
  supervisor_approval_date date [note: 'Date when the work order was reviewed and approved by the maintenance supervisor or manager.']
  warranty_claim boolean [note: 'Indicates whether this work order is associated with a warranty claim against a vendor or contractor for defective equipment or workmanship.']
  work_order_description varchar [note: 'Detailed narrative description of the work to be performed, including scope, objectives, and any special instructions or safety considerations.']
  work_order_number varchar [note: 'Externally visible business identifier for the work order, typically human-readable and used in field operations and reporting.']
  work_order_status varchar [note: 'Current lifecycle status of the work order in the maintenance workflow, from creation through completion and closure. [ENUM-REF-CANDIDATE: draft|approved|scheduled|in_progress|on_hold|completed|closed|cancelled — 8 candidates stripped; promote to reference product]']
  work_order_type varchar [note: 'Classification of the work order by maintenance strategy: preventive maintenance (PM), corrective maintenance (CM), predictive maintenance (PdM), emergency, inspection, calibration, or capital project work. [ENUM-REF-CANDIDATE: preventive_maintenance|corrective_maintenance|predictive_maintenance|emergency|inspection|calibration|project — 7 candidates stripped; promote to reference product]']

  Note: 'Core transactional record for all maintenance activities — preventive (PM), corrective (CM), predictive (PdM), and emergency work orders. Captures work type, priority, originating asset, assigned crew/technician, scheduled and actual start/finish dates, labor hours, failure code, cause code, remedy code, downtime duration, and work order cost. Includes material line items: parts consumed or reserved with quantity, unit cost, issue date, storeroom, and reservation status. Enables actual vs. planned cost tracking (labor, material, contractor/service, overhead) per work order with GL account code and cost center. The authoritative SSOT for maintenance execution and O&M cost accounting, synchronized with IBM Maximo Work Order and SAP PM Order. Supports rate case cost justification and AWWA benchmarking.'
}

Table asset.pm_schedule {
  pm_schedule_id varchar [pk, note: 'Unique identifier for the preventive maintenance schedule record.']
  facility_id varchar [note: 'Reference to the water treatment plant (WTP), wastewater treatment plant (WWTP), pumping station, or other facility where the asset is located and the preventive maintenance will be performed.']
  job_plan_id varchar [note: 'Reference to the standardized job plan that defines the detailed work instructions, materials, tools, and safety procedures for this maintenance task.']
  registry_id varchar [note: 'Reference to the physical asset (equipment, pipe, pump, valve, vehicle) to which this preventive maintenance schedule applies.']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Regulatory requirements drive PM schedules (monthly chlorine residual checks per permit, quarterly backwash inspections per state rules). Links maintenance planning to compliance obligations, ensures ']
  asset_criticality_rating varchar [note: 'Criticality classification of the asset to which this schedule applies, indicating the impact of asset failure on operations, safety, regulatory compliance, or customer service.']
  auto_generate_work_order_flag boolean [note: 'Indicates whether work orders should be automatically generated by the CMMS system when the schedule becomes due, or whether manual review and approval is required before work order creation.']
  cost_center_code decimal(18,2) [note: 'Financial cost center code to which preventive maintenance costs should be allocated for accounting and budgeting purposes.']
  created_timestamp timestamp [note: 'Date and time when this preventive maintenance schedule record was first created in the CMMS system.']
  downtime_required_flag boolean [note: 'Indicates whether the asset must be taken out of service (downtime) to perform the preventive maintenance task, requiring operational planning and backup capacity arrangements.']
  effective_end_date date [note: 'Date when this preventive maintenance schedule expires or is deactivated, after which no further work orders will be generated. Null indicates an open-ended schedule.']
  effective_start_date date [note: 'Date when this preventive maintenance schedule becomes active and begins generating work orders.']
  estimated_downtime_hours decimal(8,2) [note: 'Estimated duration in hours that the asset will be out of service during preventive maintenance, used for operational planning and redundancy management.']
  estimated_labor_cost decimal(12,2) [note: 'Estimated cost of labor required to complete the preventive maintenance task based on estimated hours and labor rates, used for budgeting and OPEX planning.']
  estimated_labor_hours decimal(8,2) [note: 'Estimated number of labor hours required to complete the preventive maintenance task, used for workforce planning and scheduling.']
  estimated_material_cost decimal(12,2) [note: 'Estimated cost of materials, parts, and consumables required to complete the preventive maintenance task, used for budgeting and OPEX planning.']
  frequency_interval varchar [note: 'Numeric value representing the interval between preventive maintenance occurrences, interpreted based on the frequency unit (e.g., 30 for days, 500 for hours, 1000 for gallons).']
  frequency_unit varchar [note: 'Unit of measure for the frequency interval, defining whether the schedule is based on time periods (days, weeks, months, years), operating hours, operational cycles, or volume processed (gallons, cubic meters). [ENUM-REF-CANDIDATE: days|weeks|months|years|hours|cycles|gallons|cubic_meters — 8 candidates stripped; promote to reference product]']
  gl_account_code varchar [note: 'General ledger account code for recording preventive maintenance expenses in the financial system, distinguishing between OPEX maintenance and CAPEX capital improvements.']
  last_modified_by varchar [note: 'Username or identifier of the user who last modified this preventive maintenance schedule record.']
  last_modified_timestamp timestamp [note: 'Date and time when this preventive maintenance schedule record was last modified in the CMMS system.']
  last_performed_date date [note: 'Date when the preventive maintenance task was last completed, used to calculate the next due date for calendar-based schedules.']
  lead_time_days varchar [note: 'Number of days before the next due date that the work order should be generated to allow for planning, scheduling, and resource allocation.']
  maintenance_task_description varchar [note: 'Detailed description of the preventive maintenance task to be performed, including specific procedures, inspections, or servicing activities required.']
  meter_threshold decimal(15,2) [note: 'Threshold value for meter-based preventive maintenance triggers; when the asset meter reading reaches or exceeds this value, a work order is automatically generated.']
  meter_type varchar [note: 'Type of meter or measurement used for meter-based preventive maintenance triggers, such as operating hours, flow volume, pressure cycles, or other asset-specific usage metrics.']
  next_due_date date [note: 'Calculated date when the next preventive maintenance work order should be generated based on the schedule frequency and last performed date.']
  priority varchar [note: 'Priority level assigned to the preventive maintenance schedule based on asset criticality, regulatory requirements, or operational impact, used to sequence work order execution.']
  regulatory_compliance_flag boolean [note: 'Indicates whether this preventive maintenance schedule is required to meet regulatory compliance obligations such as EPA Safe Drinking Water Act (SDWA), Clean Water Act (CWA), NPDES permit conditions, or state-level inspection requirements.']
  regulatory_reference varchar [note: 'Citation or reference to the specific regulatory requirement, permit condition, or compliance standard that mandates this preventive maintenance activity (e.g., SDWA Section 1412, NPDES Permit Condition 3.2).']
  required_skill_certifications varchar [note: 'Comma-separated list of required skill certifications or qualifications that technicians must possess to perform this preventive maintenance task safely and effectively (e.g., electrical license, confined space entry, SCADA operator certification).']
  safety_requirements varchar [note: 'Description of safety precautions, personal protective equipment (PPE), lockout/tagout procedures, confined space entry protocols, or other safety measures required for this preventive maintenance task.']
  schedule_name varchar [note: 'Descriptive name of the preventive maintenance schedule for easy identification by operations and maintenance staff.']
  schedule_number varchar [note: 'Business identifier for the preventive maintenance schedule, typically assigned by the CMMS system for tracking and reporting purposes.']
  schedule_status varchar [note: 'Current lifecycle status of the preventive maintenance schedule indicating whether it is actively generating work orders or has been suspended or deactivated.']
  seasonal_end_month varchar [note: 'Month number (1-12) when seasonal preventive maintenance schedule becomes inactive, applicable only when seasonal_schedule_flag is true.']
  seasonal_schedule_flag boolean [note: 'Indicates whether this preventive maintenance schedule is seasonal in nature, applicable only during specific months or seasons (e.g., winterization of outdoor equipment, summer peak demand preparation).']
  seasonal_start_month varchar [note: 'Month number (1-12) when seasonal preventive maintenance schedule becomes active, applicable only when seasonal_schedule_flag is true.']
  trigger_type varchar [note: 'Type of trigger mechanism that determines when preventive maintenance is due: calendar-based (time intervals), meter-based (usage thresholds), condition-based (sensor readings), runtime-based (operating hours), or cycle-based (number of operations).']
  work_order_type varchar [note: 'Classification of the work order that will be generated from this schedule, indicating the nature of the maintenance activity (preventive maintenance, inspection, calibration, lubrication, cleaning).']
  work_zone varchar [note: 'Specific work zone, area, or department within the facility where the preventive maintenance activity will take place, used for crew assignment and access control.']
  created_by varchar [note: 'Username or identifier of the user who created this preventive maintenance schedule record in the CMMS system.']

  Note: 'Defines preventive maintenance schedules for assets, including maintenance task description, trigger type (calendar-based, meter-based, condition-based), frequency or interval, last performed date, next due date, estimated labor hours, required skill certifications, and associated job plan. Drives automatic work order generation in IBM Maximo. Supports AWWA O&M best practices and regulatory inspection compliance requirements.'
}

Table asset.job_plan {
  job_plan_id varchar [pk, note: 'Unique identifier for the job plan. Primary key.']
  asset_class_id varchar [note: 'Foreign key linking to asset.asset_class. Business justification: Job plans are standardized maintenance procedures defined for specific asset classes. Currently asset_class is stored as STRING code; should be FK to asset_class.asset_class_id for referential integri']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Job plans define standard maintenance tasks with estimated costs allocated to cost centers for annual O&M budgeting. Supports bottom-up budget development and cost center planning.']
  job_org_unit_id varchar [note: 'Reference to the maintenance work center or crew responsible for executing this job plan.']
  job_work_center_org_unit_id varchar [note: 'Reference to the maintenance work center or crew responsible for executing this job plan.']
  approved_by varchar [note: 'Username or identifier of the supervisor or manager who approved this job plan for active use.']
  approved_timestamp timestamp [note: 'Date and time when this job plan was approved and activated for use in work orders and preventive maintenance schedules.']
  confined_space_flag boolean [note: 'Indicates whether this job plan involves work in a confined space (e.g., wet well, tank, vault) requiring permit and atmospheric monitoring.']
  created_timestamp timestamp [note: 'Date and time when this job plan record was first created in the system.']
  downtime_required_flag boolean [note: 'Indicates whether this job plan requires taking the asset or system offline, impacting operations and requiring coordination.']
  effective_end_date date [note: 'Date when this job plan version is superseded or retired. Null indicates the job plan is currently active with no planned end date.']
  effective_start_date date [note: 'Date when this job plan version becomes effective and available for use in work order generation.']
  environmental_impact_notes varchar [note: 'Description of potential environmental impacts and mitigation measures for this job plan (e.g., chemical spill containment, waste disposal procedures).']
  estimated_downtime_hours decimal(8,2) [note: 'Estimated duration in hours that the asset or system will be out of service during execution of this job plan.']
  estimated_duration_hours decimal(8,2) [note: 'Estimated total labor hours required to complete all tasks in this job plan. Used for work order scheduling and resource planning.']
  estimated_labor_cost decimal(12,2) [note: 'Estimated total labor cost in USD to execute this job plan, calculated from labor craft rates and estimated hours.']
  estimated_material_cost decimal(12,2) [note: 'Estimated total material and parts cost in USD required to execute this job plan, based on the materials list.']
  estimated_tool_cost decimal(12,2) [note: 'Estimated cost in USD for specialized tools, equipment rental, or contractor services required for this job plan.']
  frequency_code varchar [note: 'Standard frequency code indicating how often this job plan should be executed when attached to a preventive maintenance schedule. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi_annual|annual|as_needed — 7 candidates stripped; promote to reference product]']
  inspection_points varchar [note: 'List of quality control and inspection checkpoints to be verified during or after job execution, ensuring work meets standards.']
  job_plan_description varchar [note: 'Detailed narrative description of the job plan purpose, scope, and overview of the maintenance activity to be performed.']
  job_plan_number varchar [note: 'The externally-known unique alphanumeric code identifying this job plan template across the organization. Used for referencing in work orders and preventive maintenance schedules.']
  job_plan_status varchar [note: 'Current lifecycle status of the job plan. Only active job plans can be attached to work orders or preventive maintenance schedules.']
  job_type varchar [note: 'Classification of the maintenance activity type that this job plan supports. Determines scheduling and priority rules.']
  last_modified_by varchar [note: 'Username or identifier of the person who most recently updated this job plan record.']
  last_modified_timestamp timestamp [note: 'Date and time when this job plan record was most recently updated.']
  loto_required_flag boolean [note: 'Indicates whether Lockout/Tagout procedures are mandatory for this job plan to ensure worker safety during equipment maintenance.']
  materials_list varchar [note: 'List of materials, parts, and consumables required for this job plan, including part numbers and estimated quantities.']
  notes varchar [note: 'Additional free-form notes, lessons learned, or special instructions for executing this job plan.']
  ppe_requirements varchar [note: 'List of required Personal Protective Equipment for workers executing this job plan (e.g., \'Hard hat, safety glasses, chemical-resistant gloves, steel-toe boots\').']
  priority varchar [note: 'Default priority level assigned to work orders generated from this job plan. Lower numbers indicate higher priority (e.g., 1=Critical, 5=Routine).']
  regulatory_compliance_notes varchar [note: 'Notes on regulatory requirements, permits, or compliance documentation that must be completed as part of this job plan (e.g., EPA reporting, NPDES permit conditions).']
  required_labor_crafts varchar [note: 'Comma-separated list of labor craft skills required to execute this job plan (e.g., \'Electrician, Mechanic, Instrumentation Technician\').']
  revision_number varchar [note: 'Sequential version number tracking changes to the job plan over time. Incremented each time the job plan is updated and re-approved.']
  safety_requirements varchar [note: 'Detailed safety procedures and precautions required for this job plan, including Lockout/Tagout (LOTO), confined space entry, Personal Protective Equipment (PPE), and hazard mitigation steps.']
  source_reference varchar [note: 'Reference to the source document or standard from which this job plan was derived (e.g., \'AWWA M11 Steel Pipe Manual\', \'Manufacturer Service Bulletin 2023-04\').']
  task_sequence varchar [note: 'Step-by-step instructions detailing the ordered sequence of tasks to be performed. Each step includes action description, safety notes, and quality checkpoints.']
  title varchar [note: 'Short descriptive title of the job plan that summarizes the maintenance activity (e.g., \'Pump Impeller Replacement\', \'Chlorine Analyzer Calibration\').']
  tools_list varchar [note: 'List of specialized tools, equipment, and instruments required to perform this job plan (e.g., \'Torque wrench, multimeter, pipe wrench set\').']
  created_by varchar [note: 'Username or identifier of the person who originally created this job plan record.']

  Note: 'Standardized task library defining the step-by-step instructions, required labor crafts, estimated durations, safety procedures (LOTO, confined space, PPE), and materials/tools needed to perform a specific maintenance activity. Job plans are reusable templates attached to PM schedules and work orders. Sourced from IBM Maximo Job Plan module and aligned with AWWA O&M manuals and OSHA safety standards.'
}

Table asset.failure_record {
  failure_record_id varchar [pk, note: 'Unique identifier for the asset failure event record. Primary key.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Failure events trigger emergency repairs charged to cost centers for unplanned maintenance budget tracking. Critical for analyzing cost center budget variances and justifying contingency reserves in r']
  failure_asset_registry_id varchar [note: 'Reference to the physical asset that experienced the failure (equipment, pipe, pump, valve, etc.).']
  failure_registry_id varchar [note: 'Reference to the physical asset that experienced the failure (equipment, pipe, pump, valve, etc.).']
  lab_sample_id varchar [note: 'Foreign key linking to laboratory.lab_sample. Business justification: Failure investigations require water quality sampling to determine if contamination, corrosion, or water chemistry contributed to asset failure. Regulatory requirement for reportable incidents and sta']
  premise_id varchar [note: 'Foreign key linking to customer.premise. Business justification: Failures of customer-side assets (service line breaks, meter malfunctions, lateral collapses) must be tracked to premises for customer impact analysis, regulatory reporting (e.g., lead service line fa']
  reported_by_employee_id varchar [note: 'Reference to the employee who reported or documented the failure event.']
  water_sample_id varchar [note: 'Foreign key linking to quality.water_sample. Business justification: Asset failures (main breaks, tank overflows, pressure loss events) trigger mandatory water quality sampling per regulatory requirements (e.g., bacteriological sampling after pressure loss per TCR/RTCR']
  work_order_id varchar [note: 'Reference to the corrective maintenance work order generated in response to this failure event.']
  actual_repair_cost decimal(15,2) [note: 'Actual total cost incurred to repair or replace the failed asset after work completion.']
  affected_system varchar [note: 'The operational system or process affected by the failure (e.g., high service pump station, chlorination system, SCADA network, distribution main).']
  corrective_actions_recommended varchar [note: 'List of recommended corrective and preventive actions to prevent recurrence of similar failures.']
  created_timestamp timestamp [note: 'Timestamp when this failure record was first created in the system.']
  cso_event_flag boolean [note: 'Boolean flag indicating whether the failure resulted in a Combined Sewer Overflow event requiring regulatory reporting.']
  customers_affected_count varchar [note: 'Count of customer accounts impacted by the failure event (service interruption, pressure loss, water quality issue).']
  detection_method varchar [note: 'Method by which the failure was discovered (SCADA alarm, operator inspection, customer complaint, etc.). [ENUM-REF-CANDIDATE: scada_alarm|operator_inspection|customer_complaint|scheduled_inspection|predictive_maintenance|routine_testing|emergency_response — 7 candidates stripped; promote to reference product]']
  downtime_duration_hours decimal(10,2) [note: 'Total duration in hours that the asset was out of service due to the failure.']
  emergency_response_actions varchar [note: 'Detailed description of immediate emergency response actions taken to mitigate the failure (e.g., valve isolation, backup system activation, customer notification).']
  environmental_impact_description varchar [note: 'Description of any environmental impact resulting from the failure (e.g., water body contamination, soil contamination, habitat damage).']
  failure_cause varchar [note: 'Identified root cause of the failure (e.g., age-related deterioration, improper installation, inadequate maintenance, design deficiency, operational error, external damage).']
  failure_criticality_score varchar [note: 'Calculated criticality score based on failure severity, service impact, and asset importance (typically 1-100 scale).']
  failure_date date [note: 'Calendar date when the asset failure occurred.']
  failure_effect varchar [note: 'Description of the operational impact and consequences of the failure on system performance and service delivery.']
  failure_mode varchar [note: 'Classification of how the asset failed (e.g., mechanical fracture, electrical short, corrosion perforation, seal leakage, bearing seizure, control malfunction).']
  failure_number varchar [note: 'Business-readable unique identifier for the failure event, typically auto-generated by CMMS.']
  failure_severity varchar [note: 'Severity classification of the failure based on service impact, safety risk, and regulatory implications.']
  failure_status varchar [note: 'Current lifecycle status of the failure record in the investigation and resolution workflow.']
  failure_time timestamp [note: 'Precise date and time when the asset failure was detected or occurred.']
  last_modified_timestamp timestamp [note: 'Timestamp when this failure record was last updated or modified.']
  mtbf_impact_flag boolean [note: 'Boolean flag indicating whether this failure event should be included in MTBF reliability calculations for the asset class.']
  mttr_hours decimal(10,2) [note: 'Measured time in hours from failure detection to restoration of asset to full operational status.']
  notes varchar [note: 'Additional free-text notes, observations, or context related to the failure event.']
  overflow_volume_gallons decimal(15,2) [note: 'Estimated volume of wastewater overflow in gallons resulting from SSO or CSO event, if applicable.']
  pressure_drop_psi decimal(8,2) [note: 'Measured drop in system pressure (PSI) resulting from the failure event.']
  production_loss_mgd decimal(12,3) [note: 'Estimated water production capacity lost due to the failure, measured in Million Gallons per Day.']
  regulatory_notification_date date [note: 'Date when regulatory agencies were notified of the failure event, if applicable.']
  regulatory_notification_required_flag boolean [note: 'Boolean flag indicating whether the failure event requires notification to regulatory agencies (EPA, state primacy agency).']
  repair_cost_estimate decimal(15,2) [note: 'Estimated total cost to repair or replace the failed asset, including labor, materials, and contractor costs.']
  resolution_date date [note: 'Date when the failure was fully resolved and the asset was restored to normal operation.']
  root_cause_analysis_completed_flag boolean [note: 'Boolean flag indicating whether a formal root cause analysis (RCA) has been completed for this failure event.']
  root_cause_analysis_findings varchar [note: 'Detailed findings and conclusions from the root cause analysis investigation, including contributing factors and systemic issues identified.']
  service_interruption_flag boolean [note: 'Boolean flag indicating whether the failure resulted in a complete service interruption to customers.']
  sso_event_flag boolean [note: 'Boolean flag indicating whether the failure resulted in a Sanitary Sewer Overflow event requiring regulatory reporting.']
  warranty_claim_flag boolean [note: 'Boolean flag indicating whether the failure is covered under manufacturer or contractor warranty and a claim was filed.']

  Note: 'Documents asset failure events including failure date and time, failure mode, failure cause, failure effect, affected system, downtime duration, service impact (customers affected, MGD lost, PSI drop), emergency response actions taken, and root cause analysis findings. Supports reliability-centered maintenance (RCM) analysis, MTBF/MTTR calculations, and regulatory SSO/CSO incident reporting. Linked to corrective work orders in IBM Maximo.'
}

Table asset.asset_meter {
  asset_meter_id varchar [pk, note: 'Unique surrogate identifier for the asset meter record in the enterprise data platform. Primary key for the asset_meter product. Role: MASTER_RESOURCE.']
  asset_registry_id varchar [note: 'Reference to the parent physical asset (pump, motor, valve, pipe segment, vehicle, etc.) to which this operational meter or counter is attached. Links to the asset master record in the asset domain.']
  location_id varchar [note: 'Reference to the functional location or facility location record where the metered asset is installed. Links to the location hierarchy in the asset domain (e.g., WTP, pump station, WWTP). Supports geographic and facility-level aggregation of meter data.']
  primary_asset_registry_id varchar [note: 'Reference to the parent physical asset (pump, motor, valve, pipe segment, vehicle, etc.) to which this operational meter or counter is attached. Links to the asset master record in the asset domain.']
  alarm_high_threshold decimal(18,4) [note: 'The upper alarm threshold value for this meter. When the reading exceeds this value, a SCADA or CMMS alarm is triggered. For example, high vibration alarm at 0.5 in/s for a pump motor. Supports integration with SCADA HMI alarm management.']
  alarm_low_threshold decimal(18,4) [note: 'The lower alarm threshold value for this meter. When the reading falls below this value, a SCADA or CMMS alarm is triggered. For example, low flow alarm at 0.1 MGD for a treatment process feed pump.']
  asset_metering_meter_id varchar [note: 'The native meter identifier from IBM Maximo Asset Management CMMS (METERNAME or internal Maximo meter key). Used for system-of-record traceability and bidirectional synchronization between the Silver Layer and Maximo.']
  average_reading_rate decimal(18,6) [note: 'The average rate of change per day for this meter, calculated and stored by the CMMS during reading entry (not a derived KPI — stored as a CMMS field used for PM trigger forecasting). For example, average run-hours per day for a pump. Used by meter-based PM triggers to forecast next maintenance due date.']
  avg_calculation_method varchar [note: 'Method used by the CMMS to compute the average_reading_rate. SLIDING_WINDOW: rolling average over a configurable number of recent readings. FIXED_PERIOD: average over a fixed calendar period. LAST_READING: uses only the most recent reading interval.']
  calibration_interval_days decimal(18,6) [note: 'The required frequency of calibration expressed in calendar days. Used to compute next_calibration_date from last_calibration_date and to schedule calibration work orders in IBM Maximo.']
  calibration_status decimal(18,6) [note: 'Current calibration status of the meter instrument. CALIBRATED: within valid calibration period. DUE: calibration due within the next calibration_interval_days. OVERDUE: calibration date has passed without recalibration. IN_PROGRESS: currently being calibrated. NOT_REQUIRED: meter type does not require formal calibration (e.g., simple cycle counters).']
  calibration_tolerance decimal(10,4) [note: 'Acceptable measurement tolerance or accuracy specification for this meter expressed in the meter\'s unit of measure. Readings outside this tolerance trigger recalibration. For example, ±0.5 PSI for a pressure transducer or ±0.01 MGD for a flow totalizer.']
  created_timestamp timestamp [note: 'Timestamp when the asset meter record was first created in the enterprise data platform. Supports audit trail and data lineage requirements. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  current_reading decimal(18,4) [note: 'The most recent recorded value of the meter or counter as of the last_reading_date. For CONTINUOUS meters this is the cumulative total; for GAUGE meters this is the last observed point-in-time value. Principal quantitative fact for this MASTER_RESOURCE.']
  decommission_date date [note: 'Date on which the meter was permanently removed from service and retired. Null for active meters. Used for lifecycle reporting and asset history.']
  installation_date date [note: 'Date on which the meter was physically installed on the asset. Used to calculate meter age, warranty expiry, and to establish the baseline reading at installation.']
  is_regulatory_meter boolean [note: 'Indicates whether readings from this meter are used in regulatory compliance reporting (e.g., EPA NPDES Discharge Monitoring Reports, Safe Drinking Water Act compliance, Monthly Operating Reports). True = regulatory-grade meter subject to calibration and data integrity requirements.']
  last_calibration_date date [note: 'Date on which the meter was most recently calibrated and certified as accurate. Critical for regulatory compliance where metered values (e.g., flow, pressure, chemical dosing) are used in EPA/NPDES reporting.']
  last_reading_date timestamp [note: 'Timestamp of the most recent meter reading captured, whether from SCADA/OSIsoft PI Historian automated feed or manual entry in IBM Maximo. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  location_description varchar [note: 'Free-text description of the physical location where the meter is installed on the asset, e.g., \'Discharge side of Pump 3 at WTP Building A\', \'Inlet valve actuator shaft\'. Supplements the parent asset location for field technician navigation.']
  manufacturer varchar [note: 'Name of the manufacturer of the meter instrument or sensor hardware, e.g., Endress+Hauser, Yokogawa, Emerson, Siemens. Used for procurement, warranty tracking, and spare parts management.']
  measurement_unit varchar [note: 'Engineering unit of measure for the meter reading, e.g., HOURS (run-hours), STARTS (motor starts), CYCLES (valve cycles), MGD (Million Gallons per Day), GPM (Gallons per Minute), PSI (Pounds per Square Inch), NTU (Nephelometric Turbidity Units), RPM, DEGREES_F, INCHES. Aligns with OSIsoft PI Historian tag engineering units.']
  meter_name varchar [note: 'Human-readable descriptive name for the meter or counter, e.g., \'Pump 3 Run Hours\', \'Valve 12 Cycle Count\', \'Influent Flow Totalizer\'. Used for display in CMMS work orders and PM triggers.']
  meter_number varchar [note: 'Externally-known unique alphanumeric identifier for the meter as assigned in IBM Maximo CMMS or SAP PM. Used for cross-system reference and field identification. Distinct from customer billing meter numbers managed by the Metering domain.']
  meter_status varchar [note: 'Current operational lifecycle status of the meter. ACTIVE: in service and collecting readings. INACTIVE: temporarily not in use. RETIRED: permanently decommissioned. SUSPENDED: readings paused (e.g., asset out of service). PENDING_CALIBRATION: due for or undergoing calibration.']
  meter_type varchar [note: 'Classification of the meter per IBM Maximo meter type taxonomy. CONTINUOUS: accumulating counter that never resets (e.g., run-hours, cycle counts, flow totalizer). GAUGE: point-in-time measurement that can go up or down (e.g., PSI, vibration amplitude, temperature). CHARACTERISTIC: qualitative or categorical observation (e.g., condition rating, oil color).']
  metering_meter_id varchar [note: 'Foreign key to the canonical metering_meter record in metering domain']
  model_number varchar [note: 'Manufacturer\'s model or part number for the meter instrument. Used for procurement, spare parts identification, and technical documentation lookup.']
  next_calibration_date date [note: 'Scheduled date by which the meter must next be calibrated to maintain measurement accuracy and regulatory compliance. Drives calibration work order generation in IBM Maximo.']
  pi_tag_name varchar [note: 'The OSIsoft PI Historian tag identifier associated with this meter for automated SCADA data ingestion. Enables direct linkage between the CMMS meter record and the PI Historian time-series data stream. Null if the meter is not integrated with PI Historian.']
  pm_trigger_interval decimal(18,4) [note: 'The recurring interval of meter units between successive PM work order generations. For example, every 500 run-hours or every 1000 valve cycles. Works in conjunction with pm_trigger_threshold for ongoing PM scheduling.']
  pm_trigger_threshold decimal(18,4) [note: 'The meter reading value at which a Preventive Maintenance (PM) work order is automatically generated. For example, a pump PM triggered every 2000 run-hours. Core field enabling meter-based PM scheduling in IBM Maximo.']
  previous_reading decimal(18,4) [note: 'The meter reading value recorded immediately prior to the current reading. Used to calculate consumption delta between readings and to detect anomalous jumps or rollover events.']
  previous_reading_date timestamp [note: 'Timestamp of the meter reading that preceded the current reading. Used in conjunction with previous_reading to compute usage rate and validate reading intervals.']
  reading_frequency varchar [note: 'Expected frequency at which meter readings are collected. CONTINUOUS: real-time SCADA/PI Historian streaming. HOURLY/DAILY/WEEKLY/MONTHLY: scheduled batch collection. ON_DEMAND: readings taken only when required (e.g., during inspections or work orders).']
  reading_range_max decimal(18,4) [note: 'Maximum valid reading value for this meter as defined by the instrument\'s operating range or process design limits. Readings above this value are flagged as suspect or trigger alarms. For example, 150 PSI maximum for a distribution pressure transducer.']
  reading_range_min decimal(18,4) [note: 'Minimum valid reading value for this meter as defined by the instrument\'s operating range or process design limits. Readings below this value are flagged as suspect. For example, 0 PSI minimum for a pressure transducer.']
  reading_source varchar [note: 'The system or method by which the current meter reading was captured. SCADA: from Supervisory Control and Data Acquisition system. PI_HISTORIAN: from OSIsoft PI Historian automated feed. MANUAL: entered manually by a technician in IBM Maximo. AMI: from Advanced Metering Infrastructure. CMMS_IMPORT: batch import from CMMS. FIELD_DEVICE: direct PLC/RTU feed.']
  regulatory_reporting_code varchar [note: 'The regulatory parameter code or identifier associated with this meter for compliance reporting submissions, e.g., EPA DMR parameter code, NPDES permit parameter identifier, or state drinking water program monitoring code. Null if is_regulatory_meter is False.']
  remarks varchar [note: 'Free-text field for operational notes, technician observations, or special instructions related to this meter. For example, notes about known reading anomalies, temporary bypass conditions, or pending replacement. Sourced from IBM Maximo meter remarks field.']
  rollover_value decimal(18,4) [note: 'The maximum value the meter counter can reach before rolling over to zero. Applicable to CONTINUOUS meters with fixed-digit displays (e.g., 99999.9 hours). Used to correctly compute cumulative usage across rollover events. Null if the meter has no rollover limit.']
  sap_measuring_point_code varchar [note: 'The measuring point identifier from SAP Plant Maintenance (PM) module corresponding to this asset meter. Enables reconciliation between IBM Maximo CMMS and SAP PM for assets managed across both systems.']
  serial_number varchar [note: 'Manufacturer\'s serial number uniquely identifying the physical meter instrument. Used for warranty claims, calibration certificates, and asset tracking.']
  updated_timestamp timestamp [note: 'Timestamp when the asset meter record was most recently modified in the enterprise data platform. Used for change tracking, incremental data loads, and audit compliance. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.']

  Note: 'Tracks operational meters, counters, and their reading history for asset condition and usage monitoring — distinct from customer billing meters (owned by the metering domain). Examples include pump run-hours, motor starts, valve cycle counts, flow totalizers (MGD), pressure transducers (PSI), and vibration sensors. Captures meter type, unit of measure, current reading, rollover value, calibration status, and historical reading records (reading date/time, value, source — manual or SCADA/PI Historian automated, inspector ID, delta from previous reading). Feeds meter-based PM triggers, tracks asset utilization trends, and supports predictive maintenance analytics. Integrates with OSIsoft PI Historian. [SSOT: governed by metering.metering_meter] [DEPRECATED: Single source of truth is metering.metering_meter]'
}

Table asset.warranty {
  warranty_id varchar [pk, note: 'Unique system-generated identifier for each asset warranty record in the enterprise asset management system. Primary key for the asset_warranty data product.']
  construction_contract_id varchar [note: 'Foreign key linking to project.construction_contract. Business justification: Equipment warranties originate from construction contracts; warranty claim processing, vendor accountability, and performance bond claims require direct reference to the construction contract that spe']
  created_by_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Warranty record creation audit for procurement process tracking, warranty management program accountability, and data quality monitoring.']
  vendor_id varchar [note: 'Reference to the vendor or manufacturer who issued and is responsible for honoring this warranty. Used to route warranty claims to the correct counterparty.']
  warranty_asset_registry_id varchar [note: 'Reference to the physical infrastructure asset (e.g., pump, valve, pipe, electrical panel, vehicle, WTP/WWTP equipment) covered by this warranty record.']
  warranty_registry_id varchar [note: 'Reference to the physical infrastructure asset (e.g., pump, valve, pipe, electrical panel, vehicle, WTP/WWTP equipment) covered by this warranty record.']
  claim_response_days varchar [note: 'Contractually committed number of calendar days within which the vendor must respond to a submitted warranty claim. Used for SLA monitoring and vendor performance management.']
  claim_submission_process varchar [note: 'Description of the required process for submitting a warranty claim, including required documentation, submission channel (e.g., vendor portal URL, email, phone), and any pre-authorization requirements. Ensures maintenance staff follow correct procedures.']
  claimed_amount_to_date date [note: 'Cumulative monetary value of all warranty claims submitted against this warranty record to date, expressed in USD. Used to track remaining claim capacity against the maximum claim value.']
  component_covered varchar [note: 'Specific sub-component or assembly of the asset covered by this warranty record (e.g., \'motor winding\', \'pump impeller\', \'control panel\', \'membrane module\'). A single asset may have multiple warranty records covering different components.']
  contract_number varchar [note: 'The vendor-issued or internally-assigned contract number governing the warranty terms and conditions. Used for legal reference and claim dispute resolution.']
  coverage_end_date date [note: 'The date on which warranty coverage expires. Proactive monitoring of this date enables timely claim submission and maintenance routing through warranty channels before expiration, reducing OPEX.']
  coverage_scope varchar [note: 'Narrative description of what is covered under this warranty, including specific components, failure modes, and exclusions. For example: \'Covers all mechanical and electrical components of the centrifugal pump excluding wear parts (seals, impellers) and damage caused by cavitation or improper operation.\'']
  coverage_start_date date [note: 'The date on which warranty coverage becomes effective. Typically aligned with the asset installation date, commissioning date, or purchase date depending on warranty terms.']
  created_timestamp timestamp [note: 'The timestamp when this warranty record was first created in the system. Used for audit trail, data lineage, and compliance reporting.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code applicable to all monetary values on this warranty record (e.g., USD). Supports multi-currency environments for international equipment procurement.']
  duration_months decimal(18,6) [note: 'Total length of the warranty coverage period expressed in months. Derived from the vendor contract terms and used for planning and renewal tracking.']
  exclusions varchar [note: 'Explicit list of conditions, components, or failure modes NOT covered by this warranty. Critical for maintenance routing decisions to avoid voiding coverage through excluded repair activities.']
  expiry_alert_days varchar [note: 'Number of calendar days before the coverage end date at which an automated alert should be triggered to notify asset managers and maintenance planners of impending warranty expiration. Enables proactive claim submission and maintenance routing.']
  extended_warranty_cost decimal(18,2) [note: 'The cost paid to purchase an extended warranty beyond the standard manufacturer warranty period, expressed in USD. Captured for CAPEX/OPEX planning and ROI analysis of extended warranty investments.']
  installation_date date [note: 'The date the covered asset or component was physically installed and commissioned. Often used as the warranty coverage start trigger and is required for warranty claim substantiation.']
  last_updated_timestamp timestamp [note: 'The timestamp when this warranty record was most recently modified. Used for change tracking, audit trail, and incremental data pipeline processing in the Databricks lakehouse silver layer.']
  max_claim_value decimal(18,2) [note: 'The maximum cumulative monetary value of claims that can be submitted under this warranty agreement, expressed in USD. Enables OPEX planning and ensures claims do not exceed contractual limits.']
  maximo_warranty_code varchar [note: 'The native warranty record identifier from IBM Maximo Asset Management (CMMS). Retained as a cross-reference key to enable bidirectional traceability between the lakehouse silver layer and the operational CMMS source system.']
  notes varchar [note: 'Free-text field for additional warranty-related information not captured in structured fields, such as special claim conditions, vendor negotiation history, or maintenance routing instructions specific to this warranty.']
  performance_guarantee_metric varchar [note: 'For performance-type warranties, the specific operational metric that is guaranteed (e.g., \'pump flow rate >= 500 GPM\', \'motor efficiency >= 92%\', \'membrane rejection rate >= 99%\'). Null for parts/labor-only warranties.']
  performance_guarantee_threshold decimal(18,4) [note: 'The minimum or target numeric value of the performance guarantee metric that the asset must achieve under the warranty. For example, 500 (GPM) or 92 (%). Used to trigger performance warranty claims when asset output falls below the guaranteed level.']
  performance_guarantee_unit varchar [note: 'Unit of measure for the performance guarantee threshold value (e.g., GPM, MGD, PSI, %, NTU). Ensures correct interpretation of the numeric threshold in the context of the guaranteed metric.']
  purchase_date date [note: 'The date the asset or component was purchased. Some warranties are triggered from purchase date rather than installation date; retained for accurate coverage period calculation.']
  purchase_order_number varchar [note: 'The SAP purchase order number associated with the original procurement of the asset or component. Links the warranty to the procurement transaction for audit and claim substantiation.']
  registration_date date [note: 'The date the warranty was formally registered with the vendor or manufacturer. Some warranties require registration within a specified period post-purchase to be valid; failure to register may void coverage.']
  renewal_option boolean [note: 'Indicates whether the warranty agreement includes an option to renew or extend coverage beyond the original expiration date. If True, renewal terms and pricing should be captured in the coverage_scope field.']
  requires_oem_service boolean [note: 'Indicates whether the warranty terms require that all maintenance and repair work be performed exclusively by the original equipment manufacturer (OEM) or an OEM-authorized service provider. If True, routing non-OEM technicians to this asset may void the warranty.']
  sap_pm_order_number varchar [note: 'The SAP PM maintenance order number associated with warranty-covered repair or maintenance work. Links warranty coverage to the SAP PM work order for cost recovery and OPEX tracking.']
  transferable boolean [note: 'Indicates whether this warranty can be transferred to a new owner or operator in the event of asset sale, transfer, or organizational restructuring. Relevant for capital project asset handovers.']
  vendor_contact_email varchar [note: 'Email address for the designated warranty claims contact at the vendor or manufacturer. Used for formal claim submission and written correspondence.']
  vendor_contact_name varchar [note: 'Name of the designated warranty claims contact person at the vendor or manufacturer organization. Used to initiate and follow up on warranty claims.']
  vendor_contact_phone varchar [note: 'Phone number for the designated warranty claims contact at the vendor or manufacturer. Used to initiate and follow up on warranty claims.']
  warranty_number varchar [note: 'Externally-known warranty certificate or agreement number assigned by the vendor or manufacturer. Used for claim submission and correspondence with the warranty provider. Aligns with IBM Maximo warranty record identifier.']
  warranty_status varchar [note: 'Current lifecycle state of the warranty record. \'active\' indicates coverage is in force; \'expired\' indicates the coverage period has ended; \'claimed\' indicates a claim has been submitted and is under review; \'voided\' indicates the warranty was invalidated (e.g., unauthorized repair); \'pending_activation\' indicates the warranty has been registered but the coverage period has not yet started.']
  warranty_type varchar [note: 'Classification of the warranty coverage scope. \'parts\' covers replacement components only; \'labor\' covers repair labor costs; \'performance\' guarantees operational output levels (e.g., pump flow rate, motor efficiency); \'comprehensive\' covers both parts and labor; \'extended\' is a purchased extension beyond the original term; \'manufacturer\' is the standard OEM warranty.']

  Note: 'Tracks warranty coverage for assets and components, including warranty type (parts, labor, performance), vendor/manufacturer, warranty start and expiration dates, coverage terms, claim submission process, maximum claim value, and warranty status. Enables proactive warranty claim management before expiration and ensures maintenance work is routed through warranty channels when applicable, reducing OPEX.'
}

Table asset.depreciation_schedule {
  depreciation_schedule_id varchar [pk, note: 'Unique system-generated identifier for the depreciation schedule record. Primary key for this entity.']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Capitalized assets from CIP projects require depreciation schedules linked to originating project for GASB 34 compliance, rate case justification, and audit trail connecting capital expenditure author']
  depreciation_asset_registry_id varchar [note: 'Reference to the capital asset for which this depreciation schedule is maintained. Links to the enterprise asset registry.']
  depreciation_registry_id varchar [note: 'Reference to the capital asset for which this depreciation schedule is maintained. Links to the enterprise asset registry.']
  fixed_asset_id varchar [note: 'Foreign key linking to finance.fixed_asset. Business justification: Depreciation schedules calculate periodic depreciation expense for fixed assets. Direct link supports automated depreciation posting, GASB 34 infrastructure reporting, and rate base calculations for u']
  accumulated_depreciation decimal(18,2) [note: 'Total depreciation expense recognized from the depreciation start date through the end of the current fiscal period. Represents the contra-asset balance on the balance sheet. Expressed in USD.']
  acquisition_cost decimal(18,2) [note: 'Total capitalized cost of the asset at acquisition, including purchase price, installation, freight, and any directly attributable costs required to bring the asset to its intended use. Expressed in USD.']
  annual_depreciation_amount decimal(18,2) [note: 'The total depreciation expense allocated for the full fiscal year for this asset. For straight-line method: depreciable_base / useful_life_years. Expressed in USD.']
  asset_class_code varchar [note: 'SAP FI-AA asset class code categorizing the type of capital asset for depreciation area assignment and useful life defaults (e.g., \'PUMP\', \'PIPE\', \'BLDG\', \'VEHICLE\', \'ELEC\', \'METER\').']
  asset_description varchar [note: 'Human-readable description of the capital asset being depreciated (e.g., \'WTP High-Service Pump Unit 3\', \'WWTP Aeration Blower\', \'12-inch Ductile Iron Main - Oak Street\').']
  asset_location_code varchar [note: 'Functional location or facility code where the asset is installed (e.g., WTP facility code, WWTP unit, pump station ID, distribution zone). Aligns with IBM Maximo functional location hierarchy and Esri ArcGIS GIS asset registry.']
  asset_number varchar [note: 'The externally-known fixed asset number as assigned in SAP FI/CO Fixed Asset Accounting (FI-AA) or IBM Maximo. Used for cross-system reconciliation and audit trails.']
  capex_project_number varchar [note: 'The Capital Improvement Program (CIP) project number associated with the asset\'s acquisition or construction. Links depreciation schedules to CAPEX planning and project close-out reporting.']
  capitalization_date date [note: 'The date the asset was formally capitalized and transferred from construction-in-progress (CIP) to fixed assets in SAP FI-AA. May differ from depreciation start date for assets with a commissioning lag.']
  company_code varchar [note: 'SAP FI company code representing the legal entity or municipal utility enterprise to which this depreciation schedule belongs. Supports multi-entity financial reporting and GASB fund accounting.']
  cost_center_code decimal(18,2) [note: 'SAP CO cost center to which depreciation charges are posted, enabling OPEX/CAPEX allocation by operational unit (e.g., WTP operations, distribution, wastewater).']
  declining_balance_rate decimal(8,4) [note: 'The percentage rate applied per period for declining balance or double declining balance depreciation methods. Expressed as a decimal (e.g., 0.2000 = 20%). Null for straight-line method.']
  depreciable_base decimal(18,2) [note: 'The amount subject to depreciation, calculated as acquisition cost minus salvage value. This is the total amount to be allocated over the asset\'s useful life. Expressed in USD.']
  depreciation_area_code varchar [note: 'SAP FI-AA depreciation area identifier representing the valuation purpose (e.g., \'01\' for book depreciation per GAAP/GASB, \'15\' for tax depreciation, \'20\' for cost accounting). Supports parallel valuation for regulatory and tax reporting.']
  depreciation_convention varchar [note: 'The period convention applied to determine depreciation in the first and last year of the asset\'s life (e.g., full_month, half_year, pro_rata). Aligns with SAP FI-AA period control settings.']
  depreciation_end_date date [note: 'The projected or actual date on which depreciation ceases, corresponding to the end of the asset\'s useful life or full depreciation of the depreciable base.']
  depreciation_key varchar [note: 'SAP FI-AA depreciation key code that defines the calculation method, period control, and base value for depreciation posting (e.g., \'LINR\' for straight-line, \'0000\' for no depreciation). Enables direct reconciliation with SAP Fixed Asset Accounting.']
  depreciation_method varchar [note: 'Accounting method used to allocate the depreciable base over the asset\'s useful life. Straight-line is most common for municipal water utility infrastructure per GASB. [ENUM-REF-CANDIDATE: straight_line|declining_balance|double_declining_balance|units_of_production|sum_of_years_digits — promote to reference product]']
  depreciation_start_date date [note: 'The date on which depreciation begins for the asset, typically the in-service date or acquisition date per GAAP/GASB capitalization policy.']
  disposal_date date [note: 'The date the asset was retired, disposed of, or decommissioned. Triggers cessation of depreciation and recognition of any gain or loss on disposal in SAP FI-AA.']
  disposal_proceeds decimal(18,2) [note: 'Cash or fair value received upon disposal or sale of the asset. Used to calculate gain or loss on disposal: disposal_proceeds minus net_book_value at disposal date. Expressed in USD.']
  fiscal_period varchar [note: 'The accounting period (month 1–12) within the fiscal year for which this depreciation record applies. Enables monthly depreciation posting and period-end close reconciliation in SAP FI/CO.']
  fiscal_year varchar [note: 'The fiscal year to which this depreciation schedule record applies. Supports annual depreciation posting, CAPEX/OPEX reporting, and GASB financial statement preparation.']
  fund_code varchar [note: 'Governmental fund code (e.g., Enterprise Fund, Capital Projects Fund) to which the asset and its depreciation are attributed, per GASB fund accounting requirements for municipal utilities.']
  gl_account_code varchar [note: 'SAP FI General Ledger account code for the depreciation expense posting (e.g., the depreciation expense account and accumulated depreciation contra-asset account). Enables financial statement mapping.']
  impairment_loss decimal(18,2) [note: 'Cumulative impairment charges recognized against the asset when its carrying value exceeds its recoverable amount, per GAAP ASC 360 impairment testing. Reduces net book value beyond scheduled depreciation. Expressed in USD.']
  in_service_date date [note: 'The date the asset was placed into operational service. This is the trigger date for depreciation commencement per GAAP/GASB policy and aligns with IBM Maximo asset activation.']
  last_reviewed_date date [note: 'Date the depreciation schedule was last reviewed and validated by the asset accounting team, supporting annual audit requirements and GASB financial statement preparation.']
  net_book_value decimal(18,2) [note: 'Current carrying value of the asset on the balance sheet, calculated as acquisition cost minus accumulated depreciation. Key metric for CAPEX/OPEX planning and asset renewal decisions. Expressed in USD.']
  notes varchar [note: 'Free-text field for recording significant accounting judgments, useful life revision rationale, impairment triggers, regulatory directives, or other material information relevant to this depreciation schedule.']
  period_depreciation_amount decimal(18,2) [note: 'The depreciation expense allocated for the specific fiscal period (month). Used for monthly journal entry posting to the depreciation expense account in SAP FI/CO. Expressed in USD.']
  record_created_timestamp timestamp [note: 'The timestamp when this depreciation schedule record was first created in the system, supporting audit trail and data lineage requirements.']
  record_updated_timestamp timestamp [note: 'The timestamp when this depreciation schedule record was last modified, supporting change tracking, audit trail, and period-end reconciliation.']
  remaining_useful_life_years decimal(10,2) [note: 'Estimated remaining useful life of the asset in years as of the last assessment date. Used for condition-based depreciation adjustments and asset renewal planning under CIP.']
  reviewed_by varchar [note: 'Name or employee ID of the asset accountant or finance officer who last reviewed and approved this depreciation schedule record, supporting audit trail and SOX/GASB compliance.']
  salvage_value decimal(18,2) [note: 'Estimated residual value of the asset at the end of its useful life, used to calculate the depreciable base. For most water utility infrastructure, this is often zero. Expressed in USD.']
  schedule_status varchar [note: 'Current lifecycle status of the depreciation schedule record. \'active\' = depreciation ongoing; \'suspended\' = temporarily halted (e.g., asset taken out of service); \'fully_depreciated\' = net book value at or near salvage value; \'disposed\' = asset retired; \'impaired\' = impairment recognized; \'draft\' = pending approval.']
  units_of_production_period decimal(18,2) [note: 'Actual production units consumed during the current fiscal period, used to calculate period depreciation under the units-of-production method (e.g., gallons pumped, operating hours logged via SCADA/OSIsoft PI Historian).']
  units_of_production_total decimal(18,2) [note: 'Total estimated production units over the asset\'s useful life, used as the denominator for units-of-production depreciation method (e.g., total gallons pumped, total operating hours). Applicable only when depreciation_method = \'units_of_production\'.']
  useful_life_revised_years varchar [note: 'Updated estimated useful life in years following a formal engineering reassessment or condition assessment. Replaces original useful_life_years for prospective depreciation calculation.']
  useful_life_revision_date date [note: 'Date on which the asset\'s estimated useful life was last revised, triggering a prospective change in depreciation calculation per GAAP ASC 250 change in accounting estimate.']
  useful_life_years varchar [note: 'Estimated useful life of the asset in years, as determined by engineering assessment and aligned with AWWA asset life guidelines and GASB/GAAP standards (e.g., 50 years for water mains, 20 years for pumps, 10 years for meters).']
  wbs_element varchar [note: 'SAP PS Work Breakdown Structure element linking the asset to its originating Capital Improvement Program (CIP) project for CAPEX tracking and project settlement.']

  Note: 'Financial depreciation schedule for capital assets, capturing acquisition cost, salvage value, useful life (years), depreciation method (straight-line, declining balance, units of production), annual depreciation amount, accumulated depreciation, net book value, and depreciation start date. Aligned with GAAP/GASB standards for municipal utility accounting. Integrates with SAP FI/CO Fixed Asset module and supports CAPEX/OPEX reporting.'
}

Table asset.acquisition {
  acquisition_id varchar [pk, note: 'Unique identifier for the asset acquisition record. Primary key for the asset acquisition data product.']
  acquisition_asset_registry_id varchar [note: 'Reference to the asset being acquired in the asset registry. Links this acquisition to the corresponding asset_registry record.']
  acquisition_registry_id varchar [note: 'Reference to the asset being acquired in the asset registry. Links this acquisition to the corresponding asset_registry record.']
  cip_project_id varchar [note: 'Capital Improvement Program project identifier if the asset was acquired as part of a capital project. Links to project management and budget tracking.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Acquisitions are charged to departmental cost centers for capital budget tracking, CIP program management, and accountability. Supports budget-to-actual variance reporting for capital projects.']
  facility_id varchar [note: 'Identifier for the Water Treatment Plant (WTP), Wastewater Treatment Plant (WWTP), pump station, or other facility where the asset is located.']
  general_ledger_id varchar [note: 'Foreign key linking to finance.general_ledger. Business justification: Capital asset acquisitions post to specific GL accounts for capitalization, depreciation tracking, and GASB 34 infrastructure reporting. Critical for financial statement preparation and regulatory com']
  vendor_id varchar [note: 'Unique identifier for the vendor in the procurement or Enterprise Resource Planning (ERP) system.']
  acquisition_date date [note: 'Date on which the asset was legally acquired or title transferred to the utility. Used for depreciation start date calculation and asset lifecycle tracking.']
  acquisition_status varchar [note: 'Current status of the acquisition record in the workflow. Tracks progression from initiation through completion and asset registry creation.']
  acquisition_type varchar [note: 'Method by which the asset was acquired into the utility\'s asset base. Determines accounting treatment and capitalization rules.']
  approval_date date [note: 'Date on which the asset acquisition was formally approved by the designated authority. Part of the audit trail.']
  approved_by varchar [note: 'Name or identifier of the manager or authority who approved the asset acquisition. Required for audit trail and governance.']
  asset_category varchar [note: 'Detailed categorization within the asset class such as pump, valve, pipe, tank, or vehicle. Supports asset hierarchy and reporting.']
  asset_class varchar [note: 'High-level classification of the asset type such as treatment equipment, distribution infrastructure, collection system, or vehicle. Used for depreciation schedule assignment.']
  capitalization_threshold_amount decimal(18,2) [note: 'Minimum dollar amount threshold for capitalizing an asset as defined by the utility\'s accounting policy. Typically ranges from $1,000 to $5,000 for water utilities.']
  capitalization_threshold_met_flag boolean [note: 'Indicates whether the acquisition cost meets the utility\'s capitalization threshold for fixed asset recording. Determines if asset is capitalized or expensed.']
  commissioning_date date [note: 'Date on which the asset was placed into service and became operational. Marks the start of depreciation for accounting purposes.']
  contractor_name varchar [note: 'Name of the construction contractor who built or installed the asset, applicable for construction acquisition type.']
  cost decimal(18,2) [note: 'Total cost of acquiring the asset including purchase price, installation, freight, and other capitalizable costs. Basis for depreciation calculation.']
  created_timestamp timestamp [note: 'Timestamp when the asset acquisition record was first created in the system. Audit field for data lineage and compliance.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the acquisition cost. Typically USD for United States water utilities.']
  depreciation_method varchar [note: 'Accounting method used to depreciate the asset over its useful life. Straight-line is most common for water utility infrastructure.']
  functional_location varchar [note: 'SAP PM functional location code representing the hierarchical location of the asset within the utility\'s infrastructure. Supports Geographic Information System (GIS) integration.']
  funding_source varchar [note: 'Source of funds used to finance the asset acquisition. Critical for Capital Expenditure (CAPEX) tracking and regulatory rate case filings.']
  grant_award_num varchar [note: 'Unique identifier for the grant award that funded the acquisition, required for grant compliance reporting.']
  grant_program_name varchar [note: 'Name of the federal, state, or local grant program that funded the acquisition, if applicable. Examples include EPA Water Infrastructure Finance and Innovation Act (WIFIA) or State Revolving Fund (SRF).']
  initial_condition_grade varchar [note: 'Condition assessment grade assigned at the time of acquisition. Baseline for future condition monitoring and asset health tracking.']
  last_modified_timestamp timestamp [note: 'Timestamp when the asset acquisition record was last updated. Audit field for change tracking and data quality monitoring.']
  maximo_asset_num varchar [note: 'IBM Maximo Computerized Maintenance Management System (CMMS) asset number assigned at acquisition. External system identifier for cross-reference.']
  notes varchar [note: 'Free-text notes documenting special circumstances, conditions, or details about the asset acquisition. Supports audit trail and historical context.']
  purchase_order_num varchar [note: 'Purchase order number from SAP Materials Management (MM) or procurement system authorizing the asset acquisition. Links to procurement transaction.']
  salvage_value decimal(18,2) [note: 'Estimated residual value of the asset at the end of its useful life. Used in depreciation calculation for certain methods.']
  sap_equipment_num varchar [note: 'SAP Enterprise Resource Planning (ERP) Plant Maintenance (PM) equipment number assigned at acquisition. External system identifier for cross-reference.']
  useful_life_years varchar [note: 'Expected useful life of the asset in years for depreciation calculation. Varies by asset class per Generally Accepted Accounting Principles (GAAP) and Governmental Accounting Standards Board (GASB) guidelines.']
  warranty_duration_months decimal(18,6) [note: 'Duration of the warranty period in months. Calculated from warranty start and expiry dates for reporting purposes.']
  warranty_expiry_date date [note: 'Date on which the manufacturer or contractor warranty period ends. Critical for maintenance planning and defect liability tracking.']
  warranty_start_date date [note: 'Date on which the manufacturer or contractor warranty period begins for the acquired asset.']
  work_order_num varchar [note: 'Work order number from IBM Maximo or SAP PM for construction or installation activities related to the acquisition.']

  Note: 'Records the acquisition of new assets into the utility\'s asset base, capturing acquisition type (purchase, construction, donation, transfer), acquisition date, purchase order reference, vendor/contractor, acquisition cost, funding source (CAPEX, grant, developer contribution), commissioning date, and initial condition grade. Triggers creation of the asset_registry record and depreciation_schedule. Integrates with SAP MM purchase orders and SAP FI asset capitalization.'
}

Table asset.disposal {
  disposal_id varchar [pk, note: 'Unique identifier for the asset disposal record. Primary key for the asset disposal transaction.']
  cip_project_id varchar [note: 'Reference to the CIP project that triggered the asset replacement and disposal, if applicable. Links disposal to capital planning and renewal programs.']
  disposal_registry_id varchar [note: 'Reference to the asset being disposed from the asset registry. Links to the physical infrastructure asset (pipe, pump, valve, equipment, vehicle) that is being retired or decommissioned.']
  disposal_replacement_asset_registry_id varchar [note: 'Reference to the new asset that replaced the disposed asset, if disposal reason was replacement. Links retired asset to its successor for lifecycle tracking.']
  general_ledger_id varchar [note: 'Foreign key linking to finance.general_ledger. Business justification: Asset disposals generate gain/loss transactions posted to specific GL accounts for financial reporting. Required for accurate net book value adjustments and GASB compliance in financial statements.']
  primary_disposal_registry_id varchar [note: 'Reference to the asset being disposed from the asset registry. Links to the physical infrastructure asset (pipe, pump, valve, equipment, vehicle) that is being retired or decommissioned.']
  vendor_id varchar [note: 'Reference to the vendor or contractor who performed the disposal, demolition, or removal services. Links to vendor master data in SAP MM or procurement system.']
  accumulated_depreciation decimal(15,2) [note: 'The total depreciation expense accumulated on the asset from installation date through disposal date. Used in calculating book value and gain/loss on disposal.']
  approval_date date [note: 'The date on which the disposal transaction was formally approved by the authorizing approver. Required before disposal can proceed.']
  approved_by varchar [note: 'Name or identifier of the authorizing approver who approved the asset disposal. Typically a senior manager, director, or capital planning committee member with authority over asset retirement decisions.']
  book_value_at_disposal decimal(15,2) [note: 'The net book value (original acquisition cost minus accumulated depreciation) of the asset at the time of disposal. Used to calculate gain or loss on disposal for financial reporting.']
  buyer_contact_info varchar [note: 'Contact information (phone, email, or address) for the buyer of the asset. Used for transfer documentation and warranty transfer. Confidential business contact data.']
  buyer_name varchar [note: 'Name of the individual or organization that purchased the asset, if disposal method was sale or auction. Null for other disposal methods.']
  completion_date date [note: 'The date on which the physical disposal activity was completed. May differ from disposal effective date if removal or demolition took multiple days.']
  cost decimal(15,2) [note: 'The total cost incurred to dispose of the asset. Includes demolition costs, removal costs, environmental remediation, transportation, and disposal fees.']
  cost_center decimal(18,2) [note: 'The cost center responsible for the asset at the time of disposal. Used for departmental cost allocation and budget tracking.']
  created_timestamp timestamp [note: 'The timestamp when this disposal record was first created in the system. Audit trail for record creation.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts in this disposal record. Typically USD for U.S. water utilities.']
  disposal_date date [note: 'The date on which the asset was officially retired or disposed. This is the principal business event date that triggers SAP FI-AA asset retirement posting and updates the asset registry operational status to Retired.']
  disposal_number varchar [note: 'Business identifier for the disposal transaction. Externally-known unique number used for tracking and audit purposes across SAP FI-AA and Maximo.']
  disposal_status varchar [note: 'Current lifecycle status of the disposal transaction. Tracks workflow from initiation through final completion and posting to financial systems. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|in_progress|completed|cancelled|reversed — 7 candidates stripped; promote to reference product]']
  environmental_clearance_date date [note: 'The date on which environmental clearance was obtained, if required. Null if no clearance was required.']
  environmental_clearance_notes varchar [note: 'Free-text notes documenting environmental clearance process, remediation actions taken, or hazardous material handling procedures followed during disposal.']
  environmental_clearance_required boolean [note: 'Indicates whether environmental clearance or remediation was required before disposal. True for assets containing hazardous materials, lead pipes, asbestos insulation, or contaminated equipment.']
  gain_loss_on_disposal decimal(15,2) [note: 'The accounting gain or loss recognized on the disposal transaction, calculated as net disposal value minus book value at disposal. Positive values represent gains, negative values represent losses.']
  initiated_by varchar [note: 'Name or identifier of the employee or department that initiated the disposal request. Typically an asset manager, operations supervisor, or maintenance planner.']
  last_modified_by varchar [note: 'The user identifier or name of the person who last modified this disposal record. Audit trail for accountability.']
  last_modified_timestamp timestamp [note: 'The timestamp when this disposal record was last updated. Audit trail for record modification.']
  location varchar [note: 'The physical location or facility where the asset was disposed, demolished, or removed from. May be a treatment plant, pump station, or field location.']
  maximo_disposal_code varchar [note: 'The disposal transaction identifier in IBM Maximo CMMS. Used for cross-system reconciliation and audit trail between Maximo and SAP FI-AA.']
  method varchar [note: 'The method by which the asset was disposed. Indicates whether the asset was sold, scrapped, transferred to another entity, donated, demolished, or salvaged for parts. [ENUM-REF-CANDIDATE: salvage|demolition|sale|donation|transfer|scrap|auction — 7 candidates stripped; promote to reference product]']
  net_disposal_value decimal(15,2) [note: 'The net financial result of the disposal transaction, calculated as disposal proceeds minus disposal costs. May be positive (gain) or negative (loss).']
  notes varchar [note: 'Free-text notes providing additional context, special handling instructions, lessons learned, or other relevant information about the disposal transaction.']
  proceeds decimal(15,2) [note: 'The monetary amount received from the disposal of the asset, if any. Represents sale price, salvage value, or auction proceeds. Zero for demolition or scrap with no recovery value.']
  retirement_reason varchar [note: 'The primary business or operational reason for retiring the asset. Captures whether disposal was due to end of useful life, failure, regulatory mandate, planned replacement, or other strategic decision. [ENUM-REF-CANDIDATE: end_of_life|catastrophic_failure|obsolescence|regulatory_requirement|replacement|consolidation|capacity_reduction|safety_hazard|environmental_compliance — 9 candidates stripped; promote to reference product]']
  retirement_reason_notes varchar [note: 'Free-text narrative providing additional context and details about the reason for asset retirement. May include failure analysis, condition assessment summary, or regulatory citation.']
  sap_asset_retirement_doc varchar [note: 'The SAP FI-AA asset retirement document number generated when the disposal transaction was posted to the financial system. Used for financial audit and reconciliation.']
  sap_posting_date date [note: 'The date on which the asset retirement transaction was posted to SAP FI-AA general ledger. May differ from disposal date due to period-end closing rules.']
  transfer_to_entity varchar [note: 'Name of the entity (department, municipality, or organization) to which the asset was transferred, if disposal method was transfer. Null for other disposal methods.']
  work_order_number varchar [note: 'The Maximo work order number associated with the physical removal, demolition, or disposal activity. Links disposal transaction to field execution.']
  created_by varchar [note: 'The user identifier or name of the person who created this disposal record. Audit trail for accountability.']

  Note: 'Records the retirement, disposal, or decommissioning of assets from the utility\'s active inventory. Captures disposal date, disposal method (salvage, demolition, sale, transfer), disposal proceeds, reason for retirement (end of life, failure, regulatory, replacement), authorizing approver, and final book value at disposal. Triggers SAP FI-AA asset retirement posting and updates asset_registry operational status to Retired.'
}

Table asset.inspection_event {
  inspection_event_id varchar [pk, note: 'Unique identifier for the inspection event record. Primary key.']
  facility_id varchar [note: 'Reference to the water treatment plant (WTP), wastewater treatment plant (WWTP), or other facility where the inspection occurred.']
  inspection_asset_registry_id varchar [note: 'Reference to the asset or infrastructure component that was inspected.']
  inspection_checklist_id varchar [note: 'Reference to the standardized inspection checklist or form template used during the inspection.']
  inspection_registry_id varchar [note: 'Reference to the asset or infrastructure component that was inspected.']
  inspector_employee_id varchar [note: 'Reference to the employee who performed the inspection.']
  lab_sample_id varchar [note: 'Foreign key linking to laboratory.lab_sample. Business justification: Inspections trigger compliance and investigative sampling: tank inspections require bacteriological verification, cross-connection inspections require water quality testing, valve inspections may trig']
  premise_id varchar [note: 'Foreign key linking to customer.premise. Business justification: Inspections of backflow prevention devices, service laterals, and customer-owned infrastructure occur at premises. Required for cross-connection control programs, LCRR compliance, and regulatory repor']
  primary_inspection_approved_by_employee_id varchar [note: 'Reference to the supervisor or manager who reviewed and approved the inspection results.']
  water_sample_id varchar [note: 'Foreign key linking to quality.water_sample. Business justification: Regulatory inspections (sanitary surveys, LCRR system assessments, tank inspections) include water quality sampling as part of the inspection protocol. Real business need: compliance documentation lin']
  work_order_id varchar [note: 'Reference to the parent work order under which this inspection was performed, if applicable.']
  approval_date date [note: 'Date on which the inspection results were formally approved by the reviewing authority.']
  checklist_version varchar [note: 'Version identifier of the inspection checklist used, ensuring traceability to specific regulatory or operational standards.']
  corrective_action_due_date date [note: 'Target date by which identified deficiencies must be remediated, based on regulatory or operational requirements.']
  corrective_action_required_flag boolean [note: 'Indicates whether corrective action work orders or follow-up activities are required as a result of this inspection.']
  created_timestamp timestamp [note: 'Timestamp when this inspection event record was first created in the system.']
  critical_deficiency_flag boolean [note: 'Indicates whether any critical or high-severity deficiencies were identified that require immediate corrective action.']
  deficiencies_identified_count varchar [note: 'Total number of deficiencies, non-conformances, or issues identified during the inspection.']
  deficiency_summary varchar [note: 'Summary description of all deficiencies identified during the inspection, including severity and recommended actions.']
  duration_minutes decimal(18,6) [note: 'Total time spent performing the inspection, measured in minutes.']
  environmental_impact_flag boolean [note: 'Indicates whether the inspection identified any environmental compliance issues or potential environmental impacts.']
  functional_location varchar [note: 'SAP PM functional location code representing the hierarchical location of the inspected asset within the facility.']
  inspection_date date [note: 'The calendar date on which the physical inspection was performed.']
  inspection_end_time timestamp [note: 'Timestamp when the inspection activity was completed.']
  inspection_frequency_days varchar [note: 'Required frequency of this inspection type, measured in days, as mandated by regulatory or operational policy.']
  inspection_notes varchar [note: 'Free-text field for inspector observations, comments, and detailed findings from the inspection.']
  inspection_start_time timestamp [note: 'Timestamp when the inspection activity commenced.']
  inspection_status varchar [note: 'Current lifecycle status of the inspection event. [ENUM-REF-CANDIDATE: scheduled|in_progress|completed|cancelled|failed|pending_review|approved — 7 candidates stripped; promote to reference product]']
  inspection_type varchar [note: 'Classification of the inspection activity. [ENUM-REF-CANDIDATE: routine|regulatory|post_incident|pre_commissioning|condition_assessment|safety|environmental|quality|preventive|corrective — promote to reference product]']
  inspector_certification_num varchar [note: 'Professional certification or license number of the inspector, if required by regulatory authority.']
  inspector_name varchar [note: 'Full name of the inspector who conducted the inspection.']
  last_modified_timestamp timestamp [note: 'Timestamp when this inspection event record was most recently updated.']
  maximo_inspection_num varchar [note: 'External inspection identifier from IBM Maximo CMMS system.']
  next_inspection_due_date date [note: 'Scheduled date for the next required inspection of this asset or component.']
  pass_fail_outcome varchar [note: 'Overall pass/fail result of the inspection based on checklist criteria and regulatory requirements.']
  permit_number varchar [note: 'External permit identifier issued by the regulatory authority, if this inspection is tied to permit compliance.']
  regulatory_agency varchar [note: 'Name of the regulatory authority that mandated or oversees this inspection (e.g., EPA, state primacy agency, OSHA).']
  regulatory_inspection_flag boolean [note: 'Indicates whether this inspection was mandated by a regulatory authority (EPA, state primacy agency, OSHA) or was voluntary/internal.']
  report_submission_date date [note: 'Date on which the inspection report was submitted to the regulatory authority.']
  report_submitted_flag boolean [note: 'Indicates whether the inspection report has been submitted to the regulatory authority, if required.']
  safety_incident_flag boolean [note: 'Indicates whether a safety incident or near-miss occurred during the inspection activity.']
  weather_conditions varchar [note: 'Weather conditions at the time of inspection, relevant for outdoor infrastructure inspections (pipes, valves, tanks).']

  Note: 'Operational record of a physical inspection performed on an asset or infrastructure component, including inspection type (routine, regulatory, post-incident, pre-commissioning), inspector identity, inspection date, checklist used, pass/fail outcome, deficiencies identified, corrective action required flag, and regulatory permit reference. Distinct from condition_assessment (which produces a scored condition grade) — inspection_event captures compliance-driven inspection activities required by EPA, state primacy agencies, and OSHA.'
}

Table asset.document {
  document_id varchar [pk, note: 'Unique identifier for the asset document record. Primary key for the asset document registry.']
  certificate_of_analysis_id varchar [note: 'Foreign key linking to laboratory.certificate_of_analysis. Business justification: Asset files contain certificates of analysis for treatment chemicals, pipe materials, coatings, and construction materials. Standard procurement documentation and regulatory compliance requirement for']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: As-built drawings, O&M manuals, warranty certificates, and technical specifications generated during capital projects must reference the originating CIP project for asset lifecycle documentation, regu']
  compliance_permit_id varchar [note: 'Reference to the regulatory permit this document is associated with, if applicable.']
  design_contract_id varchar [note: 'Foreign key linking to project.design_contract. Business justification: Design deliverables (calculations, specifications, technical memoranda, basis-of-design reports) are design contract work products; professional liability claims, design standard compliance verificati']
  document_asset_registry_id varchar [note: 'Reference to the physical asset this document is associated with. Links to the asset registry.']
  document_registry_id varchar [note: 'Reference to the physical asset this document is associated with. Links to the asset registry for equipment, pipes, pumps, valves, and other infrastructure.']
  facility_id varchar [note: 'Reference to the water treatment plant (WTP), wastewater treatment plant (WWTP), or other facility this document pertains to.']
  primary_document_approved_by_employee_id varchar [note: 'Employee identifier for the internal staff member who approved the document.']
  primary_superseded_by_document_id varchar [note: 'Reference to the newer document that replaces this document. Maintains document version lineage and ensures users access the current revision.']
  related_work_order_id varchar [note: 'Reference to a work order that generated or is associated with this document, such as inspection reports or maintenance records.']
  test_result_id varchar [note: 'Foreign key linking to laboratory.test_result. Business justification: Asset documentation packages include laboratory test results for commissioning reports, material certifications, water quality compliance records, and coating/lining verification. Required for regulat']
  vendor_id varchar [note: 'Reference to the vendor or supplier who provided the document, applicable for vendor-supplied documentation such as manuals and specifications.']
  access_restriction varchar [note: 'Description of who may access the document. Defines user roles, departments, or security clearances required for document access.']
  approval_date date [note: 'Date when the document received official approval for release and use.']
  approved_by varchar [note: 'Name of the individual who approved the document for use. Establishes document authority and accountability.']
  approved_date date [note: 'Date when the document was formally approved. Marks the transition to active status.']
  author_name varchar [note: 'Name of the individual or organization that created the document. Identifies the document originator for accountability.']
  author_organization varchar [note: 'Organization or company that produced the document. Relevant for vendor-supplied documentation and external engineering firms.']
  compliance_standard varchar [note: 'Industry or regulatory standard that the document complies with. Examples include AWWA standards, ISO 55001, SDWA, CWA, or OSHA regulations.']
  confidentiality_level varchar [note: 'Data classification level of the document content. Determines access controls and distribution restrictions.']
  created_timestamp timestamp [note: 'Date and time when the document record was first created in the system. Supports audit trails and data lineage.']
  destruction_eligible_date date [note: 'Calculated date when the document becomes eligible for destruction based on retention policies.']
  disposal_date date [note: 'Date when the document is eligible for destruction or archival per retention policy. Supports records lifecycle management.']
  document_category varchar [note: 'High-level categorization of the document by business function. Supports document organization and retrieval.']
  document_description varchar [note: 'Detailed description of the document content, scope, and purpose. Supports document search and classification.']
  document_number varchar [note: 'Unique business identifier for the document. Used for tracking and retrieval in document management systems and regulatory audits.']
  document_status varchar [note: 'Current lifecycle status of the document. Tracks document progression through review, approval, and archival processes. [ENUM-REF-CANDIDATE: draft|under_review|approved|active|superseded|archived|obsolete — 7 candidates stripped; promote to reference product]']
  document_type varchar [note: 'Classification of the document type. Categorizes documents by their purpose and content to support ISO 55001 documentation requirements and regulatory audit readiness. [ENUM-REF-CANDIDATE: as_built_drawing|om_manual|equipment_datasheet|commissioning_report|test_certificate|regulatory_permit|warranty_document|inspection_report|maintenance_procedure|safety_data_sheet — 10 candidates stripped; promote to reference product]']
  effective_date date [note: 'Date when the document becomes effective and applicable for use. Critical for regulatory permits and compliance documentation.']
  expiration_date date [note: 'Date when the document expires or is no longer valid. Applicable to permits, certifications, and time-limited approvals.']
  file_format varchar [note: 'Digital file format of the document. Identifies the software and tools required to view and edit the document. [ENUM-REF-CANDIDATE: pdf|dwg|dxf|docx|xlsx|jpg|png|tif — 8 candidates stripped; promote to reference product]']
  file_name varchar [note: 'Name of the digital file as stored in the document management system. Includes file extension for format identification.']
  file_size_kb decimal(12,2) [note: 'Size of the electronic document file measured in kilobytes.']
  file_size_mb decimal(10,2) [note: 'Size of the document file in megabytes. Used for storage management and download time estimation.']
  gis_feature_code varchar [note: 'Identifier for the associated GIS feature in Esri ArcGIS. Links documents to spatial assets such as pipes, valves, and facilities.']
  issue_date date [note: 'Date when the document was officially issued or published for use.']
  keywords varchar [note: 'Comma-separated list of keywords or tags for document search and classification. Enhances document discoverability in the document management system.']
  language_code varchar [note: 'Three-letter ISO 639-2 language code indicating the primary language of the document. Supports multilingual document management.']
  last_modified_timestamp timestamp [note: 'Date and time when the document record was last updated. Tracks the most recent change to the document metadata.']
  maximo_document_code varchar [note: 'Document identifier in IBM Maximo CMMS. Provides traceability to the source system for asset management integration.']
  notes varchar [note: 'Additional comments, instructions, or context about the document. Provides supplementary information not captured in other fields.']
  regulatory_agency varchar [note: 'Name of the regulatory agency that requires or issued the document. Examples include EPA, state drinking water programs, OSHA, or local health departments.']
  regulatory_reference varchar [note: 'Citation or reference to the regulatory requirement, permit, or compliance obligation that this document supports or fulfills.']
  regulatory_requirement_flag boolean [note: 'Indicates whether the document is required by regulatory agencies such as EPA, state primacy agencies, or OSHA. Critical for compliance audit readiness.']
  retention_period_years varchar [note: 'Number of years the document must be retained per regulatory or business policy requirements. Supports records management and compliance.']
  retention_trigger_date date [note: 'Date from which the retention period begins, typically the document effective date or superseded date.']
  review_due_date date [note: 'Scheduled date for the next periodic review of the document to ensure continued accuracy and relevance.']
  review_frequency_months varchar [note: 'Standard interval in months between scheduled reviews of the document.']
  reviewed_by varchar [note: 'Name of the individual who reviewed the document for technical accuracy and completeness. Part of document quality control process.']
  reviewed_date date [note: 'Date when the document review was completed. Tracks document quality assurance timeline.']
  revision_date date [note: 'Date when the current revision of the document was created or last modified. Supports version tracking and audit trails.']
  revision_number varchar [note: 'Version or revision identifier for the document. Tracks document changes and updates over time to maintain version control.']
  sap_document_number varchar [note: 'Document number in SAP ERP system. Links to SAP PM or MM modules for equipment documentation and procurement records.']
  storage_location varchar [note: 'Physical or electronic location where the document is stored, such as file path, cabinet number, or repository identifier.']
  storage_location_url varchar [note: 'URL or file path to the document in the document management system. Provides direct access to the digital document file.']
  title varchar [note: 'Descriptive title of the document. Provides human-readable identification of the document content and purpose.']
  url varchar [note: 'Web address or hyperlink to access the electronic document in the document management system or external repository.']

  Note: 'Master reference table for asset_document. '
}

Table asset.procurement_mapping {
  procurement_mapping_id varchar [pk, note: 'Unique surrogate identifier for the asset class to procurement category mapping record']
  asset_class_id varchar [note: 'Foreign key linking to the asset class being sourced']
  default_vendor_id varchar [note: 'Default vendor for this asset class procurement']
  material_master_id varchar [note: 'Reference to substitute material if primary is unavailable']
  procurement_category_id varchar [note: 'Foreign key linking to the procurement category used for sourcing']
  procurement_contract_id varchar [note: 'Active procurement contract for this asset class mapping.']
  procurement_material_master_id varchar [note: 'FK to material master']
  specification_document_id varchar [note: 'FK to specification document']
  updated_by_employee_id varchar [note: 'Employee identifier for the procurement professional who last updated this mapping']
  abc_classification varchar [note: 'ABC classification for inventory management']
  alternate_vendor_count varchar [note: 'Number of alternate approved vendors']
  annual_spend_budget decimal(18,2) [note: 'Budgeted annual spend for this asset class procurement.']
  approved_vendor_count varchar [note: 'Number of approved vendors for this asset class within this procurement category. Used for supplier diversity analysis and sourcing risk assessment.']
  average_unit_cost decimal(15,2) [note: 'Benchmark average unit cost in USD for items of this asset class when procured through this category. Used for budgeting, cost variance analysis, and procurement performance tracking.']
  bid_threshold_amount decimal(14,2) [note: 'Dollar threshold requiring competitive bidding']
  budget_code varchar [note: 'Budget code used for procurement of this asset class.']
  buy_america_compliant boolean [note: 'Whether item is Buy America compliant']
  commodity_code varchar [note: 'Standard commodity code for procurement']
  contract_required_flag boolean [note: 'Indicates if contract is required for procurement']
  cooperative_contract_available boolean [note: 'Whether cooperative purchasing contract is available']
  cooperative_contract_name varchar [note: 'Name of cooperative purchasing contract']
  created_date timestamp [note: 'Timestamp when this mapping was established in the system']
  critical_spare_flag boolean [note: 'Whether this is a critical spare part']
  criticality_tier varchar [note: 'Criticality tier for procurement prioritization (e.g., Critical, High, Medium, Low).']
  economic_order_quantity varchar [note: 'Economic order quantity for procurement']
  effective_date date [note: 'Date when this procurement mapping became effective.']
  environmental_compliance_required boolean [note: 'Whether environmental compliance is required']
  expiration_date date [note: 'Date when this procurement mapping expires and must be reviewed.']
  gsa_schedule_available boolean [note: 'Whether GSA schedule is available']
  gsa_schedule_number varchar [note: 'GSA schedule number if available']
  hazmat_handling_required_flag boolean [note: 'Indicates if hazardous material handling is required']
  installation_required_flag boolean [note: 'Indicates if professional installation is required']
  last_price_update_date date [note: 'Date of last price update']
  last_procurement_date date [note: 'Most recent date when an item of this asset class was procured through this procurement category. Used to identify inactive mappings and refresh cost benchmarks.']
  last_unit_cost decimal(15,2) [note: 'Unit cost from the most recent procurement transaction.']
  last_updated_date timestamp [note: 'Timestamp when this mapping was last modified, including updates to sourcing strategy, lead times, or cost benchmarks']
  local_preference_applicable boolean [note: 'Whether local vendor preference applies']
  mapping_status varchar [note: 'Current lifecycle status of this asset class to procurement category mapping. Active mappings are used in procurement workflows and materials planning.']
  minimum_order_quantity varchar [note: 'Minimum order quantity for this asset class']
  minority_business_preference boolean [note: 'Whether minority business preference applies']
  naics_code varchar [note: 'NAICS industry code for suppliers']
  nigp_code varchar [note: 'NIGP commodity code']
  notes varchar [note: 'Additional notes about the procurement mapping']
  obsolescence_risk_flag boolean [note: 'Indicates if item has obsolescence risk']
  preferred_sourcing_strategy decimal(18,6) [note: 'Recommended procurement approach for this specific asset class when sourced through this procurement category. Drives purchasing workflow and approval routing.']
  price_volatility_flag boolean [note: 'Whether item has high price volatility']
  reorder_point varchar [note: 'Inventory level that triggers reorder']
  reorder_point_quantity varchar [note: 'Inventory level at which a reorder should be triggered.']
  safety_stock_quantity varchar [note: 'Safety stock quantity to maintain']
  small_business_set_aside boolean [note: 'Whether procurement is set aside for small business']
  sole_source_allowed_flag boolean [note: 'Indicates if sole source procurement is allowed']
  sole_source_flag boolean [note: 'Indicates whether this asset class has only a single approved vendor.']
  specification_document_url varchar [note: 'URL or path to the procurement specification document.']
  standard_lead_time_days varchar [note: 'Typical procurement lead time in days for items of this asset class when sourced through this procurement category. Used for materials planning and inventory reorder point calculations.']
  typical_warranty_months varchar [note: 'Typical warranty period in months']
  unspsc_code varchar [note: 'UNSPSC commodity code']

  Note: 'This association product represents the strategic sourcing configuration between asset classes and procurement categories. It captures class-specific procurement strategies, lead times, cost benchmarks, and approved vendor counts used for materials planning, strategic sourcing decisions, and inventory optimization. Each record links one asset class to one procurement category with sourcing parameters that exist only in the context of this relationship.. Existence Justification: In water utility operations, asset classes (pumps, valves, meters, SCADA equipment) are sourced through multiple procurement categories (mechanical parts, electrical components, instrumentation supplies), and each procurement category serves multiple asset classes. The procurement function actively manages these mappings to maintain class-specific sourcing strategies, lead time benchmarks, approved vendor pools, and cost standards for strategic sourcing, materials planning, and inventory optimization.'
}

Table asset.asset_sampling_point {
  asset_sampling_point_id varchar [pk, note: 'Primary key for asset_sampling_point']
  asset_quality_sampling_point_id varchar [note: 'Foreign key linking to the approved water quality sampling location where samples are collected']
  quality_sampling_point_id varchar [note: 'Foreign key to the canonical quality_sampling_point record in quality domain']
  registry_id varchar [note: 'Foreign key linking to the physical infrastructure asset being monitored (tank, pump station, treatment unit, pipe segment, valve, etc.)']
  configuration_status decimal(18,6) [note: 'Current operational status of this asset-sampling point configuration. Active = in use; suspended = temporarily inactive; under_review = pending validation; decommissioned = permanently retired.']
  last_configuration_review_date date [note: 'Date when this asset-sampling point configuration was last reviewed and validated as part of monitoring plan audits or regulatory compliance reviews.']
  regulatory_requirement_flag boolean [note: 'Indicates whether sampling at this specific asset-sampling point combination is mandated by regulatory permit conditions (NPDES, SDWA, state requirements) versus operational/voluntary monitoring.']
  relationship_end_date date [note: 'Date when this asset-sampling point configuration was deactivated (e.g., asset decommissioned, sampling point relocated, monitoring requirements changed). Null if currently active.']
  relationship_start_date date [note: 'Date when this asset-sampling point configuration became active and sampling began for this specific asset at this location. Used to track historical changes in monitoring configurations.']
  sample_collection_responsibility varchar [note: 'Identifies which team or entity is responsible for collecting samples at this asset-sampling point combination (may vary by asset even at the same sampling location based on access requirements or operational constraints).']
  sampling_access_notes varchar [note: 'Asset-specific access instructions, safety requirements, or logistical notes for sampling personnel collecting samples at this location for this particular asset (e.g., \'Requires confined space entry permit for tank interior sampling\', \'Access via north valve vault only\', \'Coordinate with operations for pump shutdown\').']
  sampling_frequency_override varchar [note: 'Asset-specific override of the default sampling frequency for this sampling point. Allows different sampling cadences for different assets monitored at the same location (e.g., critical assets sampled daily while standard assets sampled weekly at the same point).']
  sampling_priority_rank varchar [note: 'Priority ranking (1=highest) for this asset-sampling point combination used to sequence sampling activities when multiple assets are monitored at the same location. Based on asset criticality, regulatory requirements, and operational risk.']

  Note: 'This association product represents the operational configuration between physical infrastructure assets and water quality sampling points. It captures the many-to-many relationship where a single asset (e.g., storage tank, pump station) can have multiple designated sampling locations (inlet, outlet, overflow, different depths), and a single sampling point can monitor water quality across multiple interconnected assets (e.g., a distribution system sampling point representing multiple mains). Each record defines the sampling configuration, frequency overrides, priority ranking, and access logistics specific to each asset-sampling point pair.. Existence Justification: In water utility operations, the relationship between physical assets and sampling points is genuinely many-to-many. A single asset such as a storage tank has multiple designated sampling locations (inlet, outlet, overflow, different depths for stratification monitoring), and a single sampling point in the distribution system can monitor water quality across multiple interconnected assets (mains, valves, service connections). The utility actively manages these sampling configurations as part of regulatory compliance and operational monitoring programs, with each asset-sampling point pair having specific frequency overrides, priority rankings, and access logistics. [SSOT: governed by quality.quality_sampling_point] [DEPRECATED: Single source of truth is quality.quality_sampling_point]'
}

Table asset.grant_funding {
  grant_funding_id varchar [pk, note: 'Unique identifier for this asset-grant funding relationship record. Primary key.']
  grant_id varchar [note: 'Foreign key linking to the grant providing funding for the asset']
  registry_id varchar [note: 'Foreign key linking to the physical infrastructure asset being funded by the grant']
  amount decimal(18,2) [note: 'Dollar amount of grant funds allocated to this specific asset from this specific grant. Used for reimbursement tracking and audit reporting.']
  amount_reimbursed decimal(18,2) [note: 'Cumulative dollar amount that has been reimbursed by the grantor for this asset under this grant. Used to calculate remaining funding balance.']
  compliance_status varchar [note: 'Current compliance status of this asset-grant funding relationship with respect to grantor requirements. Values: compliant (meets all conditions), non_compliant (violation identified), under_review (audit in progress), pending_documentation (awaiting supporting docs), closed (funding complete and closed out).']
  created_date timestamp [note: 'Timestamp when this asset-grant funding record was created in the system.']
  eligible_cost_amount decimal(18,2) [note: 'Dollar amount of costs incurred for this asset that have been determined eligible for reimbursement under this grant\'s allowable cost categories.']
  funding_end_date date [note: 'Date on which funding for this asset under this grant ends, typically aligned with the grant\'s period of performance end date or asset completion date.']
  funding_start_date date [note: 'Date on which this asset became eligible for funding under this grant, typically aligned with the grant\'s period of performance start date or asset installation date.']
  grant_percentage decimal(5,2) [note: 'Percentage of the asset\'s total cost that is funded by this grant (e.g., 75.00 means 75% grant-funded, 25% utility match). Used for matching requirement calculations.']
  ineligible_cost_amount decimal(18,2) [note: 'Dollar amount of costs incurred for this asset that have been determined ineligible for reimbursement under this grant (e.g., costs incurred outside period of performance, non-allowable cost categories).']
  last_drawdown_request_date date [note: 'Date of the most recent drawdown request submitted to the grantor for reimbursement of costs associated with this asset under this grant.']
  last_updated_date timestamp [note: 'Timestamp when this asset-grant funding record was last modified.']
  notes varchar [note: 'Free-text notes documenting special conditions, compliance issues, or other relevant information about this asset-grant funding relationship.']
  project_phase varchar [note: 'Current phase of the capital project for this asset under this grant. Used to track project milestones and align with grant drawdown schedules.']

  Note: 'This association product represents the funding relationship between physical infrastructure assets and grants. It captures the allocation of grant funds to specific assets, tracking the funding amount, percentage, compliance status, and funding period for each asset-grant combination. Each record links one asset to one grant with attributes that exist only in the context of this funding relationship, supporting audit trails, reimbursement tracking, and grantor compliance reporting.. Existence Justification: In water utility capital finance, individual infrastructure assets (treatment plant upgrades, main replacements, pump stations) are routinely funded through multiple concurrent grants (DWSRF, CWSRF, EPA WIFIA, state programs, ARPA), and each grant program funds multiple assets across capital improvement projects. The utility must track the specific funding amount, percentage, compliance status, and reimbursement details for each asset-grant combination to support grantor reporting, single audit requirements (SEFA schedules), and drawdown requests.'
}

Table asset.compliance_requirement {
  compliance_requirement_id varchar [pk, note: 'Unique surrogate primary key for each asset-requirement compliance relationship record']
  registry_id varchar [note: 'Foreign key linking to the physical infrastructure asset subject to the regulatory requirement']
  regulatory_requirement_id varchar [note: 'Foreign key linking to the regulatory requirement that applies to the asset']
  compliance_method varchar [note: 'The specific method, control, or operational practice by which this asset achieves compliance with this requirement (e.g., \'continuous monitoring\', \'quarterly sampling\', \'treatment technique\', \'operational control\'). Varies by asset-requirement combination.']
  compliance_notes varchar [note: 'Free-text notes documenting compliance issues, corrective actions, assessment findings, or special considerations specific to this asset-requirement relationship.']
  compliance_status varchar [note: 'Current compliance status of this specific asset with respect to this specific regulatory requirement. Tracks whether the asset meets the requirement, is out of compliance, is pending assessment, or has been granted a variance.']
  created_timestamp timestamp [note: 'Timestamp when this asset-requirement compliance relationship record was created in the system.']
  effective_date date [note: 'Date on which this regulatory requirement became applicable to this specific asset. May differ from the requirement\'s general effective date based on asset installation date, facility type, or system size.']
  last_assessment_date date [note: 'Date of the most recent compliance assessment performed for this asset against this specific regulatory requirement. Used to track assessment currency and trigger next assessment scheduling.']
  next_assessment_due_date date [note: 'Scheduled date for the next compliance assessment of this asset against this regulatory requirement. Calculated based on the requirement\'s monitoring frequency and the last assessment date.']
  responsible_person varchar [note: 'Name or identifier of the individual responsible for ensuring this specific asset maintains compliance with this specific requirement. May differ from the general requirement owner based on asset location or operational area.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to this asset-requirement compliance relationship record.']
  variance_expiry_date date [note: 'Expiration date of the granted variance or exemption for this asset-requirement pair. Null if no variance is granted or if variance is permanent.']
  variance_granted_flag boolean [note: 'Indicates whether a regulatory variance, exemption, or waiver has been granted for this specific asset-requirement combination. True if variance is active, false otherwise.']

  Note: 'This association product represents the compliance relationship between physical infrastructure assets and regulatory requirements. It captures the specific compliance obligations, assessment schedules, and compliance status for each asset-requirement pair. Each record links one asset to one regulatory requirement with attributes that track compliance method, assessment dates, variance status, and compliance state specific to that asset-requirement combination.. Existence Justification: In water utility operations, a single physical asset (e.g., a chlorine contact basin) must comply with multiple overlapping regulatory requirements from different regulatory programs (SDWA Surface Water Treatment Rule for CT requirements, state disinfection rules, EPA DBP rules for chlorine residual limits, NPDES for discharge). Conversely, a single regulatory requirement (e.g., SDWA Lead and Copper Rule) applies to multiple different asset types across the utility (service lines, treatment plant corrosion control systems, distribution system storage tanks, sampling stations). The compliance relationship itself carries operational data including compliance status, assessment schedules, compliance methods, and variance status that are specific to each asset-requirement pair.'
}

Table asset.inspection_checklist {
  inspection_checklist_id varchar [pk, note: 'Primary key for inspection_checklist']
  parent_inspection_checklist_id varchar [note: 'Self-referencing FK on inspection_checklist (parent_inspection_checklist_id)']
  applicable_asset_category varchar [note: 'Asset category for which this checklist is intended.']
  approval_status varchar [note: 'Current approval state of the checklist.']
  author varchar [note: 'Name of the person who authored the checklist.']
  checklist_name varchar
  checklist_number varchar
  checklist_status varchar
  checklist_type varchar [note: 'Category of the checklist indicating its primary focus.']
  created_timestamp timestamp [note: 'Date and time when the checklist record was created.']
  effective_from date [note: 'Date from which the checklist becomes valid.']
  effective_until date [note: 'Date after which the checklist is no longer valid (nullable).']
  estimated_duration_minutes decimal(18,6) [note: 'Estimated time required to complete the checklist, in minutes.']
  frequency_interval varchar [note: 'Numeric interval defining how often the inspection should occur.']
  frequency_unit varchar [note: 'Time unit for the inspection frequency interval.']
  inspection_checklist_description varchar [note: 'Detailed description of the purpose and scope of the checklist.']
  inspection_checklist_name varchar [note: 'Descriptive name of the checklist used to identify it in the system.']
  inspection_checklist_status varchar [note: 'Current lifecycle status of the checklist.']
  is_mandatory boolean [note: 'Indicates whether the checklist must be performed for the asset.']
  last_modified_by varchar [note: 'User identifier who performed the most recent modification.']
  last_updated_timestamp timestamp
  last_used_timestamp timestamp [note: 'Date and time when the checklist was last applied to an inspection.']
  notes varchar [note: 'Free‑form notes or comments about the checklist.']
  number_of_items varchar [note: 'Total count of individual inspection items in the checklist.']
  regulation_reference varchar [note: 'Identifier of the regulation that mandates this checklist.']
  regulatory_reference varchar
  required_by_regulation boolean [note: 'Indicates whether the checklist is mandated by regulation.']
  reviewer varchar [note: 'Name of the person who reviewed and approved the checklist.']
  revision_number varchar
  risk_level varchar [note: 'Risk classification associated with the checklist.']
  updated_timestamp timestamp [note: 'Date and time of the most recent update to the checklist record.']
  version varchar
  version_number varchar [note: 'Version identifier for the checklist, e.g., v1.0.']

  Note: 'Master reference table for inspection_checklist. Referenced by inspection_checklist_id.'
}

