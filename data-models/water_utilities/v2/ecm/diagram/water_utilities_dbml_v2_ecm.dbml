  mrp_type varchar [note: 'Material requirements planning type.']
  plant_code varchar [note: 'Plant code.']
  procurement_type varchar [note: 'Procurement type.']
  quality_inspection_stock_quantity decimal(15,3) [note: 'Quantity in quality inspection.']
  reorder_point decimal(15,3) [note: 'Reorder point level.']
  reserved_quantity decimal(15,3) [note: 'Quantity reserved for orders.']
  safety_stock_quantity decimal(15,3) [note: 'Safety stock quantity.']
  serial_number_managed_flag boolean [note: 'Serial number managed indicator.']
  stock_status varchar [note: 'Overall stock status.']
  stock_turnover_ratio decimal(10,2) [note: 'Inventory turnover ratio.']
  stock_type varchar [note: 'Stock type.']
  stock_value_amount decimal(15,2) [note: 'Total value of stock on hand.']
  storage_location_code varchar [note: 'Storage location code.']
  unit_of_measure varchar [note: 'Unit of measure.']
  unrestricted_stock_quantity decimal(15,3) [note: 'Unrestricted use quantity.']
  valuation_currency_code varchar [note: 'Currency for stock valuation.']

  Note: 'Current stock position for a material at a specific warehouse location including quantities, valuation, and replenishment parameters.'
}

Table supply.stock_movement {
  stock_movement_id varchar [pk, note: 'Unique surrogate key.']
