Table quality.analytical_result {
  analytical_result_id varchar [pk, note: 'Primary key']
  certified_analyst_id varchar [note: 'FK to analyst']
  cip_project_id varchar [note: 'FK to CIP project']
  contaminant_id varchar [note: 'FK to contaminant']
  contaminant_limit_id varchar [note: 'FK to contaminant limit']
  cost_center_id varchar [note: 'FK to cost center']
  dmr_result_id varchar [note: 'FK to DMR result']
  employee_id varchar [note: 'FK to employee']
  lab_instrument_id varchar [note: 'FK to lab instrument']
  meter_installation_id varchar [note: 'FK to meter installation']
  pfas_compound_master_id varchar [note: 'FK to PFAS compound master']
  qaqc_batch_id varchar [note: 'FK to QAQC batch']
  test_result_id varchar [note: 'FK to test result']
  vendor_id varchar [note: 'FK to vendor']
  water_sample_id varchar [note: 'FK to water sample']
  analysis_date date [note: 'Analysis date']
  analysis_timestamp timestamp [note: 'Analysis timestamp']
  analytical_method varchar [note: 'Analytical method']
  calibration_date date [note: 'Calibration date']
  compliance_exceeded boolean [note: 'Compliance exceeded flag']
  created_timestamp timestamp [note: 'Created timestamp']
  data_validation_level varchar [note: 'Data validation level']
  detection_limit decimal(18,6) [note: 'Detection limit']
  dilution_factor decimal(10,4) [note: 'Dilution factor']
  eu_sum20_contribution_ng_l decimal(18,6) [note: 'EU sum-of-20 contribution in ng/L']
  hazard_index_contribution decimal(18,6) [note: 'Hazard index contribution']
  hazard_quotient decimal(10,6) [note: 'Hazard quotient']
  hold_time_compliant boolean [note: 'Hold time compliant flag']
  hold_time_hours varchar [note: 'Hold time in hours']
  is_pfas_result boolean [note: 'Is PFAS result flag']
  jurisdiction_code varchar [note: 'Jurisdiction code (US/EU/other)']
  laboratory_accreditation_number varchar [note: 'Laboratory accreditation number']
  lims_result_code varchar [note: 'LIMS result code']
  mcl_value decimal(18,2) [note: 'MCL value']
  mclg_value decimal(18,2) [note: 'MCLG value']
  modified_timestamp timestamp [note: 'Modified timestamp']
  percent_recovery decimal(5,2) [note: 'Percent recovery']
  pfas_compound_class varchar [note: 'PFAS compound class (long-chain/short-chain)']
  pfas_compound_id varchar [note: 'FK to PFAS compound']
  pfas_monitoring_id varchar [note: 'FK to PFAS monitoring']
  qualifier_code varchar [note: 'Qualifier code']
  quantitation_limit decimal(18,6) [note: 'Quantitation limit']
  regulatory_framework varchar [note: 'Regulatory framework (US/EU/WHO)']
  relative_percent_difference decimal(5,2) [note: 'Relative percent difference']
  reporting_required boolean [note: 'Reporting required flag']
  result_comment varchar [note: 'Result comment']
  result_status varchar [note: 'Result status']
  result_value decimal(18,2) [note: 'Result value']
  sample_matrix varchar [note: 'Sample matrix']
  unit_of_measure varchar [note: 'Unit of measure']
  validated_by varchar [note: 'Validated by']
  validation_timestamp timestamp [note: 'Validation timestamp']

  Note: 'Analytical result from water quality testing SSOT: This is the canonical source for all water quality analytical results across drinking water, wastewater, and source water monitoring.'
}

Table quality.contaminant {
  contaminant_id varchar [pk, note: 'Primary key']
  analyte_id varchar [note: 'FK to analyte']
  contaminant_group_id varchar [note: 'FK to contaminant group']
  pfas_compound_master_id varchar [note: 'FK to PFAS compound master']
  regulatory_requirement_id varchar [note: 'FK to regulatory requirement']
  action_level_unit varchar [note: 'Action level unit']
  action_level_value decimal(18,2) [note: 'Action level value']
  analytical_method_code varchar [note: 'Analytical method code']
  cas_number varchar [note: 'CAS number']
  ccr_language_template varchar [note: 'CCR language template']
  ccr_reporting_required boolean [note: 'CCR reporting required flag']
  chain_class varchar [note: 'Chain class']
  contaminant_code varchar [note: 'Contaminant code']
  contaminant_name varchar [note: 'Contaminant name']
  contaminant_status varchar [note: 'Contaminant status']
  contaminant_type varchar [note: 'Contaminant type']
  created_timestamp timestamp [note: 'Created timestamp']
  detection_limit_unit varchar [note: 'Detection limit unit']
  detection_limit_value decimal(18,2) [note: 'Detection limit value']
  effective_date date [note: 'Effective date']
  eu_class_restriction_flag boolean [note: 'EU class restriction flag']
  eu_dwd_parametric_value_ng_l decimal(18,2) [note: 'EU DWD parametric value in ng/L']
  eu_parametric_value_ng_l decimal(18,2) [note: 'EU parametric value in ng/L']
  eu_regulatory_framework varchar [note: 'EU regulatory framework']
  eu_sum20_member boolean [note: 'EU sum-of-20 member flag']
  eu_sum_of_20_limit_ng_l decimal(18,6) [note: 'EU sum-of-20 limit in ng/L']
  eu_sum_of_20_member boolean [note: 'EU sum-of-20 member flag']
  eu_total_pfas_class_member boolean [note: 'EU total PFAS class member flag']
  eu_total_pfas_included boolean [note: 'EU total PFAS included flag']
  eu_total_pfas_limit_ng_l decimal(18,6) [note: 'EU total PFAS limit in ng/L']
  eu_total_pfas_member boolean [note: 'True if part of EU total PFAS class']
  hazard_based_water_concentration_ng_l decimal(18,6) [note: 'Hazard-based water concentration in ng/L']
  hazard_index_member boolean [note: 'Hazard index member flag']
  health_effect_category varchar [note: 'Health effect category']
  health_effect_description varchar [note: 'Health effect description']
  is_pfas boolean [note: 'Is PFAS flag']
  is_pfas_compound boolean [note: 'Is PFAS compound flag']
  jurisdiction_code varchar [note: 'Jurisdiction code (US/EU/other)']
  mcl_unit varchar [note: 'MCL unit']
  mcl_value decimal(18,2) [note: 'MCL value']
  mclg_unit varchar [note: 'MCLG unit']
  mclg_value decimal(18,2) [note: 'MCLG value']
  modified_timestamp timestamp [note: 'Modified timestamp']
  monitoring_frequency_code varchar [note: 'Monitoring frequency code']
  monitoring_location_type varchar [note: 'Monitoring location type']
  notes varchar [note: 'Notes']
  npdes_effluent_limit_unit varchar [note: 'NPDES effluent limit unit']
  npdes_effluent_limit_value decimal(18,2) [note: 'NPDES effluent limit value']
  pfas_chain_class varchar [note: 'PFAS chain class (long-chain, short-chain)']
  pfas_chain_length varchar [note: 'PFAS chain length']
  pfas_chain_length_class varchar [note: 'PFAS chain length class (long/short)']
  pfas_chain_type varchar [note: 'PFAS chain type']
  pfas_class varchar [note: 'PFAS class']
  pfas_regulatory_framework varchar [note: 'PFAS regulatory framework']
  pfas_regulatory_framework_note varchar [note: 'PFAS regulatory framework note']
  public_notification_tier varchar [note: 'Public notification tier']
  regulatory_framework varchar [note: 'Regulatory framework (EPA, EU DWD, etc.)']
  regulatory_program varchar [note: 'Regulatory program']
  reporting_threshold_unit varchar [note: 'Reporting threshold unit']
  reporting_threshold_value decimal(18,2) [note: 'Reporting threshold value']
  revision_date date [note: 'Revision date']
  source_category varchar [note: 'Source category']
  source_description varchar [note: 'Source description']
  subgroup varchar [note: 'Subgroup']
  treatment_technique_description varchar [note: 'Treatment technique description']
  treatment_technique_required boolean [note: 'Treatment technique required flag']
  treatment_technology_options varchar [note: 'Treatment technology options (GAC, ion exchange, etc.)']
  us_hazard_index_member boolean [note: 'US hazard index member flag']
  us_hbwc_ng_l decimal(18,6) [note: 'US hazard-based water concentration in ng/L']
  us_mcl_ng_l decimal(18,6) [note: 'US MCL in ng/L']
  us_mclg_ng_l decimal(18,6) [note: 'US MCLG in ng/L']
  violation_trigger_logic varchar [note: 'Violation trigger logic']
  wastewater_parameter boolean [note: 'Wastewater parameter flag']
  who_guideline_unit varchar [note: 'WHO guideline unit']
  who_guideline_value decimal(18,2) [note: 'WHO guideline value']

  Note: 'Contaminant master list for water quality monitoring SSOT: This is the canonical master for all contaminant definitions, regulatory limits, and monitoring requirements across all water quality programs.'
}

Table quality.contaminant_limit {
  contaminant_limit_id varchar [pk, note: 'Primary key']
  contaminant_id varchar [note: 'FK to contaminant']
  monitoring_context_id varchar [note: 'FK to monitoring context']
  treatment_permit_id varchar [note: 'FK to treatment permit']
  analytical_method_required varchar [note: 'Analytical method required']
  applicable_regulation varchar [note: 'Applicable regulation']
  averaging_period varchar [note: 'Averaging period']
  ccr_reporting_required boolean [note: 'CCR reporting required flag']
  compliance_status varchar [note: 'Compliance status']
  created_timestamp timestamp [note: 'Created timestamp']
  detection_limit_required decimal(18,6) [note: 'Detection limit required']
  effective_date date [note: 'Effective date']
  exceedance_action_required varchar [note: 'Exceedance action required']
  health_effect_category varchar [note: 'Health effect category']
  jurisdiction varchar [note: 'Jurisdiction (US/EU/other)']
  jurisdiction_authority varchar [note: 'Jurisdiction authority']
  limit_type varchar [note: 'Limit type']
  limit_value decimal(18,2) [note: 'Limit value']
  monitoring_frequency_required varchar [note: 'Monitoring frequency required']
  notes varchar [note: 'Notes']
  public_notification_tier varchar [note: 'Public notification tier']
  sample_location_type varchar [note: 'Sample location type']
  superseded_date date [note: 'Superseded date']
  unit_of_measure varchar [note: 'Unit of measure']
  updated_timestamp timestamp [note: 'Updated timestamp']
  variance_expiration_date date [note: 'Variance expiration date']
  variance_waiver_flag boolean [note: 'Variance waiver flag']

  Note: 'Regulatory and operational limits for each contaminant at each applicable monitoring context (drinking water, effluent discharge, source water). Captures MCL, MCLG, action level, treatment technique standard, permit-specific effluent limit (daily max, monthly average), applicable regulation citation, effective date, superseded date, and jurisdiction (federal, state primacy agency). Enables automated compliance comparison against analytical_result values.'
}

Table quality.exceedance {
  exceedance_id varchar [pk, note: 'Primary key']
  analytical_result_id varchar [note: 'FK to analytical result']
  compliance_violation_id varchar [note: 'FK to compliance violation']
  contaminant_id varchar [note: 'FK to contaminant']
  contaminant_limit_id varchar [note: 'Foreign key linking to quality.contaminant_limit. Business justification: Exceedances are violations of specific regulatory or operational limits. Currently exceedance links to contaminant (the substance) but not to the specific limit record that was exceeded. Adding contam']
  facility_id varchar [note: 'FK to facility']
  quality_sampling_point_id varchar [note: 'FK to sampling point']
  water_sample_id varchar [note: 'FK to water sample']
  corrective_action_required boolean [note: 'Corrective action required flag']
  created_timestamp timestamp [note: 'Created timestamp']
  exceedance_date date [note: 'Exceedance date']
  exceedance_severity varchar [note: 'Exceedance severity']
  exceedance_type varchar [note: 'Exceedance type']
  last_modified_timestamp timestamp [note: 'Last modified timestamp']
  measured_value decimal(18,2) [note: 'Measured value']
  notes varchar [note: 'Notes']
  parameter_name varchar [note: 'Parameter name']
  public_notification_required boolean [note: 'Public notification required flag']
  resolution_date date [note: 'Resolution date']
  resolution_status varchar [note: 'Resolution status']
  severity varchar [note: 'Severity']
  unit_of_measure varchar [note: 'Unit of measure']

  Note: 'Transactional record of each confirmed MCL, action level, or permit limit exceedance detected from analytical results. Captures exceedance date, contaminant, sampling point, measured value, applicable limit, exceedance magnitude, regulatory notification deadline, public notification requirement flag, corrective action required, and resolution status. This is the primary operational record driving regulatory response workflows and violation tracking. SSOT: References quality.analytical_result as the canonical source for measured values; this entity captures regulatory exceedance events and response actions.'
}

Table quality.dbp_monitoring_event {
  dbp_monitoring_event_id varchar [pk, note: 'Unique identifier for the disinfection byproduct monitoring event record.']
  compliance_monitoring_point_id varchar [note: 'Reference to the compliance monitoring point where the DBP sample was collected.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: DBP monitoring is a recurring compliance cost with dedicated budget allocation; linking to cost_center enables tracking of Stage 2 DBPR compliance costs for regulatory reporting and rate case cost rec']
  lab_sample_id varchar [note: 'The unique sample identifier assigned by the laboratory for tracking and chain of custody.']
  territory_id varchar [note: 'Reference to the public water system subject to DBP monitoring requirements.']
  vendor_id varchar [note: 'Reference to the certified laboratory that performed the DBP analysis.']
  water_sample_id varchar [note: 'Foreign key linking to quality.water_sample. Business justification: DBP monitoring events are based on water samples collected and analyzed. Currently has lab_sample_id (cross-domain to laboratory). Adding water_sample_id establishes the in-domain link to the quality ']
  water_system_id varchar [note: 'Reference to the public water system subject to DBP monitoring requirements.']
  analysis_completion_date date [note: 'The date when the laboratory completed the DBP analysis and reported results.']
  bromide_concentration_mg_l decimal(8,4) [note: 'The bromide ion concentration in milligrams per liter, which influences the formation of brominated DBP species.']
  bromodichloromethane_concentration_ug_l decimal(10,4) [note: 'Measured concentration of bromodichloromethane (CHBrCl2), a trihalomethane species, in micrograms per liter.']
  bromoform_concentration_ug_l decimal(10,4) [note: 'Measured concentration of bromoform (CHBr3), a trihalomethane species, in micrograms per liter.']
  ccr_inclusion_flag boolean [note: 'Indicates whether this monitoring event result is included in the annual Consumer Confidence Report.']
  chloroform_concentration_ug_l decimal(10,4) [note: 'Measured concentration of chloroform (CHCl3), a trihalomethane species, in micrograms per liter.']
  created_timestamp timestamp [note: 'The timestamp when this DBP monitoring event record was first created in the system.']
  dibromoacetic_acid_concentration_ug_l decimal(10,4) [note: 'Measured concentration of dibromoacetic acid (DBAA), a haloacetic acid species, in micrograms per liter.']
  dibromochloromethane_concentration_ug_l decimal(10,4) [note: 'Measured concentration of dibromochloromethane (CHBr2Cl), a trihalomethane species, in micrograms per liter.']
  dichloroacetic_acid_concentration_ug_l decimal(10,4) [note: 'Measured concentration of dichloroacetic acid (DCAA), a haloacetic acid species, in micrograms per liter.']
  free_chlorine_residual_mg_l decimal(8,3) [note: 'The free chlorine residual measured at the time of sample collection, in milligrams per liter, which influences DBP formation.']
  haa5_compliance_status varchar [note: 'Indicates whether the HAA5 LRAA at this monitoring point is in compliance with the MCL.']
  haa5_concentration_ug_l decimal(10,4) [note: 'Sum of the five regulated haloacetic acid species (MCAA, DCAA, TCAA, MBAA, DBAA) in micrograms per liter.']
  haa5_lraa_ug_l decimal(10,4) [note: 'The locational running annual average of HAA5 concentrations at this monitoring point, calculated as the arithmetic average of the current quarter and the previous three quarters.']
  haa5_mcl_ug_l decimal(10,4) [note: 'The applicable HAA5 maximum contaminant level for this monitoring event, typically 60 µg/L under Stage 2 DBPR.']
  last_modified_timestamp timestamp [note: 'The timestamp when this DBP monitoring event record was last updated in the system.']
  monitoring_frequency varchar [note: 'The required monitoring frequency for this location under Stage 2 DBPR, which may vary based on system size and historical compliance.']
  monitoring_period_end_date date [note: 'The last day of the monitoring period (typically quarterly) for which this DBP sample applies.']
  monitoring_period_start_date date [note: 'The first day of the monitoring period (typically quarterly) for which this DBP sample applies.']
  monobromoacetic_acid_concentration_ug_l decimal(10,4) [note: 'Measured concentration of monobromoacetic acid (MBAA), a haloacetic acid species, in micrograms per liter.']
  monochloroacetic_acid_concentration_ug_l decimal(10,4) [note: 'Measured concentration of monochloroacetic acid (MCAA), a haloacetic acid species, in micrograms per liter.']
  notes varchar [note: 'Additional notes or comments regarding the monitoring event, sample collection, or analysis results.']
  ph_value decimal(18,2) [note: 'The pH value of the water sample at the time of collection, which influences DBP speciation and formation.']
  reported_to_state_date date [note: 'The date when this monitoring event result was reported to the state primacy agency.']
  reported_to_state_flag boolean [note: 'Indicates whether this monitoring event result has been reported to the state primacy agency.']
  sample_collection_timestamp timestamp [note: 'The precise date and time when the DBP water sample was collected from the monitoring point.']
  sample_type varchar [note: 'Classification of the sample purpose: routine compliance monitoring, confirmation of exceedance, investigative, or special study.']
  system_wide_haa5_raa_ug_l decimal(10,4) [note: 'The system-wide running annual average of HAA5 concentrations across all monitoring points, used for overall system compliance assessment.']
  system_wide_tthm_raa_ug_l decimal(10,4) [note: 'The system-wide running annual average of TTHM concentrations across all monitoring points, used for overall system compliance assessment.']
  toc_concentration_mg_l decimal(8,3) [note: 'The total organic carbon concentration in milligrams per liter, a key precursor to DBP formation.']
  total_chlorine_residual_mg_l decimal(8,3) [note: 'The total chlorine residual measured at the time of sample collection, in milligrams per liter.']
  trichloroacetic_acid_concentration_ug_l decimal(10,4) [note: 'Measured concentration of trichloroacetic acid (TCAA), a haloacetic acid species, in micrograms per liter.']
  tthm_compliance_status varchar [note: 'Indicates whether the TTHM LRAA at this monitoring point is in compliance with the MCL.']
  tthm_concentration_ug_l decimal(10,4) [note: 'Sum of the four trihalomethane species (chloroform, bromodichloromethane, dibromochloromethane, bromoform) in micrograms per liter.']
  tthm_lraa_ug_l decimal(10,4) [note: 'The locational running annual average of TTHM concentrations at this monitoring point, calculated as the arithmetic average of the current quarter and the previous three quarters.']
  tthm_mcl_ug_l decimal(10,4) [note: 'The applicable TTHM maximum contaminant level for this monitoring event, typically 80 µg/L under Stage 2 DBPR.']
  water_temperature_c decimal(5,2) [note: 'The water temperature at the time of sample collection in degrees Celsius, which affects DBP formation rates.']

  Note: 'Specialized transactional record for Disinfection Byproduct (DBP) monitoring events under Stage 2 DBPR rules. Captures monitoring period, LRAA (Locational Running Annual Average) calculation inputs, THM and HAA5 individual species results (chloroform, bromodichloromethane, dibromochloromethane, bromoform; monochloroacetic acid, dichloroacetic acid, trichloroacetic acid, monobromoacetic acid, dibromoacetic acid), TTHM and HAA5 totals, compliance status, and system-wide running annual average. Distinct from general analytical_result due to LRAA compliance calculation requirements.'
}

Table quality.pfas_monitoring {
  pfas_monitoring_id varchar [pk, note: 'Primary key for PFAS monitoring event record.']
  analytical_result_id varchar [note: 'FK to the analytical result record for this PFAS measurement.']
  contaminant_id varchar [note: 'FK to the specific PFAS contaminant being monitored (e.g. PFOA, PFOS).']
  facility_id varchar [note: 'FK to the treatment facility where monitoring occurs.']
  laboratory_id varchar [note: 'Identifier of the certified laboratory performing the PFAS analysis.']
  pfas_compound_master_id varchar [note: 'FK to quality.pfas_compound_master']
  quality_sampling_point_id varchar [note: 'FK to the sampling point where PFAS sample was collected.']
  regulatory_requirement_id varchar [note: 'FK to the governing regulatory requirement, providing the parallel US/EU/other reference path.']
  sampling_schedule_id varchar [note: 'FK to the sampling schedule governing this PFAS monitoring event.']
  water_sample_id varchar [note: 'FK to the water sample collected for this PFAS monitoring event.']
  water_system_id varchar [note: 'FK to quality.water_system']
  analytical_method varchar [note: 'EPA analytical method used (e.g. EPA 533, EPA 537.1).']
  bed_volumes_treated varchar [note: 'Number of bed volumes treated since last GAC/IX media change.']
  breakthrough_pct decimal(5,2) [note: 'Percentage of MCL at which treatment media breakthrough is occurring.']
  compliance_status varchar
  created_timestamp timestamp [note: 'Record creation timestamp.']
  data_quality_flag boolean [note: 'Boolean flag indicating whether data quality issues exist for this record.']
  detection_limit_ng_l decimal(18,6) [note: 'Method detection limit for the PFAS compound in ng/L.']
  detection_limit_ppt decimal(18,6) [note: 'Method detection limit in ppt']
  eu_compliance_status varchar [note: 'Compliance status against EU DWD 2020/2184 PFAS limits.']
  eu_parametric_value_ng_l decimal(18,2) [note: 'EU Drinking Water Directive 2020/2184 parametric value for PFAS in ng/L.']
  eu_parametric_value_ppt decimal(18,2) [note: 'EU DWD parametric value in ppt']
  eu_pfas_sum_of_20_basis_flag boolean [note: 'True when monitoring uses EU Drinking Water Directive 2020/2184 sum-of-20 / REACH class restriction framework.']
  eu_pfas_sum_of_20_limit_ug_l decimal(18,6) [note: 'EU DWD 2020/2184 sum-of-20 priority compounds limit = 0.1 ug/L.']
  eu_pfas_sum_of_20_result_ug_l decimal(18,6) [note: 'Measured sum-of-20 PFAS priority compounds in ug/L.']
  eu_pfas_total_limit_ug_l decimal(18,6) [note: 'EU DWD 2020/2184 PFAS total limit = 0.5 ug/L.']
  eu_pfas_total_result_ug_l decimal(18,6) [note: 'Measured PFAS total in ug/L (EU framework).']
  eu_reference_path varchar [note: 'EU reference path: Drinking Water Directive 2020/2184; REACH; WFD; UWWTD citation chain.']
  eu_sum_of_20_compliance_flag boolean [note: 'TRUE if EU sum-of-20 PFAS concentration is at or below 0.10 ug/L (compliant); FALSE if exceeding. NULL for US jurisdiction.']
  eu_sum_of_20_compliant_flag boolean [note: 'EU sum-of-20 compliance']
  eu_sum_of_20_member boolean [note: 'True if this compound is included in the EU sum-of-20 PFAS parameter.']
  eu_sum_of_20_ng_l decimal(12,4)
  eu_sum_of_20_pfas_ng_l decimal(18,6) [note: 'Sum of 20 individual PFAS substances as defined in DWD 2020/2184 Annex I Part B, parametric value 100 ng/L. NULL for US-only monitoring.']
  eu_sum_of_20_pfas_ug_l decimal(12,6) [note: 'Sum of 20 individual PFAS substances concentration in micrograms per liter as defined by EU DWD 2020/2184 Annex I Part B (limit 0.10 ug/L). NULL for US jurisdiction.']
  eu_sum_of_20_result_ng_l decimal(12,4) [note: 'Sum of 20 specified PFAS compounds in ng/L as required by EU Drinking Water Directive 2020/2184. EU limit is 100 ng/L. NULL for non-EU jurisdictions.']
  eu_sum_of_20_value_ng_l decimal(18,2) [note: 'Cumulative sum of 20 PFAS compounds per EU DWD 2020/2184 (limit 100 ng/L).']
  eu_sum_of_20_value_ppt decimal(18,2) [note: 'EU sum-of-20 PFAS value']
  eu_sum_of_twenty_basis_flag boolean [note: 'TRUE when evaluated under EU Drinking Water Directive 2020/2184 sum-of-20 PFAS framework.']
  eu_total_pfas_compliant_flag boolean [note: 'Whether the EU total PFAS value is at or below the parametric value of 500 ng/L per DWD 2020/2184.']
  eu_total_pfas_ng_l decimal(18,6) [note: 'Total PFAS measurement per DWD 2020/2184 (all per- and polyfluoroalkyl substances), parametric value 500 ng/L. NULL for US-only monitoring.']
  eu_total_pfas_result_ng_l decimal(12,4) [note: 'Total PFAS class measurement in ng/L per EU Drinking Water Directive 2020/2184. EU limit is 500 ng/L. NULL for non-EU jurisdictions.']
  eu_total_pfas_ug_l decimal(12,6) [note: 'Total PFAS concentration in micrograms per liter as defined by EU DWD 2020/2184 (limit 0.50 ug/L for total PFAS). NULL for US jurisdiction.']
  eu_total_pfas_value_ng_l decimal(18,2) [note: 'Total PFAS measurement per EU class restriction (limit 500 ng/L).']
  eu_total_pfas_value_ppt decimal(18,2) [note: 'EU total PFAS (class restriction)']
  hazard_index double [note: 'Calculated hazard index for PFNA+PFHxS+PFBS+HFPO-DA.']
  hazard_index_compliance_status varchar [note: 'Compliance status for the hazard index (COMPLIANT if HI<=1.0, EXCEEDS if HI>1.0).']
  hazard_index_compliant_flag boolean [note: 'Whether hazard index is compliant']
  hazard_index_contribution decimal(10,6) [note: 'Contribution to hazard index (PFNA+PFHxS+PFBS+HFPO-DA)']
  hazard_index_exceedance_flag boolean
  hazard_index_member boolean [note: 'True if this compound participates in the EPA hazard index calculation (PFNA, PFHxS, PFBS, HFPO-DA).']
  hazard_index_total decimal(10,6) [note: 'Total hazard index value']
  hazard_index_value decimal(18,2) [note: 'Cumulative hazard index (sum of hazard quotients for PFNA+PFHxS+PFBS+HFPO-DA); must be <= 1.0.']
  hazard_quotient decimal(10,6) [note: 'Individual hazard quotient for this compound (result / HBWC), used in hazard index sum.']
  hfpo_da_concentration_ng_l decimal(12,4)
  hfpo_da_value_ng_l decimal(18,2) [note: 'Measured HFPO-DA (GenX) concentration in ng/L.']
  is_non_detect boolean [note: 'True if the result is below the method detection limit.']
  jurisdiction varchar [note: 'Allowed regions: US,EU,OTHER.']
  jurisdiction_code varchar [note: 'Regulatory jurisdiction code (US_EPA, EU_DWD, STATE, etc.) for this monitoring record.']
  jurisdiction_mcl_unit varchar [note: 'Unit of measure for the jurisdiction-specific MCL (e.g. ppt for US individual compounds, ug/L for EU sum parameters).']
  jurisdiction_mcl_value decimal(18,2) [note: 'Maximum contaminant level applicable in the relevant jurisdiction for the monitored PFAS compound or group.']
  jurisdiction_region varchar [note: 'Regulatory region code (US, EU, OTHER) determining which PFAS regulatory framework applies. US uses per-compound MCLs (PFOA 4ppt, PFOS 4ppt, etc.) plus hazard index for PFNA+PFHxS+PFBS+HFPO-DA; EU uses sum-of-20 PFAS (100ng/L) and total PFAS class restriction (500ng/L) per Drinking Water Directive 2020/2184.']
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  mcl_compliance_status varchar [note: 'Compliance status against the applicable MCL (COMPLIANT, EXCEEDS, PENDING).']
  mcl_compliant_flag boolean [note: 'Whether individual MCL is met']
  mcl_exceedance_flag boolean
  mcl_value_ppt decimal(18,2) [note: 'US EPA MCL in ppt']
  modified_timestamp timestamp [note: 'Record last modification timestamp.']
  monitoring_date date
  monitoring_period_end date [note: 'End of the PFAS monitoring period.']
  monitoring_period_end_date date [note: 'End date of the PFAS monitoring period.']
  monitoring_period_start date [note: 'Start of the PFAS monitoring period.']
  monitoring_period_start_date date [note: 'Start date of the PFAS monitoring period (quarterly/annual per UCMR/state rule).']
  monitoring_status varchar [note: 'Status of monitoring event']
  monitoring_type varchar [note: 'Type of monitoring (INITIAL, QUARTERLY, ANNUAL, CONFIRMATION, TRIGGERED).']
  notes varchar [note: 'Free-text notes about this PFAS monitoring event.']
  other_reference_path varchar [note: 'Other national/regional regulatory reference path.']
  pfas_chain_length varchar
  pfbs_concentration_ng_l decimal(12,4)
  pfbs_value_ng_l decimal(18,2) [note: 'Measured PFBS concentration in ng/L.']
  pfhxs_concentration_ng_l decimal(12,4)
  pfhxs_value_ng_l decimal(18,2) [note: 'Measured PFHxS concentration in ng/L.']
  pfna_concentration_ng_l decimal(12,4)
  pfna_value_ng_l decimal(18,2) [note: 'Measured PFNA concentration in ng/L.']
  pfoa_concentration_ng_l decimal(12,4)
  pfoa_value_ng_l decimal(18,2) [note: 'Measured PFOA concentration in ng/L.']
  pfos_concentration_ng_l decimal(12,4)
  pfos_value_ng_l decimal(18,2) [note: 'Measured PFOS concentration in ng/L.']
  qualifier_code varchar [note: 'Laboratory qualifier code (J=estimated, U=non-detect, B=blank contamination).']
  quantitation_limit_ppt decimal(12,4)
  regulatory_framework varchar [note: 'Applicable regulatory framework for the region (US=EPA/AWWA/NPDWR/UCMR/NPDES; EU=Drinking Water Directive 2020/2184; REACH; Water Framework Directive; Urban Wastewater Treatment Directive; OTHER=Other national/regional frameworks).']
  regulatory_framework_reference varchar [note: 'Specific regulatory citation (e.g. US: 40 CFR 141.61, EU: DWD 2020/2184 Annex I Part B, REACH Annex XVII restriction).']
  regulatory_program varchar [note: 'Applicable regulatory program (UCMR5, NPDWR_PFAS_2024, EU_DWD_2020_2184, STATE_MCL).']
  regulatory_region varchar [note: 'Top-level regulatory region (US, EU, OTHER). Determines applicable PFAS framework: US (NPDWR per-compound MCLs + hazard index for PFNA/PFHxS/PFBS/HFPO-DA) or EU (DWD 2020/2184 sum parameters). Allowed regions: US,EU,OTHER.']
  regulatory_region_code varchar [note: 'ISO region code identifying the jurisdiction for this PFAS monitoring event (US, EU, OTHER). US uses per-compound MCLs + hazard index; EU uses sum-of-20 PFAS + total PFAS class restriction per DWD 2020/2184.']
  reporting_limit_ng_l decimal(18,6) [note: 'Practical quantitation/reporting limit for the PFAS compound in ng/L.']
  reporting_limit_ppt decimal(18,6) [note: 'Reporting limit in ppt']
  result_value_ng_l decimal(18,2) [note: 'Measured concentration of the PFAS compound in nanograms per liter.']
  result_value_ppt decimal(18,2) [note: 'Result value in parts per trillion']
  sample_collection_date date [note: 'Date the PFAS sample was physically collected.']
  sample_collection_timestamp timestamp [note: 'Exact timestamp of PFAS sample collection.']
  sample_type varchar [note: 'Type of sample (ENTRY_POINT, RAW, FINISHED, DISTRIBUTION).']
  treatment_response_trigger_flag boolean [note: 'True if result triggers a treatment response action (e.g. GAC replacement, IX regeneration).']
  treatment_response_triggered boolean [note: 'Whether a treatment response was triggered.']
  treatment_response_type varchar [note: 'Type of treatment response triggered (GAC_REPLACEMENT, IX_REGENERATION, BLENDING, SHUTDOWN).']
  treatment_technology varchar [note: 'PFAS treatment technology in use at the sampling point (GAC, IX, RO, NANOFILTRATION).']
  unit_of_measure varchar [note: 'Unit of measure for the result value (ng/L, ppt).']
  us_compound_mcl_status varchar [note: 'Per-compound MCL compliance status for US EPA individual PFAS MCLs (PFOA 4ppt, PFOS 4ppt, PFNA, PFHxS, PFBS, HFPO-DA). Values: COMPLIANT, EXCEEDS_MCL, PENDING. NULL for non-US jurisdictions.']
  us_hazard_index decimal(18,6) [note: 'US hazard index for PFNA+PFHxS+PFBS+HFPO-DA (per-compound MCL framework).']
  us_hazard_index_compliance_flag boolean [note: 'TRUE if the US hazard index value is at or below 1.0 (compliant); FALSE if exceeding threshold. NULL for EU jurisdiction.']
  us_hazard_index_compliant_flag boolean [note: 'Whether the US hazard index value is at or below the MCL of 1.0. TRUE = compliant, FALSE = exceedance.']
  us_hazard_index_value decimal(18,2) [note: 'US EPA NPDWR hazard index calculation for mixture of PFNA, PFHxS, PFBS, and HFPO-DA (GenX). MCL is hazard index <= 1.0. NULL for EU-only monitoring.']
  us_mcl_ng_l decimal(18,6) [note: 'US EPA Maximum Contaminant Level for this PFAS compound in ng/L.']
  us_mclg_ng_l decimal(18,6) [note: 'US EPA Maximum Contaminant Level Goal for this PFAS compound in ng/L.']
  us_per_compound_mcl_basis_flag boolean [note: 'TRUE when evaluated under US per-compound MCL / hazard-index framework.']
  us_reference_path varchar [note: 'US reference path: EPA/AWWA/NPDWR/UCMR/NPDES citation chain.']

  Note: 'Records individual PFAS compound monitoring events including PFOA, PFOS, PFNA, PFHxS, PFBS, and HFPO-DA (GenX). Supports both US EPA per-compound MCL compliance and hazard index calculation (PFNA+PFHxS+PFBS+HFPO-DA <= 1.0), as well as EU Drinking Water Directive 2020/2184 sum-of-20 (100 ng/L) and total PFAS class restriction (500 ng/L). Tracks treatment response triggers for GAC, ion exchange, and other PFAS removal technologies. SSOT: Extends quality.analytical_result with PFAS-specific monitoring context (hazard index, EU sum-of-20, treatment response triggers).'
}

Table quality.turbidity_reading {
  turbidity_reading_id varchar [pk, note: 'Unique identifier for the turbidity measurement record. Primary key.']
  analytical_result_id varchar [note: 'Unique identifier linking the turbidity reading to a laboratory analysis record in the Laboratory Information Management System (LIMS), if the reading was obtained through laboratory testing.']
  analytical_test_id varchar [note: 'Unique identifier linking the turbidity reading to a laboratory analysis record in the Laboratory Information Management System (LIMS), if the reading was obtained through laboratory testing.']
  chain_of_custody_id varchar [note: 'Unique identifier for the chain of custody documentation associated with the sample, ensuring traceability and integrity for regulatory compliance.']
  online_instrument_id varchar [note: 'Unique identifier of the turbidity monitoring instrument or analyzer that captured the reading.']
  quality_sampling_point_id varchar [note: 'Unique identifier of the physical sampling location or monitoring point within the treatment plant or distribution system where the turbidity reading was captured.']
  turbidity_employee_id varchar [note: 'Unique identifier of the certified water treatment plant operator or laboratory technician who collected or validated the turbidity reading.']
  turbidity_facility_id varchar [note: 'Unique identifier of the Water Treatment Plant where the turbidity measurement was recorded.']
  turbidity_operator_employee_id varchar [note: 'Unique identifier of the certified water treatment plant operator or laboratory technician who collected or validated the turbidity reading.']
  turbidity_wtp_facility_id varchar [note: 'Unique identifier of the Water Treatment Plant where the turbidity measurement was recorded.']
  alarm_threshold_ntu decimal(6,3) [note: 'The turbidity threshold value in NTU configured in the SCADA system that triggers an operational alarm when exceeded.']
  alarm_triggered_flag boolean [note: 'Boolean indicator (True/False) denoting whether the turbidity reading triggered an automated alarm in the SCADA system due to exceeding a predefined threshold.']
  calibration_timestamp timestamp [note: 'Date and time of the most recent calibration performed on the turbidity instrument prior to this reading.']
  compliance_status varchar [note: 'The compliance status of the turbidity reading relative to regulatory requirements, indicating whether the reading meets Surface Water Treatment Rule standards.']
  corrective_action_taken varchar [note: 'Description of any corrective action taken by plant operators in response to the turbidity reading, such as filter backwash, chemical dosage adjustment, or process shutdown.']
  created_timestamp timestamp
  ct_compliance_context varchar [note: 'Contextual information linking the turbidity reading to disinfection Contact Time (CT) compliance calculations, indicating whether the reading impacts CT credit eligibility under the Surface Water Treatment Rule.']
  data_quality_code varchar [note: 'Code indicating the quality and reliability of the turbidity reading, including flags for suspect data, instrument faults, calibration status, or manual overrides.']
  data_source_system varchar [note: 'The source system from which the turbidity reading was ingested into the lakehouse: OSIsoft PI Historian, LIMS, manual entry, or direct SCADA feed.']
  exceedance_flag boolean [note: 'Boolean indicator (True/False) denoting whether the turbidity reading exceeded the regulatory Maximum Contaminant Level (MCL) or treatment technique requirement under the Surface Water Treatment Rule.']
  filter_unit_number varchar [note: 'Identifier of the specific filter unit at the Water Treatment Plant (WTP) from which the turbidity reading was captured. Applicable for Individual Filter Effluent (IFE) measurements.']
  flow_rate_mgd decimal(10,3) [note: 'The flow rate through the filter or treatment process at the time of the turbidity measurement, expressed in Million Gallons per Day (MGD).']
  measurement_location_type varchar [note: 'Designation of where in the treatment process the turbidity measurement was taken: Individual Filter Effluent (IFE), Combined Filter Effluent (CFE), distribution system entry point, raw water intake, settled water, or filtered water.']
  measurement_method varchar [note: 'The method used to capture the turbidity measurement, indicating whether it was a continuous online reading, grab sample, or laboratory analysis.']
  measurement_timestamp timestamp [note: 'Date and time when the turbidity measurement was captured by the instrument or collected as a grab sample.']
  notes varchar [note: 'Free-text field for operator or analyst notes regarding the turbidity reading, including contextual information, anomalies, or special conditions.']
  pi_tag_name varchar [note: 'The OSIsoft PI Historian tag name associated with the turbidity measurement point, used for SCADA data integration and historical trending.']
  record_created_timestamp timestamp [note: 'Timestamp when this turbidity reading record was first created in the lakehouse silver layer.']
  record_updated_timestamp timestamp [note: 'Timestamp when this turbidity reading record was last updated in the lakehouse silver layer.']
  regulatory_limit_ntu decimal(6,3) [note: 'The applicable regulatory turbidity limit in NTU for the measurement location and context, as defined by the Surface Water Treatment Rule or state primacy agency requirements.']
  reporting_period varchar [note: 'The regulatory reporting period (e.g., monthly, quarterly) to which this turbidity reading applies for compliance reporting purposes.']
  sample_collection_method varchar [note: 'Method by which the water sample was collected for turbidity analysis: automated continuous monitoring, manual grab sample, or composite sample.']
  temperature_c decimal(5,2) [note: 'Temperature of the water sample at the time of turbidity measurement, expressed in degrees Celsius. Temperature can affect turbidity readings and is recorded for quality assurance.']
  turbidity_value_ntu decimal(18,2) [note: 'The measured turbidity value expressed in Nephelometric Turbidity Units (NTU), representing the cloudiness or haziness of the water sample.']

  Note: 'High-frequency turbidity monitoring records from continuous online instruments and grab samples at WTP filter effluents, combined filter effluent, and distribution entry points. Captures NTU value, measurement timestamp, instrument ID, measurement method (nephelometric), filter unit number, CT compliance context, IFE (Individual Filter Effluent) vs CFE (Combined Filter Effluent) designation, and exceedance flag against Surface Water Treatment Rule turbidity limits. Sourced from OSIsoft PI Historian via SCADA integration.'
}

Table quality.ct_calculation {
  ct_calculation_id varchar [pk, note: 'Unique identifier for the CT calculation record. Primary key.']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: New disinfection systems require CT validation during commissioning before operational acceptance. Project substantial completion depends on demonstrated CT compliance. Role-prefixed because ongoing o']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: CT calculations are part of disinfection operations; associated costs (SCADA systems, operator time, validation) are allocated to treatment cost centers for operational budgeting and rate case cost-of']
  ct_employee_id varchar [note: 'Foreign key reference to the certified water treatment plant operator who reviewed or validated the CT calculation.']
  ct_facility_id varchar [note: 'Foreign key reference to the water treatment plant where this CT calculation was performed.']
  ct_operator_employee_id varchar [note: 'Foreign key reference to the certified water treatment plant operator who reviewed or validated the CT calculation.']
  ct_wtp_facility_id varchar [note: 'Foreign key reference to the water treatment plant where this CT calculation was performed.']
  process_unit_id varchar [note: 'Foreign key reference to the specific disinfection process unit or stage within the WTP.']
  quality_sampling_point_id varchar [note: 'Foreign key linking to quality.sampling_point. Business justification: CT calculations are performed at specific measurement points in the disinfection process. Currently has measurement_point_location as a STRING. Adding sampling_point_id normalizes this to reference th']
  turbidity_reading_id varchar [note: 'Foreign key linking to quality.turbidity_reading. Business justification: CT calculations use turbidity as a key input parameter (CT credit depends on turbidity levels). Currently has turbidity_ntu as a denormalized value. Adding turbidity_reading_id links to the authoritat']
  calculated_ct_value_mg_min_l decimal(18,2) [note: 'Calculated CT value (C × T) in mg·min/L. This is the achieved disinfection contact time value.']
  calculation_method varchar [note: 'Method used to perform the CT calculation. Values: manual (operator calculated), automated_scada (real-time SCADA calculation), pi_calculation (OSIsoft PI calculation), laboratory (lab-based calculation).']
  calculation_timestamp timestamp [note: 'Date and time when the CT calculation was performed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Sourced from OSIsoft PI Historian.']
  compliance_status varchar [note: 'Overall compliance status of the CT calculation. Compliant if both Giardia and virus CT ratios ≥ 1.0. Values: compliant, non_compliant, marginal (close to threshold), under_review.']
  contact_chamber_volume_gallons decimal(15,2) [note: 'Volume of the disinfection contact chamber in gallons. Used in conjunction with flow rate to calculate contact time (T).']
  contact_time_minutes decimal(10,2) [note: 'Measured or calculated contact time (T) in minutes that water is exposed to the disinfectant. This is the \'T\' component of the CT calculation. Typically calculated as T10 (time for 10% of water to pass through the contact chamber).']
  created_timestamp timestamp [note: 'Timestamp when this CT calculation record was first created in the system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  ct_ratio_giardia decimal(8,4) [note: 'Ratio of achieved CT to required CT for Giardia inactivation (calculated_ct_value / required_ct_giardia_3log). Must be ≥ 1.0 for compliance.']
  ct_ratio_virus decimal(8,4) [note: 'Ratio of achieved CT to required CT for virus inactivation (calculated_ct_value / required_ct_virus_4log). Must be ≥ 1.0 for compliance.']
  data_quality_flag boolean [note: 'Flag indicating the quality or reliability of the source data used in the CT calculation. Values: good, suspect (questionable readings), estimated (interpolated values), missing (incomplete data), calibration_due (instrument calibration overdue).']
  disinfectant_residual_concentration_mg_l decimal(8,3) [note: 'Measured disinfectant residual concentration (C) in mg/L at the point of measurement. This is the \'C\' component of the CT calculation.']
  disinfectant_type varchar [note: 'Type of disinfectant used in the treatment process. Values: chlorine, chloramine, ozone, uv (ultraviolet), chlorine_dioxide, mixed_oxidant.']
  flow_rate_mgd decimal(12,3) [note: 'Water flow rate through the disinfection process in million gallons per day at the time of calculation. Used to calculate contact time.']
  log_inactivation_giardia decimal(5,2) [note: 'Calculated log inactivation credit achieved for Giardia based on the CT ratio. Minimum 3-log required by SWTR.']
  log_inactivation_virus decimal(5,2) [note: 'Calculated log inactivation credit achieved for viruses based on the CT ratio. Minimum 4-log required by SWTR.']
  modified_timestamp timestamp [note: 'Timestamp when this CT calculation record was last modified. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  mor_reporting_period varchar [note: 'Monthly Operating Report period to which this CT calculation applies, in YYYY-MM format. Used for regulatory reporting aggregation.']
  notes varchar [note: 'Free-text notes or comments regarding the CT calculation, including any anomalies, equipment issues, or special conditions observed during the calculation period.']
  ph_level decimal(4,2) [note: 'pH level of the water at the time of CT calculation. pH affects disinfection efficacy and required CT values per EPA tables. Typical range: 6.5-8.5.']
  required_ct_giardia_3log_mg_min_l decimal(12,3) [note: 'Required CT value for achieving 3-log (99.9%) inactivation of Giardia lamblia cysts, based on EPA CT tables considering water temperature, pH, and disinfectant type.']
  required_ct_virus_4log_mg_min_l decimal(12,3) [note: 'Required CT value for achieving 4-log (99.99%) inactivation of viruses, based on EPA CT tables considering water temperature, pH, and disinfectant type.']
  scada_tag_flow varchar [note: 'SCADA tag identifier in OSIsoft PI Historian for the flow rate measurement point.']
  scada_tag_ph varchar [note: 'SCADA tag identifier in OSIsoft PI Historian for the pH measurement point.']
  scada_tag_residual varchar [note: 'SCADA tag identifier in OSIsoft PI Historian for the disinfectant residual concentration measurement point.']
  scada_tag_temperature varchar [note: 'SCADA tag identifier in OSIsoft PI Historian for the water temperature measurement point.']
  t10_factor decimal(5,4) [note: 'T10 factor representing the ratio of T10 (time for 10% of water to pass through) to theoretical detention time. Typically determined through tracer studies. Used to calculate effective contact time.']
  validation_status varchar [note: 'Status of operator or supervisor validation of the CT calculation. Values: pending, validated, rejected, requires_review.']
  validation_timestamp timestamp [note: 'Date and time when the CT calculation was validated by an operator or supervisor. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  water_temperature_c decimal(5,2) [note: 'Water temperature in degrees Celsius at the time of CT calculation. Temperature affects disinfection efficacy and required CT values per EPA tables.']

  Note: 'Disinfection CT (Contact Time) calculation records for each WTP disinfection process. Captures calculation date/time, disinfectant type (chlorine, chloramine, ozone, UV), disinfectant residual concentration (C in mg/L), contact time (T in minutes), calculated CT value (mg·min/L), required CT for 3-log Giardia and 4-log virus inactivation, CT ratio (achieved/required), temperature, pH, and compliance status. Sourced from OSIsoft PI Historian. Critical for Surface Water Treatment Rule compliance.'
}

Table quality.residual_chlorine_reading {
  residual_chlorine_reading_id varchar [pk, note: 'Unique identifier for the residual chlorine reading record.']
  online_instrument_id varchar [note: 'Identifier of the field instrument, handheld meter, or SCADA analyzer used to perform the measurement. Used for calibration tracking and data quality assurance.']
  process_control_setpoint_id varchar [note: 'Foreign key linking to treatment.process_control_setpoint. Business justification: Distribution system chlorine residual measurements are validated against treatment plant process control setpoints. Links field measurement to operational target for disinfection adequacy verification']
  quality_sampling_point_id varchar [note: 'Identifier of the location where the chlorine residual sample was collected. Links to distribution system nodes, WTP process points, or WWTP discharge points.']
  residual_employee_id varchar [note: 'Identifier of the certified water treatment or distribution operator who collected the manual field reading. Required for regulatory compliance and data quality assurance.']
  residual_operator_employee_id varchar [note: 'Identifier of the certified water treatment or distribution operator who collected the manual field reading. Required for regulatory compliance and data quality assurance.']
  sampling_schedule_id varchar [note: 'Identifier linking this reading to a planned compliance monitoring schedule. Used to track adherence to regulatory sampling frequency requirements.']
  calibration_date date [note: 'Date when the measurement instrument was last calibrated. Regular calibration is required for data validity and regulatory compliance.']
  compliance_flag boolean [note: 'Indicates whether the measured residual meets regulatory minimum requirements. False indicates non-compliance requiring corrective action and potential reporting to primacy agency.']
  contact_time_minutes decimal(8,2) [note: 'Elapsed time between disinfectant application and this measurement point. Used to calculate CT (concentration × time) for disinfection credit under SWTR.']
  corrective_action_description varchar [note: 'Description of corrective actions taken in response to non-compliant or suspect readings. Documents operational response for regulatory reporting and audit trail.']
  corrective_action_required boolean [note: 'Indicates whether the reading triggered a need for corrective action such as booster chlorination, system flushing, or regulatory notification.']
  created_timestamp timestamp
  data_source varchar [note: 'Origin of the residual chlorine reading. SCADA continuous monitors provide real-time data via PI Historian; manual field readings are collected by operators; lab readings are from grab samples.']
  disinfectant_type varchar [note: 'Type of disinfectant residual being measured. Free chlorine is the most common primary disinfectant; total chlorine includes both free and combined forms; chloramine is used for secondary disinfection to reduce DBP formation.']
  flow_rate_gpm decimal(10,2) [note: 'Water flow rate at the sampling point in gallons per minute. Flow affects contact time and mixing; low flow can lead to stagnation and chlorine loss.']
  holding_time_hours decimal(6,2) [note: 'Elapsed time between sample collection and analysis. Chlorine residual must be measured immediately or within 15 minutes to prevent decay and ensure accuracy.']
  maximum_allowed_residual_mg_per_l decimal(6,3) [note: 'Maximum Residual Disinfectant Level (MRDL) allowed by EPA. For chlorine and chloramine, MRDL is 4.0 mg/L as annual average; chlorine dioxide MRDL is 0.8 mg/L.']
  measurement_method varchar [note: 'Analytical method used to determine chlorine residual. DPD colorimetric is standard for field testing; amperometric is used for precise lab analysis; online analyzers provide continuous SCADA monitoring.']
  measurement_timestamp timestamp [note: 'Date and time when the chlorine residual measurement was taken in the field or recorded by SCADA system.']
  minimum_required_residual_mg_per_l decimal(6,3) [note: 'Regulatory or operational minimum disinfectant residual threshold applicable at this sampling point. Typically 0.2 mg/L free chlorine at distribution entry point per EPA requirements.']
  notes varchar [note: 'Free-text field for operator observations, unusual conditions, or contextual information relevant to the reading (e.g., recent main break, flushing activity, taste/odor complaints).']
  ph_value decimal(18,2) [note: 'pH level of water at sampling point. pH affects chlorine speciation and disinfection effectiveness; optimal range for free chlorine is 6.5-7.5.']
  pressure_psi decimal(6,2) [note: 'Water pressure at sampling point in pounds per square inch. Pressure fluctuations can indicate system issues affecting water quality and disinfectant distribution.']
  quality_control_flag boolean [note: 'Data quality indicator based on QA/QC review. Suspect or invalid readings may result from instrument malfunction, calibration drift, or sampling error.']
  record_created_timestamp timestamp [note: 'Timestamp when this record was first created in the data system. Used for audit trail and data lineage tracking.']
  record_updated_timestamp timestamp [note: 'Timestamp when this record was last modified. Tracks data quality corrections, QC flag updates, or supplemental information additions.']
  regulatory_monitoring_flag boolean [note: 'Indicates whether this reading is part of required regulatory compliance monitoring for state primacy agency or EPA reporting (e.g., MOR, CCR).']
  residual_value_mg_per_l decimal(18,2) [note: 'Measured concentration of disinfectant residual in milligrams per liter. EPA requires minimum 0.2 mg/L free chlorine or detectable residual entering distribution system.']
  sample_collection_method varchar [note: 'Method by which the water sample was obtained. Grab samples are instantaneous; composite samples are time-weighted; continuous monitors provide real-time streaming data.']
  sample_location_type varchar [note: 'Classification of the sampling point within the water system infrastructure. Critical for compliance monitoring as different locations have different regulatory requirements.']
  sample_volume_ml decimal(8,2) [note: 'Volume of water sample collected for analysis in milliliters. Standard sample volumes ensure analytical accuracy and method compliance.']
  turbidity_ntu decimal(6,3) [note: 'Turbidity measurement at sampling point. High turbidity can shield pathogens from disinfectant contact and increase chlorine demand.']
  water_temperature_c decimal(5,2) [note: 'Temperature of the water sample at time of measurement. Temperature affects chlorine decay rate and disinfection efficacy; warmer water accelerates chlorine loss.']
  weather_condition varchar [note: 'Weather conditions at time of field sampling. Extreme weather can affect water quality, chlorine demand, and distribution system hydraulics.']

  Note: 'Transactional records of disinfectant residual measurements throughout the distribution system and at WTP/WWTP process points. Captures measurement date/time, sampling point, disinfectant type (free chlorine, total chlorine, chloramine), residual value (mg/L), measurement method (colorimetric, amperometric), field instrument ID, and compliance flag against minimum residual requirements (0.2 mg/L free or detectable). Sourced from both SCADA continuous monitors (PI Historian) and manual field readings.'
}

Table quality.bacteriological_result {
  bacteriological_result_id varchar [pk, note: 'Unique identifier for the bacteriological test result record.']
  analytical_test_id varchar [note: 'Foreign key linking to laboratory.analytical_test. Business justification: Bacteriological results must reference laboratory\'s analytical_test record for method traceability (SM 9223B, Colilert), analyst certification verification, and proficiency testing correlation. Requir']
  bacteriological_employee_id varchar [note: 'Reference to the laboratory supervisor or quality assurance personnel who verified and approved the final result.']
  certified_analyst_id varchar [note: 'Reference to the laboratory analyst who performed the bacteriological test.']
  contaminant_id varchar [note: 'Foreign key linking to quality.contaminant. Business justification: Bacteriological results are for specific contaminants (total coliform, E. coli, fecal coliform, enterococci, HPC). This FK identifies which contaminant the result applies to, enabling proper linkage t']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Bacteriological testing is a major compliance cost with dedicated budget lines; linking to cost_center enables tracking of RTCR compliance costs for budget variance analysis and regulatory cost recove']
  meter_installation_id varchar [note: 'Foreign key linking to metering.installation. Business justification: Bacteriological samples (total coliform, E.coli) collected at customer taps must be traceable to meter installation for RTCR compliance, repeat sampling location identification, and Level 1/2 assessme']
  primary_bacteriological_employee_id varchar [note: 'Reference to the laboratory analyst who performed the bacteriological test.']
  qaqc_batch_id varchar [note: 'Identifier for the quality control batch in which this sample was analyzed, linking to QC blanks, duplicates, and standards.']
  qc_batch_id varchar [note: 'Foreign key linking to laboratory.qc_batch. Business justification: Bacteriological results must reference laboratory QC batch for method validation and regulatory defensibility. RTCR compliance requires demonstrating QC acceptance criteria were met for each analytica']
  quality_sampling_point_id varchar [note: 'Reference to the location where the sample was collected (distribution system tap, treatment plant, reservoir, etc.).']
  sampling_schedule_id varchar [note: 'Foreign key linking to quality.sampling_schedule. Business justification: Bacteriological samples (total coliform, E. coli) are collected per RTCR-mandated sampling schedules. Links result to regulatory schedule for compliance tracking, repeat sample triggering, and assessm']
  vendor_id varchar [note: 'Reference to the laboratory that performed the bacteriological analysis.']
  water_sample_id varchar [note: 'Reference to the water quality sample that was tested.']
  analysis_completion_timestamp timestamp [note: 'Precise timestamp when the bacteriological analysis was completed and results were finalized.']
  analysis_date date [note: 'Date when the bacteriological analysis was performed in the laboratory.']
  analytical_method varchar [note: 'Laboratory analytical method used for bacteriological testing (Membrane Filtration, Colilert, Colisure, MUG, EC-MUG, Multiple Tube Fermentation, Presence-Absence). [ENUM-REF-CANDIDATE: membrane_filtration|colilert|colisure|mug|ec_mug|multiple_tube_fermentation|presence_absence — 7 candidates stripped; promote to reference product]']
  chain_of_custody_number varchar [note: 'Chain of custody tracking number for the sample from collection through analysis, ensuring sample integrity and traceability.']
  compliance_status varchar [note: 'Regulatory compliance status of the result (compliant, non-compliant, exceeds MCL, requires repeat sampling, RTCR assessment triggered).']
  created_timestamp timestamp [note: 'Timestamp when this bacteriological result record was first created in the system.']
  dilution_factor decimal(10,4) [note: 'Dilution factor applied to the sample during analysis, used to calculate final concentration from raw counts.']
  e_coli_cfu decimal(10,2) [note: 'Quantitative result for E. coli bacteria expressed as Colony Forming Units per 100 mL when membrane filtration method is used.']
  e_coli_mpn decimal(10,2) [note: 'Quantitative result for E. coli bacteria expressed as Most Probable Number per 100 mL when enumeration method is used.']
  e_coli_result varchar [note: 'Presence or absence result for E. coli bacteria in the sample.']
  enterococci_cfu decimal(10,2) [note: 'Quantitative result for enterococci bacteria expressed as Colony Forming Units per 100 mL.']
  enterococci_result varchar [note: 'Presence or absence result for enterococci bacteria, typically used for wastewater and recreational water monitoring.']
  fecal_coliform_cfu decimal(10,2) [note: 'Quantitative result for fecal coliform bacteria expressed as Colony Forming Units per 100 mL.']
  fecal_coliform_result varchar [note: 'Presence or absence result for fecal coliform bacteria in the sample (legacy parameter, replaced by E. coli under RTCR).']
  hpc_result decimal(10,2) [note: 'Quantitative result for Heterotrophic Plate Count expressed as Colony Forming Units per milliliter (CFU/mL), used to assess general bacterial population and treatment effectiveness.']
  incubation_duration_hours decimal(5,2) [note: 'Duration in hours for which the sample was incubated during analysis (typically 24 or 48 hours depending on method).']
  incubation_temperature_c decimal(5,2) [note: 'Temperature in degrees Celsius at which the sample was incubated during analysis (typically 35°C or 44.5°C depending on test type).']
  invalidation_reason varchar [note: 'Reason for invalidating the test result if result_status is invalidated (e.g., contamination, procedural error, equipment failure).']
  last_modified_timestamp timestamp [note: 'Timestamp when this bacteriological result record was last modified or updated.']
  mcl_exceeded_flag boolean [note: 'Boolean flag indicating whether the result exceeded the Maximum Contaminant Level for the tested parameter.']
  public_notification_required_flag boolean [note: 'Boolean flag indicating whether this result triggers a public notification requirement under SDWA.']
  regulatory_reporting_flag boolean [note: 'Boolean flag indicating whether this result must be included in regulatory compliance reporting to EPA or state primacy agency.']
  repeat_sample_required_flag boolean [note: 'Boolean flag indicating whether RTCR requires repeat sampling due to a positive total coliform result.']
  result_comments varchar [note: 'Free-text comments from the analyst regarding the test result, including observations, anomalies, or special conditions.']
  result_status varchar [note: 'Current status of the bacteriological test result in the laboratory workflow (preliminary, final, verified, invalidated, pending review).']
  rtcr_assessment_level varchar [note: 'RTCR assessment level triggered by the result (none, Level 1 Assessment, Level 2 Assessment) based on coliform detection patterns.']
  sample_collection_date date [note: 'Date when the water sample was collected from the sampling point.']
  sample_collection_time timestamp [note: 'Precise timestamp when the water sample was collected, including time of day.']
  sample_type varchar [note: 'Classification of the sample within the monitoring program (routine, repeat, triggered, investigative, special).']
  sample_volume_ml decimal(10,2) [note: 'Volume of the water sample in milliliters that was analyzed.']
  test_type varchar [note: 'Type of bacteriological test performed (Total Coliform, E. coli, Fecal Coliform, Heterotrophic Plate Count, Enterococci, or Combined TCR/RTCR).']
  total_coliform_cfu decimal(10,2) [note: 'Quantitative result for total coliform bacteria expressed as Colony Forming Units per 100 mL when membrane filtration method is used.']
  total_coliform_mpn decimal(10,2) [note: 'Quantitative result for total coliform bacteria expressed as Most Probable Number per 100 mL when enumeration method is used.']
  total_coliform_result varchar [note: 'Presence or absence result for total coliform bacteria in the sample.']
  verification_timestamp timestamp [note: 'Timestamp when the result was verified and approved by quality assurance personnel.']

  Note: 'Specialized transactional record for bacteriological testing results including Total Coliform Rule (TCR), Revised Total Coliform Rule (RTCR), and E. coli monitoring. Captures sample date, sampling point, total coliform presence/absence or MPN count, E. coli presence/absence, fecal coliform result, HPC (Heterotrophic Plate Count), analytical method (membrane filtration, Colilert), incubation temperature/time, and triggered repeat sampling requirement. Distinct from general analytical_result due to presence/absence reporting and RTCR Level 1/Level 2 assessment triggers.'
}

Table quality.lead_copper_result {
  lead_copper_result_id varchar [pk, note: 'Unique identifier for the lead and copper sampling result record.']
  analytical_test_id varchar [note: 'Foreign key linking to laboratory.analytical_test. Business justification: Lead/copper results must reference laboratory analytical_test for method compliance verification (EPA 200.8/200.9), QA/QC acceptance, and 90th percentile calculation defensibility. Required for LCR/LC']
  contaminant_id varchar [note: 'Foreign key linking to quality.contaminant. Business justification: Lead and copper results are for specific contaminants (lead or copper). This FK identifies which contaminant the result applies to, enabling proper linkage to contaminant limits and regulatory require']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Lead/copper monitoring involves significant costs (sampling, analysis, customer notification, reporting); utilities track LCR program costs by cost center for compliance budgeting and rate case justif']
  customer_account_id varchar [note: 'Reference to the customer account associated with the sampling site premises.']
  meter_installation_id varchar [note: 'Foreign key linking to metering.installation. Business justification: Lead and Copper Rule explicitly requires sampling at customer taps with documented service line materials. Meter installation is the sampling location for tier classification, 90th percentile calculat']
  point_id varchar [note: 'Foreign key linking to service.service_point. Business justification: Lead and Copper Rule requires sampling at customer taps (service points) with specific site selection criteria based on service line material and building age. Service point linkage is mandatory for 9']
  premise_id varchar [note: 'Foreign key linking to customer.premise. Business justification: Premise characteristics (service line material, building age, plumbing configuration) are mandatory for lead/copper site selection, tier classification, and LCRR compliance. Business process: site inv']
  quality_sampling_point_id varchar [note: 'Reference to the customer tap location selected for Lead and Copper Rule monitoring.']
  sample_collector_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: EPA Lead and Copper Rule requires certified personnel for sampling. Tracking collector employee enables license verification, training compliance audits, and chain-of-custody validation for regulatory']
  sampling_round_id varchar [note: 'Reference to the 6-month monitoring period during which this sample was collected per LCRR requirements.']
  sampling_schedule_id varchar [note: 'Foreign key linking to quality.sampling_schedule. Business justification: Lead/copper monitoring follows LCR sampling rounds with specific site selection and frequency requirements. Links result to regulatory schedule for 90th percentile calculation, action level exceedance']
  sampling_site_id varchar [note: 'Reference to the customer tap location selected for Lead and Copper Rule monitoring.']
  service_address_id varchar [note: 'Foreign key linking to customer.service_address. Business justification: Lead/copper sampling requires precise service address tracking for tier site selection, customer notification within 30 days of result, and LCRR compliance documentation. Already has customer_account_']
  vendor_id varchar [note: 'Reference to the certified laboratory that performed the lead and copper analysis.']
  water_sample_id varchar [note: 'Laboratory-assigned unique identifier for the physical water sample collected at the tap.']
  analysis_date date [note: 'Date when the laboratory completed the lead and copper analysis.']
  analysis_method varchar [note: 'EPA-approved analytical method used for lead and copper determination (e.g., EPA 200.8 ICP-MS, EPA 200.9 ICP-AES).']
  copper_action_level_exceeded boolean [note: 'Indicates whether the copper result exceeds the EPA action level of 1300 ppb (1.3 mg/L), triggering potential corrosion control treatment requirements.']
  copper_result_ppb decimal(8,3) [note: 'Measured concentration of copper in the water sample expressed in parts per billion (ppb or µg/L). Used for 90th percentile calculation and action level comparison.']
  corrosion_control_treatment_status varchar [note: 'Status of corrosion control treatment optimization at the time of sampling, indicating whether the water system has optimized corrosion control per LCRR requirements.']
  created_timestamp timestamp [note: 'Timestamp when this lead and copper result record was first created in the system.']
  customer_notification_date date [note: 'Date when the customer was notified of their individual lead and copper sample result.']
  customer_notification_sent boolean [note: 'Indicates whether the customer was notified of their individual sample result as required by LCRR within 30 days of receiving results.']
  detection_limit_copper_ppb decimal(8,3) [note: 'Minimum concentration of copper that the analytical method can reliably detect and quantify for this sample.']
  detection_limit_lead_ppb decimal(8,3) [note: 'Minimum concentration of lead that the analytical method can reliably detect and quantify for this sample.']
  holding_time_compliant boolean [note: 'Indicates whether the sample was analyzed within the EPA-required holding time (6 months for metals) from collection to analysis.']
  included_in_90th_percentile decimal(18,6) [note: 'Indicates whether this result was included in the 90th percentile calculation for LCRR compliance determination. Invalid or QC-failed samples are excluded.']
  lead_action_level_exceeded boolean [note: 'Indicates whether the lead result exceeds the EPA action level of 15 ppb, triggering potential corrosion control treatment requirements.']
  lead_result_ppb decimal(8,3) [note: 'Measured concentration of lead in the water sample expressed in parts per billion (ppb or µg/L). Used for 90th percentile calculation and action level comparison.']
  modified_timestamp timestamp [note: 'Timestamp when this lead and copper result record was last updated in the system.']
  quality_control_status varchar [note: 'Laboratory quality control status indicating whether the sample result passed all QC checks including blanks, duplicates, and spike recoveries.']
  regulatory_reporting_status varchar [note: 'Status of this result in the regulatory reporting workflow to state primacy agency and EPA.']
  remarks varchar [note: 'Free-text field for additional notes, observations, or special circumstances related to the sample collection or analysis.']
  sample_collection_date date [note: 'Date when the first-draw water sample was collected at the customer tap.']
  sample_collection_time timestamp [note: 'Precise timestamp when the first-draw water sample was collected, including time of day to verify minimum stagnation period compliance.']
  sample_ph decimal(4,2) [note: 'pH measurement of the water sample at collection, relevant for corrosion control assessment.']
  sample_preservation_method varchar [note: 'Method used to preserve the sample for metals analysis, typically acidification with nitric acid to pH < 2.']
  sample_temperature_c decimal(5,2) [note: 'Water temperature at the time of sample collection, recorded to document field conditions.']
  sample_volume_ml decimal(8,2) [note: 'Volume of the first-draw water sample collected, typically 1 liter (1000 mL) per LCRR protocol.']
  service_line_material varchar [note: 'Material composition of the customer service line as classified under LCRR for site selection and tiering. [ENUM-REF-CANDIDATE: lead|galvanized_requiring_replacement|lead_status_unknown|non_lead|copper|plastic|steel|iron|unknown — promote to reference product]']
  site_tier varchar [note: 'LCRR-mandated tier classification of the sampling site based on service line material and building construction date (Tier 1: lead service lines, Tier 2: lead status unknown, Tier 3: non-lead).']
  stagnation_time_hours decimal(5,2) [note: 'Duration in hours that water remained stagnant in the service line prior to sample collection. LCRR requires minimum 6-hour stagnation for first-draw samples.']

  Note: 'Specialized transactional record for Lead and Copper Rule (LCR/LCRR) monitoring at customer tap sampling sites. Captures sampling round (6-month period), customer service line material classification (lead, galvanized, copper, unknown), first-draw sample result (lead ppb, copper ppb), 90th percentile calculation inputs, action level exceedance flag (lead >15 ppb, copper >1300 ppb), tier classification of sampling site, and corrosion control treatment optimization status. Distinct from general analytical_result due to LCRR-specific site selection, tiering, and 90th percentile compliance methodology.'
}

Table quality.source_water_quality {
  source_water_quality_id varchar [pk, note: 'Unique identifier for the source water quality measurement record.']
  bulk_water_agreement_id varchar [note: 'Foreign key linking to service.bulk_water_agreement. Business justification: Bulk water agreements specify contractual water quality standards at delivery points. Source water monitoring at these points verifies compliance with contracted quality parameters, triggers price adj']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: New source water intakes require baseline water quality characterization during commissioning to validate design assumptions. Project cannot be turned over to operations without documented source wate']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Source water monitoring costs are allocated to raw water/intake operations cost centers for budget tracking and rate case documentation of source water protection and monitoring program expenses.']
  quality_sampling_point_id varchar [note: 'Foreign key linking to quality.sampling_point. Business justification: Source water quality measurements are taken at specific sampling points (intake locations). Currently has source_water_intake_id (cross-domain to treatment) and sample_id. Adding sampling_point_id est']
  sampled_by_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Source water monitoring under SDWA requires operator certification. Linking sampler employee enables compliance verification for intake monitoring programs, training record validation, and regulatory ']
  source_water_intake_id varchar [note: 'Reference to the specific water source intake point or well where the sample was collected.']
  water_sample_id varchar [note: 'Unique laboratory identifier assigned to the water sample for tracking and chain of custody.']
  algae_count_cells_per_ml varchar [note: 'Concentration of algae cells per milliliter of source water, important for taste, odor, and treatment challenges.']
  alkalinity_mg_per_l decimal(8,2) [note: 'Total alkalinity expressed as milligrams per liter of calcium carbonate equivalent, indicating buffering capacity.']
  ammonia_mg_per_l decimal(7,4) [note: 'Ammonia nitrogen concentration in milligrams per liter, affecting disinfection effectiveness and DBP formation.']
  analysis_method varchar [note: 'EPA or Standard Methods reference number for the analytical method used for testing.']
  chloride_mg_per_l decimal(8,2) [note: 'Chloride concentration in milligrams per liter, affecting taste and corrosivity.']
  color_pcu varchar [note: 'Apparent color of the source water measured in Platinum-Cobalt Units, indicating dissolved organic matter.']
  conductivity_us_per_cm decimal(10,2) [note: 'Electrical conductivity of the source water in microsiemens per centimeter, indicating ionic content.']
  created_timestamp timestamp [note: 'Timestamp when this source water quality record was first created in the system.']
  cyanotoxin_concentration_ug_per_l decimal(10,4) [note: 'Concentration of cyanotoxins in micrograms per liter if detected, null if not detected or not analyzed.']
  cyanotoxin_detected boolean [note: 'Boolean indicator of whether cyanotoxins (blue-green algae toxins) were detected in the screening analysis.']
  dissolved_oxygen_mg_per_l decimal(6,2) [note: 'Concentration of dissolved oxygen in milligrams per liter, indicating water quality and biological activity.']
  flow_rate_mgd decimal(10,3) [note: 'Flow rate of the source water at the intake point at time of sampling, expressed in Million Gallons per Day.']
  hardness_mg_per_l decimal(8,2) [note: 'Total hardness expressed as milligrams per liter of calcium carbonate equivalent, indicating calcium and magnesium content.']
  iron_mg_per_l decimal(7,4) [note: 'Total iron concentration in milligrams per liter, important for treatment process design and aesthetic quality.']
  lab_analyzed_by varchar [note: 'Name or identifier of the laboratory analyst who performed the water quality analysis.']
  manganese_mg_per_l decimal(7,4) [note: 'Total manganese concentration in milligrams per liter, important for treatment and aesthetic quality.']
  measurement_timestamp timestamp [note: 'Date and time when the source water quality sample was collected and measured.']
  nitrate_mg_per_l decimal(7,3) [note: 'Nitrate nitrogen concentration in milligrams per liter, a regulated contaminant under SDWA.']
  notes varchar [note: 'Free-text field for additional observations, anomalies, or contextual information about the source water quality measurement.']
  ph_level decimal(4,2) [note: 'Measure of acidity or alkalinity of the source water on a scale of 0-14, critical for treatment process optimization.']
  quality_control_passed boolean [note: 'Boolean indicator of whether the laboratory analysis passed all quality control checks and validation criteria.']
  regulatory_exceedance boolean [note: 'Boolean indicator of whether any measured parameter exceeded regulatory action levels or Maximum Contaminant Levels (MCL).']
  season varchar [note: 'Season during which the source water sample was collected, used for seasonal trend analysis.']
  seasonal_variation_flag boolean [note: 'Boolean indicator of whether this measurement represents a period of significant seasonal variation in source water quality.']
  source_location_source_water_intake_id varchar [note: 'Reference to the specific water source intake point or well where the sample was collected.']
  source_type varchar [note: 'Classification of the water source from which the sample was collected.']
  sulfate_mg_per_l decimal(8,2) [note: 'Sulfate concentration in milligrams per liter, a secondary contaminant affecting taste and odor.']
  tds_mg_per_l decimal(8,2) [note: 'Total Dissolved Solids concentration in milligrams per liter, indicating mineral content and salinity.']
  temperature_celsius decimal(5,2) [note: 'Temperature of the source water at time of sampling, measured in degrees Celsius.']
  toc_mg_per_l decimal(8,3) [note: 'Total Organic Carbon concentration in milligrams per liter, a key indicator for disinfection byproduct formation potential.']
  treatment_adjustment_required boolean [note: 'Boolean indicator of whether the source water quality measurement triggered a need for Water Treatment Plant (WTP) process adjustment.']
  tss_mg_per_l decimal(8,2) [note: 'Total Suspended Solids concentration in milligrams per liter, indicating particulate matter load.']
  turbidity_ntu decimal(8,3) [note: 'Raw turbidity measurement of the source water expressed in Nephelometric Turbidity Units, indicating suspended particle concentration.']
  updated_timestamp timestamp [note: 'Timestamp when this source water quality record was last modified in the system.']
  weather_condition varchar [note: 'General weather condition at the time of sampling, affecting source water quality characteristics.']

  Note: 'Transactional records of raw source water quality measurements at intake points (surface water intakes, groundwater wells, purchased water entry points). Captures measurement date/time, source type (river, reservoir, lake, groundwater, purchased), raw turbidity (NTU), TOC (mg/L), pH, temperature, alkalinity, hardness, color, algae counts, cyanotoxin screening results, and seasonal variation flags. Drives WTP treatment process adjustments and source water assessment reporting.'
}

Table quality.effluent_quality {
  effluent_quality_id varchar [pk, note: 'Unique identifier for the effluent quality measurement record.']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: New or upgraded WWTP facilities require effluent quality validation during commissioning to demonstrate NPDES permit compliance before final acceptance. Project closeout requires documented effluent q']
  compliance_permit_id varchar [note: 'Foreign key reference to the NPDES permit governing this discharge point.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Wastewater effluent monitoring costs are allocated to treatment operations cost centers for NPDES compliance budgeting, DMR reporting cost tracking, and rate case justification of wastewater treatment']
  dmr_id varchar [note: 'Foreign key linking to compliance.dmr. Business justification: Effluent quality measurements populate DMR (Discharge Monitoring Report) submissions for NPDES compliance. This link connects laboratory results to regulatory reporting documents, essential for wastew']
  lab_sample_id varchar [note: 'Foreign key linking to laboratory.lab_sample. Business justification: Wastewater effluent samples analyzed in laboratory for NPDES compliance. Direct lab_sample link required for DMR reporting, laboratory QA/QC traceability, and permit limit verification. Supports EPA N']
  outfall_id varchar [note: 'Foreign key reference to the specific discharge outfall point where the effluent sample was collected.']
  permit_condition_id varchar [note: 'Foreign key linking to compliance.permit_condition. Business justification: Effluent quality measurements are evaluated against specific permit conditions (BOD limits, TSS limits, pH ranges). This link enables automated compliance determination by comparing measured values to']
  primary_effluent_sampled_by_employee_id varchar [note: 'Foreign key reference to the employee who collected the effluent sample.']
  quality_sampling_point_id varchar [note: 'Foreign key linking to quality.sampling_point. Business justification: Effluent quality measurements are taken at specific sampling points. Currently has outfall_id (not a product in this domain) and outfall_identifier (STRING). Adding sampling_point_id establishes the l']
  wwtp_id varchar [note: 'Foreign key reference to the wastewater treatment plant where the effluent sample was collected.']
  ammonia_nitrogen_mg_l decimal(10,3) [note: 'Ammonia nitrogen concentration in milligrams per liter, measuring un-ionized and ionized ammonia.']
  ammonia_permit_limit_mg_l decimal(10,3) [note: 'NPDES permit limit for ammonia nitrogen concentration in milligrams per liter for this discharge point.']
  analysis_completion_date date [note: 'Date when the laboratory completed all analytical testing for this effluent sample.']
  bod5_mg_l decimal(10,3) [note: 'Five-day biochemical oxygen demand concentration in milligrams per liter, measuring organic pollution load.']
  bod5_permit_limit_mg_l decimal(10,3) [note: 'NPDES permit limit for BOD5 concentration in milligrams per liter for this discharge point.']
  cbod5_mg_l decimal(10,3) [note: 'Five-day carbonaceous biochemical oxygen demand concentration in milligrams per liter, excluding nitrogenous demand.']
  cod_mg_l decimal(10,3) [note: 'Chemical oxygen demand concentration in milligrams per liter, measuring total organic and inorganic oxidizable matter.']
  compliance_status varchar [note: 'Overall compliance status of this effluent sample against NPDES permit limits: compliant (all parameters within limits), non-compliant (one or more violations), exceedance (exceeds but within reporting tolerance), or pending review.']
  created_timestamp timestamp [note: 'System timestamp when this effluent quality record was first created in the database.']
  discharge_date date [note: 'Calendar date of the effluent discharge event for reporting purposes.']
  dissolved_oxygen_mg_l decimal(10,3) [note: 'Dissolved oxygen concentration in milligrams per liter, measuring oxygen available in the effluent.']
  dmr_reporting_period varchar [note: 'The DMR reporting period (e.g., 2024-01, 2024-Q1) to which this effluent measurement applies.']
  e_coli_cfu_100ml decimal(15,2) [note: 'E. coli bacteria count in colony forming units per 100 milliliters, indicating fecal contamination and pathogen risk.']
  fecal_coliform_cfu_100ml decimal(15,2) [note: 'Fecal coliform bacteria count in colony forming units per 100 milliliters, indicating fecal contamination.']
  fecal_coliform_permit_limit_cfu_100ml decimal(15,2) [note: 'NPDES permit limit for fecal coliform bacteria count in colony forming units per 100 milliliters for this discharge point.']
  flow_rate_mgd decimal(12,4) [note: 'Effluent discharge flow rate measured in million gallons per day at the time of sampling.']
  modified_timestamp timestamp [note: 'System timestamp when this effluent quality record was last modified.']
  npdes_permit_number varchar [note: 'The EPA-issued NPDES permit number authorizing this discharge (e.g., CA0001234).']
  ph_permit_range_max decimal(4,2) [note: 'NPDES permit maximum allowable pH value for this discharge point.']
  ph_permit_range_min decimal(4,2) [note: 'NPDES permit minimum allowable pH value for this discharge point.']
  ph_value decimal(18,2) [note: 'pH measurement of the effluent, indicating acidity or alkalinity on a scale of 0-14.']
  remarks varchar [note: 'Free-text field for operational notes, unusual conditions, or explanations related to this effluent sample (e.g., heavy rainfall event, equipment malfunction, process upset).']
  sample_collection_timestamp timestamp [note: 'Date and time when the effluent sample was collected at the discharge point.']
  sample_type varchar [note: 'Method of sample collection: grab (instantaneous), composite over 24 hours, flow-weighted composite, or continuous monitoring.']
  tds_mg_l decimal(10,3) [note: 'Total dissolved solids concentration in milligrams per liter, measuring dissolved inorganic and organic substances.']
  temperature_celsius decimal(5,2) [note: 'Effluent temperature measured in degrees Celsius at the time of discharge.']
  toc_mg_l decimal(10,3) [note: 'Total organic carbon concentration in milligrams per liter, measuring all carbon in organic compounds.']
  total_nitrogen_mg_l decimal(10,3) [note: 'Total nitrogen concentration in milligrams per liter, including organic nitrogen, ammonia, nitrite, and nitrate.']
  total_phosphorus_mg_l decimal(10,3) [note: 'Total phosphorus concentration in milligrams per liter, measuring all forms of phosphorus including orthophosphate and organic phosphorus.']
  total_residual_chlorine_mg_l decimal(10,3) [note: 'Total residual chlorine concentration in milligrams per liter, measuring disinfectant residual in the effluent.']
  tss_mg_l decimal(10,3) [note: 'Total suspended solids concentration in milligrams per liter, measuring particulate matter in the effluent.']
  tss_permit_limit_mg_l decimal(10,3) [note: 'NPDES permit limit for TSS concentration in milligrams per liter for this discharge point.']
  turbidity_ntu decimal(10,3) [note: 'Turbidity measurement in nephelometric turbidity units, indicating water clarity and suspended particle content.']

  Note: 'Transactional records of treated wastewater effluent quality at WWTP discharge points. Captures discharge date/time, outfall identifier, NPDES permit number, BOD5 (mg/L), CBOD5, COD, TSS (mg/L), TDS, ammonia-nitrogen, total nitrogen, total phosphorus, pH, dissolved oxygen, fecal coliform, E. coli, flow rate (MGD), and permit limit compliance status for each parameter. Drives DMR (Discharge Monitoring Report) preparation and NPDES compliance tracking.'
}

Table quality.ccr_period {
  ccr_period_id varchar [pk, note: 'Unique identifier for the Consumer Confidence Report period. Primary key.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: CCR preparation and distribution involves costs (printing, mailing, staff time, translation) allocated to customer service or compliance cost centers for budget tracking and rate case justification of']
  regulatory_requirement_id varchar [note: 'FK to the governing regulatory requirement, providing the parallel US/EU/other reference path.']
  additional_languages varchar [note: 'Comma-separated list of additional languages in which the CCR was made available (e.g., Spanish, Chinese, Vietnamese).']
  certification_method varchar [note: 'Method used to submit the CCR certification to the primacy agency. Many states now require electronic submission through online portals.']
  certification_submission_date date [note: 'Date when the CCR certification was submitted to the primacy agency. Systems must certify delivery of the CCR to customers by October 1.']
  certified_by_name varchar [note: 'Name of the authorized water system official who certified the CCR. Typically the system manager, superintendent, or designated compliance officer.']
  certified_by_title varchar [note: 'Job title of the authorized official who certified the CCR.']
  comments varchar [note: 'Additional notes, observations, or context about this CCR period, preparation process, or special circumstances.']
  contact_email varchar [note: 'Email address for customer inquiries about the CCR. Increasingly included as an additional contact method.']
  contact_name varchar [note: 'Name of the water system contact person for customer questions about the CCR. Required to be included in the published report.']
  contact_phone varchar [note: 'Phone number for customer inquiries about the CCR. Required to be included in the published report.']
  created_timestamp timestamp [note: 'Timestamp when this CCR period record was first created in the system.']
  customers_served_count varchar [note: 'Total number of customer accounts or service connections served by the water system during the report year. Used to determine CCR distribution requirements.']
  detected_contaminant_count varchar [note: 'Total number of regulated contaminants detected in the water system during the report year. Includes contaminants above and below Maximum Contaminant Levels (MCL).']
  distribution_method varchar [note: 'Primary method used to deliver the Consumer Confidence Report to customers. EPA allows mail, electronic delivery, or posting with notification.']
  document_file_path varchar [note: 'File system path or cloud storage location of the final published CCR document (typically PDF format).']
  eu_article_17_compliance_flag boolean [note: 'Whether this reporting period meets EU DWD 2020/2184 Article 17 requirements for consumer information and online access to water quality data.']
  eu_information_access_method varchar [note: 'Method by which consumer water quality information is made accessible per EU DWD 2020/2184 Art 14 (e.g. online portal, annual mailing, on-request). NULL for US jurisdiction.']
  eu_reference_path varchar [note: 'EU reference path: Drinking Water Directive 2020/2184; REACH; WFD; UWWTD citation chain.']
  health_effects_language_included_flag boolean [note: 'Indicates whether mandatory EPA health effects language was included for all detected contaminants. Required for CCR compliance.']
  jurisdiction varchar [note: 'Jurisdiction flavor for this record. Allowed: US,EU,OTHER.']
  jurisdiction_code varchar [note: 'Regulatory jurisdiction for this CCR/consumer information report (US_EPA, US_STATE, EU_MEMBER_STATE, OTHER). EU equivalent is DWD 2020/2184 Article 17 consumer information provision.']
  jurisdiction_region varchar [note: 'Regulatory region code (US, EU, OTHER) for this consumer confidence report period. US requires annual CCR per SDWA; EU requires equivalent consumer information under Drinking Water Directive 2020/2184 Article 17.']
  language_accessibility_provided_flag boolean [note: 'Indicates whether the CCR was made available in languages other than English to serve non-English speaking populations. Required for systems serving significant non-English speaking populations.']
  lead_copper_educational_information_flag boolean [note: 'Indicates whether mandatory lead and copper educational information was included in the CCR. Required under Lead and Copper Rule Revisions (LCRR).']
  mcl_violation_count varchar [note: 'Number of Maximum Contaminant Level violations that occurred during the report year. Must be prominently disclosed in the CCR.']
  modified_by varchar [note: 'User ID or name of the person who last modified this CCR period record.']
  modified_timestamp timestamp [note: 'Timestamp when this CCR period record was last modified.']
  monitoring_violation_count varchar [note: 'Number of monitoring and reporting violations that occurred during the report year. Includes failures to test or report as required.']
  online_ccr_url varchar [note: 'Web address where the CCR is posted online. Required if using electronic delivery method.']
  other_reference_path varchar [note: 'Other national/regional regulatory reference path.']
  population_served_count varchar [note: 'Estimated total population receiving water from the system during the report year. Used for regulatory classification and reporting.']
  preparation_start_date date [note: 'Date when preparation of the Consumer Confidence Report began. Typically starts in January following the report year.']
  primacy_agency varchar [note: 'State or tribal agency with primary enforcement responsibility for public water systems under the Safe Drinking Water Act. Typically the state Department of Environmental Quality or Health.']
  publication_date date [note: 'Date when the Consumer Confidence Report was published and made available to customers. Must be by July 1 following the report year per EPA regulations.']
  pwsid varchar [note: 'EPA-assigned unique identifier for the public water system. Format: two-letter state code followed by seven digits (e.g., CA1234567).']
  regulatory_framework varchar [note: 'Applicable regulatory framework for the region (US=EPA/AWWA/NPDWR/UCMR/NPDES; EU=Drinking Water Directive 2020/2184; REACH; Water Framework Directive; Urban Wastewater Treatment Directive; OTHER=Other national/regional frameworks).']
  regulatory_region varchar [note: 'Top-level regulatory region (US, EU, OTHER). US requires annual CCR per SDWA; EU requires real-time online access to water quality data per DWD 2020/2184 Article 17. Allowed regions: US,EU,OTHER.']
  regulatory_region_code varchar [note: 'ISO region code identifying the jurisdiction for this consumer confidence / water quality report period (US, EU, OTHER). US uses CCR per SDWA; EU uses DWD 2020/2184 Art 14 consumer information.']
  report_status varchar [note: 'Current lifecycle status of the Consumer Confidence Report. Tracks progression from draft through publication and certification to primacy agency.']
  report_year varchar [note: 'Calendar year for which this Consumer Confidence Report is prepared. CCRs are annual reports covering the previous calendar year\'s water quality data.']
  source_water_assessment_summary varchar [note: 'Summary of the source water assessment including susceptibility to contamination and availability information. Required CCR content element.']
  special_notices_included varchar [note: 'Description of any special notices included in the CCR such as boil water advisories, vulnerable population warnings, or emerging contaminant information.']
  treatment_technique_violation_count varchar [note: 'Number of treatment technique violations that occurred during the report year. Treatment techniques are required processes for contaminants without MCLs.']
  us_reference_path varchar [note: 'US reference path: EPA/AWWA/NPDWR/UCMR/NPDES citation chain.']
  violation_summary varchar [note: 'Narrative summary of all violations that occurred during the report year, including health effects language and corrective actions taken. Required CCR content element.']
  water_source_summary varchar [note: 'Narrative description of the water system\'s sources including surface water, groundwater, purchased water, and source water protection information. Required CCR content element.']
  water_system_name varchar [note: 'Official name of the public water system as registered with the primacy agency.']
  created_by varchar [note: 'User ID or name of the person who created this CCR period record.']

  Note: 'Master record for each annual Consumer Confidence Report (CCR) reporting period. Captures report year, water system name, PWSID (Public Water System ID), primacy agency, report preparation status, publication date, distribution method (mailed, posted, electronic), number of customers served, water source summary, detected contaminant summary count, violation summary, and certification submission date to primacy agency. Serves as the organizing entity for all CCR-related quality data aggregation.'
}

Table quality.ccr_detected_contaminant {
  ccr_detected_contaminant_id varchar [pk, note: 'Unique identifier for each contaminant detection record required to be reported in the annual Consumer Confidence Report (CCR) for a given reporting period. Primary key.']
  ccr_created_by_user_employee_id varchar [note: 'Identifier of the user who originally created this contaminant detection record. Supports accountability and audit trail for regulatory compliance.']
  ccr_employee_id varchar [note: 'Identifier of the water quality manager or compliance officer who reviewed and approved this contaminant detection record for inclusion in the Consumer Confidence Report. Supports audit trail and regulatory accountability.']
  ccr_modified_by_user_employee_id varchar [note: 'Identifier of the user who last modified this contaminant detection record. Supports change tracking and accountability for data quality.']
  ccr_period_id varchar [note: 'Foreign key linking to quality.ccr_period. Business justification: CCR detected contaminants belong to a CCR period within the quality domain. The existing ccr_id points to quality.ccr (cross-domain), but ccr_period is the in-domain master record for CCR reporting']
  contaminant_id varchar [note: 'Foreign key linking to quality.contaminant. Business justification: ccr_detected_contaminant currently has contaminant_code and contaminant_name as denormalized attributes. This product reports contaminants detected in the annual Consumer Confidence Report and must re']
  primary_ccr_employee_id varchar [note: 'Identifier of the water quality manager or compliance officer who reviewed and approved this contaminant detection record for inclusion in the Consumer Confidence Report. Supports audit trail and regulatory accountability.']
  quality_sampling_point_id varchar [note: 'Foreign key linking to quality.sampling_point. Business justification: CCR detected contaminants are detected at specific sampling points. This FK identifies the primary sampling point where the contaminant was detected, enabling location-specific reporting in the CCR.']
  segment_id varchar [note: 'Foreign key linking to customer.customer_segment. Business justification: CCR distribution and contaminant messaging varies by customer segment (residential vs commercial, language requirements, delivery method preferences). Regulatory requirement: targeted CCR delivery and']
  territory_id varchar [note: 'Foreign key linking to service.service_territory. Business justification: Consumer Confidence Reports are prepared and distributed by service territory (water system). Detected contaminants must be associated with the specific service territory for accurate CCR generation, ']
  tertiary_ccr_modified_by_user_employee_id varchar [note: 'Identifier of the user who last modified this contaminant detection record. Supports change tracking and accountability for data quality.']
  action_level decimal(18,6) [note: 'The concentration of a contaminant which, if exceeded, triggers treatment or other requirements that a water system must follow. Primarily used for lead and copper under the Lead and Copper Rule (LCR) and Lead and Copper Rule Revisions (LCRR). Null if not applicable.']
  approval_timestamp timestamp [note: 'Date and time when this contaminant detection record was reviewed and approved for CCR publication. Part of the quality assurance and regulatory compliance workflow.']
  ccr_table_display_order varchar [note: 'Sequence number controlling the display order of this contaminant in the published CCR detected contaminants table. Allows utilities to organize contaminants by category, regulatory importance, or alphabetically for public presentation.']
  comments varchar [note: 'Internal notes, comments, or observations regarding this contaminant detection. May include quality control notes, data validation comments, or context for unusual results. Not published in the CCR but retained for internal documentation.']
  compliance_status varchar [note: 'Overall compliance status for this contaminant during the reporting period. Indicates whether the water system met all regulatory requirements including MCL/AL compliance, monitoring frequency, and reporting obligations.']
  contaminant_category varchar [note: 'Classification of the contaminant type for regulatory grouping and CCR presentation. Categories align with EPA National Primary Drinking Water Regulations structure.']
  corrective_action_description varchar [note: 'Description of corrective actions taken or planned by the water system in response to violations or elevated contaminant levels. Required disclosure in CCR when violations occur. Includes treatment modifications, infrastructure improvements, or operational changes.']
  created_timestamp timestamp [note: 'Date and time when this contaminant detection record was first created in the system. Part of the audit trail for regulatory compliance and data governance.']
  data_source varchar [note: 'Identifies the system or process from which this contaminant detection data was obtained (e.g., Laboratory Information Management System, SCADA historian, manual data entry, state drinking water database). Supports data lineage and quality assurance.']
  detection_frequency_percent decimal(5,2) [note: 'Percentage of samples in which this contaminant was detected, calculated as (number_of_detections / number_of_samples) * 100. Provides statistical context for contaminant presence in the water system.']
  footnote_text varchar [note: 'Additional explanatory text or footnotes specific to this contaminant detection that will appear in the CCR. Used to provide context, explain unusual results, clarify monitoring schedules, or reference specific regulatory requirements.']
  health_effects_language varchar [note: 'EPA-mandated health effects language describing the potential health impacts of this contaminant when present above the MCL or MCLG. Must use EPA-approved standard language as specified in 40 CFR 141.153 Appendix B. Required for all contaminants with violations or detections above health-based levels.']
  highest_level_detected decimal(18,6) [note: 'The highest single measurement or calculated running annual average (RAA) of the contaminant detected during the reporting period. For some contaminants (e.g., THM, HAA5), this represents the highest locational running annual average (LRAA). Reporting format depends on contaminant-specific regulations.']
  mcl decimal(18,6) [note: 'The Maximum Contaminant Level (MCL) - the highest level of a contaminant that is allowed in drinking water. MCLs are enforceable standards set as close to MCLGs as feasible using the best available treatment technology. Null if a Treatment Technique (TT) applies instead of an MCL.']
  mclg decimal(18,6) [note: 'The Maximum Contaminant Level Goal (MCLG) - the level of a contaminant in drinking water below which there is no known or expected risk to health. MCLGs are non-enforceable public health goals. Value of zero indicates no safe level. Null indicates no MCLG established.']
  modified_timestamp timestamp [note: 'Date and time when this contaminant detection record was last modified. Supports change tracking and audit requirements for regulatory reporting.']
  monitoring_period_end_date date [note: 'The ending date of the monitoring period for which this contaminant detection data was collected. Defines the temporal scope of the reported results.']
  monitoring_period_start_date date [note: 'The beginning date of the monitoring period for which this contaminant detection data was collected. Defines the temporal scope of the reported results.']
  number_of_detections varchar [note: 'Count of samples in which this contaminant was detected above the method detection limit (MDL) or practical quantitation level (PQL) during the reporting period. Provides transparency on detection frequency.']
  number_of_samples varchar [note: 'Total count of samples collected and analyzed for this contaminant during the reporting period. Used to demonstrate compliance with monitoring frequency requirements and provide context for detection statistics.']
  public_notification_required_flag boolean [note: 'Indicates whether this contaminant detection triggered Public Notification (PN) requirements under 40 CFR 141 Subpart Q. True if Tier 1, 2, or 3 public notice was required, False otherwise. Public notification is separate from but related to CCR reporting.']
  range_high decimal(18,6) [note: 'The highest level detected for this contaminant across all samples collected during the reporting period. Forms the upper bound of the detection range required for CCR reporting. Typically matches highest_level_detected unless different averaging methods apply.']
  range_low decimal(18,6) [note: 'The lowest level detected for this contaminant across all samples collected during the reporting period. Forms the lower bound of the detection range required for CCR reporting. May be zero or below detection limit.']
  regulatory_program varchar [note: 'The specific EPA regulatory program or rule under which this contaminant is monitored and reported (e.g., National Primary Drinking Water Regulations, Lead and Copper Rule, Disinfectants and Disinfection Byproducts Rule, Unregulated Contaminant Monitoring Rule). [ENUM-REF-CANDIDATE: npdwr|surface_water_treatment_rule|groundwater_rule|lead_copper_rule|dbp_rule|radionuclides_rule|unregulated_contaminant_monitoring — 7 candidates stripped; promote to reference product]']
  reporting_year varchar [note: 'Calendar year for which this contaminant detection is being reported in the CCR. Typically the year in which samples were collected and analyzed.']
  sample_year varchar [note: 'The actual year in which the water samples were collected for this contaminant. May differ from reporting year for contaminants with multi-year monitoring cycles (e.g., lead and copper, certain synthetic organic chemicals).']
  treatment_technique_flag boolean [note: 'Indicates whether this contaminant is regulated by a Treatment Technique (TT) requirement rather than an MCL. True if TT applies (e.g., turbidity, lead and copper action levels), False if MCL applies.']
  typical_source_description varchar [note: 'EPA-mandated language describing the likely sources of this contaminant in drinking water. Must use EPA-approved standard language for each contaminant as specified in 40 CFR 141.153 Appendix A. This text appears directly in the published CCR.']
  unit_of_measure varchar [note: 'The unit of measurement for contaminant concentration values (e.g., mg/L for milligrams per liter, ug/L for micrograms per liter, pCi/L for picocuries per liter, NTU for Nephelometric Turbidity Units, MFL for million fibers per liter). Must align with EPA reporting standards. [ENUM-REF-CANDIDATE: mg/L|ug/L|pCi/L|MFL|NTU|%|CFU/100mL|MPN/100mL — 8 candidates stripped; promote to reference product]']
  violation_flag boolean [note: 'Indicates whether the detected contaminant level resulted in a violation of the MCL, MCLG, Treatment Technique, or Action Level during the reporting period. True if violation occurred, False if compliant. Violations must be prominently disclosed in the CCR.']
  violation_type varchar [note: 'Classification of the type of violation if violation_flag is True. Specifies whether the violation was due to MCL exceedance, action level exceedance, treatment technique failure, monitoring failure, or reporting failure. Value is \'none\' if no violation occurred.']

  Note: 'Transactional record of each contaminant detected and required to be reported in the annual CCR for a given reporting period. Captures contaminant name, MCLG, MCL or treatment technique, highest level detected, range of detections (low-high), sample year, violation flag, typical source description, and health effects language. Directly populates the CCR table of detected contaminants as required by 40 CFR 141.153.'
}

Table quality.monitoring_waiver {
  monitoring_waiver_id varchar [pk, note: 'Unique identifier for the monitoring waiver record. Primary key.']
  contaminant_id varchar [note: 'Reference to the specific contaminant or contaminant group for which the monitoring waiver is granted. Links to the contaminant product.']
  quality_sampling_point_id varchar [note: 'Reference to the specific sampling point or compliance monitoring point where the waiver applies. Links to the sampling_point product.']
  regulatory_requirement_id varchar [note: 'Foreign key linking to compliance.regulatory_requirement. Business justification: Monitoring waivers are granted under specific regulatory requirements (vulnerability assessments per 40 CFR 141). This link documents the regulatory authority and conditions for reduced monitoring, es']
  responsible_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Monitoring waivers require primacy agency approval and internal accountability tracking. Linking responsible employee enables compliance tracking, renewal deadline management, regulatory correspondenc']
  sampling_schedule_id varchar [note: 'Foreign key linking to quality.sampling_schedule. Business justification: Monitoring waivers affect specific sampling schedules by reducing monitoring frequency. This FK links the waiver to the schedule(s) it modifies, enabling proper tracking of which schedules operate und']
  approval_date date [note: 'Date on which the monitoring waiver was officially approved and granted by the primacy agency.']
  baseline_monitoring_frequency varchar [note: 'Original required monitoring frequency before the waiver was granted (e.g., quarterly, monthly, annual). Expressed as a frequency code or description.']
  ccr_reporting_impact varchar [note: 'Description of how the monitoring waiver affects Consumer Confidence Report (CCR) reporting requirements and public notification language.']
  comments varchar [note: 'Additional free-text comments, notes, or observations related to the monitoring waiver, including internal coordination notes or historical context.']
  contaminant_group varchar [note: 'Descriptive name of the contaminant group covered by this waiver (e.g., Disinfection Byproducts (DBP), Volatile Organic Compounds (VOC), Synthetic Organic Chemicals (SOC), Inorganic Chemicals (IOC), Radionuclides).']
  created_timestamp timestamp [note: 'Timestamp when this monitoring waiver record was first created in the system.']
  effective_date date [note: 'Date from which the monitoring waiver becomes effective and the reduced monitoring frequency applies.']
  expiration_date date [note: 'Date on which the monitoring waiver expires and full monitoring frequency must resume unless the waiver is renewed.']
  historical_monitoring_period_end date [note: 'End date of the historical monitoring period used to demonstrate non-detect results for waiver eligibility.']
  historical_monitoring_period_start date [note: 'Start date of the historical monitoring period used to demonstrate non-detect results for waiver eligibility.']
  historical_non_detect_count varchar [note: 'Number of consecutive historical samples with non-detect results for the contaminant, supporting the waiver justification.']
  modified_by varchar [note: 'Username or identifier of the user who last modified this monitoring waiver record.']
  modified_timestamp timestamp [note: 'Timestamp when this monitoring waiver record was last modified or updated in the system.']
  next_renewal_date date [note: 'Date by which the waiver renewal application must be submitted or the waiver reassessment must be completed.']
  primacy_agency_approval_reference varchar [note: 'Official reference number, permit number, or document identifier issued by the primacy agency for this waiver approval.']
  primacy_agency_name varchar [note: 'Name of the state or federal primacy agency that approved and granted the monitoring waiver (e.g., State Department of Environmental Quality, EPA Region).']
  reduced_monitoring_frequency varchar [note: 'Reduced monitoring frequency allowed under the waiver (e.g., annual, triennial, once per compliance period). Expressed as a frequency code or description.']
  renewal_frequency_years varchar [note: 'Frequency in years at which the waiver must be renewed or reassessed if renewal is required.']
  renewal_required_flag boolean [note: 'Indicates whether the waiver requires periodic renewal or reapplication (True) or is granted indefinitely subject to conditions (False).']
  responsible_department varchar [note: 'Department or organizational unit responsible for waiver compliance and monitoring (e.g., Water Quality, Regulatory Compliance, Laboratory).']
  revocation_date date [note: 'Date on which the waiver was revoked by the primacy agency or voluntarily withdrawn by the utility, if applicable.']
  revocation_reason varchar [note: 'Detailed explanation of the reason for waiver revocation, including regulatory violations, detection events, or operational changes.']
  revocation_trigger_conditions varchar [note: 'Specific conditions or events that would trigger automatic revocation of the waiver (e.g., detection above action level, source water contamination, operational changes).']
  sampling_schedule_adjustment_notes varchar [note: 'Operational notes describing how the sampling schedule must be adjusted to reflect the waiver-reduced monitoring frequency.']
  vulnerability_assessment_date date [note: 'Date on which the vulnerability assessment or source water assessment supporting the waiver was completed.']
  vulnerability_assessment_result varchar [note: 'Outcome of the vulnerability assessment indicating the level of vulnerability to the contaminant at the sampling point (e.g., not vulnerable, low vulnerability).']
  waiver_conditions varchar [note: 'Specific conditions, requirements, or restrictions imposed by the primacy agency for maintaining the waiver (e.g., annual source water monitoring, notification requirements, operational changes).']
  waiver_duration_years decimal(5,2) [note: 'Duration of the monitoring waiver in years, representing the period between effective date and expiration date.']
  waiver_justification varchar [note: 'Detailed business and regulatory justification for granting the monitoring waiver, including vulnerability assessment results, historical non-detect data, or source water protection measures.']
  waiver_number varchar [note: 'Externally-known unique identifier or reference number assigned by the primacy agency or utility for this monitoring waiver.']
  waiver_status varchar [note: 'Current lifecycle status of the monitoring waiver indicating whether it is active, expired, revoked, pending approval, suspended, or renewed.']
  waiver_type varchar [note: 'Classification of the monitoring waiver based on the regulatory basis for reduced monitoring (e.g., vulnerability assessment waiver, source water waiver, contaminant-specific waiver).']
  created_by varchar [note: 'Username or identifier of the user who created this monitoring waiver record.']

  Note: 'Master record of approved monitoring waivers granted by the primacy agency allowing reduced monitoring frequency for specific contaminants at specific sampling points. Captures waiver type (vulnerability assessment, source water, contaminant-specific), contaminant group, waiver approval date, expiration date, reduced monitoring frequency, primacy agency approval reference, and conditions for waiver continuation. Ensures the sampling_schedule correctly reflects waiver-adjusted requirements.'
}

Table quality.quality_public_notification {
  quality_public_notification_id varchar [pk, note: 'Unique identifier for the quality_public_notification data product (auto-inserted pre-linking).']
  compliance_public_notification_id varchar [note: 'Canonical single-source-of-truth reference to compliance.compliance_public_notification (compliance_public_notification_id); this entity defers authoritative attribute values to that master entity.']
  contaminant_id varchar [note: 'Contaminant triggering the notification']
  customer_account_id varchar [note: 'Foreign key linking to customer.customer_account. Business justification: Public notifications for water quality violations (Tier 1/2/3 PN) must be delivered to affected customer accounts with proof of delivery tracking. EPA regulatory requirement: PN delivery documentation']
  exceedance_id varchar [note: 'Associated exceedance event']
  facility_id varchar [note: 'Affected facility']
  quality_compliance_public_notification_id varchar [note: 'References the single source of truth record in compliance.compliance_public_notification']
  service_address_id varchar [note: 'Foreign key linking to customer.service_address. Business justification: Geographic targeting of public notifications based on affected service areas (boil water notices, lead exceedances, pressure zone contamination). Operational necessity: incident response, door-to-door']
  actual_distribution_date date [note: 'Actual distribution date']
  affected_connections varchar [note: 'Number of affected connections']
  affected_population varchar [note: 'Estimated population affected']
  agency_notification_date date [note: 'Date the agency was notified']
  alternative_water_provided boolean [note: 'Whether alternative water was provided']
  alternative_water_source varchar [note: 'Source of alternative water']
  approved_by varchar [note: 'Person who approved notification']
  certification_date date [note: 'Date certification was submitted']
  certification_of_delivery boolean [note: 'Whether delivery was certified']
  certification_submitted boolean [note: 'Whether certification was submitted']
  compliance_status varchar
  connections_affected varchar [note: 'Number of service connections affected']
  connections_notified varchar [note: 'Number of connections notified']
  consumer_actions_description varchar [note: 'Recommended consumer actions']
  contaminant_involved varchar
  contaminant_or_issue varchar
  corrective_action_language varchar
  corrective_actions_described varchar [note: 'Corrective actions described']
  corrective_actions_description varchar [note: 'Description of corrective actions being taken']
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp
  data_quality_flag boolean [note: 'True when record passed data validation.']
  deadline_date date [note: 'Regulatory deadline date.']
  delivered_timestamp timestamp
  delivery_confirmation varchar
  delivery_date date [note: 'Date notification was delivered']
  delivery_deadline date [note: 'Delivery deadline']
  delivery_method varchar [note: 'Delivery method (mail, door hanger, media)']
  distribution_method varchar [note: 'How notification was distributed (mail, door-to-door, media, electronic)']
  effective_date date [note: 'Date notification becomes effective']
  geographic_area_affected varchar [note: 'Description of affected geographic area']
  health_effects_language varchar [note: 'Required health effects language included']
  is_acknowledged boolean
  is_acute_violation boolean
  is_delivered boolean
  is_resolved boolean [note: 'Whether notification cycle resolved.']
  issue_date date [note: 'Date the notification was issued']
  issued_date date
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  measured_level varchar [note: 'Measured contaminant level as reported']
  media_advisory_issued boolean [note: 'Whether media advisory was issued']
  message_text varchar
  notes varchar [note: 'Notification notes']
  notification_date date
  notification_method varchar
  notification_number varchar
  notification_reason varchar [note: 'Reason for notification (MCL_violation, boil_water, do_not_use, do_not_drink)']
  notification_status varchar
  notification_text varchar
  notification_tier varchar
  notification_type varchar
  population_affected varchar [note: 'Population affected']
  population_notified varchar [note: 'Population notified.']
  population_served varchar [note: 'Population affected']
  primacy_agency_notified boolean [note: 'Whether primacy agency was notified']
  primacy_agency_notified_date date [note: 'Date primacy agency was notified']
  primacy_notification_date date [note: 'Date primacy agency was notified']
  pwsid varchar [note: 'Public Water System ID']
  quality_public_notification_status varchar [note: 'Notification status (draft, issued, active, rescinded)']
  record_status varchar
  regulator_notified varchar
  regulatory_agency_notified boolean [note: 'Whether the regulatory agency was notified']
  regulatory_agency_notified_flag boolean [note: 'Whether agency was notified']
  regulatory_deadline date
  regulatory_deadline_met_flag boolean
  repeat_frequency varchar [note: 'Frequency of repeat notification']
  repeat_notification_required boolean [note: 'Whether repeat notification required']
  required_by_date date [note: 'Date notification was required by']
  required_response_deadline date [note: 'Regulatory deadline for issuing notification']
  rescind_date date [note: 'Date the notification was rescinded']
  state_approval_date date [note: 'Date of state approval']
  state_approval_required boolean [note: 'Whether state approval required']
  template_used varchar [note: 'Template used for notification']
  tier_level varchar
  trigger_event varchar [note: 'Event that triggered notification']
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp.']
  violation_description varchar [note: 'Description of underlying violation.']
  violation_type varchar [note: 'Type of violation']

  Note: 'Transactional record of each public notification issued to customers and the primacy agency in response to MCL violations, monitoring failures, or other reportable water quality events. Captures notification type (Tier 1 immediate, Tier 2 30-day, Tier 3 annual), triggering violation or event, notification date, delivery method (newspaper, mail, electronic, posting), affected population count, health effects language used, and certification of delivery to primacy agency. Tracks compliance with public notification rule timelines. [SSOT: governed by compliance.compliance_public_notification] [DEPRECATED: Single source of truth is compliance.compliance_public_notification]'
}

Table quality.online_instrument {
  online_instrument_id varchar [pk, note: 'Unique identifier for the online water quality monitoring instrument. Primary key for the online instrument registry.']
  contaminant_id varchar [note: 'Foreign key linking to quality.contaminant. Business justification: Online instruments measure specific contaminants/parameters. Currently has measurement_parameter as a STRING. Adding contaminant_id normalizes this to reference the contaminant registry and allows rem']
  facility_id varchar [note: 'Identifier of the water treatment plant (WTP), wastewater treatment plant (WWTP), pump station, or other facility where the instrument is installed.']
  fixed_asset_id varchar [note: 'Foreign key linking to finance.fixed_asset. Business justification: Online instruments are capital assets requiring depreciation tracking, asset management, and inclusion in rate base for rate case proceedings—standard utility practice for capitalizing monitoring equi']
  online_asset_registry_id varchar [note: 'Reference to the general asset registry if this instrument is also tracked as a capital asset in the CMMS or ERP system. Links quality-specific instrument metadata to enterprise asset management.']
  online_registry_id varchar [note: 'Reference to the general asset registry if this instrument is also tracked as a capital asset in the CMMS or ERP system. Links quality-specific instrument metadata to enterprise asset management.']
  quality_sampling_point_id varchar [note: 'Reference to the specific sampling point or monitoring location where the instrument is deployed. Links to the sampling point registry for regulatory compliance tracking.']
  vendor_id varchar [note: 'Foreign key linking to supply.vendor. Business justification: Online instruments purchased from and serviced by vendors. Required for warranty tracking, calibration service scheduling, spare parts procurement, and vendor performance evaluation. No existing unlin']
  accuracy_specification varchar [note: 'Manufacturer\'s stated accuracy or precision specification for the instrument (e.g., \'±0.02 NTU\', \'±2% of reading\', \'±0.1 pH units\'). Critical for data quality assessment.']
  alarm_high_threshold decimal(18,6) [note: 'Upper alarm threshold value configured in SCADA. When instrument reading exceeds this value, an alarm is triggered for operator response.']
  alarm_low_threshold decimal(18,6) [note: 'Lower alarm threshold value configured in SCADA. When instrument reading falls below this value, an alarm is triggered for operator response.']
  calibration_frequency_days decimal(18,6) [note: 'Required interval between calibrations, expressed in days. Determined by manufacturer recommendations, regulatory requirements, and operational experience.']
  calibration_standard_used decimal(18,6) [note: 'Description of the calibration standard or reference material used during the most recent calibration (e.g., \'NIST-traceable 10 NTU formazin standard\', \'pH 7.0 buffer solution\').']
  calibration_technician decimal(18,6) [note: 'Name or identifier of the technician who performed the most recent calibration. Used for quality assurance and accountability.']
  communication_protocol varchar [note: 'Communication protocol used by the instrument to transmit data to SCADA or control systems (e.g., Modbus RTU, Modbus TCP/IP, HART, Profibus, analog 4-20mA signal). [ENUM-REF-CANDIDATE: modbus_rtu|modbus_tcp|hart|profibus|foundation_fieldbus|ethernet_ip|analog_4_20ma|digital_pulse|bacnet — 9 candidates stripped; promote to reference product]']
  created_timestamp timestamp [note: 'Timestamp when this instrument record was first created in the system. Used for data lineage and audit trail.']
  data_logging_interval_seconds varchar [note: 'Frequency at which the instrument records or transmits data to the SCADA/historian system, expressed in seconds (e.g., 60 for one-minute intervals, 300 for five-minute intervals).']
  expected_service_life_years varchar [note: 'Anticipated operational lifespan of the instrument in years, based on manufacturer specifications and utility experience. Used for capital planning and replacement scheduling.']
  gis_feature_code varchar [note: 'Unique identifier in the GIS system linking this instrument to its geographic location and network context. Enables spatial analysis and network modeling.']
  installation_date date [note: 'Date when the instrument was installed and commissioned at its current location. Used for asset lifecycle tracking and warranty management.']
  installation_location varchar [note: 'Detailed description of where the instrument is physically installed (e.g., \'WTP Filter Effluent Gallery\', \'Distribution Pump Station 5 Discharge\', \'WWTP Final Clarifier Effluent Channel\').']
  instrument_name varchar [note: 'Descriptive name of the online monitoring instrument indicating its function and location (e.g., \'WTP Effluent Turbidimeter\', \'Distribution Zone 3 Chlorine Analyzer\').']
  instrument_status varchar
  instrument_tag varchar [note: 'Unique alphanumeric tag or asset identifier assigned to the instrument for field identification and maintenance tracking. Typically follows plant or utility tagging conventions.']
  instrument_type varchar [note: 'Classification of the online instrument by measurement function. Defines the primary water quality parameter or operational metric the instrument monitors. [ENUM-REF-CANDIDATE: turbidimeter|chlorine_analyzer|ph_meter|toc_analyzer|uv254_sensor|flow_meter|conductivity_meter|dissolved_oxygen_analyzer|particle_counter|fluorometer|ammonia_analyzer|nitrate_analyzer|phosphate_analyzer|bod_analyzer|cod_analyzer|tss_analyzer|ozone_analyzer|pressure_transmitter|temperature_sensor — promote to reference product]']
  last_calibration_date date [note: 'Date when the instrument was most recently calibrated. Used to track calibration compliance and schedule next calibration.']
  latitude decimal(10,8) [note: 'Geographic latitude coordinate of the instrument installation location in decimal degrees. Used for mapping and spatial analysis.']
  longitude decimal(11,8) [note: 'Geographic longitude coordinate of the instrument installation location in decimal degrees. Used for mapping and spatial analysis.']
  maintenance_notes varchar [note: 'Free-text field for recording maintenance history, operational issues, calibration adjustments, or other relevant notes about the instrument\'s performance and service history.']
  measurement_parameter varchar
  measurement_range_max decimal(18,6) [note: 'Maximum value of the instrument\'s calibrated measurement range. Defines the upper detection limit for accurate readings.']
  measurement_range_min decimal(18,6) [note: 'Minimum value of the instrument\'s calibrated measurement range. Defines the lower detection limit for accurate readings.']
  measurement_unit varchar [note: 'Unit of measure for the parameter reported by the instrument (e.g., \'mg/L\', \'NTU\', \'pH units\', \'µS/cm\', \'ppm\', \'ppb\', \'GPM\', \'MGD\', \'PSI\').']
  model_number varchar [note: 'Manufacturer\'s model or part number for the instrument. Used for procurement, spare parts identification, and technical support.']
  modified_by varchar [note: 'Username or identifier of the person who most recently modified this instrument record. Used for accountability and audit trail.']
  modified_timestamp timestamp [note: 'Timestamp when this instrument record was most recently updated. Used for change tracking and data quality monitoring.']
  next_calibration_due_date date [note: 'Scheduled date for the next required calibration. Calculated from last calibration date plus calibration frequency. Used for preventive maintenance scheduling.']
  operational_status decimal(18,6) [note: 'Current operational state of the instrument. Indicates whether the instrument is actively monitoring, undergoing maintenance, or out of service.']
  pi_historian_tag varchar [note: 'Tag name in the OSIsoft PI Historian or equivalent time-series database where continuous instrument readings are stored for trending and analysis.']
  power_supply_type varchar [note: 'Type of electrical power supply used by the instrument (e.g., AC 120V, DC 24V, battery-powered, solar-powered, loop-powered from 4-20mA signal).']
  regulatory_compliance_flag boolean [note: 'Indicates whether this instrument is used for regulatory compliance monitoring and reporting (e.g., SDWA, NPDES permit requirements). True if data from this instrument is reported to regulatory agencies.']
  responsible_department varchar [note: 'Name of the department or work group responsible for maintaining and calibrating this instrument (e.g., \'Water Quality Lab\', \'Instrumentation & Controls\', \'Plant Operations\').']
  scada_tag_name varchar [note: 'Unique tag identifier in the SCADA system that receives real-time data from this instrument. Used for process control, alarming, and data historian integration.']
  serial_number varchar [note: 'Unique serial number assigned by the manufacturer to this specific instrument unit. Critical for warranty tracking and service history.']
  treatment_stage varchar [note: 'Stage in the water or wastewater treatment process where the instrument is monitoring. Critical for understanding data context and compliance requirements. [ENUM-REF-CANDIDATE: raw_water|pre_treatment|coagulation|flocculation|sedimentation|filtration|disinfection|post_treatment|distribution|wastewater_influent|primary_treatment|secondary_treatment|tertiary_treatment|effluent_discharge|sludge_processing — promote to reference product]']
  warranty_expiration_date date [note: 'Date when the manufacturer\'s warranty coverage expires. Critical for maintenance planning and budgeting.']
  created_by varchar [note: 'Username or identifier of the person who created this instrument record. Used for accountability and audit trail.']

  Note: 'Master registry of continuous online water quality monitoring instruments deployed across WTPs, WWTPs, and the distribution network. Captures instrument type (turbidimeter, chlorine analyzer, pH meter, TOC analyzer, UV254 sensor, flow meter), manufacturer, model, serial number, installation location/sampling point, calibration frequency, last calibration date, calibration standard used, communication protocol (SCADA/Modbus/HART), PI Historian tag name, and operational status. Distinct from the asset domain\'s general asset registry by focusing on quality-specific instrument metadata and calibration management.'
}

Table quality.quality_instrument_calibration {
  quality_instrument_calibration_id varchar [pk, note: 'Unique identifier for the quality_instrument_calibration data product (auto-inserted pre-linking).']
  online_instrument_id varchar [note: 'FK to online instrument']
  quality_calibrated_by_employee_id varchar
  quality_employee_id varchar [note: 'FK to responsible employee']
  acceptance_criteria varchar [note: 'Acceptance criteria']
  acceptance_criteria_pct decimal(6,2) [note: 'Acceptance criteria as percentage deviation']
  accuracy_percentage decimal(6,2)
  adjustment_description varchar [note: 'Description of adjustment']
  adjustment_made boolean [note: 'Whether adjustment was made']
  as_found_value decimal(18,2) [note: 'As-found reading value.']
  as_left_value decimal(18,2) [note: 'As-left reading value.']
  calibration_certificate_number varchar [note: 'Calibration certificate number']
  calibration_date date
  calibration_frequency_days varchar [note: 'Calibration frequency in days']
  calibration_method varchar
  calibration_number varchar [note: 'Unique calibration number']
  calibration_result varchar
  calibration_standard_used varchar
  calibration_standard_value decimal(18,2)
  calibration_status varchar [note: 'Result status (pass, fail, adjusted)']
  calibration_time timestamp [note: 'Time of calibration']
  calibration_timestamp date
  calibration_type varchar [note: 'Type (initial, routine, post-maintenance, verification)']
  corrective_action_taken varchar [note: 'Corrective action if failed']
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp
  data_quality_flag boolean [note: 'True when record passed data validation.']
  deviation varchar
  deviation_pct decimal(8,4) [note: 'Actual deviation from standard']
  deviation_percent decimal(6,2) [note: 'Deviation from standard']
  drift_pct decimal(8,4) [note: 'Drift as percentage of standard']
  drift_value decimal(18,2) [note: 'Calculated drift from standard']
  expected_value decimal(18,2) [note: 'Expected standard value']
  instrument_name varchar
  instrument_serial_number varchar [note: 'Instrument serial number']
  instrument_type varchar [note: 'Type of instrument']
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  measured_value decimal(18,2)
  measured_value_1 decimal(18,2) [note: 'Instrument reading for standard 1']
  measured_value_2 decimal(18,2) [note: 'Instrument reading for standard 2']
  measured_value_3 decimal(18,2) [note: 'Instrument reading for standard 3']
  next_calibration_date date
  next_calibration_due date [note: 'Next calibration due date.']
  next_calibration_due_date date [note: 'Next calibration due date']
  next_due_date date [note: 'Next calibration due date']
  notes varchar [note: 'Calibration notes']
  offset decimal(10,6) [note: 'Calibration curve offset/intercept']
  parameter varchar
  parameter_measured varchar [note: 'Parameter being measured']
  pass_fail_flag boolean
  pass_fail_result varchar [note: 'Overall pass/fail result']
  pass_fail_status varchar [note: 'Pass/fail determination']
  pass_flag boolean [note: 'Whether calibration passed']
  passed boolean [note: 'Whether calibration passed.']
  passed_flag boolean
  post_calibration_reading decimal(18,6) [note: 'Instrument reading after calibration']
  pre_calibration_reading decimal(18,6) [note: 'Instrument reading before calibration']
  quality_laboratory_instrument_calibration_id varchar [note: 'References the single source of truth record in laboratory.laboratory_instrument_calibration']
  quality_ssot_laboratory_instrument_calibration_laboratory_instrument_calibration_id varchar [note: 'SSOT delegation link to canonical laboratory.laboratory_instrument_calibration']
  r_squared decimal(8,6) [note: 'Correlation coefficient R-squared']
  reagent_lot_number varchar [note: 'Reagent/standard lot number']
  record_status varchar
  reference_value decimal(18,2)
  slope decimal(10,6) [note: 'Calibration curve slope']
  standard_expiration_date date [note: 'Expiration date of calibration standard']
  standard_lot_number varchar [note: 'Lot number of calibration standard used']
  standard_source varchar [note: 'Source/manufacturer of calibration standard']
  standard_used varchar [note: 'Calibration standard used']
  standard_value decimal(18,2) [note: 'Known standard value used for calibration']
  standard_value_1 decimal(18,2) [note: 'First calibration standard value']
  standard_value_2 decimal(18,2) [note: 'Second calibration standard value']
  standard_value_3 decimal(18,2) [note: 'Third calibration standard value']
  supervisor_review boolean [note: 'Whether supervisor reviewed']
  supervisor_review_date date [note: 'Date of supervisor review']
  technician_name varchar [note: 'Name of technician']
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp.']

  Note: 'Transactional record of each calibration event performed on an online or field water quality instrument. Captures calibration date/time, instrument ID, calibration type (single-point, multi-point, verification), standard solution used (concentration, lot number, expiry), pre-calibration reading, post-calibration reading, calibration factor applied, technician ID, pass/fail status, and next calibration due date. Ensures data quality and defensibility of continuous monitoring data used for regulatory compliance. [SSOT: canonical source is laboratory.laboratory_instrument_calibration; this entity is a duplicate retained for backward compatibility.]'
}

Table quality.iup_monitoring_result {
  iup_monitoring_result_id varchar [pk, note: 'Unique identifier for the industrial user pretreatment monitoring result record.']
  analytical_result_id varchar [note: 'Foreign key linking to quality.analytical_result. Business justification: IUP monitoring results are based on underlying analytical results. Currently duplicates many analytical_result attributes (result_value, detection_limit, analytical_method, etc.). Adding analytical_re']
  compliance_permit_id varchar [note: 'Identifier for the NPDES permit under which this industrial user monitoring result is reported.']
  contaminant_id varchar [note: 'Identifier for the contaminant or parameter being monitored in this result.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Industrial user monitoring costs are often recovered through IUP permit fees; cost center tracking enables cost recovery analysis, fee justification, and budget management for pretreatment program ope']
  industrial_user_id varchar [note: 'Identifier for the significant industrial user (SIU) subject to pretreatment monitoring.']
  industrial_user_permit_id varchar [note: 'Identifier for the Industrial User Permit under which this monitoring result was collected.']
  laboratory_id varchar [note: 'Identifier for the laboratory that performed the analysis.']
  primary_iup_sampler_employee_id varchar [note: 'Identifier for the utility employee who collected the sample, if utility-collected.']
  reviewer_employee_id varchar [note: 'Identifier for the utility employee who reviewed and validated the monitoring result.']
  sampling_schedule_id varchar [note: 'Foreign key linking to quality.sampling_schedule. Business justification: Industrial user permit monitoring follows pretreatment program sampling schedules for local limits and categorical standards. Links result to regulatory schedule for compliance determination, enforcem']
  special_contract_id varchar [note: 'Foreign key linking to service.special_contract. Business justification: Industrial users with special contracts often have negotiated discharge limits, monitoring frequencies, and penalty structures beyond standard IUP permits. IUP monitoring results verify compliance wit']
  water_sample_id varchar [note: 'Identifier linking this monitoring result to the water sample record in the laboratory information management system.']
  categorical_standard_value decimal(18,2) [note: 'The federal categorical pretreatment standard applicable to this industrial user category and parameter, if applicable.']
  compliance_status varchar [note: 'The compliance status of this monitoring result relative to the applicable local or categorical pretreatment limit.']
  composite_duration_hours decimal(10,2) [note: 'The duration in hours over which a composite sample was collected, if applicable.']
  created_timestamp timestamp [note: 'The timestamp when this monitoring result record was first created in the system.']
  daily_flow_mgd decimal(18,6) [note: 'The total daily flow in million gallons per day from the industrial user on the sampling date.']
  dmr_reporting_period varchar [note: 'The reporting period (e.g., 2024-Q1, 2024-03) for which this result will be included in the DMR.']
  dmr_reporting_required boolean [note: 'Indicates whether this monitoring result must be included in the utility\'s Discharge Monitoring Report to the regulatory agency.']
  enforcement_action_triggered boolean [note: 'Indicates whether this non-compliant result triggered an enforcement action against the industrial user.']
  exceedance_percentage decimal(10,2) [note: 'The percentage by which the result value exceeds the applicable limit, if non-compliant.']
  flow_rate_gpm decimal(18,3) [note: 'The flow rate in gallons per minute at the sampling point during sample collection.']
  holding_time_compliant boolean [note: 'Indicates whether the sample was analyzed within the required holding time for the parameter.']
  local_limit_unit varchar [note: 'The unit of measure for the local pretreatment limit.']
  local_limit_value decimal(18,2) [note: 'The local pretreatment limit established by the utility for this parameter under the Industrial User Permit.']
  modified_by varchar [note: 'The username or identifier of the user who last modified this monitoring result record.']
  modified_timestamp timestamp [note: 'The timestamp when this monitoring result record was last modified.']
  monitoring_type varchar [note: 'Indicates whether the sample was collected through industrial user self-monitoring, utility inspection, or third-party sampling.']
  parameter_code varchar [note: 'The standardized code for the parameter being monitored, typically aligned with EPA or state regulatory codes.']
  parameter_name varchar [note: 'The name of the parameter or contaminant being measured (e.g., Biochemical Oxygen Demand (BOD), Chemical Oxygen Demand (COD), Total Suspended Solids (TSS), heavy metals, Fats Oils and Grease (FOG), pH, specific toxics).']
  permit_limit_value decimal(18,2)
  permit_number varchar [note: 'The externally-known permit number issued to the industrial user for pretreatment compliance.']
  quality_control_status varchar [note: 'The quality control status of the analytical result, indicating whether QC checks passed.']
  remarks varchar [note: 'Additional notes or comments regarding the monitoring result, sample collection, or compliance status.']
  result_value decimal(18,2)
  sample_date date
  sample_type varchar [note: 'The type of sample collected (grab sample, composite sample, or continuous monitoring).']
  sampler_name varchar [note: 'The name of the individual who collected the sample.']
  sampling_date date [note: 'The date on which the industrial user sample was collected for pretreatment monitoring.']
  sampling_point_description varchar [note: 'Detailed description of the specific sampling location at the industrial user facility.']
  sampling_point_type varchar [note: 'The type of sampling location where the industrial user sample was collected (influent to facility, effluent from pretreatment unit, process stream, final discharge point, etc.).']
  sampling_time timestamp [note: 'The precise timestamp when the industrial user sample was collected, including time of day.']
  unit_of_measure varchar
  created_by varchar [note: 'The username or identifier of the user who created this monitoring result record.']

  Note: 'Transactional record of industrial user pretreatment monitoring results collected from significant industrial users (SIUs) under Industrial User Permits (IUPs). Captures industrial user ID, permit number, sampling date, sampling point (influent, effluent, process), parameter (BOD, COD, TSS, heavy metals, FOG, pH, specific toxics), result value, local pretreatment limit, compliance status, and self-monitoring vs. utility-collected designation. Supports pretreatment program compliance and NPDES permit reporting.'
}

Table quality.fog_monitoring_event {
  fog_monitoring_event_id varchar [pk, note: 'Unique identifier for the FOG monitoring event record.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: FOG inspection program costs (inspector time, equipment, enforcement) are tracked by cost center for program budgeting, cost recovery through fees, and rate case justification of collection system mai']
  fog_employee_id varchar [note: 'Identifier of the employee who conducted the FOG inspection.']
  grease_interceptor_id varchar [note: 'Identifier of the specific grease trap or interceptor being monitored.']
  inspector_employee_id varchar [note: 'Identifier of the employee who conducted the FOG inspection.']
  pretreatment_iup_id varchar [note: 'Foreign key linking to compliance.pretreatment_iup. Business justification: FOG monitoring events enforce pretreatment permit conditions for food service establishments (grease trap/interceptor compliance). This link connects FOG inspections to industrial user permits, essent']
  primary_establishment_fog_source_id varchar [note: 'Identifier of the food service establishment or industrial contributor being inspected.']
  quality_sampling_point_id varchar [note: 'Foreign key linking to quality.sampling_point. Business justification: FOG monitoring events occur at specific sampling locations. While fog_source_id links to the establishment (cross-domain), sampling_point_id identifies the physical monitoring location within the qual']
  water_sample_id varchar
  best_management_practices_compliant boolean [note: 'Indicates whether the establishment is following FOG best management practices.']
  bmp_deficiencies varchar [note: 'Description of any deficiencies in FOG best management practices observed.']
  compliance_status varchar [note: 'Compliance status of the establishment with local FOG ordinance requirements.']
  corrective_action_description varchar [note: 'Description of the corrective actions required to achieve compliance.']
  corrective_action_due_date date [note: 'Deadline by which the establishment must complete required corrective actions.']
  corrective_action_required boolean [note: 'Indicates whether corrective action is required to address inspection findings.']
  created_timestamp timestamp [note: 'Timestamp when this FOG monitoring event record was created in the system.']
  days_since_last_pump_out varchar [note: 'Number of days elapsed since the last pump-out service.']
  effluent_fog_concentration_mg_l decimal(10,2) [note: 'Measured concentration of FOG in the effluent discharge in milligrams per liter.']
  enforcement_action_triggered boolean [note: 'Indicates whether this inspection triggered an enforcement action due to non-compliance.']
  enforcement_action_type varchar [note: 'Type of enforcement action taken as a result of the inspection findings.']
  establishment_type varchar [note: 'Type of food service establishment or industrial contributor. [ENUM-REF-CANDIDATE: restaurant|cafeteria|food_processor|bakery|hotel|hospital|school|industrial — 8 candidates stripped; promote to reference product]']
  exceedance_flag boolean
  fog_concentration_mg_l decimal(10,3)
  grease_accumulation_depth_inches decimal(6,2) [note: 'Measured depth of accumulated fats, oils, and grease in the interceptor in inches.']
  grease_accumulation_percentage decimal(5,2) [note: 'Percentage of interceptor capacity filled with FOG accumulation.']
  inspection_date date [note: 'Date when the FOG monitoring inspection was conducted.']
  inspection_timestamp timestamp [note: 'Precise date and time when the FOG monitoring inspection was performed.']
  inspection_type varchar [note: 'Type of FOG monitoring inspection conducted.']
  inspector_notes varchar [note: 'Additional notes and observations recorded by the inspector during the FOG monitoring event.']
  interceptor_condition varchar [note: 'Physical condition assessment of the grease interceptor or trap.']
  interceptor_size_gallons decimal(10,2) [note: 'Capacity of the grease interceptor or trap in gallons.']
  last_pump_out_date date [note: 'Date when the grease interceptor was last pumped out or cleaned.']
  maintenance_issues_noted varchar [note: 'Description of any maintenance issues or deficiencies observed during the inspection.']
  modified_by varchar [note: 'User identifier of the person who last modified this record.']
  modified_timestamp timestamp [note: 'Timestamp when this FOG monitoring event record was last modified.']
  notification_sent_date date [note: 'Date when the inspection notification or report was sent to the establishment.']
  notification_sent_to_establishment boolean [note: 'Indicates whether an inspection report or notification was sent to the establishment.']
  ordinance_threshold_exceeded boolean [note: 'Indicates whether the FOG accumulation or concentration exceeded the local ordinance threshold.']
  permit_limit_mg_l decimal(10,3)
  photo_documentation_available boolean [note: 'Indicates whether photographic documentation of the inspection is available.']
  pump_out_frequency_compliant boolean [note: 'Indicates whether the establishment is compliant with the required pump-out frequency.']
  pump_out_service_provider varchar [note: 'Name of the licensed service provider who performed the last pump-out.']
  reinspection_required boolean [note: 'Indicates whether a follow-up reinspection is required to verify corrective actions.']
  reinspection_scheduled_date date [note: 'Scheduled date for the follow-up reinspection.']
  required_pump_out_frequency_days varchar [note: 'Required frequency for pump-out service as mandated by local FOG ordinance, in days.']
  sample_date date
  sso_risk_level varchar [note: 'Assessed risk level of potential sanitary sewer overflow based on FOG accumulation and discharge quality.']
  violation_code varchar [note: 'Code identifying the specific FOG ordinance violation observed during inspection.']
  violation_description varchar [note: 'Detailed description of the FOG ordinance violation identified during the inspection.']
  created_by varchar [note: 'User identifier of the person who created this record.']

  Note: 'Transactional record of Fats, Oils, and Grease (FOG) program inspections and monitoring events at food service establishments and industrial grease interceptor sites. Captures inspection date, establishment identifier, interceptor specifications (size, type), grease accumulation measurement, effluent FOG concentration (mg/L), compliance status against local FOG ordinance limits, pump-out frequency verification, maintenance condition assessment, and enforcement action triggered (warning, NOV, permit revocation). Supports FOG program management, sanitary sewer overflow (SSO) prevention, and pretreatment program reporting.'
}

Table quality.quality_corrective_action {
  quality_corrective_action_id varchar [pk, note: 'Primary key for corrective_action']
  compliance_corrective_action_id varchar [note: 'Canonical single-source-of-truth reference to compliance.compliance_corrective_action (compliance_corrective_action_id); this entity defers authoritative attribute values to that master entity.']
  exceedance_id varchar [note: 'Foreign key linking to quality.exceedance. Business justification: Quality corrective actions are often triggered by MCL exceedances. Currently has triggering_event_reference_id as a STRING. Adding exceedance_id as a typed FK establishes the proper relationship and a']
  facility_id varchar [note: 'Affected facility']
  laboratory_corrective_action_id varchar [note: 'Canonical single-source-of-truth reference to laboratory.laboratory_corrective_action (laboratory_corrective_action_id); this entity defers authoritative attribute values to that master entity.']
  quality_assigned_employee_id varchar [note: 'Employee assigned to the corrective action']
  quality_assigned_to_employee_id varchar
  quality_compliance_corrective_action_id varchar [note: 'References the single source of truth record in compliance.compliance_corrective_action']
  quality_instrument_calibration_id varchar [note: 'Foreign key linking to quality.quality_instrument_calibration. Business justification: Quality corrective actions can be triggered by instrument calibration failures or out-of-tolerance conditions. This FK links corrective actions to the specific calibration event that triggered them.']
  quality_responsible_employee_id varchar [note: 'Employee responsible for the action']
  action_date date
  action_description varchar
  action_number varchar
  action_status varchar
  action_type varchar [note: 'Type of corrective action (resample, treatment adjustment, notification, investigation)']
  actual_completion_date date [note: 'Actual completion date']
  actual_cost decimal(18,2) [note: 'Actual cost of action']
  assigned_to varchar [note: 'Person assigned to action']
  completed_date date [note: 'Date the action was completed']
  completion_date date
  corrective_action_number varchar [note: 'Corrective action reference number.']
  corrective_measure varchar
  cost_estimate decimal(18,2) [note: 'Estimated cost of action']
  cost_usd decimal(18,2) [note: 'Cost of the corrective action in USD']
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp
  data_quality_flag boolean [note: 'True when record passed data validation.']
  due_date date [note: 'Due date for completion']
  effectiveness_confirmed boolean [note: 'Whether effectiveness confirmed']
  effectiveness_rating varchar
  effectiveness_verified boolean [note: 'Whether effectiveness was verified']
  effectiveness_verified_flag boolean [note: 'Whether effectiveness was verified']
  estimated_cost decimal(18,2) [note: 'Estimated cost of action']
  estimated_cost_usd decimal(18,2)
  follow_up_date date [note: 'Scheduled follow-up date']
  follow_up_required boolean [note: 'Whether follow-up is required']
  identified_date date [note: 'Date issue identified']
  immediate_action_taken varchar [note: 'Immediate action taken']
  initiated_date date [note: 'Date the corrective action was initiated']
  initiation_date date [note: 'Date action was initiated']
  is_closed boolean
  is_complete boolean
  is_completed boolean
  is_effective boolean
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  long_term_action_planned varchar [note: 'Long-term action planned']
  notes varchar [note: 'Action notes']
  preventive_action_flag boolean [note: 'Whether preventive action was also implemented']
  preventive_action_required boolean [note: 'Whether preventive action required']
  priority varchar
  quality_corrective_action_description varchar [note: 'Description of the corrective action']
  quality_corrective_action_status varchar [note: 'Current status (open, in progress, completed, verified)']
  quality_laboratory_corrective_action_id varchar [note: 'References the single source of truth record in laboratory.laboratory_corrective_action']
  record_status varchar
  recurrence_prevention varchar [note: 'Steps to prevent recurrence']
  regulatory_deadline date [note: 'Regulatory deadline if applicable']
  regulatory_notification_date date [note: 'Date of regulatory notification']
  regulatory_notification_required boolean [note: 'Whether regulatory notification required']
  regulatory_reporting_required boolean [note: 'Whether regulatory reporting is required']
  regulatory_reporting_required_flag boolean [note: 'Whether regulatory reporting needed']
  regulatory_required boolean [note: 'Whether required by regulation']
  responsible_party varchar [note: 'Responsible party']
  root_cause varchar [note: 'Identified root cause']
  root_cause_category varchar [note: 'Root cause category']
  ssot_source_domain varchar [note: 'Indicates SSOT owner domain for corrective actions']
  state_notification_required boolean [note: 'Whether state notification is required']
  state_notified_date date [note: 'Date state was notified']
  target_completion_date date [note: 'Target completion date']
  trigger_date date [note: 'Date of trigger event']
  trigger_event varchar [note: 'Event that triggered action']
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp']
  verification_date date [note: 'Date effectiveness was verified']
  verification_flag boolean
  verification_method varchar [note: 'Method used to verify effectiveness']
  verification_required boolean [note: 'Whether verification required']

  Note: 'Operational record tracking corrective and preventive actions arising from water quality events including MCL exceedances, monitoring failures, instrument malfunctions, and process upsets. Captures triggering event reference, action type (corrective, preventive, investigative), action description, responsible party, due date, completion date, verification method, and closure status. Provides the quality management workflow layer connecting quality findings to operational response and regulatory reporting. [SSOT: governed by compliance.compliance_corrective_action] [SSOT: governed by laboratory.laboratory_corrective_action] [DEPRECATED: Single source of truth is compliance.compliance_corrective_action]'
}

Table quality.compliance_determination {
  compliance_determination_id varchar [pk, note: 'Unique identifier for the compliance_determination data product (auto-inserted pre-linking).']
  compliance_determined_by_employee_id varchar
  contaminant_id varchar [note: 'Foreign key linking to quality.contaminant. Business justification: Compliance determinations are contaminant-specific (e.g., compliance determination for lead, for TTHM, etc.). This FK identifies which contaminant the determination applies to.']
  facility_id varchar [note: 'Facility evaluated']
  reviewer_employee_id varchar [note: 'Employee who reviewed the determination']
  sampling_schedule_id varchar [note: 'Foreign key linking to quality.sampling_schedule. Business justification: Compliance determinations aggregate analytical results for a specific sampling schedule over a monitoring period. This FK links the compliance determination to the schedule being evaluated, eliminatin']
  superseded_compliance_determination_id varchar [note: 'Self-referencing FK on compliance_determination (superseded_compliance_determination_id)']
  water_system_id varchar
  action_level double [note: 'Action level if applicable']
  action_level_exceeded boolean [note: 'Whether action level was exceeded']
  approval_date date [note: 'Date of approval']
  basis varchar
  calculated_value decimal(18,2) [note: 'Calculated compliance value']
  calculation_method varchar [note: 'Calculation method used']
  compliance_basis varchar [note: 'Basis for compliance (RAA, LRAA, single sample)']
  compliance_period varchar [note: 'Compliance period identifier']
  compliance_period_end date [note: 'Compliance period end.']
  compliance_period_start date [note: 'Compliance period start.']
  compliance_status varchar
  compliance_value decimal(18,2) [note: 'Calculated compliance value (RAA, LRAA)']
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp
  data_quality_flag boolean [note: 'True when record passed data validation.']
  detection_frequency_pct decimal(5,2) [note: 'Detection frequency percentage']
  determination_basis varchar
  determination_date date
  determination_method varchar [note: 'Method used (RAA, LRAA, single sample max, etc.)']
  determination_number varchar [note: 'Unique determination number']
  determination_period_end date
  determination_period_start date
  determination_status varchar [note: 'Current determination status']
  determination_type varchar [note: 'Type of determination (MCL, treatment technique)']
  effective_date date [note: 'Effective date of determination']
  exceedance_count varchar [note: 'Number of exceedances in the period']
  in_compliance varchar
  is_compliant boolean
  is_in_compliance boolean
  is_superseded boolean
  is_violation boolean [note: 'Whether a violation occurred.']
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  limit_value decimal(18,2) [note: 'Regulatory limit value']
  locational_running_annual_average double [note: 'LRAA value if applicable']
  mcl_value decimal(18,2) [note: 'Applicable MCL for comparison']
  mclg_value decimal(18,2) [note: 'MCLG value']
  minimum_samples_required varchar [note: 'Minimum samples required']
  monitoring_period varchar
  monitoring_period_end date [note: 'End of the monitoring period evaluated']
  monitoring_period_end_date date [note: 'End of monitoring period']
  monitoring_period_start date [note: 'Start of the monitoring period evaluated']
  monitoring_period_start_date date [note: 'Start of monitoring period']
  notes varchar [note: 'Notes about the determination']
  number_of_detections varchar [note: 'Number of detections']
  number_of_samples varchar [note: 'Number of samples in determination']
  parameter_name varchar
  percentile_90_value decimal(18,2) [note: '90th percentile value (for lead/copper)']
  period_end date
  period_end_date date [note: 'Period end date']
  period_start date
  period_start_date date [note: 'Period start date']
  public_notification_required boolean [note: 'Whether public notification required']
  pwsid varchar [note: 'Public Water System ID']
  record_status varchar
  regulatory_limit double [note: 'Applicable regulatory limit']
  regulatory_rule varchar [note: 'Applicable regulatory rule']
  regulatory_standard varchar
  return_to_compliance_date date [note: 'Date returned to compliance']
  reviewer_name varchar [note: 'Name of reviewer']
  rule_citation varchar [note: 'Regulatory rule citation']
  running_annual_average decimal(18,6) [note: 'Running annual average value for the contaminant']
  running_average_value decimal(18,2)
  sample_count varchar [note: 'Number of samples in the determination period']
  samples_above_mcl varchar [note: 'Number of samples above MCL']
  single_sample_max double [note: 'Single sample maximum value']
  state_report_date date [note: 'Date reported to state']
  state_reported boolean [note: 'Whether reported to state']
  unit_of_measure varchar [note: 'Unit of measure for values']
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp.']
  violation_flag boolean
  violation_generated boolean [note: 'Whether a violation was generated']
  violation_generated_flag boolean [note: 'Whether a violation was generated from this determination']
  violation_triggered boolean
  violation_type varchar [note: 'Type of violation if applicable']

  Note: 'Period-level compliance determination record that aggregates analytical results into a formal compliance status for each contaminant group, monitoring period, and regulatory rule. Captures determination period (monthly, quarterly, annual), contaminant or contaminant group, applicable rule (SDWA, CWA, NPDES), calculation method (single sample max, running annual average, 90th percentile), calculated compliance value, applicable limit, pass/fail status, and determination date. Bridges the gap between individual analytical results and regulatory reporting by providing the formal compliance roll-up that drives CCR preparation, DMR submission, and violation determination.'
}

Table quality.qaqc_batch {
  qaqc_batch_id varchar [pk, note: 'Unique identifier for the qaqc_batch data product (auto-inserted pre-linking).']
  laboratory_id varchar [note: 'Laboratory']
  qaqc_analyst_employee_id varchar [note: 'Analyst']
  qc_batch_id varchar [note: 'Foreign key linking to laboratory.qc_batch. Business justification: Quality domain\'s QA/QC batch tracking must reference laboratory\'s QC batch for method validation and data defensibility. Regulatory audits (EPA, primacy agencies) require tracing quality results to la']
  reanalysis_qaqc_batch_id varchar [note: 'Self-referencing FK on qaqc_batch (reanalysis_qaqc_batch_id)']
  reviewer_employee_id varchar [note: 'Employee who reviewed the batch']
  water_sample_id varchar [note: 'Foreign key linking to quality.water_sample. Business justification: QA/QC batches group analytical results with their associated samples for quality control purposes. Linking to the primary water_sample in the batch establishes the in-domain relationship and eliminate']
  acceptance_criteria varchar [note: 'QA/QC acceptance criteria applied']
  acceptance_criteria_high double [note: 'Upper acceptance limit']
  acceptance_criteria_low double [note: 'Lower acceptance limit']
  acceptance_criteria_met boolean [note: 'Whether all QA/QC acceptance criteria were met']
  acceptance_status varchar
  affected_sample_count varchar [note: 'Number of samples affected by QC failure']
  analysis_date date [note: 'Date of analysis']
  analysis_method varchar
  analyst_name varchar [note: 'Name of analyst']
  analytical_method varchar [note: 'Analytical method used for the batch']
  batch_acceptance_status varchar
  batch_date date
  batch_number varchar
  batch_status varchar
  batch_type varchar [note: 'Type of QA/QC batch']
  blank_contamination_detected boolean [note: 'Whether contamination was detected in blanks']
  blank_count varchar
  blank_result decimal(18,6) [note: 'Method blank result.']
  blank_result_acceptable boolean [note: 'Whether method blank results were acceptable']
  blank_result_acceptable_flag boolean [note: 'Whether blank results are acceptable']
  corrective_action_description varchar [note: 'Description of corrective action']
  corrective_action_required boolean [note: 'Whether corrective action is needed']
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp
  data_quality_flag boolean [note: 'True when record passed data validation.']
  data_usability varchar [note: 'Data usability determination']
  data_usability_flag boolean [note: 'Data usability determination']
  duplicate_count varchar
  duplicate_rpd decimal(6,2) [note: 'Duplicate RPD']
  duplicate_rpd_pct decimal(8,4) [note: 'Relative percent difference for duplicates']
  duplicate_rsd_acceptable_flag boolean [note: 'Whether duplicate RSD is acceptable']
  expected_value decimal(18,2) [note: 'Expected/true value']
  is_accepted boolean
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  lcs_acceptable boolean [note: 'Whether LCS is acceptable']
  lcs_recovery_pct decimal(6,2) [note: 'LCS recovery percentage']
  lcsd_recovery_pct decimal(6,2) [note: 'LCSD recovery percentage']
  lcsd_rpd decimal(6,2) [note: 'LCS/LCSD relative percent difference']
  measured_value decimal(18,2) [note: 'Measured value']
  method_blank_acceptable boolean [note: 'Whether method blank is acceptable']
  method_blank_result double [note: 'Method blank result']
  method_code varchar [note: 'Analytical method code']
  ms_acceptable boolean [note: 'Whether MS acceptable']
  ms_msd_rpd decimal(6,2) [note: 'MS/MSD relative percent difference']
  ms_recovery_pct decimal(6,2) [note: 'Matrix spike recovery percentage']
  msd_recovery_pct decimal(6,2) [note: 'Matrix spike duplicate recovery']
  notes varchar [note: 'Batch notes']
  overall_qc_pass_flag boolean [note: 'Overall QC pass/fail']
  overall_qc_status varchar [note: 'Overall QC status']
  parameter_group varchar [note: 'Parameter group analyzed']
  parameter_name varchar [note: 'Parameter being QC checked']
  pass_fail_result varchar [note: 'Pass/fail result']
  pass_fail_status varchar [note: 'Overall pass/fail determination']
  pass_flag boolean
  passed_qc varchar
  percent_recovery decimal(5,2)
  qc_acceptance_flag boolean [note: 'Whether the batch met QC acceptance criteria.']
  qc_acceptance_status varchar
  qc_notes varchar
  qc_pass_flag boolean
  qc_pass_rate double [note: 'Qc pass rate']
  qc_pass_rate_pct decimal(6,2)
  qc_sample_count varchar [note: 'Number of QC samples']
  qc_type varchar
  reanalysis_date date [note: 'Date of reanalysis']
  reanalysis_required boolean [note: 'Whether reanalysis is required.']
  record_status varchar
  recovery_pct decimal(9,4)
  recovery_percent decimal(10,4) [note: 'Spike recovery percent']
  relative_percent_difference decimal(5,2)
  requires_reanalysis boolean
  review_date date [note: 'Date the batch was reviewed']
  reviewer_name varchar [note: 'QC reviewer name']
  rpd_acceptable boolean [note: 'Whether RPD acceptable']
  rpd_pct decimal(10,4)
  rpd_value decimal(18,2) [note: 'Relative percent difference']
  sample_count varchar [note: 'Number of samples in the batch']
  spike_count varchar
  spike_recovery_acceptable_flag boolean [note: 'Whether spike recovery is acceptable']
  spike_recovery_pct decimal(8,4) [note: 'Matrix spike recovery percentage']
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp.']

  Note: 'Quality assurance and quality control batch record grouping analytical results with their associated QC samples (method blanks, laboratory control samples, matrix spikes, duplicates, surrogate recoveries). Captures batch ID, analytical method, analysis date, QC acceptance criteria, batch-level pass/fail status, corrective action if failed, and data usability assessment. Essential for defending analytical data quality during regulatory audits and ensuring results meet method-specific precision and accuracy requirements. SSOT: Extends laboratory.qc_batch with field QA/QC context for water quality monitoring; laboratory.qc_batch is canonical for laboratory analytical QC.'
}

Table quality.territory_contaminant_monitoring_requirement {
  territory_contaminant_monitoring_requirement_id varchar [pk, note: 'Primary key for the territory_contaminant_monitoring_requirement association']
  contaminant_id varchar [note: 'Foreign key linking to the contaminant being monitored in this territory']
  regulatory_requirement_id varchar
  sampling_schedule_id varchar [note: 'Foreign key linking to quality.sampling_schedule. Business justification: Territory-specific contaminant monitoring requirements drive the creation and configuration of sampling schedules. This FK links the requirement to the schedule(s) that implement it, enabling tracking']
  territory_id varchar [note: 'Foreign key linking to the service territory where monitoring requirements apply']
  active_flag boolean
  compliance_notes varchar [note: 'Free-text notes documenting the rationale for territory-specific requirements, variance conditions, or special monitoring instructions from the primacy agency.']
  created_timestamp timestamp
  effective_date date [note: 'Date when this territory-specific monitoring requirement, variance, or action level became effective. Critical for compliance tracking and historical regulatory reporting.']
  expiration_date date [note: 'Date when this territory-specific monitoring requirement, variance, or exemption expires and reverts to standard requirements. Null if permanent. Essential for proactive compliance management.']
  jurisdiction varchar
  local_action_level decimal(18,6) [note: 'Action level specific to this territory that may differ from the federal standard due to state primacy agency requirements or local conditions. Exists because state agencies with primacy can set more stringent requirements than federal MCLs.']
  monitoring_frequency varchar
  monitoring_frequency_override varchar [note: 'Territory-specific monitoring frequency that overrides the default contaminant monitoring_frequency_code based on primacy agency approval, vulnerability assessment results, or granted waivers. This attribute exists because different territories may have different monitoring requirements for the same contaminant.']
  primacy_agency_override varchar [note: 'Identification of the specific primacy agency (state or EPA regional office) that issued the territory-specific requirement or variance. Necessary because different territories may fall under different primacy jurisdictions.']
  samples_required_per_period varchar
  territory_specific_mcl decimal(18,6) [note: 'Maximum contaminant level specific to this territory, typically more stringent than federal MCL when set by state primacy agencies. This attribute captures jurisdiction-specific regulatory limits that vary by territory.']
  variance_approval_number varchar [note: 'Official reference number of the variance, waiver, or exemption approval issued by the primacy agency. Used for regulatory correspondence and audit trail.']
  variance_status varchar [note: 'Current status of any monitoring variance, waiver, or exemption granted by the primacy agency for this contaminant in this territory. Tracks whether the utility has been granted relief from standard monitoring requirements.']
  vulnerability_assessment_result varchar [note: 'Result of source water vulnerability assessment for this contaminant in this territory. Determines eligibility for monitoring waivers and reduced frequency. This is territory-specific because vulnerability depends on local source water characteristics.']

  Note: 'This association product represents the territory-specific monitoring requirements and regulatory variances between contaminants and service territories. It captures jurisdiction-specific monitoring frequencies, action levels, and variance statuses that exist only in the context of a specific contaminant being monitored within a specific service territory. Each record links one contaminant to one service territory with regulatory override attributes that reflect primacy agency decisions, vulnerability assessments, and approved variances.. Existence Justification: In water utility operations, contaminants have different monitoring requirements across service territories based on primacy agency jurisdiction, source water vulnerability assessments, and approved regulatory variances. A single contaminant (e.g., lead) may require quarterly monitoring in one territory but have a waiver for reduced frequency in another territory based on vulnerability assessment results. Conversely, a single service territory must track territory-specific monitoring requirements, action levels, and variance statuses for dozens of regulated contaminants. This is an operational compliance management relationship that utilities actively maintain.'
}

Table quality.monitoring_context {
  monitoring_context_id varchar [pk, note: 'Primary key for monitoring_context']
  parent_monitoring_context_id varchar [note: 'Self-referencing FK on monitoring_context (parent_monitoring_context_id)']
  water_system_id varchar
  context_name varchar
  context_type varchar [note: 'Category of the monitoring context indicating the water system segment it applies to.']
  created_timestamp timestamp [note: 'Timestamp when the monitoring context record was first created in the system.']
  data_quality_flag boolean [note: 'Indicator of the quality and reliability of the data collected under this context.']
  effective_date date
  effective_end_date date [note: 'Date when the monitoring context expires or is retired (null if open‑ended).']
  effective_start_date date [note: 'Date when the monitoring context becomes effective.']
  geographic_region varchar [note: 'Three‑letter ISO country code representing the region of the monitoring location.']
  jurisdiction varchar
  location_code varchar [note: 'Code identifying the physical location (e.g., treatment plant, reservoir, distribution node) where monitoring occurs.']
  measurement_parameter varchar [note: 'Water quality parameter measured in this context (e.g., pH, turbidity, chlorine, BOD, COD, TSS, TDS, TOC, DBP, PFAS). [ENUM-REF-CANDIDATE: pH|turbidity|temperature|chlorine|conductivity|BOD|COD|TSS|TDS|TOC|DBP|PFAS — promote to reference product]']
  monitoring_context_code varchar [note: 'Unique business code used to reference the monitoring context in operational systems.']
  monitoring_context_name varchar [note: 'Human‑readable name describing the monitoring context.']
  monitoring_context_status varchar [note: 'Current lifecycle status of the monitoring context.']
  notes varchar [note: 'Free‑form comments or additional information about the monitoring context.']
  regulatory_limit_unit varchar [note: 'Unit associated with the regulatory limit value.']
  regulatory_limit_value decimal(18,2) [note: 'Maximum allowable value for the measurement parameter as defined by regulatory standards.']
  regulatory_program varchar
  sampling_frequency varchar [note: 'How often samples are collected for this monitoring context.']
  sampling_method varchar [note: 'Technique used to obtain water samples.']
  unit_of_measure varchar [note: 'Unit used for the measurement parameter (e.g., mg/L, NTU, pH units, µg/L).']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the monitoring context record.']

  Note: 'Master reference table for monitoring_context. Referenced by monitoring_context_id.'
}

Table quality.sampling_round {
  sampling_round_id varchar [pk, note: 'Primary key for sampling_round']
  certified_analyst_id varchar [note: 'Identifier of the laboratory analyst responsible for processing the samples.']
  facility_id varchar [note: 'Identifier of the water facility or site where the sampling round is performed.']
  parent_sampling_round_id varchar [note: 'Self-referencing FK on sampling_round (parent_sampling_round_id)']
  sampling_plan_id varchar [note: 'Reference to the predefined sampling plan governing this round.']
  sampling_schedule_id varchar
  completion_flag boolean
  compliance_status varchar [note: 'Regulatory compliance outcome for the round.']
  created_timestamp timestamp [note: 'Timestamp when the sampling round record was first created in the system.']
  end_timestamp timestamp [note: 'Exact end time of the sampling activities.']
  event_timestamp timestamp [note: 'Date‑time when the sampling round was executed or is scheduled to occur.']
  is_emergency boolean [note: 'Indicates whether the round was initiated as an emergency response.']
  mcl_exceedance_flag boolean [note: 'True if any measured parameter exceeds its MCL for the round.']
  notes varchar [note: 'Free‑form comments entered by field staff.']
  parameters_measured varchar [note: 'Comma‑separated list of water quality parameters (e.g., pH, turbidity, lead) measured in this round.']
  round_code varchar [note: 'External code used by field crews and regulators to reference the sampling round.']
  round_end_date date
  round_name varchar [note: 'Human‑readable name or description of the sampling round.']
  round_number varchar
  round_start_date date
  round_status varchar
  sample_type varchar [note: 'Category of water being sampled.']
  samples_collected_count varchar
  samples_required_count varchar
  sampling_method varchar [note: 'Technique used to collect the water sample.']
  sampling_round_status varchar [note: 'Current lifecycle state of the sampling round.']
  scheduled_date date [note: 'Planned calendar date for the sampling round.']
  start_timestamp timestamp [note: 'Exact start time of the sampling activities.']
  total_samples_collected varchar [note: 'Number of samples actually collected during the round.']
  total_samples_expected varchar [note: 'Number of individual samples planned for the round.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the sampling round record.']
  weather_conditions varchar [note: 'Brief description of weather during sampling (e.g., sunny, rain).']

  Note: 'Master reference table for sampling_round. Referenced by sampling_round_id.'
}

Table quality.contaminant_group {
  contaminant_group_id varchar [pk, note: 'Primary key for contaminant_group']
  parent_contaminant_group_id varchar [note: 'Self-referencing FK on contaminant_group (parent_contaminant_group_id)']
  active_flag boolean
  applicable_standards varchar [note: 'List of standards, guidelines, or regulations that apply to this contaminant group (e.g., EPA MCL, WHO guidelines).']
  contaminant_category varchar [note: 'Broad classification of the contaminant group.']
  contaminant_group_description varchar [note: 'Detailed description of the contaminant group, its relevance and typical usage.']
  created_timestamp timestamp [note: 'Timestamp when the record was first inserted into the lakehouse.']
  effective_from date [note: 'Date when the contaminant group definition became effective.']
  effective_until date [note: 'Date when the contaminant group definition expires or is superseded (null if indefinite).']
  group_code varchar [note: 'Short alphanumeric code used to reference the contaminant group in systems and reports.']
  group_name varchar [note: 'Human‑readable name of the contaminant group (e.g., Disinfection By‑Products).']
  group_type varchar
  health_effects_summary varchar [note: 'Brief summary of known health impacts associated with exposure to the contaminant group.']
  is_active boolean [note: 'Indicates whether the contaminant group is currently in active use within the system.']
  max_contaminant_level decimal(10,3) [note: 'Regulatory maximum allowable concentration for the contaminant group.']
  max_contaminant_level_goal decimal(10,3) [note: 'Health‑based goal concentration for the contaminant group (non‑enforceable).']
  monitoring_frequency_days varchar [note: 'Recommended number of days between routine monitoring events for this contaminant group.']
  regulatory_program varchar
  regulatory_status varchar [note: 'Current regulatory status of the contaminant group under federal or state law.']
  risk_level varchar [note: 'Overall risk classification based on toxicity, prevalence, and regulatory concern.']
  typical_concentration_range_high decimal(10,3) [note: 'Upper bound of typical observed concentration range for the contaminant group.']
  typical_concentration_range_low decimal(10,3) [note: 'Lower bound of typical observed concentration range for the contaminant group.']
  typical_sources varchar [note: 'Common natural or anthropogenic sources of the contaminants in this group.']
  unit_of_measure varchar [note: 'Standard unit used for reporting concentrations of this contaminant group.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the record.']

  Note: 'Master reference table for contaminant_group. Referenced by contaminant_group_id.'
}

Table quality.water_system {
  water_system_id varchar [pk, note: 'Primary key for water_system']
  parent_water_system_id varchar [note: 'Self-referencing FK on water_system (parent_water_system_id)']
  territory_id varchar
  active_flag boolean
  average_daily_consumption_mgd decimal(10,2) [note: 'Average daily water consumption served by the system.']
  average_daily_production_mgd decimal(10,2) [note: 'Average daily water production volume.']
  capacity_mgd decimal(10,2) [note: 'Maximum designed water flow capacity.']
  chlorine_residual_mg_l decimal(6,2) [note: 'Typical residual chlorine concentration.']
  classification varchar [note: 'Ownership and governance classification of the water system.']
  commissioning_date date [note: 'Date when the water system entered service.']
  compliance_status varchar [note: 'Current compliance status with water quality regulations.']
  construction_date date [note: 'Date when construction of the water system was completed.']
  created_timestamp timestamp [note: 'Timestamp when the water system record was created.']
  decommission_date date [note: 'Date when the water system was retired, if applicable.']
  is_active boolean [note: 'Indicates whether the water system is currently active in the system.']
  last_inspection_date date [note: 'Date of the most recent regulatory inspection.']
  latitude decimal(9,6) [note: 'Geographic latitude coordinate.']
  location_city varchar [note: 'City where the water system is located.']
  location_state varchar [note: 'State or province of the water system location.']
  longitude decimal(9,6) [note: 'Geographic longitude coordinate.']
  maintenance_schedule varchar [note: 'Textual description of routine maintenance schedule (e.g., quarterly, annual).']
  mean_time_between_failures_hours decimal(10,2) [note: 'Average operational hours between failures.']
  mean_time_to_repair_hours decimal(10,2) [note: 'Average time to repair a failure.']
  next_inspection_due date [note: 'Scheduled date for the next inspection.']
  number_of_units varchar [note: 'Count of major equipment units within the system (e.g., pumps, filters).']
  owner_organization varchar [note: 'Name of the organization that owns the water system.']
  permit_expiry_date date [note: 'Expiration date of the regulatory permit.']
  permit_number varchar [note: 'Identifier of the regulatory permit governing the water system.']
  ph_range varchar [note: 'Typical pH range of output water (e.g., 6.5-8.5).']
  population_served varchar
  primacy_agency varchar
  primary_source_type varchar
  pwsid varchar
  source_type varchar [note: 'Primary source of raw water for the system.']
  system_code varchar [note: 'Unique alphanumeric code assigned to the water system.']
  system_name varchar
  system_type varchar [note: 'Category of the water system based on function.']
  total_coliforms_cfu_100ml decimal(8,2) [note: 'Typical total coliform count.']
  treatment_processes varchar [note: 'Comma-separated list of treatment processes applied (e.g., coagulation, filtration, disinfection).']
  turbidity_ntu decimal(6,2) [note: 'Typical turbidity measurement in Nephelometric Turbidity Units.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the record.']
  water_quality_category varchar [note: 'Classification of water quality produced.']
  water_system_name varchar [note: 'Human readable name of the water system.']
  water_system_status varchar [note: 'Current operational status of the water system.']

  Note: 'Master reference table for water_system. Referenced by water_system_id.'
}

Table quality.quality_prediction_event {
  quality_prediction_event_id varchar [pk, note: 'Unique identifier for the prediction event']
  actual_label varchar [note: 'Actual categorical label (for classification models)']
  actual_value decimal(18,2) [note: 'The actual observed value (null if not yet observed)']
  confidence double [note: 'Model confidence (alternative representation)']
  confidence_score decimal(5,4) [note: 'Model confidence score (0.0 to 1.0)']
  created_timestamp timestamp [note: 'Timestamp when the record was created']
  error_metric double [note: 'Calculated error metric (e.g., MAE, RMSE, MAPE) when actual value is available']
  error_value decimal(18,2) [note: 'Absolute error value']
  evaluated_at timestamp [note: 'Timestamp when the prediction was evaluated']
  evaluation_timestamp timestamp [note: 'When the actual value was observed and the prediction was evaluated']
  feature_set_version varchar [note: 'Version of the feature set used for prediction']
  feature_vector_json varchar [note: 'JSON representation of the feature vector used for prediction']
  is_actual_recorded boolean [note: 'Flag indicating if the actual value has been recorded']
  is_anomaly boolean [note: 'Flag indicating if the prediction detected an anomaly']
  lower_bound double [note: 'Lower confidence interval bound']
  model_name varchar [note: 'Name of the ML model (e.g., PFAS_Breakthrough_LSTM, Demand_Forecast_ARIMA, Leak_Detection_RandomForest)']
  model_type varchar [note: 'Type/class of ML model (e.g., LSTM, RandomForest, ARIMA, XGBoost)']
  model_version varchar [note: 'Version identifier of the model (e.g., v2.3.1)']
  notes varchar [note: 'Additional notes or metadata about the prediction']
  predicted_at timestamp [note: 'Timestamp when the prediction was made']
  predicted_label varchar [note: 'Predicted categorical label (for classification models)']
  predicted_value decimal(18,2) [note: 'The value predicted by the model']
  prediction_horizon varchar [note: 'Time horizon of the prediction (e.g., 1h, 24h, 7d)']
  prediction_status varchar [note: 'Status of the prediction (pending, confirmed, refuted, expired)']
  prediction_timestamp timestamp [note: 'When the prediction was generated']
  prediction_type varchar [note: 'Type of prediction (e.g., breakthrough, demand, leak, failure, exceedance)']
  scored_at timestamp [note: 'Timestamp when the model scored the prediction']
  subject_entity_ref varchar [note: 'ID of the entity being predicted (polymorphic reference)']
  subject_entity_type varchar [note: 'Type of entity being predicted (e.g., contaminant, meter, pipe, demand_zone)']
  target_domain varchar [note: 'Domain of the target entity']
  target_entity varchar [note: 'Name of the target entity']
  target_entity_key varchar [note: 'Primary key of the target entity']
  target_entity_ref varchar [note: 'ID of target entity (alternative naming)']
  target_entity_type varchar [note: 'Type of target entity (alternative naming)']
  training_run_ref varchar [note: 'Identifier of the training run that produced this model']
  unit_of_measure varchar [note: 'Unit of measure for predicted/actual values']
  upper_bound double [note: 'Upper confidence interval bound']

  Note: 'Generic ML/AI prediction event capturing predicted vs actual values, confidence, and model metadata for use across water utility operations (PFAS breakthrough, demand forecasting, leak detection, etc.)'
}

Table quality.pfas_compound_master {
  pfas_compound_master_id varchar [pk, note: 'Primary key for pfas_compound_master']
  parent_pfas_compound_id varchar [note: 'Self-referencing FK on pfas_compound_master (parent_pfas_compound_id)']
  action_level_ppt decimal(12,6) [note: 'Concentration threshold in parts per trillion (ppt) at which regulatory or operational action is required for this PFAS compound. May differ from MCL and represent a lower trigger for investigation or response.']
  active_flag boolean [note: 'Indicates whether this PFAS compound master record is currently active and should be used for monitoring, compliance, and reporting purposes.']
  analytical_method_reference varchar [note: 'Standard analytical method(s) used for laboratory detection and quantification of this PFAS compound (e.g., EPA Method 533, EPA Method 537.1, EPA Method 1633, ISO 21675).']
  bioaccumulation_potential varchar [note: 'Assessment of the PFAS compound\'s potential to bioaccumulate in living organisms and food chains (high, moderate, low, negligible).']
  carbon_chain_length varchar [note: 'Number of carbon atoms in the perfluorinated carbon chain of the PFAS compound.']
  carcinogenicity_classification varchar [note: 'Cancer risk classification for the PFAS compound based on available toxicological evidence (known carcinogen, probable carcinogen, possible carcinogen, not classifiable, not carcinogenic).']
  cas_number varchar [note: 'Unique CAS registry number assigned to the PFAS compound for global chemical identification.']
  chain_length_category varchar [note: 'Classification of the PFAS compound based on carbon chain length: long-chain (C8 or greater for carboxylates, C6 or greater for sulfonates), short-chain (C4-C7 for carboxylates, C4-C5 for sulfonates), or ultra-short-chain (C3 or less).']
  common_sources varchar [note: 'Description of common sources of this PFAS compound in the environment (e.g., firefighting foam, industrial discharge, consumer products, landfill leachate, wastewater treatment plant effluent).']
  compound_abbreviation varchar [note: 'Standard abbreviation or acronym for the PFAS compound (e.g., PFOA, PFOS, PFNA, PFHxS, PFBS, HFPO-DA, GenX).']
  compound_class varchar [note: 'Chemical classification category of the PFAS compound (e.g., perfluoroalkyl acid, polyfluoroalkyl substance, perfluoroalkyl sulfonate, perfluoroalkyl carboxylate, fluorotelomer, perfluoroether).']
  compound_name varchar [note: 'Full chemical name of the PFAS compound (e.g., Perfluorooctanoic Acid, Perfluorooctane Sulfonic Acid, Perfluorononanoic Acid, Perfluorohexane Sulfonic Acid, Perfluorobutane Sulfonic Acid, Hexafluoropropylene Oxide Dimer Acid).']
  created_timestamp timestamp [note: 'Timestamp when this PFAS compound master record was first created in the system.']
  effective_date date [note: 'Date when this PFAS compound master record became effective for use in monitoring and compliance programs.']
  endocrine_disruption_flag boolean [note: 'Indicates whether the PFAS compound is known or suspected to disrupt endocrine system function.']
  eu_individual_limit_value decimal(12,6) [note: 'EU individual parametric value for the PFAS compound in drinking water, expressed in nanograms per liter (ng/L). Null if no individual limit is established.']
  eu_regulated_flag boolean [note: 'Indicates whether the PFAS compound is regulated under European Union Drinking Water Directive or REACH regulations.']
  eu_sum_of_20_inclusion_flag boolean [note: 'Indicates whether this PFAS compound is included in the EU sum-of-20 PFAS parameter for drinking water compliance (total limit 100 ng/L for sum of 20 specified PFAS compounds).']
  eu_total_pfas_inclusion_flag boolean [note: 'Indicates whether this PFAS compound is included in the EU total PFAS parameter for drinking water compliance (total limit 500 ng/L for sum of all PFAS).']
  expiration_date date [note: 'Date when this PFAS compound master record expires or is superseded. Null if currently active with no planned expiration.']
  functional_group varchar [note: 'Primary functional group present in the PFAS compound structure (e.g., carboxylic acid, sulfonic acid, sulfonamide, alcohol, ether).']
  hazard_index_inclusion_flag boolean [note: 'Indicates whether this PFAS compound is included in the US EPA hazard index calculation for mixtures (e.g., PFNA, PFHxS, PFBS, HFPO-DA are included in the hazard index with a combined limit of 1).']
  hazard_index_weight decimal(8,6) [note: 'Weighting factor applied to this PFAS compound concentration when calculating the cumulative hazard index for PFAS mixtures. Null if compound is not included in hazard index.']
  immunotoxicity_flag boolean [note: 'Indicates whether the PFAS compound has documented immune system toxicity concerns based on scientific studies.']
  industrial_use_applications varchar [note: 'Description of industrial and commercial applications where this PFAS compound has been or is currently used (e.g., surface coatings, firefighting foam, textile treatments, food packaging).']
  last_updated_timestamp timestamp [note: 'Timestamp when this PFAS compound master record was most recently updated or modified.']
  molecular_formula varchar [note: 'Chemical molecular formula of the PFAS compound (e.g., C8HF15O2 for PFOA).']
  molecular_weight decimal(10,4) [note: 'Molecular weight of the PFAS compound expressed in grams per mole (g/mol).']
  monitoring_frequency_requirement varchar [note: 'Required monitoring frequency for this PFAS compound under applicable drinking water regulations (quarterly, semi-annual, annual, triennial, as needed, not required).']
  persistence_classification varchar [note: 'Classification of the PFAS compound based on environmental persistence and resistance to degradation (extremely persistent, highly persistent, persistent, moderately persistent).']
  phase_out_date date [note: 'Date when production or use of this PFAS compound was phased out or banned, if applicable.']
  precursor_compound_flag boolean [note: 'Indicates whether this PFAS compound is a precursor that can transform into other PFAS compounds through environmental or biological processes.']
  production_status varchar [note: 'Current production and use status of the PFAS compound (currently produced, phased out, restricted, banned, legacy compound no longer in production).']
  public_notification_trigger_flag boolean [note: 'Indicates whether detection of this PFAS compound above regulatory limits triggers mandatory public notification requirements.']
  replacement_compounds varchar [note: 'List of alternative PFAS or non-PFAS compounds that have been used as replacements for this compound in industrial applications.']
  reproductive_toxicity_flag boolean [note: 'Indicates whether the PFAS compound has documented reproductive or developmental toxicity concerns based on scientific studies.']
  state_regulation_notes varchar [note: 'Free-text notes documenting state-specific regulatory limits or requirements for this PFAS compound (e.g., California, Michigan, New Jersey, Vermont have state-specific PFAS limits that may differ from federal standards).']
  toxicity_classification varchar [note: 'Classification of known or suspected human health toxicity concerns for the PFAS compound (high concern, moderate concern, low concern, insufficient data).']
  transformation_products varchar [note: 'List of PFAS compounds that this compound can transform into through degradation, metabolism, or environmental processes.']
  treatment_removal_efficiency_gac decimal(5,2) [note: 'Typical removal efficiency percentage for this PFAS compound using granular activated carbon (GAC) treatment technology under standard operating conditions.']
  treatment_removal_efficiency_ix decimal(5,2) [note: 'Typical removal efficiency percentage for this PFAS compound using ion exchange (IX) treatment technology under standard operating conditions.']
  treatment_removal_efficiency_ro decimal(5,2) [note: 'Typical removal efficiency percentage for this PFAS compound using reverse osmosis (RO) or nanofiltration treatment technology under standard operating conditions.']
  treatment_response_trigger_flag boolean [note: 'Indicates whether detection of this PFAS compound above specified action levels triggers mandatory treatment system response or operational changes.']
  typical_detection_limit_ppt decimal(12,6) [note: 'Typical laboratory method detection limit for this PFAS compound, expressed in parts per trillion (ppt) or nanograms per liter (ng/L).']
  typical_quantitation_limit_ppt decimal(12,6) [note: 'Typical laboratory method quantitation limit (reporting limit) for this PFAS compound, expressed in parts per trillion (ppt) or nanograms per liter (ng/L).']
  ucmr_cycle_number varchar [note: 'UCMR cycle number in which this PFAS compound was or is being monitored (e.g., UCMR 3, UCMR 4, UCMR 5).']
  ucmr_inclusion_flag boolean [note: 'Indicates whether this PFAS compound is included in the current US EPA Unregulated Contaminant Monitoring Rule (UCMR) for occurrence monitoring in public water systems.']
  us_epa_health_advisory_level decimal(12,6) [note: 'US EPA interim health advisory level for the PFAS compound in drinking water, expressed in parts per trillion (ppt) or nanograms per liter (ng/L). Used when formal MCL has not been established.']
  us_epa_mcl_value decimal(12,6) [note: 'US EPA enforceable maximum contaminant level for the PFAS compound in drinking water, expressed in parts per trillion (ppt) or nanograms per liter (ng/L). Null if no individual MCL is established.']
  us_epa_mclg_value decimal(12,6) [note: 'US EPA non-enforceable health-based maximum contaminant level goal for the PFAS compound in drinking water, expressed in parts per trillion (ppt) or nanograms per liter (ng/L). Null if no MCLG is established.']
  us_epa_regulated_flag boolean [note: 'Indicates whether the PFAS compound is currently regulated by the US EPA under the Safe Drinking Water Act or other federal regulations.']

  Note: 'Master reference table for pfas_compound_master. Referenced by pfas_compound_id.'
}

Table laboratory.lab_sample {
  lab_sample_id varchar [pk, note: 'Unique identifier for the laboratory sample record.']
  cip_project_id varchar [note: 'Link to capital improvement project if sample is part of project commissioning or validation.']
  collection_point_id varchar [note: 'Service point where sample was collected.']
  cost_center_id varchar [note: 'Cost center responsible for sample analysis costs.']
  dma_id varchar [note: 'DMA where sample was collected.']
  hydrant_id varchar [note: 'Hydrant where sample was collected.']
  lab_employee_id varchar [note: 'Employee who logged or received the sample.']
  lab_sampler_employee_id varchar [note: 'Employee who collected the sample.']
  lab_work_order_id varchar [note: 'Work order authorizing the sample analysis.']
  meter_installation_id varchar [note: 'Meter installation where sample was collected.']
  metering_dma_zone_id varchar [note: 'Metering DMA zone where sample was collected.']
  pipe_main_id varchar [note: 'Pipe main where sample was collected.']
  pressure_zone_id varchar [note: 'Pressure zone where sample was collected.']
  qc_batch_id varchar [note: 'Quality control batch to which this sample belongs.']
  sample_collection_event_id varchar [note: 'Collection event that produced this sample.']
  sampling_location_id varchar [note: 'Sampling location where sample was collected.']
  service_address_id varchar [note: 'Service address where sample was collected.']
  storage_tank_id varchar [note: 'Storage tank where sample was collected.']
  vendor_id varchar [note: 'External laboratory vendor if sample was sent out for analysis.']
  analysis_requested varchar [note: 'Comma-separated list of analyses requested for this sample.']
  chain_of_custody_number varchar [note: 'Chain of custody document number.']
  comments varchar [note: 'Additional comments or notes about the sample.']
  compliance_program varchar [note: 'Regulatory compliance program (e.g., SDWA, NPDES, UCMR).']
  composite_end_datetime timestamp [note: 'End timestamp for composite sample collection.']
  composite_interval_minutes varchar [note: 'Interval in minutes between composite sample aliquots.']
  composite_start_datetime timestamp [note: 'Start timestamp for composite sample collection.']
  container_type varchar [note: 'Type of container used (e.g., glass, plastic, sterile).']
  container_volume_ml decimal(10,2) [note: 'Volume of the sample container in milliliters.']
  created_timestamp timestamp [note: 'Timestamp when the sample record was created.']
  disposal_date date [note: 'Date when the sample was disposed of.']
  disposal_method varchar [note: 'Method used to dispose of the sample.']
  field_chlorine_residual_mg_l decimal(6,3) [note: 'Chlorine residual measured in the field at time of collection.']
  field_ph decimal(4,2) [note: 'pH measured in the field at time of collection.']
  field_temperature_c decimal(5,2) [note: 'Temperature in Celsius measured in the field at time of collection.']
  holding_time_expiry_datetime timestamp [note: 'Datetime when the sample holding time expires.']
  logged_datetime timestamp [note: 'Datetime when the sample was logged into the LIMS.']
  modified_timestamp timestamp [note: 'Timestamp when the sample record was last modified.']
  preservation_method varchar [note: 'Method used to preserve the sample (e.g., acidification, refrigeration).']
  priority varchar [note: 'Priority level for sample analysis (e.g., routine, urgent, emergency).']
  qc_level varchar [note: 'Quality control level required for this sample.']
  received_datetime timestamp [note: 'Datetime when the sample was received by the laboratory.']
  sample_condition varchar [note: 'Condition of the sample upon receipt (e.g., acceptable, damaged, temperature exceedance).']
  sample_condition_notes varchar [note: 'Additional notes about sample condition.']
  sample_matrix varchar [note: 'Matrix type (e.g., drinking water, wastewater, groundwater, soil).']
  sample_number varchar [note: 'Unique sample number assigned by the laboratory.']
  sample_origin varchar [note: 'Origin of the sample (e.g., distribution system, treatment plant, source water).']
  sample_status varchar [note: 'Current status of the sample (e.g., pending, in progress, completed, cancelled).']
  sample_temperature_c decimal(5,2) [note: 'Temperature of the sample upon receipt in Celsius.']
  sample_type varchar [note: 'Type of sample (e.g., grab, composite, duplicate, blank).']
  sample_volume_ml decimal(10,2) [note: 'Volume of the sample in milliliters.']
  turnaround_time_hours varchar [note: 'Required turnaround time for sample analysis in hours.']

  Note: 'Laboratory sample record capturing sample metadata, collection details, chain of custody, preservation, holding time, and analysis requests for drinking water, wastewater, and environmental compliance testing.'
}

Table laboratory.sample_collection_event {
  sample_collection_event_id varchar [pk, note: 'Unique identifier for the sample collection event.']
  cost_center_id varchar [note: 'Cost center responsible for collection costs.']
  hydrant_id varchar [note: 'Hydrant where sample was collected.']
  material_master_id varchar [note: 'Material used in sample collection (e.g., sample bottles, preservatives).']
  meter_installation_id varchar [note: 'Meter installation where sample was collected.']
  sample_collector_employee_id varchar [note: 'Employee who collected the sample.']
  sample_employee_id varchar [note: 'Employee responsible for the collection event.']
  sampling_location_id varchar [note: 'Sampling location where sample was collected.']
  sampling_plan_id varchar [note: 'Sampling plan under which this collection event was conducted.']
  service_address_id varchar [note: 'Service address where sample was collected.']
  ambient_temperature_c decimal(5,2) [note: 'Ambient air temperature in Celsius at time of collection.']
  chain_of_custody_number varchar [note: 'Chain of custody document number.']
  collection_equipment_code varchar [note: 'Code for equipment used in collection.']
  collection_equipment_description varchar [note: 'Description of equipment used in collection.']
  collection_event_number varchar [note: 'Unique number assigned to the collection event.']
  collection_latitude decimal(10,7) [note: 'Latitude coordinate of collection location.']
  collection_location_name varchar [note: 'Name of the collection location.']
  collection_longitude decimal(10,7) [note: 'Longitude coordinate of collection location.']
  collection_method_code varchar [note: 'Code for collection method used.']
  collection_method_description varchar [note: 'Description of collection method used.']
  collection_notes varchar [note: 'Additional notes about the collection event.']
  collection_status varchar [note: 'Status of the collection event (e.g., completed, cancelled, rescheduled).']
  collection_timestamp timestamp [note: 'Timestamp when the sample was collected.']
  collector_certification_number varchar [note: 'Certification number of the sample collector.']
  collector_name varchar [note: 'Name of the sample collector.']
  compliance_monitoring_flag boolean [note: 'Flag indicating if this is a compliance monitoring sample.']
  composite_duration_hours decimal(6,2) [note: 'Duration of composite sample collection in hours.']
  composite_interval_minutes varchar [note: 'Interval in minutes between composite sample aliquots.']
  container_type varchar [note: 'Type of container used for sample collection.']
  created_timestamp timestamp [note: 'Timestamp when the collection event record was created.']
  field_conductivity_us_cm decimal(8,2) [note: 'Conductivity measured in the field in microsiemens per centimeter.']
  field_dissolved_oxygen_mg_l decimal(6,3) [note: 'Dissolved oxygen measured in the field in milligrams per liter.']
  field_ph decimal(4,2) [note: 'pH measured in the field.']
  field_residual_chlorine_mg_l decimal(6,3) [note: 'Residual chlorine measured in the field in milligrams per liter.']
  field_temperature_c decimal(5,2) [note: 'Temperature measured in the field in Celsius.']
  field_turbidity_ntu decimal(7,3) [note: 'Turbidity measured in the field in nephelometric turbidity units.']
  flow_rate_gpm decimal(10,2) [note: 'Flow rate at collection point in gallons per minute.']
  modified_by varchar [note: 'User who last modified the collection event record.']
  modified_timestamp timestamp [note: 'Timestamp when the collection event record was last modified.']
  preservative_used varchar [note: 'Preservative used for sample preservation.']
  regulatory_program varchar [note: 'Regulatory program under which sample was collected (e.g., SDWA, NPDES).']
  sample_matrix varchar [note: 'Matrix type of the sample (e.g., drinking water, wastewater).']
  sample_type varchar [note: 'Type of sample collected (e.g., grab, composite).']
  sample_volume_ml decimal(10,2) [note: 'Volume of sample collected in milliliters.']
  weather_conditions varchar [note: 'Weather conditions at time of collection.']
  created_by varchar [note: 'User who created the collection event record.']

  Note: 'Sample collection event capturing field collection details, collector information, field measurements, environmental conditions, and collection method for drinking water and wastewater compliance sampling.'
}

Table laboratory.chain_of_custody {
  chain_of_custody_id varchar [pk, note: 'Unique identifier for the chain of custody record.']
  cip_project_id varchar [note: 'Link to capital improvement project if sample is part of project commissioning.']
  collected_by_employee_id varchar [note: 'Employee who collected the sample.']
  customer_account_id varchar [note: 'Customer account if sample was collected at customer location.']
  lab_sample_id varchar [note: 'Laboratory sample associated with this chain of custody.']
  laboratory_id varchar [note: 'Laboratory that received the sample.']
  sample_collection_event_id varchar [note: 'Collection event that produced the sample.']
  sampling_location_id varchar [note: 'Sampling location where sample was collected.']
  collection_datetime timestamp [note: 'Datetime when the sample was collected.']
  collector_certification_number varchar [note: 'Certification number of the sample collector.']
  collector_signature varchar [note: 'Signature of the sample collector.']
  container_count varchar [note: 'Number of containers in the shipment.']
  corrective_action_taken varchar [note: 'Corrective action taken if discrepancy was noted.']
  courier_name varchar [note: 'Name of courier service used for sample transport.']
  courier_tracking_number varchar [note: 'Tracking number for courier shipment.']
  created_timestamp timestamp [note: 'Timestamp when the chain of custody record was created.']
  custody_document_number varchar [note: 'Unique document number for the chain of custody form.']
  custody_status varchar [note: 'Current status of the chain of custody (e.g., in transit, received, complete).']
  discrepancy_description varchar [note: 'Description of any discrepancy noted during transfer.']
  discrepancy_noted boolean [note: 'Flag indicating if a discrepancy was noted.']
  hold_time_compliant boolean [note: 'Flag indicating if sample holding time was compliant.']
  ice_present boolean [note: 'Flag indicating if ice was present in the cooler upon receipt.']
  modified_by varchar [note: 'User who last modified the chain of custody record.']
  modified_timestamp timestamp [note: 'Timestamp when the chain of custody record was last modified.']
  preservation_method varchar [note: 'Method used to preserve the sample during transport.']
  preservation_verified boolean [note: 'Flag indicating if preservation was verified upon receipt.']
  received_by varchar [note: 'Name of person who received the sample.']
  received_datetime timestamp [note: 'Datetime when the sample was received by the laboratory.']
  received_signature varchar [note: 'Signature of person who received the sample.']
  relinquished_by varchar [note: 'Name of person who relinquished custody of the sample.']
  relinquished_datetime timestamp [note: 'Datetime when custody was relinquished.']
  relinquished_signature varchar [note: 'Signature of person who relinquished custody.']
  remarks varchar [note: 'Additional remarks or notes.']
  sample_condition_at_transfer varchar [note: 'Condition of the sample at time of transfer.']
  seal_intact boolean [note: 'Flag indicating if the seal was intact upon receipt.']
  seal_number varchar [note: 'Seal number used to secure the sample container.']
  temperature_at_receipt_c decimal(5,2) [note: 'Temperature of the sample upon receipt in Celsius.']
  temperature_compliant boolean [note: 'Flag indicating if sample temperature was compliant upon receipt.']
  transfer_type varchar [note: 'Type of transfer (e.g., hand delivery, courier, mail).']

  Note: 'Chain of custody record documenting sample transfer, custody signatures, seal integrity, temperature compliance, and discrepancies for regulatory compliance and data defensibility.'
}

Table laboratory.test_method {
  test_method_id varchar [pk, note: 'Unique identifier for the analytical test method record. Primary key.']
  created_by_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Method validation documentation requires employee accountability. Accreditation standards mandate traceable method development and validation records linked to qualified analysts for regulatory defens']
  vendor_id varchar [note: 'Foreign key linking to supply.vendor. Business justification: Many test methods require proprietary kits or reagents from specific vendors (e.g., Hach chlorine kits, IDEXX Colilert for coliforms). Method specifications reference approved vendor products for regu']
  accreditation_body varchar [note: 'Name of the accreditation or certification body that granted laboratory certification for this method (e.g., State Department of Health, EPA, NELAC, A2LA).']
  accreditation_date date [note: 'Date on which the laboratory received accreditation for this test method.']
  accreditation_expiration_date date [note: 'Date on which the current accreditation for this test method expires and requires renewal.']
  accreditation_status varchar [note: 'Current accreditation status of the laboratory for this specific test method under state or federal certification programs.']
  analysis_cost decimal(12,2) [note: 'Standard cost per sample analysis for this method, used for budgeting and billing purposes.']
  analyst_certification_required boolean [note: 'Indicates whether analysts must hold specific certification or training credentials to perform this method.']
  analyte_group varchar [note: 'The specific analyte or group of analytes measured by this method (e.g., Trace Metals, Volatile Organic Compounds, Total Coliform, Turbidity, PFAS).']
  applicable_matrix_types varchar [note: 'Comma-separated list of sample matrix types for which this method is validated and approved (e.g., drinking water, wastewater, source water, groundwater, soil, sludge, biosolids).']
  container_type varchar [note: 'Required sample container material and specifications (e.g., glass amber bottle, polyethylene bottle, sterile container).']
  created_timestamp timestamp [note: 'Timestamp when this test method record was first created in the system.']
  detection_technique varchar [note: 'The analytical detection or measurement technique employed by the method (e.g., ICP-MS, GC-MS, LC-MS/MS, colorimetric, titration, UV spectrophotometry, membrane filtration, enzyme substrate).']
  effective_date date [note: 'Date on which this method became effective and approved for use in the laboratory.']
  holding_time_hours varchar [note: 'Maximum allowable time in hours between sample collection and analysis to ensure result validity, as specified by the method.']
  instrument_required varchar [note: 'Type of analytical instrument required to perform this method (e.g., ICP-MS, GC-MS, UV-Vis Spectrophotometer, Incubator).']
  interferences varchar [note: 'Known interferences or matrix effects that may impact method accuracy or precision, as documented in the method reference.']
  last_modified_timestamp timestamp [note: 'Timestamp when this test method record was last updated or modified.']
  last_reviewed_date date [note: 'Date of the most recent technical review or validation of this method by laboratory quality assurance personnel.']
  lims_method_code varchar [note: 'Unique identifier for this test method in the laboratory LIMS system (LabWare or equivalent), used for system integration and data traceability.']
  mdl_unit varchar [note: 'Unit of measure for the MDL value (e.g., mg/L, µg/L, CFU/100mL, NTU, MPN/100mL).']
  mdl_value decimal(18,6) [note: 'The Method Detection Limit - the minimum concentration of an analyte that can be measured and reported with 99% confidence that the value is greater than zero.']
  method_category varchar [note: 'High-level classification of the test method by analyte category (inorganic, organic, microbiological, physical, radiological, emerging contaminants).']
  method_code varchar [note: 'Standardized code identifying the analytical test method (e.g., EPA 200.8, SM 2130B, EPA 524.2, ASTM D1067). This is the externally-recognized identifier used in regulatory reporting and laboratory documentation.']
  method_description varchar [note: 'Detailed technical description of the analytical procedure, including sample preparation, analysis steps, and calculation methods.']
  method_name varchar [note: 'Full descriptive name of the analytical test method (e.g., Determination of Trace Elements in Waters and Wastes by Inductively Coupled Plasma-Mass Spectrometry).']
  method_source varchar [note: 'The authoritative source or publishing organization of the method (e.g., EPA, Standard Methods, ASTM, ISO, USGS).']
  method_status varchar [note: 'Current operational status of the test method in the laboratory (active, inactive, under validation, obsolete, suspended).']
  method_version varchar [note: 'Version or revision number of the method (e.g., Rev 5.4, 23rd Edition, 2017 version).']
  next_review_date date [note: 'Scheduled date for the next periodic review or revalidation of this method.']
  obsolete_date date [note: 'Date on which this method was retired or superseded by a newer method. Null if the method is still active.']
  pql_unit varchar [note: 'Unit of measure for the PQL value (e.g., mg/L, µg/L, CFU/100mL, NTU, MPN/100mL).']
  pql_value decimal(18,6) [note: 'The Practical Quantitation Limit - the lowest concentration that can be reliably measured within specified limits of precision and accuracy during routine laboratory operations.']
  preservation_requirements varchar [note: 'Required sample preservation techniques and conditions (e.g., cool to 4°C, acidify to pH<2 with HNO3, add sodium thiosulfate, protect from light).']
  proficiency_testing_required boolean [note: 'Indicates whether successful proficiency testing is required for laboratory certification for this method.']
  qc_requirements varchar [note: 'Summary of quality control requirements for the method including frequency of blanks, duplicates, spikes, and control standards.']
  regulatory_acceptance varchar [note: 'Comma-separated list of regulatory programs that accept this method for compliance monitoring (e.g., SDWA, CWA, NPDES, state-specific programs).']
  reporting_limit decimal(18,6) [note: 'The minimum concentration at which results are reported to clients or regulatory agencies, typically equal to or greater than the PQL.']
  reporting_limit_unit varchar [note: 'Unit of measure for the reporting limit (e.g., mg/L, µg/L, CFU/100mL, NTU).']
  superseded_by_method_code varchar [note: 'Method code of the replacement method if this method has been superseded. Null if still current.']
  turnaround_time_days varchar [note: 'Standard turnaround time in business days from sample receipt to result reporting for routine analysis.']

  Note: 'Reference catalog of approved analytical test methods used by the laboratory. Defines the method code (e.g., EPA 200.8, SM 2130B, EPA 524.2), method name, analyte or analyte group, detection technique (ICP-MS, GC-MS, colorimetric, titration, UV), accreditation status, applicable matrix types (drinking water, wastewater, source water, soil), holding time requirements, preservation requirements, MDL (Method Detection Limit), PQL (Practical Quantitation Limit), and regulatory acceptance (SDWA, CWA, NPDES).'
}

Table laboratory.analytical_test {
  analytical_test_id varchar [pk, note: 'Unique identifier for the analytical test record. Primary key for the analytical test entity.']
  analyte_id varchar [note: 'Reference to the specific chemical, physical, or biological parameter being measured (e.g., lead, total coliform, pH, turbidity, PFAS).']
  calibration_curve_id varchar [note: 'Reference to the instrument calibration curve used to convert raw instrument response to analyte concentration. Links to calibration standards, curve coefficients, and correlation coefficient (R²).']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Analytical tests are frequently performed for specific capital projects (new treatment plant startup, pipeline disinfection verification, construction phase monitoring). Required for project cost allo']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Individual test costs must be allocated to the requesting department\'s cost center for interdepartmental billing and budget tracking. Water utilities operate labs as internal service centers that char']
  lab_instrument_id varchar [note: 'Reference to the laboratory instrument or equipment used to perform the test (e.g., ICP-MS, spectrophotometer, incubator). Links to calibration and maintenance records.']
  lab_sample_id varchar [note: 'Reference to the parent laboratory sample on which this analytical test was performed. Links to the sample collection and chain of custody record.']
  primary_analytical_certified_analyst_id varchar [note: 'Reference to the certified laboratory analyst who performed the test. Used for quality assurance, proficiency tracking, and regulatory audit trails.']
  qc_batch_id varchar [note: 'Reference to the quality control batch that includes this test. QC batches contain blanks, duplicates, spikes, and control standards to validate analytical accuracy and precision.']
  tertiary_analytical_approved_by_analyst_certified_analyst_id varchar [note: 'Reference to the laboratory director or authorized signatory who provided final approval for the test result. Approved results are certified for regulatory reporting and external release.']
  test_method_id varchar [note: 'Reference to the standardized analytical test method applied (e.g., EPA 200.7, SM 2540C, ASTM D1067). Defines the procedure, detection limits, and quality control requirements.']
  accreditation_body varchar [note: 'Name of the organization that accredited the laboratory to perform this test method (e.g., NELAC, A2LA, ANAB, state primacy agency). Required for regulatory acceptance of results.']
  accreditation_number varchar [note: 'Unique certificate or license number issued by the accreditation body authorizing the laboratory to perform this test method. Must be current and valid for regulatory reporting.']
  approval_timestamp timestamp [note: 'Date and time when the test result received final approval and was certified for regulatory reporting. Marks transition to approved status and enables result release.']
  chain_of_custody_number varchar [note: 'Unique identifier for the chain of custody document that accompanied the sample from collection through laboratory receipt. Ensures sample integrity and traceability for legal defensibility.']
  created_timestamp timestamp [note: 'Date and time when this analytical test record was first created in the laboratory system. Represents the initial entry into the laboratory workflow.']
  detection_limit decimal(18,6) [note: 'Minimum concentration of analyte that can be measured and reported with 99% confidence that the value is greater than zero. Used to determine non-detect results and reporting limits.']
  dilution_factor decimal(10,4) [note: 'Multiplier applied to raw instrument response to account for sample dilution performed to bring analyte concentration within instrument calibration range. A value of 1.0 indicates no dilution.']
  hold_time_compliant_flag boolean [note: 'Indicates whether the test was performed within the maximum allowable time between sample collection and analysis. Hold times vary by analyte and method (e.g., 48 hours for bacteria, 28 days for metals). Non-compliance may invalidate results for regulatory reporting.']
  last_modified_timestamp timestamp [note: 'Date and time when this analytical test record was most recently updated. Tracks changes to results, status transitions, or corrections throughout the test lifecycle.']
  lims_import_timestamp timestamp [note: 'Date and time when this test record was imported from the source Laboratory Information Management System (LabWare) into the enterprise data lakehouse. Used for data lineage and reconciliation.']
  matrix_type varchar [note: 'Classification of the sample medium being analyzed. Matrix type affects method selection, quality control requirements, and regulatory applicability. Different matrices may require different preparation techniques and have different interference profiles. [ENUM-REF-CANDIDATE: drinking_water|raw_water|wastewater|groundwater|surface_water|biosolids|soil|sediment — 8 candidates stripped; promote to reference product]']
  percent_recovery decimal(6,2) [note: 'Quality control metric indicating the percentage of known analyte concentration recovered in matrix spike or laboratory control sample. Used to assess method accuracy and matrix interference. Acceptable ranges are method-specific.']
  preservation_method varchar [note: 'Chemical or physical treatment applied to the sample to maintain analyte stability during storage and transport (e.g., acidification with HNO3, refrigeration at 4°C, addition of sodium thiosulfate for dechlorination).']
  qualifier_code varchar [note: 'Data quality flag indicating special conditions affecting the result. U=non-detect (below detection limit), J=estimated value (between MDL and RL), B=blank contamination detected, E=exceeds calibration range, H=hold time exceeded, N=tentative identification, Q=QC failure, R=rejected, S=spike recovery out of range, T=temperature exceedance, V=value verified, X=other (see comments). [ENUM-REF-CANDIDATE: U|J|B|E|H|N|Q|R|S|T|V|X — 12 candidates stripped; promote to reference product]']
  raw_instrument_response decimal(18,6) [note: 'Uncorrected measurement value directly from the analytical instrument before applying dilution factors, calibration curves, or other corrections. Retained for audit trails and method validation.']
  reanalysis_required_flag boolean [note: 'Indicates whether the test must be repeated due to quality control failure, questionable results, or regulatory requirements. Triggers workflow to schedule reanalysis from the same sample or request new sample collection.']
  regulatory_program varchar [note: 'Federal or state regulatory program under which this test is being performed. Determines applicable compliance thresholds, reporting requirements, and data quality objectives. SDWA=Safe Drinking Water Act, CWA=Clean Water Act, NPDES=National Pollutant Discharge Elimination System. [ENUM-REF-CANDIDATE: sdwa|cwa|npdes|rcra|cercla|tsca|state_program — 7 candidates stripped; promote to reference product]']
  rejection_reason varchar [note: 'Detailed explanation for why the test result was rejected and cannot be used for regulatory reporting. Common reasons include QC failure, hold time exceedance, contamination, instrument malfunction, or analyst error. Triggers resampling or reanalysis.']
  relative_percent_difference decimal(6,2) [note: 'Quality control metric measuring precision between duplicate samples. Calculated as the absolute difference divided by the mean, expressed as a percentage. Used to assess analytical reproducibility.']
  reporting_limit decimal(18,6) [note: 'Minimum concentration that can be reliably quantified and reported. Typically set at 2-10 times the Method Detection Limit (MDL) to ensure data quality and regulatory compliance.']
  result_unit varchar [note: 'Unit of measure for the result value (e.g., mg/L, ug/L, NTU, MPN/100mL, pH units, CFU/100mL). Must align with regulatory reporting requirements and Maximum Contaminant Level (MCL) units.']
  result_value decimal(18,6) [note: 'Calculated analytical result value after applying dilution factors, calibration curves, and method-specific calculations. This is the reportable concentration or measurement for the analyte.']
  review_timestamp timestamp [note: 'Date and time when the test result was reviewed and validated by a senior analyst or supervisor. Marks transition from preliminary to reviewed status.']
  test_comments varchar [note: 'Free-text field for analyst notes, observations, or explanations regarding unusual conditions, deviations from standard procedures, or result interpretation. May include details on matrix interference, instrument issues, or quality control anomalies.']
  test_completion_timestamp timestamp [note: 'Date and time when the analytical test procedure was completed and raw results were recorded. Used to calculate turnaround time and verify hold time compliance.']
  test_number varchar [note: 'Human-readable business identifier for the analytical test, often used in laboratory worksheets, chain of custody forms, and external reporting. May follow lab-specific numbering conventions.']
  test_priority varchar [note: 'Business priority classification for the analytical test. STAT tests require immediate processing for operational decisions; regulatory tests support compliance reporting deadlines; routine tests follow standard turnaround times.']
  test_start_timestamp timestamp [note: 'Date and time when the analytical test procedure was initiated. Critical for hold time compliance and contact time (CT) calculations for disinfection validation.']
  test_status varchar [note: 'Current lifecycle status of the analytical test. Tracks progression from initiation through final approval or rejection. Preliminary results are unvalidated; reviewed results have passed QC checks; approved results are certified for regulatory reporting. [ENUM-REF-CANDIDATE: pending|in_progress|preliminary|reviewed|approved|rejected|cancelled — 7 candidates stripped; promote to reference product]']
  uncertainty_value decimal(18,6) [note: 'Quantified estimate of the doubt associated with the measurement result, expressed in the same units as the result. Includes contributions from sampling, sample preparation, calibration, and instrument variability.']

  Note: 'Core transactional record representing a single analytical test performed on a lab sample. Captures the test method applied, assigned analyst, instrument used, test start and completion datetimes, raw instrument response, calculated result value, result unit, dilution factor, qualifier codes (U=non-detect, J=estimated, B=blank contamination), QC batch reference, and result status (preliminary, reviewed, approved, rejected). This is the primary result-generating entity in the laboratory workflow.'
}

Table laboratory.test_result {
  test_result_id varchar [pk, note: 'Unique identifier for the validated and finalized analytical test result record. Primary key.']
  analytical_test_id varchar [note: 'Reference to the parent analytical test record from which this result was produced. Links to the in-process measurement and test execution context.']
  calibration_curve_id varchar [note: 'Reference to the instrument calibration curve used to quantify this result. Links result to the specific calibration standards and curve parameters in effect at the time of analysis.']
  certified_analyst_id varchar [note: 'Reference to the certified analyst or laboratory supervisor who reviewed and approved this result for release. Must be a qualified individual with appropriate certification and training.']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Test results must be attributed to projects for regulatory compliance reporting, cost recovery, and commissioning documentation. Water utilities track which analytical results support specific capital']
  contaminant_id varchar [note: 'Reference to the regulatory parameter this result maps to (e.g., Total Coliform, Lead, Nitrate). Links result to compliance thresholds such as Maximum Contaminant Level (MCL), Maximum Contaminant Level Goal (MCLG), or National Pollutant Discharge Elimination System (NPDES) effluent limits.']
  lab_instrument_id varchar [note: 'Reference to the laboratory instrument used to perform the analysis (e.g., Inductively Coupled Plasma Mass Spectrometry (ICP-MS), Gas Chromatography-Mass Spectrometry (GC-MS), spectrophotometer). Links result to instrument calibration and maintenance records.']
  lab_sample_id varchar [note: 'Reference to the water or wastewater sample that was analyzed to produce this result.']
  metering_dma_zone_id varchar [note: 'Foreign key linking to metering.dma_zone. Business justification: Water quality test results must be analyzed by DMA/pressure zone to identify spatial patterns, assess treatment effectiveness across zones, and support regulatory zone-level compliance reporting. Requ']
  original_result_test_result_id varchar [note: 'Reference to the original test result record if this result is a reanalysis. Links reanalysis results back to the initial result for audit trail and comparison purposes. Null if this is the first analysis.']
  point_id varchar [note: 'Foreign key linking to service.service_point. Business justification: When test results exceed regulatory limits (lead action level, MCL violations), utilities must notify affected customers at specific service points. Customer notification letters, remediation tracking']
  qc_batch_id varchar [note: 'Reference to the quality control batch in which this sample was analyzed. Links result to associated QC samples (blanks, duplicates, spikes, standards) run concurrently to validate analytical performance.']
  regulatory_requirement_id varchar [note: 'Reference to the regulatory parameter this result maps to (e.g., Total Coliform, Lead, Nitrate). Links result to compliance thresholds such as Maximum Contaminant Level (MCL), Maximum Contaminant Level Goal (MCLG), or National Pollutant Discharge Elimination System (NPDES) effluent limits.']
  test_method_id varchar [note: 'Reference to the standardized analytical test method used (e.g., EPA Method 200.7, Standard Methods 2540 C). Defines the procedure, detection limits, and quality control requirements.']
  accreditation_flag boolean [note: 'Boolean flag indicating whether this result was produced under laboratory accreditation (e.g., ISO/IEC 17025, state certification program). True indicates the result was produced by an accredited laboratory using an accredited method; False indicates non-accredited analysis.']
  analysis_completion_timestamp timestamp [note: 'Date and time when the analytical test was completed and the raw result was generated by the instrument or analyst. Distinct from approval_timestamp which represents the validation and release event.']
  approval_timestamp timestamp [note: 'Date and time when the result was reviewed and approved by the approving analyst. Marks the point at which the result became the authoritative reported value available for compliance and operational use.']
  approved_result_flag boolean [note: 'Boolean flag indicating whether this result has been reviewed and approved by a qualified analyst or laboratory supervisor. True indicates the result has passed all quality control checks and is released for reporting; False indicates the result is pending review or has been rejected.']
  blank_contamination_flag boolean [note: 'Boolean flag indicating whether the method blank analyzed in the same batch showed detectable contamination of the target analyte. True indicates blank contamination was detected, which may affect result interpretation.']
  compliance_status varchar [note: 'Indicates whether the result meets applicable regulatory thresholds. Values: compliant (result within acceptable limits), non-compliant (result exceeds Maximum Contaminant Level (MCL) or violates National Pollutant Discharge Elimination System (NPDES) limit), exceedance (result exceeds action level but not MCL), not_applicable (no regulatory threshold for this parameter), pending_review (compliance determination not yet made).']
  created_timestamp timestamp [note: 'Date and time when this test result record was first created in the system. Represents the initial capture of the result data.']
  detection_status varchar [note: 'Indicates whether the analyte was detected in the sample. Values: detected (analyte present above Method Detection Limit), non-detect (analyte not detected or below MDL), trace (analyte detected but below quantitation limit), below_mdl (result below Method Detection Limit), above_mdl (result above Method Detection Limit and quantifiable).']
  dilution_factor decimal(10,2) [note: 'The factor by which the sample was diluted prior to analysis. A value of 1.0 indicates no dilution. Values greater than 1.0 indicate the sample was diluted to bring analyte concentration within the calibration range or to reduce matrix interference.']
  duplicate_relative_percent_difference decimal(5,2) [note: 'Relative percent difference between the sample result and its duplicate, calculated as (|Sample - Duplicate| / Average) × 100. Indicates the precision of the analytical method. Acceptable ranges are method-specific (typically <20%).']
  holding_time_compliance_flag boolean [note: 'Boolean flag indicating whether the sample was analyzed within the method-specified holding time (time between sample collection and analysis). True indicates compliance; False indicates holding time was exceeded, which may affect result validity.']
  lims_result_code varchar [note: 'The unique result identifier from the source Laboratory Information Management System (LIMS), such as LabWare. Enables traceability back to the originating system and supports data reconciliation.']
  matrix_spike_recovery_percent decimal(5,2) [note: 'Percent recovery of the analyte from the matrix spike sample analyzed in the same batch. Indicates the accuracy of the method in the presence of the sample matrix. Acceptable ranges are method-specific (typically 75-125%).']
  method_detection_limit decimal(18,6) [note: 'The minimum concentration of an analyte that can be measured and reported with 99% confidence that the value is greater than zero. Specific to the test method and laboratory instrumentation used.']
  modified_timestamp timestamp [note: 'Date and time when this test result record was last modified. Tracks any updates to the result data after initial creation.']
  proficiency_test_flag boolean [note: 'Boolean flag indicating whether this result is from a proficiency testing (PT) sample used to evaluate laboratory performance. True indicates this is a PT result; False indicates a routine sample result.']
  reanalysis_flag boolean [note: 'Boolean flag indicating whether this result is from a reanalysis of the sample. True indicates the sample was reanalyzed due to quality control failure, holding time exceedance, or other issue with the initial analysis; False indicates this is the first analysis.']
  regulatory_threshold_unit varchar [note: 'Unit of measure for the regulatory threshold value. Must be compatible with the reporting_unit to enable valid comparison. [ENUM-REF-CANDIDATE: mg/L|ug/L|NTU|CFU/100mL|MPN/100mL|pH units|percent|ppm|ppb|SU — 10 candidates stripped; promote to reference product]']
  regulatory_threshold_value decimal(18,6) [note: 'The applicable regulatory limit against which this result is compared (e.g., Maximum Contaminant Level (MCL), Maximum Contaminant Level Goal (MCLG), National Pollutant Discharge Elimination System (NPDES) effluent limit). Captured at the time of result approval to preserve the threshold in effect.']
  reporting_limit decimal(18,6) [note: 'The minimum concentration at which the laboratory can quantitatively report a result with confidence. Typically set at 2-10 times the Method Detection Limit (MDL). Also known as Practical Quantitation Limit (PQL) or Limit of Quantitation (LOQ).']
  reporting_timestamp timestamp [note: 'Date and time when the result was officially reported to the client or regulatory agency. Distinct from approval_timestamp which is internal laboratory validation; this marks external release.']
  reporting_unit varchar [note: 'Unit of measure in which the result value is reported. Common units include milligrams per liter (mg/L), micrograms per liter (ug/L), Nephelometric Turbidity Units (NTU), Colony Forming Units per 100 milliliters (CFU/100mL), Most Probable Number per 100 milliliters (MPN/100mL), pH units, percent, parts per million (ppm), parts per billion (ppb), Standard Units (SU). [ENUM-REF-CANDIDATE: mg/L|ug/L|NTU|CFU/100mL|MPN/100mL|pH units|percent|ppm|ppb|SU — 10 candidates stripped; promote to reference product]']
  result_comment varchar [note: 'Free-text comment field for analyst notes, observations, or explanations regarding the result. May include information about matrix interference, unusual sample characteristics, deviations from standard procedure, or other contextual information.']
  result_qualifier varchar [note: 'Data qualifier code providing additional context about the result (e.g., J=estimated value, U=undetected, E=exceeds calibration range, B=blank contamination, H=holding time exceeded, Q=quality control failure). Follows EPA and laboratory-specific qualifier conventions.']
  result_status varchar [note: 'Current lifecycle status of the result record. Values: final (result approved and released), preliminary (result generated but not yet approved), rejected (result failed quality control and is not valid), under_review (result pending analyst review), cancelled (result voided due to sample or procedural issue).']
  result_value decimal(18,6) [note: 'The validated and finalized numeric result value reported from the analytical test. This is the authoritative measurement released for compliance and operational use.']
  uncertainty_estimate decimal(10,4) [note: 'Quantitative estimate of the uncertainty associated with the reported result, expressed in the same units as the result. Represents the range within which the true value is expected to lie with a specified confidence level (typically 95%).']

  Note: 'Validated and finalized analytical result record produced from an analytical test. Stores the reported result value, reporting unit, detection status (detected, non-detect, trace), result qualifier, uncertainty estimate, approved result flag, approving analyst, approval datetime, and the regulatory parameter it maps to (e.g., MCL, MCLG, NPDES effluent limit). Distinct from analytical_test which captures the raw in-process measurement; test_result is the authoritative reported value released for compliance and operational use.'
}

Table laboratory.sampling_plan {
  sampling_plan_id varchar [pk, note: 'Unique identifier for the sampling plan. Primary key.']
  created_by_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Sampling plans are regulatory compliance documents requiring documented authorship. EPA and state regulations mandate traceable plan development by qualified employees for permit compliance and audit ']
  territory_id varchar [note: 'Foreign key linking to service.service_territory. Business justification: Sampling plans are designed for specific service territories to meet regulatory monitoring requirements (distribution system monitoring, source water monitoring). Each territory has unique permit cond']
  treatment_permit_id varchar [note: 'Foreign key linking to treatment.treatment_permit. Business justification: Sampling plans implement permit monitoring requirements (NPDES discharge limits, drinking water MCLs, withdrawal permits). Every compliance sampling plan is driven by a specific permit\'s monitoring sc']
  approved_by varchar [note: 'User identifier or name of the person who approved this sampling plan. Used for audit trail and regulatory compliance documentation. Nullable for draft plans.']
  approved_timestamp timestamp [note: 'Timestamp when this sampling plan was formally approved for use by authorized personnel (e.g., laboratory manager, quality assurance officer, regulatory compliance manager). Nullable for draft plans.']
  certified_analyst_required boolean [note: 'Indicates whether samples under this plan must be analyzed by a state-certified or EPA-certified analyst. True for regulatory compliance samples; false for operational monitoring.']
  chain_of_custody_required boolean [note: 'Indicates whether formal chain of custody documentation is required for samples collected under this plan. True for regulatory, legal, or enforcement-related samples; false for routine operational monitoring.']
  compliance_threshold_reference varchar [note: 'Reference to the regulatory standard or internal guideline defining acceptable limits for analytes in this sampling plan (e.g., MCL, MCLG, NPDES permit limits, internal action levels). Detailed thresholds are managed in the quality domain.']
  container_type varchar [note: 'Type of sample container required for collection (e.g., sterile plastic bottle, amber glass bottle, pre-preserved vial). Ensures compatibility with analyte and test method requirements.']
  created_timestamp timestamp [note: 'Timestamp when this sampling plan record was first created in the system. Used for audit trail and data lineage tracking.']
  effective_end_date date [note: 'Date on which this sampling plan is scheduled to end or be replaced. Nullable for ongoing plans without a defined end date.']
  effective_start_date date [note: 'Date on which this sampling plan becomes active and sample collection events should begin. Aligns with regulatory compliance periods or operational schedules.']
  holding_time_hours varchar [note: 'Maximum allowable time (in hours) between sample collection and analysis to ensure sample integrity and regulatory compliance. Varies by analyte and test method.']
  last_sample_collected_date date [note: 'Date of the most recent sample collection event completed under this plan. Used for compliance verification and schedule adherence tracking.']
  lims_integration_flag boolean [note: 'Indicates whether this sampling plan is integrated with the LabWare LIMS system for automated sample tracking, result entry, and reporting. True for plans with LIMS integration; false for manual tracking.']
  modified_by varchar [note: 'User identifier or name of the person who last modified this sampling plan record. Used for audit trail and accountability.']
  modified_timestamp timestamp [note: 'Timestamp when this sampling plan record was last modified. Used for audit trail and change tracking.']
  next_scheduled_sample_date date [note: 'Date of the next scheduled sample collection event under this plan. Updated dynamically as sample collection events are completed. Used for operational scheduling and compliance tracking.']
  notes varchar [note: 'Free-text field for additional context, special instructions, or operational notes related to this sampling plan (e.g., seasonal adjustments, site access requirements, coordination with other departments).']
  plan_code varchar [note: 'Externally-known unique business identifier for the sampling plan, used in LIMS and regulatory reporting systems.']
  plan_name varchar [note: 'Human-readable name of the sampling plan describing its purpose and scope.']
  plan_type varchar [note: 'Classification of the sampling plan based on its purpose: regulatory (compliance-driven), operational (routine monitoring), investigational (troubleshooting), proficiency (QA/QC), emergency (incident response), or special (one-time study).']
  preservation_method varchar [note: 'Required sample preservation technique to maintain analyte stability during transport and storage (e.g., refrigeration at 4°C, acidification with HNO3, addition of sodium thiosulfate for dechlorination). Nullable if no preservation is required.']
  proficiency_testing_required boolean [note: 'Indicates whether the laboratory performing analyses under this plan must participate in proficiency testing programs (e.g., EPA Water Pollution Performance Evaluation Studies, state PT programs). True for regulatory compliance samples.']
  qaqc_protocol varchar [note: 'Reference to the QA/QC protocol or standard operating procedure governing quality control measures for this sampling plan (e.g., blank samples, duplicate samples, spike recovery, proficiency testing frequency).']
  regulatory_driver varchar [note: 'Primary regulatory framework or permit requirement driving this sampling plan: SDWA (Safe Drinking Water Act), NPDES (National Pollutant Discharge Elimination System), LCRR (Lead and Copper Rule Revisions), state primacy agency requirements, local ordinance, or none for operational plans.']
  reporting_frequency varchar [note: 'Frequency at which results from this sampling plan must be reported to regulatory agencies or internal stakeholders: monthly, quarterly, semiannual, annual, or as-needed (event-driven).']
  reporting_requirement varchar [note: 'Primary regulatory or internal reporting obligation that this sampling plan supports: CCR (Consumer Confidence Report), DMR (Discharge Monitoring Report), MOR (Monthly Operating Report), state-specific report, internal management report, or none.']
  responsible_party varchar [note: 'Name or identifier of the person, team, or organizational unit responsible for executing this sampling plan (e.g., Water Quality Team, Field Operations, Contract Laboratory). May reference employee or organizational unit records.']
  revision_reason varchar [note: 'Brief description of the reason for the most recent revision to this sampling plan (e.g., regulatory change, permit update, operational improvement, corrective action). Supports change control and audit trail.']
  sample_type varchar [note: 'Type of sample collection method required: grab (single point-in-time), composite (time- or flow-weighted), continuous (automated real-time), field (on-site analysis), or split (duplicate for QA/QC or third-party verification).']
  sample_volume_ml varchar [note: 'Minimum required sample volume in milliliters to perform all specified analyses. Ensures sufficient sample quantity for laboratory testing and QA/QC replicates.']
  sampling_frequency varchar [note: 'Scheduled frequency at which samples must be collected under this plan: continuous (real-time monitoring), hourly, daily, weekly, biweekly, monthly, quarterly, semiannual, annual, or event-driven (triggered by specific conditions). [ENUM-REF-CANDIDATE: continuous|hourly|daily|weekly|biweekly|monthly|quarterly|semiannual|annual|event_driven — 10 candidates stripped; promote to reference product]']
  sampling_plan_status varchar [note: 'Current lifecycle status of the sampling plan: draft (under development), active (in use), suspended (temporarily paused), retired (no longer used), archived (historical record).']
  total_samples_collected varchar [note: 'Cumulative count of sample collection events completed under this sampling plan since its effective start date. Used for compliance reporting and plan performance tracking.']
  version_number varchar [note: 'Version number of this sampling plan, incremented with each revision. Supports change control and regulatory audit requirements.']

  Note: 'Master record defining a scheduled or regulatory-driven sampling program. Specifies the sampling frequency (daily, weekly, monthly, quarterly), required analytes, sampling locations, applicable regulation or permit (SDWA, NPDES, LCRR, state primacy), sample type requirements, required test methods, and responsible party. Drives the generation of sample_collection_event records and ensures regulatory sampling schedules are met. Covers CCR monitoring, DBP (THM/HAA5) monitoring, PFAS sampling, LCRR tap sampling, and NPDES effluent monitoring.'
}

Table laboratory.sampling_location {
  sampling_location_id varchar [pk, note: 'Unique identifier for the sampling location. Primary key for the sampling location master record.']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Construction projects require water quality monitoring at project sites during and after construction. Sampling locations are established for pre-commissioning testing, post-construction verification,']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Sampling locations are associated with operational facilities (WTPs, pump stations, pressure zones) that have assigned cost centers. Compliance monitoring costs must be allocated to the responsible op']
  created_by_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Sampling location registry management requires employee accountability for data quality. Location setup affects compliance monitoring site selection and must be traceable to qualified employees for re']
  customer_account_id varchar [note: 'Foreign key linking to customer.customer_account. Business justification: LCRR Tier 1/2/3 sampling sites are customer taps requiring account linkage for access coordination, volunteer recruitment, sampling appointment scheduling, and result notification. Utilities maintain ']
  dma_id varchar [note: 'Foreign key linking to distribution.dma. Business justification: Water quality monitoring programs align with DMA boundaries for correlating quality issues with leak detection, NRW analysis, and system performance. Location records must reference the DMA for integr']
  facility_id varchar [note: 'Reference to the parent facility (WTP, WWTP, pump station, reservoir) to which this sampling location belongs.']
  hydrant_id varchar [note: 'Foreign key linking to distribution.hydrant. Business justification: Designated sampling locations in distribution systems are typically hydrants used for routine compliance monitoring. Location records must reference the physical hydrant asset for field crew navigatio']
  material_master_id varchar [note: 'Foreign key linking to supply.material_master. Business justification: Sampling locations often have assigned field equipment (bailers, pumps, sample bottles) that are inventory-managed materials. Links location to its standard sampling kit for logistics planning, restoc']
  meter_installation_id varchar [note: 'Foreign key linking to metering.installation. Business justification: Sampling locations in distribution systems are frequently established at metered service points to ensure representative samples and enable correlation between water quality and consumption patterns. ']
  point_id varchar [note: 'Foreign key linking to service.service_point. Business justification: Many sampling locations ARE service points (customer taps for lead/copper monitoring, distribution system sample stations). LCRR requires tier classification of service points, linking monitoring loca']
  pressure_zone_id varchar [note: 'Foreign key linking to distribution.pressure_zone. Business justification: Regulatory sampling plans require representative coverage across pressure zones to ensure water quality throughout the distribution system. Location records must identify which pressure zone they repr']
  sampling_asset_registry_id varchar [note: 'Reference to the specific asset (pipe segment, valve, tank, outfall structure) at which sampling occurs. Links to IBM Maximo asset registry.']
  sampling_registry_id varchar [note: 'Reference to the specific asset (pipe segment, valve, tank, outfall structure) at which sampling occurs. Links to IBM Maximo asset registry.']
  scada_tag_id varchar [note: 'Reference to the SCADA tag or point in OSIsoft PI Historian associated with this sampling location, if applicable (e.g., for online monitoring).']
  storage_tank_id varchar [note: 'Foreign key linking to distribution.storage_tank. Business justification: Storage tanks are designated sampling locations for water quality monitoring programs. Location records must link to the specific tank asset for regulatory compliance tracking, operational monitoring ']
  accessibility_notes varchar [note: 'Free-text notes describing access requirements, restrictions, or special instructions for field sampling crews (e.g., key required, gate code, contact property owner).']
  address_line_1 varchar [note: 'Primary street address or location descriptor for the sampling point. Used for field crew navigation and regulatory reporting.']
  address_line_2 varchar [note: 'Secondary address information (suite, building, unit) for the sampling location.']
  city varchar [note: 'City or municipality where the sampling location is situated.']
  country_code varchar [note: 'Three-letter ISO country code (e.g., USA, CAN, MEX) for the sampling location.']
  created_timestamp timestamp [note: 'Timestamp when this sampling location record was first created in the system.']
  decommission_date date [note: 'Date when the sampling location was decommissioned or removed from active sampling schedules.']
  elevation_ft decimal(8,2) [note: 'Elevation above sea level in feet at the sampling location. Relevant for hydraulic modeling and pressure zone analysis.']
  gis_feature_code varchar [note: 'Unique feature identifier in the Esri ArcGIS system linking this sampling location to the spatial layer.']
  installation_date date [note: 'Date when the sampling location was established or the sampling infrastructure was installed.']
  is_compliance_location boolean [note: 'Boolean flag indicating whether this location is designated for regulatory compliance monitoring (true) or operational monitoring only (false).']
  is_public_access boolean [note: 'Boolean flag indicating whether the sampling location is in a publicly accessible area (true) or requires special access arrangements (false).']
  last_sample_date date [note: 'Date of the most recent sample collected at this location. Used for scheduling and compliance tracking.']
  latitude decimal(10,7) [note: 'Geographic latitude coordinate (WGS84 decimal degrees) of the sampling location. Used for GIS mapping and spatial analysis in Esri ArcGIS.']
  lcrr_tier_classification varchar [note: 'Tier classification under EPA Lead and Copper Rule Revisions (LCRR). Determines sampling frequency and priority for lead service line locations.']
  lims_location_code varchar [note: 'Location code used in the LabWare LIMS system for sample tracking and chain of custody. May differ from the utility\'s internal location code.']
  location_code varchar [note: 'Business identifier for the sampling location, used in field operations, laboratory requisitions, and regulatory reporting. Typically follows utility-specific naming conventions.']
  location_name varchar [note: 'Human-readable name or description of the sampling location (e.g., \'Main Street Tap\', \'WTP Effluent Point A\', \'Outfall 001\').']
  location_status varchar [note: 'Current operational status of the sampling location. Determines whether the location is included in active sampling schedules.']
  location_type varchar [note: 'Classification of the sampling location based on its position in the water or wastewater system. Determines applicable regulatory requirements and sampling protocols. [ENUM-REF-CANDIDATE: entry_point_distribution|distribution_system_tap|source_water_intake|wtp_effluent|wwtp_influent|wwtp_effluent|industrial_user_discharge|ambient_receiving_water|reservoir|storage_tank|pump_station — 11 candidates stripped; promote to reference product]']
  longitude decimal(11,7) [note: 'Geographic longitude coordinate (WGS84 decimal degrees) of the sampling location. Used for GIS mapping and spatial analysis in Esri ArcGIS.']
  modified_by varchar [note: 'User ID or name of the person who last modified this sampling location record.']
  modified_timestamp timestamp [note: 'Timestamp when this sampling location record was last modified.']
  notes varchar [note: 'General notes or comments about the sampling location, including historical context, special considerations, or operational observations.']
  npdes_outfall_number varchar [note: 'EPA-assigned NPDES permit outfall identifier for wastewater discharge points. Required for DMR reporting and compliance monitoring.']
  postal_code varchar [note: 'ZIP or postal code for the sampling location address.']
  regulatory_designation varchar [note: 'Additional regulatory classification or designation for the sampling location (e.g., compliance monitoring point, operational monitoring point, special study site).']
  sample_point_description varchar [note: 'Detailed description of the physical sampling point (e.g., tap type, valve location, manhole ID, outfall structure details).']
  sampling_frequency varchar [note: 'Standard sampling frequency for this location as defined by regulatory requirements or operational protocols. [ENUM-REF-CANDIDATE: daily|weekly|biweekly|monthly|quarterly|annual|event_based|as_needed — 8 candidates stripped; promote to reference product]']
  service_area varchar [note: 'Service area or district designation for the sampling location. Used for operational reporting and customer communication.']
  site_contact_name varchar [note: 'Name of the on-site contact person or property owner who can provide access to the sampling location.']
  site_contact_phone varchar [note: 'Phone number for the on-site contact person or property owner.']
  state_province varchar [note: 'Two-letter state or province code (e.g., CA, TX, NY) for the sampling location.']
  water_source_type varchar [note: 'Type of water source serving this sampling location. Relevant for source water monitoring and treatment correlation.']

  Note: 'Master record for each designated sampling point in the water and wastewater system. Captures location identifier, location type (entry point to distribution, distribution system tap, source water intake, WTP effluent, WWTP influent, WWTP effluent, industrial user discharge, ambient receiving water), GIS coordinates, associated facility or asset, accessibility notes, and regulatory designation (e.g., NPDES outfall number, LCRR tier classification). Provides the spatial anchor for all sampling activities.'
}

Table laboratory.lab_instrument {
  lab_instrument_id varchar [pk, note: 'Unique identifier for the laboratory instrument. Primary key for the lab_instrument product.']
  lab_asset_registry_id varchar [note: 'Reference to the enterprise asset registry for this instrument, linking laboratory equipment to the broader asset management system for depreciation, warranty, and disposal tracking.']
  lab_registry_id varchar [note: 'Reference to the enterprise asset registry for this instrument, linking laboratory equipment to the broader asset management system for depreciation, warranty, and disposal tracking.']
  primary_lab_certified_analyst_id varchar [note: 'Reference to the certified laboratory analyst who is the primary operator or custodian of this instrument, responsible for routine operation, calibration verification, and performance monitoring.']
  procurement_contract_id varchar [note: 'Foreign key linking to supply.procurement_contract. Business justification: High-value instruments often have multi-year service contracts covering calibration, preventive maintenance, and parts. Links instrument to its service agreement for contract compliance tracking and c']
  vendor_id varchar [note: 'Foreign key linking to supply.vendor. Business justification: Every lab instrument has a manufacturer/vendor for procurement, service contracts, calibration, and spare parts. Critical for asset lifecycle management, warranty tracking, and maintenance planning. R']
  accuracy_specification varchar [note: 'Manufacturer-stated accuracy or precision specification for the instrument, typically expressed as a percentage or absolute value (e.g., \'±2%\', \'±0.01 pH units\', \'±0.5 NTU\'). Used for method validation and quality control (QC) acceptance criteria.']
  annual_service_cost decimal(15,2) [note: 'Annual cost in USD for vendor service contract, preventive maintenance, and consumables for this instrument. Used for OPEX (Operating Expenditure) budgeting and total cost of ownership analysis.']
  calibration_frequency_days decimal(18,6) [note: 'Required interval in days between calibration events for this instrument, as defined by manufacturer specifications, regulatory requirements, or laboratory quality manual. Typical values range from 30 to 365 days depending on instrument type and criticality.']
  certification_expiration_date date [note: 'Date the instrument\'s regulatory certification expires, after which it cannot be used for compliance testing until recertified. Applicable for instruments used in SDWA, NPDES, or state-mandated testing programs.']
  certification_status varchar [note: 'Current certification or accreditation status of the instrument for regulatory compliance testing. Certified indicates the instrument meets all requirements for use in compliance monitoring under SDWA (Safe Drinking Water Act), NPDES (National Pollutant Discharge Elimination System), or other programs. Pending indicates certification is in progress. Expired indicates recertification is required. Not Required indicates the instrument is used for non-compliance testing only.']
  created_timestamp timestamp [note: 'Timestamp when this instrument record was first created in the system, used for audit trail and data lineage tracking.']
  in_service_date date [note: 'Date the instrument was first placed into operational service in the laboratory, marking the start of its useful life for depreciation and lifecycle tracking.']
  instrument_name varchar [note: 'Human-readable name or designation for the instrument, often combining type and location for operational clarity (e.g., \'Main Lab ICP-MS Unit 1\').']
  instrument_tag varchar [note: 'Unique physical asset tag or barcode identifier affixed to the instrument for inventory tracking and field identification. Typically follows organizational asset tagging conventions.']
  instrument_type varchar [note: 'Classification of the analytical instrument by its primary measurement technology. ICP-MS (Inductively Coupled Plasma Mass Spectrometry) for metals, GC-MS (Gas Chromatography Mass Spectrometry) for organics, IC (Ion Chromatography) for anions, TOC (Total Organic Carbon) Analyzer, Turbidimeter for NTU (Nephelometric Turbidity Units), Spectrophotometer for colorimetric analysis, pH Meter, DO (Dissolved Oxygen) Meter, Conductivity Meter, and various parameter-specific analyzers for water quality testing. [ENUM-REF-CANDIDATE: ICP-MS|GC-MS|IC|TOC Analyzer|Turbidimeter|Spectrophotometer|pH Meter|DO Meter|Conductivity Meter|Chlorine Analyzer|Fluoride Analyzer|Ammonia Analyzer|Nitrate Analyzer|Phosphate Analyzer|BOD Analyzer|COD Analyzer — 16 candidates stripped; promote to reference product]']
  lab_location varchar [note: 'Physical location of the instrument within the laboratory facility (e.g., \'Main Lab - Room 201\', \'WTP Lab - Bench 3\', \'WWTP Lab - Instrument Room\'). Used for operational logistics and sample routing.']
  last_calibration_date date [note: 'Date of the most recent successful calibration event for this instrument. Critical for determining current calibration status and next due date per laboratory quality assurance (QA) protocols.']
  last_maintenance_date date [note: 'Date of the most recent preventive maintenance (PM) activity performed on this instrument, used to track maintenance schedules and predict next service needs.']
  lims_instrument_code varchar [note: 'Unique instrument identifier in the laboratory\'s LIMS (Laboratory Information Management System), such as LabWare. Used for electronic data integration, sample tracking, and result validation workflows.']
  maintenance_frequency_days varchar [note: 'Required interval in days between preventive maintenance activities for this instrument, as defined by manufacturer recommendations or laboratory maintenance program. Typical values range from 90 to 365 days.']
  manufacturer varchar [note: 'Name of the company that manufactured the instrument (e.g., Agilent, Thermo Fisher Scientific, Hach, YSI, Shimadzu).']
  measurement_range_max decimal(15,6) [note: 'Upper bound of the instrument\'s measurement range, expressed in the instrument\'s native units. For example, 1000 mg/L for an ICP-MS, or 1000 NTU for a turbidimeter. Values beyond this range require dilution or alternative methods.']
  measurement_range_min decimal(15,6) [note: 'Lower bound of the instrument\'s measurement range or detection limit, expressed in the instrument\'s native units. For example, 0.001 mg/L for an ICP-MS measuring trace metals, or 0.1 NTU for a turbidimeter.']
  measurement_unit varchar [note: 'Standard unit of measure for results produced by this instrument (e.g., \'mg/L\', \'ug/L\', \'NTU\', \'pH units\', \'uS/cm\', \'mg/L as CaCO3\'). Must align with regulatory reporting requirements and laboratory LIMS (Laboratory Information Management System) configuration.']
  model_number varchar [note: 'Manufacturer\'s model number or designation for the instrument, used for parts ordering, service manuals, and technical specifications.']
  next_calibration_due_date date [note: 'Scheduled date for the next required calibration event, calculated based on calibration frequency requirements and last calibration date. Instruments past due for calibration must be taken out of service per ISO/IEC 17025.']
  next_maintenance_due_date date [note: 'Scheduled date for the next preventive maintenance activity, calculated based on maintenance frequency and last maintenance date. Used for work order scheduling in CMMS (Computerized Maintenance Management System).']
  notes varchar [note: 'Free-text field for additional information about the instrument, including special handling requirements, known quirks, configuration details, or historical context not captured in structured fields.']
  operational_status decimal(18,6) [note: 'Current operational state of the instrument. In Service indicates the instrument is available and qualified for testing. Out of Service indicates temporary unavailability. Calibration and Maintenance indicate scheduled activities. Repair indicates unplanned downtime. Retired indicates permanent removal from service. Quarantined indicates the instrument is under investigation for performance issues. [ENUM-REF-CANDIDATE: In Service|Out of Service|Calibration|Maintenance|Repair|Retired|Quarantined — 7 candidates stripped; promote to reference product]']
  primary_test_method varchar [note: 'Primary analytical test method or Standard Method number that this instrument is configured to perform (e.g., \'EPA 200.8\', \'SM 2540 C\', \'EPA 300.0\', \'SM 2130 B\'). Links the instrument to specific regulatory-approved analytical procedures.']
  purchase_cost decimal(15,2) [note: 'Original acquisition cost of the instrument in USD, used for asset valuation, depreciation calculations, and capital budgeting. Excludes installation and training costs unless capitalized.']
  purchase_date date [note: 'Date the instrument was purchased or acquired by the organization, used for warranty tracking and capital expenditure (CAPEX) reporting.']
  retirement_date date [note: 'Date the instrument was permanently retired from service and removed from the active laboratory inventory. Used for asset disposal tracking and historical record keeping.']
  retirement_reason varchar [note: 'Explanation for why the instrument was retired (e.g., \'End of useful life\', \'Replaced by newer model\', \'Excessive repair costs\', \'Obsolete technology\', \'Regulatory method discontinued\'). Used for asset lifecycle analysis and replacement planning.']
  secondary_test_methods varchar [note: 'Comma-separated list of additional test methods or Standard Method numbers that this instrument can perform, beyond the primary method. Used for multi-parameter instruments or instruments with multiple configurations.']
  serial_number varchar [note: 'Manufacturer-assigned unique serial number for this specific instrument unit, used for warranty claims, service history, and regulatory traceability.']
  service_contract_expiration_date date [note: 'Date the current vendor service contract expires, after which service calls will be billed separately or a new contract must be negotiated. Used for budgeting and contract renewal planning.']
  updated_timestamp timestamp [note: 'Timestamp when this instrument record was last modified, used for audit trail, change tracking, and data synchronization with source systems.']
  warranty_expiration_date date [note: 'Date the manufacturer\'s warranty coverage expires, after which repairs and parts are at the organization\'s expense. Used for maintenance planning and service contract decisions.']

  Note: 'Master inventory record for each analytical instrument in the laboratory. Captures instrument type (ICP-MS, GC-MS, IC, TOC analyzer, turbidimeter, spectrophotometer, pH meter, DO meter), manufacturer, model, serial number, asset tag, location within lab, current operational status, date placed in service, and associated test methods. Serves as the equipment master for calibration scheduling and maintenance tracking within the laboratory domain.'
}

Table laboratory.laboratory_instrument_calibration {
  laboratory_instrument_calibration_id varchar [pk, note: 'Unique identifier for the laboratory_instrument_calibration data product (auto-inserted pre-linking).']
  calibration_curve_id varchar [note: 'FK to the calibration curve record']
  certified_analyst_id varchar [note: 'Analyst who performed calibration']
  employee_id varchar
  lab_instrument_id varchar [note: 'Foreign key linking to laboratory.lab_instrument. Business justification: Calibration events are performed ON specific laboratory instruments. This is a core N:1 relationship (many calibration events per instrument). The FK enables tracking of calibration history per instru']
  laboratory_certified_analyst_id varchar [note: 'Foreign key linking to laboratory.certified_analyst. Business justification: Calibration events are performed BY certified analysts. This N:1 relationship (many calibrations per analyst) tracks who performed the calibration, which is required for regulatory traceability and qu']
  laboratory_verified_by_analyst_id varchar
  reagent_standard_id varchar [note: 'FK to the reagent/standard used for calibration']
  acceptance_criteria varchar [note: 'Acceptance criteria applied']
  acceptance_criteria_met_flag boolean
  analytical_method varchar [note: 'Analytical method']
  as_found_value decimal(18,6)
  as_left_value decimal(18,6)
  blank_acceptance_limit double [note: 'Blank acceptance limit']
  blank_value double [note: 'Calibration blank value']
  calibration_certificate_number varchar
  calibration_curve_r_squared decimal(8,6)
  calibration_date date
  calibration_due_date date
  calibration_frequency_days varchar
  calibration_method varchar
  calibration_notes varchar
  calibration_number varchar [note: 'Unique calibration number']
  calibration_range_high double [note: 'High end of calibration range']
  calibration_range_low double [note: 'Low end of calibration range']
  calibration_result varchar
  calibration_standard_expiration date
  calibration_standard_lot varchar
  calibration_standard_used varchar
  calibration_status varchar [note: 'Result (pass, fail, adjusted)']
  calibration_time timestamp [note: 'Time of calibration']
  calibration_timestamp timestamp
  calibration_type varchar [note: 'Type (initial, continuing, verification)']
  calibration_units varchar [note: 'Calibration units']
  ccb_value double [note: 'Continuing calibration blank value']
  ccv_pct_recovery decimal(6,2) [note: 'Continuing cal verification % recovery']
  comments varchar [note: 'Analyst comments on the calibration event']
  corrective_action_description varchar
  corrective_action_required boolean
  corrective_action_taken varchar [note: 'Corrective action if failed']
  correlation_coefficient decimal(8,6) [note: 'R-squared value of calibration curve']
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp
  curve_type varchar [note: 'Calibration curve type (linear, quadratic, weighted)']
  data_quality_flag boolean [note: 'True when record passed data validation.']
  deviation varchar
  deviation_from_standard decimal(10,4)
  deviation_percent decimal(6,2) [note: 'Maximum deviation from standard']
  drift_percentage decimal(6,2)
  environmental_conditions varchar
  expected_response decimal(18,6) [note: 'Expected instrument response to the standard']
  high_standard_value double [note: 'Highest calibration standard value']
  highest_standard_value decimal(18,6) [note: 'Highest calibration standard concentration']
  humidity_during_calibration_pct decimal(5,2)
  humidity_percent decimal(5,2) [note: 'Ambient humidity during calibration']
  ical_verification_pct_recovery decimal(6,2) [note: 'Initial cal verification % recovery']
  instrument_name varchar [note: 'Instrument name']
  instrument_serial_number varchar [note: 'Instrument serial number']
  instrument_type varchar [note: 'Type of instrument']
  intercept double [note: 'Calibration curve intercept']
  laboratory_quality_instrument_calibration_id varchar [note: 'Foreign key to single source of truth quality.quality_instrument_calibration']
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  lims_calibration_code varchar
  low_standard_value double [note: 'Lowest calibration standard value']
  lowest_standard_value decimal(18,6) [note: 'Lowest calibration standard concentration']
  measured_response decimal(18,6)
  measured_value decimal(18,2)
  method_code varchar [note: 'Analytical method requiring calibration']
  method_reference varchar
  modified_timestamp timestamp
  next_calibration_date date
  next_calibration_due date [note: 'Next calibration due date.']
  next_calibration_due_date date [note: 'Next calibration due date']
  next_due_date date [note: 'Next calibration due date']
  notes varchar [note: 'Calibration notes']
  number_of_points varchar [note: 'Number of calibration points used']
  number_of_standards varchar [note: 'Number of calibration standards used']
  pass_fail_flag boolean
  pass_fail_result varchar [note: 'Pass/fail result']
  pass_fail_status varchar [note: 'Pass/fail determination']
  pass_flag boolean [note: 'Whether calibration passed']
  passed boolean [note: 'Whether calibration passed.']
  passed_flag boolean
  percent_deviation decimal(8,4) [note: 'Percent deviation from expected response']
  performed_by_name varchar
  post_calibration_check decimal(18,6)
  post_calibration_reading decimal(18,6)
  pre_calibration_check decimal(18,6)
  pre_calibration_reading decimal(18,6)
  quality_instrument_calibration_id varchar [note: 'Foreign key to the canonical quality_instrument_calibration record in quality domain']
  r_squared decimal(8,6) [note: 'R-squared value']
  r_squared_value decimal(8,6)
  record_status varchar
  reference_value decimal(18,2)
  relative_response_factor_rsd decimal(6,3) [note: 'RSD of relative response factors']
  review_date date [note: 'Review date']
  review_timestamp timestamp
  reviewed_by varchar [note: 'Reviewer name']
  reviewed_by_name varchar
  slope double [note: 'Calibration curve slope']
  standard_concentration decimal(18,6)
  standard_concentration_units varchar [note: 'Standard concentration units']
  standard_expiration_date date [note: 'Expiration date of standards']
  standard_lot_number varchar [note: 'Lot number of standards used']
  standard_lot_numbers varchar [note: 'Lot numbers of standards used']
  standard_source varchar [note: 'Source/vendor of calibration standards']
  standard_unit varchar [note: 'Unit of measure for the calibration standard']
  standard_used varchar [note: 'Reference standard used.']
  temperature_c decimal(5,2) [note: 'Ambient temperature during calibration in Celsius']
  temperature_during_calibration_c decimal(5,2)
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp.']
  verification_measured_value double [note: 'Measured value of verification standard']
  verification_recovery_pct decimal(6,2) [note: 'Verification recovery percentage']
  verification_standard_result double [note: 'Verification standard result']
  verification_standard_value double [note: 'Independent verification standard value']

  Note: 'Transactional record of each instrument calibration event performed in the laboratory. Captures calibration type (initial, continuing, multi-point, single-point), calibration standard used, standard lot number and expiry, calibration curve coefficients, acceptance criteria (R² threshold, percent recovery), pass/fail result, calibration datetime, analyst performing calibration, and next calibration due date. Required for data defensibility under NELAC/TNI accreditation and EPA method requirements. [SSOT: Canonical instrument calibration; quality.quality_instrument_calibration references this as SSOT] [SSOT: governed by quality.quality_instrument_calibration] [DEPRECATED: Single source of truth is quality.quality_instrument_calibration]'
}

Table laboratory.qc_batch {
  qc_batch_id varchar [pk, note: 'Unique identifier for the quality control batch record. Primary key.']
  certified_analyst_id varchar [note: 'Reference to the certified laboratory analyst who performed the analytical work for this batch. Ensures traceability and accountability for test results.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: QC batch costs (reference standards, control samples, analyst time) represent laboratory overhead that must be allocated to a cost center for overhead rate calculation and indirect cost distribution. ']
  lab_instrument_id varchar [note: 'Reference to the analytical instrument used for this batch. Links to instrument calibration records and maintenance history.']
  qc_employee_id varchar [note: 'Reference to the laboratory supervisor or QA officer who reviewed and approved the batch QC results. Ensures accountability for data validation decisions.']
  reviewer_employee_id varchar [note: 'Reference to the laboratory supervisor or QA officer who reviewed and approved the batch QC results. Ensures accountability for data validation decisions.']
  test_method_id varchar [note: 'Reference to the analytical test method applied to all samples in this QC batch. Ensures all samples are processed under the same standardized procedure.']
  batch_completion_datetime timestamp [note: 'Date and time when all analytical work for the batch was completed and results were recorded. Used to calculate batch processing time and ensure timely reporting.']
  batch_number varchar [note: 'Human-readable unique batch identifier assigned by the laboratory information management system (LIMS). Used for tracking and referencing in laboratory documentation and chain of custody records.']
  batch_preparation_datetime decimal(18,6) [note: 'Date and time when the batch preparation or analytical run was initiated. Critical for hold time compliance and method-specific timing requirements.']
  batch_review_datetime timestamp [note: 'Date and time when the QC batch was reviewed and acceptance status was assigned by the laboratory supervisor or quality assurance officer.']
  batch_size varchar [note: 'Total number of samples (including field samples and QC samples) processed together in this batch. Used to verify batch integrity and compliance with method-specific batch size limits.']
  batch_type varchar [note: 'Classification of the QC batch based on the laboratory process stage. Preparation batch groups samples undergoing initial preparation; analytical batch groups samples analyzed together under identical conditions; extraction/digestion batches are specific to sample matrix processing.']
  corrective_action_required boolean [note: 'Indicates whether QC failures or deviations in this batch require formal corrective action per laboratory quality management system. Triggers corrective action workflow.']
  created_timestamp timestamp [note: 'Timestamp when this QC batch record was first created in the data system. Part of audit trail for data lineage and compliance.']
  duplicate_acceptance_status varchar [note: 'QC acceptance status for the duplicate sample based on RPD limits. Fail status may indicate sample heterogeneity or analytical imprecision.']
  duplicate_relative_percent_difference decimal(5,2) [note: 'Calculated RPD between original and duplicate field samples. Measures precision of the entire analytical process including sample heterogeneity.']
  duplicate_sample_included boolean [note: 'Indicates whether a duplicate field sample was analyzed in this batch. Duplicates assess overall analytical precision for unspiked samples.']
  field_sample_count varchar [note: 'Number of actual field samples (non-QC samples) included in this batch. Excludes method blanks, laboratory control samples, and other QC samples.']
  lcs_acceptance_status varchar [note: 'QC acceptance status for the LCS based on percent recovery limits. Fail status indicates systematic bias and may require corrective action or batch reanalysis.']
  lcs_expected_value decimal(18,6) [note: 'Known or true concentration of the analyte in the laboratory control sample. Used to calculate percent recovery.']
  lcs_included boolean [note: 'Indicates whether a laboratory control sample was included in this batch. LCS is a known-concentration standard used to verify method accuracy and instrument performance.']
  lcs_measured_value decimal(18,6) [note: 'Analytical result obtained for the laboratory control sample. Compared against expected value to calculate percent recovery.']
  lcs_percent_recovery decimal(5,2) [note: 'Calculated percent recovery for the LCS: (measured_value / expected_value) * 100. Must fall within method-specific acceptance limits (typically 80-120%) to validate batch accuracy.']
  lims_batch_code varchar [note: 'External batch identifier from the laboratory information management system (LabWare or similar). Used for integration and cross-system traceability.']
  matrix_spike_acceptance_status varchar [note: 'QC acceptance status for the matrix spike based on percent recovery limits. Fail status may indicate matrix interference requiring method modification or result qualification.']
  matrix_spike_duplicate_included boolean [note: 'Indicates whether a matrix spike duplicate was included in this batch. MSD is a second spiked aliquot of the same sample used to assess analytical precision through relative percent difference (RPD) calculation.']
  matrix_spike_included boolean [note: 'Indicates whether a matrix spike sample was included in this batch. Matrix spike is a field sample spiked with known analyte concentration to assess matrix interference and method accuracy in real sample matrices.']
  matrix_spike_percent_recovery decimal(5,2) [note: 'Calculated percent recovery for the matrix spike. Evaluates the effect of sample matrix on analytical accuracy. Acceptance limits are method-specific.']
  method_blank_acceptance_status varchar [note: 'QC acceptance status for the method blank based on method-specific criteria. Fail status indicates contamination and may require batch reanalysis.']
  method_blank_included boolean [note: 'Indicates whether a method blank (reagent blank) was included in this batch. Method blanks are required to detect contamination from reagents, glassware, or the analytical process.']
  method_blank_result decimal(18,6) [note: 'Analytical result for the method blank. Should be below the method detection limit (MDL) to confirm no contamination. Elevated blank results may invalidate the entire batch.']
  modified_timestamp timestamp [note: 'Timestamp when this QC batch record was last modified. Tracks data changes for audit and quality assurance purposes.']
  msd_acceptance_status varchar [note: 'QC acceptance status for the MSD based on RPD limits. Fail status indicates poor precision and may require investigation or reanalysis.']
  msd_percent_recovery decimal(5,2) [note: 'Calculated percent recovery for the matrix spike duplicate. Used in conjunction with MS recovery to calculate relative percent difference.']
  msd_relative_percent_difference decimal(5,2) [note: 'Calculated RPD between matrix spike and matrix spike duplicate: |MS - MSD| / ((MS + MSD) / 2) * 100. Measures analytical precision; must meet method-specific limits (typically <20%).']
  overall_batch_acceptance_status varchar [note: 'Final QC acceptance status for the entire batch based on all QC sample results. Accepted batches have all QC criteria met; rejected batches require reanalysis; conditional batches may have qualified results.']
  qc_comments varchar [note: 'Free-text field for documenting QC issues, corrective actions taken, deviations from standard procedures, or explanations for conditional acceptance. Critical for audit trail and regulatory compliance.']
  surrogate_acceptance_status varchar [note: 'QC acceptance status for surrogate standards based on recovery limits. Fail status may indicate sample preparation problems or matrix interference.']
  surrogate_included boolean [note: 'Indicates whether surrogate standards were added to all samples in this batch. Surrogates are analyte-like compounds added before sample processing to monitor extraction and analytical efficiency.']
  surrogate_percent_recovery decimal(5,2) [note: 'Average percent recovery for surrogate standards across the batch. Used to assess sample preparation and extraction efficiency. Method-specific acceptance limits apply.']

  Note: 'Quality control batch record grouping a set of analytical tests processed together under the same QC conditions. Defines the batch type (preparation batch, analytical batch), associated test method, batch size, batch preparation datetime, analyst, and the QC samples included (method blank, laboratory control sample, matrix spike, matrix spike duplicate, surrogate). Tracks overall batch acceptance status based on QC acceptance criteria and is the primary unit for QC review and data validation in the laboratory. Batch failure triggers corrective action and may require re-analysis of all associated samples.'
}

Table laboratory.qc_sample {
  qc_sample_id varchar [pk, note: 'Unique identifier for the quality control sample record. Primary key.']
  analyte_id varchar [note: 'Reference to the specific analyte or parameter being measured in this QC sample (e.g., lead, chlorine, pH, Total Organic Carbon (TOC), Biochemical Oxygen Demand (BOD)).']
  lab_instrument_id varchar [note: 'Reference to the laboratory instrument used for this QC sample analysis. Links to instrument calibration and maintenance records.']
  lab_sample_id varchar [note: 'Reference to the associated environmental or production sample when applicable (e.g., for matrix spike or field duplicate QC types). Null for method blanks and laboratory control samples.']
  primary_qc_certified_analyst_id varchar [note: 'Reference to the certified laboratory analyst who performed the QC sample analysis. Required for chain of custody and accreditation compliance.']
  qc_batch_id varchar [note: 'Reference to the QC batch that contains this QC sample. Links to the parent batch for traceability.']
  test_method_id varchar [note: 'Reference to the analytical test method applied to this QC sample. Links to the standard operating procedure and method specifications.']
  accreditation_body varchar [note: 'Name of the accreditation body or state certification program under which this QC sample was analyzed (e.g., state drinking water laboratory certification program, NELAP, A2LA). Required for regulatory reporting and audit trail.']
  analysis_date date [note: 'Date the QC sample was analyzed in the laboratory. Used to verify compliance with method-specific holding time requirements and to track batch chronology.']
  analysis_timestamp timestamp [note: 'Precise date and time the QC sample analysis was completed. Provides detailed audit trail for Laboratory Information Management System (LIMS) integration and regulatory reporting.']
  concentration_unit decimal(18,6) [note: 'Unit of measure for the expected and measured concentration values. Common units include milligrams per liter (mg/L), micrograms per liter (ug/L), nanograms per liter (ng/L), parts per million (ppm), parts per billion (ppb), parts per trillion (ppt), Nephelometric Turbidity Units (NTU), Colony Forming Units per 100 milliliters (CFU/100mL), Most Probable Number per 100 milliliters (MPN/100mL), pH units, percent, and Standard Units (SU). [ENUM-REF-CANDIDATE: mg/L|ug/L|ng/L|ppm|ppb|ppt|NTU|CFU/100mL|MPN/100mL|pH_units|percent|SU — 12 candidates stripped; promote to reference product]']
  corrective_action_required boolean [note: 'Boolean flag indicating whether corrective action is required based on QC sample failure. True if the QC failure necessitates re-analysis, method adjustment, or other corrective measures; false otherwise.']
  corrective_action_taken varchar [note: 'Description of corrective action taken in response to QC sample failure. May include re-analysis, instrument recalibration, method modification, or sample re-collection. Required for laboratory accreditation and audit trail.']
  created_timestamp timestamp [note: 'Timestamp when this QC sample record was first created in the data warehouse. Part of the audit trail for data lineage and compliance.']
  detection_limit decimal(18,6) [note: 'Method Detection Limit (MDL) for the analyte and test method at the time of analysis. Represents the minimum concentration that can be measured and reported with 99% confidence that the analyte is greater than zero.']
  dilution_factor decimal(10,4) [note: 'Dilution factor applied to the QC sample during preparation or analysis. A value of 1.0 indicates no dilution; values greater than 1.0 indicate the sample was diluted. Used to back-calculate original concentrations.']
  expected_concentration decimal(18,6) [note: 'The known or target concentration value for the QC sample. For LCS and CRM, this is the certified value; for matrix spikes, this is the spiked amount plus the native sample concentration; for blanks, this is typically zero.']
  lims_sample_number varchar [note: 'Unique sample identifier assigned by the Laboratory Information Management System (LIMS), such as LabWare. Used for integration and cross-referencing between the data warehouse and the operational LIMS system.']
  lower_acceptance_limit decimal(8,3) [note: 'Lower bound of the acceptable range for percent recovery or Relative Percent Difference (RPD). Defined by the analytical method, laboratory Standard Operating Procedure (SOP), or regulatory requirement. QC samples below this limit fail acceptance criteria.']
  measured_concentration decimal(18,6) [note: 'The actual concentration value obtained from laboratory analysis of the QC sample. Used to calculate recovery and evaluate method performance.']
  modified_timestamp timestamp [note: 'Timestamp when this QC sample record was last modified in the data warehouse. Tracks data lineage and supports audit trail requirements.']
  native_concentration decimal(18,6) [note: 'Original concentration of the analyte in the sample before spiking, applicable to matrix spike and matrix spike duplicate QC types. Used in recovery calculations: recovery = (measured - native) / spike * 100.']
  percent_recovery decimal(8,3) [note: 'Calculated percent recovery of the QC sample, computed as (measured_concentration / expected_concentration) * 100. Indicates the accuracy of the analytical method. Typically evaluated against acceptance limits defined in the method or laboratory QA plan.']
  proficiency_test_flag boolean [note: 'Boolean flag indicating whether this QC sample is part of an external proficiency testing program (e.g., EPA Water Pollution Performance Evaluation Studies, AWWA proficiency testing). True if part of proficiency testing; false for routine internal QC.']
  proficiency_test_provider varchar [note: 'Name of the external proficiency testing provider if this QC sample is part of a proficiency test (e.g., EPA, AWWA, Environmental Resource Associates). Null for routine internal QC samples.']
  qc_comments varchar [note: 'Free-text comments from the analyst or quality assurance officer regarding the QC sample. May include notes on anomalies, corrective actions taken, reasons for failure, or special handling procedures.']
  qc_sample_type varchar [note: 'Type of quality control sample. Method blank verifies absence of contamination; Laboratory Control Sample (LCS) verifies method accuracy; Matrix Spike (MS) and Matrix Spike Duplicate (MSD) verify matrix interference and precision; field duplicate and field blank verify field collection procedures; surrogate spike verifies extraction efficiency; Certified Reference Material (CRM) verifies instrument calibration. [ENUM-REF-CANDIDATE: method_blank|laboratory_control_sample|matrix_spike|matrix_spike_duplicate|field_duplicate|field_blank|surrogate_spike|certified_reference_material — 8 candidates stripped; promote to reference product]']
  qc_status varchar [note: 'Pass/fail status of the QC sample based on comparison of percent recovery or Relative Percent Difference (RPD) against acceptance limits. Pass indicates the QC sample met all acceptance criteria; fail indicates one or more criteria were not met; warning indicates results are marginal; pending_review indicates awaiting quality assurance officer review; not_applicable for QC types without numeric acceptance criteria.']
  relative_percent_difference decimal(8,3) [note: 'Relative Percent Difference between duplicate QC samples (e.g., matrix spike and matrix spike duplicate, or field duplicates). Calculated as absolute difference divided by the mean, multiplied by 100. Measures precision and reproducibility of the analytical method.']
  reporting_limit decimal(18,6) [note: 'Reporting Limit (RL) or Practical Quantitation Limit (PQL) for the analyte and test method. The minimum concentration that can be reliably quantified and reported to regulatory agencies. Typically 3-5 times the Method Detection Limit (MDL).']
  review_date date [note: 'Date the QC sample results were reviewed and validated by the quality assurance officer. Part of the data validation and approval workflow.']
  spike_concentration decimal(18,6) [note: 'Concentration of analyte added to the sample for matrix spike, matrix spike duplicate, or surrogate spike QC types. Null for other QC types. Used to calculate percent recovery in the presence of sample matrix.']
  upper_acceptance_limit decimal(8,3) [note: 'Upper bound of the acceptable range for percent recovery or Relative Percent Difference (RPD). Defined by the analytical method, laboratory Standard Operating Procedure (SOP), or regulatory requirement. QC samples above this limit fail acceptance criteria.']

  Note: 'Record for each quality control sample included in a QC batch. Captures QC sample type (method blank, laboratory control sample LCS, matrix spike MS, matrix spike duplicate MSD, field duplicate, field blank, surrogate spike, certified reference material CRM), expected concentration, measured concentration, percent recovery, relative percent difference RPD, acceptance limits, and pass/fail status. Provides the QA/QC evidence trail required for data validation and laboratory accreditation.'
}

Table laboratory.certified_analyst {
  certified_analyst_id varchar [pk, note: 'Unique identifier for the certified laboratory analyst record. Primary key for the certified analyst entity.']
  certified_employee_id varchar [note: 'Reference to the employee ID of the analysts direct supervisor or laboratory manager. Used for organizational hierarchy and approval workflows.']
  primary_certified_employee_id varchar [note: 'Reference to the employee record in the workforce domain. Links the laboratory certification record to the underlying employee master data.']
  analyst_first_name varchar [note: 'First name of the certified laboratory analyst. Used for identification on laboratory reports and chain of custody documentation.']
  analyst_last_name varchar [note: 'Last name of the certified laboratory analyst. Used for identification on laboratory reports and chain of custody documentation.']
  analyst_middle_initial varchar [note: 'Middle initial of the certified laboratory analyst. Optional field for complete name identification.']
  background_check_date date [note: 'Date of the most recent background check or security clearance verification. Required for analysts working with sensitive data or in facilities subject to security regulations.']
  certification_level varchar [note: 'Hierarchical level or grade of the certification indicating the complexity of analytical work the analyst is authorized to perform. Higher levels typically authorize more complex testing methods and supervisory responsibilities.']
  certification_number varchar [note: 'Unique certification number or license number issued by the certifying body. This is the official credential identifier that must be referenced on laboratory reports and regulatory submissions.']
  certification_status varchar [note: 'Current lifecycle status of the certification. Active certifications authorize the analyst to perform regulated work; expired, suspended, or revoked certifications prohibit such work until reinstated.']
  certification_type varchar [note: 'Type of laboratory certification held by the analyst. Categories include state drinking water analyst certification, wastewater operator certification, NELAC (National Environmental Laboratory Accreditation Conference) signatory authority, laboratory director certification, quality assurance officer certification, or specialty method certification.']
  certifying_body varchar [note: 'Name of the organization or agency that issued the certification. Examples include state environmental agencies, EPA regional offices, NELAC accreditation bodies, or professional associations such as AWWA or WEF.']
  continuing_education_hours decimal(6,2) [note: 'Total number of continuing education hours or professional development units earned by the analyst in the current certification period. Required for certification renewal.']
  created_timestamp timestamp [note: 'Timestamp when this certified analyst record was first created in the system. Part of the audit trail for data lineage and compliance tracking.']
  email_address varchar [note: 'Primary email address for the analyst. Used for official communications, training notifications, and certification renewal reminders.']
  emergency_contact_phone varchar [note: 'Emergency contact phone number for the analyst. Used for urgent notifications related to laboratory incidents, sample integrity issues, or regulatory inquiries.']
  expiration_date date [note: 'Date on which the certification expires and must be renewed. Critical for compliance tracking to ensure only currently certified analysts perform regulated analytical work.']
  instrument_qualifications varchar [note: 'Comma-separated list of laboratory instruments the analyst is trained and qualified to operate. Examples include ICP-MS (Inductively Coupled Plasma Mass Spectrometry), GC-MS (Gas Chromatography Mass Spectrometry), IC (Ion Chromatography), UV-Vis spectrophotometer, TOC (Total Organic Carbon) analyzer, etc.']
  is_active boolean [note: 'Boolean flag indicating whether this certified analyst record is currently active. Inactive records represent analysts who have left the organization or whose certifications are no longer maintained.']
  issue_date date [note: 'Date on which the certification was originally issued to the analyst. Used to calculate tenure and experience with the certification.']
  laboratory_assignment varchar [note: 'Name or code of the laboratory facility or work center where the analyst is primarily assigned. Examples include Central Laboratory, WTP (Water Treatment Plant) Lab, WWTP (Wastewater Treatment Plant) Lab, or Field Testing Unit.']
  last_modified_timestamp timestamp [note: 'Timestamp when this certified analyst record was most recently updated. Part of the audit trail for data lineage and compliance tracking.']
  last_proficiency_test_date date [note: 'Date of the most recent proficiency testing event completed by the analyst. Used to track compliance with annual or semi-annual PT requirements.']
  lims_user_code varchar [note: 'User identifier for the analyst in the Laboratory Information Management System (LabWare or similar). Links the certification record to the analysts login and activity in the LIMS for audit trail and data integrity purposes.']
  notes varchar [note: 'Free-text field for additional notes, comments, or special conditions related to the analysts certification or qualifications. May include restrictions, accommodations, or historical context.']
  proficiency_testing_status varchar [note: 'Status of the analysts participation in proficiency testing programs. Proficiency testing is required for NELAC accreditation and demonstrates the analysts ability to produce accurate results. Current status indicates successful completion of required PT samples.']
  quality_control_role varchar [note: 'Role of the analyst in the laboratorys quality assurance and quality control program. Roles include bench analyst, data reviewer, QA officer, or technical director with oversight responsibilities.']
  record_source varchar [note: 'Identifier of the source system from which this certified analyst record originated. Examples include LIMS (LabWare), SAP HR, or manual certification tracking system.']
  renewal_date date [note: 'Date on which the certification was most recently renewed. Tracks the analysts compliance with continuing education and renewal requirements.']
  safety_training_date date [note: 'Date of the most recent laboratory safety training completion. Required annually for OSHA compliance and includes topics such as chemical hygiene, hazardous waste handling, and emergency response.']
  shift_assignment varchar [note: 'Work shift to which the analyst is assigned. Relevant for 24/7 laboratory operations and emergency response coverage.']
  signatory_authority boolean [note: 'Boolean flag indicating whether the analyst has signatory authority to approve and sign laboratory reports for regulatory submission. Signatory authority is typically restricted to senior analysts or laboratory directors who meet specific qualification criteria.']
  specialty_areas varchar [note: 'Comma-separated list of analytical specialty areas or matrices the analyst is qualified to work with. Examples include drinking water microbiology, wastewater metals, organic compounds, radiochemistry, or specific contaminant groups such as PFAS (Per- and Polyfluoroalkyl Substances) or DBPs (Disinfection Byproducts).']

  Note: 'Master record for each laboratory analyst holding certifications relevant to water and wastewater analytical work. Captures analyst name, employee reference, certification type (state drinking water analyst certification, wastewater operator certification, NELAC signatory authority), certifying body, certification number, issue date, expiration date, renewal status, and approved test methods the analyst is qualified to perform. Distinct from the workforce domain employee record; this entity owns the laboratory-specific certification and method authorization data.'
}

Table laboratory.lab_accreditation {
  lab_accreditation_id varchar [pk, note: 'Unique identifier for the laboratory accreditation record. Primary key.']
  laboratory_id varchar [note: 'Foreign key linking to laboratory.laboratory. Business justification: Each accreditation record belongs to a specific laboratory; adding laboratory_id FK enables direct navigation and eliminates need to infer via other tables. No existing FK from laboratory to lab_accre']
  accreditation_certificate_number varchar [note: 'The unique certificate number issued by the accrediting body for this accreditation.']
  accreditation_cost_usd decimal(12,2) [note: 'The total cost in US dollars for obtaining and maintaining this accreditation, including application fees, assessment fees, and proficiency testing costs.']
  accreditation_document_url varchar [note: 'URL or file path to the digital copy of the accreditation certificate and scope document.']
  accreditation_scope_description varchar [note: 'Detailed description of the accreditation scope, including the list of accredited analytes, matrices, and test methods covered under this accreditation.']
  accreditation_status varchar [note: 'Current status of the accreditation (active, suspended, revoked, expired, pending, provisional).']
  accreditation_type varchar [note: 'The type or program of accreditation granted (e.g., state primacy, NELAC/TNI, A2LA, DoD ELAP, ISO 17025).']
  conditions_or_deficiencies_noted varchar [note: 'Any conditions, limitations, or deficiencies noted by the accrediting body during the last assessment. May include corrective action requirements.']
  corrective_action_due_date date [note: 'The deadline by which corrective actions must be completed and submitted to the accrediting body.']
  corrective_action_required_flag boolean [note: 'Indicates whether corrective action is required to maintain or restore accreditation status.']
  created_timestamp timestamp [note: 'Timestamp when this accreditation record was first created in the system.']
  initial_accreditation_date date [note: 'The date when the laboratory first received this accreditation from the accrediting body.']
  last_modified_timestamp timestamp [note: 'Timestamp when this accreditation record was last updated in the system.']
  next_assessment_due_date date [note: 'The scheduled date for the next on-site or surveillance assessment by the accrediting body.']

  Note: 'Master record for the laboratorys accreditation and certification status with regulatory and accrediting bodies. Captures accrediting organization (state primacy agency, NELAC/TNI, A2LA, DoD ELAP), accreditation scope (list of accredited analytes and matrices), certificate number, accreditation status, initial accreditation date, current certificate expiry, last on-site assessment date, next assessment due date, and any conditions or deficiencies noted. Critical for demonstrating regulatory defensibility of analytical data.'
}

Table laboratory.proficiency_test {
  proficiency_test_id varchar [pk, note: 'Unique identifier for the proficiency testing study participation event.']
  analyte_id varchar [note: 'Reference to the analyte or parameter tested (e.g., lead, pH, total coliform).']
  certified_analyst_id varchar [note: 'Reference to the certified analyst who performed the proficiency test analysis.']
  compliance_corrective_action_id varchar [note: 'Reference to the corrective action record initiated in response to proficiency test failure.']
  lab_instrument_id varchar [note: 'Reference to the laboratory instrument used for the proficiency test analysis.']
  laboratory_id varchar [note: 'Reference to the laboratory that participated in this proficiency test.']
  primary_proficiency_lab_sample_id varchar [note: 'Unique sample identifier assigned by the proficiency test provider.']
  proficiency_employee_id varchar [note: 'Reference to the quality assurance officer or supervisor who reviewed the proficiency test results.']
  proficiency_reviewed_by_employee_id varchar [note: 'Reference to the quality assurance officer or supervisor who reviewed the proficiency test results.']
  pt_provider_id varchar [note: 'Reference to the proficiency testing provider organization (ERA, NERL, LGC, etc.).']
  test_method_id varchar [note: 'Reference to the analytical test method used for this proficiency test.']
  vendor_id varchar [note: 'Reference to the proficiency testing provider organization (ERA, NERL, LGC, etc.).']
  acceptance_criteria varchar [note: 'Acceptance limits or criteria defined by the proficiency test provider (e.g., z-score ±2.0, recovery 80-120%).']
  accreditation_field varchar [note: 'Field of accreditation or testing category this proficiency test supports (e.g., Drinking Water Chemistry, Microbiology).']
  accreditation_impact varchar [note: 'Assessment of the impact of this proficiency test result on laboratory accreditation status.']
  analysis_date date [note: 'Date the proficiency test sample was analyzed by the laboratory.']
  assigned_value decimal(18,6) [note: 'True or reference concentration value assigned by the proficiency test provider.']
  comments varchar [note: 'Additional comments or notes regarding the proficiency test participation, analysis, or results.']
  corrective_action_required boolean [note: 'Indicates whether corrective action is required due to proficiency test failure or unacceptable performance.']
  created_timestamp timestamp [note: 'Timestamp when this proficiency test record was first created in the system.']
  modified_timestamp timestamp [note: 'Timestamp when this proficiency test record was last modified.']
  participant_count varchar [note: 'Number of laboratories that participated in this proficiency test round.']
  peer_group_mean decimal(18,6) [note: 'Mean value reported by all participating laboratories in the peer group.']
  peer_group_standard_deviation decimal(18,6) [note: 'Standard deviation of values reported by all participating laboratories in the peer group.']
  percentile_rank decimal(5,2) [note: 'Percentile ranking of the laboratorys performance relative to all participants (0-100).']
  performance_score decimal(10,4) [note: 'Alternative performance metric used by some proficiency test providers (e.g., percent recovery, bias).']
  pt_round varchar [note: 'Round or cycle identifier for the proficiency test (e.g., 2024-Q1, Round 45).']
  pt_study_name varchar [note: 'Name of the proficiency testing study or program (e.g., WP-123, DMR-QA).']
  report_receipt_date date [note: 'Date the laboratory received the final proficiency test report from the provider.']
  reported_value decimal(18,6) [note: 'Concentration value reported by the laboratory for the proficiency test sample.']
  result_status varchar [note: 'Pass/fail determination or acceptability status of the proficiency test result.']
  review_date date [note: 'Date the proficiency test results were reviewed and approved by quality assurance.']
  sample_matrix varchar [note: 'Type of sample matrix tested in the proficiency test. [ENUM-REF-CANDIDATE: drinking_water|wastewater|surface_water|groundwater|soil|sediment|sludge|biosolids|other — 9 candidates stripped; promote to reference product]']
  sample_receipt_date date [note: 'Date the proficiency test sample was received by the laboratory.']
  submission_date date [note: 'Actual date the laboratory submitted results to the proficiency test provider.']
  submission_deadline date [note: 'Deadline date by which the laboratory must submit results to the proficiency test provider.']
  unit_of_measure varchar [note: 'Unit of measure for the assigned and reported values (e.g., mg/L, ug/L, NTU, pH units).']
  z_score decimal(10,4) [note: 'Statistical z-score calculated from the reported value, assigned value, and standard deviation, indicating performance relative to peer laboratories.']

  Note: 'Record of each proficiency testing (PT) study participation event required to maintain laboratory accreditation. Captures the PT provider (ERA, NERL, LGC), study name and round, analyte(s) tested, sample matrix, assigned value (true concentration), reported value, z-score or performance score, pass/fail determination, and submission deadline. Tracks the laboratorys ongoing demonstration of analytical competency as required by NELAC/TNI and state primacy agencies.'
}

Table laboratory.result_validation {
  result_validation_id varchar [pk, note: 'Unique identifier for the result validation record. Primary key.']
  analytical_result_id varchar [note: 'Foreign key linking to quality.analytical_result. Business justification: Laboratory\'s result_validation process validates quality domain\'s analytical_result records. Data validation workflow (Level II/III review) requires linking validation findings to final reported resul']
  primary_result_employee_id varchar [note: 'Reference to the certified analyst or data validator who performed the validation review. Must be a qualified individual per laboratory QA/QC protocols.']
  result_employee_id varchar [note: 'Reference to the certified analyst or data validator who performed the validation review. Must be a qualified individual per laboratory QA/QC protocols.']
  reviewer_employee_id varchar [note: 'Reference to a secondary reviewer or quality assurance officer who performed independent review of the validation. Used in laboratories with multi-tier validation protocols.']
  reviewer_id varchar [note: 'Reference to a secondary reviewer or quality assurance officer who performed independent review of the validation. Used in laboratories with multi-tier validation protocols.']
  test_result_id varchar [note: 'Reference to the test result record being validated. Links to the laboratory test result that underwent this validation review.']
  validation_batch_id varchar [note: 'Reference to the validation batch if multiple results were validated together. Enables grouping of validation activities performed in a single review session.']
  approval_required_flag boolean [note: 'Indicates whether this validation requires formal approval by a laboratory director or quality assurance manager before data release. True if approval is required, False if validator authority is sufficient.']
  approval_timestamp timestamp [note: 'Date and time when the validation was formally approved for data release. Applicable when approval_required_flag is True.']
  calibration_verification_flag boolean [note: 'Indicates whether instrument calibration was current and verified at the time of analysis. True if calibration was valid, False if calibration issues were identified.']
  chain_of_custody_verified_flag boolean [note: 'Indicates whether the chain of custody documentation was complete and verified during validation. True if COC is intact and verified, False if discrepancies were found.']
  created_timestamp timestamp [note: 'Date and time when this validation record was first created in the system. Audit trail field for data lineage and compliance tracking.']
  data_release_timestamp timestamp [note: 'Date and time when the validated result was released for regulatory reporting, customer delivery, or internal use. Marks the completion of the validation and approval workflow.']
  flags_raised_count varchar [note: 'Number of quality flags or warnings raised during validation. Flags may indicate potential issues that do not necessarily result in rejection but require documentation.']
  holding_time_compliance_flag boolean [note: 'Indicates whether the sample holding time requirements were met per EPA method specifications. True if compliant, False if holding time was exceeded.']
  method_compliance_flag boolean [note: 'Indicates whether the analytical method was performed in full compliance with the approved EPA or Standard Method protocol. True if compliant, False if deviations occurred.']
  modified_by varchar [note: 'User ID or name of the person who last modified this validation record. Audit trail field for tracking changes and maintaining data integrity.']
  modified_timestamp timestamp [note: 'Date and time when this validation record was last modified. Audit trail field for tracking changes to validation decisions or documentation.']
  qc_acceptance_criteria_met_flag boolean [note: 'Indicates whether all quality control acceptance criteria (blanks, duplicates, spikes, surrogates, calibration verification) were met for this result. True if all QC passed, False if any QC failure occurred.']
  qualifiers_applied varchar [note: 'Data qualifiers or flags assigned to the result during validation. Common qualifiers include J (estimated value), U (non-detect), R (rejected), Q (quality control issue). Multiple qualifiers may be comma-separated.']
  regulatory_defensibility_flag boolean [note: 'Indicates whether the validated result meets the full defensibility standard required for regulatory reporting and potential legal proceedings. True if defensible, False if data quality issues compromise defensibility.']
  regulatory_program varchar [note: 'The regulatory program or compliance framework under which this validation was performed. Examples: SDWA compliance monitoring, NPDES permit monitoring, CWA industrial pretreatment, state-specific programs.']
  results_rejected_count varchar [note: 'Number of individual test results rejected during this validation review. Used for quality metrics and laboratory performance tracking.']
  review_timestamp timestamp [note: 'Date and time when the secondary review was completed. Applicable when laboratory protocols require independent QA review of validation decisions.']
  validation_criteria_applied varchar [note: 'Description of the specific validation criteria, checklists, or protocols applied during the review. May reference EPA method requirements, laboratory SOP numbers, or regulatory program-specific validation rules.']
  validation_disposition varchar [note: 'Final outcome of the validation review. Accepted: result meets all quality criteria and is released without qualification. Qualified: result is usable but carries data qualifiers or flags. Rejected: result fails validation and cannot be used for regulatory reporting.']
  validation_duration_minutes decimal(18,6) [note: 'Total time in minutes spent performing the validation review. Used for laboratory productivity metrics and resource planning.']
  validation_findings varchar [note: 'Detailed narrative of validation findings, issues identified, corrective actions taken, and rationale for the final disposition. Critical for regulatory audit trail and data defensibility.']
  validation_level varchar [note: 'The EPA validation protocol level applied to this result. Level I: basic data verification; Level II: analytical QC review; Level III: method and holding time compliance; Level IV: full data package audit for regulatory defensibility.']
  validation_notes varchar [note: 'Additional notes, comments, or observations recorded by the validator during the review process. May include references to supporting documentation, communications with analysts, or special circumstances.']
  validation_status varchar [note: 'Current workflow status of the validation process. Tracks whether the validation review is pending, in progress, completed, or on hold pending additional information.']
  validation_timestamp timestamp [note: 'Date and time when the validation review was completed. Critical for establishing data release timeline and regulatory reporting deadlines.']
  validator_certification_number varchar [note: 'Professional certification or license number of the validator. Required for regulatory defensibility under SDWA and CWA compliance programs.']
  validator_name varchar [note: 'Full name of the validator who performed the review. Provides human-readable identification for audit trail and regulatory reporting.']
  created_by varchar [note: 'User ID or name of the person who created this validation record. Audit trail field for accountability and data governance.']

  Note: 'Record of the formal data validation review applied to a set of test results before release. Captures the validation level (level I through IV per EPA validation protocols), validator identity, validation datetime, validation criteria applied, findings (qualifiers applied, results rejected, flags raised), and final validation disposition (accepted, qualified, rejected). Ensures that all data released for regulatory reporting meets defensibility standards under SDWA, CWA, and NPDES requirements.'
}

Table laboratory.reagent_standard {
  reagent_standard_id varchar [pk, note: 'Unique identifier for the laboratory reagent or chemical standard record. Primary key for the reagent standard master inventory.']
  general_ledger_id varchar [note: 'Foreign key linking to finance.general_ledger. Business justification: Reagent and standard purchases must be expensed to specific GL accounts (lab supplies, chemicals) for inventory management, monthly expense recognition, and financial reporting. Required for GASB-comp']
  prepared_by_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: QC/QA protocols require documented employee accountability for reagent preparation. Accreditation standards (TNI, NELAC) mandate traceable preparation records linking to qualified employees for method']
  vendor_id varchar [note: 'Foreign key linking to supply.vendor. Business justification: Reagents and certified reference materials are procured from chemical suppliers. Tracking vendor is essential for COA verification, lot traceability, reordering, and quality control. Replaces denormal']
  associated_test_methods varchar [note: 'Comma-separated list of analytical test method codes or names for which this reagent or standard is used. Supports traceability of reagents to specific analytical procedures and regulatory compliance demonstrations.']
  cas_number varchar [note: 'Unique numerical identifier assigned by the Chemical Abstracts Service to every chemical substance described in the open scientific literature. Used for unambiguous identification of reagents and standards.']
  catalog_number varchar [note: 'Manufacturer or supplier catalog number for the reagent or standard. Used for reordering and traceability to supplier specifications.']
  certificate_number varchar [note: 'Certificate of analysis or certificate of conformance number provided by the manufacturer or certifying body. Documents the certified properties and traceability of the standard.']
  certified_reference_material_flag boolean [note: 'Indicates whether this standard is a certified reference material with traceability to national or international measurement standards. True if CRM, false otherwise. CRMs are required for certain regulatory compliance testing.']
  concentration_unit decimal(18,6) [note: 'Unit of measure for the concentration or purity value: milligrams per liter (mg/L), micrograms per liter (ug/L), percent (%), parts per million (ppm), parts per billion (ppb), molarity (M), or normality (N). [ENUM-REF-CANDIDATE: mg_l|ug_l|percent|ppm|ppb|molarity|normality — 7 candidates stripped; promote to reference product]']
  concentration_value decimal(18,6) [note: 'Numeric concentration or purity of the reagent or standard as certified by the manufacturer or as prepared in the laboratory. Used in calibration calculations and quality control verification.']
  created_timestamp timestamp [note: 'Date and time when this reagent standard record was first created in the Laboratory Information Management System (LIMS). Part of the audit trail.']
  current_stock_quantity decimal(12,3) [note: 'Current quantity of the reagent or standard available in laboratory inventory. Updated as material is consumed or replenished.']
  disposal_method varchar [note: 'Approved method for disposing of expired or unused reagent or standard, such as chemical waste collection, neutralization, incineration, or return to supplier. Ensures compliance with environmental and safety regulations.']
  expiry_date date [note: 'Date after which the reagent or standard should no longer be used for analytical testing due to potential degradation or loss of certified properties. Determined by manufacturer specifications or laboratory stability studies.']
  hazard_classification varchar [note: 'Safety hazard classification of the reagent according to Globally Harmonized System (GHS) or OSHA Hazard Communication Standard. Examples include flammable, corrosive, toxic, oxidizer, or non-hazardous.']
  last_calibration_date date [note: 'Date on which this standard was last used for instrument calibration or quality control verification. Supports traceability and audit trail for analytical data defensibility.']
  lot_number varchar [note: 'Manufacturer-assigned lot or batch number for the reagent or standard. Essential for traceability in the event of quality issues or recalls and for demonstrating chain of custody in regulatory audits.']
  modified_by varchar [note: 'User identifier or name of the person who last modified this reagent standard record in the Laboratory Information Management System (LIMS). Supports accountability and audit compliance.']
  modified_timestamp timestamp [note: 'Date and time when this reagent standard record was last modified in the Laboratory Information Management System (LIMS). Supports change tracking and audit compliance.']
  notes varchar [note: 'Free-text field for additional information, observations, or special handling instructions related to the reagent or standard. May include stability observations, usage restrictions, or audit findings.']
  preparation_date date [note: 'Date on which the reagent or standard was prepared or diluted in the laboratory. For commercially prepared standards, this is the manufacture date. Critical for determining shelf life and expiry.']
  reagent_name varchar [note: 'Full chemical or commercial name of the reagent, standard, or reference material as provided by the manufacturer or as catalogued in the Laboratory Information Management System (LIMS).']
  reagent_standard_status varchar [note: 'Current lifecycle status of the reagent or standard: active (in use), expired (past expiry date), depleted (stock exhausted), quarantined (under investigation or hold), or disposed (removed from inventory).']
  reagent_type varchar [note: 'Classification of the chemical material by its intended laboratory use: reagent for general analytical work, standard for calibration, reference material for quality control, buffer for pH adjustment, indicator for endpoint detection, or solvent for dilution and extraction.']
  reorder_threshold decimal(12,3) [note: 'Minimum stock quantity that triggers a reorder alert or procurement action. Ensures continuous availability of critical reagents and standards for analytical operations.']
  safety_data_sheet_reference varchar [note: 'Reference identifier or file location for the Safety Data Sheet (SDS) associated with this reagent. SDS provides hazard information, handling instructions, and emergency procedures.']
  stock_unit varchar [note: 'Unit of measure for the stock quantity: milliliters (mL), liters (L), grams (g), kilograms (kg), units, or vials.']
  storage_conditions varchar [note: 'Required environmental conditions for storing the reagent or standard to maintain stability and integrity: ambient temperature, refrigerated (2-8°C), frozen (<0°C), protected from light (dark), or under inert atmosphere.']
  storage_location varchar [note: 'Physical location within the laboratory where the reagent or standard is stored, such as refrigerator ID, cabinet number, or shelf designation. Supports inventory management and retrieval.']
  verified_by varchar [note: 'Name or identifier of the laboratory supervisor or quality assurance officer who verified the preparation or receipt of the reagent or standard. Ensures independent quality control.']
  created_by varchar [note: 'User identifier or name of the person who created this reagent standard record in the Laboratory Information Management System (LIMS). Part of the audit trail.']

  Note: 'Master inventory record for laboratory reagents, chemical standards, and reference materials used in analytical testing. Captures reagent name, CAS number, supplier, lot number, concentration or purity, preparation date, expiry date, storage conditions, current stock quantity, reorder threshold, and associated test methods. Tracks the traceability of standards used in calibration and QC to ensure analytical data defensibility. Distinct from the supply domain which manages procurement; this entity owns the in-lab inventory and traceability record.'
}

Table laboratory.analyte {
  analyte_id varchar [pk, note: 'Unique identifier for the analyte parameter. Primary key for the analyte reference catalog.']
  created_by_employee_id varchar [note: 'Foreign key linking to workforce.employee. Business justification: Regulatory parameter registry management requires employee accountability. Analyte setup affects compliance reporting and must be traceable to qualified employees for data quality assurance and regula']
  action_level_value decimal(18,6) [note: 'The concentration of a contaminant which, if exceeded, triggers treatment or other requirements. Primarily used for lead and copper under the Lead and Copper Rule Revisions (LCRR).']
  analyte_category varchar [note: 'Detailed sub-classification within the analyte group (e.g., heavy metals, volatile organic compounds, disinfection byproducts, indicator organisms).']
  analyte_code varchar [note: 'Short alphanumeric code used to identify the analyte in laboratory systems and reports. Often corresponds to LIMS internal codes or regulatory parameter codes.']
  analyte_group varchar [note: 'High-level classification of the analyte by its chemical or biological nature (inorganic, organic, microbiological, radiological, physical, emerging contaminant).']
  analyte_name varchar [note: 'Full descriptive name of the chemical, biological, or physical parameter being measured (e.g., Total Coliform, Lead, pH, Turbidity).']
  analyte_status varchar [note: 'Current status of the analyte in the laboratory catalog (active, inactive, retired, pending approval, under review).']
  astm_method_code varchar [note: 'The ASTM International standard method code(s) for measuring this analyte, if applicable. Multiple methods may be comma-separated.']
  cas_number varchar [note: 'Unique numerical identifier assigned by the Chemical Abstracts Service to chemical substances. Used for unambiguous identification of chemical analytes.']
  certified_analyst_required_flag boolean [note: 'Indicates whether analysis of this analyte must be performed by a state-certified or specially trained analyst.']
  container_type varchar [note: 'Required container material and type for sample collection (e.g., plastic bottle, glass bottle amber, sterile bag, VOA vial).']
  created_timestamp timestamp [note: 'Timestamp when this analyte record was first created in the system.']
  default_reporting_unit varchar [note: 'Standard unit of measure for reporting results for this analyte (e.g., mg/L, µg/L, CFU/100mL, NTU, pH units, pCi/L).']
  detection_limit decimal(18,6) [note: 'The minimum concentration of the analyte that can be measured and reported with 99% confidence that the analyte concentration is greater than zero, expressed in the default reporting unit.']
  effective_date date [note: 'Date when this analyte definition became effective in the laboratory catalog or when regulatory requirements took effect.']
  epa_method_code varchar [note: 'The EPA-approved analytical method code(s) for measuring this analyte (e.g., EPA 200.8, EPA 300.0, EPA 1103.1). Multiple methods may be comma-separated.']
  health_effect varchar [note: 'Summary of known or potential health effects associated with exposure to this analyte at elevated concentrations (e.g., gastrointestinal illness, neurological effects, increased cancer risk).']
  holding_time_hours varchar [note: 'Maximum time allowed between sample collection and analysis, expressed in hours, to ensure result validity and regulatory compliance.']
  lims_integration_code decimal(18,6) [note: 'The analyte identifier or code used in the LIMS (LabWare or similar) for system integration and data exchange.']
  mcl_value decimal(18,6) [note: 'The enforceable regulatory limit for this analyte in drinking water, expressed in the default reporting unit. Null if no MCL is established.']
  mclg_value decimal(18,6) [note: 'The non-enforceable health goal for this analyte in drinking water, expressed in the default reporting unit. Null if no MCLG is established.']
  minimum_sample_volume_ml varchar [note: 'Minimum volume of sample required for analysis of this analyte, expressed in milliliters.']
  modified_by varchar [note: 'User identifier or name of the person who last modified this analyte record.']
  modified_timestamp timestamp [note: 'Timestamp when this analyte record was last modified.']
  monitoring_location_type varchar [note: 'Types of monitoring locations where this analyte is typically measured (e.g., entry point to distribution system, distribution system, source water, treatment plant effluent, NPDES outfall).']
  notes varchar [note: 'Additional notes, special instructions, or comments regarding this analyte, including method-specific considerations, interferences, or regulatory updates.']
  preservation_method varchar [note: 'Required preservation technique for samples collected for this analyte (e.g., acidify to pH<2 with HNO3, cool to 4°C, add sodium thiosulfate, no preservation required).']
  proficiency_testing_required_flag boolean [note: 'Indicates whether the laboratory must participate in proficiency testing programs for this analyte to maintain accreditation and regulatory compliance.']
  qaqc_requirement varchar [note: 'Specific QA/QC protocols required for this analyte (e.g., matrix spike/matrix spike duplicate, laboratory control sample, method blank, field duplicate, proficiency testing frequency).']
  quantitation_limit decimal(18,6) [note: 'The minimum concentration at which the analyte can be reliably quantified with acceptable precision and accuracy, expressed in the default reporting unit. Typically higher than the detection limit.']
  regulatory_classification varchar [note: 'Classification of the analyte based on regulatory requirements: primary MCL (Maximum Contaminant Level), secondary MCL, NPDES (National Pollutant Discharge Elimination System) parameter, PFAS (Per- and Polyfluoroalkyl Substances), DBP (Disinfection Byproduct), DBP precursor, unregulated, or action level. [ENUM-REF-CANDIDATE: primary_mcl|secondary_mcl|npdes_parameter|pfas|dbp|dbp_precursor|unregulated|action_level — 8 candidates stripped; promote to reference product]']
  reporting_frequency varchar [note: 'Required frequency for reporting results for this analyte to regulatory agencies (daily, weekly, monthly, quarterly, annually, as required, continuous). [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annually|as_required|continuous — 7 candidates stripped; promote to reference product]']
  retirement_date date [note: 'Date when this analyte was retired from the laboratory catalog or when regulatory requirements were superseded. Null if still active.']
  sample_matrix_applicability varchar [note: 'The types of sample matrices for which this analyte is applicable (e.g., drinking water, wastewater, surface water, groundwater, biosolids, sludge). Multiple matrices may be comma-separated.']
  seasonal_monitoring_flag boolean [note: 'Indicates whether monitoring for this analyte is required only during specific seasons or months (e.g., DBP monitoring during warmer months).']
  source_of_contamination varchar [note: 'Common sources or pathways by which this analyte enters water systems (e.g., naturally occurring, industrial discharge, agricultural runoff, corrosion of household plumbing, disinfection byproduct).']
  standard_method_code varchar [note: 'The Standard Methods for the Examination of Water and Wastewater method code(s) for measuring this analyte (e.g., SM 2320 B, SM 4500-Cl G). Multiple methods may be comma-separated.']
  treatment_technology varchar [note: 'Recommended or required treatment technologies for removing or reducing this analyte (e.g., coagulation/filtration, activated carbon, reverse osmosis, ion exchange, UV disinfection, chlorination).']

  Note: 'Reference catalog of all chemical, biological, and physical parameters that the laboratory is capable of or required to measure. Captures analyte name, CAS number, analyte group (inorganic, organic, microbiological, radiological, physical), regulatory classification (primary MCL, secondary MCL, NPDES parameter, PFAS, DBP precursor), default reporting unit, and associated EPA or Standard Methods method codes. Serves as the authoritative analyte dictionary linking laboratory results to regulatory parameters across the quality and compliance domains.'
}

Table laboratory.laboratory_corrective_action {
  laboratory_corrective_action_id varchar [pk, note: 'Unique identifier for the laboratory_corrective_action data product (auto-inserted pre-linking).']
  certified_analyst_id varchar [note: 'Analyst responsible for the action']
  compliance_corrective_action_id varchar [note: 'Canonical single-source-of-truth reference to compliance.compliance_corrective_action (compliance_corrective_action_id); this entity defers authoritative attribute values to that master entity.']
  lab_instrument_id varchar [note: 'Related instrument']
  laboratory_assigned_analyst_id varchar [note: 'Assigned analyst']
  laboratory_assigned_to_employee_id varchar [note: 'FK to the employee assigned to complete the corrective action']
  laboratory_certified_analyst_id varchar [note: 'Foreign key linking to laboratory.certified_analyst. Business justification: Corrective actions are assigned to specific analysts for investigation and resolution. This N:1 relationship (many corrective actions per analyst) tracks responsibility and workload. The FK column use']
  laboratory_compliance_corrective_action_id varchar [note: 'References the single source of truth record in compliance.compliance_corrective_action']
  laboratory_verified_by_employee_id varchar [note: 'FK to the employee who verified effectiveness']
  proficiency_test_id varchar [note: 'Foreign key linking to laboratory.proficiency_test. Business justification: Corrective actions are triggered by proficiency test failures (z-score out of range, unacceptable performance). This N:1 relationship (many corrective actions per PT failure) links the corrective acti']
  qc_batch_id varchar [note: 'Foreign key linking to laboratory.qc_batch. Business justification: Corrective actions are often triggered by QC batch failures (method blank contamination, LCS recovery out of range, etc.). This N:1 relationship (many corrective actions per failed batch) links the co']
  accreditation_impact boolean [note: 'Whether accreditation was impacted']
  accreditation_impact_flag boolean [note: 'Whether the issue impacts lab accreditation']
  action_date date
  action_description varchar
  action_number varchar
  action_status varchar
  action_type varchar [note: 'Type of corrective action (reanalysis, recalibration, method review, training)']
  actual_completion_date date [note: 'Actual completion date']
  actual_cost decimal(18,2) [note: 'Actual cost']
  affected_methods varchar [note: 'Analytical methods affected']
  affected_results_count varchar
  affected_sample_count varchar [note: 'Number of samples potentially affected']
  affected_samples_count varchar
  affected_test_methods varchar [note: 'Test methods affected by the issue']
  approval_date date
  approved_by_name varchar
  assigned_to varchar [note: 'Person assigned']
  assigned_to_name varchar
  client_notification_date date [note: 'Date client notified']
  client_notification_required boolean [note: 'Whether client notification is required']
  client_notified_date date [note: 'Date client was notified']
  closed_date date
  completed_date date [note: 'Date the action was completed']
  completion_date date
  corrective_action_description varchar
  corrective_action_number varchar [note: 'Corrective action reference number.']
  corrective_action_status varchar
  corrective_action_type varchar
  corrective_measure varchar
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp
  data_quality_flag boolean [note: 'True when record passed data validation.']
  data_recall_required boolean [note: 'Whether data recall is required']
  due_date date [note: 'Due date for completion']
  effectiveness_confirmed boolean [note: 'Whether effectiveness confirmed']
  effectiveness_review_date date [note: 'Date of effectiveness review']
  effectiveness_verification_date date
  effectiveness_verified boolean [note: 'Whether effectiveness verified']
  effectiveness_verified_flag boolean
  estimated_cost decimal(18,2) [note: 'Estimated cost']
  identified_date date [note: 'Date issue identified']
  immediate_action varchar [note: 'Immediate action taken']
  impact_assessment varchar [note: 'Assessment of impact on reported results']
  initiated_date date [note: 'Date the corrective action was initiated']
  initiation_date date [note: 'Date action was initiated']
  is_closed boolean
  is_complete boolean
  is_completed boolean
  is_effective boolean
  laboratory_corrective_action_description varchar [note: 'Description of the corrective action taken']
  laboratory_corrective_action_status varchar [note: 'Current status (open, in progress, completed, verified, closed)']
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  lims_ca_code varchar
  long_term_action varchar [note: 'Long-term corrective action']
  modified_timestamp timestamp
  nonconformance_category varchar
  nonconformance_description varchar [note: 'Description of the nonconformance that triggered the action']
  nonconformance_type varchar [note: 'Type of nonconformance']
  notes varchar [note: 'Corrective action notes']
  opened_date date
  preventive_action varchar [note: 'Preventive action planned']
  preventive_action_description varchar
  preventive_measure varchar
  priority varchar [note: 'Priority (low, medium, high, critical)']
  priority_level varchar
  quality_corrective_action_id varchar [note: 'Foreign key to single source of truth quality.quality_corrective_action']
  reanalysis_completed_flag boolean
  reanalysis_required boolean [note: 'Whether sample reanalysis is required']
  reanalysis_required_flag boolean
  record_status varchar
  recurrence_prevention varchar [note: 'Steps to prevent recurrence']
  regulatory_notification_date date
  regulatory_notification_required boolean [note: 'Whether regulatory notification is required']
  regulatory_notification_required_flag boolean
  responsible_analyst varchar [note: 'Responsible analyst']
  root_cause varchar [note: 'Identified root cause of the issue']
  root_cause_analysis varchar
  root_cause_category varchar [note: 'Root cause category']
  root_cause_description varchar
  ssot_source_domain varchar [note: 'Indicates SSOT owner domain for corrective actions']
  target_completion_date date [note: 'Target completion date']
  trigger_date date [note: 'Date of trigger event']
  trigger_description varchar [note: 'Description of triggering event']
  trigger_event varchar [note: 'Event that triggered action']
  trigger_event_type varchar [note: 'Trigger type (QC_failure, PT_failure, audit_finding, complaint)']
  trigger_type varchar
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp']
  verification_date date [note: 'Date effectiveness was verified']
  verification_method varchar [note: 'Method used to verify effectiveness']
  verification_required boolean [note: 'Whether verification required']
  verified_date date

  Note: 'Record of corrective actions initiated in response to laboratory QC failures, accreditation deficiencies, proficiency test failures, or data quality issues. Captures the triggering event (QC batch failure, PT failure, customer complaint, internal audit finding), root cause analysis, corrective action description, responsible analyst or supervisor, target completion date, actual completion date, and effectiveness verification. Required for NELAC/TNI accreditation maintenance and continuous quality improvement. [SSOT: Lab-specific corrective action; quality.quality_corrective_action references this as SSOT] [SSOT: governed by compliance.compliance_corrective_action] [DEPRECATED: Single source of truth is compliance.compliance_corrective_action]'
}

Table laboratory.method_detection_limit {
  method_detection_limit_id varchar [pk, note: 'Unique identifier for the method detection limit study record. Primary key.']
  analyte_id varchar [note: 'Reference to the specific analyte (contaminant or parameter) for which the MDL study was performed.']
  certified_analyst_id varchar [note: 'Reference to the certified analyst who performed the MDL study.']
  lab_instrument_id varchar [note: 'Reference to the laboratory instrument used to perform the MDL study.']
  method_employee_id varchar [note: 'Reference to the quality assurance reviewer who validated the MDL study calculations and acceptance criteria.']
  reviewer_employee_id varchar [note: 'Reference to the quality assurance reviewer who validated the MDL study calculations and acceptance criteria.']
  test_method_id varchar [note: 'Reference to the analytical test method used in the MDL study.']
  acceptance_criteria_met_flag boolean [note: 'Boolean flag indicating whether the MDL study met all acceptance criteria (recovery range, RSD limits, replicate count).']
  accreditation_field varchar [note: 'Accreditation field of testing code or identifier that this MDL study supports.']
  analyst_certification_number varchar [note: 'Certification number of the analyst who performed the MDL study, issued by the accrediting body.']
  analyst_name varchar [note: 'Full name of the certified analyst who performed the MDL study.']
  approval_timestamp timestamp [note: 'Date and time when the MDL study was formally approved for use in laboratory reporting.']
  approved_by varchar [note: 'Name or identifier of the laboratory manager or quality officer who approved the MDL study.']
  calculated_mdl decimal(18,6) [note: 'Calculated Method Detection Limit value, determined as the standard deviation of replicate measurements multiplied by the Student\'s t-value at 99% confidence level.']
  calculated_mrl decimal(18,6) [note: 'Calculated Minimum Reporting Level (also known as Practical Quantitation Limit or PQL), typically set at 3-10 times the MDL to ensure reliable quantitation.']
  created_timestamp timestamp [note: 'Date and time when the MDL study record was first created in the system.']
  effective_end_date date [note: 'Date on which the calculated MDL and MRL values expire and a new study is required. Typically one year from the study date or when method or instrument conditions change.']
  effective_start_date date [note: 'Date from which the calculated MDL and MRL values become effective for use in laboratory reporting.']
  lims_integration_flag boolean [note: 'Boolean flag indicating whether the MDL values have been integrated into the LIMS for automated reporting limit enforcement.']
  lims_mdl_code varchar [note: 'Unique identifier for the corresponding MDL record in the Laboratory Information Management System (LabWare).']
  mdl_unit varchar [note: 'Unit of measure for the calculated MDL and MRL values.']
  mean_recovery decimal(5,2) [note: 'Mean recovery percentage of the spiked analyte across all replicates, used to assess method accuracy.']
  modified_by varchar [note: 'User identifier of the person who last modified the MDL study record.']
  modified_timestamp timestamp [note: 'Date and time when the MDL study record was last modified.']
  next_study_due_date date [note: 'Date by which the next MDL study must be conducted to maintain regulatory compliance.']
  previous_mdl_value decimal(18,6) [note: 'Previously established MDL value for comparison and trend analysis.']
  previous_mrl_value decimal(18,6) [note: 'Previously established MRL value for comparison and trend analysis.']
  regulatory_acceptance_status varchar [note: 'Regulatory acceptance status of the MDL study, indicating whether it meets EPA or state primacy agency requirements.']
  regulatory_program varchar [note: 'Regulatory program under which the MDL study is required (e.g., Safe Drinking Water Act, Clean Water Act, NPDES).']
  relative_standard_deviation_percent decimal(5,2) [note: 'Relative standard deviation (coefficient of variation) expressed as a percentage, used to assess method precision.']
  replicate_count varchar [note: 'Number of replicate samples analyzed in the MDL study. EPA requires a minimum of 7 replicates.']
  review_timestamp timestamp [note: 'Date and time when the MDL study was reviewed and validated by the quality assurance reviewer.']
  reviewer_name varchar [note: 'Full name of the quality assurance reviewer who validated the MDL study.']
  sample_matrix varchar [note: 'Type of sample matrix used in the MDL study (e.g., drinking water, wastewater, surface water).']
  spike_concentration decimal(18,6) [note: 'Concentration at which the sample matrix was spiked for the MDL study, typically 1-5 times the estimated detection limit.']
  spike_concentration_unit decimal(18,6) [note: 'Unit of measure for the spike concentration (e.g., mg/L, ug/L, ng/L).']
  standard_deviation decimal(18,6) [note: 'Standard deviation of the replicate measurements used in the MDL calculation.']
  study_date date [note: 'Date on which the method detection limit study was conducted.']
  study_notes varchar [note: 'Free-text notes documenting any special conditions, deviations, or observations during the MDL study.']
  study_reason varchar [note: 'Reason for conducting the MDL study (e.g., annual renewal, method change, instrument change, matrix change).']
  study_status varchar [note: 'Current status of the MDL study in the approval workflow.']
  t_value decimal(6,4) [note: 'Student\'s t-value at 99% confidence level for the number of replicates used in the MDL calculation.']
  created_by varchar [note: 'User identifier of the person who created the MDL study record.']

  Note: 'Record of Method Detection Limit (MDL) and Minimum Reporting Level (MRL) determinations performed for each analyte-method-instrument combination in the laboratory. Captures the study date, number of replicates, spike concentration, calculated MDL, calculated MRL/PQL, analyst, instrument used, and regulatory acceptance status. MDL studies must be conducted annually or when method or instrument conditions change, per EPA MDL procedure (40 CFR Part 136 Appendix B).'
}

Table laboratory.lab_work_order {
  lab_work_order_id varchar [pk, note: 'Unique identifier for the laboratory work order. Primary key for the work order entity.']
  certified_analyst_id varchar [note: 'Identifier of the primary certified analyst assigned to perform or oversee the analytical work for this work order.']
  cip_project_id varchar [note: 'Foreign key linking to project.cip_project. Business justification: Lab work orders are issued for project-specific testing campaigns (construction water quality monitoring, commissioning testing, post-construction verification). Required for project cost allocation a']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Work orders represent service requests from specific departments; all associated costs must be charged to the requesting department\'s cost center for internal cost recovery and budget variance analysi']
  customer_account_id varchar [note: 'Foreign key linking to customer.customer_account. Business justification: Customer-requested testing services (private well analysis, voluntary lead testing, complaint investigations) require work order linkage to customer account for billing, result delivery, appointment s']
  purchase_order_id varchar [note: 'Foreign key linking to supply.purchase_order. Business justification: When external lab services are procured, the work order references the PO for cost tracking, budget management, and three-way match (PO-GR-Invoice). Essential for financial reconciliation and vendor p']
  sampling_plan_id varchar [note: 'Foreign key linking to laboratory.sampling_plan. Business justification: Lab work orders are often generated from scheduled sampling plans. The work order has regulatory_program and permit_number attributes that align with sampling plan drivers. This FK allows tracing work']
  wtp_facility_id varchar [note: 'Foreign key linking to treatment.facility. Business justification: Lab work orders are organized by facility for routine compliance monitoring, operational troubleshooting, and process optimization. Linking work orders to facilities enables cost allocation, workload ']
  actual_completion_timestamp timestamp [note: 'Date and time when all analyses were completed, validated, and results released. Used to measure TAT performance and identify bottlenecks.']
  actual_cost_usd decimal(15,2) [note: 'Actual total cost in US dollars incurred for completing the work order, including labor, reagents, instrument time, and overhead allocation.']
  analysis_count varchar [note: 'Total number of individual analytical tests requested across all samples in the work order. A single sample may require multiple analyses.']
  assigned_analyst_name varchar [note: 'Name of the primary analyst assigned to the work order. Used for accountability and quality assurance tracking.']
  billable_flag boolean [note: 'Indicates whether this work order is billable to an external client or internal cost recovery. True for external client work and some internal service agreements.']
  certification_required_flag boolean [note: 'Indicates whether the work order requires analysis by a state-certified analyst. True for regulatory compliance samples that must be legally defensible.']
  compliance_monitoring_flag boolean [note: 'Indicates whether this work order is part of regulatory compliance monitoring. True for samples required by permits, regulations, or consent decrees.']
  cost_center decimal(18,2) [note: 'Financial cost center to which laboratory charges for this work order will be allocated. Supports internal chargeback and budget tracking.']
  created_timestamp timestamp [note: 'Date and time when the work order record was first created in the LIMS. Used for audit trail and workflow tracking.']
  data_release_timestamp timestamp [note: 'Date and time when validated analytical results were officially released to the requestor. Marks the end of the laboratory workflow.']
  estimated_cost_usd decimal(15,2) [note: 'Estimated total cost in US dollars for completing all analyses in the work order, based on standard labor and material rates.']
  holding_time_compliant_flag boolean [note: 'Indicates whether all analyses in the work order were completed within the required holding time. False triggers data qualification and potential regulatory reporting.']
  holding_time_hours varchar [note: 'Maximum allowable time in hours between sample collection and analysis completion, as specified by analytical method or regulation. Critical for regulatory defensibility.']
  invoice_date date [note: 'Date when the invoice was generated for the completed work order. Used for revenue recognition and accounts receivable aging.']
  invoice_number varchar [note: 'Invoice number generated for billable work orders. Links laboratory work to accounts receivable and revenue recognition.']
  lims_batch_code varchar [note: 'Batch identifier in LabWare LIMS grouping samples analyzed together under the same QC protocol and instrument calibration.']
  modified_by varchar [note: 'User ID or name of the person who last modified the work order record. Supports change tracking and audit trail requirements.']
  modified_timestamp timestamp [note: 'Date and time when the work order record was last modified. Tracks changes to status, assignments, or other work order attributes.']
  notes varchar [note: 'Free-text field for additional instructions, special handling requirements, deviations, or observations related to the work order.']
  permit_number varchar [note: 'Regulatory permit or authorization number associated with the work order, such as NPDES permit for wastewater discharge monitoring or public water system ID.']
  priority_level varchar [note: 'Priority classification determining the urgency and sequence of analytical work. Emergency priority typically reserved for regulatory exceedances or operational incidents.']
  qaqc_protocol varchar [note: 'Name or identifier of the QA/QC protocol to be applied, including requirements for blanks, duplicates, spikes, and control standards.']
  regulatory_program varchar [note: 'Name of the regulatory program driving the analytical requirements, such as SDWA compliance monitoring, NPDES permit, LCRR, or state-specific programs.']
  requested_analyte_list varchar [note: 'Comma-separated list of analytes or parameters to be tested, such as pH, turbidity, total coliform, lead, copper, BOD, TSS, PFAS, or specific contaminants.']
  requested_test_method_list varchar [note: 'Comma-separated list of analytical test methods to be used, such as EPA 200.8, SM 2540C, EPA 1664A. Methods must be approved for regulatory defensibility.']
  requesting_entity varchar [note: 'Name of the department, facility, or external client that submitted the work order. May include treatment operations, compliance team, WTP, WWTP, or external industrial clients.']
  requesting_entity_type varchar [note: 'Classification of the requesting entity to support workflow routing, billing, and reporting requirements.']
  requestor_contact_email varchar [note: 'Email address of the requestor for result delivery, status updates, and work order correspondence.']
  requestor_contact_phone varchar [note: 'Phone number of the requestor for urgent communication regarding sample issues, result clarification, or turnaround time adjustments.']
  requestor_name varchar [note: 'Name of the individual who submitted the work order. Used for clarification and communication during analysis.']
  required_turnaround_time_hours varchar [note: 'Number of hours within which analytical results must be delivered. Driven by regulatory requirements, operational needs, or client service level agreements.']
  sample_count varchar [note: 'Total number of samples included in this work order. Used for workload planning and resource allocation.']
  scheduled_completion_date date [note: 'Target date by which all analyses in the work order should be completed and results validated. Calculated from submission timestamp and required TAT.']
  submission_timestamp timestamp [note: 'Date and time when the work order was submitted to the laboratory. Used to calculate turnaround time and holding time compliance.']
  work_order_number varchar [note: 'Business identifier for the work order, typically generated by LabWare LIMS. Used for external communication and tracking.']
  work_order_status varchar [note: 'Current lifecycle status of the work order in the laboratory workflow. Tracks progression from receipt through completion and invoicing.']
  work_order_type varchar [note: 'Classification of the work order based on its purpose and origin. Determines workflow routing and priority handling.']
  created_by varchar [note: 'User ID or name of the person who created the work order record in the LIMS. Supports accountability and audit requirements.']

  Note: 'Operational work order record that organizes and tracks the analytical workload assigned to the laboratory for a given submission or sampling event. Captures work order number, requesting entity (treatment operations, compliance team, distribution crew, external client), priority level, required turnaround time (TAT), list of requested analyses, assigned analyst(s), scheduled completion date, receipt condition of samples (temperature, seal integrity, discrepancies), and current status (received, in-progress, pending review, completed, reported). Serves as the primary workflow management entity in LabWare LIMS and the official laboratory receipt record for incoming sample submissions.'
}

Table laboratory.certificate_of_analysis {
  certificate_of_analysis_id varchar [pk, note: 'Unique identifier for the certificate_of_analysis data product (auto-inserted pre-linking).']
  certificate_reviewed_by_analyst_id varchar
  certified_analyst_id varchar [note: 'Foreign key linking to laboratory.certified_analyst. Business justification: COAs require formal approval and signature by a certified analyst with signatory authority before release to customers or regulatory agencies. This FK captures the approving analyst. Labeled FK (appro']
  customer_account_id varchar [note: 'Foreign key linking to customer.customer_account. Business justification: Certificates of analysis for customer-origin samples (lead testing, complaint investigations, fee-based services) must link to account for secure result delivery, regulatory notification compliance, r']
  employee_id varchar
  lab_sample_id varchar [note: 'Foreign key linking to laboratory.lab_sample. Business justification: A Certificate of Analysis (COA) is the formal report issued for a lab sample, documenting all test results and certifications. Every COA must reference the sample it reports on. This is a standard rep']
  lab_work_order_id varchar [note: 'Foreign key linking to laboratory.lab_work_order. Business justification: COAs are generated to fulfill lab work orders submitted by internal or external customers. This FK links the deliverable (COA) to the originating work request. This enables tracking of work order comp']
  laboratory_id varchar [note: 'Issuing laboratory']
  revised_certificate_of_analysis_id varchar [note: 'Self-referencing FK on certificate_of_analysis (revised_certificate_of_analysis_id)']
  accreditation_number varchar [note: 'Laboratory accreditation number']
  accreditation_reference varchar [note: 'Lab accreditation reference for the certificate.']
  accreditation_statement varchar
  all_qc_acceptable boolean [note: 'Whether all QC met acceptance criteria']
  all_results_within_limits_flag boolean [note: 'Whether all results are within limits']
  analysis_end_date date [note: 'Date analysis completed']
  analysis_start_date date [note: 'Date analysis started']
  analysis_summary varchar [note: 'Summary of analysis results.']
  analyte_summary varchar
  analytical_summary varchar
  approval_date date [note: 'Date of approval']
  approval_status varchar
  approval_timestamp timestamp
  approved_by varchar [note: 'Name of approving analyst.']
  approved_date date
  approved_flag boolean [note: 'Whether approved']
  approved_signatory varchar [note: 'Approved signatory name']
  certificate_number varchar
  certificate_status varchar
  chain_of_custody_complete boolean [note: 'Whether COC was complete']
  client_name varchar [note: 'Client name']
  client_po_number varchar [note: 'Client purchase order number']
  client_project varchar [note: 'Client project reference']
  client_project_name varchar [note: 'Client project name']
  client_project_number varchar [note: 'Client project number']
  collection_date date
  collection_time timestamp [note: 'Sample collection time']
  comments varchar
  compliance_statement varchar
  created_at timestamp
  created_date timestamp [note: 'Record creation timestamp']
  created_timestamp timestamp
  data_qualifiers varchar [note: 'Data qualifiers applied']
  data_qualifiers_present boolean [note: 'Whether data qualifiers are present']
  data_quality_flag boolean [note: 'True when record passed data validation.']
  date_analysis_completed date [note: 'Date analysis completed']
  date_analysis_started date [note: 'Date analysis started']
  date_samples_received date [note: 'Date samples were received']
  delivered_date date [note: 'Date delivered to client']
  delivery_date date [note: 'Date delivered to client']
  delivery_method varchar [note: 'Delivery method']
  document_url varchar
  effective_date date
  expiration_date date
  holding_times_met boolean [note: 'Whether all holding times were met']
  is_accredited boolean [note: 'Whether issued under accreditation.']
  is_approved boolean
  is_final boolean
  is_revised boolean [note: 'Whether certificate is a revision.']
  issue_date date
  laboratory_accreditation_number varchar
  laboratory_address varchar [note: 'Laboratory address']
  last_modified_timestamp timestamp [note: 'Record last modified timestamp']
  lims_report_code varchar
  matrix_type varchar
  methods_used varchar [note: 'Analytical methods used']
  modified_timestamp timestamp
  narrative_comments varchar [note: 'Narrative comments']
  narrative_included boolean [note: 'Whether case narrative is included']
  notes varchar [note: 'Certificate notes']
  overall_result varchar
  parameter_count varchar [note: 'Number of parameters analyzed']
  parameters_analyzed varchar [note: 'Parameters analyzed']
  project_name varchar [note: 'Project name']
  qc_summary varchar [note: 'QC summary']
  qualifiers_description varchar [note: 'Description of data qualifiers']
  recipient_address varchar
  recipient_email varchar
  recipient_name varchar
  record_status varchar
  regulatory_program varchar
  report_date date [note: 'Reporting date.']
  report_format varchar [note: 'Report format (standard, custom, regulatory)']
  result_count varchar
  review_date date
  reviewed_by varchar [note: 'Reviewer name']
  revision_date date [note: 'Date of revision']
  revision_number varchar [note: 'Revision number']
  revision_reason varchar [note: 'Reason for revision']
  sample_condition_acceptable boolean [note: 'Whether sample condition was acceptable']
  sample_count varchar [note: 'Number of samples on certificate']
  sample_description varchar [note: 'Sample description']
  sample_location varchar [note: 'Sample location']
  sample_matrix varchar [note: 'Sample matrix type']
  sample_received_date date [note: 'Date sample was received']
  sampling_period_end date
  sampling_period_start date
  signatory_name varchar
  signatory_title varchar [note: 'Signatory title']
  signature_date date
  test_count varchar [note: 'Number of tests performed']
  total_analytes_reported varchar
  total_exceedances varchar
  turnaround_days varchar [note: 'Turnaround time in days']
  turnaround_time_days varchar
  updated_at timestamp
  updated_date timestamp [note: 'Record last update timestamp']
  updated_timestamp timestamp [note: 'Record last update timestamp.']

  Note: 'Record of each formal laboratory report or certificate of analysis (COA) issued to internal or external requestors. Captures report number, report type (compliance, operational, customer), associated work order, list of included test results, report generation datetime, reviewing analyst, signatory (NELAC-authorized), delivery method, recipient, and report status (draft, final, revised, superseded). The COA is the official deliverable that packages validated results for regulatory submission, operational decision-making, or external client delivery.'
}

Table laboratory.analyst_method_qualification {
  analyst_method_qualification_id varchar [pk, note: 'Unique identifier for this analyst-method qualification record. Primary key.']
  analyst_qualified_by_employee_id varchar
  analyst_supervisor_employee_id varchar [note: 'Reference to the employee ID of the supervisor who approved this method qualification. Part of the quality assurance audit trail.']
  certified_analyst_id varchar [note: 'Foreign key linking to the certified analyst who holds the method qualification']
  test_method_id varchar [note: 'Foreign key linking to the test method for which the analyst is qualified']
  acceptance_criteria_met_flag boolean
  approved_test_methods varchar [note: 'Comma-separated list or structured text of EPA method numbers and analytical procedures the analyst is qualified and authorized to perform. Examples include EPA 200.7 (metals by ICP), EPA 300.0 (anions by IC), EPA 524.2 (VOCs by GC/MS), Standard Methods 2540 (solids), etc. [Moved from certified_analyst: This comma-separated list attribute in certified_analyst is a denormalized representation of the many-to-many relationship. The proper model is to track each analyst-method qualification as a separate record in the association table with full qualification details. This attribute should be removed and replaced by queries against the analyst_method_qualification association.]']
  certification_date date [note: 'Date on which the analyst was certified or qualified to perform this specific test method. Used to track when the qualification became effective.']
  certification_level varchar [note: 'Hierarchical level of qualification for this specific method indicating the complexity of analyses the analyst can perform independently (Trainee, Qualified, Senior, Signatory).']
  continuing_education_hours decimal(6,2) [note: 'Total number of continuing education hours or professional development units earned by the analyst specific to this test method or method category. Required for certification renewal.']
  created_timestamp timestamp [note: 'Timestamp when this qualification record was first created in the system. Part of audit trail.']
  demonstration_of_capability_date date [note: 'Date on which the analyst successfully completed the Demonstration of Capability (DOC) for this method, proving they can meet method performance criteria. Required by TNI and NELAC standards.']
  expiration_date date [note: 'Date on which this method-specific qualification expires and must be renewed. Critical for compliance with accreditation requirements.']
  initial_demonstration_capability_date date
  initial_training_date date [note: 'Date on which the analyst completed initial training for this specific test method. Part of the qualification documentation trail.']
  last_continuing_proficiency_date date
  last_modified_timestamp timestamp [note: 'Timestamp when this qualification record was most recently updated. Part of audit trail.']
  last_proficiency_test_date date [note: 'Date of the most recent proficiency testing event completed by the analyst for this specific method. Used to track compliance with annual or biennial PT requirements.']
  modified_timestamp timestamp
  notes varchar [note: 'Free-text field for additional notes, comments, or special conditions related to this analyst-method qualification (e.g., matrix-specific limitations, instrument-specific qualifications).']
  proficiency_test_status varchar [note: 'Status of the analyst\'s most recent proficiency testing for this specific method. Proficiency testing is required by accreditation bodies to verify analyst competency.']
  qualification_date date
  qualification_notes varchar
  qualification_status varchar [note: 'Current lifecycle status of this analyst-method qualification. Active qualifications authorize the analyst to perform the method; expired or suspended qualifications require remediation.']
  qualification_type varchar
  record_source varchar [note: 'Identifier of the source system from which this qualification record originated (e.g., LIMS, QMS, training management system).']
  signatory_authority boolean [note: 'Boolean flag indicating whether the analyst has signatory authority to approve and certify analytical results for this specific test method. Signatory authority requires demonstrated proficiency and supervisor approval.']
  supervisor_approval_date date [note: 'Date on which the laboratory supervisor or quality manager approved the analyst\'s qualification for this method. Required for accreditation compliance.']

  Note: 'This association product represents the certification relationship between certified analysts and test methods in the laboratory quality assurance program. It captures the formal qualification of each analyst to perform specific analytical test methods, including certification dates, proficiency testing results, and signatory authority. Each record links one certified analyst to one test method with attributes that exist only in the context of this qualification relationship. This is a critical quality control entity audited by accreditation bodies (NELAC, TNI) and required for data defensibility in regulatory reporting.. Existence Justification: In water utility laboratories, analyst method qualification is a formal, audited business process required by accreditation bodies (NELAC, TNI). Each analyst must be individually certified to perform specific test methods, with documented training, proficiency testing, and supervisor approval. One analyst is qualified for multiple methods (e.g., an analyst qualified for EPA 200.8, SM 2130B, and EPA 524.2), and each method has multiple qualified analysts (e.g., EPA 200.8 can be performed by 5 different certified analysts). The laboratory quality manager actively manages this matrix of qualifications, tracking expiration dates, proficiency test results, and signatory authority for each analyst-method combination.'
}

Table laboratory.plan_analyte_requirement {
  plan_analyte_requirement_id varchar [pk, note: 'Unique identifier for this plan-analyte requirement record. Primary key.']
  analyte_id varchar [note: 'Foreign key linking to the analyte parameter that must be tested under this sampling plan']
  sampling_plan_id varchar [note: 'Foreign key linking to the sampling plan that requires this analyte to be tested']
  test_method_id varchar
  analyte_list varchar [note: 'Comma-separated list of required analytes or parameters to be tested under this sampling plan (e.g., pH, turbidity, chlorine residual, THM, HAA5, lead, copper, PFAS, BOD, TSS, E. coli). Detailed test methods are specified separately. [Moved from sampling_plan: This comma-separated list in sampling_plan is a denormalized representation of the M:N relationship. The proper model is to have individual plan_analyte_requirement records rather than a text list. This attribute should be deprecated in favor of querying the association table.]']
  compliance_threshold_unit varchar [note: 'Unit of measure for the compliance threshold (e.g., mg/L, µg/L, CFU/100mL). Stored at the requirement level because different plans may report the same analyte in different units.']
  compliance_threshold_value decimal(18,6) [note: 'The specific regulatory or permit limit for this analyte under this sampling plan. May differ from the default MCL in the analyte table if the plan is driven by a specific permit or state regulation with stricter limits.']
  container_type varchar [note: 'Required sample container type for this analyte under this plan (e.g., sterile plastic bottle, amber glass, PFAS-free container). Stored at requirement level because container requirements may vary by test method.']
  created_timestamp timestamp
  effective_end_date date [note: 'Date on which this analyte requirement expires or is replaced for this sampling plan. Nullable for ongoing requirements. Used when regulatory requirements change or permits are updated.']
  effective_start_date date [note: 'Date on which this analyte requirement becomes effective for this sampling plan. Allows for phased implementation of new regulatory requirements (e.g., PFAS monitoring phase-in).']
  holding_time_hours varchar [note: 'Maximum allowable time between sample collection and analysis for this analyte under this plan. Stored at requirement level because different regulatory programs may impose different holding time requirements for the same analyte.']
  mandatory_flag boolean [note: 'Indicates whether testing for this analyte is mandatory (true) or optional (false) under this sampling plan. Some plans may include optional analytes for operational monitoring beyond regulatory requirements.']
  minimum_sample_volume_ml varchar [note: 'Minimum sample volume required for this analyte under this plan, in milliliters. May differ from the analyte\'s default if the plan requires multiple replicates or QA/QC samples.']
  modified_timestamp timestamp
  monitoring_frequency varchar
  notes varchar [note: 'Free-text field for additional context about this specific analyte requirement, such as special handling instructions, regulatory citations, or operational notes.']
  plan_analyte_requirement_status varchar [note: 'Current status of this analyte requirement: active (currently in effect), inactive (temporarily suspended), pending (scheduled for future activation), superseded (replaced by updated requirement).']
  preservation_method varchar [note: 'Required sample preservation technique for this analyte under this plan (e.g., acidify to pH<2, refrigerate to 4°C, add sodium thiosulfate). Stored at requirement level because preservation may vary by test method or regulatory program.']
  qaqc_protocol varchar [note: 'Specific quality assurance and quality control protocol required for this analyte under this plan (e.g., matrix spike frequency, duplicate sample requirements, blank requirements). May be more stringent than default analyte QA/QC.']
  qaqc_requirement varchar
  regulatory_limit decimal(18,6)
  reporting_limit decimal(18,6)
  reporting_limit_unit varchar
  reporting_requirement varchar [note: 'Specific reporting obligation for this analyte under this plan (e.g., CCR annual report, NPDES DMR monthly, LCRR 90th percentile calculation). Different plans may have different reporting requirements for the same analyte.']
  required_detection_limit decimal(18,6) [note: 'The minimum detection limit required for this analyte under this plan. May be more stringent than the analyte\'s default detection limit if the plan is driven by a regulatory program requiring lower detection limits (e.g., PFAS monitoring).']
  required_flag boolean
  sampling_frequency varchar [note: 'Required sampling frequency for this specific analyte under this plan (e.g., daily, weekly, monthly, quarterly). May differ from the plan\'s overall frequency if certain analytes require more or less frequent testing.']
  test_method_list varchar [note: 'Comma-separated list of required analytical test methods or standard method references (e.g., EPA 200.8, SM 2320B, ASTM D1067) corresponding to the analyte list. Ensures regulatory compliance and analytical consistency. [Moved from sampling_plan: This comma-separated list in sampling_plan is a denormalized representation of test methods that should be stored at the plan-analyte requirement level. Different analytes under the same plan require different test methods, so this belongs in the association, not as a plan-level list.]']

  Note: 'This association product represents the regulatory monitoring requirement between sampling_plan and analyte. It captures the specific testing parameters, methods, and compliance thresholds that define which analytes must be tested under each sampling plan. Each record links one sampling plan to one analyte with attributes that exist only in the context of this regulatory requirement, such as the specific test method to use, compliance threshold values, and preservation requirements for that analyte within that plan\'s context.. Existence Justification: Water utilities manage sampling plans that specify multiple analytes to be tested (e.g., a SDWA compliance plan tests for lead, copper, chlorine, THMs, HAA5, PFAS), and each analyte appears in multiple sampling plans (e.g., lead is tested under LCRR tap sampling, distribution system monitoring, and entry point monitoring plans). The relationship itself carries critical regulatory data: the specific test method required for that analyte under that plan, the compliance threshold value (which may differ from default MCL based on permit conditions), preservation requirements, holding times, and reporting obligations. This is actively managed in LIMS as the core configuration that drives sample analysis and compliance reporting.'
}

Table laboratory.lab_accreditation_grant {
  lab_accreditation_grant_id varchar [pk, note: 'Primary key for the lab_accreditation_grant association']
  grant_id varchar
  lab_accreditation_id varchar [note: 'Foreign key linking to the laboratory accreditation record']
  regulatory_agency_id varchar [note: 'Foreign key linking to the regulatory agency that issued this accreditation']
  accreditation_certificate_number varchar [note: 'The unique certificate number issued by the accrediting body for this specific accreditation grant. This is relationship-specific data that exists only in the context of this agency-laboratory accreditation.']
  accreditation_contact_email varchar [note: 'Email address of the laboratory staff member responsible for managing this accreditation. [Moved from lab_accreditation: Contact email for managing this specific agency relationship. Relationship-specific.]']
  accreditation_contact_name varchar [note: 'Name of the laboratory staff member responsible for managing this accreditation and serving as the primary contact with the accrediting body. [Moved from lab_accreditation: The lab contact responsible for managing this specific accreditation relationship with this agency. Relationship-specific.]']
  accreditation_contact_phone varchar [note: 'Phone number of the laboratory staff member responsible for managing this accreditation. [Moved from lab_accreditation: Contact phone for managing this specific agency relationship. Relationship-specific.]']
  accreditation_cost_usd decimal(12,2) [note: 'The total cost in US dollars for obtaining and maintaining this specific accreditation from this agency.']
  accreditation_document_url varchar [note: 'URL or file path to the digital copy of this accreditation certificate and scope document.']
  accreditation_scope_description varchar [note: 'Detailed description of the accreditation scope for this specific grant, including the list of accredited analytes, matrices, and methods approved by this agency.']
  accreditation_status varchar [note: 'Current status of this specific accreditation grant (active, suspended, revoked, expired, pending). This is relationship-specific state.']
  accreditation_type varchar [note: 'The type or program of accreditation granted by this agency (e.g., state primacy, NELAC/TNI, A2LA, DoD ELAP).']
  accredited_analyte_count varchar [note: 'The total number of analytes for which the laboratory is accredited under this accreditation. [Moved from lab_accreditation: The count of accredited analytes varies by agency and their scope. This is relationship-specific or derivable.]']
  accredited_matrix_list varchar [note: 'Comma-separated or structured list of matrices (e.g., drinking water, wastewater, soil, sludge) covered under this accreditation. [Moved from lab_accreditation: The list of accredited matrices varies by agency. EPA may accredit for drinking water while state accredits for wastewater.]']
  accredited_method_list varchar [note: 'Comma-separated or structured list of test methods (e.g., EPA 200.7, SM 2540C) for which the laboratory is accredited. [Moved from lab_accreditation: The list of accredited methods varies by agency and their program scope. This is relationship-specific.]']
  accrediting_organization_name varchar [note: 'Name of the accrediting body that issued this accreditation (e.g., state primacy agency, NELAC/TNI, A2LA, DoD ELAP). [Moved from lab_accreditation: This is redundant with the regulatory_agency reference and should be derived from the agency master record, not stored in the association or lab_accreditation.]']
  allocation_amount decimal(18,2)
  allocation_date date
  allocation_percentage decimal(7,4)
  allocation_status varchar
  assessment_frequency_months varchar [note: 'The frequency in months at which the accrediting body conducts assessments (e.g., 12, 24, 36 months). [Moved from lab_accreditation: Assessment frequency is determined by the agency\'s program requirements, not the lab. This should be an attribute of the agency or the relationship.]']
  certificate_effective_date date [note: 'The effective start date of this accreditation certificate issued by this agency to this laboratory.']
  certificate_expiry_date date [note: 'The expiration date of this accreditation certificate. Critical for renewal tracking and ensuring regulatory defensibility.']
  conditions_or_deficiencies_noted varchar [note: 'Any conditions, limitations, or deficiencies noted by this agency during assessments for this accreditation.']
  corrective_action_due_date date [note: 'The deadline by which corrective actions must be completed for this accreditation.']
  corrective_action_required_flag boolean [note: 'Indicates whether corrective action is required for this specific accreditation grant.']
  created_timestamp timestamp [note: 'Timestamp when this accreditation grant record was first created in the system.']
  current_certificate_effective_date date [note: 'The effective start date of the current accreditation certificate. [Moved from lab_accreditation: Each agency issues its own certificate with its own effective date. This is relationship-specific.]']
  current_certificate_expiry_date date [note: 'The expiration date of the current accreditation certificate. Critical for ensuring continuous regulatory defensibility. [Moved from lab_accreditation: Each agency\'s certificate has its own expiry date. This is relationship-specific and critical for renewal tracking per agency.]']
  initial_accreditation_date date [note: 'The date when the laboratory first received this accreditation from this agency.']
  last_assessment_date date [note: 'The date of the most recent on-site assessment conducted by this agency for this accreditation.']
  last_onsite_assessment_date date [note: 'The date of the most recent on-site assessment conducted by the accrediting body. [Moved from lab_accreditation: Each agency conducts its own assessments on its own schedule. This is relationship-specific.]']
  last_proficiency_test_date date [note: 'The date of the most recent proficiency testing event completed for this accreditation. [Moved from lab_accreditation: PT dates are tracked per accreditation program/agency. This is relationship-specific.]']
  modified_timestamp timestamp
  next_assessment_due_date date [note: 'The scheduled date for the next assessment by this agency for this accreditation.']
  notes varchar [note: 'Additional notes or comments regarding this accreditation, including special conditions, historical context, or operational considerations. [Moved from lab_accreditation: Notes are specific to each agency-lab accreditation relationship. Different agencies may have different notes.]']
  proficiency_test_pass_rate_percent decimal(5,2) [note: 'The percentage of proficiency test samples that passed acceptance criteria in the most recent testing cycle. [Moved from lab_accreditation: PT pass rates are evaluated per agency program. This is relationship-specific.]']
  proficiency_testing_provider varchar [note: 'Name of the proficiency testing provider used to satisfy accreditation requirements (e.g., ERA, APHA, NELAP PT providers). [Moved from lab_accreditation: PT provider requirements may vary by agency program. This is relationship-specific or should be on the agency.]']
  regulatory_defensibility_flag boolean [note: 'Indicates whether the accreditation is currently in good standing and provides regulatory defensibility for analytical data. [Moved from lab_accreditation: Regulatory defensibility is specific to each agency relationship. Data may be defensible for EPA but not for a state agency if that accreditation is suspended.]']
  renewal_notification_days_prior varchar [note: 'Number of days before expiry that renewal notifications should be triggered to ensure timely renewal. [Moved from lab_accreditation: Renewal notification timing may vary by agency program requirements. This is relationship-specific or agency-specific.]']

  Note: 'This association product represents the formal accreditation grant issued by a regulatory agency to a laboratory for specific testing capabilities. Each record captures the certificate, scope, validity period, assessment schedule, and compliance status for one accreditation relationship. A laboratory holds multiple accreditations from different agencies (EPA, state primacy, NELAC, A2LA), and each agency accredits multiple laboratories. This is a core compliance artifact that laboratories actively manage for regulatory defensibility.. Existence Justification: In water utility laboratory operations, a single laboratory holds multiple simultaneous accreditations from different regulatory agencies (EPA, state primacy agency, NELAC/TNI, A2LA, DoD ELAP), and each regulatory agency accredits multiple laboratories across their jurisdiction. Each accreditation grant is a distinct compliance artifact with its own certificate number, scope, validity period, assessment schedule, and status. Laboratory managers actively manage their accreditation portfolio, tracking renewal dates, responding to agency-specific deficiencies, and ensuring regulatory defensibility of analytical data for each agency relationship.'
}

Table laboratory.method_material_usage {
  method_material_usage_id varchar [pk, note: 'Unique identifier for this method-material usage record. Primary key.']
  material_master_id varchar [note: 'Foreign key linking to the material, chemical, reagent, or consumable used in this test method']
  reagent_standard_id varchar
  test_method_id varchar [note: 'Foreign key linking to the analytical test method that requires this material']
  alternative_material_flag boolean [note: 'Indicates whether this material is an approved alternative or substitute for the primary material specified in the method. True if alternative, false if primary/required material.']
  consumption_rate decimal(15,6) [note: 'Average consumption rate of this material for this method, expressed as quantity per time period (e.g., liters per month). Used for procurement planning and reorder point calculations.']
  consumption_rate_unit decimal(18,6) [note: 'Time unit for the consumption rate (per_test, per_day, per_week, per_month).']
  cost_per_test decimal(15,2) [note: 'Calculated material cost for this specific material per single test execution. Derived from quantity_per_test and material standard_price. Used for test method cost accounting and pricing.']
  created_timestamp timestamp
  criticality varchar [note: 'Criticality classification for this material in the context of this method. Critical materials have no substitutes and stockouts halt testing; important materials have limited alternatives; standard materials are readily substitutable.']
  effective_date date [note: 'Date on which this material became approved and effective for use with this test method. Supports method version changes and material substitutions over time.']
  estimated_cost_per_test decimal(12,4)
  expiration_date date [note: 'Date on which this material is no longer approved for use with this test method. Null if currently active. Used when materials are phased out or methods are updated.']
  last_updated_date timestamp [note: 'Timestamp of the most recent update to this method-material usage record. Tracks when consumption rates, quantities, or material preferences were last reviewed.']
  material_role varchar [note: 'The functional role this material plays in the execution of this test method (reagent, standard, calibration_solution, preservative, consumable, quality_control_sample).']
  modified_timestamp timestamp
  notes varchar
  preferred_vendor_flag boolean [note: 'Indicates whether the vendor associated with this material is the preferred vendor for this specific method-material combination, based on quality, reliability, or regulatory acceptance.']
  quantity_per_test decimal(15,3) [note: 'Standard quantity of this material consumed per single test execution. Used for inventory forecasting and cost allocation. Units align with material base_unit_of_measure.']
  unit_of_measure varchar
  updated_by varchar [note: 'User ID or name of the laboratory staff member who last updated this method-material usage record.']
  usage_type varchar

  Note: 'This association product represents the bill-of-materials relationship between laboratory test methods and the materials, reagents, chemicals, and consumables required to perform each test. It captures the specific materials needed for each analytical method, including quantities, consumption rates, and material preferences. Each record links one test method to one material with attributes that exist only in the context of this method-material pairing, enabling accurate inventory planning, cost allocation per test, and procurement forecasting for laboratory operations.. Existence Justification: Laboratory test methods require multiple materials (reagents, standards, calibration solutions, preservatives, consumables) to execute, and each material is used across multiple different test methods. The laboratory actively manages this bill-of-materials relationship, tracking consumption rates per method-material pair for inventory planning, cost allocation per test, and procurement forecasting. This is a genuine operational M:N relationship where the pairing itself carries critical business data.'
}

Table laboratory.analyst_grant_allocation {
  analyst_grant_allocation_id varchar [pk, note: 'Primary key for the analyst_grant_allocation association']
  certified_analyst_id varchar [note: 'Foreign key linking to the certified laboratory analyst whose effort is being allocated to this grant.']
  grant_id varchar [note: 'Foreign key linking to the grant receiving the analyst\'s labor allocation.']
  allocated_hours decimal(10,2)
  allocation_amount decimal(18,2)
  allocation_end_date date
  allocation_percentage decimal(7,4)
  allocation_period_end_date date [note: 'End date of the period during which this effort allocation is effective. Used to track historical allocations and support quarterly effort certification reporting.']
  allocation_period_start_date date [note: 'Start date of the period during which this effort allocation is effective. Typically aligns with grant quarters or fiscal periods for effort certification.']
  allocation_start_date date
  allocation_status varchar
  cost_category decimal(18,2) [note: 'Classification of the labor cost for grant accounting purposes. Distinguishes between direct labor, fringe benefits, and indirect costs applied to the analyst\'s time.']
  created_timestamp timestamp [note: 'Timestamp when this allocation record was first created in the system.']
  effort_certification_date date [note: 'Date on which the analyst or authorized representative certified the effort allocation for this grant period. Required for federal grant compliance.']
  effort_certification_status varchar [note: 'Status of the quarterly effort certification for this analyst-grant allocation. Federal grants require analysts to certify their effort quarterly.']
  effort_percentage decimal(5,2) [note: 'Percentage of the analyst\'s total work time allocated to this grant. Used for quarterly effort certification required by federal grants. Must sum to 100% or less across all grants for each analyst.']
  grant_account_code varchar [note: 'General ledger account code to which this analyst\'s labor costs are charged. Links the allocation to the utility\'s chart of accounts for grant accounting.']
  grant_role varchar [note: 'The specific role the analyst performs on this grant project. Required for federal grant reporting to distinguish between PI, co-investigators, and support staff.']
  labor_cost_allocation decimal(18,2) [note: 'Dollar amount of the analyst\'s labor costs charged to this grant during the allocation period. Calculated from effort percentage and analyst\'s salary/benefits. Used for grant drawdown requests and SEFA reporting.']
  last_modified_timestamp timestamp [note: 'Timestamp when this allocation record was most recently updated.']
  modified_timestamp timestamp
  notes varchar [note: 'Free-text field for additional notes about this allocation, such as special conditions, adjustments, or explanations for effort certification.']
  record_source varchar [note: 'Identifier of the source system from which this allocation record originated (e.g., payroll system, grant management system, time tracking system).']

  Note: 'This association product represents the labor allocation between certified laboratory analysts and grants. It captures the effort certification and cost allocation required for federal grant compliance. Each record links one certified analyst to one grant with attributes that track the analyst\'s role, effort percentage, labor costs, and allocation period for grant accounting and federal reporting requirements.. Existence Justification: Water utilities must track labor allocation of certified laboratory analysts across multiple federal and state grants for compliance with OMB Uniform Guidance effort certification requirements. One analyst can charge time to multiple grants simultaneously (split effort), and one grant employs multiple analysts in different roles. The business actively manages quarterly effort certification, where each analyst must certify their effort percentage across all grants, and finance must allocate labor costs to the correct grant accounts for drawdown requests and Single Audit SEFA reporting.'
}

Table laboratory.analyst_training_completion {
  analyst_training_completion_id varchar [pk, note: 'Unique identifier for this analyst training completion record. Primary key.']
  certified_analyst_id varchar [note: 'Foreign key linking to the certified analyst who completed the training']
  training_course_id varchar [note: 'Foreign key linking to the training course that was completed']
  training_record_id varchar
  assessment_score decimal(5,2) [note: 'Percentage score achieved by the analyst on the training course assessment or exam. Null if no assessment was required.']
  attendance_hours decimal(6,2) [note: 'Actual number of hours the analyst attended or participated in the training. May differ from the course duration if partial attendance occurred.']
  certificate_number varchar
  certification_issued varchar [note: 'Name or code of the certification or credential issued to the analyst upon completion of this training course. May be null if the course does not award a certification.']
  ceu_credits_earned decimal(5,2) [note: 'Number of Continuing Education Unit credits earned by the analyst for this specific training completion. Used to track progress toward certification renewal requirements.']
  completion_date date [note: 'Date on which the analyst successfully completed the training course. Critical for tracking certification renewal timelines and regulatory compliance windows.']
  cost_charged decimal(10,2) [note: 'Actual cost in US dollars charged for this analyst\'s enrollment in this training course offering. May differ from standard cost due to discounts or group rates.']
  created_timestamp timestamp [note: 'Timestamp when this training completion record was first created in the system.']
  enrollment_date date [note: 'Date on which the analyst enrolled in this training course offering.']
  expiration_date date [note: 'Date on which the certification or qualification earned from this training completion expires and must be renewed. Null if the training does not expire.']
  funding_source varchar [note: 'Department, grant, or budget code that funded this training enrollment.']
  instructor_name varchar [note: 'Name of the instructor or facilitator who delivered this specific training session to the analyst.']
  last_modified_timestamp timestamp [note: 'Timestamp when this training completion record was most recently updated.']
  modified_timestamp timestamp
  notes varchar [note: 'Free-text field for additional notes, comments, or special circumstances related to this specific training completion.']
  pass_fail_status varchar [note: 'Status indicating whether the analyst passed, failed, or is still in progress with the training course.']
  passed_flag boolean
  score decimal(6,2)
  training_completion_date date [note: 'Date on which the analyst completed initial laboratory training and was authorized to perform independent analytical work. Marks the transition from trainee to qualified analyst status. [Moved from certified_analyst: This attribute in certified_analyst appears to track a single initial training completion date. In reality, analysts complete multiple training courses over time, each with its own completion date. This attribute should be removed from certified_analyst and tracked in the analyst_training_completion association where each training completion has its own date.]']
  training_hours decimal(6,2)
  training_location varchar [note: 'Physical location or online platform where the training was delivered for this completion record.']
  training_status varchar

  Note: 'This association product represents the completion event between certified_analyst and training_course. It captures the regulatory compliance and continuing education tracking required for laboratory analyst certification maintenance. Each record links one certified_analyst to one training_course with completion dates, CEU credits earned, and certification issuance details that exist only in the context of this specific training completion.. Existence Justification: In water utility laboratory operations, certified analysts must complete multiple training courses over their careers to maintain certifications, earn continuing education credits, and stay current with regulatory requirements and analytical methods. Each training course is completed by multiple analysts across the organization. The business actively manages these training completion records to ensure regulatory compliance, track CEU credit accumulation toward certification renewals, and maintain analyst authorization for specific test methods.'
}

Table laboratory.laboratory {
  laboratory_id varchar [pk, note: 'Primary key for laboratory']
  parent_laboratory_id varchar [note: 'Self-referencing FK on laboratory (parent_laboratory_id)']
  registry_id varchar
  vendor_id varchar
  accreditation_expiry_date date [note: 'Date when the laboratory\'s accreditation expires.']
  accreditation_number varchar [note: 'Identifier of the laboratory\'s accreditation certificate (e.g., ISO 17025).']
  accreditation_status varchar
  address_line_1 varchar
  address_line_2 varchar
  calibration_schedule decimal(18,6) [note: 'Standard schedule for instrument calibration (e.g., quarterly, semi‑annual).']
  capacity_daily_tests varchar [note: 'Maximum number of analytical tests the laboratory can process per day.']
  capacity_samples_per_day varchar
  certification_number varchar
  certification_status varchar
  city varchar
  closure_date date [note: 'Date the laboratory was decommissioned or ceased operations, if applicable.']
  contact_email varchar
  contact_name varchar
  contact_phone varchar
  country_code varchar
  created_timestamp timestamp [note: 'Timestamp when the laboratory record was first created.']
  data_retention_policy varchar [note: 'Policy governing how long laboratory data is retained.']
  director_name varchar
  email_address varchar [note: 'Primary contact email address for the laboratory.']
  instrument_count varchar [note: 'Total number of analytical instruments housed in the laboratory.']
  is_in_house_flag boolean
  lab_certification_number varchar
  lab_code varchar [note: 'Internal code used to uniquely identify the laboratory within the organization.']
  lab_type varchar [note: 'Category of analytical testing performed by the laboratory.']
  laboratory_code varchar
  laboratory_description varchar [note: 'Additional free‑text notes describing the laboratory\'s capabilities, specialties, or other relevant information.']
  laboratory_name varchar [note: 'Descriptive name of the laboratory.']
  laboratory_status varchar [note: 'Current operational status of the laboratory.']
  laboratory_type varchar
  latitude decimal(10,7)
  lims_system_name varchar
  lims_version varchar
  location_address varchar [note: 'Physical street address of the laboratory facility.']
  longitude decimal(11,7)
  method_catalog_version varchar [note: 'Version identifier of the test method catalog used for analyses.']
  modified_timestamp timestamp
  nelap_certification_number varchar
  notes varchar
  operating_hours varchar [note: 'Standard daily operating hours (e.g., 08:00-17:00).']
  operational_status varchar
  phone_number varchar [note: 'Primary contact phone number for the laboratory.']
  postal_code varchar
  primary_accrediting_body varchar
  primary_analyst_name varchar [note: 'Name of the lead certified analyst responsible for laboratory oversight.']
  qa_qc_protocol varchar [note: 'Name or code of the quality assurance / quality control protocol applied in the laboratory.']
  quality_manager_name varchar
  safety_level varchar [note: 'Overall safety classification of the laboratory based on hazard assessments.']
  state_province varchar
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the laboratory record.']
  waste_disposal_method varchar [note: 'Standard method used for disposal of laboratory waste.']

  Note: 'Master reference table for laboratory. Referenced by laboratory_id.'
}

Table laboratory.calibration_curve {
  calibration_curve_id varchar [pk, note: 'Primary key for calibration_curve']
  analyte_id varchar
  calibration_certified_analyst_id varchar
  calibration_lab_instrument_id varchar
  certified_analyst_id varchar [note: 'Identifier of the certified analyst who performed the calibration.']
  lab_instrument_id varchar [note: 'Identifier of the instrument to which this calibration curve applies.']
  reference_calibration_curve_id varchar [note: 'Self-referencing FK on calibration_curve (reference_calibration_curve_id)']
  test_method_id varchar
  acceptance_criteria_met_flag boolean
  acceptance_criteria_r_squared decimal(8,6)
  acceptance_met_flag boolean
  acceptance_status varchar
  calibration_curve_description varchar [note: 'Free‑form description of the calibration curve purpose and characteristics.']
  calibration_curve_status varchar [note: 'Current lifecycle status of the calibration curve.']
  calibration_date date [note: 'Calendar date on which the calibration was performed.']
  calibration_equation decimal(18,6) [note: 'Mathematical equation representing the calibration curve.']
  calibration_method decimal(18,6) [note: 'Methodology used to generate the calibration curve.']
  calibration_point_count varchar
  calibration_time decimal(18,6) [note: 'Exact timestamp of the calibration activity.']
  concentration_unit varchar
  correlation_coefficient decimal(8,6)
  created_timestamp timestamp [note: 'Timestamp when the calibration curve record was first created.']
  curve_code varchar [note: 'External code or identifier used to reference the calibration curve in laboratory systems.']
  curve_name varchar [note: 'Human‑readable name of the calibration curve.']
  curve_number varchar
  curve_status varchar
  curve_type varchar [note: 'Mathematical model used for the calibration curve.']
  data_source varchar [note: 'System or process that supplied the calibration curve data.']
  effective_end_date date [note: 'Date after which the calibration curve is no longer valid (nullable).']
  effective_start_date date [note: 'Date from which the calibration curve is considered valid.']
  expiration_date date
  high_standard_concentration decimal(18,6)
  highest_calibration_standard decimal(18,6)
  humidity_percent decimal(5,2) [note: 'Relative humidity percentage during calibration.']
  instrument_model varchar [note: 'Model designation of the instrument associated with the curve.']
  intercept decimal(18,6)
  is_verified boolean [note: 'Indicates whether the calibration curve has passed QA verification.']
  last_used_timestamp timestamp [note: 'Timestamp of the most recent use of this calibration curve.']
  last_verification_date date
  lims_curve_code varchar
  low_standard_concentration decimal(18,6)
  lowest_calibration_standard decimal(18,6)
  modified_timestamp timestamp
  notes varchar [note: 'Additional free‑text notes or comments about the calibration curve.']
  number_of_points varchar [note: 'Count of data points used to generate the calibration curve.']
  number_of_standards varchar
  r_squared decimal(5,4) [note: 'Statistical measure of fit quality for the calibration curve.']
  reference_value decimal(12,4) [note: 'Primary concentration value that the curve is anchored to.']
  regression_type varchar
  slope decimal(18,6)
  standard_deviation decimal(8,4) [note: 'Standard deviation of the residuals from the calibration fit.']
  temperature_c decimal(6,2) [note: 'Temperature (in degrees Celsius) at which the calibration was performed.']
  unit_of_measure varchar [note: 'Measurement unit for the reference concentration and curve values.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the calibration curve record.']
  verification_date date [note: 'Date on which the calibration curve was verified.']
  verification_frequency varchar
  version_number varchar [note: 'Version number for change control of the calibration curve.']
  weighting_factor varchar

  Note: 'Master reference table for calibration_curve. Referenced by calibration_curve_id.'
}

Table laboratory.validation_batch {
  validation_batch_id varchar [pk, note: 'Primary key for validation_batch']
  certified_analyst_id varchar
  lab_instrument_id varchar [note: 'Identifier of the laboratory instrument used for the batch.']
