ind:euSumOf20ResultNgL rdf:type rdf:Property ;
    rdfs:label 'Eu Sum Of 20 Result Ng L' ;
    rdfs:comment 'Sum of 20 specified PFAS compounds in ng/L as required by EU Drinking Water Directive 2020/2184. EU limit is 100 ng/L. NULL for non-EU jurisdictions.' ;
    rdfs:domain ind:PfasMonitoring ;
