ind:euTotalPfasResultNgL rdf:type rdf:Property ;
    rdfs:label 'Eu Total Pfas Result Ng L' ;
    rdfs:comment 'Total PFAS class measurement in ng/L per EU Drinking Water Directive 2020/2184. EU limit is 500 ng/L. NULL for non-EU jurisdictions.' ;
    rdfs:domain ind:PfasMonitoring ;
