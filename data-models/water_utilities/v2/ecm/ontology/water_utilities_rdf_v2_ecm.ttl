ind:predictionType rdf:type rdf:Property ;
    rdfs:label 'Prediction Type' ;
    rdfs:comment 'Category of prediction (e.g., PFAS_BREAKTHROUGH, DEMAND_FORECAST, LEAK_DETECTION, ASSET_FAILURE, WATER_QUALITY).' ;
