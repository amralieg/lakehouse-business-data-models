ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Third-party notification arrangements (for elderly/disabled customers) are set up by CSR staff. Regulatory requirement for vulnerable populations under state PUC rules. New FK needed; created_by_user ' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryThirdPartyPersonId rdf:type rdf:Property ;
    rdfs:label 'Primary Third Party Person Id' ;
    rdfs:comment 'Foreign key linking to customer.person. Business justification: Third parties receiving notifications may be persons already in the system (e.g., family members, social workers). This FK links to person master when applicable. Nullable as many third parties are ex' ;
    rdfs:domain ind:ThirdPartyNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Person .

ind:thirdPersonId rdf:type rdf:Property ;
    rdfs:label 'Third Person Id' ;
    rdfs:comment 'FK to person' ;
    rdfs:domain ind:ThirdPartyNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Person .

ind:advanceNoticeDays rdf:type rdf:Property ;
