ind:euSumOf20CompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Eu Sum Of 20 Compliant Flag' ;
    rdfs:comment 'EU sum-of-20 compliance' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:euSumOf20NgL rdf:type rdf:Property ;
    rdfs:label 'Eu Sum Of 20 Ng L' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:euSumOf20PfasNgL rdf:type rdf:Property ;
    rdfs:label 'Eu Sum Of 20 Pfas Ng L' ;
    rdfs:comment 'Sum of 20 individual PFAS substances as defined in DWD 2020/2184 Annex I Part B, parametric value 100 ng/L. NULL for US-only monitoring.' ;
