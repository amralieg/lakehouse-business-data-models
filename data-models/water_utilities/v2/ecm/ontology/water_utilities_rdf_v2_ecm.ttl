ind:freeChlorineResidualMgL rdf:type rdf:Property ;
    rdfs:label 'Free Chlorine Residual Mg L' ;
    rdfs:comment 'The free chlorine residual measured at the time of sample collection, in milligrams per liter, which influences DBP formation.' ;
    rdfs:domain ind:DbpMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haa5ComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Haa5 Compliance Status' ;
    rdfs:comment 'Indicates whether the HAA5 LRAA at this monitoring point is in compliance with the MCL.' ;
    rdfs:domain ind:DbpMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haa5ConcentrationUgL rdf:type rdf:Property ;
    rdfs:label 'Haa5 Concentration Ug L' ;
    rdfs:comment 'Sum of the five regulated haloacetic acid species (MCAA, DCAA, TCAA, MBAA, DBAA) in micrograms per liter.' ;
    rdfs:domain ind:DbpMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haa5LraaUgL rdf:type rdf:Property ;
    rdfs:label 'Haa5 Lraa Ug L' ;
    rdfs:comment 'The locational running annual average of HAA5 concentrations at this monitoring point, calculated as the arithmetic average of the current quarter and the previous three quarters.' ;
    rdfs:domain ind:DbpMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haa5MclUgL rdf:type rdf:Property ;
    rdfs:label 'Haa5 Mcl Ug L' ;
    rdfs:comment 'The applicable HAA5 maximum contaminant level for this monitoring event, typically 60 µg/L under Stage 2 DBPR.' ;
    rdfs:domain ind:DbpMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monobromoaceticAcidConcentrationUgL rdf:type rdf:Property ;
    rdfs:label 'Monobromoacetic Acid Concentration Ug L' ;
    rdfs:comment 'Measured concentration of monobromoacetic acid (MBAA), a haloacetic acid species, in micrograms per liter.' ;
    rdfs:domain ind:DbpMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monochloroaceticAcidConcentrationUgL rdf:type rdf:Property ;
    rdfs:label 'Monochloroacetic Acid Concentration Ug L' ;
    rdfs:comment 'Measured concentration of monochloroacetic acid (MCAA), a haloacetic acid species, in micrograms per liter.' ;
    rdfs:domain ind:DbpMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedToStateDate rdf:type rdf:Property ;
    rdfs:label 'Reported To State Date' ;
    rdfs:comment 'The date when this monitoring event result was reported to the state primacy agency.' ;
