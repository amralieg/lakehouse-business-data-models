    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedByUserName rdf:type rdf:Property ;
    rdfs:label 'Approved By User Name' ;
    rdfs:comment 'Full name of the user who approved the document for audit and accountability purposes.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Timestamp when the document was officially approved for use or distribution.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
