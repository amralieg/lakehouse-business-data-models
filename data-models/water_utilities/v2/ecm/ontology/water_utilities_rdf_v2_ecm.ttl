    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniorCitizenFlag rdf:type rdf:Property ;
    rdfs:label 'Senior Citizen Flag' ;
    rdfs:comment 'Whether senior citizen discount applies' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceAddressCount rdf:type rdf:Property ;
    rdfs:label 'Service Address Count' ;
    rdfs:comment 'Number of service addresses on account' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceEndDate rdf:type rdf:Property ;
    rdfs:label 'Service End Date' ;
    rdfs:comment 'Date service ended if applicable' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Start Date' ;
    rdfs:comment 'Date service started' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Service type (water, sewer, both, reclaimed)' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shutoffProtected rdf:type rdf:Property ;
    rdfs:label 'Shutoff Protected' ;
    rdfs:comment 'Whether protected from shutoff' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shutoffProtectionReason rdf:type rdf:Property ;
    rdfs:label 'Shutoff Protection Reason' ;
    rdfs:comment 'Reason for shutoff protection' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExempt rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt' ;
    rdfs:comment 'Whether account is tax exempt' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptCertificate rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Certificate' ;
    rdfs:comment 'Tax exemption certificate number' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedAt rdf:type rdf:Property ;
    rdfs:label 'Updated At' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:updatedDate rdf:type rdf:Property ;
    rdfs:label 'Updated Date' ;
    rdfs:comment 'Record last update timestamp' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:personId rdf:type rdf:Property ;
    rdfs:label 'Person Id' ;
    rdfs:comment 'Unique identifier for the person record. Primary key for the person entity. Serves as the single source of truth for individual identity within the customer domain.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Person .

ind:serviceAddressId rdf:type rdf:Property ;
    rdfs:label 'Service Address Id' ;
    rdfs:comment 'FK to service address' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceAddress .

ind:autopayEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Autopay Enrollment Date' ;
    rdfs:comment 'The date when the person enrolled in or opted out of autopay in yyyy-MM-dd format. Used for payment preference tracking and billing operations.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:autopayEnrollmentFlag rdf:type rdf:Property ;
    rdfs:label 'Autopay Enrollment Flag' ;
    rdfs:comment 'Boolean flag indicating whether the person has enrolled in automatic payment (autopay) for their utility bills. True if enrolled in autopay, False otherwise. Used for payment processing and customer convenience tracking.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditCheckConsentDate rdf:type rdf:Property ;
    rdfs:label 'Credit Check Consent Date' ;
    rdfs:comment 'The date when the person provided consent for credit check in yyyy-MM-dd format. Used for compliance documentation and audit trails.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditCheckConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Check Consent Flag' ;
    rdfs:comment 'Boolean flag indicating whether the person has provided consent for the utility to perform a credit check. True if consent given, False otherwise. Required for deposit determination and account establishment.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'The business segment classification of the person based on their primary account relationship. Used for rate classification, service level determination, and customer analytics. Aligns with rate schedule eligibility.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsentDate rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent Date' ;
    rdfs:comment 'The date when the person provided or withdrew data sharing consent in yyyy-MM-dd format. Used for compliance documentation and privacy management.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSharingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent Flag' ;
    rdfs:comment 'Boolean flag indicating whether the person has consented to sharing their data with third parties (e.g., energy efficiency program partners, government agencies, research organizations). True if consent given, False otherwise.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'The person\'s date of birth in yyyy-MM-dd format. Used for identity verification, age-based service eligibility (e.g., senior citizen rates), and compliance with age-restricted service programs.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disabilityAccommodationFlag rdf:type rdf:Property ;
    rdfs:label 'Disability Accommodation Flag' ;
    rdfs:comment 'Boolean flag indicating whether the person requires disability accommodations for service delivery, communications, or billing. True if accommodations required, False otherwise. Used to ensure accessible service delivery.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disabilityAccommodationNotes rdf:type rdf:Property ;
    rdfs:label 'Disability Accommodation Notes' ;
    rdfs:comment 'Free-text notes describing specific disability accommodations required by the person (e.g., large print bills, TTY/TDD phone service, accessible meter location). Used to ensure appropriate service delivery and ADA compliance.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentIdExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Government Id Expiration Date' ;
    rdfs:comment 'The expiration date of the government-issued identification document in yyyy-MM-dd format. Used to ensure identity verification documents remain current and valid.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governmentIdIssuingState rdf:type rdf:Property ;
    rdfs:label 'Government Id Issuing State' ;
    rdfs:comment 'The U.S. state or territory that issued the government identification document. Used for identity verification and fraud prevention. Two-letter state abbreviation (e.g., CA, NY, TX).' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentIdNumberMasked rdf:type rdf:Property ;
    rdfs:label 'Government Id Number Masked' ;
    rdfs:comment 'The masked or partially redacted government-issued identification number (e.g., last 4 digits of SSN, masked driver\'s license number). Full number stored in secure vault; this field contains display-safe version for operational use.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentIdType rdf:type rdf:Property ;
    rdfs:label 'Government Id Type' ;
    rdfs:comment 'The type of government-issued identification document provided by the person for identity verification during account application or service connection. Used to comply with customer identification requirements.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Date' ;
    rdfs:comment 'The date when the person\'s identity was successfully verified in yyyy-MM-dd format. Used for audit trails and compliance reporting on customer identification procedures.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identityVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Method' ;
    rdfs:comment 'The method used to verify the person\'s identity (in-person document review, online verification service, mail-in documentation, third-party identity verification service). Used for audit and compliance tracking.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Status' ;
    rdfs:comment 'The current status of the person\'s identity verification process. Indicates whether government-issued identification has been validated and approved for service connection and account establishment.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalFirstName rdf:type rdf:Property ;
    rdfs:label 'Legal First Name' ;
    rdfs:comment 'The legal first name of the person as it appears on government-issued identification documents. Used for identity verification and legal correspondence.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalLastName rdf:type rdf:Property ;
    rdfs:label 'Legal Last Name' ;
    rdfs:comment 'The legal last name (surname) of the person as it appears on government-issued identification documents. Used for identity verification and legal correspondence.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalMiddleName rdf:type rdf:Property ;
    rdfs:label 'Legal Middle Name' ;
    rdfs:comment 'The legal middle name or initial of the person as it appears on government-issued identification documents. May be null if not provided.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifeSupportEquipmentFlag rdf:type rdf:Property ;
    rdfs:label 'Life Support Equipment Flag' ;
    rdfs:comment 'Boolean flag indicating whether the person or household member relies on life-support medical equipment that requires uninterrupted water service. True if life-support equipment present, False otherwise. Used for service disconnection protection and emergency prioritization.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifeSupportVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Life Support Verification Date' ;
    rdfs:comment 'The date when the life-support equipment status was verified by medical certification in yyyy-MM-dd format. Used for program compliance and annual recertification tracking.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lowIncomeAssistanceEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Low Income Assistance Eligible Flag' ;
    rdfs:comment 'Boolean flag indicating whether the person is eligible for low-income assistance programs, rate discounts, or payment assistance based on income verification. True if eligible, False otherwise. Used for social equity program administration.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowIncomeVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Low Income Verification Date' ;
    rdfs:comment 'The date when the person\'s low-income status was verified for assistance program eligibility in yyyy-MM-dd format. Used for program compliance and recertification tracking.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingConsentDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent Date' ;
    rdfs:comment 'The date when the person provided or withdrew marketing consent in yyyy-MM-dd format. Used for compliance documentation and preference management.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent Flag' ;
    rdfs:comment 'Boolean flag indicating whether the person has consented to receive marketing communications and promotional materials from the utility. True if consent given, False otherwise. Used to comply with marketing communication regulations.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paperlessBillingEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Paperless Billing Enrollment Date' ;
    rdfs:comment 'The date when the person enrolled in or opted out of paperless billing in yyyy-MM-dd format. Used for billing preference tracking and environmental impact reporting.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:personStatus rdf:type rdf:Property ;
    rdfs:label 'Person Status' ;
    rdfs:comment 'The current lifecycle status of the person record. Active indicates the person is currently associated with one or more accounts. Inactive indicates no current account relationships. Deceased, merged, and duplicate statuses support data quality and master data management.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personType rdf:type rdf:Property ;
    rdfs:label 'Person Type' ;
    rdfs:comment 'The role or relationship type of the person within the customer domain. Distinguishes between account holders, co-applicants, authorized contacts, guarantors, and other person roles. One person may have multiple types across different accounts.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'The person\'s preferred method for receiving utility communications and notifications. Used to honor customer communication preferences and improve engagement rates.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'The name the person prefers to be called in day-to-day interactions, which may differ from their legal name. Used for customer service communications and personalization.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhoneType rdf:type rdf:Property ;
    rdfs:label 'Primary Phone Type' ;
    rdfs:comment 'The type of primary phone number (mobile, home, work, other). Used to determine appropriate communication channels and times for customer outreach.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryPhone rdf:type rdf:Property ;
    rdfs:label 'Secondary Phone' ;
    rdfs:comment 'An alternate contact phone number for the person. Used as backup contact method when primary phone is unavailable or for emergency escalation.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryPhoneType rdf:type rdf:Property ;
    rdfs:label 'Secondary Phone Type' ;
    rdfs:comment 'The type of secondary phone number (mobile, home, work, other). Used to determine appropriate communication channels and times for alternate contact.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suffix rdf:type rdf:Property ;
    rdfs:label 'Suffix' ;
    rdfs:comment 'Generational or professional suffix appended to the person\'s legal name (e.g., Jr, Sr, II, III). Used to distinguish individuals with identical names.' ;
    rdfs:domain ind:Person ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Parent Organization Id' ;
    rdfs:comment 'Reference to the parent organization in corporate hierarchies. Enables consolidated billing, enterprise account management, and multi-location reporting for corporate customers.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:accountClosedDate rdf:type rdf:Property ;
    rdfs:label 'Account Closed Date' ;
    rdfs:comment 'Date when the organization\'s account was closed or terminated. Null for active accounts.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Account Opened Date' ;
    rdfs:comment 'Date when the organization\'s first service account was established with the utility. Used for customer tenure analysis and loyalty program eligibility.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualRevenueRange rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Range' ;
    rdfs:comment 'Estimated annual revenue range of the organization. Used for credit assessment, account prioritization, and business development targeting.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoPayEnrolledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enrolled Flag' ;
    rdfs:comment 'Indicates whether the organization is enrolled in automatic payment processing. True if enrolled, False otherwise.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the organization\'s billing address, typically street number and name. Used for invoice delivery and legal correspondence.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of billing address for suite, floor, or department information.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City name for the organization\'s billing address.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountry rdf:type rdf:Property ;
    rdfs:label 'Billing Country' ;
    rdfs:comment 'Three-letter ISO country code for the organization\'s billing address.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'ZIP or ZIP+4 postal code for the organization\'s billing address.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingState rdf:type rdf:Property ;
    rdfs:label 'Billing State' ;
    rdfs:comment 'Two-letter state code for the organization\'s billing address.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum outstanding balance allowed for the organization before service restrictions are applied. Expressed in USD.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditTier rdf:type rdf:Property ;
    rdfs:label 'Credit Tier' ;
    rdfs:comment 'Internal credit rating tier assigned to the organization based on payment history, financial strength, and risk assessment. Determines deposit requirements and payment terms.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'Trade name or fictitious business name under which the organization operates, if different from legal name. Used for customer-facing communications and service delivery.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCountRange rdf:type rdf:Property ;
    rdfs:label 'Employee Count Range' ;
    rdfs:comment 'Estimated number of employees at the organization. Used for water demand forecasting and commercial rate structure assignment. [ENUM-REF-CANDIDATE: 1_to_10|11_to_50|51_to_200|201_to_500|501_to_1000|over_1000|unknown — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:federalTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Federal Tax Number' ;
    rdfs:comment 'IRS-issued Employer Identification Number (EIN) for tax reporting and identification purposes. Nine-digit number in format XX-XXXXXXX.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'Date the organization was legally incorporated, registered, or chartered. Used for account tenure analysis and credit assessment.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incorporationState rdf:type rdf:Property ;
    rdfs:label 'Incorporation State' ;
    rdfs:comment 'Two-letter state code where the organization is legally incorporated or registered. Used for jurisdictional compliance and legal correspondence.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:industrialUserClassification rdf:type rdf:Property ;
    rdfs:label 'Industrial User Classification' ;
    rdfs:comment 'EPA classification level for industrial users subject to pretreatment requirements. Categorical Industrial User (CIU) discharges regulated pollutants; Significant Industrial User (SIU) meets discharge thresholds; Non-Significant does not meet thresholds.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrialUserFlag rdf:type rdf:Property ;
    rdfs:label 'Industrial User Flag' ;
    rdfs:comment 'Indicates whether the organization is classified as an industrial user subject to pretreatment program requirements under the Clean Water Act. True if industrial user, False otherwise.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iupExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Iup Expiration Date' ;
    rdfs:comment 'Date when the current IUP permit expires and renewal is required. Used for compliance tracking and permit renewal notifications.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iupPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Iup Permit Number' ;
    rdfs:comment 'Permit number issued for industrial users authorized to discharge wastewater into the municipal collection system. Required for tracking pretreatment compliance and discharge monitoring.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The official registered legal name of the organization as filed with state incorporation documents or municipal charter. Used for contracts, billing, and regulatory reporting.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naicsCode rdf:type rdf:Property ;
    rdfs:label 'Naics Code' ;
    rdfs:comment 'Six-digit NAICS code identifying the organization\'s primary industry sector. Used for industrial user classification, rate structure assignment, and regulatory reporting.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationType rdf:type rdf:Property ;
    rdfs:label 'Organization Type' ;
    rdfs:comment 'Legal structure classification of the organization. Determines billing rules, credit policies, and regulatory treatment.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary contact for electronic billing, service notifications, and account correspondence.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary telephone number for reaching the organization contact. Used for urgent service notifications, outage alerts, and account inquiries.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Job title or role of the primary contact person within the organization (e.g., Facilities Manager, CFO, City Manager).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sicCode rdf:type rdf:Property ;
    rdfs:label 'Sic Code' ;
    rdfs:comment 'Four-digit SIC code for legacy industry classification. Maintained for historical reporting and systems that have not migrated to NAICS.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialBillingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Billing Instructions' ;
    rdfs:comment 'Free-text field for custom billing requirements, invoice formatting preferences, or special handling instructions for the organization account.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Certificate Number' ;
    rdfs:comment 'State-issued tax exemption certificate number for organizations claiming tax-exempt status. Required for audit compliance.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether the organization is exempt from sales tax or utility taxes. True if tax-exempt (typically government entities), False otherwise.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Public website URL for the organization. Used for customer research and business development.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmaId rdf:type rdf:Property ;
    rdfs:label 'Dma Id' ;
    rdfs:comment 'Foreign key linking to distribution.dma. Business justification: Service addresses fall within District Metered Areas for non-revenue water tracking, leak detection program management, and consumption pattern analysis. Essential for AWWA water audit compliance, tar' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dma .

ind:parcelId rdf:type rdf:Property ;
    rdfs:label 'Parcel Id' ;
    rdfs:comment 'Foreign key linking to customer.parcel. Business justification: Service address is physically located on a land parcel; linking provides geographic context and eliminates isolated parcel table.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Parcel .

ind:addressEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Address Effective Date' ;
    rdfs:comment 'Date when this service address became effective and available for service delivery. Start of the address lifecycle.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressEndDate rdf:type rdf:Property ;
    rdfs:label 'Address End Date' ;
    rdfs:comment 'Date when this service address was retired or became unavailable for service. Null if address is still active.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for apartment number, suite, unit, building, floor, or other location qualifier within the premise.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressNotes rdf:type rdf:Property ;
    rdfs:label 'Address Notes' ;
    rdfs:comment 'Free-text notes or comments about the service address including special access instructions, delivery restrictions, or historical context.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Address Source System' ;
    rdfs:comment 'Name of the source system or application that created or last updated this service address record (e.g., CC&B, GIS, CRM).' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Lifecycle status of the service address record. Values: active (currently serviceable), inactive (temporarily not in use), pending (awaiting activation), retired (permanently closed).' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Address Validation Status' ;
    rdfs:comment 'Status indicating whether the address has been validated against USPS or other authoritative address databases. Values: validated, unvalidated, corrected, invalid.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apn rdf:type rdf:Property ;
    rdfs:label 'Apn' ;
    rdfs:comment 'County assessor parcel number uniquely identifying the land parcel for property tax and ownership purposes. Links service address to GIS parcel data.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingType rdf:type rdf:Property ;
    rdfs:label 'Building Type' ;
    rdfs:comment 'Type or classification of building structure at the service address (e.g., single-family, multi-family, office, retail, warehouse, school).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the service address (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:county rdf:type rdf:Property ;
    rdfs:label 'County' ;
    rdfs:comment 'County or parish name where the service address is located. Used for regulatory reporting and jurisdictional compliance.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floodZoneDesignation rdf:type rdf:Property ;
    rdfs:label 'Flood Zone Designation' ;
    rdfs:comment 'FEMA flood zone classification (e.g., A, AE, X, VE) indicating flood risk level. Used for infrastructure planning and emergency response.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gisFeatureCode rdf:type rdf:Property ;
    rdfs:label 'Gis Feature Code' ;
    rdfs:comment 'Unique identifier linking this service address to the corresponding feature in the Esri ArcGIS spatial database for network modeling and asset management.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Meter Location Description' ;
    rdfs:comment 'Free-text description of where the water meter is physically located at the premise (e.g., front yard, basement, alley, inside garage).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occupancyStatus rdf:type rdf:Property ;
    rdfs:label 'Occupancy Status' ;
    rdfs:comment 'Current occupancy status of the premise. Values: occupied, vacant, seasonal, under_construction.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressureZone rdf:type rdf:Property ;
    rdfs:label 'Pressure Zone' ;
    rdfs:comment 'Water distribution pressure zone identifier indicating the hydraulic zone serving this address. Used for hydraulic modeling and pressure management.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Service Territory Code' ;
    rdfs:comment 'Code identifying the utility service territory or franchise area where the address is located. Determines regulatory jurisdiction and service provider.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sewerBasin rdf:type rdf:Property ;
    rdfs:label 'Sewer Basin' ;
    rdfs:comment 'Wastewater collection basin or drainage area identifier indicating which sewer system and treatment plant serve this address.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardizedAddress rdf:type rdf:Property ;
    rdfs:label 'Standardized Address' ;
    rdfs:comment 'Fully standardized and concatenated address string following USPS formatting rules. Used for address matching and deduplication.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withinServiceBoundaryFlag rdf:type rdf:Property ;
    rdfs:label 'Within Service Boundary Flag' ;
    rdfs:comment 'Boolean flag indicating whether the address is within the utility\'s authorized service boundary. True if within boundary, False if outside.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:premiseId rdf:type rdf:Property ;
    rdfs:label 'Premise Id' ;
    rdfs:comment 'Unique identifier for the premise record. Primary key representing the utility\'s asset record for a serviceable location.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Premise .

ind:connectedPipeMainId rdf:type rdf:Property ;
    rdfs:label 'Connected Pipe Main Id' ;
    rdfs:comment 'Foreign key linking to distribution.pipe_main. Business justification: Premises physically connect to specific distribution mains for water service delivery. Essential for hydraulic modeling, service line inventory (LCRR compliance), outage impact analysis, and main brea' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipeMain .

ind:backflowPreventionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Backflow Prevention Required Flag' ;
    rdfs:comment 'Indicates whether the premise requires backflow prevention devices due to cross-connection hazards. Mandatory for commercial, industrial, and irrigation services per Safe Drinking Water Act (SDWA).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buildingSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Building Square Footage' ;
    rdfs:comment 'Total conditioned floor area of structures on the premise in square feet. Used for commercial water demand forecasting and capacity fee assessments.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:connectionFeePaidAmount rdf:type rdf:Property ;
    rdfs:label 'Connection Fee Paid Amount' ;
    rdfs:comment 'Total one-time connection or capacity fees paid for this premise to establish utility service. Includes system development charges and impact fees.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:connectionFeePaidDate rdf:type rdf:Property ;
    rdfs:label 'Connection Fee Paid Date' ;
    rdfs:comment 'Date when connection or capacity fees were paid for this premise. Used for revenue recognition and capital improvement program (CIP) funding tracking.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constructionYear rdf:type rdf:Property ;
    rdfs:label 'Construction Year' ;
    rdfs:comment 'Year the primary structure on the premise was originally constructed. Used for infrastructure age analysis and lead service line risk assessment per Lead and Copper Rule Revisions (LCRR).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:districtMeteredAreaCode rdf:type rdf:Property ;
    rdfs:label 'District Metered Area Code' ;
    rdfs:comment 'Code identifying the District Metered Area (DMA) for water loss management and Non-Revenue Water (NRW) tracking. Used for hydraulic zone analysis.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when this premise record was retired or became inactive. Null for currently active premises. Supports temporal data management and historical analysis.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when this premise record became active and available for service connections. Supports temporal data management and historical analysis.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:elevationFeet rdf:type rdf:Property ;
    rdfs:label 'Elevation Feet' ;
    rdfs:comment 'Ground elevation of the premise in feet above mean sea level. Critical for hydraulic pressure calculations and gravity sewer flow analysis.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDailyDemandGallons rdf:type rdf:Property ;
    rdfs:label 'Estimated Daily Demand Gallons' ;
    rdfs:comment 'Projected average daily water consumption in gallons for this premise based on premise type, units, and historical usage patterns. Used for capacity planning and meter sizing.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fatsOilsGreaseProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Fats Oils Grease Program Flag' ;
    rdfs:comment 'Indicates whether the premise is subject to Fats, Oils, and Grease (FOG) control program requirements. Applicable to food service establishments to prevent Sanitary Sewer Overflows (SSO).' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fireProtectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Fire Protection Required Flag' ;
    rdfs:comment 'Indicates whether the premise requires dedicated fire protection service (fire hydrant or sprinkler connection). Determines fire service charge applicability.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industrialUserPermitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Industrial User Permit Required Flag' ;
    rdfs:comment 'Indicates whether the premise requires an Industrial User Permit (IUP) for wastewater discharge due to industrial processes. Triggers pretreatment program compliance monitoring.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizeSquareFeet rdf:type rdf:Property ;
    rdfs:label 'Lot Size Square Feet' ;
    rdfs:comment 'Total land area of the premise parcel in square feet. Used for irrigation demand estimation and stormwater fee calculations.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meterSizeInches rdf:type rdf:Property ;
    rdfs:label 'Meter Size Inches' ;
    rdfs:comment 'Standard meter size in inches required or installed at this premise based on demand characteristics. Common sizes: 0.625, 0.75, 1.0, 1.5, 2.0, 3.0, 4.0, 6.0, 8.0 inches.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfUnits rdf:type rdf:Property ;
    rdfs:label 'Number Of Units' ;
    rdfs:comment 'Count of individual dwelling or tenant units within the premise. Applicable for multi-family residential and commercial properties. Used for equivalent dwelling unit (EDU) calculations.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parcelNumber rdf:type rdf:Property ;
    rdfs:label 'Parcel Number' ;
    rdfs:comment 'County assessor\'s parcel number (APN) or tax lot identifier for the property. Used for cross-reference with property tax records and GIS systems.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakDemandGpm rdf:type rdf:Property ;
    rdfs:label 'Peak Demand Gpm' ;
    rdfs:comment 'Estimated peak instantaneous water demand in Gallons Per Minute (GPM) for this premise. Used for hydraulic modeling and service line sizing.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiseNumber rdf:type rdf:Property ;
    rdfs:label 'Premise Number' ;
    rdfs:comment 'Externally-known business identifier for the premise, used in customer communications and field operations. Unique across the utility service territory.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiseStatus rdf:type rdf:Property ;
    rdfs:label 'Premise Status' ;
    rdfs:comment 'Current lifecycle status of the premise in the utility\'s service inventory. Determines whether the premise is available for service connection.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiseType rdf:type rdf:Property ;
    rdfs:label 'Premise Type' ;
    rdfs:comment 'Classification of the premise based on its primary use and service characteristics. Determines applicable rate schedules and service requirements.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reclaimedWaterServiceAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Reclaimed Water Service Available Flag' ;
    rdfs:comment 'Indicates whether recycled or reclaimed water distribution infrastructure is available for non-potable uses such as irrigation. Part of water conservation programs.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLineDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Service Line Diameter Inches' ;
    rdfs:comment 'Internal diameter of the water service line in inches. Determines flow capacity and pressure loss from main to premise.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLineMaterial rdf:type rdf:Property ;
    rdfs:label 'Service Line Material' ;
    rdfs:comment 'Material composition of the water service line connecting the distribution main to the premise. Critical for Lead and Copper Rule Revisions (LCRR) compliance and lead service line inventory. [ENUM-REF-CANDIDATE: copper|galvanized_steel|lead|pvc|pex|hdpe|unknown — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sewerLateralDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Sewer Lateral Diameter Inches' ;
    rdfs:comment 'Internal diameter of the sanitary sewer lateral in inches. Determines wastewater conveyance capacity from premise to collection system.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sewerLateralMaterial rdf:type rdf:Property ;
    rdfs:label 'Sewer Lateral Material' ;
    rdfs:comment 'Material composition of the sanitary sewer lateral connecting the premise to the collection main. Used for Inflow and Infiltration (I&I) risk assessment.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialNotes rdf:type rdf:Property ;
    rdfs:label 'Special Notes' ;
    rdfs:comment 'Free-text field for operational notes, access instructions, or unique characteristics of the premise relevant to field service personnel and customer service representatives.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stormwaterServiceAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Stormwater Service Available Flag' ;
    rdfs:comment 'Indicates whether stormwater drainage infrastructure serves this premise. Determines applicability of stormwater utility fees.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wastewaterServiceAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Wastewater Service Available Flag' ;
    rdfs:comment 'Indicates whether sanitary sewer collection infrastructure is available to serve this premise. True if sewer mains are accessible within standard connection distance.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterServiceAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Water Service Available Flag' ;
    rdfs:comment 'Indicates whether potable water distribution infrastructure is available to serve this premise. True if water mains are accessible within standard connection distance.' ;
    rdfs:domain ind:Premise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoningClassification rdf:type rdf:Property ;
    rdfs:label 'Zoning Classification' ;
    rdfs:comment 'Municipal zoning code designation for the premise parcel. Determines permitted land uses and development density. Format varies by jurisdiction.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Service Agreement Id' ;
    rdfs:comment 'Unique identifier for the customer_service_agreement data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceAgreement .

ind:billingRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Schedule Id' ;
    rdfs:comment 'Applicable billing rate schedule' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingRateSchedule .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the bulk water agreement based on the nature of service: wholesale supply (ongoing large-volume delivery), bulk purchase (one-time or periodic large purchases), emergency interconnection (backup supply during outages), seasonal supply (peak demand periods), treatment services (wastewater treatment for another utility), or wastewater discharge (acceptance of wastewater flows).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPayEnrolled rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enrolled' ;
    rdfs:comment 'Whether enrolled in automatic payment' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoPayFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Flag' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenew rdf:type rdf:Property ;
    rdfs:label 'Auto Renew' ;
    rdfs:comment 'Auto renew' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backflowDeviceRequired rdf:type rdf:Property ;
    rdfs:label 'Backflow Device Required' ;
    rdfs:comment 'Whether backflow prevention required' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backflowPreventionRequired rdf:type rdf:Property ;
    rdfs:label 'Backflow Prevention Required' ;
    rdfs:comment 'Whether backflow prevention device is required' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backflowRequired rdf:type rdf:Property ;
    rdfs:label 'Backflow Required' ;
    rdfs:comment 'Whether backflow prevention required' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
