    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardIndexComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Hazard Index Compliance Status' ;
    rdfs:comment 'Compliance status for the hazard index (COMPLIANT if HI<=1.0, EXCEEDS if HI>1.0).' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardIndexCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Hazard Index Compliant Flag' ;
