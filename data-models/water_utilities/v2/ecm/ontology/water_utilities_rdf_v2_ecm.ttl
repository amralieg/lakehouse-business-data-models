    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countyName rdf:type rdf:Property ;
    rdfs:label 'County Name' ;
    rdfs:comment 'Primary county in which the service territory is located, used for regulatory reporting and jurisdictional analysis.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Number' ;
    rdfs:comment 'Identifier of the regulatory franchise agreement or certificate of public convenience and necessity (CPCN) authorizing service in this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Expiration Date' ;
    rdfs:comment 'Date when the current franchise agreement or certificate expires and requires renewal or renegotiation.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industrialCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Industrial Customer Count' ;
    rdfs:comment 'Number of industrial customer accounts within the territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable name of the service territory (e.g., \'Downtown District\', \'North County Service Area\').' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npdesPermitJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Npdes Permit Jurisdiction' ;
    rdfs:comment 'Regulatory authority responsible for wastewater discharge permits under the Clean Water Act (CWA) in this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingDivisionCode rdf:type rdf:Property ;
    rdfs:label 'Operating Division Code' ;
    rdfs:comment 'Internal code identifying the utility\'s operating division or business unit responsible for service delivery in this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakDailyDemandMgd rdf:type rdf:Property ;
    rdfs:label 'Peak Daily Demand Mgd' ;
    rdfs:comment 'Peak daily water demand for the territory measured in million gallons per day, used for infrastructure sizing and emergency planning.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potableWaterServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Potable Water Service Flag' ;
    rdfs:comment 'Indicates whether the utility provides potable (drinking) water service within this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predecessorUtilityName rdf:type rdf:Property ;
    rdfs:label 'Predecessor Utility Name' ;
    rdfs:comment 'Name of the previous utility that served this territory before acquisition or transfer, used for historical data lineage.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primacyAgencyJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Primacy Agency Jurisdiction' ;
    rdfs:comment 'State or federal agency with primary regulatory authority over drinking water quality in this territory (e.g., \'California State Water Resources Control Board\').' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateZoneCode rdf:type rdf:Property ;
    rdfs:label 'Rate Zone Code' ;
    rdfs:comment 'Code identifying the rate zone or pricing district applicable to customers in this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recycledWaterServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Recycled Water Service Flag' ;
    rdfs:comment 'Indicates whether the utility provides recycled (reclaimed) water service for non-potable uses within this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'Name of the state or local regulatory body with jurisdiction over rates and service quality in this territory (e.g., \'California Public Utilities Commission\').' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Residential Customer Count' ;
    rdfs:comment 'Number of residential customer accounts within the territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceCenterLocation rdf:type rdf:Property ;
    rdfs:label 'Service Center Location' ;
    rdfs:comment 'Name or identifier of the primary service center or operations facility serving this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceClassification rdf:type rdf:Property ;
    rdfs:label 'Service Classification' ;
    rdfs:comment 'Geographic and demographic classification of the territory, used for rate design and infrastructure planning.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stormwaterServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Stormwater Service Flag' ;
    rdfs:comment 'Indicates whether the utility provides stormwater management service within this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tariffScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Tariff Schedule Reference' ;
    rdfs:comment 'Reference to the applicable rate tariff schedule approved by the regulatory authority for this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current operational status of the service territory in the utility\'s service portfolio.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of the service territory based on regulatory authorization and service delivery model.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wastewaterServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Wastewater Service Flag' ;
    rdfs:comment 'Indicates whether the utility provides wastewater collection and treatment service within this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageMonthlyConsumptionGallons rdf:type rdf:Property ;
    rdfs:label 'Average Monthly Consumption Gallons' ;
    rdfs:comment 'Typical average monthly water consumption in gallons for accounts in this service class. Used for rate modeling and demand forecasting.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awwaClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Awwa Classification Code' ;
    rdfs:comment 'Standard classification code from AWWA M1 Manual used for industry benchmarking and best practice alignment.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycleType rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Type' ;
    rdfs:comment 'Standard billing frequency for accounts in this service class (e.g., monthly, bimonthly, quarterly). Determines meter reading and invoice generation schedules.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classType rdf:type rdf:Property ;
    rdfs:label 'Class Type' ;
    rdfs:comment 'High-level category of the service class used for grouping and analysis. Aligns with regulatory reporting categories. [ENUM-REF-CANDIDATE: residential|commercial|industrial|irrigation|fire_protection|municipal|wholesale|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conservationProgramEligible rdf:type rdf:Property ;
    rdfs:label 'Conservation Program Eligible' ;
    rdfs:comment 'Indicates whether accounts in this service class are eligible for water conservation programs, rebates, or incentives.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumptionTierStructure rdf:type rdf:Property ;
    rdfs:label 'Consumption Tier Structure' ;
    rdfs:comment 'Type of rate structure applied to consumption for this class (e.g., flat rate, tiered/block rates, seasonal rates, time-of-use rates).' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Requirement Amount' ;
    rdfs:comment 'Standard security deposit amount required for new accounts in this service class. May vary based on credit risk and consumption history.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceClassDescription rdf:type rdf:Property ;
    rdfs:label 'Service Class Description' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disconnectionPolicy rdf:type rdf:Property ;
    rdfs:label 'Disconnection Policy' ;
    rdfs:comment 'Policy governing service disconnection for non-payment for this class (e.g., standard, protected for vulnerable populations, restricted for essential services).' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireFlowRequirementGpm rdf:type rdf:Property ;
    rdfs:label 'Fire Flow Requirement Gpm' ;
    rdfs:comment 'Minimum fire flow capacity requirement in gallons per minute (GPM) for properties served under this class. Applicable primarily to commercial, industrial, and fire protection classes.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:latePaymentPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Rate' ;
    rdfs:comment 'Percentage rate applied to overdue balances for accounts in this service class. Subject to regulatory limits.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumChargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge Applicable' ;
    rdfs:comment 'Indicates whether a minimum monthly or periodic charge applies to accounts in this service class, regardless of consumption.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakDemandFactor rdf:type rdf:Property ;
    rdfs:label 'Peak Demand Factor' ;
    rdfs:comment 'Multiplier representing the ratio of peak demand to average demand for this service class. Used in capacity planning and infrastructure sizing.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pressureRequirementPsi rdf:type rdf:Property ;
    rdfs:label 'Pressure Requirement Psi' ;
    rdfs:comment 'Minimum service pressure requirement in pounds per square inch (PSI) for accounts in this service class. Ensures adequate pressure for intended use.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pucApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Puc Approval Date' ;
    rdfs:comment 'Date when the Public Utilities Commission approved this service class and its associated rate structure. Required for regulated utilities.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pucFilingReference rdf:type rdf:Property ;
    rdfs:label 'Puc Filing Reference' ;
    rdfs:comment 'Reference number or identifier of the PUC rate case filing or tariff document that established or modified this service class.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateScheduleGroup rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Group' ;
    rdfs:comment 'Identifier of the rate schedule group applicable to this service class. Links the class to specific rate structures and tariff schedules for billing purposes.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalNotificationDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Days' ;
    rdfs:comment 'Number of days advance notice required before contract renewal or rate changes for this service class.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalRateApplicable rdf:type rdf:Property ;
    rdfs:label 'Seasonal Rate Applicable' ;
    rdfs:comment 'Indicates whether seasonal rate variations (e.g., higher summer rates for irrigation) apply to this service class.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceAssetClassId rdf:type rdf:Property ;
    rdfs:label 'Service Asset Class Id' ;
    rdfs:comment 'References the single source of truth record in asset.asset_class' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceClassStatus rdf:type rdf:Property ;
    rdfs:label 'Service Class Status' ;
    rdfs:comment 'Current lifecycle status of the service class. Active classes are available for new account assignments; deprecated classes are phased out but may have existing accounts.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelAgreementTier rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement Tier' ;
    rdfs:comment 'Service level tier defining response times, service restoration priorities, and quality commitments for this class (e.g., standard, priority, premium, critical).' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffClassification rdf:type rdf:Property ;
    rdfs:label 'Tariff Classification' ;
    rdfs:comment 'Official tariff classification as filed with and approved by the Public Utilities Commission. Used for rate case modeling and tariff compliance.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterQualityMonitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Water Quality Monitoring Frequency' ;
    rdfs:comment 'Required frequency of water quality monitoring or testing for accounts in this service class. More stringent for industrial and high-risk classes.' ;
    rdfs:domain ind:ServiceClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceOfferingId rdf:type rdf:Property ;
    rdfs:label 'Service Offering Id' ;
    rdfs:comment 'Reference to the specific service offering (water, wastewater, reclaimed water, stormwater) that this agreement covers. Links to the service catalog.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:autoPayEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled' ;
    rdfs:comment 'Indicates whether automatic payment is enabled for this service agreement. When true, invoices are automatically paid from the customers designated payment method.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether the service agreement automatically renews at the end of the contract term. When false, agreement requires explicit renewal action.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Budget Billing Enabled' ;
    rdfs:comment 'Indicates whether the customer is enrolled in budget billing program, which averages annual usage into equal monthly payments to reduce seasonal bill variation.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:industrialUserPermitRequired rdf:type rdf:Property ;
    rdfs:label 'Industrial User Permit Required' ;
    rdfs:comment 'Indicates whether this service agreement requires an Industrial User Permit for wastewater discharge per NPDES (National Pollutant Discharge Elimination System) pretreatment program requirements.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irrigationServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Irrigation Service Flag' ;
    rdfs:comment 'Indicates whether this agreement includes irrigation or outdoor water service, which may be billed separately or subject to seasonal rates and wastewater exemptions.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowIncomeAssistanceEligible rdf:type rdf:Property ;
    rdfs:label 'Low Income Assistance Eligible' ;
    rdfs:comment 'Indicates whether this service agreement qualifies for low-income customer assistance programs, rate discounts, or payment plans per regulatory requirements.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumUsageCommitmentGallons rdf:type rdf:Property ;
    rdfs:label 'Minimum Usage Commitment Gallons' ;
    rdfs:comment 'Minimum water usage volume (in gallons) that the customer commits to consume per billing period. Common for commercial and industrial agreements. Used for minimum charge calculations.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paperlessBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Paperless Billing Enabled' ;
    rdfs:comment 'Indicates whether the customer has opted for electronic billing instead of paper invoices. Supports environmental sustainability initiatives.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seniorCitizenDiscountEligible rdf:type rdf:Property ;
    rdfs:label 'Senior Citizen Discount Eligible' ;
    rdfs:comment 'Indicates whether this service agreement qualifies for senior citizen rate discounts or special programs as defined by utility tariff.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Termination Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for service agreement termination. Examples include customer move-out, non-payment, property demolition, or service transfer.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when service delivery was first activated at this service point, marking the beginning of billable service. May differ from installation date if there was a delay between physical installation and service turn-on.' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amiEnabled rdf:type rdf:Property ;
    rdfs:label 'Ami Enabled' ;
    rdfs:comment 'Indicates whether this service point is equipped with Advanced Metering Infrastructure for automated remote meter reading and real-time consumption monitoring. True if AMI meter is installed; false for manual read meters.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:connectionMaterial rdf:type rdf:Property ;
    rdfs:label 'Connection Material' ;
    rdfs:comment 'Material composition of the service line connecting the distribution main to the customer premises. Critical for Lead and Copper Rule Revisions (LCRR) compliance and service line inventory reporting. [ENUM-REF-CANDIDATE: copper|pvc|hdpe|galvanized_steel|lead|ductile_iron|pex|unknown — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireServiceIndicator rdf:type rdf:Property ;
    rdfs:label 'Fire Service Indicator' ;
    rdfs:comment 'Indicates whether this service point includes fire protection service (fire sprinkler system or fire hydrant connection). True if fire service is provided; false for domestic-only service.' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointName rdf:type rdf:Property ;
    rdfs:label 'Point Name' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointType rdf:type rdf:Property ;
    rdfs:label 'Point Type' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCountryCode rdf:type rdf:Property ;
    rdfs:label 'Service Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the service point is located (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePointDescription rdf:type rdf:Property ;
    rdfs:label 'Service Point Description' ;
    rdfs:comment 'Free-text description providing additional context about the service point location, special characteristics, or access instructions for field personnel.' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePointNumber rdf:type rdf:Property ;
    rdfs:label 'Service Point Number' ;
    rdfs:comment 'Externally-known business identifier for the service point, typically displayed on customer bills and used in customer service interactions. Unique across the utility service territory.' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePointStatus rdf:type rdf:Property ;
    rdfs:label 'Service Point Status' ;
    rdfs:comment 'Current operational status of the service point in its lifecycle. Active indicates service is being delivered; inactive indicates no current service; suspended indicates temporary service hold; pending_activation indicates awaiting turn-on; disconnected indicates service terminated; abandoned indicates permanently retired.' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointStatus rdf:type rdf:Property ;
    rdfs:label 'Point Status' ;
    rdfs:domain ind:Point ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionApplicationId rdf:type rdf:Property ;
    rdfs:label 'Connection Application Id' ;
    rdfs:comment 'Unique identifier for the connection application record. Primary key.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConnectionApplication .

ind:connectionCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Connection Customer Account Id' ;
    rdfs:comment 'Identifier of the customer account associated with this connection application. Links to the customer master record.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:applicantEmail rdf:type rdf:Property ;
    rdfs:label 'Applicant Email' ;
    rdfs:comment 'Primary email address of the applicant for correspondence and notifications regarding the connection application.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantName rdf:type rdf:Property ;
    rdfs:label 'Applicant Name' ;
    rdfs:comment 'Full legal name of the individual or organization applying for the service connection.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantPhone rdf:type rdf:Property ;
    rdfs:label 'Applicant Phone' ;
    rdfs:comment 'Primary contact phone number of the applicant for communication regarding the connection application.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Application Fee Amount' ;
    rdfs:comment 'Fee charged for processing the connection application, in USD.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityAvailable rdf:type rdf:Property ;
    rdfs:label 'Capacity Available' ;
    rdfs:comment 'Indicates whether sufficient system capacity (pressure, flow, treatment capacity) is available to serve the requested connection without infrastructure upgrades.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Capacity Charge Amount' ;
    rdfs:comment 'System development or capacity charge assessed to fund infrastructure expansion to serve the new connection, in USD.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedFlowDemandGpm rdf:type rdf:Property ;
    rdfs:label 'Estimated Flow Demand Gpm' ;
    rdfs:comment 'Estimated peak flow demand in gallons per minute (GPM) for the requested service connection. Used for hydraulic modeling and capacity verification.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:infrastructureUpgradeRequired rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Upgrade Required' ;
    rdfs:comment 'Indicates whether main extensions, pump station upgrades, or other infrastructure improvements are required to serve the connection.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meterTypeRequested rdf:type rdf:Property ;
    rdfs:label 'Meter Type Requested' ;
    rdfs:comment 'Type or model of water meter requested or recommended for the connection (e.g., positive displacement, turbine, compound, electromagnetic).' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyType rdf:type rdf:Property ;
    rdfs:label 'Property Type' ;
    rdfs:comment 'Classification of the property requesting service: residential, commercial, industrial, institutional, agricultural, or mixed-use.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedServiceDate rdf:type rdf:Property ;
    rdfs:label 'Requested Service Date' ;
    rdfs:comment 'Date by which the applicant requests the service connection to be activated or completed.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:connectionApplicationStatus rdf:type rdf:Property ;
    rdfs:label 'Connection Application Status' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Technical Review Date' ;
    rdfs:comment 'Date when the technical feasibility and capacity review of the connection application was completed.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalFeesAssessed rdf:type rdf:Property ;
    rdfs:label 'Total Fees Assessed' ;
    rdfs:comment 'Total of all fees assessed for the connection application (application fee, connection fee, capacity charge, and any other charges), in USD.' ;
    rdfs:domain ind:ConnectionApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'System user identifier of the person or process that last modified the service order record.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:orderCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Order Customer Account Id' ;
    rdfs:comment 'Reference to the customer account associated with this service order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:primaryOrderCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Created By User Employee Id' ;
    rdfs:comment 'System user identifier of the person or process that created the service order record.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryOrderMeteringMeterId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Metering Meter Id' ;
    rdfs:comment 'Serial number or identifier of the meter removed during a meter exchange service order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeteringMeter .

ind:slaDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Id' ;
    rdfs:comment 'Foreign key linking to service.sla_definition. Business justification: Service orders are executed according to defined SLA standards. order currently has sla_target_hours, sla_actual_hours, and sla_met_flag. The target hours should be derived from sla_definition rather ' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaDefinition .

ind:tertiaryOrderModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Order Modified By User Employee Id' ;
    rdfs:comment 'System user identifier of the person or process that last modified the service order record.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual date and time when the field crew completed the service order activity.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Actual date and time when the field crew began performing the service order activity.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Appointment Window End' ;
    rdfs:comment 'End of the time window communicated to the customer for the service order appointment.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentWindowStart rdf:type rdf:Property ;
    rdfs:label 'Appointment Window Start' ;
    rdfs:comment 'Beginning of the time window communicated to the customer for the service order appointment.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:meterReadingUnit rdf:type rdf:Property ;
    rdfs:label 'Meter Reading Unit' ;
    rdfs:comment 'Unit of measure for the meter reading value captured during the service order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterReadingValue rdf:type rdf:Property ;
    rdfs:label 'Meter Reading Value' ;
    rdfs:comment 'Final meter reading captured during the service order activity, measured in appropriate units (gallons, cubic meters, etc.).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outcomeCode rdf:type rdf:Property ;
    rdfs:label 'Outcome Code' ;
    rdfs:comment 'Standardized code indicating the final outcome or result of the service order execution.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'Date when the customer or system requested the service order to be performed.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Planned date and time when the field crew is expected to complete the service order activity.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Precise date and time when the field crew is scheduled to begin the service order activity.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Service Fee Amount' ;
    rdfs:comment 'Monetary charge assessed to the customer for the service order activity, in US dollars.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaActualHours rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Hours' ;
    rdfs:comment 'Actual number of hours elapsed from order creation to completion, used for SLA compliance tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the service order was completed within the target SLA timeframe.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workPerformedDescription rdf:type rdf:Property ;
    rdfs:label 'Work Performed Description' ;
    rdfs:comment 'Detailed narrative description of the work actually performed by the field crew, including any findings or issues encountered.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Percentage' ;
    rdfs:comment 'Required percentage of time or occurrences that the SLA target must be met to maintain compliance, expressed as a percentage (e.g., 99.5% for high-availability commitments).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaDefinitionDescription rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Description' ;
    rdfs:comment 'Detailed description of the SLA commitment, including the business purpose, customer benefit, and operational context.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationProcedure rdf:type rdf:Property ;
    rdfs:label 'Escalation Procedure' ;
    rdfs:comment 'Defined escalation path or procedure to be followed when the SLA is breached, including management notification, regulatory reporting, and customer communication steps.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionConditions rdf:type rdf:Property ;
    rdfs:label 'Exclusion Conditions' ;
    rdfs:comment 'Conditions or circumstances under which the SLA does not apply or is temporarily suspended, such as force majeure events, natural disasters, regulatory-mandated shutdowns, or customer-requested service interruptions.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Geographic area or service territory to which this SLA applies: system-wide across all service areas, specific district, pressure zone, District Metered Area (DMA), or specific customer location.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Value' ;
    rdfs:comment 'Maximum acceptable value for the SLA metric, above which the SLA is considered breached. Applicable for metrics with upper bounds such as Maximum Contaminant Level (MCL), turbidity (NTU), or response time.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Value' ;
    rdfs:comment 'Minimum acceptable value for the SLA metric, below which the SLA is considered breached. Applicable for metrics with lower bounds such as minimum water pressure (PSI) or minimum pH.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationRequirement rdf:type rdf:Property ;
    rdfs:label 'Notification Requirement' ;
    rdfs:comment 'Timeframe within which customers or regulatory agencies must be notified of an SLA breach or service issue, such as immediate notification for water quality violations or 24-hour notice for planned outages.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Penalty Calculation Method' ;
    rdfs:comment 'Method used to calculate the penalty or credit: fixed amount per breach, per occurrence, per hour of non-compliance, per day, percentage of customer bill, or tiered based on severity or duration.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyType rdf:type rdf:Property ;
    rdfs:label 'Penalty Type' ;
    rdfs:comment 'Type of penalty or consequence applied when the SLA is breached: customer credit, service rebate, regulatory fine, escalation to management, or no penalty.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Business identifier code for the SLA definition, used for external reference and regulatory tariff filings.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Status' ;
    rdfs:comment 'Current lifecycle status of the SLA definition: active and enforceable, inactive, pending regulatory approval, superseded by a newer version, or temporarily suspended.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Human-readable name of the SLA definition, describing the commitment or guarantee.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Category of SLA commitment: response time for outage acknowledgment, restoration time for service recovery, water quality guarantee parameters, pressure guarantee thresholds, customer notification requirements, or system availability targets.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolutionHours rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Hours' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetResponseHours rdf:type rdf:Property ;
    rdfs:label 'Target Response Hours' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'Numeric target or threshold value for the SLA metric, representing the committed performance level or guarantee.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededTariffId rdf:type rdf:Property ;
    rdfs:label 'Superseded Tariff Id' ;
    rdfs:comment 'Reference to the prior tariff that this tariff replaces. Establishes the lineage of rate changes and enables historical rate analysis.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tariff .

ind:adjustmentClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Clause Flag' ;
    rdfs:comment 'Indicates whether the tariff includes automatic adjustment clauses or riders that allow for rate changes without a full rate case. Common adjustment clauses include purchased water adjustment clauses (PWAC), infrastructure surcharges, and cost recovery mechanisms for specific capital programs.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Order Number' ;
    rdfs:comment 'The official order or docket number issued by the regulatory authority approving this tariff. This reference links the tariff to the formal regulatory decision and provides traceability to the rate case proceeding.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffCode rdf:type rdf:Property ;
    rdfs:label 'Tariff Code' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conservationRateFlag rdf:type rdf:Property ;
    rdfs:label 'Conservation Rate Flag' ;
    rdfs:comment 'Indicates whether the tariff incorporates conservation-oriented rate design features such as increasing block rates, seasonal pricing, or water budget-based rates intended to promote efficient water use.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costOfServiceStudyReference rdf:type rdf:Property ;
    rdfs:label 'Cost Of Service Study Reference' ;
    rdfs:comment 'Reference to the cost-of-service study or rate design analysis that supports the tariff rates. This study allocates utility costs to customer classes and justifies the rate structure to the regulatory authority.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tariffDescription rdf:type rdf:Property ;
    rdfs:label 'Tariff Description' ;
    rdfs:comment 'A detailed narrative description of the tariff, including its purpose, scope, applicability, and key terms. This field captures the regulatory intent and business context of the tariff.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffName rdf:type rdf:Property ;
    rdfs:label 'Tariff Name' ;
    rdfs:comment 'The official name or title of the tariff as it appears in regulatory filings and customer communications.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Base Amount' ;
    rdfs:comment 'The net investment in utility plant and working capital upon which the utility is allowed to earn a return. Rate base is calculated as gross plant in service less accumulated depreciation plus working capital allowances.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateOfReturnPercent rdf:type rdf:Property ;
    rdfs:label 'Rate Of Return Percent' ;
    rdfs:comment 'The allowed rate of return on rate base approved by the regulatory authority. Expressed as a decimal percentage (e.g., 0.0725 for 7.25%). This is the weighted average cost of capital (WACC) the utility is permitted to earn.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Reference' ;
    rdfs:comment 'Reference to the detailed rate schedule document or section number within the tariff filing that specifies the complete pricing structure, including block tiers, surcharges, and adjustments.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Requirement Amount' ;
    rdfs:comment 'The total annual revenue requirement approved by the regulatory authority for the utility under this tariff. This is the aggregate revenue the utility is authorized to collect to cover operating expenses, capital costs, and allowed return on investment.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceRulesReference rdf:type rdf:Property ;
    rdfs:label 'Service Rules Reference' ;
    rdfs:comment 'Reference to the service rules, terms, and conditions document or section number within the tariff filing that governs service delivery, customer obligations, disconnection policies, and dispute resolution procedures.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffNumber rdf:type rdf:Property ;
    rdfs:label 'Tariff Number' ;
    rdfs:comment 'The official regulatory tariff number assigned by the Public Utilities Commission or state regulatory authority. This is the externally-known identifier used in all regulatory filings and rate case proceedings.' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffStatus rdf:type rdf:Property ;
    rdfs:label 'Tariff Status' ;
    rdfs:comment 'Current lifecycle status of the tariff filing. Draft indicates internal preparation, filed means submitted to the regulator, pending approval is under regulatory review, approved means accepted by the commission, active is currently in force, suspended is temporarily halted, superseded is replaced by a newer tariff, and withdrawn is retracted before approval. [ENUM-REF-CANDIDATE: draft|filed|pending_approval|approved|active|suspended|superseded|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffType rdf:type rdf:Property ;
    rdfs:label 'Tariff Type' ;
    rdfs:comment 'Classification of the tariff based on the customer segment and service arrangement it governs. General service tariffs apply to standard retail customers, special contracts cover negotiated agreements with large users, wholesale tariffs govern bulk water sales to other utilities, and industrial/municipal/residential/commercial designate specific customer classes. [ENUM-REF-CANDIDATE: general_service|special_contract|wholesale|industrial|municipal|residential|commercial — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tariff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affordabilityRatioPct rdf:type rdf:Property ;
    rdfs:label 'Affordability Ratio Pct' ;
    rdfs:comment 'Affordability ratio (water bill / median income)' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedIncreasePct rdf:type rdf:Property ;
    rdfs:label 'Approved Increase Pct' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedIncreasePercentage rdf:type rdf:Property ;
    rdfs:label 'Approved Increase Percentage' ;
    rdfs:comment 'Approved percentage increase' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedPercentage rdf:type rdf:Property ;
    rdfs:label 'Approved Percentage' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Revenue Amount' ;
    rdfs:comment 'Approved additional revenue amount' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedRevenueIncrease rdf:type rdf:Property ;
    rdfs:label 'Approved Revenue Increase' ;
    rdfs:comment 'Approved revenue increase' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedRevenueIncreaseAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Revenue Increase Amount' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedRevenueIncreasePct rdf:type rdf:Property ;
    rdfs:label 'Approved Revenue Increase Pct' ;
    rdfs:comment 'Approved revenue increase percentage' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedRevenueIncreaseUsd rdf:type rdf:Property ;
    rdfs:label 'Approved Revenue Increase Usd' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedRoePct rdf:type rdf:Property ;
    rdfs:label 'Authorized Roe Pct' ;
    rdfs:comment 'Authorized return on equity percentage' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalStructureEquityPct rdf:type rdf:Property ;
    rdfs:label 'Capital Structure Equity Pct' ;
    rdfs:comment 'Equity component of capital structure' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caseName rdf:type rdf:Property ;
    rdfs:label 'Case Name' ;
    rdfs:comment 'Rate case name' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseTitle rdf:type rdf:Property ;
    rdfs:label 'Case Title' ;
    rdfs:comment 'Title of the rate case' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfCapitalPct rdf:type rdf:Property ;
    rdfs:label 'Cost Of Capital Pct' ;
    rdfs:comment 'Cost of capital percentage' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentRevenueRequirement rdf:type rdf:Property ;
    rdfs:label 'Current Revenue Requirement' ;
    rdfs:comment 'Current revenue requirement' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerImpactAvgMonthly rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Avg Monthly' ;
    rdfs:comment 'Average monthly customer impact' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerImpactAvgMonthlyUsd rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Avg Monthly Usd' ;
    rdfs:comment 'Average monthly bill impact in USD' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationExpense rdf:type rdf:Property ;
    rdfs:label 'Depreciation Expense' ;
    rdfs:comment 'Depreciation expense' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceRateCaseDescription rdf:type rdf:Property ;
    rdfs:label 'Service Rate Case Description' ;
    rdfs:comment 'Description of the rate case' ;
    rdfs:domain ind:ServiceRateCase ;
    rdf:type owl:DatatypeProperty ;
