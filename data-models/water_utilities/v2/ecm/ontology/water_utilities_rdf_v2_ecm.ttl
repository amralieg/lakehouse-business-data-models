    rdfs:range ind:Laboratory .

ind:bedVolumesTreated rdf:type rdf:Property ;
    rdfs:label 'Bed Volumes Treated' ;
    rdfs:comment 'Number of bed volumes treated since last GAC/IX media change.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breakthroughPct rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Pct' ;
    rdfs:comment 'Percentage of MCL at which treatment media breakthrough is occurring.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionLimitNgL rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Ng L' ;
    rdfs:comment 'Method detection limit for the PFAS compound in ng/L.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionLimitPpt rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Ppt' ;
    rdfs:comment 'Method detection limit in ppt' ;
