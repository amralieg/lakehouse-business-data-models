    rdfs:comment 'Indicates whether the alert rule is active.' ;
    rdfs:domain ind:AlertRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationLevel rdf:type rdf:Property ;
