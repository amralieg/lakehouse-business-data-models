ind:ccrDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Ccr Delivery Flag' ;
    rdfs:comment 'Indicates whether this document is part of the annual Consumer Confidence Report (CCR) delivery requirement under the Safe Drinking Water Act (SDWA).' ;
    rdfs:domain ind:AccountDocument ;
