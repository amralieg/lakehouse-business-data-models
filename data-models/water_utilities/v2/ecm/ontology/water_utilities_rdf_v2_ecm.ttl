    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyDate rdf:type rdf:Property ;
    rdfs:label 'Study Date' ;
    rdfs:comment 'Date on which the method detection limit study was conducted.' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyNotes rdf:type rdf:Property ;
    rdfs:label 'Study Notes' ;
    rdfs:comment 'Free-text notes documenting any special conditions, deviations, or observations during the MDL study.' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyReason rdf:type rdf:Property ;
    rdfs:label 'Study Reason' ;
    rdfs:comment 'Reason for conducting the MDL study (e.g., annual renewal, method change, instrument change, matrix change).' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStatus rdf:type rdf:Property ;
    rdfs:label 'Study Status' ;
