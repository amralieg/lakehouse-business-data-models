ind:euSumOf20ValuePpt rdf:type rdf:Property ;
    rdfs:label 'Eu Sum Of 20 Value Ppt' ;
    rdfs:comment 'EU sum-of-20 PFAS value' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:euSumOfTwentyBasisFlag rdf:type rdf:Property ;
    rdfs:label 'Eu Sum Of Twenty Basis Flag' ;
    rdfs:comment 'TRUE when evaluated under EU Drinking Water Directive 2020/2184 sum-of-20 PFAS framework.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:euTotalPfasCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Eu Total Pfas Compliant Flag' ;
    rdfs:comment 'Whether the EU total PFAS value is at or below the parametric value of 500 ng/L per DWD 2020/2184.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:euTotalPfasNgL rdf:type rdf:Property ;
    rdfs:label 'Eu Total Pfas Ng L' ;
