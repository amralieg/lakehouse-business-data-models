    rdfs:comment 'Primary analytical test method or Standard Method number that this instrument is configured to perform (e.g., \'EPA 200.8\', \'SM 2540 C\', \'EPA 300.0\', \'SM 2130 B\'). Links the instrument to specific regulatory-approved analytical procedures.' ;
    rdfs:domain ind:LabInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryTestMethods rdf:type rdf:Property ;
