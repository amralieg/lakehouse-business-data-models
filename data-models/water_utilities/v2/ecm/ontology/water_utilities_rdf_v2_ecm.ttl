    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictedValue rdf:type rdf:Property ;
    rdfs:label 'Predicted Value' ;
    rdfs:comment 'The numeric value predicted by the ML model.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictionError rdf:type rdf:Property ;
    rdfs:label 'Prediction Error' ;
    rdfs:comment 'Calculated error between predicted and actual values.' ;
    rdfs:domain ind:TreatmentPredictionEvent ;
