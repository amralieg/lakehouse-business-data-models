    rdfs:domain ind:OnlineInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentName rdf:type rdf:Property ;
    rdfs:label 'Instrument Name' ;
    rdfs:comment 'Descriptive name of the online monitoring instrument indicating its function and location (e.g., \'WTP Effluent Turbidimeter\', \'Distribution Zone 3 Chlorine Analyzer\').' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentStatus rdf:type rdf:Property ;
