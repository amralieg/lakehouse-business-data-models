    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isNonDetect rdf:type rdf:Property ;
    rdfs:label 'Is Non Detect' ;
    rdfs:comment 'True if the result is below the method detection limit.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionMclUnit rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Mcl Unit' ;
    rdfs:comment 'Unit of measure for the jurisdiction-specific MCL (e.g. ppt for US individual compounds, ug/L for EU sum parameters).' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionMclValue rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Mcl Value' ;
    rdfs:comment 'Maximum contaminant level applicable in the relevant jurisdiction for the monitored PFAS compound or group.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
