ind:uploadedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Uploaded Timestamp' ;
    rdfs:comment 'Timestamp when the document was uploaded or ingested into the system.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:verifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verified Timestamp' ;
    rdfs:comment 'Date and time when the document was verified. Null if the document has not yet been verified.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version number of the document. Increments when a new version of the same document is uploaded. Supports document version control.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

