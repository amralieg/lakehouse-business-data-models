    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverablesDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverables Description' ;
    rdfs:comment 'Description of deliverables.' ;
    rdfs:domain ind:PermitVendorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Vendor performance rating.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCost rdf:type rdf:Property ;
    rdfs:label 'Service Cost' ;
    rdfs:comment 'Service cost' ;
    rdfs:domain ind:PermitVendorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceDescription rdf:type rdf:Property ;
