    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementRangeMin rdf:type rdf:Property ;
    rdfs:label 'Measurement Range Min' ;
    rdfs:comment 'Minimum value of the instrument\'s calibrated measurement range. Defines the lower detection limit for accurate readings.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:piHistorianTag rdf:type rdf:Property ;
