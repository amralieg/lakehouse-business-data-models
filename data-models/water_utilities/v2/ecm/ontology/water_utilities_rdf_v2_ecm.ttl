ind:accountReviewedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Reviewed By User Employee Id' ;
    rdfs:comment 'User identifier of the supervisor or QA team member who reviewed the note. Null if not yet reviewed or review not required.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:enforcementActionId rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Id' ;
    rdfs:comment 'Foreign key linking to compliance.enforcement_action. Business justification: Notes capture enforcement action impacts on customer accounts (payment plans, service restrictions, legal holds)—operational documentation requirement for coordinating compliance and customer service ' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnforcementAction .

ind:primaryAccountCustomerComplaintId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Customer Complaint Id' ;
    rdfs:comment 'Reference to a formal customer complaint record if this note documents or follows up on a complaint. Null if not associated with a complaint.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerComplaint .

ind:primaryAccountOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Order Id' ;
    rdfs:comment 'Reference to a service order if this note was created in the context of a specific field service activity (e.g., meter installation, leak repair, disconnection). Null if not associated with a service order.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:alertFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Flag' ;
    rdfs:comment 'Indicates whether this note triggers an alert or pop-up notification when the account is accessed by customer service representatives or field crews. True if alert is active, False otherwise.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of file attachments (documents, images, recordings) associated with this note. Zero if no attachments. Attachments are stored separately and linked to the note.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Generated Flag' ;
    rdfs:comment 'Indicates whether the note was automatically generated by a system process (e.g., billing engine, workflow automation, IVR system) rather than manually entered by a user. True if auto-generated, False if manually created.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:characterCount rdf:type rdf:Property ;
    rdfs:label 'Character Count' ;
    rdfs:comment 'Total number of characters in the note_text field. Used for reporting and data quality monitoring. Calculated at note creation and update.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionsHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Collections Hold Flag' ;
    rdfs:comment 'Indicates whether the note places or documents a hold on collections activities (e.g., payment arrangement in place, dispute under review, bankruptcy filing). True if collections hold is active, False otherwise.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerVisibleFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Visible Flag' ;
    rdfs:comment 'Indicates whether the note is visible to the customer through self-service channels (web portal, mobile app). True if customer can view, False if internal only. Subset of visibility_level logic for simplified customer portal filtering.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardIndicatorFlag rdf:type rdf:Property ;
    rdfs:label 'Hazard Indicator Flag' ;
    rdfs:comment 'Indicates whether the note contains information about a safety hazard or dangerous condition at the service address (e.g., aggressive dog, unstable structure, hazardous materials). True if hazard is present, False otherwise. Used to alert field crews.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-2 three-letter language code indicating the language in which the note was written: ENG (English), SPA (Spanish), CHI (Chinese), VIE (Vietnamese), KOR (Korean), TGL (Tagalog), FRE (French). Supports multilingual customer service operations. [ENUM-REF-CANDIDATE: ENG|SPA|CHI|VIE|KOR|TGL|FRE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Indicates whether the note is subject to legal hold for litigation, regulatory investigation, or legal discovery. True if legal hold applies, False otherwise. Prevents deletion or modification of the note.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noteAuthorName rdf:type rdf:Property ;
    rdfs:label 'Note Author Name' ;
    rdfs:comment 'Full name of the utility staff member who created the note, or system name if auto-generated. Provides human-readable identification of the note creator.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noteCategory rdf:type rdf:Property ;
    rdfs:label 'Note Category' ;
    rdfs:comment 'Broad business category for the note: BILLING (payment arrangements, billing disputes), SERVICE_DELIVERY (service quality, outages), SAFETY (hazardous conditions, dangerous animals), REGULATORY (compliance holds, legal restrictions), CUSTOMER_PREFERENCE (communication preferences, special requests), PROPERTY_ACCESS (gate codes, access instructions).' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noteStatus rdf:type rdf:Property ;
    rdfs:label 'Note Status' ;
    rdfs:comment 'Current lifecycle status of the note: ACTIVE (currently relevant and visible), ARCHIVED (retained for history but not actively displayed), DELETED (soft-deleted, retained for audit), EXPIRED (past expiration date, no longer applicable).' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noteText rdf:type rdf:Property ;
    rdfs:label 'Note Text' ;
    rdfs:comment 'Free-text content of the note entered by utility staff or generated by automated systems. May contain customer service observations, field crew instructions (e.g., dangerous dog, locked gate), dispute details, or special handling requirements.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noteType rdf:type rdf:Property ;
    rdfs:label 'Note Type' ;
    rdfs:comment 'Attribute note_type for account_note' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noteTypeCode rdf:type rdf:Property ;
    rdfs:label 'Note Type Code' ;
    rdfs:comment 'Classification of the note indicating its business purpose: GENERAL (routine account information), COLLECTIONS (payment or delinquency related), FIELD_SERVICE (field crew instructions or observations), COMPLAINT (customer complaint or dispute), LEGAL_HOLD (legal or regulatory restriction), MEDICAL_BASELINE (medical equipment dependency or special needs).' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printOnBillFlag rdf:type rdf:Property ;
    rdfs:label 'Print On Bill Flag' ;
    rdfs:comment 'Indicates whether the note should be printed on the customer\'s bill or included in bill messaging. True if note should appear on bill, False otherwise. Used for important customer communications (e.g., rate change notices, service reminders).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewedFlag rdf:type rdf:Property ;
    rdfs:label 'Reviewed Flag' ;
    rdfs:comment 'Indicates whether the note has been reviewed by a supervisor or quality assurance team member. True if reviewed, False if pending review. Used for quality control and training purposes.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reviewed Timestamp' ;
    rdfs:comment 'Date and time when the note was reviewed by a supervisor or QA team member. Null if not yet reviewed. Follows format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'Automated sentiment analysis score ranging from -1.00 (very negative) to +1.00 (very positive), with 0.00 as neutral. Generated by natural language processing engine for customer-facing notes. Null if sentiment analysis not performed.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Visibility Level' ;
    rdfs:comment 'Determines who can view the note: INTERNAL (utility staff only), EXTERNAL (visible to customer via self-service portal or printed on bill), RESTRICTED (limited to specific roles or departments, e.g., legal, management).' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Workflow Trigger Flag' ;
    rdfs:comment 'Indicates whether this note initiates an automated workflow or business process (e.g., escalation to supervisor, field service dispatch, collections hold). True if workflow is triggered, False otherwise.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Unique identifier for each customer interaction record. Primary key.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hydrantId rdf:type rdf:Property ;
    rdfs:label 'Hydrant Id' ;
    rdfs:comment 'Foreign key linking to distribution.hydrant. Business justification: Customer reports about hydrant problems (leaking, damaged, blocked access, vandalism) reference specific hydrant assets. Enables tracking of public-reported hydrant defects, prioritizing inspection/re' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hydrant .

ind:interactionAgentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Interaction Agent Employee Id' ;
    rdfs:comment 'Identifier of the customer service agent or representative who handled the interaction. Null for self-service interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:interactionContactPersonId rdf:type rdf:Property ;
    rdfs:label 'Interaction Contact Person Id' ;
    rdfs:comment 'Foreign key linking to customer.person. Business justification: Customer interactions capture contact details that should reference the person master when the contact is a known person. This eliminates duplication of person contact information. Nullable as some in' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Person .

ind:interactionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Interaction Employee Id' ;
    rdfs:comment 'Identifier of the customer service agent or representative who handled the interaction. Null for self-service interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:interactionPersonId rdf:type rdf:Property ;
    rdfs:label 'Interaction Person Id' ;
    rdfs:comment 'FK to person' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Person .

ind:networkValveId rdf:type rdf:Property ;
    rdfs:label 'Network Valve Id' ;
    rdfs:comment 'Foreign key linking to distribution.network_valve. Business justification: Customer reports about valve issues (leaking valve box, exposed valve, damaged cover) reference specific valve assets. Enables public-sourced defect identification, prioritizes valve maintenance, and ' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkValve .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Reference to a service request created as a result of this interaction. Null if no service request was generated.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:overflowEventId rdf:type rdf:Property ;
    rdfs:label 'Overflow Event Id' ;
    rdfs:comment 'Foreign key linking to compliance.overflow_event. Business justification: Interactions capture customer reports of overflow events or utility communication about events affecting customers—event documentation and public notification tracking required for regulatory complian' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OverflowEvent .

ind:accessibilityAccommodation rdf:type rdf:Property ;
    rdfs:label 'Accessibility Accommodation' ;
    rdfs:comment 'Description of any accessibility accommodations provided during the interaction (e.g., TTY, large print, sign language). Null if no accommodation was required.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentName rdf:type rdf:Property ;
    rdfs:label 'Agent Name' ;
    rdfs:comment 'Full name of the customer service agent who handled the interaction. Null for self-service interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callbackCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Callback Completed Timestamp' ;
    rdfs:comment 'Date and time when the requested callback was completed. Null if callback was not requested or not yet completed.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callbackRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Callback Requested Flag' ;
    rdfs:comment 'Indicates whether the customer requested a callback from the utility.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Reference to a formal case or complaint record created in the CRM system as a result of this interaction. Null if no case was created.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionCategory rdf:type rdf:Property ;
    rdfs:label 'Interaction Category' ;
    rdfs:comment 'High-level category grouping for the interaction type, used for reporting and analytics (e.g., billing, service delivery, water quality, account management).' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the interaction was formally closed. Null if interaction is not yet closed.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Customer satisfaction rating provided by the customer after the interaction, typically on a scale of 1 to 5. Null if not captured.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionDescription rdf:type rdf:Property ;
    rdfs:label 'Interaction Description' ;
    rdfs:comment 'Detailed narrative description of the interaction, including customer inquiry, issue reported, and any relevant context provided by the customer or agent.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Total duration of the interaction in seconds, applicable primarily to call and chat channels. Null for asynchronous channels like email.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalatedFlag rdf:type rdf:Property ;
    rdfs:label 'Escalated Flag' ;
    rdfs:comment 'Escalated flag' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether the interaction was escalated to a supervisor, specialist, or higher tier of support.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Reason for escalating the interaction, such as complex technical issue, customer dissatisfaction, or policy exception required. Null if not escalated.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstContactResolutionFlag rdf:type rdf:Property ;
    rdfs:label 'First Contact Resolution Flag' ;
    rdfs:comment 'Indicates whether the interaction was resolved during the first contact without requiring follow-up. Key customer service performance indicator.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Follow up date' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Follow up required flag' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactionChannel rdf:type rdf:Property ;
    rdfs:label 'Interaction Channel' ;
    rdfs:comment 'Interaction channel' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionDate rdf:type rdf:Property ;
    rdfs:label 'Interaction Date' ;
    rdfs:comment 'Interaction date' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactionNumber rdf:type rdf:Property ;
    rdfs:label 'Interaction Number' ;
    rdfs:comment 'Business-facing unique identifier for the interaction, used for tracking and reference in customer communications.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle status of the interaction: open, in progress, pending customer response, pending internal action, resolved, closed, or cancelled. [ENUM-REF-CANDIDATE: open|in_progress|pending_customer|pending_internal|resolved|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'Date and time when the interaction was initiated or received by the utility. Primary business event timestamp for the interaction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the interaction purpose: billing inquiry, service request, complaint, outage report, payment arrangement, or general inquiry.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interpreterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Interpreter Required Flag' ;
    rdfs:comment 'Indicates whether a language interpreter was required or used during the interaction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPromoterScore rdf:type rdf:Property ;
    rdfs:label 'Net Promoter Score' ;
    rdfs:comment 'Net Promoter Score provided by the customer, typically on a scale of 0 to 10, measuring likelihood to recommend the utility. Null if not captured.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level assigned to the interaction based on urgency and impact: low, medium, high, urgent, or critical.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Code' ;
    rdfs:comment 'Resolution code' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Detailed notes documenting the resolution provided, actions taken, and any follow-up required. Populated when interaction is resolved or closed.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Attribute resolution_status for interaction' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the interaction was marked as resolved. Null if interaction is still open or in progress.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:satisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Score' ;
    rdfs:comment 'Customer satisfaction score' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Detailed subcategory within the interaction category, providing granular classification for analytics (e.g., high bill inquiry, leak report, water pressure issue).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief subject or title summarizing the purpose or topic of the interaction.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Interaction summary' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Survey Completed Flag' ;
    rdfs:comment 'Indicates whether the customer completed a post-interaction satisfaction survey.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerAssignedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Customer Assigned Employee Id' ;
    rdfs:comment 'FK to assigned employee' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:customerAssignedToUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Customer Assigned To User Employee Id' ;
    rdfs:comment 'Reference to the employee or user assigned as the resolution owner for this complaint.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:customerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Customer Employee Id' ;
    rdfs:comment 'Reference to the employee or user assigned as the resolution owner for this complaint.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:customerPersonId rdf:type rdf:Property ;
    rdfs:label 'Customer Person Id' ;
    rdfs:comment 'FK to person' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Person .

ind:customerReportedByPersonId rdf:type rdf:Property ;
    rdfs:label 'Customer Reported By Person Id' ;
    rdfs:comment 'Foreign key linking to customer.person. Business justification: Complaints capture reporter details that should reference the person master when the reporter is a known person. This eliminates duplication and enables proper reporter tracking. Nullable as some comp' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Person .

ind:pipeMainId rdf:type rdf:Property ;
    rdfs:label 'Pipe Main Id' ;
    rdfs:comment 'Foreign key linking to distribution.pipe_main. Business justification: Water quality complaints (taste, odor, discoloration, pressure) routinely reference the specific distribution main where the issue originates. Operations teams use this for targeted flushing, leak det' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipeMain .

ind:primaryCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Account Id' ;
    rdfs:comment 'Reference to the customer account associated with this complaint.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:primaryCustomerOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Order Id' ;
    rdfs:comment 'Reference to the service order created to address customer-facing service actions related to the complaint, such as meter test, service reconnection, or billing adjustment.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:primaryCustomerWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Work Order Id' ;
    rdfs:comment 'Reference to the work order created to address the physical or operational issue underlying the complaint, such as a repair, inspection, or maintenance activity in IBM Maximo Asset Management (CMMS).' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'Actual date when the complaint was resolved and closed.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'Date when the complaint was assigned to a resolution owner.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedToDepartment rdf:type rdf:Property ;
    rdfs:label 'Assigned To Department' ;
    rdfs:comment 'Department or functional area responsible for resolving the complaint, such as Customer Service, Water Quality, Distribution Operations and Maintenance (O&M), Billing, or Laboratory.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Billing Adjustment Amount' ;
    rdfs:comment 'Dollar amount of billing adjustment or credit issued to the customer as a result of the complaint resolution, if applicable.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Provided Flag' ;
    rdfs:comment 'Indicates whether any form of compensation, credit, or goodwill gesture was provided to the customer as part of the complaint resolution.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintCategory rdf:type rdf:Property ;
    rdfs:label 'Complaint Category' ;
    rdfs:comment 'Primary classification of the complaint type. Water quality includes turbidity, discoloration, and contaminant concerns. Billing disputes cover charges, meter reads, and rate application. Service interruption includes planned and unplanned outages. Pressure issues cover low or high Pounds per Square Inch (PSI). Regulatory complaints are those escalated to state primacy agencies or Public Utilities Commission (PUC). [ENUM-REF-CANDIDATE: water_quality|billing_dispute|service_interruption|pressure_issue|odor_taste|leak|meter_accuracy|customer_service|regulatory|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintDate rdf:type rdf:Property ;
    rdfs:label 'Complaint Date' ;
    rdfs:comment 'Complaint date' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complaintDescription rdf:type rdf:Property ;
    rdfs:label 'Complaint Description' ;
    rdfs:comment 'Detailed narrative description of the complaint as reported by the customer, including symptoms, duration, and customer concerns.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Number' ;
    rdfs:comment 'Externally visible unique complaint tracking number assigned by the Customer Information System (CIS) or Customer Care and Billing (CC&B) system.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintStatus rdf:type rdf:Property ;
    rdfs:label 'Complaint Status' ;
    rdfs:comment 'Current lifecycle status of the complaint in the resolution workflow. [ENUM-REF-CANDIDATE: open|in_progress|pending_customer|pending_investigation|resolved|closed|escalated|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintType rdf:type rdf:Property ;
    rdfs:label 'Complaint Type' ;
    rdfs:comment 'Complaint type' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactMethod rdf:type rdf:Property ;
    rdfs:label 'Contact Method' ;
    rdfs:comment 'Channel through which the complaint was received by the utility. [ENUM-REF-CANDIDATE: phone|email|web_portal|mobile_app|in_person|mail|social_media — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Specific corrective action taken to address the root cause and prevent recurrence, such as infrastructure repair, meter replacement, billing adjustment, or process improvement.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionComments rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Comments' ;
    rdfs:comment 'Free-text feedback provided by the customer regarding their satisfaction with the complaint resolution process and outcome.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Customer satisfaction score provided by the customer after complaint resolution, typically on a scale of 1 to 5 or 1 to 10.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysToResolve rdf:type rdf:Property ;
    rdfs:label 'Days To Resolve' ;
    rdfs:comment 'Days to resolve' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerComplaintDescription rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Description' ;
    rdfs:comment 'Attribute description for customer_complaint' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal notes and comments for staff use, not visible to the customer, documenting investigation steps, coordination with other departments, and operational context.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meteringComplaintId rdf:type rdf:Property ;
    rdfs:label 'Metering Complaint Id' ;
    rdfs:comment 'Cross-reference to metering complaint' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Attribute received_date for customer_complaint' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'Name of the regulatory agency involved if the complaint was escalated, such as state Department of Environmental Quality, Public Utilities Commission (PUC), or U.S. Environmental Protection Agency (EPA).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Case Number' ;
    rdfs:comment 'Case or reference number assigned by the regulatory agency for tracking the escalated complaint.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryEscalationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Escalation Flag' ;
    rdfs:comment 'Indicates whether the complaint was escalated to or originated from a regulatory agency such as state primacy agency, Public Utilities Commission (PUC), or U.S. Environmental Protection Agency (EPA).' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Regulatory reportable flag' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Response Due Date' ;
    rdfs:comment 'Date by which the utility must provide a formal response to the regulatory agency regarding the escalated complaint.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Date when the complaint was first reported to the utility by the customer.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Precise date and time when the complaint was logged into the system, including time zone offset.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Resolution date' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed narrative of the actions taken to resolve the complaint, including investigation findings, corrective actions, and customer communication.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedDate rdf:type rdf:Property ;
    rdfs:label 'Resolved Date' ;
    rdfs:comment 'Attribute resolved_date for customer_complaint' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause of the complaint issue, such as main break, meter malfunction, billing system error, water treatment process deviation, or customer misunderstanding.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Source channel' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'Target date by which the complaint should be resolved, based on Service Level Agreement (SLA) commitments and regulatory requirements.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waterQualityRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Water Quality Related Flag' ;
    rdfs:comment 'Water quality related flag' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterQualityTestRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Water Quality Test Required Flag' ;
    rdfs:comment 'Indicates whether a water quality test was required or performed as part of the complaint investigation, particularly for complaints involving taste, odor, discoloration, or suspected contamination.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterQualityTestResult rdf:type rdf:Property ;
    rdfs:label 'Water Quality Test Result' ;
    rdfs:comment 'Summary of water quality test results if testing was performed, including parameters tested such as pH, Nephelometric Turbidity Units (NTU), chlorine residual, Total Dissolved Solids (TDS), and whether results were within Maximum Contaminant Level (MCL) standards.' ;
    rdfs:domain ind:CustomerComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique identifier for the account hierarchy relationship record.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childAccountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Account Customer Account Id' ;
    rdfs:comment 'Reference to the child account in the hierarchy. For corporate rollup structures, this is the subsidiary or division account. For master-sub meter arrangements, this is the sub-metered tenant account. For HOA structures, this is the individual unit owner account. For wholesale-retail relationships, this is the retail customer account.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:childCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Customer Account Id' ;
    rdfs:comment 'FK to child account' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:parentCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Customer Account Id' ;
    rdfs:comment 'FK to parent account' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate shared costs or consumption from parent to child accounts. Proportional usage allocates based on relative consumption. Equal split divides costs evenly among children. Fixed percentage uses predefined allocation percentages. Custom formula applies business-specific calculation rules. Direct metered indicates child has dedicated meter with no allocation needed. Critical for master-sub meter billing and HOA common area cost allocation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Fixed percentage of parent account charges or consumption allocated to this child account when allocation method is fixed percentage. Value between 0.00 and 100.00. Sum of allocation percentages across all children under the same parent should equal 100.00 for balanced allocation. Used in HOA common area cost sharing and wholesale water distribution.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Workflow state indicating whether the hierarchy relationship has been reviewed and approved by authorized personnel. Draft indicates initial setup. Pending approval indicates awaiting management review. Approved indicates authorized for activation. Rejected indicates denied and requires revision. Supports governance controls for corporate account structures and wholesale agreements.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingConsolidatedFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Consolidated Flag' ;
    rdfs:comment 'Billing consolidated flag' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingConsolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Consolidation Flag' ;
    rdfs:comment 'Indicates whether charges from the child account should be consolidated onto the parent account invoice. True means child account charges appear on parent bill. False means child account receives separate bill despite hierarchy relationship. Supports corporate consolidated billing and master meter billing arrangements.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumptionRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Consumption Rollup Flag' ;
    rdfs:comment 'Indicates whether child account consumption should be aggregated and reported at the parent account level for analytics and reporting. True enables corporate-level water usage tracking across multiple facilities. False keeps consumption reporting separate. Supports corporate sustainability reporting and wholesale customer usage monitoring.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'External reference to the legal contract, service agreement, or wholesale water purchase agreement that establishes this account hierarchy relationship. Links to physical contract documents stored in document management systems. Critical for wholesale-retail relationships and special contract arrangements.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of this relationship in a multi-tier hierarchy structure. Level 1 represents the top-level parent. Level 2 represents immediate children. Level 3 and beyond represent nested sub-hierarchies. Enables recursive hierarchy traversal and reporting rollups.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyPriority rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Priority' ;
    rdfs:comment 'Numeric ranking used to resolve conflicts when an account participates in multiple hierarchies. Lower numbers indicate higher priority. Used to determine which parent relationship takes precedence for billing consolidation when an account could roll up to multiple parents. Ensures deterministic processing in complex organizational structures.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Classification of the account relationship structure. Corporate rollup supports consolidated billing for multi-location businesses. Master-sub meter supports properties with a master meter and individual tenant sub-meters. HOA common area links homeowner association common facilities to individual unit accounts. Wholesale-retail links bulk water purchasers to their retail distribution customers. Municipal department links city departments to the main municipal account. Irrigation district links agricultural water districts to individual grower accounts.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentResponsibility rdf:type rdf:Property ;
    rdfs:label 'Payment Responsibility' ;
    rdfs:comment 'Defines which party in the hierarchy relationship is financially responsible for payment. Parent pays all means parent account is billed and responsible for all charges including children. Child pays own means each child receives and pays their own bill. Split responsibility means specific charges are assigned to parent or child based on charge type. Parent guarantees means child is billed but parent is backup guarantor. Critical for credit management and collections.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipLevel rdf:type rdf:Property ;
    rdfs:label 'Relationship Level' ;
    rdfs:comment 'Attribute relationship_level for account_hierarchy' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:depositId rdf:type rdf:Property ;
    rdfs:label 'Deposit Id' ;
    rdfs:comment 'Unique identifier for the customer_deposit data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:Deposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Foreign key linking to finance.bank_account. Business justification: Customer deposits held in specific segregated bank accounts per state regulatory requirements and fiduciary duty. Essential for deposit reconciliation, interest calculation, and regulatory audit compl' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:accruedInterest rdf:type rdf:Property ;
    rdfs:label 'Accrued Interest' ;
    rdfs:comment 'Total accrued interest' ;
    rdfs:domain ind:Deposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Payment amount' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

