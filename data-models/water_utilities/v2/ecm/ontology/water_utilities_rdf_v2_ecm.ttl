    rdfs:range xsd:decimal .

ind:predictionHorizon rdf:type rdf:Property ;
    rdfs:label 'Prediction Horizon' ;
    rdfs:comment 'Forecast horizon for the prediction (e.g. 1h, 24h, 7d, 30d).' ;
