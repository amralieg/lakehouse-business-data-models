    rdfs:comment 'Comparison operator used in the rule condition.' ;
    rdfs:domain ind:AlertRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Alert Rule Description' ;
    rdfs:comment 'Detailed description of the purpose and logic of the alert rule.' ;
    rdfs:domain ind:AlertRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enabledFlag rdf:type rdf:Property ;
