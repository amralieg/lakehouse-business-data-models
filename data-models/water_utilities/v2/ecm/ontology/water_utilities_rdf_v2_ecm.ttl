    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcSummary rdf:type rdf:Property ;
    rdfs:label 'Qc Summary' ;
    rdfs:comment 'QC summary' ;
    rdfs:domain ind:CertificateOfAnalysis ;
