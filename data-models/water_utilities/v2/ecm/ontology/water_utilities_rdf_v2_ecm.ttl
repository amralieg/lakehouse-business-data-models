    rdfs:range xsd:decimal .

ind:euSumOf20ValueNgL rdf:type rdf:Property ;
    rdfs:label 'Eu Sum Of 20 Value Ng L' ;
    rdfs:comment 'Cumulative sum of 20 PFAS compounds per EU DWD 2020/2184 (limit 100 ng/L).' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
