    rdfs:range xsd:boolean .

ind:checksumHash rdf:type rdf:Property ;
    rdfs:label 'Checksum Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the document file to ensure integrity and detect tampering or corruption.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceProgramCode rdf:type rdf:Property ;
    rdfs:label 'Compliance Program Code' ;
    rdfs:comment 'Code identifying the regulatory compliance program or requirement that this document supports. Examples include LCRR (Lead and Copper Rule Revisions), IUP (Industrial User Permit), NPDES (National Pollutant Discharge Elimination System), SDWA (Safe Drinking Water Act), CWA (Clean Water Act), and PUC audit requirements. [ENUM-REF-CANDIDATE: LCRR|IUP|NPDES|SDWA|CWA|PUC_AUDIT|LOW_INCOME_ASSISTANCE|OTHER — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Classification level indicating the sensitivity and access restrictions for the document. Aligns with organizational data classification policy.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountDocumentDescription rdf:type rdf:Property ;
    rdfs:label 'Account Document Description' ;
    rdfs:comment 'Document description' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignaturePresentFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Present Flag' ;
    rdfs:comment 'Indicates whether the document contains a digital signature for authentication and non-repudiation purposes.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'High-level categorization of the document for organizational and retrieval purposes.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The official date of the document as indicated on the document itself, such as the signature date, issuance date, or effective date. Represents the business event date of the document.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentDescription rdf:type rdf:Property ;
    rdfs:label 'Document Description' ;
    rdfs:comment 'Detailed description of the document content, purpose, or context. Provides additional information beyond the title.' ;
