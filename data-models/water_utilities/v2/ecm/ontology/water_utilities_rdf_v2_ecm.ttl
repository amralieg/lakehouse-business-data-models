    rdfs:range xsd:integer .

ind:predictionOntologyClass rdf:type rdf:Property ;
    rdfs:label 'Prediction Ontology Class' ;
    rdfs:comment 'Ontology: breakthrough, demand_forecast, leak_detection, water_quality' ;
