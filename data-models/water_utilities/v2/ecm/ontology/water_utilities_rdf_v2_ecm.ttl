ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Associated work order number' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amiEndpointId rdf:type rdf:Property ;
    rdfs:label 'Ami Endpoint Id' ;
    rdfs:comment 'Unique identifier for the AMI/AMR communication endpoint device. Primary key for the endpoint registry.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmiEndpoint .

ind:amiNetworkCollectorId rdf:type rdf:Property ;
    rdfs:label 'Ami Network Collector Id' ;
    rdfs:comment 'Reference to the FlexNet collector or gateway device that receives transmissions from this endpoint. Part of the AMI network infrastructure.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmiNetworkCollector .

ind:batteryExpectedLifeYears rdf:type rdf:Property ;
    rdfs:label 'Battery Expected Life Years' ;
    rdfs:comment 'Manufacturer-specified expected battery life in years under normal operating conditions. Typically 15-20 years for AMI endpoints.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batteryInstallDate rdf:type rdf:Property ;
    rdfs:label 'Battery Install Date' ;
    rdfs:comment 'Date when the battery was installed or last replaced in the endpoint device. Used to calculate expected battery life remaining.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batteryLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Battery Level Percent' ;
    rdfs:comment 'Current battery charge level as a percentage. Critical for battery-powered endpoints to schedule replacement before failure.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationFrequencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Communication Frequency Minutes' ;
    rdfs:comment 'Configured interval in minutes between endpoint transmissions. Typical values: 15, 30, 60 minutes for hourly reads; 1440 for daily reads.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataRetentionDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Days' ;
    rdfs:comment 'Number of days of interval consumption data stored locally on the endpoint device before being overwritten. Typically 35-45 days.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decommissionReason rdf:type rdf:Property ;
    rdfs:label 'Decommission Reason' ;
    rdfs:comment 'Reason for endpoint decommissioning (e.g., meter replacement, device failure, service disconnection, upgrade to new technology).' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Encryption Algorithm' ;
    rdfs:comment 'Cryptographic algorithm used to secure communications between endpoint and collector. AES-128 or AES-256 for encrypted devices.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionKeyVersion rdf:type rdf:Property ;
    rdfs:label 'Encryption Key Version' ;
    rdfs:comment 'Version identifier for the encryption key currently provisioned on the endpoint. Used for secure communication and key rotation management.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Endpoint Serial Number' ;
    rdfs:comment 'Manufacturer-assigned unique serial number for the AMI/AMR endpoint device. Used for warranty tracking and device identification.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointType rdf:type rdf:Property ;
    rdfs:label 'Endpoint Type' ;
    rdfs:comment 'Type of AMI/AMR communication device. ERT (Encoder Receiver Transmitter) for drive-by reading, MXU (Meter Transmit Unit) for fixed network, iPerl for integrated smart meter, Orion for cellular endpoint, Ally for water meter module.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicLatitude rdf:type rdf:Property ;
    rdfs:label 'Geographic Latitude' ;
    rdfs:comment 'Latitude coordinate of the endpoint installation location in decimal degrees. Used for GIS mapping and network planning.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicLongitude rdf:type rdf:Property ;
    rdfs:label 'Geographic Longitude' ;
    rdfs:comment 'Longitude coordinate of the endpoint installation location in decimal degrees. Used for GIS mapping and network planning.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installationTechnician rdf:type rdf:Property ;
    rdfs:label 'Installation Technician' ;
    rdfs:comment 'Name or identifier of the technician who installed the endpoint device. Used for quality tracking and accountability.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address assigned to the endpoint device for cellular or IP-based communication protocols. Null for RF-only devices.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCommunicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Communication Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful communication received from this endpoint. Used to identify non-communicating devices.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastFirmwareUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Firmware Update Date' ;
    rdfs:comment 'Date when the endpoint firmware was last updated. Critical for security patch tracking and compliance.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leakAlertThresholdGpm rdf:type rdf:Property ;
    rdfs:label 'Leak Alert Threshold Gpm' ;
    rdfs:comment 'Continuous flow threshold in gallons per minute that triggers a leak alert. Typically 0.01 to 0.5 GPM for residential meters.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leakDetectionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Leak Detection Enabled Flag' ;
    rdfs:comment 'Indicates whether continuous leak detection monitoring is enabled on this endpoint. True if enabled, False if disabled.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:macAddress rdf:type rdf:Property ;
    rdfs:label 'Mac Address' ;
    rdfs:comment 'Unique hardware address assigned to the endpoint network interface. Used for device authentication and network routing.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkNodeCode rdf:type rdf:Property ;
    rdfs:label 'Network Node Code' ;
    rdfs:comment 'Identifier for the network node or collector that this endpoint communicates with in the AMI network topology.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Read Interval Seconds' ;
    rdfs:comment 'Interval in seconds at which the endpoint records consumption data internally. Typical values: 900 (15 min), 3600 (hourly), 86400 (daily).' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reverseFlowDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Reverse Flow Detected Flag' ;
    rdfs:comment 'Indicates whether reverse flow has been detected by the endpoint. True if reverse flow detected, False otherwise. May indicate backflow or meter installation error.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signalQualityIndicator rdf:type rdf:Property ;
    rdfs:label 'Signal Quality Indicator' ;
    rdfs:comment 'Qualitative assessment of communication signal quality. Derived from signal strength and packet success rate.' ;
    rdfs:domain ind:AmiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tamperDetectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tamper Detected Timestamp' ;
    rdfs:comment 'Timestamp when the most recent tamper event was detected by the endpoint. Null if no tamper has been detected.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tamperStatus rdf:type rdf:Property ;
    rdfs:label 'Tamper Status' ;
    rdfs:comment 'Current tamper detection status reported by the endpoint. Alerts to potential theft, fraud, or unauthorized access.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterInstallationId rdf:type rdf:Property ;
    rdfs:label 'Meter Installation Id' ;
    rdfs:comment 'Foreign key linking to metering.installation. Business justification: A meter read is captured for a specific meter installation (a meter deployed at a location), not just an abstract meter device. Reads are tied to the installation context (location, service point). Th' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Installation .

ind:readRouteId rdf:type rdf:Property ;
    rdfs:label 'Read Route Id' ;
    rdfs:comment 'Foreign key linking to metering.read_route. Business justification: Meter reads are collected along defined read routes (for manual, walk-by, or drive-by reading operations). Each read should reference which route it was collected on for operational tracking and route' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReadRoute .

ind:readerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reader Employee Id' ;
    rdfs:comment 'Employee who performed the read' ;
    rdfs:domain ind:Read ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:averageDailyConsumption rdf:type rdf:Property ;
    rdfs:label 'Average Daily Consumption' ;
    rdfs:comment 'Average daily consumption' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyUsage rdf:type rdf:Property ;
    rdfs:label 'Average Daily Usage' ;
    rdfs:comment 'Average daily usage for the period' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batteryVoltage rdf:type rdf:Property ;
    rdfs:label 'Battery Voltage' ;
    rdfs:comment 'Endpoint battery voltage' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billedDate rdf:type rdf:Property ;
    rdfs:label 'Billed Date' ;
    rdfs:comment 'Date read was billed' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billedFlag rdf:type rdf:Property ;
    rdfs:label 'Billed Flag' ;
    rdfs:comment 'Whether read has been billed' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingPeriod rdf:type rdf:Property ;
    rdfs:label 'Billing Period' ;
    rdfs:comment 'Billing period identifier' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Billing Period End' ;
    rdfs:comment 'End of billing period for this read' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start' ;
    rdfs:comment 'Start of billing period for this read' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consumption rdf:type rdf:Property ;
    rdfs:label 'Consumption' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionUnit rdf:type rdf:Property ;
    rdfs:label 'Consumption Unit' ;
    rdfs:comment 'Unit of consumption (gallons, cubic feet, liters)' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionUnits rdf:type rdf:Property ;
    rdfs:label 'Consumption Units' ;
    rdfs:comment 'Units of consumption' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionValue rdf:type rdf:Property ;
    rdfs:label 'Consumption Value' ;
    rdfs:comment 'Calculated consumption since last read' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionVariancePct rdf:type rdf:Property ;
    rdfs:label 'Consumption Variance Pct' ;
    rdfs:comment 'Variance from historical average percent' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:continuousFlowDays rdf:type rdf:Property ;
    rdfs:label 'Continuous Flow Days' ;
    rdfs:comment 'Number of continuous flow days' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentReading rdf:type rdf:Property ;
    rdfs:label 'Current Reading' ;
    rdfs:comment 'Current meter reading' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyAverage rdf:type rdf:Property ;
    rdfs:label 'Daily Average' ;
    rdfs:comment 'Daily average consumption' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyAverageConsumption rdf:type rdf:Property ;
    rdfs:label 'Daily Average Consumption' ;
    rdfs:comment 'Average daily consumption' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysInPeriod rdf:type rdf:Property ;
    rdfs:label 'Days In Period' ;
    rdfs:comment 'Days in read period' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysSinceLastRead rdf:type rdf:Property ;
    rdfs:label 'Days Since Last Read' ;
    rdfs:comment 'Number of days since previous read' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimationReason rdf:type rdf:Property ;
    rdfs:label 'Estimation Reason' ;
    rdfs:comment 'Reason for estimation' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Exception code if any' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Exception description.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highLowFlag rdf:type rdf:Property ;
    rdfs:label 'High Low Flag' ;
    rdfs:comment 'Flag indicating abnormally high or low consumption' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBilled rdf:type rdf:Property ;
    rdfs:label 'Is Billed' ;
    rdfs:comment 'Whether the read has been billed.' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leakFlag rdf:type rdf:Property ;
    rdfs:label 'Leak Flag' ;
    rdfs:comment 'Whether continuous flow indicates a possible leak' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noFlowDays rdf:type rdf:Property ;
    rdfs:label 'No Flow Days' ;
    rdfs:comment 'Number of no-flow days' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousReadValue rdf:type rdf:Property ;
    rdfs:label 'Previous Read Value' ;
    rdfs:comment 'Previous meter read value' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousReading rdf:type rdf:Property ;
    rdfs:label 'Previous Reading' ;
    rdfs:comment 'Previous register reading' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readDate rdf:type rdf:Property ;
    rdfs:label 'Read Date' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:readExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Read Exception Code' ;
    rdfs:comment 'Exception code if applicable' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readStatus rdf:type rdf:Property ;
    rdfs:label 'Read Status' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readTimestamp rdf:type rdf:Property ;
    rdfs:label 'Read Timestamp' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:readType rdf:type rdf:Property ;
    rdfs:label 'Read Type' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readerEmployeeIdManual rdf:type rdf:Property ;
    rdfs:label 'Reader Employee Id Manual' ;
    rdfs:comment 'Manual reader employee identifier' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readerNotes rdf:type rdf:Property ;
    rdfs:label 'Reader Notes' ;
    rdfs:comment 'Reader notes' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registerReading rdf:type rdf:Property ;
    rdfs:label 'Register Reading' ;
    rdfs:comment 'Register reading value' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reverseFlowFlag rdf:type rdf:Property ;
    rdfs:label 'Reverse Flow Flag' ;
    rdfs:comment 'Whether reverse flow was detected' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rolloverFlag rdf:type rdf:Property ;
    rdfs:label 'Rollover Flag' ;
    rdfs:comment 'Whether register rollover occurred' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:source rdf:type rdf:Property ;
    rdfs:label 'Source' ;
    rdfs:comment 'read source for read' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tamperFlag rdf:type rdf:Property ;
    rdfs:label 'Tamper Flag' ;
    rdfs:comment 'Whether tamper was detected' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationCode rdf:type rdf:Property ;
    rdfs:label 'Validation Code' ;
    rdfs:comment 'Validation code' ;
    rdfs:domain ind:Read ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zeroConsumptionFlag rdf:type rdf:Property ;
    rdfs:label 'Zero Consumption Flag' ;
    rdfs:comment 'Whether zero consumption' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueAccrualGeneralLedgerId rdf:type rdf:Property ;
    rdfs:label 'Revenue Accrual General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: AMI interval data enables real-time revenue accrual accounting. Utilities must map interval consumption to GL accounts for unbilled revenue accrual at period-end, supporting accurate financial close p' ;
    rdfs:domain ind:IntervalConsumption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:alarmCode rdf:type rdf:Property ;
    rdfs:label 'Alarm Code' ;
    rdfs:comment 'Code indicating any alarm condition detected during this interval. Examples include leak alarm, burst alarm, backflow alarm, low battery alarm, or communication failure alarm. Empty if no alarm condition exists.' ;
    rdfs:domain ind:IntervalConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Consumption Volume Gallons' ;
    rdfs:comment 'The total volume of water consumed during this interval, measured in gallons. This is the primary consumption metric used for billing, leak detection, and demand analysis.' ;
    rdfs:domain ind:IntervalConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityIndicator rdf:type rdf:Property ;
    rdfs:label 'Data Quality Indicator' ;
    rdfs:comment 'Indicates the quality and reliability of this interval reading. Valid readings are directly measured; estimated readings are interpolated due to communication gaps; suspect readings show anomalies; missing indicates no data received; tampered indicates potential meter tampering; overflow indicates meter register overflow.' ;
    rdfs:domain ind:IntervalConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedMethod rdf:type rdf:Property ;
    rdfs:label 'Estimated Method' ;
    rdfs:comment 'The method used to estimate this interval reading if data was missing or invalid. None indicates actual measured data. Other values indicate the estimation algorithm applied.' ;
    rdfs:domain ind:IntervalConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapFlag rdf:type rdf:Property ;
    rdfs:label 'Gap Flag' ;
    rdfs:comment 'Boolean flag indicating whether this interval represents a data gap that was filled by estimation or interpolation. True indicates the reading is estimated due to missing data transmission.' ;
    rdfs:domain ind:IntervalConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:highUsageFlag rdf:type rdf:Property ;
    rdfs:label 'High Usage Flag' ;
    rdfs:comment 'Boolean flag indicating whether this interval exceeded the high-usage threshold for this meter installation. True indicates consumption significantly above normal patterns, potentially indicating irrigation, filling pools, or abnormal usage.' ;
    rdfs:domain ind:IntervalConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intervalEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interval End Timestamp' ;
    rdfs:comment 'The precise date and time when the consumption interval ended. Represents the end of the measurement period for this interval reading.' ;
    rdfs:domain ind:IntervalConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:intervalStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interval Start Timestamp' ;
    rdfs:comment 'The precise date and time when the consumption interval began. Represents the beginning of the measurement period for this interval reading.' ;
    rdfs:domain ind:IntervalConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leakDetectionFlag rdf:type rdf:Property ;
    rdfs:label 'Leak Detection Flag' ;
    rdfs:comment 'Boolean flag indicating whether this interval triggered a potential leak alert based on continuous low-flow patterns. True indicates sustained consumption suggesting a possible leak.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'The date and time when this interval reading was processed and loaded into the data warehouse. Used for data pipeline monitoring and audit trails.' ;
    rdfs:domain ind:IntervalConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pulseIncrementGallons rdf:type rdf:Property ;
    rdfs:label 'Pulse Increment Gallons' ;
    rdfs:comment 'The volume of water represented by each pulse from the meter encoder, measured in gallons. Varies by meter size and type. Used to convert pulse counts to consumption volumes.' ;
    rdfs:domain ind:IntervalConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rawPulseCount rdf:type rdf:Property ;
    rdfs:label 'Raw Pulse Count' ;
    rdfs:comment 'The raw cumulative pulse count from the meter encoder at the end of this interval. Each pulse represents a fixed volume increment. Used for data validation and troubleshooting.' ;
    rdfs:domain ind:IntervalConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'The date and time when this interval reading was received by the AMI head-end system. Used to calculate transmission latency and identify delayed readings.' ;
    rdfs:domain ind:IntervalConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tamperEventCode rdf:type rdf:Property ;
    rdfs:label 'Tamper Event Code' ;
    rdfs:comment 'Code indicating the type of tamper event detected during this interval, if any. Examples include magnetic interference, tilt detection, removal detection, or reverse flow. Empty if no tamper event detected.' ;
    rdfs:domain ind:IntervalConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionRetryCount rdf:type rdf:Property ;
    rdfs:label 'Transmission Retry Count' ;
    rdfs:comment 'The number of transmission attempts required to successfully deliver this interval reading to the AMI collector. Higher retry counts indicate communication challenges.' ;
    rdfs:domain ind:IntervalConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumptionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Consumption Employee Id' ;
    rdfs:comment 'User identifier of the system or person who validated this consumption profile. Used for audit trail and quality assurance.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:consumptionValidatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Consumption Validated By User Employee Id' ;
    rdfs:comment 'User identifier of the system or person who validated this consumption profile. Used for audit trail and quality assurance.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:revenueGeneralLedgerId rdf:type rdf:Property ;
    rdfs:label 'Revenue General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: Water consumption billing requires GL account mapping for revenue recognition and financial statement preparation. Consumption profiles drive revenue postings to specific GL accounts (water sales reve' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:adjustmentAmountGallons rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount Gallons' ;
    rdfs:comment 'Volume adjustment in gallons applied to the raw consumption data. May reflect leak adjustments, meter accuracy corrections, or billing dispute resolutions. Zero if no adjustment applied.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Free-text explanation of why a consumption adjustment was applied. Null if no adjustment. Used for audit trail and customer communication.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageDailyUsageGpd rdf:type rdf:Property ;
    rdfs:label 'Average Daily Usage Gpd' ;
    rdfs:comment 'Average daily water consumption in gallons per day (GPD) calculated by dividing total consumption by billing period days. Used for trend analysis and customer benchmarking.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingHandoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Billing Handoff Timestamp' ;
    rdfs:comment 'Date and time when this consumption profile was transmitted to Oracle CC&B for invoice generation. Null if not yet handed off to billing.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Billing Period Days' ;
    rdfs:comment 'Total number of calendar days in the billing period. Used to normalize consumption for comparison across periods of different lengths.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumptionStatus rdf:type rdf:Property ;
    rdfs:label 'Consumption Status' ;
    rdfs:comment 'Current validation status of the consumption data. Indicates whether the consumption is based on actual reads, estimates, or has been adjusted. Only validated or final records are used for billing.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionTier rdf:type rdf:Property ;
    rdfs:label 'Consumption Tier' ;
    rdfs:comment 'Classification of consumption volume into rate tiers for tiered pricing structures. Determines applicable rate schedule and conservation incentives.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionVariancePercent rdf:type rdf:Property ;
    rdfs:label 'Consumption Variance Percent' ;
    rdfs:comment 'Percentage change in consumption compared to prior period. Positive values indicate increased usage; negative values indicate decreased usage. Used to trigger high-usage alerts.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Composite score (0-100) representing the quality and reliability of the consumption data. Based on read method, completeness of interval data, validation checks passed, and absence of anomalies. Higher scores indicate higher confidence.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedReadReason rdf:type rdf:Property ;
    rdfs:label 'Estimated Read Reason' ;
    rdfs:comment 'Reason code explaining why consumption was estimated rather than based on actual meter read. Null if consumption is based on actual read.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highUsageAlertFlag rdf:type rdf:Property ;
    rdfs:label 'High Usage Alert Flag' ;
    rdfs:comment 'Indicates whether consumption exceeded predefined thresholds triggering a high-usage alert. Used for proactive customer outreach and potential billing dispute prevention.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intervalDataAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Interval Data Available Flag' ;
    rdfs:comment 'Indicates whether granular interval consumption data (typically hourly) is available from AMI system for this billing period. True if AMI data exists; false if only aggregated reads are available.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leakDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Leak Detected Flag' ;
    rdfs:comment 'Indicates whether a potential leak was detected during the billing period based on continuous flow patterns or minimum night flow analysis. Triggers customer notification and field investigation.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumNightFlowGpm rdf:type rdf:Property ;
    rdfs:label 'Minimum Night Flow Gpm' ;
    rdfs:comment 'Minimum flow rate in gallons per minute (GPM) observed during overnight hours (typically 2 AM - 4 AM). Used for leak detection and continuous-use identification in AMI systems.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nrwContributionGallons rdf:type rdf:Property ;
    rdfs:label 'Nrw Contribution Gallons' ;
    rdfs:comment 'Estimated volume of consumption that contributes to Non-Revenue Water (NRW) or Unaccounted-for Water (UFW) calculations. Includes unbilled authorized consumption and apparent losses.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakDayConsumptionGallons rdf:type rdf:Property ;
    rdfs:label 'Peak Day Consumption Gallons' ;
    rdfs:comment 'Maximum single-day water consumption in gallons during the billing period. Identifies peak demand events and potential high-usage anomalies.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakDayDate rdf:type rdf:Property ;
    rdfs:label 'Peak Day Date' ;
    rdfs:comment 'The date on which the peak day consumption occurred. Used for correlation with weather events, holidays, or operational anomalies.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorPeriodConsumptionGallons rdf:type rdf:Property ;
    rdfs:label 'Prior Period Consumption Gallons' ;
    rdfs:comment 'Total consumption in gallons from the immediately preceding billing period. Used for period-over-period variance analysis and trend detection.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorYearConsumptionGallons rdf:type rdf:Property ;
    rdfs:label 'Prior Year Consumption Gallons' ;
    rdfs:comment 'Total consumption in gallons from the same billing period in the prior year. Used for year-over-year comparison and seasonal trend analysis.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readMethod rdf:type rdf:Property ;
    rdfs:label 'Read Method' ;
    rdfs:comment 'Method by which the meter reading was obtained. AMI (Advanced Metering Infrastructure) provides interval data; AMR (Automatic Meter Reading) provides periodic reads; manual and self-reads are less frequent.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalFactor rdf:type rdf:Property ;
    rdfs:label 'Seasonal Factor' ;
    rdfs:comment 'Multiplier representing expected seasonal variation in consumption for this customer class and service type. Used for forecasting and anomaly detection. 1.0 = average; >1.0 = high season; <1.0 = low season.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalConsumptionCcf rdf:type rdf:Property ;
    rdfs:label 'Total Consumption Ccf' ;
    rdfs:comment 'Total water consumption for the billing period measured in CCF (hundred cubic feet). Standard billing unit for many water utilities. 1 CCF = 748 gallons.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalConsumptionGallons rdf:type rdf:Property ;
    rdfs:label 'Total Consumption Gallons' ;
    rdfs:comment 'Total water consumption for the billing period measured in gallons. Aggregated from validated interval reads or manual meter reads.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherNormalizedConsumptionGallons rdf:type rdf:Property ;
    rdfs:label 'Weather Normalized Consumption Gallons' ;
    rdfs:comment 'Consumption adjusted for weather variations using heating/cooling degree days or precipitation data. Used for fair year-over-year comparisons and conservation program evaluation.' ;
    rdfs:domain ind:ConsumptionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leakDetectionEventId rdf:type rdf:Property ;
    rdfs:label 'Leak Detection Event Id' ;
    rdfs:comment 'Unique identifier for the leak detection event record. Primary key.' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Billing Adjustment Id' ;
    rdfs:comment 'Reference to the billing adjustment record created for this leak event, if applicable. Links to billing adjustment transaction.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:leakAmiDeviceAmiEndpointId rdf:type rdf:Property ;
    rdfs:label 'Leak Ami Device Ami Endpoint Id' ;
    rdfs:comment 'Reference to the AMI device (Sensus FlexNet endpoint or similar) that generated the interval data used for leak detection. Links to AMI device registry.' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmiEndpoint .

ind:leakAmiEndpointId rdf:type rdf:Property ;
    rdfs:label 'Leak Ami Endpoint Id' ;
    rdfs:comment 'Reference to the AMI device (Sensus FlexNet endpoint or similar) that generated the interval data used for leak detection. Links to AMI device registry.' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmiEndpoint .

ind:leakEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Leak Employee Id' ;
    rdfs:comment 'User identifier of the system user or automated process that created this leak detection event record. Used for audit and accountability.' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:leakLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Leak Last Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the system user who last modified this leak detection event record. Used for audit and accountability.' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryLeakEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Leak Employee Id' ;
    rdfs:comment 'User identifier of the system user or automated process that created this leak detection event record. Used for audit and accountability.' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryCorrespondenceId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Correspondence Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_correspondence. Business justification: Significant leak events trigger regulatory notification requirements under water loss control programs and infrastructure compliance mandates. Real process: notifying primacy agencies of major leak ev' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryCorrespondence .

ind:billingAdjustmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Adjustment Eligible Flag' ;
    rdfs:comment 'Boolean indicator whether this leak event qualifies for a customer billing adjustment under utility leak adjustment policy. True indicates eligibility for adjustment consideration.' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Algorithmic confidence score (0-100) indicating the likelihood that the detected anomaly represents a true leak. Higher scores indicate greater confidence in detection accuracy.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:continuousFlowFlag rdf:type rdf:Property ;
    rdfs:label 'Continuous Flow Flag' ;
    rdfs:comment 'Boolean indicator that the leak was detected through continuous flow analysis (flow detected 24 hours without interruption). True indicates continuous flow was the detection trigger.' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'Date when the customer was notified about the detected leak event. Used for tracking notification timeliness and customer service metrics.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notified Flag' ;
    rdfs:comment 'Boolean indicator whether the customer has been notified of the detected leak event. True indicates notification has been sent.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionAlgorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Detection Algorithm Version' ;
    rdfs:comment 'Version identifier of the leak detection algorithm or software that identified this event. Used for algorithm performance tracking and continuous improvement.' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Method or technique used to identify the leak event. Indicates whether detection was automated (AMI interval analysis, continuous flow flag, minimum night flow anomaly) or manual (acoustic sensor, field inspection, customer report).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the leak was first detected by the AMI system or monitoring algorithm. Principal business event timestamp for this event.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedLeakVolumeGallonsPerDay rdf:type rdf:Property ;
    rdfs:label 'Estimated Leak Volume Gallons Per Day' ;
    rdfs:comment 'Estimated daily water loss volume attributed to the detected leak, measured in gallons per day. Calculated from interval consumption data or continuous flow analysis.' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTotalLossGallons rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Loss Gallons' ;
    rdfs:comment 'Total estimated water loss volume from leak start to resolution, measured in gallons. Calculated as leak volume per day multiplied by duration. Contributes to Non-Revenue Water (NRW) and Unaccounted-for Water (UFW) metrics.' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Flow Threshold Value' ;
    rdfs:comment 'The flow rate threshold value (in gallons per minute or GPM) that was exceeded to trigger the leak detection alert. Used for continuous flow and threshold-based detection methods.' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investigationNotes rdf:type rdf:Property ;
    rdfs:label 'Investigation Notes' ;
    rdfs:comment 'Free-text field for field technician or customer service representative notes regarding leak investigation, customer interaction, or resolution details.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leakDurationHours rdf:type rdf:Property ;
    rdfs:label 'Leak Duration Hours' ;
    rdfs:comment 'Estimated or measured duration of the leak event from detection timestamp to resolution or current time if unresolved, measured in hours.' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leakLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Leak Location Description' ;
    rdfs:comment 'Textual description of the suspected or confirmed leak location (e.g., service line, toilet, irrigation system, water heater). Provides context for leak source and repair scope.' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leakStatus rdf:type rdf:Property ;
    rdfs:label 'Leak Status' ;
    rdfs:comment 'Current lifecycle status of the leak detection event. Tracks progression from initial detection through investigation, customer notification, and resolution.' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leakType rdf:type rdf:Property ;
    rdfs:label 'Leak Type' ;
    rdfs:comment 'Classification of the leak by type or source. Helps categorize leak patterns and target customer education programs. [ENUM-REF-CANDIDATE: service_line|meter|toilet|faucet|irrigation|water_heater|pool|unknown — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumNightFlowAnomalyFlag rdf:type rdf:Property ;
    rdfs:label 'Minimum Night Flow Anomaly Flag' ;
    rdfs:comment 'Boolean indicator that the leak was detected through minimum night flow analysis showing abnormal consumption during low-usage hours (typically 2 AM - 4 AM). True indicates MNF anomaly detection.' ;
    rdfs:domain ind:LeakDetectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome or resolution status of the leak detection event. Indicates whether the leak was confirmed and repaired, determined to be a false positive, or remains pending.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highUsageAlertId rdf:type rdf:Property ;
    rdfs:label 'High Usage Alert Id' ;
    rdfs:comment 'Unique identifier for the high usage alert record. Primary key.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertRuleId rdf:type rdf:Property ;
    rdfs:label 'Alert Rule Id' ;
    rdfs:comment 'Reference to the business rule or threshold configuration that triggered this alert. Links to alert rule definition for audit and tuning purposes.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AlertRule .

ind:highAmiDeviceAmiEndpointId rdf:type rdf:Property ;
    rdfs:label 'High Ami Device Ami Endpoint Id' ;
    rdfs:comment 'Unique identifier of the AMI endpoint device (Sensus FlexNet or similar) that generated the consumption data triggering this alert. Used for device diagnostics and data quality validation.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmiEndpoint .

ind:highAmiEndpointId rdf:type rdf:Property ;
    rdfs:label 'High Ami Endpoint Id' ;
    rdfs:comment 'Unique identifier of the AMI endpoint device (Sensus FlexNet or similar) that generated the consumption data triggering this alert. Used for device diagnostics and data quality validation.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmiEndpoint .

ind:investigationAssignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Investigation Assigned To Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: High usage alert investigation assignment to customer service or field technicians is core operational workflow. Enables workload tracking, SLA compliance monitoring, and employee performance metrics.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualConsumptionUnit rdf:type rdf:Property ;
    rdfs:label 'Actual Consumption Unit' ;
    rdfs:comment 'Unit of measure for the actual consumption value. Gallons, cubic feet, and cubic meters represent volume; GPM (Gallons per Minute) and MGD (Million Gallons per Day) represent flow rate.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualConsumptionValue rdf:type rdf:Property ;
    rdfs:label 'Actual Consumption Value' ;
    rdfs:comment 'The measured consumption value during the detection period that triggered the alert. Represents the actual usage that exceeded the threshold.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Generated Timestamp' ;
    rdfs:comment 'Date and time when the alert was generated by the Advanced Metering Infrastructure (AMI) or analytics system. Represents the moment the threshold breach was detected.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertNumber rdf:type rdf:Property ;
    rdfs:label 'Alert Number' ;
    rdfs:comment 'Business-facing unique alert number used for tracking and customer communication. Format: HUA-XXXXXXXXXX.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertStatus rdf:type rdf:Property ;
    rdfs:label 'Alert Status' ;
    rdfs:comment 'Current lifecycle status of the alert. Open indicates newly generated; notified means customer has been contacted; acknowledged means customer confirmed receipt; investigating indicates active review; resolved means issue addressed; dismissed means no action required; false positive indicates erroneous alert. [ENUM-REF-CANDIDATE: open|notified|acknowledged|investigating|resolved|dismissed|false_positive — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Classification of the high usage alert based on consumption pattern analysis. High consumption indicates volume exceeds baseline; continuous flow suggests uninterrupted usage; backflow suspected indicates reverse flow detection; leak detected flags potential infrastructure failure; abnormal pattern identifies irregular usage; threshold exceeded indicates absolute limit breach.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineConsumptionValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Consumption Value' ;
    rdfs:comment 'Historical average or expected consumption value used as the comparison baseline for this alert. May be calculated from seasonal norms, customer history, or similar account profiles.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselinePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Baseline Period Days' ;
    rdfs:comment 'Number of days used to calculate the baseline consumption value. Typical values include 30, 60, 90, or 365 days depending on seasonality and data availability.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerAcknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Acknowledged Timestamp' ;
    rdfs:comment 'Date and time when the customer acknowledged receipt and awareness of this alert. Null if customer has not acknowledged.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionPeriodEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Period End Timestamp' ;
    rdfs:comment 'End of the time window during which the high usage condition was detected. Used to define the consumption analysis interval.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionPeriodStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Period Start Timestamp' ;
    rdfs:comment 'Beginning of the time window during which the high usage condition was detected. Used to define the consumption analysis interval.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedRevenueImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue Impact Amount' ;
    rdfs:comment 'Estimated financial impact of the high usage condition, representing potential lost revenue or customer billing adjustment. Positive values indicate revenue at risk; negative values indicate customer credits issued. Null if not calculated.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Notification Timestamp' ;
    rdfs:comment 'Date and time when the first customer notification was sent for this alert. Null if customer has not been notified.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigationStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation Started Timestamp' ;
    rdfs:comment 'Date and time when investigation of this alert began. Null if investigation has not started.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationCount rdf:type rdf:Property ;
    rdfs:label 'Notification Count' ;
    rdfs:comment 'Total number of notification attempts made to the customer regarding this alert. Includes all channels and retries.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionCategory rdf:type rdf:Property ;
    rdfs:label 'Resolution Category' ;
    rdfs:comment 'Classification of the root cause or resolution outcome for this alert. Customer leak repaired indicates customer-side plumbing issue fixed; utility leak repaired indicates utility infrastructure issue fixed; meter malfunction indicates faulty meter; seasonal usage indicates expected variance; customer behavior change indicates legitimate usage increase; irrigation system and pool filling indicate specific high-volume activities; construction activity indicates temporary usage spike; false alarm indicates erroneous alert; other indicates miscellaneous resolution. [ENUM-REF-CANDIDATE: customer_leak_repaired|utility_leak_repaired|meter_malfunction|seasonal_usage|customer_behavior_change|irrigation_system|pool_filling|construction_activity|false_alarm|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceOrderCreatedFlag rdf:type rdf:Property ;
    rdfs:label 'Service Order Created Flag' ;
    rdfs:comment 'Indicates whether a field service order was created in response to this alert. True means service order generated; False means no service order created.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression Flag' ;
    rdfs:comment 'Indicates whether this alert was suppressed from customer notification due to business rules (e.g., customer opted out, account in dispute, recent similar alert). True means suppressed; False means not suppressed.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'Explanation of why this alert was suppressed from customer notification. Null if alert was not suppressed.' ;
    rdfs:domain ind:HighUsageAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measure for the threshold value. Gallons and cubic feet/meters represent volume; GPM (Gallons per Minute) and MGD (Million Gallons per Day) represent flow rate; percent represents variance from baseline.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Percentage by which actual consumption exceeded the threshold value. Calculated as ((actual - threshold) / threshold) * 100. Positive values indicate over-threshold conditions.' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accuracyTestId rdf:type rdf:Property ;
    rdfs:label 'Accuracy Test Id' ;
    rdfs:comment 'Primary key for accuracy_test' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccuracyTest .

ind:accuracyTechnicianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Accuracy Technician Employee Id' ;
    rdfs:comment 'Employee who performed the test' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accuracyTestedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Accuracy Tested By Employee Id' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceptanceThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Acceptance Threshold Pct' ;
    rdfs:comment 'Accuracy threshold for pass/fail determination' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accuracyHighFlowPercent rdf:type rdf:Property ;
    rdfs:label 'Accuracy High Flow Percent' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accuracyLowFlowPercent rdf:type rdf:Property ;
    rdfs:label 'Accuracy Low Flow Percent' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accuracyMidFlowPercent rdf:type rdf:Property ;
    rdfs:label 'Accuracy Mid Flow Percent' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Accuracy Percent' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Accuracy Percentage' ;
    rdfs:comment 'Measured accuracy percentage.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accuracyThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Accuracy Threshold Pct' ;
    rdfs:comment 'Accuracy threshold for pass/fail' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualVolume rdf:type rdf:Property ;
    rdfs:label 'Actual Volume' ;
    rdfs:comment 'Actual volume passed through meter' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Adjustment Factor' ;
    rdfs:comment 'Adjustment factor applied' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentMade rdf:type rdf:Property ;
    rdfs:label 'Adjustment Made' ;
    rdfs:comment 'Whether adjustment was made' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:awwaStandardUsed rdf:type rdf:Property ;
    rdfs:label 'Awwa Standard Used' ;
    rdfs:comment 'AWWA standard used for test' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Certificate Number' ;
    rdfs:comment 'Factory calibration certificate number' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositeAccuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Composite Accuracy Percent' ;
    rdfs:comment 'Weighted composite accuracy' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Corrective action taken if meter failed' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPresent rdf:type rdf:Property ;
    rdfs:label 'Customer Present' ;
    rdfs:comment 'Whether customer was present' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Meter disposition (return to service, scrap, etc.)' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highFlowAccuracy rdf:type rdf:Property ;
    rdfs:label 'High Flow Accuracy' ;
    rdfs:comment 'High flow accuracy percentage.' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:highFlowAccuracyPct rdf:type rdf:Property ;
    rdfs:label 'High Flow Accuracy Pct' ;
    rdfs:comment 'Accuracy at high flow rate' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:highFlowAccuracyPercent rdf:type rdf:Property ;
    rdfs:label 'High Flow Accuracy Percent' ;
    rdfs:comment 'Accuracy at high flow rate' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:highFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'High Flow Rate Gpm' ;
    rdfs:comment 'High flow test rate' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowFlowAccuracy rdf:type rdf:Property ;
    rdfs:label 'Low Flow Accuracy' ;
    rdfs:comment 'Low flow accuracy percentage.' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowFlowAccuracyPct rdf:type rdf:Property ;
    rdfs:label 'Low Flow Accuracy Pct' ;
    rdfs:comment 'Accuracy at low flow rate' ;
    rdfs:domain ind:Metering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowFlowAccuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Low Flow Accuracy Percent' ;
    rdfs:comment 'Accuracy at low flow rate' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Low Flow Rate Gpm' ;
    rdfs:comment 'Low flow test rate' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredVolume rdf:type rdf:Property ;
    rdfs:label 'Measured Volume' ;
    rdfs:comment 'Volume measured by the meter during test' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediumFlowAccuracyPct rdf:type rdf:Property ;
    rdfs:label 'Medium Flow Accuracy Pct' ;
    rdfs:comment 'Accuracy at medium flow rate' ;
    rdfs:domain ind:AccuracyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediumFlowAccuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Medium Flow Accuracy Percent' ;
    rdfs:comment 'Accuracy at medium flow rate' ;
    rdfs:domain ind:AccuracyTest ;
