ind:accountPersonRelId rdf:type rdf:Property ;
    rdfs:label 'Account Person Rel Id' ;
    rdfs:comment 'Unique identifier for the account-person relationship record. Primary key.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAccountPersonId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Person Id' ;
    rdfs:comment 'Reference to the person entity in this relationship. Links to the individual who has a role on the account.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Person .

ind:accessibilityRequirements rdf:type rdf:Property ;
    rdfs:label 'Accessibility Requirements' ;
    rdfs:comment 'Special accessibility or accommodation needs for this person when communicating about the account. May include requirements for large print, braille, TTY, or other assistive technologies.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'The date when this relationship was formally authorized or approved. Used for audit trail and compliance verification.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Authorization Document Reference' ;
    rdfs:comment 'Reference number or identifier for the legal document or form that authorizes this relationship. May reference a power of attorney, lease agreement, or authorization form.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Authority Flag' ;
    rdfs:comment 'Indicates whether this person has authority to make billing decisions, dispute charges, or modify payment arrangements for the account. True if authorized, false otherwise.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccrDeliveryRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ccr Delivery Required Flag' ;
    rdfs:comment 'Indicates whether this person must receive the annual Consumer Confidence Report for water quality as required by the Safe Drinking Water Act. True if delivery is required, false otherwise.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'The system user ID or username of the person who created this relationship record. Used for audit trail and accountability.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPriority rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Priority' ;
    rdfs:comment 'The order in which this person should be contacted in case of emergency at the service address. Lower numbers indicate higher priority. Null if not an emergency contact.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financialResponsibilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Financial Responsibility Percentage' ;
    rdfs:comment 'The percentage of account charges for which this person is financially responsible. Used in split-billing scenarios or shared responsibility arrangements. Value between 0.00 and 100.00.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landlordTenantIndicator rdf:type rdf:Property ;
    rdfs:label 'Landlord Tenant Indicator' ;
    rdfs:comment 'Specifies whether this person is the property owner (landlord), renter (tenant), owner-occupant, or property manager. Used for billing responsibility determination and compliance reporting.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The system user ID or username of the person who last modified this relationship record. Used for audit trail and accountability.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcrrNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Lcrr Notification Required Flag' ;
    rdfs:comment 'Indicates whether this person must receive mandatory notifications under the EPA Lead and Copper Rule Revisions regarding lead service lines at the service address. True if notification is required, false otherwise.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationPreference rdf:type rdf:Property ;
    rdfs:label 'Notification Preference' ;
    rdfs:comment 'The preferred communication channel for sending notifications to this person regarding the account. Used for outage alerts, billing reminders, and compliance notifications.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipNotes rdf:type rdf:Property ;
    rdfs:label 'Relationship Notes' ;
    rdfs:comment 'Free-form text field for additional information about this account-person relationship. May include special instructions, restrictions, or context relevant to customer service representatives.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle status of the account-person relationship. Indicates whether the relationship is currently in effect or has been terminated.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'The role or capacity in which the person is associated with the account. Defines the nature of the relationship between the person and the service account.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Service Authorization Flag' ;
    rdfs:comment 'Indicates whether this person has authority to request service orders, schedule appointments, or authorize field work for the account. True if authorized, false otherwise.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyPayerFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Payer Flag' ;
    rdfs:comment 'Indicates whether this person is responsible for paying the bill on behalf of the primary account holder. True for third-party payers such as social service agencies or property managers, false otherwise.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date when the person\'s identity and relationship authorization were last verified. Used for periodic re-verification requirements and audit compliance.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'The method used to verify the person\'s identity and authorization for this relationship. Used for audit trail and fraud prevention analysis.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Indicates whether the person\'s identity and authorization for this relationship have been verified. Used for fraud prevention and compliance with customer identification requirements.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Unique identifier for the customer segment classification record. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name of the regulatory body or internal authority that approved this segment definition. Examples: State PUC, Board of Directors, City Council.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date when this customer segment definition was approved by the Public Utilities Commission (PUC) or governing board for rate-making purposes.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assistanceProgramEligible rdf:type rdf:Property ;
    rdfs:label 'Assistance Program Eligible' ;
    rdfs:comment 'Indicates whether customers in this segment are eligible for low-income assistance programs, payment plans, or rate discounts. True if eligible, False otherwise.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccrDistributionRequired rdf:type rdf:Property ;
    rdfs:label 'Ccr Distribution Required' ;
    rdfs:comment 'Indicates whether customers in this segment must receive the annual Consumer Confidence Report (CCR) as required by the Safe Drinking Water Act (SDWA). True if required, False otherwise.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the customer segment. Examples: LIRA (Low-Income Residential Assistance), LIU (Large Industrial User), MUN_WHSL (Municipal Wholesale), IRR (Irrigation-Only), FIRE_PROT (Fire Protection Only).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conservationTargetPct rdf:type rdf:Property ;
    rdfs:label 'Conservation Target Pct' ;
    rdfs:comment 'Target water conservation reduction percentage for this segment during drought or conservation programs. Expressed as a percentage (e.g., 15.00 for 15% reduction).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerCount rdf:type rdf:Property ;
    rdfs:label 'Customer Count' ;
    rdfs:comment 'Current number of active customer accounts assigned to this segment. Updated periodically for reporting and forecasting purposes.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demandForecastCategory rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Category' ;
    rdfs:comment 'Category used for water demand forecasting and capacity planning. Segments with similar consumption patterns are grouped for predictive modeling.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed description of the customer segment, including eligibility criteria, business purpose, and usage characteristics.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicZone rdf:type rdf:Property ;
    rdfs:label 'Geographic Zone' ;
    rdfs:comment 'Geographic zone, District Metered Area (DMA), or service territory identifier used for segmentation. Null if geography is not a segmentation criterion.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Code' ;
    rdfs:comment 'NAICS (North American Industry Classification System) or SIC (Standard Industrial Classification) code for commercial and industrial segments. Used for regulatory reporting and demand forecasting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterSizeRange rdf:type rdf:Property ;
    rdfs:label 'Meter Size Range' ;
    rdfs:comment 'Range of meter sizes (in inches) typically associated with this segment. Examples: 5/8-3/4 inch, 1-2 inch, 3+ inch. Used for infrastructure planning and rate design.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Full business name of the customer segment for display and reporting purposes.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Service priority level for this segment during water shortage or emergency conditions. Critical segments (e.g., hospitals, fire protection) receive highest priority.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCaseDocketNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Case Docket Number' ;
    rdfs:comment 'Regulatory docket or case number associated with the rate case that established or modified this customer segment. Used for audit trail and regulatory compliance.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateTier rdf:type rdf:Property ;
    rdfs:label 'Rate Tier' ;
    rdfs:comment 'Applicable rate tier or rate schedule identifier associated with this customer segment. Links segment to pricing structure for billing purposes.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Category' ;
    rdfs:comment 'Category used for state and federal regulatory reporting, including EPA and state primacy agency reports. Examples: residential, commercial, industrial, public authority.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueContributionPct rdf:type rdf:Property ;
    rdfs:label 'Revenue Contribution Pct' ;
    rdfs:comment 'Percentage of total utility revenue contributed by this customer segment. Used for rate design and financial planning. Expressed as a percentage (e.g., 25.50 for 25.5%).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalVariationFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Variation Flag' ;
    rdfs:comment 'Indicates whether this segment exhibits significant seasonal variation in water usage (e.g., irrigation customers with summer peaks). True if seasonal, False otherwise.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the customer segment. Active segments are available for customer assignment; pending segments are approved but not yet effective; retired segments are historical only.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'High-level classification of the customer segment by primary customer type.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentationBasis rdf:type rdf:Property ;
    rdfs:label 'Segmentation Basis' ;
    rdfs:comment 'Primary criterion used to define and assign customers to this segment. Examples: usage volume thresholds, customer type classification, industry class (NAICS), geographic zone (DMA), income qualification, meter size. [ENUM-REF-CANDIDATE: usage_volume|customer_type|industry_class|geographic_zone|rate_class|service_type|income_level|meter_size — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageThresholdMaxMgd rdf:type rdf:Property ;
    rdfs:label 'Usage Threshold Max Mgd' ;
    rdfs:comment 'Maximum average daily water usage in Million Gallons per Day (MGD) allowed for assignment to this segment. Null if usage volume is not a segmentation criterion or if there is no upper limit.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageThresholdMinMgd rdf:type rdf:Property ;
    rdfs:label 'Usage Threshold Min Mgd' ;
    rdfs:comment 'Minimum average daily water usage in Million Gallons per Day (MGD) required for assignment to this segment. Null if usage volume is not a segmentation criterion.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountSegmentAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Account Segment Assignment Id' ;
    rdfs:comment 'Unique identifier for each account segment assignment record. Primary key for the account segment assignment entity.' ;
    rdfs:domain ind:AccountSegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'General free-text notes field for capturing additional information about the segment assignment that does not fit into structured fields. May include customer service interactions, special circumstances, or operational reminders.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Business-readable unique identifier for the segment assignment. Used for tracking and audit purposes in customer service and billing operations.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason or trigger that caused the segment assignment. Examples include annual income recertification for low-income programs, usage threshold crossing for high-volume commercial customers, manual override by customer service representative, rate class change due to meter size upgrade, enrollment in conservation program, or regulatory mandate for special customer class.' ;
    rdfs:domain ind:AccountSegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason Description' ;
    rdfs:comment 'Free-text explanation providing additional context for the segment assignment. Captures details not conveyed by the reason code, such as specific program names, regulatory citation, or customer service notes.' ;
    rdfs:domain ind:AccountSegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentSourceReference rdf:type rdf:Property ;
    rdfs:label 'Assignment Source Reference' ;
    rdfs:comment 'External reference identifier from the source system that created the assignment. May contain transaction ID, batch job ID, API request ID, or other traceability information to support audit and troubleshooting.' ;
    rdfs:domain ind:AccountSegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Assignment Source System' ;
    rdfs:comment 'System or process that originated the segment assignment record. Identifies whether the assignment was created by the billing system (CC&B), customer information system (CIS), customer relationship management system (CRM), manual entry by staff, automated batch process, external API integration, or data migration activity. [ENUM-REF-CANDIDATE: CC&B|CIS|CRM|MANUAL|BATCH_PROCESS|API|DATA_MIGRATION — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountSegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the segment assignment. Active assignments are currently in effect; pending assignments are scheduled for future activation; expired assignments have passed their end date; superseded assignments have been replaced by newer assignments; cancelled assignments were terminated before their natural expiration.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date when the customer or account was certified as eligible for the assigned segment. Particularly relevant for income-qualified programs, special assistance programs, or regulatory customer classes that require periodic recertification.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isPrimarySegment rdf:type rdf:Property ;
    rdfs:label 'Is Primary Segment' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary segment assignment for the account. Only one assignment per account should be marked as primary at any given time. Primary segment drives default billing behavior and customer service routing.' ;
    rdfs:domain ind:AccountSegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User identifier or system process name that most recently modified the segment assignment record. Supports accountability and audit trail for data change events.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideAuthorizedBy rdf:type rdf:Property ;
    rdfs:label 'Override Authorized By' ;
    rdfs:comment 'Name or employee identifier of the staff member who authorized a manual override of the segment assignment. Required when override_flag is true. Supports audit trail and accountability for exception processing.' ;
    rdfs:domain ind:AccountSegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Boolean flag indicating whether this assignment was manually overridden by authorized staff, bypassing normal automated assignment rules. Used for audit and compliance reporting to track exceptions to standard segmentation logic.' ;
    rdfs:domain ind:AccountSegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideJustification rdf:type rdf:Property ;
    rdfs:label 'Override Justification' ;
    rdfs:comment 'Free-text explanation of the business justification for manually overriding the segment assignment. Required when override_flag is true. Captures the reason for the exception to support regulatory audits and management review.' ;
    rdfs:domain ind:AccountSegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric ranking used to resolve conflicts when an account has multiple active segment assignments. Lower numbers indicate higher priority. Used by billing and rate engine to determine which segment rules apply when overlapping assignments exist.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Recertification Due Date' ;
    rdfs:comment 'Date by which the customer must recertify their eligibility for the assigned segment. Used for programs requiring annual or periodic income verification, such as low-income assistance programs. Triggers customer notifications and workflow tasks.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User identifier or system process name that created the segment assignment record. Supports accountability and audit trail for data creation events.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceApplicationId rdf:type rdf:Property ;
    rdfs:label 'Service Application Id' ;
    rdfs:comment 'Unique identifier for the service application record. Primary key.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicantPersonId rdf:type rdf:Property ;
    rdfs:label 'Applicant Person Id' ;
    rdfs:comment 'Foreign key linking to customer.person. Business justification: Service applications capture applicant details that should reference the person master record. This eliminates data duplication and ensures applicant identity is properly managed. The person table con' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Person .

ind:offeringId rdf:type rdf:Property ;
    rdfs:label 'Offering Id' ;
    rdfs:comment 'Foreign key linking to service.offering. Business justification: Applications request specific service offerings (potable water, wastewater, reclaimed). Application review validates requested service against available offerings, calculates connection fees per offer' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:pressureZoneId rdf:type rdf:Property ;
    rdfs:label 'Pressure Zone Id' ;
    rdfs:comment 'Foreign key linking to distribution.pressure_zone. Business justification: New service applications require engineering review to verify adequate pressure and capacity in the target pressure zone before approval. Critical for ensuring system can support additional demand wit' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PressureZone .

ind:primaryServiceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Employee Id' ;
    rdfs:comment 'User ID of the utility staff member who approved the service application.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:serviceAssignedToUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Service Assigned To User Employee Id' ;
    rdfs:comment 'User ID of the utility staff member currently assigned to review and process this service application.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:serviceCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Service Customer Account Id' ;
    rdfs:comment 'Reference to the customer (applicant) who submitted this service application. Links to the customer master record.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:serviceCustomerCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Service Customer Customer Account Id' ;
    rdfs:comment 'Reference to the customer (applicant) who submitted this service application. Links to the customer master record.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:serviceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Service Employee Id' ;
    rdfs:comment 'User ID of the utility staff member who approved the service application.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Externally-visible unique application number assigned when the customer submits a service application. Used for customer communication and tracking.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the service application: submitted (initial state), under review (being processed by utility staff), approved (ready for service establishment), rejected (application denied), withdrawn (applicant cancelled), or pending payment (awaiting deposit or connection fee).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Type of service application: new service establishment, transfer of service to new occupant, service upgrade (larger meter or additional service), service downgrade, service termination, or reconnection after disconnection.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Precise date and time when the service application was approved.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditCheckResult rdf:type rdf:Property ;
    rdfs:label 'Credit Check Result' ;
    rdfs:comment 'Outcome of the credit check: pass (credit meets utility standards), fail (credit does not meet standards, deposit required), insufficient history (no credit history available), or not applicable (credit check not performed).' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Check Status' ;
    rdfs:comment 'Status of credit check for the applicant: not required (based on service class or policy), pending (credit check requested), completed (credit check results received), or waived (credit check requirement waived by management).' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterSizeRequested rdf:type rdf:Property ;
    rdfs:label 'Meter Size Requested' ;
    rdfs:comment 'Size of water meter requested by the applicant or recommended by utility staff based on anticipated usage (e.g., 5/8 inch, 3/4 inch, 1 inch, 1.5 inch, 2 inch, etc.).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingNotes rdf:type rdf:Property ;
    rdfs:label 'Processing Notes' ;
    rdfs:comment 'Free-text notes entered by utility staff during application review and processing, documenting special circumstances, follow-up actions, or additional context.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date when the service application was rejected by the utility. Null if application was not rejected.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed explanation of why the service application was rejected (e.g., failed credit check, incomplete documentation, service not available at address, outstanding balance from previous account).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code categorizing the reason for application rejection: credit failure, incomplete documentation, service unavailable at location, outstanding balance from prior account, duplicate application, or invalid service address.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedServiceStartDate rdf:type rdf:Property ;
    rdfs:label 'Requested Service Start Date' ;
    rdfs:comment 'Date when the applicant requests water or wastewater service to begin at the service address.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Review Completed Date' ;
    rdfs:comment 'Date when the application review process was completed and a decision (approved or rejected) was made.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'Date when utility staff began reviewing and processing the service application.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceClassRequested rdf:type rdf:Property ;
    rdfs:label 'Service Class Requested' ;
    rdfs:comment 'Customer segment or service class requested: residential (single-family or multi-family), commercial (retail, office), industrial (manufacturing, processing), municipal (government facilities), agricultural (irrigation, livestock), or institutional (schools, hospitals).' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTypeRequested rdf:type rdf:Property ;
    rdfs:label 'Service Type Requested' ;
    rdfs:comment 'Type of utility service requested by the applicant: water only, wastewater (sewer) only, or combined water and wastewater service.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Due Date' ;
    rdfs:comment 'Target date by which the application should be reviewed and processed according to utility service level agreement standards.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Channel through which the customer submitted the service application: online customer portal, phone call to customer service, walk-in at utility office, postal mail, mobile app, or email.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Precise date and time when the service application was submitted by the customer or entered into the system.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:withdrawnDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawn Date' ;
    rdfs:comment 'Date when the applicant withdrew or cancelled the service application. Null if application was not withdrawn.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawnReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawn Reason' ;
    rdfs:comment 'Reason provided by the applicant for withdrawing the service application (e.g., changed mind, moved to different location, service no longer needed).' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Account Status History Id' ;
    rdfs:comment 'Unique identifier for each account status transition record. Primary key for the account status history log.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Created By User Employee Id' ;
    rdfs:comment 'The system user identifier of the person or process that created this status history record. Supports audit trail and data quality investigations.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Employee Id' ;
    rdfs:comment 'The system user identifier of the person who initiated or approved the status transition. May be a customer service representative, billing clerk, or system administrator.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountPaymentArrangementPaymentPlanId rdf:type rdf:Property ;
    rdfs:label 'Account Payment Arrangement Payment Plan Id' ;
    rdfs:comment 'Reference to an active payment arrangement or installment plan associated with the status transition. Used to track compliance with payment agreements.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentPlan .

ind:accountPaymentPlanId rdf:type rdf:Property ;
    rdfs:label 'Account Payment Plan Id' ;
    rdfs:comment 'Reference to an active payment arrangement or installment plan associated with the status transition. Used to track compliance with payment agreements.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentPlan .

ind:arTransactionId rdf:type rdf:Property ;
    rdfs:label 'Ar Transaction Id' ;
    rdfs:comment 'The unique transaction or event identifier from the source system that generated this status history record. Enables traceability back to the originating system.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArTransaction .

ind:billingCycleId rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Id' ;
    rdfs:comment 'Reference to the billing cycle during which the status transition occurred. Used for financial period analysis and revenue recognition.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingCycle .

ind:caseId rdf:type rdf:Property ;
    rdfs:label 'Case Id' ;
    rdfs:comment 'Reference to the customer service case or dispute that is associated with this status transition. Used for tracking customer interactions and complaint resolution.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:complianceViolationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Violation Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_violation. Business justification: Account status changes (service holds, disconnection restrictions) may be triggered by compliance violations—e.g., industrial user violations preventing disconnection per regulatory requirements.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceViolation .

ind:customerComplaintId rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Id' ;
    rdfs:comment 'Reference to the customer service case or dispute that is associated with this status transition. Used for tracking customer interactions and complaint resolution.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerComplaint .

ind:meterReadId rdf:type rdf:Property ;
    rdfs:label 'Meter Read Id' ;
    rdfs:comment 'Reference to the final or initial meter reading associated with the status transition, such as a final read at termination or initial read at activation.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Read .

ind:pointId rdf:type rdf:Property ;
    rdfs:label 'Point Id' ;
    rdfs:comment 'Reference to the physical service point (meter location) associated with the account at the time of the status transition. Links status changes to physical infrastructure.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Point .

ind:primaryAccountEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Employee Id' ;
    rdfs:comment 'The system user identifier of the person who initiated or approved the status transition. May be a customer service representative, billing clerk, or system administrator.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reversedHistoryAccountStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Reversed History Account Status History Id' ;
    rdfs:comment 'Reference to the original account status history record that this transition reverses or corrects. Maintains audit trail linkage for reversed transactions.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountStatusHistory .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Reference to the field service work order that triggered or resulted from the status transition, such as a disconnect or reconnect order.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text field for documenting regulatory compliance considerations, special circumstances, or audit trail notes related to the status transition.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedBySystemCode rdf:type rdf:Property ;
    rdfs:label 'Initiated By System Code' ;
    rdfs:comment 'The source system or channel that triggered the status transition. Distinguishes between automated system-driven changes and manual user actions. [ENUM-REF-CANDIDATE: CC&B|MAXIMO|CRM|BATCH_BILLING|AMI|MANUAL|IVR|PORTAL — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Flag' ;
    rdfs:comment 'Indicates whether a medical certification was on file at the time of the status transition, which may prevent service disconnection under state regulations.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newStatusCode rdf:type rdf:Property ;
    rdfs:label 'New Status Code' ;
    rdfs:comment 'The status code of the account after this transition. Represents the to state in the status lifecycle. [ENUM-REF-CANDIDATE: PENDING|ACTIVE|SUSPENDED|FINAL_NOTICE|TERMINATED|INACTIVE|CLOSED|DELINQUENT — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'The communication channel used to notify the customer of the status change. Supports multi-channel customer communication tracking.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether a customer notification was sent regarding the status change. Required for regulatory compliance and customer service audit trails.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'The date and time when the customer notification was sent. Used to verify compliance with advance notice requirements.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outstandingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance Amount' ;
    rdfs:comment 'The total outstanding account balance in USD at the time of the status transition. Critical for non-payment related status changes and collections analytics.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousStatusCode rdf:type rdf:Property ;
    rdfs:label 'Previous Status Code' ;
    rdfs:comment 'The status code of the account immediately before this transition occurred. Represents the from state in the status lifecycle. [ENUM-REF-CANDIDATE: PENDING|ACTIVE|SUSPENDED|FINAL_NOTICE|TERMINATED|INACTIVE|CLOSED|DELINQUENT — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the status transition. Used for root cause analysis and regulatory reporting. [ENUM-REF-CANDIDATE: NON_PAYMENT|CUSTOMER_REQUEST|MOVE_OUT|POLICY_VIOLATION|SEASONAL|METER_ISSUE|FRAUD|BANKRUPTCY|DECEASED|ADMINISTRATIVE — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of the reason for the status change. Provides additional context beyond the standardized reason code.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconnectionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Reconnection Fee Amount' ;
    rdfs:comment 'The reconnection or reactivation fee in USD charged for restoring service after suspension or termination. Supports revenue recognition and fee tracking.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether the status transition is subject to a regulatory hold or moratorium, such as winter shutoff protection or pandemic-related restrictions.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this status transition represents a reversal or correction of a previous status change. Used for audit trail integrity and dispute resolution.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledFlag rdf:type rdf:Property ;
    rdfs:label 'Scheduled Flag' ;
    rdfs:comment 'Indicates whether this status transition was scheduled in advance or occurred immediately. Used to distinguish planned versus reactive status changes.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'The originating system of record for this status history entry. Used for data lineage tracking and system integration reconciliation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'The exact date and time when the account status transition became effective. This is the business event timestamp for the status change.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Unique identifier for the contact record. Primary key.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Contact Customer Account Id' ;
    rdfs:comment 'Reference to the customer account or person this contact is associated with. Links contact to the customer master record in Oracle Utilities CC&B.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:contactCustomerCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Contact Customer Customer Account Id' ;
    rdfs:comment 'Reference to the customer account or person this contact is associated with. Links contact to the customer master record in Oracle Utilities CC&B.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:verifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verified By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Contact information verification (especially for emergency notifications, LCRR compliance) is performed by CSR staff. Data quality accountability and regulatory compliance requirement. New attribute n' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The communication channel or medium through which this contact point operates. Supports multi-channel customer engagement including Consumer Confidence Report (CCR) delivery, boil-water notices, and outage notifications.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. Active contacts are used for communications; inactive contacts are retained for history; invalid contacts have been identified as unreachable; pending_verification contacts await confirmation.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact purpose. Indicates whether this contact is used for billing correspondence, service notifications, emergency alerts, legal notices, technical communications, or general customer service inquiries.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFailureCount rdf:type rdf:Property ;
    rdfs:label 'Delivery Failure Count' ;
    rdfs:comment 'Count of failed communication delivery attempts to this contact. Used to identify problematic contacts and trigger validation workflows.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliverySuccessCount rdf:type rdf:Property ;
    rdfs:label 'Delivery Success Count' ;
    rdfs:comment 'Count of successful communication deliveries to this contact. Used to calculate contact reliability and quality scores.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doNotContactFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Flag' ;
    rdfs:comment 'Boolean flag indicating customer has requested no contact through this channel except for legally required communications. Overrides opt-in preferences except for emergency and regulatory notifications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invalidDate rdf:type rdf:Property ;
    rdfs:label 'Invalid Date' ;
    rdfs:comment 'Date when this contact was marked as invalid. Used for data quality reporting and contact refresh prioritization.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invalidReason rdf:type rdf:Property ;
    rdfs:label 'Invalid Reason' ;
    rdfs:comment 'Reason why this contact was marked as invalid. Populated when contact_status is set to invalid. Supports data quality improvement and contact cleansing workflows.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary contact point for the associated customer and contact type. Used to determine default communication channel for critical notifications.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Boolean flag indicating whether this contact information has been verified as accurate and reachable. Verification may occur through confirmation emails, SMS codes, or postal mail validation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Human-readable label or nickname for this contact (e.g., \'Home Phone\', \'Work Email\', \'Billing Address\'). Helps users distinguish between multiple contacts of the same type.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date when this contact point was last used for outbound communication. Used to track contact engagement and identify stale contact records.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastContactType rdf:type rdf:Property ;
    rdfs:label 'Last Contact Type' ;
    rdfs:comment 'Type of the last communication sent to this contact (e.g., bill, service alert, CCR, boil-water notice). Supports communication history analysis.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInBilling rdf:type rdf:Property ;
    rdfs:label 'Opt In Billing' ;
    rdfs:comment 'Boolean flag indicating customer consent to receive billing-related communications through this contact channel. Supports compliance with communication preference regulations.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInEmergency rdf:type rdf:Property ;
    rdfs:label 'Opt In Emergency' ;
    rdfs:comment 'Boolean flag indicating customer consent to receive emergency alerts (e.g., boil-water notices, water quality advisories, Sanitary Sewer Overflow (SSO) notifications) through this contact channel. Typically defaults to true for critical public health communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInMarketing rdf:type rdf:Property ;
    rdfs:label 'Opt In Marketing' ;
    rdfs:comment 'Boolean flag indicating customer consent to receive marketing and promotional communications (e.g., conservation programs, new service offerings) through this contact channel.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInService rdf:type rdf:Property ;
    rdfs:label 'Opt In Service' ;
    rdfs:comment 'Boolean flag indicating customer consent to receive service-related communications (e.g., planned outages, maintenance notifications) through this contact channel.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Date' ;
    rdfs:comment 'Date when the customer opted out of communications through this contact channel. Null if customer has not opted out. Used for compliance reporting and communication suppression.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optOutReason rdf:type rdf:Property ;
    rdfs:label 'Opt Out Reason' ;
    rdfs:comment 'Free-text reason provided by customer for opting out of communications. Supports customer experience analysis and communication strategy improvement.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Data quality score for this contact record (0.00 to 100.00). Calculated based on verification status, recency, completeness, and delivery success rate. Used to prioritize contact data cleansing efforts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'Time zone associated with this contact location (e.g., America/New_York, America/Los_Angeles). Used to schedule communications at appropriate local times and comply with TCPA calling hour restrictions.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:value rdf:type rdf:Property ;
    rdfs:label 'Value' ;
    rdfs:comment 'The actual contact information value - phone number, email address, mailing address, SMS number, portal username, or fax number. Format varies by contact_channel. This is the primary contact data point.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Communication Preference Id' ;
    rdfs:comment 'Unique identifier for the customer communication preference record.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:communicationCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Communication Customer Account Id' ;
    rdfs:comment 'Reference to the customer account for which these communication preferences apply.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:communicationCustomerCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Communication Customer Customer Account Id' ;
    rdfs:comment 'Reference to the customer account for which these communication preferences apply.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:audioFormatRequired rdf:type rdf:Property ;
    rdfs:label 'Audio Format Required' ;
    rdfs:comment 'Indicates whether the customer requires audio format (recorded or synthesized speech) for communications (ADA accommodation).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billReadyChannel rdf:type rdf:Property ;
    rdfs:label 'Bill Ready Channel' ;
    rdfs:comment 'Preferred channel for bill ready notifications when a new bill is available.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boilWaterNoticeChannel rdf:type rdf:Property ;
    rdfs:label 'Boil Water Notice Channel' ;
    rdfs:comment 'Preferred channel for critical public health boil water advisories and rescissions.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brailleRequired rdf:type rdf:Property ;
    rdfs:label 'Braille Required' ;
    rdfs:comment 'Indicates whether the customer requires braille format for printed communications (ADA accommodation).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccrDeliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Ccr Delivery Channel' ;
    rdfs:comment 'Preferred channel for annual Consumer Confidence Report (CCR) delivery as required by EPA.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccrElectronicConsent rdf:type rdf:Property ;
    rdfs:label 'Ccr Electronic Consent' ;
    rdfs:comment 'Indicates whether the customer has provided explicit consent to receive the annual CCR electronically instead of by mail, as permitted by EPA rules.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccrElectronicConsentDate rdf:type rdf:Property ;
    rdfs:label 'Ccr Electronic Consent Date' ;
    rdfs:comment 'Date when the customer consented to electronic CCR delivery.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conservationAlertChannel rdf:type rdf:Property ;
    rdfs:label 'Conservation Alert Channel' ;
    rdfs:comment 'Preferred channel for water conservation alerts, drought notices, and usage reduction requests.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactTimePreference rdf:type rdf:Property ;
    rdfs:label 'Contact Time Preference' ;
    rdfs:comment 'Preferred time of day for non-urgent customer contact (morning, afternoon, evening, or anytime).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delinquencyNoticeChannel rdf:type rdf:Property ;
    rdfs:label 'Delinquency Notice Channel' ;
    rdfs:comment 'Preferred channel for past-due payment reminders and service disconnection warnings.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotCall rdf:type rdf:Property ;
    rdfs:label 'Do Not Call' ;
    rdfs:comment 'Indicates whether the customer has requested to be placed on the internal do-not-call list for non-essential phone communications.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotCallDate rdf:type rdf:Property ;
    rdfs:label 'Do Not Call Date' ;
    rdfs:comment 'Date when the customer requested do-not-call status.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ebillEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Ebill Enrollment Date' ;
    rdfs:comment 'Date when the customer enrolled in electronic billing and paperless delivery.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emailUnsubscribeDate rdf:type rdf:Property ;
    rdfs:label 'Email Unsubscribe Date' ;
    rdfs:comment 'Date when the customer unsubscribed from email communications (for non-transactional messages).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:largePrintRequired rdf:type rdf:Property ;
    rdfs:label 'Large Print Required' ;
    rdfs:comment 'Indicates whether the customer requires large print format for printed communications due to visual impairment (ADA accommodation).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp when the communication preference record was last modified.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive promotional and marketing communications.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingOptInDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Date' ;
    rdfs:comment 'Date when the customer opted in to marketing communications.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outageAlertChannel rdf:type rdf:Property ;
    rdfs:label 'Outage Alert Channel' ;
    rdfs:comment 'Preferred channel for urgent service outage and restoration notifications.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paperlessBillingConsent rdf:type rdf:Property ;
    rdfs:label 'Paperless Billing Consent' ;
    rdfs:comment 'Indicates whether the customer has consented to receive bills electronically instead of paper mail.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentConfirmationChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Confirmation Channel' ;
    rdfs:comment 'Preferred channel for payment confirmation receipts and acknowledgments.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current status of the communication preference record (active, inactive, or suspended).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Channel' ;
    rdfs:comment 'Default channel for general customer communications (email, SMS, postal mail, phone, web portal, or mobile app).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'Primary language preference for all customer communications (English, Spanish, French, Chinese, Vietnamese, or other).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:robocallConsent rdf:type rdf:Property ;
    rdfs:label 'Robocall Consent' ;
    rdfs:comment 'Indicates whether the customer has consented to receive automated or pre-recorded voice calls.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:robocallConsentDate rdf:type rdf:Property ;
    rdfs:label 'Robocall Consent Date' ;
    rdfs:comment 'Date when the customer provided robocall consent.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceAppointmentChannel rdf:type rdf:Property ;
    rdfs:label 'Service Appointment Channel' ;
    rdfs:comment 'Preferred channel for service appointment confirmations, reminders, and technician arrival notifications.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsConsent rdf:type rdf:Property ;
    rdfs:label 'Sms Consent' ;
    rdfs:comment 'Indicates whether the customer has provided explicit consent to receive SMS text message communications.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smsConsentDate rdf:type rdf:Property ;
    rdfs:label 'Sms Consent Date' ;
    rdfs:comment 'Date when the customer provided SMS consent.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:smsOptOutDate rdf:type rdf:Property ;
    rdfs:label 'Sms Opt Out Date' ;
    rdfs:comment 'Date when the customer opted out of SMS text message communications.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ttyRequired rdf:type rdf:Property ;
    rdfs:label 'Tty Required' ;
    rdfs:comment 'Indicates whether the customer requires TTY/TDD (Text Telephone/Telecommunications Device for the Deaf) for phone communications (ADA accommodation).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updateSource rdf:type rdf:Property ;
    rdfs:label 'Update Source' ;
    rdfs:comment 'Channel or system through which the preference update was received (customer portal, mobile app, call center, mail, or system).' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'User ID or system identifier of the person or process that last updated the preference record.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistanceProgramId rdf:type rdf:Property ;
    rdfs:label 'Assistance Program Id' ;
    rdfs:comment 'Unique identifier for the customer_assistance_program data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssistanceProgram .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Whether program is active' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:administeringAgency rdf:type rdf:Property ;
    rdfs:label 'Administering Agency' ;
    rdfs:comment 'Agency administering the program' ;
    rdfs:domain ind:AssistanceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administeringDepartment rdf:type rdf:Property ;
    rdfs:label 'Administering Department' ;
    rdfs:domain ind:AssistanceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Budget' ;
    rdfs:comment 'Annual program budget' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'Annual budget allocated to this program' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Usd' ;
    rdfs:domain ind:AssistanceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationDeadline rdf:type rdf:Property ;
    rdfs:label 'Application Deadline' ;
    rdfs:comment 'Application deadline date' ;
    rdfs:domain ind:AssistanceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Application Deadline Date' ;
    rdfs:comment 'Application deadline' ;
    rdfs:domain ind:AssistanceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationRequired rdf:type rdf:Property ;
    rdfs:label 'Application Required' ;
    rdfs:comment 'Whether application is required' ;
    rdfs:domain ind:AssistanceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

