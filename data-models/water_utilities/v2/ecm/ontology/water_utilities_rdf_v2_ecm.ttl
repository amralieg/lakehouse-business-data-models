    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReportable rdf:type rdf:Property ;
    rdfs:label 'Is Reportable' ;
    rdfs:comment 'Whether the event is regulatorily reportable.' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overflowCause rdf:type rdf:Property ;
    rdfs:label 'Overflow Cause' ;
    rdfs:comment 'Root cause (BLOCKAGE, CAPACITY, EQUIPMENT_FAILURE, POWER_FAILURE, INFILTRATION, STORM)' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overflowEventNumber rdf:type rdf:Property ;
    rdfs:label 'Overflow Event Number' ;
    rdfs:comment 'Unique tracking number for the overflow event' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overflowLocation rdf:type rdf:Property ;
    rdfs:label 'Overflow Location' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overflowStatus rdf:type rdf:Property ;
    rdfs:label 'Overflow Status' ;
    rdfs:comment 'Current status (ACTIVE, CONTAINED, RESOLVED, REPORTED)' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overflowType rdf:type rdf:Property ;
    rdfs:label 'Overflow Type' ;
    rdfs:comment 'Type of overflow (SSO, CSO, BYPASS, BLENDING)' ;
