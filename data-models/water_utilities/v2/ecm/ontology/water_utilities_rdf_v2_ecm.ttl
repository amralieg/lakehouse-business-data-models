    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReported rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reported' ;
    rdfs:comment 'Whether the event has been reported to regulators' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportableFlag rdf:type rdf:Property ;
    rdfs:label 'Reportable Flag' ;
    rdfs:comment 'Whether the event is regulatorily reportable.' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedToAgencyFlag rdf:type rdf:Property ;
    rdfs:label 'Reported To Agency Flag' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingDeadline rdf:type rdf:Property ;
    rdfs:label 'Reporting Deadline' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Response Time Minutes' ;
    rdfs:comment 'Time in minutes from detection to crew arrival' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rootCauseAnalysisCompleted rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Completed' ;
    rdfs:comment 'Whether root cause analysis has been completed' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'start time for overflow_event' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:volumeRecoveredGallons rdf:type rdf:Property ;
    rdfs:label 'Volume Recovered Gallons' ;
    rdfs:comment 'Volume recovered.' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule Id' ;
    rdfs:comment 'Unique identifier for the compliance schedule record. Primary key.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceSchedule .

ind:actualTotalCost rdf:type rdf:Property ;
    rdfs:label 'Actual Total Cost' ;
    rdfs:comment 'Actual total cost incurred to date in executing the compliance schedule, including all capital and operating expenditures.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTotalCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Cost' ;
    rdfs:comment 'Estimated total cost to complete all milestones and achieve full compliance under this schedule, including capital expenditures (CAPEX) and operating expenditures (OPEX).' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extensionApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Extension Approval Date' ;
    rdfs:comment 'Date on which the regulatory authority formally approved the extension request.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Approved Flag' ;
    rdfs:comment 'Indicates whether the regulatory authority approved the requested extension to the compliance schedule.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionJustification rdf:type rdf:Property ;
    rdfs:label 'Extension Justification' ;
    rdfs:comment 'Detailed explanation or justification provided by the utility for requesting an extension to the compliance schedule, including any unforeseen circumstances, technical challenges, or resource constraints.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionRequestDate rdf:type rdf:Property ;
    rdfs:label 'Extension Request Date' ;
    rdfs:comment 'Date on which the utility submitted a formal request to extend the compliance schedule deadlines.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Requested Flag' ;
    rdfs:comment 'Indicates whether the utility has requested an extension to the compliance schedule deadlines.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalComplianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Final Compliance Deadline' ;
    rdfs:comment 'The ultimate deadline by which the utility must achieve full compliance with the regulatory requirement or permit condition. This is the final milestone in the schedule.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastStatusUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Status Update Date' ;
    rdfs:comment 'Date of the most recent status update or progress report submitted to the regulatory authority regarding the compliance schedule.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of milestones defined within this compliance schedule. Milestones are typically tracked in a separate related table.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Description' ;
    rdfs:comment 'Milestone description' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestonesCompletedCount rdf:type rdf:Property ;
    rdfs:label 'Milestones Completed Count' ;
    rdfs:comment 'Number of milestones that have been completed as of the current date. Used to track progress toward full compliance.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestonesOverdueCount rdf:type rdf:Property ;
    rdfs:label 'Milestones Overdue Count' ;
    rdfs:comment 'Number of milestones that are past their due date and have not been completed. Indicates potential non-compliance with the schedule.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextStatusUpdateDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Status Update Due Date' ;
    rdfs:comment 'Date by which the next status update or progress report is due to be submitted to the regulatory authority.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onScheduleFlag rdf:type rdf:Property ;
    rdfs:label 'On Schedule Flag' ;
    rdfs:comment 'Indicates whether the compliance schedule is currently on track to meet all milestone deadlines and the final compliance deadline. False if any milestones are overdue or at risk.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalFinalDeadline rdf:type rdf:Property ;
    rdfs:label 'Original Final Deadline' ;
    rdfs:comment 'The original final compliance deadline as initially agreed upon, preserved for audit and tracking purposes even if the schedule is later extended.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Overall Completion Percentage' ;
    rdfs:comment 'Percentage of the compliance schedule that has been completed, calculated as (milestones_completed_count / milestone_count) * 100. Provides a high-level progress indicator.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryCorrespondenceCount rdf:type rdf:Property ;
    rdfs:label 'Regulatory Correspondence Count' ;
    rdfs:comment 'Number of formal correspondence items (letters, emails, reports) exchanged between the utility and the regulatory authority regarding this compliance schedule.' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Schedule Description' ;
    rdfs:comment 'Detailed description of the compliance schedule, including the nature of the non-compliance, the corrective actions required, and the overall scope of work to achieve compliance.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule Status' ;
    rdfs:comment 'Status' ;
    rdfs:domain ind:ComplianceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentRegulatoryAgencyId rdf:type rdf:Property ;
    rdfs:label 'Parent Regulatory Agency Id' ;
    rdfs:comment 'Self-referencing FK on regulatory_agency (parent_regulatory_agency_id)' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAgency .

ind:parentRegulatoryAgencyIdLegacy rdf:type rdf:Property ;
    rdfs:label 'Parent Regulatory Agency Id Legacy' ;
    rdfs:comment 'Reference to the parent or umbrella agency if this agency is a regional office, division, or sub-agency (e.g., EPA Region 5 parent is EPA). Null if this is a top-level agency.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAgency .

ind:primaryLiaisonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Liaison Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Each regulatory agency relationship requires designated utility liaison for communication continuity, relationship management, and coordination of submissions and inspections. Links to employee for wo' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:additionalProgramsAdministered rdf:type rdf:Property ;
    rdfs:label 'Additional Programs Administered' ;
    rdfs:comment 'Comma-separated list of additional regulatory programs or statutes administered by this agency that apply to the utility (e.g., IUP, FOG, SSO, LCRR).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyAcronym rdf:type rdf:Property ;
    rdfs:label 'Agency Acronym' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyCode rdf:type rdf:Property ;
    rdfs:label 'Agency Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the regulatory agency within the utility\'s systems (e.g., EPA_R5, STATE_DNR, PUC_WI).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyLevel rdf:type rdf:Property ;
    rdfs:label 'Agency Level' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyMainEmail rdf:type rdf:Property ;
    rdfs:label 'Agency Main Email' ;
    rdfs:comment 'General inquiry or main email address for the regulatory agency.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyMainPhone rdf:type rdf:Property ;
    rdfs:label 'Agency Main Phone' ;
    rdfs:comment 'Main switchboard or general inquiry phone number for the regulatory agency.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Full legal name of the regulatory agency or governing body (e.g., U.S. Environmental Protection Agency Region 5, Wisconsin Department of Natural Resources).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyShortName rdf:type rdf:Property ;
    rdfs:label 'Agency Short Name' ;
    rdfs:comment 'Abbreviated or commonly used name for the agency (e.g., EPA Region 5, WI DNR, OSHA).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyStatus rdf:type rdf:Property ;
    rdfs:label 'Agency Status' ;
    rdfs:comment 'Current operational status of the regulatory agency (active, inactive, merged, dissolved).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Classification of the regulatory agency by its primary regulatory focus (environmental, health, safety, rate regulatory, labor, quality standards, other). [ENUM-REF-CANDIDATE: environmental|health|safety|rate_regulatory|labor|quality_standards|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Agency Website Url' ;
    rdfs:comment 'Official website URL for the regulatory agency.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessHours rdf:type rdf:Property ;
    rdfs:label 'Business Hours' ;
    rdfs:comment 'Standard business hours of operation for the regulatory agency office (e.g., Monday-Friday 8:00 AM - 5:00 PM PST).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Enforcement Authority Level' ;
    rdfs:comment 'Level of enforcement authority this agency holds over the utility (primary, delegated, advisory, none). Primary indicates direct enforcement power; delegated indicates authority granted by a higher-level agency; advisory indicates no direct enforcement.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euDirectiveScope rdf:type rdf:Property ;
    rdfs:label 'Eu Directive Scope' ;
    rdfs:comment 'Comma-separated list of EU directives this agency administers (DWD_2020_2184, REACH, WFD_2000_60, UWWTD_91_271).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euMemberState rdf:type rdf:Property ;
    rdfs:label 'Eu Member State' ;
    rdfs:comment 'For EU-region agencies, the EU member state code (e.g. DE, FR, NL). NULL for non-EU agencies.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euMemberStateCode rdf:type rdf:Property ;
    rdfs:label 'Eu Member State Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 code for EU member state where this agency has competent authority (e.g. DE, FR, NL). NULL for non-EU agencies.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for document submission to the regulatory agency, if applicable.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Months' ;
    rdfs:comment 'Typical frequency in months at which this regulatory agency conducts inspections of utility facilities under its jurisdiction.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionFrequencyTypical rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Typical' ;
    rdfs:comment 'Typical frequency at which this agency conducts inspections or audits of utility facilities (annual, biennial, triennial, as-needed, risk-based).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internationalAgencyFlag rdf:type rdf:Property ;
    rdfs:label 'International Agency Flag' ;
    rdfs:comment 'True for non-US (EU/FR/UK/DE) regulatory agencies.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionGeographicArea rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Geographic Area' ;
    rdfs:comment 'Geographic area or service territory over which the agency has regulatory authority (e.g., EPA Region 5 covers IL, IN, MI, MN, OH, WI; or specific county/municipality names).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'The governmental level at which the agency operates (federal, state, regional, local, international).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDeadlineHours rdf:type rdf:Property ;
    rdfs:label 'Notification Deadline Hours' ;
    rdfs:comment 'Standard number of hours within which the utility must notify this agency of reportable incidents or violations (e.g., 24 hours for SSO events).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npdesAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Npdes Authority Flag' ;
    rdfs:comment 'Indicates whether this agency has authority to issue and enforce NPDES permits under the Clean Water Act. True if authorized, False otherwise.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pretreatmentAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Pretreatment Authority Flag' ;
    rdfs:comment 'Indicates whether this agency has authority to oversee industrial pretreatment programs. True if authorized, False otherwise.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primacyAgencyFlag rdf:type rdf:Property ;
    rdfs:label 'Primacy Agency Flag' ;
    rdfs:comment 'Indicates whether this agency has primacy authority for Safe Drinking Water Act (SDWA) enforcement in its jurisdiction. True if primacy agency, False otherwise.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primacyStatus rdf:type rdf:Property ;
    rdfs:label 'Primacy Status' ;
    rdfs:comment 'Indicates whether this agency is a primacy agency under the Safe Drinking Water Act (SDWA) or Clean Water Act (CWA), meaning it has been delegated primary enforcement authority by EPA (primacy_agency, non_primacy, not_applicable).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProgram rdf:type rdf:Property ;
    rdfs:label 'Primary Program' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRegulatoryProgram rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Program' ;
    rdfs:comment 'The main regulatory program or statute administered by this agency relevant to water utilities (e.g., SDWA, CWA, NPDES, OSHA, Rate Regulation).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequencyDefault rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency Default' ;
    rdfs:comment 'Default or most common reporting frequency required by this agency for compliance reports (monthly, quarterly, semi-annual, annual, event-driven, as-required).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingSystemName rdf:type rdf:Property ;
    rdfs:label 'Reporting System Name' ;
    rdfs:comment 'Name of the electronic reporting system used by the agency (e.g., NetDMR, SDWIS, state-specific portal).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionCredentialsReference rdf:type rdf:Property ;
    rdfs:label 'Submission Credentials Reference' ;
    rdfs:comment 'Reference identifier or location for stored login credentials or API keys used to access the agency\'s submission portal. Should reference a secure credential vault, not store actual credentials.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionPortalName rdf:type rdf:Property ;
    rdfs:label 'Submission Portal Name' ;
    rdfs:comment 'Name of the online submission portal or system (e.g., NetDMR, State Environmental Portal, OSHA Injury Tracking Application).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionPortalUrl rdf:type rdf:Property ;
    rdfs:label 'Submission Portal Url' ;
    rdfs:comment 'URL for the online portal or system used to submit compliance reports, permits, or other regulatory documents to this agency (e.g., NetDMR, state e-reporting system).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitVendorServiceId rdf:type rdf:Property ;
    rdfs:label 'Permit Vendor Service Id' ;
    rdfs:comment 'Primary key.' ;
    rdfs:domain ind:PermitVendorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountSpent rdf:type rdf:Property ;
    rdfs:label 'Amount Spent' ;
    rdfs:comment 'Amount spent to date.' ;
    rdfs:domain ind:PermitVendorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractAmount rdf:type rdf:Property ;
    rdfs:label 'Contract Amount' ;
