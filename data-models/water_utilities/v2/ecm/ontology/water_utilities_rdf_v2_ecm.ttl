ind:amountRefunded rdf:type rdf:Property ;
    rdfs:label 'Amount Refunded' ;
    rdfs:domain ind:Deposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountRefundedUsd rdf:type rdf:Property ;
    rdfs:label 'Amount Refunded Usd' ;
    rdfs:domain ind:Deposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountUsd rdf:type rdf:Property ;
    rdfs:label 'Amount Usd' ;
    rdfs:domain ind:Deposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'Amount applied to balance' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedToBalanceDate rdf:type rdf:Property ;
    rdfs:label 'Applied To Balance Date' ;
    rdfs:comment 'Date applied to account balance' ;
    rdfs:domain ind:Deposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appliedToBalanceFlag rdf:type rdf:Property ;
    rdfs:label 'Applied To Balance Flag' ;
    rdfs:comment 'Applied to balance flag' ;
    rdfs:domain ind:Deposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Check number if paid by check' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectedDate rdf:type rdf:Property ;
    rdfs:label 'Collected Date' ;
    rdfs:domain ind:Deposit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditScoreAtDeposit rdf:type rdf:Property ;
    rdfs:label 'Credit Score At Deposit' ;
    rdfs:comment 'Credit score at time of deposit' ;
    rdfs:domain ind:Deposit ;
    rdf:type owl:DatatypeProperty ;
