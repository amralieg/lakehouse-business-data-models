    rdfs:range xsd:string .

ind:leakDescription rdf:type rdf:Property ;
    rdfs:label 'Leak Description' ;
    rdfs:comment 'Detailed description of any leak detected during the inspection, including location, severity, and estimated flow rate if observable.' ;
    rdfs:domain ind:MeterFieldInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterConditionRating rdf:type rdf:Property ;
    rdfs:label 'Meter Condition Rating' ;
    rdfs:comment 'Overall condition assessment of the meter based on visual inspection: excellent, good, fair, poor, or failed. Used for asset health scoring and replacement prioritization.' ;
    rdfs:domain ind:MeterFieldInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obstructionDescription rdf:type rdf:Property ;
    rdfs:label 'Obstruction Description' ;
    rdfs:comment 'Detailed description of any obstructions noted during the inspection that prevent or hinder meter access.' ;
    rdfs:domain ind:MeterFieldInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obstructionNotedFlag rdf:type rdf:Property ;
    rdfs:label 'Obstruction Noted Flag' ;
    rdfs:comment 'Indicates whether any obstructions were noted that prevent or hinder access to the meter installation, such as landscaping, vehicles, structures, or locked gates.' ;
    rdfs:domain ind:MeterFieldInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoCount rdf:type rdf:Property ;
    rdfs:label 'Photo Count' ;
    rdfs:comment 'Number of photographs captured during the field inspection for documentation and evidence purposes.' ;
    rdfs:domain ind:MeterFieldInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:photoEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Reference' ;
    rdfs:comment 'Reference identifier or file path to photographic evidence captured during the field inspection, stored in the document management system.' ;
    rdfs:domain ind:MeterFieldInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitDebrisPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Pit Debris Present Flag' ;
    rdfs:comment 'Indicates whether debris, sediment, or foreign objects are present in the meter pit or vault that may interfere with meter operation or access.' ;
    rdfs:domain ind:MeterFieldInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pitVaultCondition rdf:type rdf:Property ;
    rdfs:label 'Pit Vault Condition' ;
    rdfs:comment 'Condition assessment of the meter pit or vault: excellent, good, fair, poor, or hazardous. Includes evaluation of structural integrity, water intrusion, and safety hazards.' ;
    rdfs:domain ind:MeterFieldInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitWaterPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Pit Water Present Flag' ;
    rdfs:comment 'Indicates whether standing water is present in the meter pit or vault, which may indicate drainage issues, leaks, or groundwater infiltration.' ;
    rdfs:domain ind:MeterFieldInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registerReadableFlag rdf:type rdf:Property ;
    rdfs:label 'Register Readable Flag' ;
    rdfs:comment 'Indicates whether the meter register is readable and visible during the inspection. False may indicate fogging, damage, or obstruction.' ;
    rdfs:domain ind:MeterFieldInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Indicates whether the meter seal is intact and unbroken. False indicates potential tampering or unauthorized access requiring investigation.' ;
    rdfs:domain ind:MeterFieldInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealNumberVerified rdf:type rdf:Property ;
    rdfs:label 'Seal Number Verified' ;
    rdfs:comment 'Seal number observed during the inspection, used to verify against the installation record and detect unauthorized seal replacement.' ;
    rdfs:domain ind:MeterFieldInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tamperEvidenceFlag rdf:type rdf:Property ;
    rdfs:label 'Tamper Evidence Flag' ;
    rdfs:comment 'Indicates whether evidence of tampering was observed during the inspection, such as broken seals, unauthorized modifications, bypass piping, or meter reversal.' ;
    rdfs:domain ind:MeterFieldInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amiAssetRegistryId rdf:type rdf:Property ;
    rdfs:label 'Ami Asset Registry Id' ;
    rdfs:comment 'Reference to the asset registry entry for this collector device in the CMMS (IBM Maximo). Links AMI network data to enterprise asset management for maintenance scheduling, depreciation, and lifecycle tracking.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:amiRegistryId rdf:type rdf:Property ;
    rdfs:label 'Ami Registry Id' ;
    rdfs:comment 'Reference to the asset registry entry for this collector device in the CMMS (IBM Maximo). Links AMI network data to enterprise asset management for maintenance scheduling, depreciation, and lifecycle tracking.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:installationWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Installation Work Order Id' ;
    rdfs:comment 'Reference to the work order that authorized and documented the installation of this collector device. Used for audit trail and cost tracking.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:backhaulConnectionType rdf:type rdf:Property ;
    rdfs:label 'Backhaul Connection Type' ;
    rdfs:comment 'Type of wide-area network connection used to transmit collected meter data from the collector to the central AMI head-end system. Cellular and fiber are most common for fixed base stations.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backhaulProvider rdf:type rdf:Property ;
    rdfs:label 'Backhaul Provider' ;
    rdfs:comment 'Name of the telecommunications carrier or internet service provider supplying the backhaul connection for this collector. Used for vendor management and service level agreement tracking.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batteryBackupFlag rdf:type rdf:Property ;
    rdfs:label 'Battery Backup Flag' ;
    rdfs:comment 'Indicates whether the collector device has battery backup power to maintain operation during AC power outages. True if battery backup is installed and functional.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectorIdentifier rdf:type rdf:Property ;
    rdfs:label 'Collector Identifier' ;
    rdfs:comment 'Externally-known unique identifier or serial number assigned to the collector device by the manufacturer or utility. Used for field operations and inventory tracking.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectorType rdf:type rdf:Property ;
    rdfs:label 'Collector Type' ;
    rdfs:comment 'Classification of the collector device based on its deployment mode and function within the AMI network topology. Fixed base stations are permanently installed, mobile collectors are vehicle-mounted for drive-by reading, and repeaters extend network coverage.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageRadiusMiles rdf:type rdf:Property ;
    rdfs:label 'Coverage Radius Miles' ;
    rdfs:comment 'Estimated radio frequency coverage radius in miles for the collector device. Defines the geographic area within which AMI endpoints can communicate with this collector. Used for network planning and coverage gap analysis.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endpointCapacity rdf:type rdf:Property ;
    rdfs:label 'Endpoint Capacity' ;
    rdfs:comment 'Maximum number of AMI endpoints that this collector device can support based on manufacturer specifications and network design. Used for capacity planning and network expansion.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endpointCount rdf:type rdf:Property ;
    rdfs:label 'Endpoint Count' ;
    rdfs:comment 'Current number of AMI endpoints (meters) actively registered and communicating through this collector. Used for load balancing and capacity planning.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firmwareUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Firmware Update Date' ;
    rdfs:comment 'Date when the collector firmware was last updated. Used for tracking patch compliance and planning future updates.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frequencyMhz rdf:type rdf:Property ;
    rdfs:label 'Frequency Mhz' ;
    rdfs:comment 'Radio frequency in megahertz on which the collector operates. Common frequencies include 900 MHz and 450 MHz bands. Critical for regulatory compliance and interference management.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthStatus rdf:type rdf:Property ;
    rdfs:label 'Health Status' ;
    rdfs:comment 'Overall health assessment of the collector device based on communication frequency, signal quality, error rates, and diagnostic metrics. Healthy indicates normal operation; degraded indicates performance issues; critical indicates imminent failure risk; offline indicates no communication.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Installation Timestamp' ;
    rdfs:comment 'Precise timestamp when the collector device was activated and began communicating with the AMI network. Provides exact commissioning time for audit and troubleshooting purposes.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:physicalAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Physical Address Line1' ;
    rdfs:comment 'Primary street address line where the collector device is physically installed. Used for field service dispatch and asset location management.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Physical Address Line2' ;
    rdfs:comment 'Secondary address line for additional location details such as building, suite, or tower designation.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerSource rdf:type rdf:Property ;
    rdfs:label 'Power Source' ;
    rdfs:comment 'Primary power source for the collector device. AC mains is typical for fixed base stations; solar and battery are used for remote or mobile installations.' ;
    rdfs:domain ind:AmiNetworkCollector ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryReplacementMeterSizeTypeId rdf:type rdf:Property ;
    rdfs:label 'Primary Replacement Meter Size Type Id' ;
    rdfs:comment 'Reference to the successor meter size and type that replaces this obsolete configuration. Null if no replacement defined.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeterSizeType .

ind:accuracyPercentageLowFlow rdf:type rdf:Property ;
    rdfs:label 'Accuracy Percentage Low Flow' ;
    rdfs:comment 'Expected measurement accuracy as a percentage at the minimum detectable flow rate. Critical for NRW analysis.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accuracyPercentageNormalFlow rdf:type rdf:Property ;
    rdfs:label 'Accuracy Percentage Normal Flow' ;
    rdfs:comment 'Expected measurement accuracy as a percentage at normal operating flow rate.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amiCompatibleFlag rdf:type rdf:Property ;
    rdfs:label 'Ami Compatible Flag' ;
    rdfs:comment 'Indicates whether this meter size and type can be equipped with AMI endpoints for remote reading and interval data collection.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amrCompatibleFlag rdf:type rdf:Property ;
    rdfs:label 'Amr Compatible Flag' ;
    rdfs:comment 'Indicates whether this meter size and type can be equipped with AMR endpoints for drive-by or walk-by reading.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageUnitCostUsd rdf:type rdf:Property ;
    rdfs:label 'Average Unit Cost Usd' ;
    rdfs:comment 'Average procurement cost in United States Dollars (USD) for a meter of this size including hardware but excluding installation labor. Used for budgeting and capital planning.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awwaStandardCode rdf:type rdf:Property ;
    rdfs:label 'Awwa Standard Code' ;
    rdfs:comment 'Applicable AWWA standard governing this meter size and type (e.g., C700, C701, C702, C706, C708, C710, C713).' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterSizeTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Meter Size Type Description' ;
    rdfs:comment 'Detailed description of the meter size type including typical applications, customer classes, and usage characteristics (e.g., \'Standard residential meter for single-family homes\').' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayName rdf:type rdf:Property ;
    rdfs:label 'Display Name' ;
    rdfs:comment 'Human-readable display name for the meter size (e.g., \'5/8 inch\', \'3/4 inch\', \'1 inch\', \'2 inch\'). Used in user interfaces, reports, and customer communications.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedServiceLifeYears rdf:type rdf:Property ;
    rdfs:label 'Expected Service Life Years' ;
    rdfs:comment 'Typical operational lifespan in years before meter replacement is recommended due to accuracy degradation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flangeStandard rdf:type rdf:Property ;
    rdfs:label 'Flange Standard' ;
    rdfs:comment 'Flange specification for flanged connections (e.g., ANSI Class 125, ANSI Class 250). Applicable to larger meter sizes requiring bolted connections.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationLaborHours rdf:type rdf:Property ;
    rdfs:label 'Installation Labor Hours' ;
    rdfs:comment 'Typical labor hours required to install or replace a meter of this size. Used for work order planning, crew scheduling, and cost estimation.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installationOrientation rdf:type rdf:Property ;
    rdfs:label 'Installation Orientation' ;
    rdfs:comment 'Required or recommended installation orientation for accurate measurement (horizontal, vertical, or any orientation).' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadFreeCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Lead Free Certified Flag' ;
    rdfs:comment 'Indicates whether this meter size and type meets lead-free certification requirements under the Safe Drinking Water Act and LCRR.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lengthInches rdf:type rdf:Property ;
    rdfs:label 'Length Inches' ;
    rdfs:comment 'Overall length of the meter body in inches. Critical for vault and pit sizing during installation.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxContinuousFlowGpm rdf:type rdf:Property ;
    rdfs:label 'Max Continuous Flow Gpm' ;
    rdfs:comment 'Maximum flow rate in gallons per minute that the meter can sustain continuously without damage or accuracy degradation.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxRegisteredFlowGpm rdf:type rdf:Property ;
    rdfs:label 'Max Registered Flow Gpm' ;
    rdfs:comment 'Peak flow rate in gallons per minute that the meter can register accurately for short durations.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Maximum Flow Rate Gpm' ;
    rdfs:comment 'Maximum continuous flow rate in gallons per minute (GPM) for meters of this size. Defines the upper capacity limit for safe and accurate operation.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumIntermittentFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Maximum Intermittent Flow Rate Gpm' ;
    rdfs:comment 'Maximum short-duration or peak flow rate in gallons per minute (GPM) that the meter can handle without damage. Used for surge and peak demand scenarios.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementClass rdf:type rdf:Property ;
    rdfs:label 'Measurement Class' ;
    rdfs:comment 'AWWA accuracy classification (Class I through Class IV). Higher classes indicate greater accuracy at low flow rates.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterSizeTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Meter Size Type Status' ;
    rdfs:comment 'Current lifecycle status of this meter size type in the reference catalog (active, inactive, obsolete, pending approval). Controls availability for new installations.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minDetectableFlowGpm rdf:type rdf:Property ;
    rdfs:label 'Min Detectable Flow Gpm' ;
    rdfs:comment 'Lowest flow rate in gallons per minute that the meter can detect and register. Critical for leak detection and low-flow accuracy.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Minimum Flow Rate Gpm' ;
    rdfs:comment 'Minimum measurable flow rate in gallons per minute (GPM) for meters of this size. Defines the lower accuracy threshold for consumption measurement.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:normalOperatingFlowGpm rdf:type rdf:Property ;
    rdfs:label 'Normal Operating Flow Gpm' ;
    rdfs:comment 'Typical sustained flow rate in gallons per minute for which the meter is optimally designed. Used for meter sizing and selection.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:normalOperatingFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Normal Operating Flow Rate Gpm' ;
    rdfs:comment 'Typical or recommended operating flow rate in gallons per minute (GPM) for optimal meter accuracy and longevity. Used for sizing and capacity planning.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsf61CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Nsf 61 Certified Flag' ;
    rdfs:comment 'Indicates whether this meter is certified to NSF/ANSI Standard 61 for drinking water system components.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:obsoleteDate rdf:type rdf:Property ;
    rdfs:label 'Obsolete Date' ;
    rdfs:comment 'Date when this meter size and type was discontinued or phased out for new installations. Null if still active.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pressureLossAtMaxFlowPsi rdf:type rdf:Property ;
    rdfs:label 'Pressure Loss At Max Flow Psi' ;
    rdfs:comment 'Expected pressure loss in pounds per square inch (PSI) across the meter at maximum continuous flow rate. Critical for hydraulic modeling and system pressure management.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registerCapacityGallons rdf:type rdf:Property ;
    rdfs:label 'Register Capacity Gallons' ;
    rdfs:comment 'Maximum cumulative volume in gallons that the meter register can display before rolling over. Important for billing cycle planning and register overflow detection.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceConnectionType rdf:type rdf:Property ;
    rdfs:label 'Service Connection Type' ;
    rdfs:comment 'Standard connection method for installing this meter size (threaded, flanged, or compression fitting).' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeCode rdf:type rdf:Property ;
    rdfs:label 'Size Code' ;
    rdfs:comment 'Short alphanumeric code representing the meter size (e.g., 5/8, 3/4, 1, 1.5, 2, 3, 4, 6, 8, 10, 12). Used as a lookup key in operational systems.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeMillimeters rdf:type rdf:Property ;
    rdfs:label 'Size Millimeters' ;
    rdfs:comment 'Nominal diameter of the meter in millimeters (e.g., 15mm, 20mm, 25mm, 40mm, 50mm, etc.). Used for international standards compliance and metric system reporting.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric value controlling the display sequence of meter sizes in user interfaces and reports (typically ordered from smallest to largest).' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:straightPipeDownstreamInches rdf:type rdf:Property ;
    rdfs:label 'Straight Pipe Downstream Inches' ;
    rdfs:comment 'Minimum length of straight pipe required downstream of the meter in inches to ensure accurate flow measurement.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:straightPipeUpstreamInches rdf:type rdf:Property ;
    rdfs:label 'Straight Pipe Upstream Inches' ;
    rdfs:comment 'Minimum length of straight pipe required upstream of the meter in inches to ensure accurate flow measurement.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureRatingFahrenheitMax rdf:type rdf:Property ;
    rdfs:label 'Temperature Rating Fahrenheit Max' ;
    rdfs:comment 'Maximum water temperature in Fahrenheit at which the meter maintains accuracy and structural integrity.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureRatingFahrenheitMin rdf:type rdf:Property ;
    rdfs:label 'Temperature Rating Fahrenheit Min' ;
    rdfs:comment 'Minimum water temperature in Fahrenheit at which the meter maintains accuracy and structural integrity.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testingFrequencyYears rdf:type rdf:Property ;
    rdfs:label 'Testing Frequency Years' ;
    rdfs:comment 'Recommended interval in years between accuracy testing and calibration per regulatory and utility standards.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:threadStandard rdf:type rdf:Property ;
    rdfs:label 'Thread Standard' ;
    rdfs:comment 'Thread specification for threaded connections (e.g., NPT, BSPT, AWWA). Ensures compatibility with service line fittings and meter setters.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalApplication rdf:type rdf:Property ;
    rdfs:label 'Typical Application' ;
    rdfs:comment 'Standard use case for this meter size and type (e.g., single-family residential, multi-family residential, commercial, industrial, fire service, irrigation).' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalCustomerClass rdf:type rdf:Property ;
    rdfs:label 'Typical Customer Class' ;
    rdfs:comment 'Primary customer class typically served by this meter size (residential, commercial, industrial, institutional, agricultural, municipal). Used for rate structure and billing configuration.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalServiceLifeYears rdf:type rdf:Property ;
    rdfs:label 'Typical Service Life Years' ;
    rdfs:comment 'Expected operational service life in years for meters of this size under normal operating conditions. Used for asset replacement planning and depreciation schedules.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightPounds rdf:type rdf:Property ;
    rdfs:label 'Weight Pounds' ;
    rdfs:comment 'Approximate weight of the meter in pounds. Used for logistics, installation planning, and safety assessments.' ;
    rdfs:domain ind:MeterSizeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endpointProcurementId rdf:type rdf:Property ;
    rdfs:label 'Endpoint Procurement Id' ;
    rdfs:comment 'Primary key for the endpoint_procurement association' ;
    rdfs:domain ind:EndpointProcurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'FK to goods receipt' ;
