ind:methodDetectionLimitId rdf:type rdf:Property ;
    rdfs:label 'Method Detection Limit Id' ;
    rdfs:comment 'Unique identifier for the method detection limit study record. Primary key.' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:DatatypeProperty ;
