ind:quantitationLimitPpt rdf:type rdf:Property ;
    rdfs:label 'Quantitation Limit Ppt' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryFrameworkReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework Reference' ;
    rdfs:comment 'Specific regulatory citation (e.g. US: 40 CFR 141.61, EU: DWD 2020/2184 Annex I Part B, REACH Annex XVII restriction).' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRegionCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Region Code' ;
    rdfs:comment 'ISO region code identifying the jurisdiction for this PFAS monitoring event (US, EU, OTHER). US uses per-compound MCLs + hazard index; EU uses sum-of-20 PFAS + total PFAS class restriction per DWD 2020/2184.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingLimitNgL rdf:type rdf:Property ;
    rdfs:label 'Reporting Limit Ng L' ;
    rdfs:comment 'Practical quantitation/reporting limit for the PFAS compound in ng/L.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingLimitPpt rdf:type rdf:Property ;
    rdfs:label 'Reporting Limit Ppt' ;
    rdfs:comment 'Reporting limit in ppt' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultValueNgL rdf:type rdf:Property ;
    rdfs:label 'Result Value Ng L' ;
    rdfs:comment 'Measured concentration of the PFAS compound in nanograms per liter.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultValuePpt rdf:type rdf:Property ;
    rdfs:label 'Result Value Ppt' ;
    rdfs:comment 'Result value in parts per trillion' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentResponseTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Treatment Response Trigger Flag' ;
    rdfs:comment 'True if result triggers a treatment response action (e.g. GAC replacement, IX regeneration).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentResponseTriggered rdf:type rdf:Property ;
    rdfs:label 'Treatment Response Triggered' ;
    rdfs:comment 'Whether a treatment response was triggered.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentResponseType rdf:type rdf:Property ;
    rdfs:label 'Treatment Response Type' ;
    rdfs:comment 'Type of treatment response triggered (GAC_REPLACEMENT, IX_REGENERATION, BLENDING, SHUTDOWN).' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentTechnology rdf:type rdf:Property ;
    rdfs:label 'Treatment Technology' ;
    rdfs:comment 'PFAS treatment technology in use at the sampling point (GAC, IX, RO, NANOFILTRATION).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usCompoundMclStatus rdf:type rdf:Property ;
    rdfs:label 'Us Compound Mcl Status' ;
    rdfs:comment 'Per-compound MCL compliance status for US EPA individual PFAS MCLs (PFOA 4ppt, PFOS 4ppt, PFNA, PFHxS, PFBS, HFPO-DA). Values: COMPLIANT, EXCEEDS_MCL, PENDING. NULL for non-US jurisdictions.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usHazardIndex rdf:type rdf:Property ;
    rdfs:label 'Us Hazard Index' ;
    rdfs:comment 'US hazard index for PFNA+PFHxS+PFBS+HFPO-DA (per-compound MCL framework).' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usHazardIndexComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Us Hazard Index Compliance Flag' ;
    rdfs:comment 'TRUE if the US hazard index value is at or below 1.0 (compliant); FALSE if exceeding threshold. NULL for EU jurisdiction.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usHazardIndexCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Us Hazard Index Compliant Flag' ;
    rdfs:comment 'Whether the US hazard index value is at or below the MCL of 1.0. TRUE = compliant, FALSE = exceedance.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usHazardIndexValue rdf:type rdf:Property ;
    rdfs:label 'Us Hazard Index Value' ;
    rdfs:comment 'US EPA NPDWR hazard index calculation for mixture of PFNA, PFHxS, PFBS, and HFPO-DA (GenX). MCL is hazard index <= 1.0. NULL for EU-only monitoring.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usPerCompoundMclBasisFlag rdf:type rdf:Property ;
    rdfs:label 'Us Per Compound Mcl Basis Flag' ;
    rdfs:comment 'TRUE when evaluated under US per-compound MCL / hazard-index framework.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usReferencePath rdf:type rdf:Property ;
    rdfs:label 'Us Reference Path' ;
    rdfs:comment 'US reference path: EPA/AWWA/NPDWR/UCMR/NPDES citation chain.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyticalTestId rdf:type rdf:Property ;
    rdfs:label 'Analytical Test Id' ;
    rdfs:comment 'Unique identifier linking the turbidity reading to a laboratory analysis record in the Laboratory Information Management System (LIMS), if the reading was obtained through laboratory testing.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnalyticalTest .

ind:turbidityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Turbidity Employee Id' ;
    rdfs:comment 'Unique identifier of the certified water treatment plant operator or laboratory technician who collected or validated the turbidity reading.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:turbidityFacilityId rdf:type rdf:Property ;
    rdfs:label 'Turbidity Facility Id' ;
    rdfs:comment 'Unique identifier of the Water Treatment Plant where the turbidity measurement was recorded.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:turbidityOperatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Turbidity Operator Employee Id' ;
    rdfs:comment 'Unique identifier of the certified water treatment plant operator or laboratory technician who collected or validated the turbidity reading.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:turbidityWtpFacilityId rdf:type rdf:Property ;
    rdfs:label 'Turbidity Wtp Facility Id' ;
    rdfs:comment 'Unique identifier of the Water Treatment Plant where the turbidity measurement was recorded.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:alarmThresholdNtu rdf:type rdf:Property ;
    rdfs:label 'Alarm Threshold Ntu' ;
    rdfs:comment 'The turbidity threshold value in NTU configured in the SCADA system that triggers an operational alarm when exceeded.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calibration Timestamp' ;
    rdfs:comment 'Date and time of the most recent calibration performed on the turbidity instrument prior to this reading.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctComplianceContext rdf:type rdf:Property ;
    rdfs:label 'Ct Compliance Context' ;
    rdfs:comment 'Contextual information linking the turbidity reading to disinfection Contact Time (CT) compliance calculations, indicating whether the reading impacts CT credit eligibility under the Surface Water Treatment Rule.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityCode rdf:type rdf:Property ;
    rdfs:label 'Data Quality Code' ;
    rdfs:comment 'Code indicating the quality and reliability of the turbidity reading, including flags for suspect data, instrument faults, calibration status, or manual overrides.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'The source system from which the turbidity reading was ingested into the lakehouse: OSIsoft PI Historian, LIMS, manual entry, or direct SCADA feed.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filterUnitNumber rdf:type rdf:Property ;
    rdfs:label 'Filter Unit Number' ;
    rdfs:comment 'Identifier of the specific filter unit at the Water Treatment Plant (WTP) from which the turbidity reading was captured. Applicable for Individual Filter Effluent (IFE) measurements.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowRateMgd rdf:type rdf:Property ;
    rdfs:label 'Flow Rate Mgd' ;
    rdfs:comment 'The flow rate through the filter or treatment process at the time of the turbidity measurement, expressed in Million Gallons per Day (MGD).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementLocationType rdf:type rdf:Property ;
    rdfs:label 'Measurement Location Type' ;
    rdfs:comment 'Designation of where in the treatment process the turbidity measurement was taken: Individual Filter Effluent (IFE), Combined Filter Effluent (CFE), distribution system entry point, raw water intake, settled water, or filtered water.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryLimitNtu rdf:type rdf:Property ;
    rdfs:label 'Regulatory Limit Ntu' ;
    rdfs:comment 'The applicable regulatory turbidity limit in NTU for the measurement location and context, as defined by the Surface Water Treatment Rule or state primacy agency requirements.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The regulatory reporting period (e.g., monthly, quarterly) to which this turbidity reading applies for compliance reporting purposes.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turbidityValueNtu rdf:type rdf:Property ;
    rdfs:label 'Turbidity Value Ntu' ;
    rdfs:comment 'The measured turbidity value expressed in Nephelometric Turbidity Units (NTU), representing the cloudiness or haziness of the water sample.' ;
    rdfs:domain ind:TurbidityReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctCalculationId rdf:type rdf:Property ;
    rdfs:label 'Ct Calculation Id' ;
    rdfs:comment 'Unique identifier for the CT calculation record. Primary key.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ctEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Ct Employee Id' ;
    rdfs:comment 'Foreign key reference to the certified water treatment plant operator who reviewed or validated the CT calculation.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ctFacilityId rdf:type rdf:Property ;
    rdfs:label 'Ct Facility Id' ;
    rdfs:comment 'Foreign key reference to the water treatment plant where this CT calculation was performed.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:ctOperatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Ct Operator Employee Id' ;
    rdfs:comment 'Foreign key reference to the certified water treatment plant operator who reviewed or validated the CT calculation.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ctWtpFacilityId rdf:type rdf:Property ;
    rdfs:label 'Ct Wtp Facility Id' ;
    rdfs:comment 'Foreign key reference to the water treatment plant where this CT calculation was performed.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:calculatedCtValueMgMinL rdf:type rdf:Property ;
    rdfs:label 'Calculated Ct Value Mg Min L' ;
    rdfs:comment 'Calculated CT value (C × T) in mg·min/L. This is the achieved disinfection contact time value.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contactChamberVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Contact Chamber Volume Gallons' ;
    rdfs:comment 'Volume of the disinfection contact chamber in gallons. Used in conjunction with flow rate to calculate contact time (T).' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contactTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Contact Time Minutes' ;
    rdfs:comment 'Measured or calculated contact time (T) in minutes that water is exposed to the disinfectant. This is the \'T\' component of the CT calculation. Typically calculated as T10 (time for 10% of water to pass through the contact chamber).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctRatioGiardia rdf:type rdf:Property ;
    rdfs:label 'Ct Ratio Giardia' ;
    rdfs:comment 'Ratio of achieved CT to required CT for Giardia inactivation (calculated_ct_value / required_ct_giardia_3log). Must be ≥ 1.0 for compliance.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctRatioVirus rdf:type rdf:Property ;
    rdfs:label 'Ct Ratio Virus' ;
    rdfs:comment 'Ratio of achieved CT to required CT for virus inactivation (calculated_ct_value / required_ct_virus_4log). Must be ≥ 1.0 for compliance.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disinfectantResidualConcentrationMgL rdf:type rdf:Property ;
    rdfs:label 'Disinfectant Residual Concentration Mg L' ;
    rdfs:comment 'Measured disinfectant residual concentration (C) in mg/L at the point of measurement. This is the \'C\' component of the CT calculation.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:logInactivationGiardia rdf:type rdf:Property ;
    rdfs:label 'Log Inactivation Giardia' ;
    rdfs:comment 'Calculated log inactivation credit achieved for Giardia based on the CT ratio. Minimum 3-log required by SWTR.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:logInactivationVirus rdf:type rdf:Property ;
    rdfs:label 'Log Inactivation Virus' ;
    rdfs:comment 'Calculated log inactivation credit achieved for viruses based on the CT ratio. Minimum 4-log required by SWTR.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:morReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Mor Reporting Period' ;
    rdfs:comment 'Monthly Operating Report period to which this CT calculation applies, in YYYY-MM format. Used for regulatory reporting aggregation.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCtGiardia3logMgMinL rdf:type rdf:Property ;
    rdfs:label 'Required Ct Giardia 3log Mg Min L' ;
    rdfs:comment 'Required CT value for achieving 3-log (99.9%) inactivation of Giardia lamblia cysts, based on EPA CT tables considering water temperature, pH, and disinfectant type.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredCtVirus4logMgMinL rdf:type rdf:Property ;
    rdfs:label 'Required Ct Virus 4log Mg Min L' ;
    rdfs:comment 'Required CT value for achieving 4-log (99.99%) inactivation of viruses, based on EPA CT tables considering water temperature, pH, and disinfectant type.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scadaTagFlow rdf:type rdf:Property ;
    rdfs:label 'Scada Tag Flow' ;
    rdfs:comment 'SCADA tag identifier in OSIsoft PI Historian for the flow rate measurement point.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaTagPh rdf:type rdf:Property ;
    rdfs:label 'Scada Tag Ph' ;
    rdfs:comment 'SCADA tag identifier in OSIsoft PI Historian for the pH measurement point.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaTagResidual rdf:type rdf:Property ;
    rdfs:label 'Scada Tag Residual' ;
    rdfs:comment 'SCADA tag identifier in OSIsoft PI Historian for the disinfectant residual concentration measurement point.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaTagTemperature rdf:type rdf:Property ;
    rdfs:label 'Scada Tag Temperature' ;
    rdfs:comment 'SCADA tag identifier in OSIsoft PI Historian for the water temperature measurement point.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:t10Factor rdf:type rdf:Property ;
    rdfs:label 'T10 Factor' ;
    rdfs:comment 'T10 factor representing the ratio of T10 (time for 10% of water to pass through) to theoretical detention time. Typically determined through tracer studies. Used to calculate effective contact time.' ;
    rdfs:domain ind:CtCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualChlorineReadingId rdf:type rdf:Property ;
    rdfs:label 'Residual Chlorine Reading Id' ;
    rdfs:comment 'Unique identifier for the residual chlorine reading record.' ;
    rdfs:domain ind:ResidualChlorineReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Residual Employee Id' ;
    rdfs:comment 'Identifier of the certified water treatment or distribution operator who collected the manual field reading. Required for regulatory compliance and data quality assurance.' ;
    rdfs:domain ind:ResidualChlorineReading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:residualOperatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Residual Operator Employee Id' ;
    rdfs:comment 'Identifier of the certified water treatment or distribution operator who collected the manual field reading. Required for regulatory compliance and data quality assurance.' ;
    rdfs:domain ind:ResidualChlorineReading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the measured residual meets regulatory minimum requirements. False indicates non-compliance requiring corrective action and potential reporting to primacy agency.' ;
    rdfs:domain ind:ResidualChlorineReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Description of corrective actions taken in response to non-compliant or suspect readings. Documents operational response for regulatory reporting and audit trail.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumAllowedResidualMgPerL rdf:type rdf:Property ;
    rdfs:label 'Maximum Allowed Residual Mg Per L' ;
    rdfs:comment 'Maximum Residual Disinfectant Level (MRDL) allowed by EPA. For chlorine and chloramine, MRDL is 4.0 mg/L as annual average; chlorine dioxide MRDL is 0.8 mg/L.' ;
    rdfs:domain ind:ResidualChlorineReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRequiredResidualMgPerL rdf:type rdf:Property ;
    rdfs:label 'Minimum Required Residual Mg Per L' ;
    rdfs:comment 'Regulatory or operational minimum disinfectant residual threshold applicable at this sampling point. Typically 0.2 mg/L free chlorine at distribution entry point per EPA requirements.' ;
    rdfs:domain ind:ResidualChlorineReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Monitoring Flag' ;
    rdfs:comment 'Indicates whether this reading is part of required regulatory compliance monitoring for state primacy agency or EPA reporting (e.g., MOR, CCR).' ;
    rdfs:domain ind:ResidualChlorineReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualValueMgPerL rdf:type rdf:Property ;
    rdfs:label 'Residual Value Mg Per L' ;
    rdfs:comment 'Measured concentration of disinfectant residual in milligrams per liter. EPA requires minimum 0.2 mg/L free chlorine or detectable residual entering distribution system.' ;
    rdfs:domain ind:ResidualChlorineReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bacteriologicalResultId rdf:type rdf:Property ;
    rdfs:label 'Bacteriological Result Id' ;
    rdfs:comment 'Unique identifier for the bacteriological test result record.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bacteriologicalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Bacteriological Employee Id' ;
    rdfs:comment 'Reference to the laboratory supervisor or quality assurance personnel who verified and approved the final result.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryBacteriologicalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Bacteriological Employee Id' ;
    rdfs:comment 'Reference to the laboratory analyst who performed the bacteriological test.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:qcBatchId rdf:type rdf:Property ;
    rdfs:label 'Qc Batch Id' ;
    rdfs:comment 'Foreign key linking to laboratory.qc_batch. Business justification: Bacteriological results must reference laboratory QC batch for method validation and regulatory defensibility. RTCR compliance requires demonstrating QC acceptance criteria were met for each analytica' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QcBatch .

ind:analysisCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Completion Timestamp' ;
    rdfs:comment 'Precise timestamp when the bacteriological analysis was completed and results were finalized.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chainOfCustodyNumber rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Number' ;
    rdfs:comment 'Chain of custody tracking number for the sample from collection through analysis, ensuring sample integrity and traceability.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eColiCfu rdf:type rdf:Property ;
    rdfs:label 'E Coli Cfu' ;
    rdfs:comment 'Quantitative result for E. coli bacteria expressed as Colony Forming Units per 100 mL when membrane filtration method is used.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eColiMpn rdf:type rdf:Property ;
    rdfs:label 'E Coli Mpn' ;
    rdfs:comment 'Quantitative result for E. coli bacteria expressed as Most Probable Number per 100 mL when enumeration method is used.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eColiResult rdf:type rdf:Property ;
    rdfs:label 'E Coli Result' ;
    rdfs:comment 'Presence or absence result for E. coli bacteria in the sample.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enterococciCfu rdf:type rdf:Property ;
    rdfs:label 'Enterococci Cfu' ;
    rdfs:comment 'Quantitative result for enterococci bacteria expressed as Colony Forming Units per 100 mL.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enterococciResult rdf:type rdf:Property ;
    rdfs:label 'Enterococci Result' ;
    rdfs:comment 'Presence or absence result for enterococci bacteria, typically used for wastewater and recreational water monitoring.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fecalColiformCfu rdf:type rdf:Property ;
    rdfs:label 'Fecal Coliform Cfu' ;
    rdfs:comment 'Quantitative result for fecal coliform bacteria expressed as Colony Forming Units per 100 mL.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fecalColiformResult rdf:type rdf:Property ;
    rdfs:label 'Fecal Coliform Result' ;
    rdfs:comment 'Presence or absence result for fecal coliform bacteria in the sample (legacy parameter, replaced by E. coli under RTCR).' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hpcResult rdf:type rdf:Property ;
    rdfs:label 'Hpc Result' ;
    rdfs:comment 'Quantitative result for Heterotrophic Plate Count expressed as Colony Forming Units per milliliter (CFU/mL), used to assess general bacterial population and treatment effectiveness.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incubationDurationHours rdf:type rdf:Property ;
    rdfs:label 'Incubation Duration Hours' ;
    rdfs:comment 'Duration in hours for which the sample was incubated during analysis (typically 24 or 48 hours depending on method).' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incubationTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Incubation Temperature C' ;
    rdfs:comment 'Temperature in degrees Celsius at which the sample was incubated during analysis (typically 35°C or 44.5°C depending on test type).' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invalidationReason rdf:type rdf:Property ;
    rdfs:label 'Invalidation Reason' ;
    rdfs:comment 'Reason for invalidating the test result if result_status is invalidated (e.g., contamination, procedural error, equipment failure).' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mclExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Mcl Exceeded Flag' ;
    rdfs:comment 'Boolean flag indicating whether the result exceeded the Maximum Contaminant Level for the tested parameter.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Public Notification Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether this result triggers a public notification requirement under SDWA.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Boolean flag indicating whether this result must be included in regulatory compliance reporting to EPA or state primacy agency.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatSampleRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Sample Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether RTCR requires repeat sampling due to a positive total coliform result.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultComments rdf:type rdf:Property ;
    rdfs:label 'Result Comments' ;
    rdfs:comment 'Free-text comments from the analyst regarding the test result, including observations, anomalies, or special conditions.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtcrAssessmentLevel rdf:type rdf:Property ;
    rdfs:label 'Rtcr Assessment Level' ;
    rdfs:comment 'RTCR assessment level triggered by the result (none, Level 1 Assessment, Level 2 Assessment) based on coliform detection patterns.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCollectionTime rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Time' ;
    rdfs:comment 'Precise timestamp when the water sample was collected, including time of day.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalColiformCfu rdf:type rdf:Property ;
    rdfs:label 'Total Coliform Cfu' ;
    rdfs:comment 'Quantitative result for total coliform bacteria expressed as Colony Forming Units per 100 mL when membrane filtration method is used.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalColiformMpn rdf:type rdf:Property ;
    rdfs:label 'Total Coliform Mpn' ;
    rdfs:comment 'Quantitative result for total coliform bacteria expressed as Most Probable Number per 100 mL when enumeration method is used.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalColiformResult rdf:type rdf:Property ;
    rdfs:label 'Total Coliform Result' ;
    rdfs:comment 'Presence or absence result for total coliform bacteria in the sample.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Timestamp when the result was verified and approved by quality assurance personnel.' ;
    rdfs:domain ind:BacteriologicalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leadCopperResultId rdf:type rdf:Property ;
    rdfs:label 'Lead Copper Result Id' ;
    rdfs:comment 'Unique identifier for the lead and copper sampling result record.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleCollectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sample Collector Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: EPA Lead and Copper Rule requires certified personnel for sampling. Tracking collector employee enables license verification, training compliance audits, and chain-of-custody validation for regulatory' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:samplingRoundId rdf:type rdf:Property ;
    rdfs:label 'Sampling Round Id' ;
    rdfs:comment 'Reference to the 6-month monitoring period during which this sample was collected per LCRR requirements.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SamplingRound .

ind:analysisMethod rdf:type rdf:Property ;
    rdfs:label 'Analysis Method' ;
    rdfs:comment 'EPA-approved analytical method used for lead and copper determination (e.g., EPA 200.8 ICP-MS, EPA 200.9 ICP-AES).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copperActionLevelExceeded rdf:type rdf:Property ;
    rdfs:label 'Copper Action Level Exceeded' ;
    rdfs:comment 'Indicates whether the copper result exceeds the EPA action level of 1300 ppb (1.3 mg/L), triggering potential corrosion control treatment requirements.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copperResultPpb rdf:type rdf:Property ;
    rdfs:label 'Copper Result Ppb' ;
    rdfs:comment 'Measured concentration of copper in the water sample expressed in parts per billion (ppb or µg/L). Used for 90th percentile calculation and action level comparison.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corrosionControlTreatmentStatus rdf:type rdf:Property ;
    rdfs:label 'Corrosion Control Treatment Status' ;
    rdfs:comment 'Status of corrosion control treatment optimization at the time of sampling, indicating whether the water system has optimized corrosion control per LCRR requirements.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLimitCopperPpb rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Copper Ppb' ;
    rdfs:comment 'Minimum concentration of copper that the analytical method can reliably detect and quantify for this sample.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionLimitLeadPpb rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Lead Ppb' ;
    rdfs:comment 'Minimum concentration of lead that the analytical method can reliably detect and quantify for this sample.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingTimeCompliant rdf:type rdf:Property ;
    rdfs:label 'Holding Time Compliant' ;
    rdfs:comment 'Indicates whether the sample was analyzed within the EPA-required holding time (6 months for metals) from collection to analysis.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includedIn90thPercentile rdf:type rdf:Property ;
    rdfs:label 'Included In 90th Percentile' ;
    rdfs:comment 'Indicates whether this result was included in the 90th percentile calculation for LCRR compliance determination. Invalid or QC-failed samples are excluded.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadActionLevelExceeded rdf:type rdf:Property ;
    rdfs:label 'Lead Action Level Exceeded' ;
    rdfs:comment 'Indicates whether the lead result exceeds the EPA action level of 15 ppb, triggering potential corrosion control treatment requirements.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadResultPpb rdf:type rdf:Property ;
    rdfs:label 'Lead Result Ppb' ;
    rdfs:comment 'Measured concentration of lead in the water sample expressed in parts per billion (ppb or µg/L). Used for 90th percentile calculation and action level comparison.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityControlStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Control Status' ;
    rdfs:comment 'Laboratory quality control status indicating whether the sample result passed all QC checks including blanks, duplicates, and spike recoveries.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Status' ;
    rdfs:comment 'Status of this result in the regulatory reporting workflow to state primacy agency and EPA.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplePh rdf:type rdf:Property ;
    rdfs:label 'Sample Ph' ;
    rdfs:comment 'pH measurement of the water sample at collection, relevant for corrosion control assessment.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplePreservationMethod rdf:type rdf:Property ;
    rdfs:label 'Sample Preservation Method' ;
    rdfs:comment 'Method used to preserve the sample for metals analysis, typically acidification with nitric acid to pH < 2.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Sample Temperature C' ;
    rdfs:comment 'Water temperature at the time of sample collection, recorded to document field conditions.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteTier rdf:type rdf:Property ;
    rdfs:label 'Site Tier' ;
    rdfs:comment 'LCRR-mandated tier classification of the sampling site based on service line material and building construction date (Tier 1: lead service lines, Tier 2: lead status unknown, Tier 3: non-lead).' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stagnationTimeHours rdf:type rdf:Property ;
    rdfs:label 'Stagnation Time Hours' ;
    rdfs:comment 'Duration in hours that water remained stagnant in the service line prior to sample collection. LCRR requires minimum 6-hour stagnation for first-draw samples.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceWaterQualityId rdf:type rdf:Property ;
    rdfs:label 'Source Water Quality Id' ;
    rdfs:comment 'Unique identifier for the source water quality measurement record.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bulkWaterAgreementId rdf:type rdf:Property ;
    rdfs:label 'Bulk Water Agreement Id' ;
    rdfs:comment 'Foreign key linking to service.bulk_water_agreement. Business justification: Bulk water agreements specify contractual water quality standards at delivery points. Source water monitoring at these points verifies compliance with contracted quality parameters, triggers price adj' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BulkWaterAgreement .

ind:sampledByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sampled By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Source water monitoring under SDWA requires operator certification. Linking sampler employee enables compliance verification for intake monitoring programs, training record validation, and regulatory ' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:algaeCountCellsPerMl rdf:type rdf:Property ;
    rdfs:label 'Algae Count Cells Per Ml' ;
    rdfs:comment 'Concentration of algae cells per milliliter of source water, important for taste, odor, and treatment challenges.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alkalinityMgPerL rdf:type rdf:Property ;
    rdfs:label 'Alkalinity Mg Per L' ;
    rdfs:comment 'Total alkalinity expressed as milligrams per liter of calcium carbonate equivalent, indicating buffering capacity.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ammoniaMgPerL rdf:type rdf:Property ;
    rdfs:label 'Ammonia Mg Per L' ;
    rdfs:comment 'Ammonia nitrogen concentration in milligrams per liter, affecting disinfection effectiveness and DBP formation.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chlorideMgPerL rdf:type rdf:Property ;
    rdfs:label 'Chloride Mg Per L' ;
    rdfs:comment 'Chloride concentration in milligrams per liter, affecting taste and corrosivity.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:colorPcu rdf:type rdf:Property ;
    rdfs:label 'Color Pcu' ;
    rdfs:comment 'Apparent color of the source water measured in Platinum-Cobalt Units, indicating dissolved organic matter.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conductivityUsPerCm rdf:type rdf:Property ;
    rdfs:label 'Conductivity Us Per Cm' ;
    rdfs:comment 'Electrical conductivity of the source water in microsiemens per centimeter, indicating ionic content.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cyanotoxinConcentrationUgPerL rdf:type rdf:Property ;
    rdfs:label 'Cyanotoxin Concentration Ug Per L' ;
    rdfs:comment 'Concentration of cyanotoxins in micrograms per liter if detected, null if not detected or not analyzed.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cyanotoxinDetected rdf:type rdf:Property ;
    rdfs:label 'Cyanotoxin Detected' ;
    rdfs:comment 'Boolean indicator of whether cyanotoxins (blue-green algae toxins) were detected in the screening analysis.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dissolvedOxygenMgPerL rdf:type rdf:Property ;
    rdfs:label 'Dissolved Oxygen Mg Per L' ;
    rdfs:comment 'Concentration of dissolved oxygen in milligrams per liter, indicating water quality and biological activity.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardnessMgPerL rdf:type rdf:Property ;
    rdfs:label 'Hardness Mg Per L' ;
    rdfs:comment 'Total hardness expressed as milligrams per liter of calcium carbonate equivalent, indicating calcium and magnesium content.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ironMgPerL rdf:type rdf:Property ;
    rdfs:label 'Iron Mg Per L' ;
    rdfs:comment 'Total iron concentration in milligrams per liter, important for treatment process design and aesthetic quality.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labAnalyzedBy rdf:type rdf:Property ;
    rdfs:label 'Lab Analyzed By' ;
    rdfs:comment 'Name or identifier of the laboratory analyst who performed the water quality analysis.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manganeseMgPerL rdf:type rdf:Property ;
    rdfs:label 'Manganese Mg Per L' ;
    rdfs:comment 'Total manganese concentration in milligrams per liter, important for treatment and aesthetic quality.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nitrateMgPerL rdf:type rdf:Property ;
    rdfs:label 'Nitrate Mg Per L' ;
    rdfs:comment 'Nitrate nitrogen concentration in milligrams per liter, a regulated contaminant under SDWA.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityControlPassed rdf:type rdf:Property ;
    rdfs:label 'Quality Control Passed' ;
    rdfs:comment 'Boolean indicator of whether the laboratory analysis passed all quality control checks and validation criteria.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:season rdf:type rdf:Property ;
    rdfs:label 'Season' ;
    rdfs:comment 'Season during which the source water sample was collected, used for seasonal trend analysis.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLocationSourceWaterIntakeId rdf:type rdf:Property ;
    rdfs:label 'Source Location Source Water Intake Id' ;
    rdfs:comment 'Reference to the specific water source intake point or well where the sample was collected.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sulfateMgPerL rdf:type rdf:Property ;
    rdfs:label 'Sulfate Mg Per L' ;
    rdfs:comment 'Sulfate concentration in milligrams per liter, a secondary contaminant affecting taste and odor.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tdsMgPerL rdf:type rdf:Property ;
    rdfs:label 'Tds Mg Per L' ;
    rdfs:comment 'Total Dissolved Solids concentration in milligrams per liter, indicating mineral content and salinity.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Temperature of the source water at time of sampling, measured in degrees Celsius.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentAdjustmentRequired rdf:type rdf:Property ;
    rdfs:label 'Treatment Adjustment Required' ;
    rdfs:comment 'Boolean indicator of whether the source water quality measurement triggered a need for Water Treatment Plant (WTP) process adjustment.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tssMgPerL rdf:type rdf:Property ;
    rdfs:label 'Tss Mg Per L' ;
    rdfs:comment 'Total Suspended Solids concentration in milligrams per liter, indicating particulate matter load.' ;
    rdfs:domain ind:SourceWaterQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effluentQualityId rdf:type rdf:Property ;
    rdfs:label 'Effluent Quality Id' ;
    rdfs:comment 'Unique identifier for the effluent quality measurement record.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dmrId rdf:type rdf:Property ;
    rdfs:label 'Dmr Id' ;
    rdfs:comment 'Foreign key linking to compliance.dmr. Business justification: Effluent quality measurements populate DMR (Discharge Monitoring Report) submissions for NPDES compliance. This link connects laboratory results to regulatory reporting documents, essential for wastew' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dmr .

ind:permitConditionId rdf:type rdf:Property ;
    rdfs:label 'Permit Condition Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit_condition. Business justification: Effluent quality measurements are evaluated against specific permit conditions (BOD limits, TSS limits, pH ranges). This link enables automated compliance determination by comparing measured values to' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PermitCondition .

ind:primaryEffluentSampledByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Effluent Sampled By Employee Id' ;
    rdfs:comment 'Foreign key reference to the employee who collected the effluent sample.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ammoniaNitrogenMgL rdf:type rdf:Property ;
    rdfs:label 'Ammonia Nitrogen Mg L' ;
    rdfs:comment 'Ammonia nitrogen concentration in milligrams per liter, measuring un-ionized and ionized ammonia.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ammoniaPermitLimitMgL rdf:type rdf:Property ;
    rdfs:label 'Ammonia Permit Limit Mg L' ;
    rdfs:comment 'NPDES permit limit for ammonia nitrogen concentration in milligrams per liter for this discharge point.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bod5MgL rdf:type rdf:Property ;
    rdfs:label 'Bod5 Mg L' ;
    rdfs:comment 'Five-day biochemical oxygen demand concentration in milligrams per liter, measuring organic pollution load.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bod5PermitLimitMgL rdf:type rdf:Property ;
    rdfs:label 'Bod5 Permit Limit Mg L' ;
    rdfs:comment 'NPDES permit limit for BOD5 concentration in milligrams per liter for this discharge point.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cbod5MgL rdf:type rdf:Property ;
    rdfs:label 'Cbod5 Mg L' ;
    rdfs:comment 'Five-day carbonaceous biochemical oxygen demand concentration in milligrams per liter, excluding nitrogenous demand.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codMgL rdf:type rdf:Property ;
    rdfs:label 'Cod Mg L' ;
    rdfs:comment 'Chemical oxygen demand concentration in milligrams per liter, measuring total organic and inorganic oxidizable matter.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargeDate rdf:type rdf:Property ;
    rdfs:label 'Discharge Date' ;
    rdfs:comment 'Calendar date of the effluent discharge event for reporting purposes.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dissolvedOxygenMgL rdf:type rdf:Property ;
    rdfs:label 'Dissolved Oxygen Mg L' ;
    rdfs:comment 'Dissolved oxygen concentration in milligrams per liter, measuring oxygen available in the effluent.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmrReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Dmr Reporting Period' ;
    rdfs:comment 'The DMR reporting period (e.g., 2024-01, 2024-Q1) to which this effluent measurement applies.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eColiCfu100ml rdf:type rdf:Property ;
    rdfs:label 'E Coli Cfu 100ml' ;
    rdfs:comment 'E. coli bacteria count in colony forming units per 100 milliliters, indicating fecal contamination and pathogen risk.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fecalColiformCfu100ml rdf:type rdf:Property ;
    rdfs:label 'Fecal Coliform Cfu 100ml' ;
    rdfs:comment 'Fecal coliform bacteria count in colony forming units per 100 milliliters, indicating fecal contamination.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fecalColiformPermitLimitCfu100ml rdf:type rdf:Property ;
    rdfs:label 'Fecal Coliform Permit Limit Cfu 100ml' ;
    rdfs:comment 'NPDES permit limit for fecal coliform bacteria count in colony forming units per 100 milliliters for this discharge point.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phPermitRangeMax rdf:type rdf:Property ;
    rdfs:label 'Ph Permit Range Max' ;
    rdfs:comment 'NPDES permit maximum allowable pH value for this discharge point.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phPermitRangeMin rdf:type rdf:Property ;
    rdfs:label 'Ph Permit Range Min' ;
    rdfs:comment 'NPDES permit minimum allowable pH value for this discharge point.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tdsMgL rdf:type rdf:Property ;
    rdfs:label 'Tds Mg L' ;
    rdfs:comment 'Total dissolved solids concentration in milligrams per liter, measuring dissolved inorganic and organic substances.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tocMgL rdf:type rdf:Property ;
    rdfs:label 'Toc Mg L' ;
    rdfs:comment 'Total organic carbon concentration in milligrams per liter, measuring all carbon in organic compounds.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNitrogenMgL rdf:type rdf:Property ;
    rdfs:label 'Total Nitrogen Mg L' ;
    rdfs:comment 'Total nitrogen concentration in milligrams per liter, including organic nitrogen, ammonia, nitrite, and nitrate.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPhosphorusMgL rdf:type rdf:Property ;
    rdfs:label 'Total Phosphorus Mg L' ;
    rdfs:comment 'Total phosphorus concentration in milligrams per liter, measuring all forms of phosphorus including orthophosphate and organic phosphorus.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalResidualChlorineMgL rdf:type rdf:Property ;
    rdfs:label 'Total Residual Chlorine Mg L' ;
    rdfs:comment 'Total residual chlorine concentration in milligrams per liter, measuring disinfectant residual in the effluent.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tssMgL rdf:type rdf:Property ;
    rdfs:label 'Tss Mg L' ;
    rdfs:comment 'Total suspended solids concentration in milligrams per liter, measuring particulate matter in the effluent.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tssPermitLimitMgL rdf:type rdf:Property ;
    rdfs:label 'Tss Permit Limit Mg L' ;
    rdfs:comment 'NPDES permit limit for TSS concentration in milligrams per liter for this discharge point.' ;
    rdfs:domain ind:EffluentQuality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccrPeriodId rdf:type rdf:Property ;
    rdfs:label 'Ccr Period Id' ;
    rdfs:comment 'Unique identifier for the Consumer Confidence Report period. Primary key.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CcrPeriod .

ind:additionalLanguages rdf:type rdf:Property ;
    rdfs:label 'Additional Languages' ;
    rdfs:comment 'Comma-separated list of additional languages in which the CCR was made available (e.g., Spanish, Chinese, Vietnamese).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationMethod rdf:type rdf:Property ;
    rdfs:label 'Certification Method' ;
    rdfs:comment 'Method used to submit the CCR certification to the primacy agency. Many states now require electronic submission through online portals.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Certification Submission Date' ;
    rdfs:comment 'Date when the CCR certification was submitted to the primacy agency. Systems must certify delivery of the CCR to customers by October 1.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certifiedByName rdf:type rdf:Property ;
    rdfs:label 'Certified By Name' ;
    rdfs:comment 'Name of the authorized water system official who certified the CCR. Typically the system manager, superintendent, or designated compliance officer.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedByTitle rdf:type rdf:Property ;
    rdfs:label 'Certified By Title' ;
    rdfs:comment 'Job title of the authorized official who certified the CCR.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customersServedCount rdf:type rdf:Property ;
    rdfs:label 'Customers Served Count' ;
    rdfs:comment 'Total number of customer accounts or service connections served by the water system during the report year. Used to determine CCR distribution requirements.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:detectedContaminantCount rdf:type rdf:Property ;
    rdfs:label 'Detected Contaminant Count' ;
    rdfs:comment 'Total number of regulated contaminants detected in the water system during the report year. Includes contaminants above and below Maximum Contaminant Levels (MCL).' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionMethod rdf:type rdf:Property ;
    rdfs:label 'Distribution Method' ;
    rdfs:comment 'Primary method used to deliver the Consumer Confidence Report to customers. EPA allows mail, electronic delivery, or posting with notification.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFilePath rdf:type rdf:Property ;
    rdfs:label 'Document File Path' ;
    rdfs:comment 'File system path or cloud storage location of the final published CCR document (typically PDF format).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euArticle17ComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Eu Article 17 Compliance Flag' ;
    rdfs:comment 'Whether this reporting period meets EU DWD 2020/2184 Article 17 requirements for consumer information and online access to water quality data.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:euInformationAccessMethod rdf:type rdf:Property ;
    rdfs:label 'Eu Information Access Method' ;
    rdfs:comment 'Method by which consumer water quality information is made accessible per EU DWD 2020/2184 Art 14 (e.g. online portal, annual mailing, on-request). NULL for US jurisdiction.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthEffectsLanguageIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Health Effects Language Included Flag' ;
    rdfs:comment 'Indicates whether mandatory EPA health effects language was included for all detected contaminants. Required for CCR compliance.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageAccessibilityProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Language Accessibility Provided Flag' ;
    rdfs:comment 'Indicates whether the CCR was made available in languages other than English to serve non-English speaking populations. Required for systems serving significant non-English speaking populations.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadCopperEducationalInformationFlag rdf:type rdf:Property ;
    rdfs:label 'Lead Copper Educational Information Flag' ;
    rdfs:comment 'Indicates whether mandatory lead and copper educational information was included in the CCR. Required under Lead and Copper Rule Revisions (LCRR).' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mclViolationCount rdf:type rdf:Property ;
    rdfs:label 'Mcl Violation Count' ;
    rdfs:comment 'Number of Maximum Contaminant Level violations that occurred during the report year. Must be prominently disclosed in the CCR.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringViolationCount rdf:type rdf:Property ;
    rdfs:label 'Monitoring Violation Count' ;
    rdfs:comment 'Number of monitoring and reporting violations that occurred during the report year. Includes failures to test or report as required.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onlineCcrUrl rdf:type rdf:Property ;
    rdfs:label 'Online Ccr Url' ;
    rdfs:comment 'Web address where the CCR is posted online. Required if using electronic delivery method.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationServedCount rdf:type rdf:Property ;
    rdfs:label 'Population Served Count' ;
    rdfs:comment 'Estimated total population receiving water from the system during the report year. Used for regulatory classification and reporting.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preparationStartDate rdf:type rdf:Property ;
    rdfs:label 'Preparation Start Date' ;
    rdfs:comment 'Date when preparation of the Consumer Confidence Report began. Typically starts in January following the report year.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primacyAgency rdf:type rdf:Property ;
    rdfs:label 'Primacy Agency' ;
    rdfs:comment 'State or tribal agency with primary enforcement responsibility for public water systems under the Safe Drinking Water Act. Typically the state Department of Environmental Quality or Health.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date when the Consumer Confidence Report was published and made available to customers. Must be by July 1 following the report year per EPA regulations.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the Consumer Confidence Report. Tracks progression from draft through publication and certification to primacy agency.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportYear rdf:type rdf:Property ;
    rdfs:label 'Report Year' ;
    rdfs:comment 'Calendar year for which this Consumer Confidence Report is prepared. CCRs are annual reports covering the previous calendar year\'s water quality data.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceWaterAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Source Water Assessment Summary' ;
    rdfs:comment 'Summary of the source water assessment including susceptibility to contamination and availability information. Required CCR content element.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialNoticesIncluded rdf:type rdf:Property ;
    rdfs:label 'Special Notices Included' ;
    rdfs:comment 'Description of any special notices included in the CCR such as boil water advisories, vulnerable population warnings, or emerging contaminant information.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentTechniqueViolationCount rdf:type rdf:Property ;
    rdfs:label 'Treatment Technique Violation Count' ;
    rdfs:comment 'Number of treatment technique violations that occurred during the report year. Treatment techniques are required processes for contaminants without MCLs.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:violationSummary rdf:type rdf:Property ;
    rdfs:label 'Violation Summary' ;
    rdfs:comment 'Narrative summary of all violations that occurred during the report year, including health effects language and corrective actions taken. Required CCR content element.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterSourceSummary rdf:type rdf:Property ;
    rdfs:label 'Water Source Summary' ;
    rdfs:comment 'Narrative description of the water system\'s sources including surface water, groundwater, purchased water, and source water protection information. Required CCR content element.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterSystemName rdf:type rdf:Property ;
    rdfs:label 'Water System Name' ;
    rdfs:comment 'Official name of the public water system as registered with the primacy agency.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccrDetectedContaminantId rdf:type rdf:Property ;
    rdfs:label 'Ccr Detected Contaminant Id' ;
    rdfs:comment 'Unique identifier for each contaminant detection record required to be reported in the annual Consumer Confidence Report (CCR) for a given reporting period. Primary key.' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ccrCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Ccr Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who originally created this contaminant detection record. Supports accountability and audit trail for regulatory compliance.' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ccrEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Ccr Employee Id' ;
    rdfs:comment 'Identifier of the water quality manager or compliance officer who reviewed and approved this contaminant detection record for inclusion in the Consumer Confidence Report. Supports audit trail and regulatory accountability.' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ccrModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Ccr Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this contaminant detection record. Supports change tracking and accountability for data quality.' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCcrEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ccr Employee Id' ;
    rdfs:comment 'Identifier of the water quality manager or compliance officer who reviewed and approved this contaminant detection record for inclusion in the Consumer Confidence Report. Supports audit trail and regulatory accountability.' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCcrModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Ccr Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this contaminant detection record. Supports change tracking and accountability for data quality.' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionLevel rdf:type rdf:Property ;
    rdfs:label 'Action Level' ;
    rdfs:comment 'The concentration of a contaminant which, if exceeded, triggers treatment or other requirements that a water system must follow. Primarily used for lead and copper under the Lead and Copper Rule (LCR) and Lead and Copper Rule Revisions (LCRR). Null if not applicable.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccrTableDisplayOrder rdf:type rdf:Property ;
    rdfs:label 'Ccr Table Display Order' ;
    rdfs:comment 'Sequence number controlling the display order of this contaminant in the published CCR detected contaminants table. Allows utilities to organize contaminants by category, regulatory importance, or alphabetically for public presentation.' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contaminantCategory rdf:type rdf:Property ;
    rdfs:label 'Contaminant Category' ;
    rdfs:comment 'Classification of the contaminant type for regulatory grouping and CCR presentation. Categories align with EPA National Primary Drinking Water Regulations structure.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionFrequencyPercent rdf:type rdf:Property ;
    rdfs:label 'Detection Frequency Percent' ;
    rdfs:comment 'Percentage of samples in which this contaminant was detected, calculated as (number_of_detections / number_of_samples) * 100. Provides statistical context for contaminant presence in the water system.' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:footnoteText rdf:type rdf:Property ;
    rdfs:label 'Footnote Text' ;
    rdfs:comment 'Additional explanatory text or footnotes specific to this contaminant detection that will appear in the CCR. Used to provide context, explain unusual results, clarify monitoring schedules, or reference specific regulatory requirements.' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthEffectsLanguage rdf:type rdf:Property ;
    rdfs:label 'Health Effects Language' ;
    rdfs:comment 'EPA-mandated health effects language describing the potential health impacts of this contaminant when present above the MCL or MCLG. Must use EPA-approved standard language as specified in 40 CFR 141.153 Appendix B. Required for all contaminants with violations or detections above health-based levels.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highestLevelDetected rdf:type rdf:Property ;
    rdfs:label 'Highest Level Detected' ;
    rdfs:comment 'The highest single measurement or calculated running annual average (RAA) of the contaminant detected during the reporting period. For some contaminants (e.g., THM, HAA5), this represents the highest locational running annual average (LRAA). Reporting format depends on contaminant-specific regulations.' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mcl rdf:type rdf:Property ;
    rdfs:label 'Mcl' ;
    rdfs:comment 'The Maximum Contaminant Level (MCL) - the highest level of a contaminant that is allowed in drinking water. MCLs are enforceable standards set as close to MCLGs as feasible using the best available treatment technology. Null if a Treatment Technique (TT) applies instead of an MCL.' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mclg rdf:type rdf:Property ;
    rdfs:label 'Mclg' ;
    rdfs:comment 'The Maximum Contaminant Level Goal (MCLG) - the level of a contaminant in drinking water below which there is no known or expected risk to health. MCLGs are non-enforceable public health goals. Value of zero indicates no safe level. Null indicates no MCLG established.' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfDetections rdf:type rdf:Property ;
    rdfs:label 'Number Of Detections' ;
    rdfs:comment 'Count of samples in which this contaminant was detected above the method detection limit (MDL) or practical quantitation level (PQL) during the reporting period. Provides transparency on detection frequency.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfSamples rdf:type rdf:Property ;
    rdfs:label 'Number Of Samples' ;
    rdfs:comment 'Total count of samples collected and analyzed for this contaminant during the reporting period. Used to demonstrate compliance with monitoring frequency requirements and provide context for detection statistics.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rangeHigh rdf:type rdf:Property ;
    rdfs:label 'Range High' ;
    rdfs:comment 'The highest level detected for this contaminant across all samples collected during the reporting period. Forms the upper bound of the detection range required for CCR reporting. Typically matches highest_level_detected unless different averaging methods apply.' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rangeLow rdf:type rdf:Property ;
    rdfs:label 'Range Low' ;
    rdfs:comment 'The lowest level detected for this contaminant across all samples collected during the reporting period. Forms the lower bound of the detection range required for CCR reporting. May be zero or below detection limit.' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleYear rdf:type rdf:Property ;
    rdfs:label 'Sample Year' ;
    rdfs:comment 'The actual year in which the water samples were collected for this contaminant. May differ from reporting year for contaminants with multi-year monitoring cycles (e.g., lead and copper, certain synthetic organic chemicals).' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentTechniqueFlag rdf:type rdf:Property ;
    rdfs:label 'Treatment Technique Flag' ;
    rdfs:comment 'Indicates whether this contaminant is regulated by a Treatment Technique (TT) requirement rather than an MCL. True if TT applies (e.g., turbidity, lead and copper action levels), False if MCL applies.' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typicalSourceDescription rdf:type rdf:Property ;
    rdfs:label 'Typical Source Description' ;
    rdfs:comment 'EPA-mandated language describing the likely sources of this contaminant in drinking water. Must use EPA-approved standard language for each contaminant as specified in 40 CFR 141.153 Appendix A. This text appears directly in the published CCR.' ;
    rdfs:domain ind:CcrDetectedContaminant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringWaiverId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Waiver Id' ;
    rdfs:comment 'Unique identifier for the monitoring waiver record. Primary key.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Monitoring waivers require primacy agency approval and internal accountability tracking. Linking responsible employee enables compliance tracking, renewal deadline management, regulatory correspondenc' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baselineMonitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Baseline Monitoring Frequency' ;
    rdfs:comment 'Original required monitoring frequency before the waiver was granted (e.g., quarterly, monthly, annual). Expressed as a frequency code or description.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccrReportingImpact rdf:type rdf:Property ;
    rdfs:label 'Ccr Reporting Impact' ;
    rdfs:comment 'Description of how the monitoring waiver affects Consumer Confidence Report (CCR) reporting requirements and public notification language.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminantGroup rdf:type rdf:Property ;
    rdfs:label 'Contaminant Group' ;
    rdfs:comment 'Descriptive name of the contaminant group covered by this waiver (e.g., Disinfection Byproducts (DBP), Volatile Organic Compounds (VOC), Synthetic Organic Chemicals (SOC), Inorganic Chemicals (IOC), Radionuclides).' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:historicalMonitoringPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Historical Monitoring Period End' ;
    rdfs:comment 'End date of the historical monitoring period used to demonstrate non-detect results for waiver eligibility.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:historicalMonitoringPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Historical Monitoring Period Start' ;
    rdfs:comment 'Start date of the historical monitoring period used to demonstrate non-detect results for waiver eligibility.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:historicalNonDetectCount rdf:type rdf:Property ;
    rdfs:label 'Historical Non Detect Count' ;
    rdfs:comment 'Number of consecutive historical samples with non-detect results for the contaminant, supporting the waiver justification.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Date' ;
    rdfs:comment 'Date by which the waiver renewal application must be submitted or the waiver reassessment must be completed.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primacyAgencyApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Primacy Agency Approval Reference' ;
    rdfs:comment 'Official reference number, permit number, or document identifier issued by the primacy agency for this waiver approval.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primacyAgencyName rdf:type rdf:Property ;
    rdfs:label 'Primacy Agency Name' ;
    rdfs:comment 'Name of the state or federal primacy agency that approved and granted the monitoring waiver (e.g., State Department of Environmental Quality, EPA Region).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reducedMonitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Reduced Monitoring Frequency' ;
    rdfs:comment 'Reduced monitoring frequency allowed under the waiver (e.g., annual, triennial, once per compliance period). Expressed as a frequency code or description.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequencyYears rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Years' ;
    rdfs:comment 'Frequency in years at which the waiver must be renewed or reassessed if renewal is required.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether the waiver requires periodic renewal or reapplication (True) or is granted indefinitely subject to conditions (False).' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revocationTriggerConditions rdf:type rdf:Property ;
    rdfs:label 'Revocation Trigger Conditions' ;
    rdfs:comment 'Specific conditions or events that would trigger automatic revocation of the waiver (e.g., detection above action level, source water contamination, operational changes).' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingScheduleAdjustmentNotes rdf:type rdf:Property ;
    rdfs:label 'Sampling Schedule Adjustment Notes' ;
    rdfs:comment 'Operational notes describing how the sampling schedule must be adjusted to reflect the waiver-reduced monitoring frequency.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerabilityAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Assessment Date' ;
    rdfs:comment 'Date on which the vulnerability assessment or source water assessment supporting the waiver was completed.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vulnerabilityAssessmentResult rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Assessment Result' ;
    rdfs:comment 'Outcome of the vulnerability assessment indicating the level of vulnerability to the contaminant at the sampling point (e.g., not vulnerable, low vulnerability).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverConditions rdf:type rdf:Property ;
    rdfs:label 'Waiver Conditions' ;
    rdfs:comment 'Specific conditions, requirements, or restrictions imposed by the primacy agency for maintaining the waiver (e.g., annual source water monitoring, notification requirements, operational changes).' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverDurationYears rdf:type rdf:Property ;
    rdfs:label 'Waiver Duration Years' ;
    rdfs:comment 'Duration of the monitoring waiver in years, representing the period between effective date and expiration date.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverJustification rdf:type rdf:Property ;
    rdfs:label 'Waiver Justification' ;
    rdfs:comment 'Detailed business and regulatory justification for granting the monitoring waiver, including vulnerability assessment results, historical non-detect data, or source water protection measures.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverNumber rdf:type rdf:Property ;
    rdfs:label 'Waiver Number' ;
    rdfs:comment 'Externally-known unique identifier or reference number assigned by the primacy agency or utility for this monitoring waiver.' ;
    rdfs:domain ind:MonitoringWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverStatus rdf:type rdf:Property ;
    rdfs:label 'Waiver Status' ;
    rdfs:comment 'Current lifecycle status of the monitoring waiver indicating whether it is active, expired, revoked, pending approval, suspended, or renewed.' ;
