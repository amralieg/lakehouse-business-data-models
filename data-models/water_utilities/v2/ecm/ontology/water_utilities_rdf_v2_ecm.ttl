ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle status of the document. Indicates whether the document is pending review, verified, approved, rejected, expired, superseded by a newer version, or archived. [ENUM-REF-CANDIDATE: PENDING_REVIEW|VERIFIED|APPROVED|REJECTED|EXPIRED|SUPERSEDED|ARCHIVED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'Human-readable title or name of the document, providing a brief description of its content or purpose.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the document type. Examples include service agreements, rate schedules, Consumer Confidence Reports (CCR), Industrial User Permits (IUP), backflow prevention certificates, meter test reports, and compliance notices. [ENUM-REF-CANDIDATE: service_agreement|rate_schedule|tariff|deposit_receipt|payment_plan|lien_notice|ccr|iup_permit|backflow_certificate|meter_test_report|compliance_notice|correspondence|other — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTypeCode rdf:type rdf:Property ;
    rdfs:label 'Document Type Code' ;
    rdfs:comment 'Classification code indicating the type of document. Examples include service agreements, signed applications, identity verification documents, income certification forms, Lead and Copper Rule Revisions (LCRR) lead service line notification acknowledgments, Industrial User Permit (IUP) permits, and legal correspondence. [ENUM-REF-CANDIDATE: SERVICE_AGREEMENT|APPLICATION|IDENTITY_VERIFICATION|INCOME_CERTIFICATION|LCRR_NOTIFICATION|IUP_PERMIT|LEGAL_CORRESPONDENCE|PAYMENT_ARRANGEMENT|BACKFLOW_PERMIT|EASEMENT|METER_INSTALLATION|CONSTRUCTION_PERMIT|WAIVER_FORM|CONSENT_FORM|OTHER — promote to reference product]' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'Attribute document_url for account_document' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'File format or MIME type of the document. Common formats include PDF, DOCX, JPEG, PNG, TIFF, and XML. [ENUM-REF-CANDIDATE: PDF|DOCX|DOC|JPEG|JPG|PNG|TIFF|TIF|XML — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Original file name of the uploaded document, including file extension. Preserves the name provided at upload time.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileReference rdf:type rdf:Property ;
    rdfs:label 'File Reference' ;
    rdfs:comment 'File reference/path' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the document file in bytes. Used for storage management and validation purposes.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isConfidential rdf:type rdf:Property ;
    rdfs:label 'Is Confidential' ;
    rdfs:comment 'Is confidential' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notarizationDate rdf:type rdf:Property ;
    rdfs:label 'Notarization Date' ;
    rdfs:comment 'Date when the document was notarized. Null if not notarized or notarization not required.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notarizationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notarization Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether the document requires notarization. True if notarization is required.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'External reference number assigned by a regulatory agency or governing body, such as permit numbers, docket numbers, or compliance case identifiers.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Boolean flag indicating whether this document is required for regulatory compliance purposes (e.g., LCRR lead notification documentation, IUP compliance records, PUC audit requirements). True if the document is regulatory-mandated.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiration Date' ;
    rdfs:comment 'Date when the document retention period expires and the document may be eligible for deletion or archival per records retention policy. Supports compliance with Public Utilities Commission (PUC) audit requirements and regulatory retention schedules.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years the document must be retained per regulatory or internal policy requirements before eligible for destruction.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Captured Flag' ;
    rdfs:comment 'Boolean flag indicating whether a signature has been captured on the document. True if signature is present.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date when the document was signed by the customer or authorized party. Null if not signed or signature not required.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether the document requires a customer or authorized party signature. True if signature is required.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageLocationUri rdf:type rdf:Property ;
    rdfs:label 'Storage Location Uri' ;
    rdfs:comment 'Uniform Resource Identifier (URI) or path to the physical or cloud storage location where the document is stored.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageReference rdf:type rdf:Property ;
    rdfs:label 'Storage Reference' ;
    rdfs:comment 'Reference path or key to the physical document storage location. May be a document management system (DMS) path, object store key (e.g., S3 bucket path), or file system path. Used for document retrieval.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadChannel rdf:type rdf:Property ;
    rdfs:label 'Upload Channel' ;
    rdfs:comment 'Channel or method through which the document was submitted or uploaded. Examples include web portal, mobile app, email, fax, mail scan, in-person submission, call center, or field service. [ENUM-REF-CANDIDATE: WEB_PORTAL|MOBILE_APP|EMAIL|FAX|MAIL_SCAN|IN_PERSON|CALL_CENTER|FIELD_SERVICE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadDate rdf:type rdf:Property ;
    rdfs:label 'Upload Date' ;
    rdfs:comment 'Attribute upload_date for account_document' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:uploadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upload Timestamp' ;
    rdfs:comment 'Date and time when the document was uploaded or received into the system. Represents the business event timestamp for document receipt.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:uploadedByName rdf:type rdf:Property ;
    rdfs:label 'Uploaded By Name' ;
    rdfs:comment 'Name of the person or system that uploaded the document. Provides human-readable context for the uploader.' ;
