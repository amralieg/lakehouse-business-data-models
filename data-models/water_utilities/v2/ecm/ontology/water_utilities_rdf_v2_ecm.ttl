ind:methodEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Method Employee Id' ;
    rdfs:comment 'Reference to the quality assurance reviewer who validated the MDL study calculations and acceptance criteria.' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:analystCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Analyst Certification Number' ;
    rdfs:comment 'Certification number of the analyst who performed the MDL study, issued by the accrediting body.' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculatedMdl rdf:type rdf:Property ;
    rdfs:label 'Calculated Mdl' ;
    rdfs:comment 'Calculated Method Detection Limit value, determined as the standard deviation of replicate measurements multiplied by the Student\'s t-value at 99% confidence level.' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedMrl rdf:type rdf:Property ;
    rdfs:label 'Calculated Mrl' ;
    rdfs:comment 'Calculated Minimum Reporting Level (also known as Practical Quantitation Limit or PQL), typically set at 3-10 times the MDL to ensure reliable quantitation.' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limsMdlCode rdf:type rdf:Property ;
    rdfs:label 'Lims Mdl Code' ;
    rdfs:comment 'Unique identifier for the corresponding MDL record in the Laboratory Information Management System (LabWare).' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanRecovery rdf:type rdf:Property ;
    rdfs:label 'Mean Recovery' ;
    rdfs:comment 'Mean recovery percentage of the spiked analyte across all replicates, used to assess method accuracy.' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextStudyDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Study Due Date' ;
    rdfs:comment 'Date by which the next MDL study must be conducted to maintain regulatory compliance.' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousMdlValue rdf:type rdf:Property ;
    rdfs:label 'Previous Mdl Value' ;
    rdfs:comment 'Previously established MDL value for comparison and trend analysis.' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousMrlValue rdf:type rdf:Property ;
    rdfs:label 'Previous Mrl Value' ;
    rdfs:comment 'Previously established MRL value for comparison and trend analysis.' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Acceptance Status' ;
    rdfs:comment 'Regulatory acceptance status of the MDL study, indicating whether it meets EPA or state primacy agency requirements.' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relativeStandardDeviationPercent rdf:type rdf:Property ;
    rdfs:label 'Relative Standard Deviation Percent' ;
    rdfs:comment 'Relative standard deviation (coefficient of variation) expressed as a percentage, used to assess method precision.' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replicateCount rdf:type rdf:Property ;
    rdfs:label 'Replicate Count' ;
    rdfs:comment 'Number of replicate samples analyzed in the MDL study. EPA requires a minimum of 7 replicates.' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spikeConcentrationUnit rdf:type rdf:Property ;
    rdfs:label 'Spike Concentration Unit' ;
    rdfs:comment 'Unit of measure for the spike concentration (e.g., mg/L, ug/L, ng/L).' ;
    rdfs:domain ind:MethodDetectionLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardDeviation rdf:type rdf:Property ;
    rdfs:label 'Standard Deviation' ;
    rdfs:comment 'Standard deviation of the replicate measurements used in the MDL calculation.' ;
