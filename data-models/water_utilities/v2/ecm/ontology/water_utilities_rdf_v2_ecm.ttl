    rdfs:domain ind:SamplingLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labAssetRegistryId rdf:type rdf:Property ;
    rdfs:label 'Lab Asset Registry Id' ;
    rdfs:comment 'Reference to the enterprise asset registry for this instrument, linking laboratory equipment to the broader asset management system for depreciation, warranty, and disposal tracking.' ;
    rdfs:domain ind:LabInstrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:labRegistryId rdf:type rdf:Property ;
    rdfs:label 'Lab Registry Id' ;
    rdfs:comment 'Reference to the enterprise asset registry for this instrument, linking laboratory equipment to the broader asset management system for depreciation, warranty, and disposal tracking.' ;
    rdfs:domain ind:LabInstrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:primaryLabCertifiedAnalystId rdf:type rdf:Property ;
    rdfs:label 'Primary Lab Certified Analyst Id' ;
    rdfs:comment 'Reference to the certified laboratory analyst who is the primary operator or custodian of this instrument, responsible for routine operation, calibration verification, and performance monitoring.' ;
    rdfs:domain ind:LabInstrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertifiedAnalyst .

ind:annualServiceCost rdf:type rdf:Property ;
    rdfs:label 'Annual Service Cost' ;
    rdfs:comment 'Annual cost in USD for vendor service contract, preventive maintenance, and consumables for this instrument. Used for OPEX (Operating Expenditure) budgeting and total cost of ownership analysis.' ;
    rdfs:domain ind:LabInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labLocation rdf:type rdf:Property ;
    rdfs:label 'Lab Location' ;
    rdfs:comment 'Physical location of the instrument within the laboratory facility (e.g., \'Main Lab - Room 201\', \'WTP Lab - Bench 3\', \'WWTP Lab - Instrument Room\'). Used for operational logistics and sample routing.' ;
    rdfs:domain ind:LabInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsInstrumentCode rdf:type rdf:Property ;
    rdfs:label 'Lims Instrument Code' ;
    rdfs:comment 'Unique instrument identifier in the laboratory\'s LIMS (Laboratory Information Management System), such as LabWare. Used for electronic data integration, sample tracking, and result validation workflows.' ;
    rdfs:domain ind:LabInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Maintenance Frequency Days' ;
    rdfs:comment 'Required interval in days between preventive maintenance activities for this instrument, as defined by manufacturer recommendations or laboratory maintenance program. Typical values range from 90 to 365 days.' ;
    rdfs:domain ind:LabInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance activity, calculated based on maintenance frequency and last maintenance date. Used for work order scheduling in CMMS (Computerized Maintenance Management System).' ;
    rdfs:domain ind:LabInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryTestMethod rdf:type rdf:Property ;
