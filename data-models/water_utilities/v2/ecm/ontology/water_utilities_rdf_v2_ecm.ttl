ind:standardUnit rdf:type rdf:Property ;
    rdfs:label 'Standard Unit' ;
    rdfs:comment 'Unit of measure for the calibration standard' ;
    rdfs:domain ind:LaboratoryInstrumentCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureDuringCalibrationC rdf:type rdf:Property ;
    rdfs:label 'Temperature During Calibration C' ;
    rdfs:domain ind:LaboratoryInstrumentCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationMeasuredValue rdf:type rdf:Property ;
    rdfs:label 'Verification Measured Value' ;
    rdfs:comment 'Measured value of verification standard' ;
    rdfs:domain ind:LaboratoryInstrumentCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationRecoveryPct rdf:type rdf:Property ;
