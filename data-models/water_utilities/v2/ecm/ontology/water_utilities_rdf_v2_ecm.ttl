    rdfs:domain ind:PermitGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'Allocated amount' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationPurpose rdf:type rdf:Property ;
    rdfs:label 'Allocation Purpose' ;
    rdfs:comment 'Purpose of the allocation.' ;
    rdfs:domain ind:PermitGrantAllocation ;
    rdf:type owl:DatatypeProperty ;
