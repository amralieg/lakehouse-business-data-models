    rdfs:label 'Interferences' ;
    rdfs:comment 'Known interferences or matrix effects that may impact method accuracy or precision, as documented in the method reference.' ;
    rdfs:domain ind:TestMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsMethodCode rdf:type rdf:Property ;
    rdfs:label 'Lims Method Code' ;
    rdfs:comment 'Unique identifier for this test method in the laboratory LIMS system (LabWare or equivalent), used for system integration and data traceability.' ;
    rdfs:domain ind:TestMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdlUnit rdf:type rdf:Property ;
    rdfs:label 'Mdl Unit' ;
    rdfs:comment 'Unit of measure for the MDL value (e.g., mg/L, µg/L, CFU/100mL, NTU, MPN/100mL).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdlValue rdf:type rdf:Property ;
    rdfs:label 'Mdl Value' ;
    rdfs:comment 'The Method Detection Limit - the minimum concentration of an analyte that can be measured and reported with 99% confidence that the value is greater than zero.' ;
    rdfs:domain ind:TestMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodCategory rdf:type rdf:Property ;
    rdfs:label 'Method Category' ;
    rdfs:comment 'High-level classification of the test method by analyte category (inorganic, organic, microbiological, physical, radiological, emerging contaminants).' ;
    rdfs:domain ind:TestMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodDescription rdf:type rdf:Property ;
    rdfs:label 'Method Description' ;
    rdfs:comment 'Detailed technical description of the analytical procedure, including sample preparation, analysis steps, and calculation methods.' ;
    rdfs:domain ind:TestMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodName rdf:type rdf:Property ;
    rdfs:label 'Method Name' ;
    rdfs:comment 'Full descriptive name of the analytical test method (e.g., Determination of Trace Elements in Waters and Wastes by Inductively Coupled Plasma-Mass Spectrometry).' ;
    rdfs:domain ind:TestMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodSource rdf:type rdf:Property ;
    rdfs:label 'Method Source' ;
    rdfs:comment 'The authoritative source or publishing organization of the method (e.g., EPA, Standard Methods, ASTM, ISO, USGS).' ;
    rdfs:domain ind:TestMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodStatus rdf:type rdf:Property ;
    rdfs:label 'Method Status' ;
    rdfs:comment 'Current operational status of the test method in the laboratory (active, inactive, under validation, obsolete, suspended).' ;
    rdfs:domain ind:TestMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodVersion rdf:type rdf:Property ;
    rdfs:label 'Method Version' ;
    rdfs:comment 'Version or revision number of the method (e.g., Rev 5.4, 23rd Edition, 2017 version).' ;
    rdfs:domain ind:TestMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pqlUnit rdf:type rdf:Property ;
    rdfs:label 'Pql Unit' ;
    rdfs:comment 'Unit of measure for the PQL value (e.g., mg/L, µg/L, CFU/100mL, NTU, MPN/100mL).' ;
    rdfs:domain ind:TestMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pqlValue rdf:type rdf:Property ;
    rdfs:label 'Pql Value' ;
    rdfs:comment 'The Practical Quantitation Limit - the lowest concentration that can be reliably measured within specified limits of precision and accuracy during routine laboratory operations.' ;
    rdfs:domain ind:TestMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preservationRequirements rdf:type rdf:Property ;
    rdfs:label 'Preservation Requirements' ;
    rdfs:comment 'Required sample preservation techniques and conditions (e.g., cool to 4°C, acidify to pH<2 with HNO3, add sodium thiosulfate, protect from light).' ;
    rdfs:domain ind:TestMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyTestingRequired rdf:type rdf:Property ;
    rdfs:label 'Proficiency Testing Required' ;
    rdfs:comment 'Indicates whether successful proficiency testing is required for laboratory certification for this method.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcRequirements rdf:type rdf:Property ;
    rdfs:label 'Qc Requirements' ;
    rdfs:comment 'Summary of quality control requirements for the method including frequency of blanks, duplicates, spikes, and control standards.' ;
    rdfs:domain ind:TestMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAcceptance rdf:type rdf:Property ;
    rdfs:label 'Regulatory Acceptance' ;
    rdfs:comment 'Comma-separated list of regulatory programs that accept this method for compliance monitoring (e.g., SDWA, CWA, NPDES, state-specific programs).' ;
    rdfs:domain ind:TestMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingLimit rdf:type rdf:Property ;
    rdfs:label 'Reporting Limit' ;
    rdfs:comment 'The minimum concentration at which results are reported to clients or regulatory agencies, typically equal to or greater than the PQL.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingLimitUnit rdf:type rdf:Property ;
    rdfs:label 'Reporting Limit Unit' ;
    rdfs:comment 'Unit of measure for the reporting limit (e.g., mg/L, µg/L, CFU/100mL, NTU).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByMethodCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Method Code' ;
    rdfs:comment 'Method code of the replacement method if this method has been superseded. Null if still current.' ;
    rdfs:domain ind:TestMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeDays rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Days' ;
    rdfs:comment 'Standard turnaround time in business days from sample receipt to result reporting for routine analysis.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationCurveId rdf:type rdf:Property ;
    rdfs:label 'Calibration Curve Id' ;
    rdfs:comment 'Reference to the instrument calibration curve used to convert raw instrument response to analyte concentration. Links to calibration standards, curve coefficients, and correlation coefficient (R²).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CalibrationCurve .

ind:primaryAnalyticalCertifiedAnalystId rdf:type rdf:Property ;
    rdfs:label 'Primary Analytical Certified Analyst Id' ;
    rdfs:comment 'Reference to the certified laboratory analyst who performed the test. Used for quality assurance, proficiency tracking, and regulatory audit trails.' ;
    rdfs:domain ind:AnalyticalTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertifiedAnalyst .

ind:tertiaryAnalyticalApprovedByAnalystCertifiedAnalystId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Analytical Approved By Analyst Certified Analyst Id' ;
    rdfs:comment 'Reference to the laboratory director or authorized signatory who provided final approval for the test result. Approved results are certified for regulatory reporting and external release.' ;
    rdfs:domain ind:AnalyticalTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertifiedAnalyst .

ind:accreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Accreditation Number' ;
    rdfs:comment 'Unique certificate or license number issued by the accreditation body authorizing the laboratory to perform this test method. Must be current and valid for regulatory reporting.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdTimeCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Hold Time Compliant Flag' ;
    rdfs:comment 'Indicates whether the test was performed within the maximum allowable time between sample collection and analysis. Hold times vary by analyte and method (e.g., 48 hours for bacteria, 28 days for metals). Non-compliance may invalidate results for regulatory reporting.' ;
    rdfs:domain ind:AnalyticalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsImportTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lims Import Timestamp' ;
    rdfs:comment 'Date and time when this test record was imported from the source Laboratory Information Management System (LabWare) into the enterprise data lakehouse. Used for data lineage and reconciliation.' ;
    rdfs:domain ind:AnalyticalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:matrixType rdf:type rdf:Property ;
    rdfs:label 'Matrix Type' ;
    rdfs:comment 'Classification of the sample medium being analyzed. Matrix type affects method selection, quality control requirements, and regulatory applicability. Different matrices may require different preparation techniques and have different interference profiles. [ENUM-REF-CANDIDATE: drinking_water|raw_water|wastewater|groundwater|surface_water|biosolids|soil|sediment — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawInstrumentResponse rdf:type rdf:Property ;
    rdfs:label 'Raw Instrument Response' ;
    rdfs:comment 'Uncorrected measurement value directly from the analytical instrument before applying dilution factors, calibration curves, or other corrections. Retained for audit trails and method validation.' ;
    rdfs:domain ind:AnalyticalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reanalysisRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reanalysis Required Flag' ;
    rdfs:comment 'Indicates whether the test must be repeated due to quality control failure, questionable results, or regulatory requirements. Triggers workflow to schedule reanalysis from the same sample or request new sample collection.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultUnit rdf:type rdf:Property ;
    rdfs:label 'Result Unit' ;
    rdfs:comment 'Unit of measure for the result value (e.g., mg/L, ug/L, NTU, MPN/100mL, pH units, CFU/100mL). Must align with regulatory reporting requirements and Maximum Contaminant Level (MCL) units.' ;
    rdfs:domain ind:AnalyticalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when the test result was reviewed and validated by a senior analyst or supervisor. Marks transition from preliminary to reviewed status.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testComments rdf:type rdf:Property ;
    rdfs:label 'Test Comments' ;
    rdfs:comment 'Free-text field for analyst notes, observations, or explanations regarding unusual conditions, deviations from standard procedures, or result interpretation. May include details on matrix interference, instrument issues, or quality control anomalies.' ;
    rdfs:domain ind:AnalyticalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Completion Timestamp' ;
    rdfs:comment 'Date and time when the analytical test procedure was completed and raw results were recorded. Used to calculate turnaround time and verify hold time compliance.' ;
    rdfs:domain ind:AnalyticalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testPriority rdf:type rdf:Property ;
    rdfs:label 'Test Priority' ;
    rdfs:comment 'Business priority classification for the analytical test. STAT tests require immediate processing for operational decisions; regulatory tests support compliance reporting deadlines; routine tests follow standard turnaround times.' ;
    rdfs:domain ind:AnalyticalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Start Timestamp' ;
    rdfs:comment 'Date and time when the analytical test procedure was initiated. Critical for hold time compliance and contact time (CT) calculations for disinfection validation.' ;
    rdfs:domain ind:AnalyticalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:uncertaintyValue rdf:type rdf:Property ;
    rdfs:label 'Uncertainty Value' ;
    rdfs:comment 'Quantified estimate of the doubt associated with the measurement result, expressed in the same units as the result. Includes contributions from sampling, sample preparation, calibration, and instrument variability.' ;
    rdfs:domain ind:AnalyticalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalResultTestResultId rdf:type rdf:Property ;
    rdfs:label 'Original Result Test Result Id' ;
    rdfs:comment 'Reference to the original test result record if this result is a reanalysis. Links reanalysis results back to the initial result for audit trail and comparison purposes. Null if this is the first analysis.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestResult .

ind:accreditationFlag rdf:type rdf:Property ;
    rdfs:label 'Accreditation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this result was produced under laboratory accreditation (e.g., ISO/IEC 17025, state certification program). True indicates the result was produced by an accredited laboratory using an accredited method; False indicates non-accredited analysis.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedResultFlag rdf:type rdf:Property ;
    rdfs:label 'Approved Result Flag' ;
    rdfs:comment 'Boolean flag indicating whether this result has been reviewed and approved by a qualified analyst or laboratory supervisor. True indicates the result has passed all quality control checks and is released for reporting; False indicates the result is pending review or has been rejected.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blankContaminationFlag rdf:type rdf:Property ;
    rdfs:label 'Blank Contamination Flag' ;
    rdfs:comment 'Boolean flag indicating whether the method blank analyzed in the same batch showed detectable contamination of the target analyte. True indicates blank contamination was detected, which may affect result interpretation.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionStatus rdf:type rdf:Property ;
    rdfs:label 'Detection Status' ;
    rdfs:comment 'Indicates whether the analyte was detected in the sample. Values: detected (analyte present above Method Detection Limit), non-detect (analyte not detected or below MDL), trace (analyte detected but below quantitation limit), below_mdl (result below Method Detection Limit), above_mdl (result above Method Detection Limit and quantifiable).' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duplicateRelativePercentDifference rdf:type rdf:Property ;
    rdfs:label 'Duplicate Relative Percent Difference' ;
    rdfs:comment 'Relative percent difference between the sample result and its duplicate, calculated as (|Sample - Duplicate| / Average) × 100. Indicates the precision of the analytical method. Acceptable ranges are method-specific (typically <20%).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingTimeComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Holding Time Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the sample was analyzed within the method-specified holding time (time between sample collection and analysis). True indicates compliance; False indicates holding time was exceeded, which may affect result validity.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matrixSpikeRecoveryPercent rdf:type rdf:Property ;
    rdfs:label 'Matrix Spike Recovery Percent' ;
    rdfs:comment 'Percent recovery of the analyte from the matrix spike sample analyzed in the same batch. Indicates the accuracy of the method in the presence of the sample matrix. Acceptable ranges are method-specific (typically 75-125%).' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodDetectionLimit rdf:type rdf:Property ;
    rdfs:label 'Method Detection Limit' ;
    rdfs:comment 'The minimum concentration of an analyte that can be measured and reported with 99% confidence that the value is greater than zero. Specific to the test method and laboratory instrumentation used.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proficiencyTestFlag rdf:type rdf:Property ;
    rdfs:label 'Proficiency Test Flag' ;
    rdfs:comment 'Boolean flag indicating whether this result is from a proficiency testing (PT) sample used to evaluate laboratory performance. True indicates this is a PT result; False indicates a routine sample result.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reanalysisFlag rdf:type rdf:Property ;
    rdfs:label 'Reanalysis Flag' ;
    rdfs:comment 'Boolean flag indicating whether this result is from a reanalysis of the sample. True indicates the sample was reanalyzed due to quality control failure, holding time exceedance, or other issue with the initial analysis; False indicates this is the first analysis.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Regulatory Threshold Unit' ;
    rdfs:comment 'Unit of measure for the regulatory threshold value. Must be compatible with the reporting_unit to enable valid comparison. [ENUM-REF-CANDIDATE: mg/L|ug/L|NTU|CFU/100mL|MPN/100mL|pH units|percent|ppm|ppb|SU — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Regulatory Threshold Value' ;
    rdfs:comment 'The applicable regulatory limit against which this result is compared (e.g., Maximum Contaminant Level (MCL), Maximum Contaminant Level Goal (MCLG), National Pollutant Discharge Elimination System (NPDES) effluent limit). Captured at the time of result approval to preserve the threshold in effect.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reporting Timestamp' ;
    rdfs:comment 'Date and time when the result was officially reported to the client or regulatory agency. Distinct from approval_timestamp which is internal laboratory validation; this marks external release.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportingUnit rdf:type rdf:Property ;
    rdfs:label 'Reporting Unit' ;
    rdfs:comment 'Unit of measure in which the result value is reported. Common units include milligrams per liter (mg/L), micrograms per liter (ug/L), Nephelometric Turbidity Units (NTU), Colony Forming Units per 100 milliliters (CFU/100mL), Most Probable Number per 100 milliliters (MPN/100mL), pH units, percent, parts per million (ppm), parts per billion (ppb), Standard Units (SU). [ENUM-REF-CANDIDATE: mg/L|ug/L|NTU|CFU/100mL|MPN/100mL|pH units|percent|ppm|ppb|SU — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultQualifier rdf:type rdf:Property ;
    rdfs:label 'Result Qualifier' ;
    rdfs:comment 'Data qualifier code providing additional context about the result (e.g., J=estimated value, U=undetected, E=exceeds calibration range, B=blank contamination, H=holding time exceeded, Q=quality control failure). Follows EPA and laboratory-specific qualifier conventions.' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uncertaintyEstimate rdf:type rdf:Property ;
    rdfs:label 'Uncertainty Estimate' ;
    rdfs:comment 'Quantitative estimate of the uncertainty associated with the reported result, expressed in the same units as the result. Represents the range within which the true value is expected to lie with a specified confidence level (typically 95%).' ;
    rdfs:domain ind:TestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certifiedAnalystRequired rdf:type rdf:Property ;
    rdfs:label 'Certified Analyst Required' ;
    rdfs:comment 'Indicates whether samples under this plan must be analyzed by a state-certified or EPA-certified analyst. True for regulatory compliance samples; false for operational monitoring.' ;
    rdfs:domain ind:SamplingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chainOfCustodyRequired rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Required' ;
    rdfs:comment 'Indicates whether formal chain of custody documentation is required for samples collected under this plan. True for regulatory, legal, or enforcement-related samples; false for routine operational monitoring.' ;
    rdfs:domain ind:SamplingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceThresholdReference rdf:type rdf:Property ;
    rdfs:label 'Compliance Threshold Reference' ;
    rdfs:comment 'Reference to the regulatory standard or internal guideline defining acceptable limits for analytes in this sampling plan (e.g., MCL, MCLG, NPDES permit limits, internal action levels). Detailed thresholds are managed in the quality domain.' ;
    rdfs:domain ind:SamplingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Lims Integration Flag' ;
    rdfs:comment 'Indicates whether this sampling plan is integrated with the LabWare LIMS system for automated sample tracking, result entry, and reporting. True for plans with LIMS integration; false for manual tracking.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known unique business identifier for the sampling plan, used in LIMS and regulatory reporting systems.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable name of the sampling plan describing its purpose and scope.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaqcProtocol rdf:type rdf:Property ;
    rdfs:label 'Qaqc Protocol' ;
    rdfs:comment 'Reference to the QA/QC protocol or standard operating procedure governing quality control measures for this sampling plan (e.g., blank samples, duplicate samples, spike recovery, proficiency testing frequency).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDriver rdf:type rdf:Property ;
    rdfs:label 'Regulatory Driver' ;
    rdfs:comment 'Primary regulatory framework or permit requirement driving this sampling plan: SDWA (Safe Drinking Water Act), NPDES (National Pollutant Discharge Elimination System), LCRR (Lead and Copper Rule Revisions), state primacy agency requirements, local ordinance, or none for operational plans.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency at which results from this sampling plan must be reported to regulatory agencies or internal stakeholders: monthly, quarterly, semiannual, annual, or as-needed (event-driven).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Brief description of the reason for the most recent revision to this sampling plan (e.g., regulatory change, permit update, operational improvement, corrective action). Supports change control and audit trail.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan Status' ;
    rdfs:comment 'Current lifecycle status of the sampling plan: draft (under development), active (in use), suspended (temporarily paused), retired (no longer used), archived (historical record).' ;
    rdfs:domain ind:SamplingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingAssetRegistryId rdf:type rdf:Property ;
    rdfs:label 'Sampling Asset Registry Id' ;
    rdfs:comment 'Reference to the specific asset (pipe segment, valve, tank, outfall structure) at which sampling occurs. Links to IBM Maximo asset registry.' ;
    rdfs:domain ind:SamplingLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:samplingRegistryId rdf:type rdf:Property ;
    rdfs:label 'Sampling Registry Id' ;
    rdfs:comment 'Reference to the specific asset (pipe segment, valve, tank, outfall structure) at which sampling occurs. Links to IBM Maximo asset registry.' ;
    rdfs:domain ind:SamplingLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:accessibilityNotes rdf:type rdf:Property ;
    rdfs:label 'Accessibility Notes' ;
    rdfs:comment 'Free-text notes describing access requirements, restrictions, or special instructions for field sampling crews (e.g., key required, gate code, contact property owner).' ;
    rdfs:domain ind:SamplingLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isComplianceLocation rdf:type rdf:Property ;
    rdfs:label 'Is Compliance Location' ;
    rdfs:comment 'Boolean flag indicating whether this location is designated for regulatory compliance monitoring (true) or operational monitoring only (false).' ;
    rdfs:domain ind:SamplingLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublicAccess rdf:type rdf:Property ;
    rdfs:label 'Is Public Access' ;
    rdfs:comment 'Boolean flag indicating whether the sampling location is in a publicly accessible area (true) or requires special access arrangements (false).' ;
    rdfs:domain ind:SamplingLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcrrTierClassification rdf:type rdf:Property ;
    rdfs:label 'Lcrr Tier Classification' ;
    rdfs:comment 'Tier classification under EPA Lead and Copper Rule Revisions (LCRR). Determines sampling frequency and priority for lead service line locations.' ;
    rdfs:domain ind:SamplingLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsLocationCode rdf:type rdf:Property ;
    rdfs:label 'Lims Location Code' ;
    rdfs:comment 'Location code used in the LabWare LIMS system for sample tracking and chain of custody. May differ from the utility\'s internal location code.' ;
    rdfs:domain ind:SamplingLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npdesOutfallNumber rdf:type rdf:Property ;
    rdfs:label 'Npdes Outfall Number' ;
    rdfs:comment 'EPA-assigned NPDES permit outfall identifier for wastewater discharge points. Required for DMR reporting and compliance monitoring.' ;
    rdfs:domain ind:SamplingLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDesignation rdf:type rdf:Property ;
