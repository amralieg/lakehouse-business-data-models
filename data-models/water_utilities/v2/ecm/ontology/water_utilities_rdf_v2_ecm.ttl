    rdfs:comment 'End time of the overflow event.' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Start Timestamp' ;
    rdfs:comment 'Start time of the overflow event.' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isRecurringLocation rdf:type rdf:Property ;
    rdfs:label 'Is Recurring Location' ;
    rdfs:comment 'Whether this location has had previous overflow events.' ;
