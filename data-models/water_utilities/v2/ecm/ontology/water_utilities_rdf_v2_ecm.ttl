    rdfs:comment 'Cumulative hazard index (sum of hazard quotients for PFNA+PFHxS+PFBS+HFPO-DA); must be <= 1.0.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hfpoDaConcentrationNgL rdf:type rdf:Property ;
