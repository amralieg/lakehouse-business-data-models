    rdfs:range xsd:string .

ind:projectScheduleId rdf:type rdf:Property ;
    rdfs:label 'Project Schedule Id' ;
    rdfs:comment 'Primary key' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Flag' ;
    rdfs:comment 'Baseline flag' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalPathDurationDays rdf:type rdf:Property ;
    rdfs:label 'Critical Path Duration Days' ;
    rdfs:comment 'Critical path duration in days' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectFinishDate rdf:type rdf:Property ;
    rdfs:label 'Project Finish Date' ;
    rdfs:comment 'Project finish date' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Date' ;
    rdfs:comment 'Schedule date' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Schedule version' ;
    rdfs:domain ind:ProjectSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseRateAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rate Amount' ;
    rdfs:comment 'Fixed monthly or periodic base charge for the service offering, independent of consumption. Covers fixed costs such as meter maintenance, billing, and infrastructure access. Expressed in local currency (USD for U.S. utilities).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityCharge rdf:type rdf:Property ;
    rdfs:label 'Capacity Charge' ;
    rdfs:comment 'Fee for reserving system capacity or infrastructure access, common in industrial and municipal bulk water agreements. May be based on meter size, peak demand, or contracted volume. Also known as a demand charge or readiness-to-serve charge.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offeringCode rdf:type rdf:Property ;
    rdfs:label 'Offering Code' ;
    rdfs:comment 'Externally-known unique code for the service offering used in billing systems, tariff schedules, and customer communications. Examples: WTR-RES-01, WWC-COM-02, RCW-IND-01.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionFee rdf:type rdf:Property ;
    rdfs:label 'Connection Fee' ;
    rdfs:comment 'One-time fee charged to establish a new service connection, including meter installation, service line connection, and administrative setup. May vary by customer class and service type.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conservationProgramEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Conservation Program Eligible Flag' ;
    rdfs:comment 'Indicates whether customers enrolled in this offering are eligible for water conservation programs, rebates, or incentives (e.g., low-flow fixture rebates, landscape conversion incentives). True = eligible; False = not eligible.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryMode rdf:type rdf:Property ;
    rdfs:label 'Delivery Mode' ;
    rdfs:comment 'Method by which the service is delivered and billed. Metered = consumption-based billing via Advanced Metering Infrastructure (AMI) or Automatic Meter Reading (AMR); Unmetered = fixed-rate service without consumption measurement; Flat rate = fixed periodic charge regardless of usage; Seasonal = service active only during specific periods; Temporary = short-term service for construction or events; Emergency = contingency supply during outages or disasters.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireProtectionServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Fire Protection Service Flag' ;
    rdfs:comment 'Indicates whether this offering includes dedicated fire protection service (e.g., fire hydrant access, private fire line). True = fire protection included; False = potable water or wastewater service only.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latePaymentPenaltyPercent rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Percent' ;
    rdfs:comment 'Percentage penalty applied to overdue balances after the payment due date. Subject to Public Utilities Commission regulations. Null if no late fee applies.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meterSizeRequiredInches rdf:type rdf:Property ;
    rdfs:label 'Meter Size Required Inches' ;
    rdfs:comment 'Standard meter size in inches required or recommended for this offering based on expected flow and customer class. Common sizes: 0.625 (5/8 inch), 0.75 (3/4 inch), 1.0, 1.5, 2.0, 3.0, 4.0, 6.0, 8.0 inches. Null for unmetered service.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumMonthlyCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Monthly Charge' ;
    rdfs:comment 'Minimum amount a customer will be billed each billing period, regardless of consumption. Ensures cost recovery for fixed infrastructure and service availability. Null if no minimum applies.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offeringName rdf:type rdf:Property ;
    rdfs:label 'Offering Name' ;
    rdfs:comment 'Human-readable name of the service offering as presented to customers and in regulatory tariff filings. Examples: Residential Potable Water Service, Commercial Wastewater Collection, Industrial Recycled Water Supply.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringDescription rdf:type rdf:Property ;
    rdfs:label 'Offering Description' ;
    rdfs:comment 'Detailed description of the service offering including scope, delivery specifications, and any special conditions or limitations. Used in customer agreements and regulatory filings.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringStatus rdf:type rdf:Property ;
    rdfs:label 'Offering Status' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringType rdf:type rdf:Property ;
    rdfs:label 'Offering Type' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressureRangePsiMax rdf:type rdf:Property ;
    rdfs:label 'Pressure Range Psi Max' ;
    rdfs:comment 'Maximum water pressure in PSI at the customer service connection under normal operating conditions. Excessive pressure may require Pressure Reducing Valve (PRV) installation. Null for wastewater or non-pressurized services.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pressureRangePsiMin rdf:type rdf:Property ;
    rdfs:label 'Pressure Range Psi Min' ;
    rdfs:comment 'Minimum water pressure in PSI guaranteed at the customer service connection under normal operating conditions. Part of service delivery specifications. Null for wastewater or non-pressurized services.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Hours' ;
    rdfs:comment 'Maximum time in hours within which the utility commits to respond to service requests, outages, or quality complaints for this offering. Part of the contractual Service Level Agreement (SLA). Null if no formal SLA applies.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaRestorationTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Restoration Time Hours' ;
    rdfs:comment 'Maximum time in hours within which the utility commits to restore service following an outage or interruption for this offering. Part of the contractual Service Level Agreement (SLA). Null if no formal SLA applies.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required for customer to terminate or discontinue service. Common for commercial and industrial contracts. Null for standard residential service.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumetricRateAmount rdf:type rdf:Property ;
    rdfs:label 'Volumetric Rate Amount' ;
    rdfs:comment 'Per-unit charge for water or wastewater service based on consumption volume. Typically expressed in dollars per thousand gallons ($/kgal) or dollars per hundred cubic feet ($/CCF). Null for unmetered or flat-rate offerings.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumetricRateUnit rdf:type rdf:Property ;
    rdfs:label 'Volumetric Rate Unit' ;
    rdfs:comment 'Unit of measure for volumetric billing. kgal = thousand gallons; CCF = hundred cubic feet; gallon = individual gallon; cubic meter = m³ (common in international contexts); acre-foot = volume unit for large agricultural or municipal contracts.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterQualityStandard rdf:type rdf:Property ;
    rdfs:label 'Water Quality Standard' ;
    rdfs:comment 'Applicable water quality standard or regulatory compliance framework for this offering. Examples: Safe Drinking Water Act (SDWA) Primary Standards, Recycled Water Quality Standards (Title 22 California), Industrial Discharge Permit Limits. Null for non-water offerings (e.g., wastewater collection).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Service Rate Schedule Id' ;
    rdfs:comment 'Unique identifier for the service_rate_schedule data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceClassId rdf:type rdf:Property ;
    rdfs:label 'Service Class Id' ;
    rdfs:comment 'Foreign key linking to service.service_class. Business justification: Rate schedules are applied by customer service class (residential, commercial, industrial, etc.). Each rate schedule should specify which service class it applies to. This is a standard water utility ' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceClass .

ind:serviceRateCaseId rdf:type rdf:Property ;
    rdfs:label 'Service Rate Case Id' ;
    rdfs:comment 'Unique identifier for the service_rate_case data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceRateCase .

ind:tariffId rdf:type rdf:Property ;
    rdfs:label 'Tariff Id' ;
    rdfs:comment 'Foreign key linking to service.tariff. Business justification: Rate schedules implement approved regulatory tariffs. In water utilities, tariffs are filed with and approved by the Public Utilities Commission, then rate schedules operationalize those tariffs. serv' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tariff .

ind:annualRevenueEstimate rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Estimate' ;
    rdfs:comment 'Estimated annual revenue' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedByAuthority rdf:type rdf:Property ;
