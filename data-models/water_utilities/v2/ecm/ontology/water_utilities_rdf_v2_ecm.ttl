    rdfs:domain ind:DbpMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tthmLraaUgL rdf:type rdf:Property ;
    rdfs:label 'Tthm Lraa Ug L' ;
    rdfs:comment 'The locational running annual average of TTHM concentrations at this monitoring point, calculated as the arithmetic average of the current quarter and the previous three quarters.' ;
    rdfs:domain ind:DbpMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tthmMclUgL rdf:type rdf:Property ;
    rdfs:label 'Tthm Mcl Ug L' ;
    rdfs:comment 'The applicable TTHM maximum contaminant level for this monitoring event, typically 80 µg/L under Stage 2 DBPR.' ;
    rdfs:domain ind:DbpMonitoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Water Temperature C' ;
    rdfs:comment 'The water temperature at the time of sample collection in degrees Celsius, which affects DBP formation rates.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laboratoryId rdf:type rdf:Property ;
