ind:jurisdictionRegion rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Region' ;
    rdfs:comment 'Regulatory region code (US, EU, OTHER) determining which PFAS regulatory framework applies. US uses per-compound MCLs (PFOA 4ppt, PFOS 4ppt, etc.) plus hazard index for PFNA+PFHxS+PFBS+HFPO-DA; EU uses sum-of-20 PFAS (100ng/L) and total PFAS class restriction (500ng/L) per Drinking Water Directive 2020/2184.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mclComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Mcl Compliance Status' ;
    rdfs:comment 'Compliance status against the applicable MCL (COMPLIANT, EXCEEDS, PENDING).' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mclCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Mcl Compliant Flag' ;
    rdfs:comment 'Whether individual MCL is met' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mclExceedanceFlag rdf:type rdf:Property ;
    rdfs:label 'Mcl Exceedance Flag' ;
    rdfs:comment 'True if any measured parameter exceeds its MCL for the round.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
