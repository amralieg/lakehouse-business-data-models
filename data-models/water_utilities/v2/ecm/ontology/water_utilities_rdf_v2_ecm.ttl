ind:euTotalPfasUgL rdf:type rdf:Property ;
    rdfs:label 'Eu Total Pfas Ug L' ;
    rdfs:comment 'Total PFAS concentration in micrograms per liter as defined by EU DWD 2020/2184 (limit 0.50 ug/L for total PFAS). NULL for US jurisdiction.' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:euTotalPfasValueNgL rdf:type rdf:Property ;
    rdfs:label 'Eu Total Pfas Value Ng L' ;
    rdfs:comment 'Total PFAS measurement per EU class restriction (limit 500 ng/L).' ;
    rdfs:domain ind:PfasMonitoring ;
    rdf:type owl:DatatypeProperty ;
