    rdfs:comment 'Verification recovery percentage' ;
    rdfs:domain ind:LaboratoryInstrumentCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationStandardResult rdf:type rdf:Property ;
    rdfs:label 'Verification Standard Result' ;
    rdfs:comment 'Verification standard result' ;
    rdfs:domain ind:LaboratoryInstrumentCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationStandardValue rdf:type rdf:Property ;
    rdfs:label 'Verification Standard Value' ;
    rdfs:comment 'Independent verification standard value' ;
    rdfs:domain ind:LaboratoryInstrumentCalibration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Qc Employee Id' ;
    rdfs:comment 'Reference to the laboratory supervisor or QA officer who reviewed and approved the batch QC results. Ensures accountability for data validation decisions.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:batchCompletionDatetime rdf:type rdf:Property ;
    rdfs:label 'Batch Completion Datetime' ;
    rdfs:comment 'Date and time when all analytical work for the batch was completed and results were recorded. Used to calculate batch processing time and ensure timely reporting.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchPreparationDatetime rdf:type rdf:Property ;
    rdfs:label 'Batch Preparation Datetime' ;
    rdfs:comment 'Date and time when the batch preparation or analytical run was initiated. Critical for hold time compliance and method-specific timing requirements.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchReviewDatetime rdf:type rdf:Property ;
    rdfs:label 'Batch Review Datetime' ;
    rdfs:comment 'Date and time when the QC batch was reviewed and acceptance status was assigned by the laboratory supervisor or quality assurance officer.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchSize rdf:type rdf:Property ;
    rdfs:label 'Batch Size' ;
    rdfs:comment 'Total number of samples (including field samples and QC samples) processed together in this batch. Used to verify batch integrity and compliance with method-specific batch size limits.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:duplicateAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Duplicate Acceptance Status' ;
    rdfs:comment 'QC acceptance status for the duplicate sample based on RPD limits. Fail status may indicate sample heterogeneity or analytical imprecision.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duplicateSampleIncluded rdf:type rdf:Property ;
    rdfs:label 'Duplicate Sample Included' ;
    rdfs:comment 'Indicates whether a duplicate field sample was analyzed in this batch. Duplicates assess overall analytical precision for unspiked samples.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldSampleCount rdf:type rdf:Property ;
    rdfs:label 'Field Sample Count' ;
    rdfs:comment 'Number of actual field samples (non-QC samples) included in this batch. Excludes method blanks, laboratory control samples, and other QC samples.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lcsAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Lcs Acceptance Status' ;
    rdfs:comment 'QC acceptance status for the LCS based on percent recovery limits. Fail status indicates systematic bias and may require corrective action or batch reanalysis.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcsExpectedValue rdf:type rdf:Property ;
    rdfs:label 'Lcs Expected Value' ;
    rdfs:comment 'Known or true concentration of the analyte in the laboratory control sample. Used to calculate percent recovery.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcsIncluded rdf:type rdf:Property ;
    rdfs:label 'Lcs Included' ;
    rdfs:comment 'Indicates whether a laboratory control sample was included in this batch. LCS is a known-concentration standard used to verify method accuracy and instrument performance.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcsMeasuredValue rdf:type rdf:Property ;
    rdfs:label 'Lcs Measured Value' ;
    rdfs:comment 'Analytical result obtained for the laboratory control sample. Compared against expected value to calculate percent recovery.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcsPercentRecovery rdf:type rdf:Property ;
    rdfs:label 'Lcs Percent Recovery' ;
    rdfs:comment 'Calculated percent recovery for the LCS: (measured_value / expected_value) * 100. Must fall within method-specific acceptance limits (typically 80-120%) to validate batch accuracy.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limsBatchCode rdf:type rdf:Property ;
    rdfs:label 'Lims Batch Code' ;
    rdfs:comment 'External batch identifier from the laboratory information management system (LabWare or similar). Used for integration and cross-system traceability.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matrixSpikeAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Matrix Spike Acceptance Status' ;
    rdfs:comment 'QC acceptance status for the matrix spike based on percent recovery limits. Fail status may indicate matrix interference requiring method modification or result qualification.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matrixSpikeDuplicateIncluded rdf:type rdf:Property ;
    rdfs:label 'Matrix Spike Duplicate Included' ;
    rdfs:comment 'Indicates whether a matrix spike duplicate was included in this batch. MSD is a second spiked aliquot of the same sample used to assess analytical precision through relative percent difference (RPD) calculation.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matrixSpikeIncluded rdf:type rdf:Property ;
    rdfs:label 'Matrix Spike Included' ;
    rdfs:comment 'Indicates whether a matrix spike sample was included in this batch. Matrix spike is a field sample spiked with known analyte concentration to assess matrix interference and method accuracy in real sample matrices.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matrixSpikePercentRecovery rdf:type rdf:Property ;
    rdfs:label 'Matrix Spike Percent Recovery' ;
    rdfs:comment 'Calculated percent recovery for the matrix spike. Evaluates the effect of sample matrix on analytical accuracy. Acceptance limits are method-specific.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodBlankAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Method Blank Acceptance Status' ;
    rdfs:comment 'QC acceptance status for the method blank based on method-specific criteria. Fail status indicates contamination and may require batch reanalysis.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodBlankIncluded rdf:type rdf:Property ;
    rdfs:label 'Method Blank Included' ;
    rdfs:comment 'Indicates whether a method blank (reagent blank) was included in this batch. Method blanks are required to detect contamination from reagents, glassware, or the analytical process.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msdAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Msd Acceptance Status' ;
    rdfs:comment 'QC acceptance status for the MSD based on RPD limits. Fail status indicates poor precision and may require investigation or reanalysis.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msdPercentRecovery rdf:type rdf:Property ;
    rdfs:label 'Msd Percent Recovery' ;
    rdfs:comment 'Calculated percent recovery for the matrix spike duplicate. Used in conjunction with MS recovery to calculate relative percent difference.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msdRelativePercentDifference rdf:type rdf:Property ;
    rdfs:label 'Msd Relative Percent Difference' ;
    rdfs:comment 'Calculated RPD between matrix spike and matrix spike duplicate: |MS - MSD| / ((MS + MSD) / 2) * 100. Measures analytical precision; must meet method-specific limits (typically <20%).' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallBatchAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Batch Acceptance Status' ;
    rdfs:comment 'Final QC acceptance status for the entire batch based on all QC sample results. Accepted batches have all QC criteria met; rejected batches require reanalysis; conditional batches may have qualified results.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcComments rdf:type rdf:Property ;
    rdfs:label 'Qc Comments' ;
    rdfs:comment 'Free-text field for documenting QC issues, corrective actions taken, deviations from standard procedures, or explanations for conditional acceptance. Critical for audit trail and regulatory compliance.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surrogateAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Surrogate Acceptance Status' ;
    rdfs:comment 'QC acceptance status for surrogate standards based on recovery limits. Fail status may indicate sample preparation problems or matrix interference.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surrogateIncluded rdf:type rdf:Property ;
    rdfs:label 'Surrogate Included' ;
    rdfs:comment 'Indicates whether surrogate standards were added to all samples in this batch. Surrogates are analyte-like compounds added before sample processing to monitor extraction and analytical efficiency.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surrogatePercentRecovery rdf:type rdf:Property ;
    rdfs:label 'Surrogate Percent Recovery' ;
    rdfs:comment 'Average percent recovery for surrogate standards across the batch. Used to assess sample preparation and extraction efficiency. Method-specific acceptance limits apply.' ;
    rdfs:domain ind:QcBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcSampleId rdf:type rdf:Property ;
    rdfs:label 'Qc Sample Id' ;
    rdfs:comment 'Unique identifier for the quality control sample record. Primary key.' ;
    rdfs:domain ind:QcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryQcCertifiedAnalystId rdf:type rdf:Property ;
    rdfs:label 'Primary Qc Certified Analyst Id' ;
    rdfs:comment 'Reference to the certified laboratory analyst who performed the QC sample analysis. Required for chain of custody and accreditation compliance.' ;
    rdfs:domain ind:QcSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertifiedAnalyst .

ind:concentrationUnit rdf:type rdf:Property ;
    rdfs:label 'Concentration Unit' ;
    rdfs:comment 'Unit of measure for the expected and measured concentration values. Common units include milligrams per liter (mg/L), micrograms per liter (ug/L), nanograms per liter (ng/L), parts per million (ppm), parts per billion (ppb), parts per trillion (ppt), Nephelometric Turbidity Units (NTU), Colony Forming Units per 100 milliliters (CFU/100mL), Most Probable Number per 100 milliliters (MPN/100mL), pH units, percent, and Standard Units (SU). [ENUM-REF-CANDIDATE: mg/L|ug/L|ng/L|ppm|ppb|ppt|NTU|CFU/100mL|MPN/100mL|pH_units|percent|SU — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedConcentration rdf:type rdf:Property ;
    rdfs:label 'Expected Concentration' ;
    rdfs:comment 'The known or target concentration value for the QC sample. For LCS and CRM, this is the certified value; for matrix spikes, this is the spiked amount plus the native sample concentration; for blanks, this is typically zero.' ;
    rdfs:domain ind:QcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limsSampleNumber rdf:type rdf:Property ;
    rdfs:label 'Lims Sample Number' ;
    rdfs:comment 'Unique sample identifier assigned by the Laboratory Information Management System (LIMS), such as LabWare. Used for integration and cross-referencing between the data warehouse and the operational LIMS system.' ;
    rdfs:domain ind:QcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerAcceptanceLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Acceptance Limit' ;
    rdfs:comment 'Lower bound of the acceptable range for percent recovery or Relative Percent Difference (RPD). Defined by the analytical method, laboratory Standard Operating Procedure (SOP), or regulatory requirement. QC samples below this limit fail acceptance criteria.' ;
    rdfs:domain ind:QcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredConcentration rdf:type rdf:Property ;
    rdfs:label 'Measured Concentration' ;
    rdfs:comment 'The actual concentration value obtained from laboratory analysis of the QC sample. Used to calculate recovery and evaluate method performance.' ;
    rdfs:domain ind:QcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nativeConcentration rdf:type rdf:Property ;
    rdfs:label 'Native Concentration' ;
    rdfs:comment 'Original concentration of the analyte in the sample before spiking, applicable to matrix spike and matrix spike duplicate QC types. Used in recovery calculations: recovery = (measured - native) / spike * 100.' ;
    rdfs:domain ind:QcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proficiencyTestProvider rdf:type rdf:Property ;
    rdfs:label 'Proficiency Test Provider' ;
    rdfs:comment 'Name of the external proficiency testing provider if this QC sample is part of a proficiency test (e.g., EPA, AWWA, Environmental Resource Associates). Null for routine internal QC samples.' ;
    rdfs:domain ind:QcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcSampleType rdf:type rdf:Property ;
    rdfs:label 'Qc Sample Type' ;
    rdfs:comment 'Type of quality control sample. Method blank verifies absence of contamination; Laboratory Control Sample (LCS) verifies method accuracy; Matrix Spike (MS) and Matrix Spike Duplicate (MSD) verify matrix interference and precision; field duplicate and field blank verify field collection procedures; surrogate spike verifies extraction efficiency; Certified Reference Material (CRM) verifies instrument calibration. [ENUM-REF-CANDIDATE: method_blank|laboratory_control_sample|matrix_spike|matrix_spike_duplicate|field_duplicate|field_blank|surrogate_spike|certified_reference_material — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:QcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Status' ;
    rdfs:comment 'Pass/fail status of the QC sample based on comparison of percent recovery or Relative Percent Difference (RPD) against acceptance limits. Pass indicates the QC sample met all acceptance criteria; fail indicates one or more criteria were not met; warning indicates results are marginal; pending_review indicates awaiting quality assurance officer review; not_applicable for QC types without numeric acceptance criteria.' ;
    rdfs:domain ind:QcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spikeConcentration rdf:type rdf:Property ;
    rdfs:label 'Spike Concentration' ;
    rdfs:comment 'Concentration of analyte added to the sample for matrix spike, matrix spike duplicate, or surrogate spike QC types. Null for other QC types. Used to calculate percent recovery in the presence of sample matrix.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperAcceptanceLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Acceptance Limit' ;
    rdfs:comment 'Upper bound of the acceptable range for percent recovery or Relative Percent Difference (RPD). Defined by the analytical method, laboratory Standard Operating Procedure (SOP), or regulatory requirement. QC samples above this limit fail acceptance criteria.' ;
    rdfs:domain ind:QcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certifiedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Certified Employee Id' ;
    rdfs:comment 'Reference to the employee ID of the analysts direct supervisor or laboratory manager. Used for organizational hierarchy and approval workflows.' ;
    rdfs:domain ind:CertifiedAnalyst ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCertifiedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Certified Employee Id' ;
    rdfs:comment 'Reference to the employee record in the workforce domain. Links the laboratory certification record to the underlying employee master data.' ;
    rdfs:domain ind:CertifiedAnalyst ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:analystFirstName rdf:type rdf:Property ;
    rdfs:label 'Analyst First Name' ;
    rdfs:comment 'First name of the certified laboratory analyst. Used for identification on laboratory reports and chain of custody documentation.' ;
    rdfs:domain ind:CertifiedAnalyst ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystLastName rdf:type rdf:Property ;
    rdfs:label 'Analyst Last Name' ;
    rdfs:comment 'Last name of the certified laboratory analyst. Used for identification on laboratory reports and chain of custody documentation.' ;
    rdfs:domain ind:CertifiedAnalyst ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystMiddleInitial rdf:type rdf:Property ;
    rdfs:label 'Analyst Middle Initial' ;
    rdfs:comment 'Middle initial of the certified laboratory analyst. Optional field for complete name identification.' ;
    rdfs:domain ind:CertifiedAnalyst ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'Date of the most recent background check or security clearance verification. Required for analysts working with sensitive data or in facilities subject to security regulations.' ;
    rdfs:domain ind:CertifiedAnalyst ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'Hierarchical level or grade of the certification indicating the complexity of analytical work the analyst is authorized to perform. Higher levels typically authorize more complex testing methods and supervisory responsibilities.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Unique certification number or license number issued by the certifying body. This is the official credential identifier that must be referenced on laboratory reports and regulatory submissions.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Type of laboratory certification held by the analyst. Categories include state drinking water analyst certification, wastewater operator certification, NELAC (National Environmental Laboratory Accreditation Conference) signatory authority, laboratory director certification, quality assurance officer certification, or specialty method certification.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBody rdf:type rdf:Property ;
    rdfs:label 'Certifying Body' ;
    rdfs:comment 'Name of the organization or agency that issued the certification. Examples include state environmental agencies, EPA regional offices, NELAC accreditation bodies, or professional associations such as AWWA or WEF.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationHours rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours' ;
    rdfs:comment 'Total number of continuing education hours or professional development units earned by the analyst in the current certification period. Required for certification renewal.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Emergency contact phone number for the analyst. Used for urgent notifications related to laboratory incidents, sample integrity issues, or regulatory inquiries.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentQualifications rdf:type rdf:Property ;
    rdfs:label 'Instrument Qualifications' ;
    rdfs:comment 'Comma-separated list of laboratory instruments the analyst is trained and qualified to operate. Examples include ICP-MS (Inductively Coupled Plasma Mass Spectrometry), GC-MS (Gas Chromatography Mass Spectrometry), IC (Ion Chromatography), UV-Vis spectrophotometer, TOC (Total Organic Carbon) analyzer, etc.' ;
    rdfs:domain ind:CertifiedAnalyst ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryAssignment rdf:type rdf:Property ;
    rdfs:label 'Laboratory Assignment' ;
    rdfs:comment 'Name or code of the laboratory facility or work center where the analyst is primarily assigned. Examples include Central Laboratory, WTP (Water Treatment Plant) Lab, WWTP (Wastewater Treatment Plant) Lab, or Field Testing Unit.' ;
    rdfs:domain ind:CertifiedAnalyst ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastProficiencyTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Proficiency Test Date' ;
    rdfs:comment 'Date of the most recent proficiency testing event completed by the analyst. Used to track compliance with annual or semi-annual PT requirements.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:limsUserCode rdf:type rdf:Property ;
    rdfs:label 'Lims User Code' ;
    rdfs:comment 'User identifier for the analyst in the Laboratory Information Management System (LabWare or similar). Links the certification record to the analysts login and activity in the LIMS for audit trail and data integrity purposes.' ;
    rdfs:domain ind:CertifiedAnalyst ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyTestingStatus rdf:type rdf:Property ;
    rdfs:label 'Proficiency Testing Status' ;
    rdfs:comment 'Status of the analysts participation in proficiency testing programs. Proficiency testing is required for NELAC accreditation and demonstrates the analysts ability to produce accurate results. Current status indicates successful completion of required PT samples.' ;
    rdfs:domain ind:CertifiedAnalyst ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlRole rdf:type rdf:Property ;
    rdfs:label 'Quality Control Role' ;
    rdfs:comment 'Role of the analyst in the laboratorys quality assurance and quality control program. Roles include bench analyst, data reviewer, QA officer, or technical director with oversight responsibilities.' ;
    rdfs:domain ind:CertifiedAnalyst ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSource rdf:type rdf:Property ;
    rdfs:label 'Record Source' ;
    rdfs:comment 'Identifier of the source system from which this certified analyst record originated. Examples include LIMS (LabWare), SAP HR, or manual certification tracking system.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Safety Training Date' ;
    rdfs:comment 'Date of the most recent laboratory safety training completion. Required annually for OSHA compliance and includes topics such as chemical hygiene, hazardous waste handling, and emergency response.' ;
    rdfs:domain ind:CertifiedAnalyst ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftAssignment rdf:type rdf:Property ;
    rdfs:label 'Shift Assignment' ;
    rdfs:comment 'Work shift to which the analyst is assigned. Relevant for 24/7 laboratory operations and emergency response coverage.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Signatory Authority' ;
    rdfs:comment 'Boolean flag indicating whether the analyst has signatory authority to approve and sign laboratory reports for regulatory submission. Signatory authority is typically restricted to senior analysts or laboratory directors who meet specific qualification criteria.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialtyAreas rdf:type rdf:Property ;
    rdfs:label 'Specialty Areas' ;
    rdfs:comment 'Comma-separated list of analytical specialty areas or matrices the analyst is qualified to work with. Examples include drinking water microbiology, wastewater metals, organic compounds, radiochemistry, or specific contaminant groups such as PFAS (Per- and Polyfluoroalkyl Substances) or DBPs (Disinfection Byproducts).' ;
    rdfs:domain ind:CertifiedAnalyst ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labAccreditationId rdf:type rdf:Property ;
    rdfs:label 'Lab Accreditation Id' ;
    rdfs:comment 'Unique identifier for the laboratory accreditation record. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabAccreditation .

ind:accreditationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Accreditation Certificate Number' ;
    rdfs:comment 'The unique certificate number issued by the accrediting body for this accreditation.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationCostUsd rdf:type rdf:Property ;
    rdfs:label 'Accreditation Cost Usd' ;
    rdfs:comment 'The total cost in US dollars for obtaining and maintaining this accreditation, including application fees, assessment fees, and proficiency testing costs.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accreditationDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Accreditation Document Url' ;
    rdfs:comment 'URL or file path to the digital copy of the accreditation certificate and scope document.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Accreditation Scope Description' ;
    rdfs:comment 'Detailed description of the accreditation scope, including the list of accredited analytes, matrices, and test methods covered under this accreditation.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationType rdf:type rdf:Property ;
    rdfs:label 'Accreditation Type' ;
    rdfs:comment 'The type or program of accreditation granted (e.g., state primacy, NELAC/TNI, A2LA, DoD ELAP, ISO 17025).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsOrDeficienciesNoted rdf:type rdf:Property ;
    rdfs:label 'Conditions Or Deficiencies Noted' ;
    rdfs:comment 'Any conditions, limitations, or deficiencies noted by the accrediting body during the last assessment. May include corrective action requirements.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialAccreditationDate rdf:type rdf:Property ;
    rdfs:label 'Initial Accreditation Date' ;
    rdfs:comment 'The date when the laboratory first received this accreditation from the accrediting body.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proficiencyTestId rdf:type rdf:Property ;
    rdfs:label 'Proficiency Test Id' ;
    rdfs:comment 'Unique identifier for the proficiency testing study participation event.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProficiencyTest .

ind:primaryProficiencyLabSampleId rdf:type rdf:Property ;
    rdfs:label 'Primary Proficiency Lab Sample Id' ;
    rdfs:comment 'Unique sample identifier assigned by the proficiency test provider.' ;
    rdfs:domain ind:ProficiencyTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabSample .

ind:proficiencyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Proficiency Employee Id' ;
    rdfs:comment 'Reference to the quality assurance officer or supervisor who reviewed the proficiency test results.' ;
    rdfs:domain ind:ProficiencyTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:proficiencyReviewedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Proficiency Reviewed By Employee Id' ;
    rdfs:comment 'Reference to the quality assurance officer or supervisor who reviewed the proficiency test results.' ;
    rdfs:domain ind:ProficiencyTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ptProviderId rdf:type rdf:Property ;
    rdfs:label 'Pt Provider Id' ;
    rdfs:comment 'Reference to the proficiency testing provider organization (ERA, NERL, LGC, etc.).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PtProvider .

ind:accreditationField rdf:type rdf:Property ;
    rdfs:label 'Accreditation Field' ;
    rdfs:comment 'Field of accreditation or testing category this proficiency test supports (e.g., Drinking Water Chemistry, Microbiology).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationImpact rdf:type rdf:Property ;
    rdfs:label 'Accreditation Impact' ;
    rdfs:comment 'Assessment of the impact of this proficiency test result on laboratory accreditation status.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedValue rdf:type rdf:Property ;
    rdfs:label 'Assigned Value' ;
    rdfs:comment 'True or reference concentration value assigned by the proficiency test provider.' ;
    rdfs:domain ind:ProficiencyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participantCount rdf:type rdf:Property ;
    rdfs:label 'Participant Count' ;
    rdfs:comment 'Number of laboratories that participated in this proficiency test round.' ;
    rdfs:domain ind:ProficiencyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peerGroupMean rdf:type rdf:Property ;
    rdfs:label 'Peer Group Mean' ;
    rdfs:comment 'Mean value reported by all participating laboratories in the peer group.' ;
    rdfs:domain ind:ProficiencyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peerGroupStandardDeviation rdf:type rdf:Property ;
    rdfs:label 'Peer Group Standard Deviation' ;
    rdfs:comment 'Standard deviation of values reported by all participating laboratories in the peer group.' ;
    rdfs:domain ind:ProficiencyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentileRank rdf:type rdf:Property ;
    rdfs:label 'Percentile Rank' ;
    rdfs:comment 'Percentile ranking of the laboratorys performance relative to all participants (0-100).' ;
    rdfs:domain ind:ProficiencyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ptRound rdf:type rdf:Property ;
    rdfs:label 'Pt Round' ;
    rdfs:comment 'Round or cycle identifier for the proficiency test (e.g., 2024-Q1, Round 45).' ;
    rdfs:domain ind:ProficiencyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptStudyName rdf:type rdf:Property ;
    rdfs:label 'Pt Study Name' ;
    rdfs:comment 'Name of the proficiency testing study or program (e.g., WP-123, DMR-QA).' ;
    rdfs:domain ind:ProficiencyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Report Receipt Date' ;
    rdfs:comment 'Date the laboratory received the final proficiency test report from the provider.' ;
    rdfs:domain ind:ProficiencyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedValue rdf:type rdf:Property ;
    rdfs:label 'Reported Value' ;
    rdfs:comment 'Concentration value reported by the laboratory for the proficiency test sample.' ;
    rdfs:domain ind:ProficiencyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Sample Receipt Date' ;
    rdfs:comment 'Date the proficiency test sample was received by the laboratory.' ;
    rdfs:domain ind:ProficiencyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'Deadline date by which the laboratory must submit results to the proficiency test provider.' ;
    rdfs:domain ind:ProficiencyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:zScore rdf:type rdf:Property ;
    rdfs:label 'Z Score' ;
    rdfs:comment 'Statistical z-score calculated from the reported value, assigned value, and standard deviation, indicating performance relative to peer laboratories.' ;
    rdfs:domain ind:ProficiencyTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultValidationId rdf:type rdf:Property ;
    rdfs:label 'Result Validation Id' ;
    rdfs:comment 'Unique identifier for the result validation record. Primary key.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryResultEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Result Employee Id' ;
    rdfs:comment 'Reference to the certified analyst or data validator who performed the validation review. Must be a qualified individual per laboratory QA/QC protocols.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:resultEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Result Employee Id' ;
    rdfs:comment 'Reference to the certified analyst or data validator who performed the validation review. Must be a qualified individual per laboratory QA/QC protocols.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewerId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Id' ;
    rdfs:comment 'Reference to a secondary reviewer or quality assurance officer who performed independent review of the validation. Used in laboratories with multi-tier validation protocols.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:validationBatchId rdf:type rdf:Property ;
    rdfs:label 'Validation Batch Id' ;
    rdfs:comment 'Reference to the validation batch if multiple results were validated together. Enables grouping of validation activities performed in a single review session.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ValidationBatch .

ind:calibrationVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Calibration Verification Flag' ;
    rdfs:comment 'Indicates whether instrument calibration was current and verified at the time of analysis. True if calibration was valid, False if calibration issues were identified.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chainOfCustodyVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Verified Flag' ;
    rdfs:comment 'Indicates whether the chain of custody documentation was complete and verified during validation. True if COC is intact and verified, False if discrepancies were found.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Release Timestamp' ;
    rdfs:comment 'Date and time when the validated result was released for regulatory reporting, customer delivery, or internal use. Marks the completion of the validation and approval workflow.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:flagsRaisedCount rdf:type rdf:Property ;
    rdfs:label 'Flags Raised Count' ;
    rdfs:comment 'Number of quality flags or warnings raised during validation. Flags may indicate potential issues that do not necessarily result in rejection but require documentation.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:methodComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Method Compliance Flag' ;
    rdfs:comment 'Indicates whether the analytical method was performed in full compliance with the approved EPA or Standard Method protocol. True if compliant, False if deviations occurred.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcAcceptanceCriteriaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Qc Acceptance Criteria Met Flag' ;
    rdfs:comment 'Indicates whether all quality control acceptance criteria (blanks, duplicates, spikes, surrogates, calibration verification) were met for this result. True if all QC passed, False if any QC failure occurred.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualifiersApplied rdf:type rdf:Property ;
    rdfs:label 'Qualifiers Applied' ;
    rdfs:comment 'Data qualifiers or flags assigned to the result during validation. Common qualifiers include J (estimated value), U (non-detect), R (rejected), Q (quality control issue). Multiple qualifiers may be comma-separated.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDefensibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Defensibility Flag' ;
    rdfs:comment 'Indicates whether the validated result meets the full defensibility standard required for regulatory reporting and potential legal proceedings. True if defensible, False if data quality issues compromise defensibility.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultsRejectedCount rdf:type rdf:Property ;
    rdfs:label 'Results Rejected Count' ;
    rdfs:comment 'Number of individual test results rejected during this validation review. Used for quality metrics and laboratory performance tracking.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationCriteriaApplied rdf:type rdf:Property ;
    rdfs:label 'Validation Criteria Applied' ;
    rdfs:comment 'Description of the specific validation criteria, checklists, or protocols applied during the review. May reference EPA method requirements, laboratory SOP numbers, or regulatory program-specific validation rules.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDisposition rdf:type rdf:Property ;
    rdfs:label 'Validation Disposition' ;
    rdfs:comment 'Final outcome of the validation review. Accepted: result meets all quality criteria and is released without qualification. Qualified: result is usable but carries data qualifiers or flags. Rejected: result fails validation and cannot be used for regulatory reporting.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Validation Duration Minutes' ;
    rdfs:comment 'Total time in minutes spent performing the validation review. Used for laboratory productivity metrics and resource planning.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationFindings rdf:type rdf:Property ;
    rdfs:label 'Validation Findings' ;
    rdfs:comment 'Detailed narrative of validation findings, issues identified, corrective actions taken, and rationale for the final disposition. Critical for regulatory audit trail and data defensibility.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationLevel rdf:type rdf:Property ;
    rdfs:label 'Validation Level' ;
    rdfs:comment 'The EPA validation protocol level applied to this result. Level I: basic data verification; Level II: analytical QC review; Level III: method and holding time compliance; Level IV: full data package audit for regulatory defensibility.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationNotes rdf:type rdf:Property ;
    rdfs:label 'Validation Notes' ;
    rdfs:comment 'Additional notes, comments, or observations recorded by the validator during the review process. May include references to supporting documentation, communications with analysts, or special circumstances.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Validator Certification Number' ;
    rdfs:comment 'Professional certification or license number of the validator. Required for regulatory defensibility under SDWA and CWA compliance programs.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatorName rdf:type rdf:Property ;
    rdfs:label 'Validator Name' ;
    rdfs:comment 'Full name of the validator who performed the review. Provides human-readable identification for audit trail and regulatory reporting.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prepared By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: QC/QA protocols require documented employee accountability for reagent preparation. Accreditation standards (TNI, NELAC) mandate traceable preparation records linking to qualified employees for method' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:associatedTestMethods rdf:type rdf:Property ;
    rdfs:label 'Associated Test Methods' ;
    rdfs:comment 'Comma-separated list of analytical test method codes or names for which this reagent or standard is used. Supports traceability of reagents to specific analytical procedures and regulatory compliance demonstrations.' ;
    rdfs:domain ind:ReagentStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogNumber rdf:type rdf:Property ;
    rdfs:label 'Catalog Number' ;
    rdfs:comment 'Manufacturer or supplier catalog number for the reagent or standard. Used for reordering and traceability to supplier specifications.' ;
    rdfs:domain ind:ReagentStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Certificate of analysis or certificate of conformance number provided by the manufacturer or certifying body. Documents the certified properties and traceability of the standard.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedReferenceMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Certified Reference Material Flag' ;
    rdfs:comment 'Indicates whether this standard is a certified reference material with traceability to national or international measurement standards. True if CRM, false otherwise. CRMs are required for certain regulatory compliance testing.' ;
    rdfs:domain ind:ReagentStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concentrationValue rdf:type rdf:Property ;
    rdfs:label 'Concentration Value' ;
    rdfs:comment 'Numeric concentration or purity of the reagent or standard as certified by the manufacturer or as prepared in the laboratory. Used in calibration calculations and quality control verification.' ;
    rdfs:domain ind:ReagentStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Current Stock Quantity' ;
    rdfs:comment 'Current quantity of the reagent or standard available in laboratory inventory. Updated as material is consumed or replenished.' ;
    rdfs:domain ind:ReagentStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Manufacturer-assigned lot or batch number for the reagent or standard. Essential for traceability in the event of quality issues or recalls and for demonstrating chain of custody in regulatory audits.' ;
    rdfs:domain ind:ReagentStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationDate rdf:type rdf:Property ;
    rdfs:label 'Preparation Date' ;
    rdfs:comment 'Date on which the reagent or standard was prepared or diluted in the laboratory. For commercially prepared standards, this is the manufacture date. Critical for determining shelf life and expiry.' ;
    rdfs:domain ind:ReagentStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reagentName rdf:type rdf:Property ;
    rdfs:label 'Reagent Name' ;
    rdfs:comment 'Full chemical or commercial name of the reagent, standard, or reference material as provided by the manufacturer or as catalogued in the Laboratory Information Management System (LIMS).' ;
    rdfs:domain ind:ReagentStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reagentStandardStatus rdf:type rdf:Property ;
    rdfs:label 'Reagent Standard Status' ;
    rdfs:comment 'Current lifecycle status of the reagent or standard: active (in use), expired (past expiry date), depleted (stock exhausted), quarantined (under investigation or hold), or disposed (removed from inventory).' ;
    rdfs:domain ind:ReagentStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reagentType rdf:type rdf:Property ;
    rdfs:label 'Reagent Type' ;
    rdfs:comment 'Classification of the chemical material by its intended laboratory use: reagent for general analytical work, standard for calibration, reference material for quality control, buffer for pH adjustment, indicator for endpoint detection, or solvent for dilution and extraction.' ;
    rdfs:domain ind:ReagentStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderThreshold rdf:type rdf:Property ;
    rdfs:label 'Reorder Threshold' ;
    rdfs:comment 'Minimum stock quantity that triggers a reorder alert or procurement action. Ensures continuous availability of critical reagents and standards for analytical operations.' ;
    rdfs:domain ind:ReagentStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyDataSheetReference rdf:type rdf:Property ;
    rdfs:label 'Safety Data Sheet Reference' ;
    rdfs:comment 'Reference identifier or file location for the Safety Data Sheet (SDS) associated with this reagent. SDS provides hazard information, handling instructions, and emergency procedures.' ;
    rdfs:domain ind:ReagentStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockUnit rdf:type rdf:Property ;
    rdfs:label 'Stock Unit' ;
    rdfs:comment 'Unit of measure for the stock quantity: milliliters (mL), liters (L), grams (g), kilograms (kg), units, or vials.' ;
    rdfs:domain ind:ReagentStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Required environmental conditions for storing the reagent or standard to maintain stability and integrity: ambient temperature, refrigerated (2-8°C), frozen (<0°C), protected from light (dark), or under inert atmosphere.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the laboratory supervisor or quality assurance officer who verified the preparation or receipt of the reagent or standard. Ensures independent quality control.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyteStatus rdf:type rdf:Property ;
    rdfs:label 'Analyte Status' ;
    rdfs:comment 'Current status of the analyte in the laboratory catalog (active, inactive, retired, pending approval, under review).' ;
    rdfs:domain ind:Analyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:astmMethodCode rdf:type rdf:Property ;
    rdfs:label 'Astm Method Code' ;
    rdfs:comment 'The ASTM International standard method code(s) for measuring this analyte, if applicable. Multiple methods may be comma-separated.' ;
    rdfs:domain ind:Analyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyteCategory rdf:type rdf:Property ;
    rdfs:label 'Analyte Category' ;
    rdfs:comment 'Detailed sub-classification within the analyte group (e.g., heavy metals, volatile organic compounds, disinfection byproducts, indicator organisms).' ;
    rdfs:domain ind:Analyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedAnalystRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certified Analyst Required Flag' ;
    rdfs:comment 'Indicates whether analysis of this analyte must be performed by a state-certified or specially trained analyst.' ;
    rdfs:domain ind:Analyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:analyteCode rdf:type rdf:Property ;
    rdfs:label 'Analyte Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the analyte in laboratory systems and reports. Often corresponds to LIMS internal codes or regulatory parameter codes.' ;
    rdfs:domain ind:Analyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultReportingUnit rdf:type rdf:Property ;
    rdfs:label 'Default Reporting Unit' ;
    rdfs:comment 'Standard unit of measure for reporting results for this analyte (e.g., mg/L, µg/L, CFU/100mL, NTU, pH units, pCi/L).' ;
    rdfs:domain ind:Analyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaMethodCode rdf:type rdf:Property ;
    rdfs:label 'Epa Method Code' ;
    rdfs:comment 'The EPA-approved analytical method code(s) for measuring this analyte (e.g., EPA 200.8, EPA 300.0, EPA 1103.1). Multiple methods may be comma-separated.' ;
    rdfs:domain ind:Analyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthEffect rdf:type rdf:Property ;
    rdfs:label 'Health Effect' ;
    rdfs:comment 'Summary of known or potential health effects associated with exposure to this analyte at elevated concentrations (e.g., gastrointestinal illness, neurological effects, increased cancer risk).' ;
    rdfs:domain ind:Analyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsIntegrationCode rdf:type rdf:Property ;
    rdfs:label 'Lims Integration Code' ;
    rdfs:comment 'The analyte identifier or code used in the LIMS (LabWare or similar) for system integration and data exchange.' ;
    rdfs:domain ind:Analyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumSampleVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Minimum Sample Volume Ml' ;
    rdfs:comment 'Minimum volume of sample required for analysis of this analyte, expressed in milliliters.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analyteName rdf:type rdf:Property ;
    rdfs:label 'Analyte Name' ;
    rdfs:comment 'Full descriptive name of the chemical, biological, or physical parameter being measured (e.g., Total Coliform, Lead, pH, Turbidity).' ;
    rdfs:domain ind:Analyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyTestingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Proficiency Testing Required Flag' ;
    rdfs:comment 'Indicates whether the laboratory must participate in proficiency testing programs for this analyte to maintain accreditation and regulatory compliance.' ;
    rdfs:domain ind:Analyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qaqcRequirement rdf:type rdf:Property ;
    rdfs:label 'Qaqc Requirement' ;
    rdfs:comment 'Specific QA/QC protocols required for this analyte (e.g., matrix spike/matrix spike duplicate, laboratory control sample, method blank, field duplicate, proficiency testing frequency).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleMatrixApplicability rdf:type rdf:Property ;
    rdfs:label 'Sample Matrix Applicability' ;
    rdfs:comment 'The types of sample matrices for which this analyte is applicable (e.g., drinking water, wastewater, surface water, groundwater, biosolids, sludge). Multiple matrices may be comma-separated.' ;
    rdfs:domain ind:Analyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Monitoring Flag' ;
    rdfs:comment 'Indicates whether monitoring for this analyte is required only during specific seasons or months (e.g., DBP monitoring during warmer months).' ;
    rdfs:domain ind:Analyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceOfContamination rdf:type rdf:Property ;
    rdfs:label 'Source Of Contamination' ;
    rdfs:comment 'Common sources or pathways by which this analyte enters water systems (e.g., naturally occurring, industrial discharge, agricultural runoff, corrosion of household plumbing, disinfection byproduct).' ;
    rdfs:domain ind:Analyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardMethodCode rdf:type rdf:Property ;
    rdfs:label 'Standard Method Code' ;
    rdfs:comment 'The Standard Methods for the Examination of Water and Wastewater method code(s) for measuring this analyte (e.g., SM 2320 B, SM 4500-Cl G). Multiple methods may be comma-separated.' ;
    rdfs:domain ind:Analyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryAssignedAnalystId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Assigned Analyst Id' ;
    rdfs:comment 'Assigned analyst' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertifiedAnalyst .

ind:laboratoryAssignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Assigned To Employee Id' ;
    rdfs:comment 'FK to the employee assigned to complete the corrective action' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:laboratoryComplianceCorrectiveActionId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Compliance Corrective Action Id' ;
    rdfs:comment 'References the single source of truth record in compliance.compliance_corrective_action' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceCorrectiveAction .

ind:laboratoryVerifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Verified By Employee Id' ;
    rdfs:comment 'FK to the employee who verified effectiveness' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accreditationImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Accreditation Impact Flag' ;
    rdfs:comment 'Whether the issue impacts lab accreditation' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedMethods rdf:type rdf:Property ;
    rdfs:label 'Affected Methods' ;
    rdfs:comment 'Analytical methods affected' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedResultsCount rdf:type rdf:Property ;
    rdfs:label 'Affected Results Count' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedSamplesCount rdf:type rdf:Property ;
    rdfs:label 'Affected Samples Count' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedTestMethods rdf:type rdf:Property ;
    rdfs:label 'Affected Test Methods' ;
    rdfs:comment 'Test methods affected by the issue' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Approver name.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedToName rdf:type rdf:Property ;
    rdfs:label 'Assigned To Name' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Client Notification Date' ;
    rdfs:comment 'Date client notified' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Client Notification Required' ;
    rdfs:comment 'Whether client notification is required' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Client Notified Date' ;
    rdfs:comment 'Date client was notified' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionType rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Type' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRecallRequired rdf:type rdf:Property ;
    rdfs:label 'Data Recall Required' ;
    rdfs:comment 'Whether data recall is required' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laboratoryCorrectiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Laboratory Corrective Action Description' ;
    rdfs:comment 'Description of the corrective action taken' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Date' ;
    rdfs:comment 'Date of effectiveness review' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Date' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:immediateAction rdf:type rdf:Property ;
    rdfs:label 'Immediate Action' ;
    rdfs:comment 'Immediate action taken' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'Assessment of impact on reported results' ;
    rdfs:domain ind:LaboratoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
