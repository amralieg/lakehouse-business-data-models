    rdfs:comment 'Whether cleanup was completed.' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cleanupCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cleanup Completed Timestamp' ;
    rdfs:comment 'Timestamp when cleanup was completed.' ;
