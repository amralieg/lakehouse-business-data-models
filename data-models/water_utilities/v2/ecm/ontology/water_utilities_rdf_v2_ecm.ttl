    rdfs:comment 'Total number of individual analytical tests requested across all samples in the work order. A single sample may require multiple analyses.' ;
    rdfs:domain ind:LabWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedAnalystName rdf:type rdf:Property ;
    rdfs:label 'Assigned Analyst Name' ;
    rdfs:comment 'Name of the primary analyst assigned to the work order. Used for accountability and quality assurance tracking.' ;
