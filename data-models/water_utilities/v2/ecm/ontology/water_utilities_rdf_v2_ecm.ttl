    rdfs:comment 'Description of where the overflow discharged' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'end time for overflow_event' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:environmentalImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Assessment' ;
    rdfs:comment 'Assessment of environmental impact from the overflow' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCategory rdf:type rdf:Property ;
    rdfs:label 'Event Category' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCause rdf:type rdf:Property ;
    rdfs:label 'Event Cause' ;
    rdfs:comment 'Root cause of the overflow (blockage, capacity, pump failure, I&I, power failure)' ;
    rdfs:domain ind:OverflowEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventEndTimestamp rdf:type rdf:Property ;
