    rdfs:domain ind:OnlineInstrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:accuracySpecification rdf:type rdf:Property ;
    rdfs:label 'Accuracy Specification' ;
    rdfs:comment 'Manufacturer\'s stated accuracy or precision specification for the instrument (e.g., \'±0.02 NTU\', \'±2% of reading\', \'±0.1 pH units\'). Critical for data quality assessment.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Frequency Days' ;
