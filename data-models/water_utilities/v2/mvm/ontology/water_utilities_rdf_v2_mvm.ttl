    rdfs:domain ind:PipeMain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominalDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Nominal Diameter Inches' ;
    rdfs:comment 'Nominal diameter in inches' ;
    rdfs:domain ind:PipeMain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingPressurePsi rdf:type rdf:Property ;
    rdfs:label 'Operating Pressure Psi' ;
    rdfs:comment 'Operating pressure in PSI' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipeNumber rdf:type rdf:Property ;
    rdfs:label 'Pipe Number' ;
    rdfs:comment 'Pipe identification number' ;
    rdfs:domain ind:PipeMain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipeType rdf:type rdf:Property ;
    rdfs:label 'Pipe Type' ;
    rdfs:comment 'Type of pipe' ;
    rdfs:domain ind:PipeMain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressureClassPsi rdf:type rdf:Property ;
    rdfs:label 'Pressure Class Psi' ;
    rdfs:comment 'Pressure class in PSI' ;
    rdfs:domain ind:PipeMain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:streetName rdf:type rdf:Property ;
    rdfs:label 'Street Name' ;
    rdfs:comment 'Street name' ;
    rdfs:domain ind:PipeMain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Warranty expiration date' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:connectionStatus rdf:type rdf:Property ;
    rdfs:label 'Connection Status' ;
    rdfs:comment 'Connection status' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curbStopInstalled rdf:type rdf:Property ;
    rdfs:label 'Curb Stop Installed' ;
    rdfs:comment 'Whether curb stop is installed' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:curbStopLocation rdf:type rdf:Property ;
    rdfs:label 'Curb Stop Location' ;
    rdfs:comment 'Curb stop location' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diameterInches rdf:type rdf:Property ;
    rdfs:label 'Diameter Inches' ;
    rdfs:comment 'Diameter in inches' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastLeakRepairDate rdf:type rdf:Property ;
    rdfs:label 'Last Leak Repair Date' ;
    rdfs:comment 'Last leak repair date' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lcrrClassification rdf:type rdf:Property ;
    rdfs:label 'Lcrr Classification' ;
    rdfs:comment 'LCRR material classification' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcrrInventoryVerified rdf:type rdf:Property ;
    rdfs:label 'Lcrr Inventory Verified' ;
    rdfs:comment 'Whether LCRR inventory is verified' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcrrVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Lcrr Verification Date' ;
    rdfs:comment 'LCRR verification date' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lcrrVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Lcrr Verification Method' ;
    rdfs:comment 'LCRR verification method' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leakHistoryCount rdf:type rdf:Property ;
    rdfs:label 'Leak History Count' ;
    rdfs:comment 'Number of historical leaks' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Material type' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Ownership type' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementMethod rdf:type rdf:Property ;
    rdfs:label 'Replacement Method' ;
    rdfs:comment 'Replacement method' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementPriorityScore rdf:type rdf:Property ;
    rdfs:label 'Replacement Priority Score' ;
    rdfs:comment 'Replacement priority score' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceLineNumber rdf:type rdf:Property ;
    rdfs:label 'Service Line Number' ;
    rdfs:comment 'Service line number' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State or province' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streetAddress rdf:type rdf:Property ;
    rdfs:label 'Street Address' ;
    rdfs:comment 'Street address' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapSizeInches rdf:type rdf:Property ;
    rdfs:label 'Tap Size Inches' ;
    rdfs:comment 'Tap size in inches' ;
    rdfs:domain ind:ServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryStorageFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Storage Facility Id' ;
    rdfs:comment 'Identifier of the primary storage tank or reservoir that serves this pressure zone, providing hydraulic head and emergency storage.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:arcgisFeatureCode rdf:type rdf:Property ;
    rdfs:label 'Arcgis Feature Code' ;
    rdfs:comment 'Corresponding feature identifier in the Esri ArcGIS Geographic Information System (GIS) for spatial representation and network topology management.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageDailyDemandMgd rdf:type rdf:Property ;
    rdfs:label 'Average Daily Demand Mgd' ;
    rdfs:comment 'Average daily water demand in Million Gallons per Day (MGD) for the pressure zone, used for capacity planning and hydraulic modeling.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageElevationFt rdf:type rdf:Property ;
    rdfs:label 'Average Elevation Ft' ;
    rdfs:comment 'Average ground elevation in feet above sea level across the pressure zone, used for hydraulic modeling and demand allocation.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boundaryDescription rdf:type rdf:Property ;
    rdfs:label 'Boundary Description' ;
    rdfs:comment 'Textual description of the geographic or infrastructure boundaries defining the pressure zone, including major streets, landmarks, or infrastructure features.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerCount rdf:type rdf:Property ;
    rdfs:label 'Customer Count' ;
    rdfs:comment 'Total number of active customer service connections within the pressure zone, used for demand forecasting and revenue allocation.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designPressurePsi rdf:type rdf:Property ;
    rdfs:label 'Design Pressure Psi' ;
    rdfs:comment 'Design or nominal operating pressure in Pounds per Square Inch (PSI) for which the zone infrastructure was engineered and constructed.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elevationMaxFt rdf:type rdf:Property ;
    rdfs:label 'Elevation Max Ft' ;
    rdfs:comment 'Maximum ground elevation in feet above sea level within the pressure zone boundary, critical for pressure management and PRV settings.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elevationMinFt rdf:type rdf:Property ;
    rdfs:label 'Elevation Min Ft' ;
    rdfs:comment 'Minimum ground elevation in feet above sea level within the pressure zone boundary, used for hydraulic gradient calculations.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fireFlowCapacityGpm rdf:type rdf:Property ;
    rdfs:label 'Fire Flow Capacity Gpm' ;
    rdfs:comment 'Minimum fire flow capacity in Gallons per Minute (GPM) that the pressure zone must maintain at specified residual pressure for fire protection, per Insurance Services Office (ISO) and NFPA standards.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hydraulicModelLastCalibratedDate rdf:type rdf:Property ;
    rdfs:label 'Hydraulic Model Last Calibrated Date' ;
    rdfs:comment 'Date when the hydraulic model for this pressure zone was last calibrated against field measurements, ensuring model accuracy for planning and operational decisions.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:infowaterModelZoneCode rdf:type rdf:Property ;
    rdfs:label 'Infowater Model Zone Code' ;
    rdfs:comment 'Corresponding pressure zone identifier in the Innovyze InfoWater hydraulic model, used for synchronization between operational systems and modeling platforms.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastBoundaryReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Boundary Review Date' ;
    rdfs:comment 'Date when the pressure zone boundaries were last reviewed and validated for accuracy, typically as part of GIS updates or hydraulic model recalibration.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nrwPercentage rdf:type rdf:Property ;
    rdfs:label 'Nrw Percentage' ;
    rdfs:comment 'Percentage of Non-Revenue Water (NRW) within the pressure zone, calculated as the difference between water supplied and billed consumption, used for loss control and efficiency analysis.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakHourDemandMgd rdf:type rdf:Property ;
    rdfs:label 'Peak Hour Demand Mgd' ;
    rdfs:comment 'Peak hourly water demand in Million Gallons per Day (MGD) for the pressure zone, critical for sizing infrastructure and ensuring adequate pressure during high-demand periods.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualPressureFirePsi rdf:type rdf:Property ;
    rdfs:label 'Residual Pressure Fire Psi' ;
    rdfs:comment 'Minimum residual pressure in Pounds per Square Inch (PSI) that must be maintained during fire flow conditions to ensure adequate service to other customers and fire suppression effectiveness.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scadaZoneTag rdf:type rdf:Property ;
    rdfs:label 'Scada Zone Tag' ;
    rdfs:comment 'SCADA system tag or point identifier for real-time monitoring of pressure, flow, and operational status within this zone via OSIsoft PI Historian or similar SCADA platforms.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaSqMi rdf:type rdf:Property ;
    rdfs:label 'Service Area Sq Mi' ;
    rdfs:comment 'Geographic area in square miles covered by the pressure zone, used for demand density calculations and infrastructure planning.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCapacityMg rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Mg' ;
    rdfs:comment 'Total storage capacity in Million Gallons (MG) of all tanks and reservoirs serving the pressure zone, used for emergency supply and pressure stabilization.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPressureMaxPsi rdf:type rdf:Property ;
    rdfs:label 'Target Pressure Max Psi' ;
    rdfs:comment 'Maximum target operating pressure in Pounds per Square Inch (PSI) to prevent infrastructure damage, excessive leakage, and customer service issues.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPressureMinPsi rdf:type rdf:Property ;
    rdfs:label 'Target Pressure Min Psi' ;
    rdfs:comment 'Minimum target operating pressure in Pounds per Square Inch (PSI) that must be maintained throughout the zone to ensure adequate service delivery and regulatory compliance.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ufwPercentage rdf:type rdf:Property ;
    rdfs:label 'Ufw Percentage' ;
    rdfs:comment 'Percentage of Unaccounted-for Water (UFW) within the pressure zone, representing water losses that cannot be attributed to known uses, critical for leak detection and infrastructure assessment.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Unique alphanumeric code or identifier for the pressure zone used in GIS, SCADA, and hydraulic modeling systems.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneName rdf:type rdf:Property ;
    rdfs:label 'Zone Name' ;
    rdfs:comment 'Business name or designation of the pressure zone used for operational reference and communication.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneType rdf:type rdf:Property ;
    rdfs:label 'Zone Type' ;
    rdfs:comment 'Classification of the pressure zone based on the primary method of pressure maintenance: gravity-fed from elevated storage, pumped from pump stations, combination of both, elevated tank-fed, or booster zone.' ;
    rdfs:domain ind:PressureZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averagePressurePsi rdf:type rdf:Property ;
    rdfs:label 'Average Pressure Psi' ;
    rdfs:comment 'Average operating pressure within the DMA measured in Pounds per Square Inch. Pressure management is critical for leakage control; excessive pressure increases leak rates and pipe stress.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:code rdf:type rdf:Property ;
    rdfs:label 'Code' ;
    rdfs:comment 'Business identifier code for the DMA used in operational systems, GIS, and reporting. Typically alphanumeric and unique across the distribution network.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionedDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioned Date' ;
    rdfs:comment 'Date when the DMA was decommissioned or reconfigured. Null for active DMAs. Used for historical tracking and audit purposes.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designFlowMgd rdf:type rdf:Property ;
    rdfs:label 'Design Flow Mgd' ;
    rdfs:comment 'Design flow capacity for the DMA in Million Gallons per Day. Represents the maximum daily demand the DMA is engineered to supply under normal operating conditions.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmaStatus rdf:type rdf:Property ;
    rdfs:label 'Dma Status' ;
    rdfs:comment 'Current operational status of the DMA. Active DMAs are fully operational and monitored; inactive or decommissioned DMAs are no longer in use; planned DMAs are in design phase; under review indicates reconfiguration or audit in progress.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'Date when the DMA was first established and commissioned for operational monitoring. Represents the start of the DMAs lifecycle.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gisPolygonBoundary rdf:type rdf:Property ;
    rdfs:label 'Gis Polygon Boundary' ;
    rdfs:comment 'GIS polygon geometry defining the spatial boundary of the DMA. Typically stored as WKT (Well-Known Text) or reference to GIS layer feature ID for integration with Esri ArcGIS.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inletMeterCount rdf:type rdf:Property ;
    rdfs:label 'Inlet Meter Count' ;
    rdfs:comment 'Number of inlet flow meters installed at entry points to the DMA. Inlet meters measure total water entering the zone and are critical for NRW calculation.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isolationValveCount rdf:type rdf:Property ;
    rdfs:label 'Isolation Valve Count' ;
    rdfs:comment 'Number of isolation valves installed at the DMA boundary. Isolation valves enable hydraulic isolation of the DMA for accurate flow measurement and leakage detection.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastLeakageSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Last Leakage Survey Date' ;
    rdfs:comment 'Date of the most recent active leakage detection survey conducted within the DMA. Used to track compliance with leakage management programs.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leakageDetectionFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Leakage Detection Frequency Days' ;
    rdfs:comment 'Frequency in days at which active leakage detection surveys are conducted within the DMA. High-risk or high-leakage DMAs may be surveyed more frequently.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mainLengthMiles rdf:type rdf:Property ;
    rdfs:label 'Main Length Miles' ;
    rdfs:comment 'Total length of water mains (distribution pipes) within the DMA measured in miles. Used for calculating leakage per mile of main and infrastructure density metrics.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumNightFlowThresholdGpm rdf:type rdf:Property ;
    rdfs:label 'Minimum Night Flow Threshold Gpm' ;
    rdfs:comment 'Minimum Night Flow threshold in Gallons per Minute. MNF is the lowest flow rate measured during nighttime hours (typically 2 AM to 4 AM) when legitimate consumption is minimal. Elevated MNF indicates leakage within the DMA.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScheduledSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Survey Date' ;
    rdfs:comment 'Scheduled date for the next active leakage detection survey within the DMA. Used for planning and resource allocation.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outletMeterCount rdf:type rdf:Property ;
    rdfs:label 'Outlet Meter Count' ;
    rdfs:comment 'Number of outlet flow meters installed at exit points from the DMA. Outlet meters are used in complex DMA configurations where water may flow to adjacent zones.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prvCount rdf:type rdf:Property ;
    rdfs:label 'Prv Count' ;
    rdfs:comment 'Number of Pressure Reducing Valves installed within or at the boundary of the DMA. PRVs control pressure to reduce leakage and pipe stress.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scadaMonitoredFlag rdf:type rdf:Property ;
    rdfs:label 'Scada Monitored Flag' ;
    rdfs:comment 'Indicates whether the DMA is actively monitored by the SCADA system. SCADA-monitored DMAs provide real-time flow, pressure, and alarm data for proactive leakage management.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceConnectionCount rdf:type rdf:Property ;
    rdfs:label 'Service Connection Count' ;
    rdfs:comment 'Total number of active service connections (customer meters) within the DMA. Used for calculating per-connection leakage rates and NRW metrics.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetNrwPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Nrw Percentage' ;
    rdfs:comment 'Target threshold for Non-Revenue Water as a percentage of total water supplied to the DMA. NRW includes physical losses (leakage) and commercial losses (metering inaccuracies, theft). Typical industry targets range from 10% to 20%.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetUfwPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Ufw Percentage' ;
    rdfs:comment 'Target threshold for Unaccounted-for Water as a percentage of total water supplied. UFW is a broader measure than NRW and includes all water that cannot be accounted for through billing or authorized use.' ;
    rdfs:domain ind:Dma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkValveId rdf:type rdf:Property ;
    rdfs:label 'Network Valve Id' ;
    rdfs:comment 'Unique identifier for the distribution network valve record. Primary key.' ;
    rdfs:domain ind:NetworkValve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryNetworkAssetRegistryId rdf:type rdf:Property ;
    rdfs:label 'Primary Network Asset Registry Id' ;
    rdfs:comment 'Reference to the asset registry record in the Computerized Maintenance Management System (CMMS). Links this valve to IBM Maximo Asset Management for maintenance tracking, work orders, and lifecycle management.' ;
    rdfs:domain ind:NetworkValve ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Registry .

ind:burialDepthFeet rdf:type rdf:Property ;
    rdfs:label 'Burial Depth Feet' ;
    rdfs:comment 'Depth in feet from ground surface to the valve operating nut. Used for excavation planning, valve box sizing, and accessibility assessment. Typical range is 3-8 feet depending on frost line and main depth.' ;
    rdfs:domain ind:NetworkValve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionRating rdf:type rdf:Property ;
    rdfs:label 'Condition Rating' ;
    rdfs:comment 'Assessment of the valve\'s physical condition based on the most recent inspection. Excellent: like new, no defects; Good: minor wear, fully functional; Fair: moderate wear, functional with minor issues; Poor: significant deterioration, may fail soon; Critical: immediate replacement required. Used for risk-based asset management and Capital Expenditure (CAPEX) planning.' ;
    rdfs:domain ind:NetworkValve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPosition rdf:type rdf:Property ;
    rdfs:label 'Current Position' ;
    rdfs:comment 'Actual current position of the valve as of the last field verification or SCADA reading. May differ from normal_position during maintenance, emergencies, or operational adjustments.' ;
    rdfs:domain ind:NetworkValve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exercisingFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Exercising Frequency Months' ;
    rdfs:comment 'Planned frequency in months for valve exercising activities. Typically 12 months for standard valves, 6 months for critical isolation valves, and 24 months for low-priority valves. Drives preventive maintenance scheduling in CMMS.' ;
    rdfs:domain ind:NetworkValve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBuried rdf:type rdf:Property ;
    rdfs:label 'Is Buried' ;
    rdfs:comment 'Indicates whether the valve is buried underground (True) or above ground in a vault or building (False). Buried valves require valve box access and are more difficult to exercise; above-ground valves are more accessible but require weather protection.' ;
    rdfs:domain ind:NetworkValve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMotorized rdf:type rdf:Property ;
    rdfs:label 'Is Motorized' ;
    rdfs:comment 'Indicates whether the valve is equipped with a motor or actuator for remote operation. True for SCADA-controlled valves; False for manual valves requiring field crew operation.' ;
    rdfs:domain ind:NetworkValve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastExercisedBy rdf:type rdf:Property ;
    rdfs:label 'Last Exercised By' ;
    rdfs:comment 'Name or identifier of the crew member or contractor who last exercised the valve. Supports accountability and quality assurance in valve maintenance programs.' ;
    rdfs:domain ind:NetworkValve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExercisedDate rdf:type rdf:Property ;
    rdfs:label 'Last Exercised Date' ;
    rdfs:comment 'Date the valve was last exercised (opened and closed through its full range of motion). Regular valve exercising prevents seizing and ensures operability during emergencies. AWWA recommends annual exercising for critical valves.' ;
    rdfs:domain ind:NetworkValve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this valve record was last modified. Supports change tracking, audit requirements, and data quality monitoring.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:normalPosition rdf:type rdf:Property ;
    rdfs:label 'Normal Position' ;
    rdfs:comment 'Standard operating position of the valve under normal conditions. Critical for hydraulic modeling, isolation planning, and Supervisory Control and Data Acquisition (SCADA) monitoring. Most distribution valves are normally open; some isolation and control valves are normally closed or throttled.' ;
    rdfs:domain ind:NetworkValve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressureRatingPsi rdf:type rdf:Property ;
    rdfs:label 'Pressure Rating Psi' ;
    rdfs:comment 'Maximum rated working pressure of the valve in Pounds per Square Inch (PSI) as specified by the manufacturer. Must exceed operating_pressure_psi with adequate safety margin. Common ratings are 150, 200, 250, and 300 PSI.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaTag rdf:type rdf:Property ;
    rdfs:label 'Scada Tag' ;
    rdfs:comment 'SCADA system tag identifier for automated valves with remote monitoring and control capability. Links to OSIsoft PI Historian for real-time position monitoring, alarm management, and operational analytics. Only populated for motorized or actuated valves integrated with SCADA.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnsToClose rdf:type rdf:Property ;
    rdfs:label 'Turns To Close' ;
    rdfs:comment 'Number of complete turns required to fully close the valve from the fully open position. Used by field crews during valve exercising programs and emergency isolation procedures. Typical range is 5-50 turns depending on valve size and type.' ;
    rdfs:domain ind:NetworkValve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected useful life of the valve in years from installation date. Used for depreciation calculations per Generally Accepted Accounting Principles (GAAP) and Governmental Accounting Standards Board (GASB) standards, and for long-term replacement planning. Typical range is 50-75 years for distribution valves.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valveBoxType rdf:type rdf:Property ;
    rdfs:label 'Valve Box Type' ;
    rdfs:comment 'Type of valve box or access structure protecting the buried valve. Standard boxes for sidewalk/lawn areas; traffic-rated boxes for roadways; extension boxes for deep valves; vaults for large valves; none for above-ground installations.' ;
    rdfs:domain ind:NetworkValve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valveFunction rdf:type rdf:Property ;
    rdfs:label 'Valve Function' ;
    rdfs:comment 'Primary operational function of the valve in the distribution network. Isolation valves segment the network for maintenance; control valves regulate flow; pressure reducing valves (PRV) manage pressure zones; check valves prevent backflow; air release valves expel trapped air; blowoff valves drain sections.' ;
    rdfs:domain ind:NetworkValve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valveNumber rdf:type rdf:Property ;
    rdfs:label 'Valve Number' ;
    rdfs:comment 'Externally-known business identifier for the valve, typically painted or tagged on the valve in the field. Used by operations and maintenance crews for identification.' ;
    rdfs:domain ind:NetworkValve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valveType rdf:type rdf:Property ;
    rdfs:label 'Valve Type' ;
    rdfs:comment 'Classification of the valve mechanism. Gate valves provide full flow with minimal pressure drop; butterfly valves are compact and quick-operating; ball valves offer tight shutoff; check valves prevent backflow; plug, cone, and needle valves provide throttling control. [ENUM-REF-CANDIDATE: gate|butterfly|ball|check|plug|cone|needle — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NetworkValve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hydrantId rdf:type rdf:Property ;
    rdfs:label 'Hydrant Id' ;
    rdfs:comment 'Unique identifier for the fire hydrant asset in the distribution network. Primary key.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hydrantMainPipePipeMainId rdf:type rdf:Property ;
    rdfs:label 'Hydrant Main Pipe Pipe Main Id' ;
    rdfs:comment 'Identifier of the nearest or connected water main pipe from which the hydrant is fed, used for hydraulic modeling and network topology analysis.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipeMain .

ind:hydrantPipeMainId rdf:type rdf:Property ;
    rdfs:label 'Hydrant Pipe Main Id' ;
    rdfs:comment 'Identifier of the nearest or connected water main pipe from which the hydrant is fed, used for hydraulic modeling and network topology analysis.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipeMain .

ind:isolationValveNetworkValveId rdf:type rdf:Property ;
    rdfs:label 'Isolation Valve Network Valve Id' ;
    rdfs:comment 'Foreign key linking to distribution.network_valve. Business justification: Every fire hydrant in a water distribution network has an associated isolation valve (the hydrant control valve) that is a distinct asset tracked in the network_valve table. Linking hydrant to its iso' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkValve .

ind:buryDepthFeet rdf:type rdf:Property ;
    rdfs:label 'Bury Depth Feet' ;
    rdfs:comment 'Depth in feet from ground surface to the hydrant valve or base, critical for freeze protection and installation specifications.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Status' ;
    rdfs:comment 'Current physical condition assessment of the hydrant based on inspection findings: excellent (like new), good (minor wear), fair (functional with moderate wear), poor (requires repair), critical (non-functional or unsafe).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireDistrict rdf:type rdf:Property ;
    rdfs:label 'Fire District' ;
    rdfs:comment 'Name or code of the fire protection district or fire department jurisdiction responsible for this hydrant, used for emergency response coordination.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowCapacityGpm rdf:type rdf:Property ;
    rdfs:label 'Flow Capacity Gpm' ;
    rdfs:comment 'Rated fire flow capacity of the hydrant in gallons per minute (GPM) at 20 pounds per square inch (PSI) residual pressure, determined by flow testing per NFPA 291.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flowClassColor rdf:type rdf:Property ;
    rdfs:label 'Flow Class Color' ;
    rdfs:comment 'Color coding per NFPA 291 indicating fire flow capacity class: Red (<500 GPM), Orange (500-999 GPM), Green (1000-1499 GPM), Blue (>=1500 GPM), Light Blue (>=2500 GPM). Used for visual identification by fire departments.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flushingProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Flushing Program Flag' ;
    rdfs:comment 'Boolean flag indicating whether this hydrant is included in the routine unidirectional flushing program for water quality maintenance and sediment removal.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hydrantNumber rdf:type rdf:Property ;
    rdfs:label 'Hydrant Number' ;
    rdfs:comment 'External business identifier or asset tag number assigned to the hydrant for field operations, maintenance tracking, and municipal records.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hydrantType rdf:type rdf:Property ;
    rdfs:label 'Hydrant Type' ;
    rdfs:comment 'Classification of hydrant design. Dry barrel hydrants drain after use (freeze-resistant for cold climates), wet barrel hydrants remain charged with water (warm climates), flush hydrants are below-grade, wall hydrants are building-mounted.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFlowTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Flow Test Date' ;
    rdfs:comment 'Date of the most recent fire flow test conducted on the hydrant per NFPA 291 standards, used to verify flow capacity and pressure performance.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastFlushingDate rdf:type rdf:Property ;
    rdfs:label 'Last Flushing Date' ;
    rdfs:comment 'Date when the hydrant was last used for system flushing or water quality maintenance activities.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mainDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Main Diameter Inches' ;
    rdfs:comment 'Diameter of the connected water main pipe in inches, critical for fire flow capacity calculations and hydraulic modeling.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Scheduled date for the next routine inspection of the hydrant, based on preventive maintenance (PM) schedule and regulatory requirements.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outletCount rdf:type rdf:Property ;
    rdfs:label 'Outlet Count' ;
    rdfs:comment 'Total number of discharge outlets (nozzles) on the hydrant, typically 2-5 outlets including pumper and hose connections.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outletSizeInches rdf:type rdf:Property ;
    rdfs:label 'Outlet Size Inches' ;
    rdfs:comment 'Sizes of hydrant outlets in inches, typically formatted as a comma-separated list (e.g., \'2.5,2.5,4.5\' for two 2.5-inch hose outlets and one 4.5-inch pumper outlet).' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualPressurePsi rdf:type rdf:Property ;
    rdfs:label 'Residual Pressure Psi' ;
    rdfs:comment 'Residual water pressure at the hydrant in pounds per square inch (PSI) during flow testing at rated capacity, used to assess available fire flow.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:staticPressurePsi rdf:type rdf:Property ;
    rdfs:label 'Static Pressure Psi' ;
    rdfs:comment 'Static water pressure at the hydrant location in pounds per square inch (PSI) when no water is flowing, measured during flow testing.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valveTurnsToOpen rdf:type rdf:Property ;
    rdfs:label 'Valve Turns To Open' ;
    rdfs:comment 'Number of complete turns required to fully open the hydrant main valve, used for operational training and maintenance documentation.' ;
    rdfs:domain ind:Hydrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pumpStationId rdf:type rdf:Property ;
    rdfs:label 'Pump Station Id' ;
    rdfs:comment 'Unique identifier for the booster pump station within the distribution network. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PumpStation .

ind:sourceFacilityId rdf:type rdf:Property ;
    rdfs:label 'Source Facility Id' ;
    rdfs:comment 'Foreign key linking to treatment.facility. Business justification: Pump stations receive finished water from a specific treatment facility. Hydraulic modeling, operational dispatch, and water quality compliance (chlorine residual tracking through the distribution sys' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:assetConditionRating rdf:type rdf:Property ;
    rdfs:label 'Asset Condition Rating' ;
    rdfs:comment 'Current condition assessment rating of the pump station based on inspection and maintenance records.' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupGeneratorAvailable rdf:type rdf:Property ;
    rdfs:label 'Backup Generator Available' ;
    rdfs:comment 'Indicates whether the pump station has a backup generator for emergency power supply.' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backupGeneratorCapacityKw rdf:type rdf:Property ;
    rdfs:label 'Backup Generator Capacity Kw' ;
    rdfs:comment 'Capacity of the backup generator in kilowatts (kW) if available.' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designFlowCapacityGpm rdf:type rdf:Property ;
    rdfs:label 'Design Flow Capacity Gpm' ;
    rdfs:comment 'Maximum design flow capacity of the pump station measured in gallons per minute (GPM).' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designFlowCapacityMgd rdf:type rdf:Property ;
    rdfs:label 'Design Flow Capacity Mgd' ;
    rdfs:comment 'Maximum design flow capacity of the pump station measured in million gallons per day (MGD).' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargePressurePsi rdf:type rdf:Property ;
    rdfs:label 'Discharge Pressure Psi' ;
    rdfs:comment 'Target discharge pressure in pounds per square inch (PSI) maintained by the pump station.' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hydraulicModelNodeCode rdf:type rdf:Property ;
    rdfs:label 'Hydraulic Model Node Code' ;
    rdfs:comment 'Node identifier in the Innovyze InfoWater hydraulic model representing this pump station.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximoAssetNumber rdf:type rdf:Property ;
    rdfs:label 'Maximo Asset Number' ;
    rdfs:comment 'Asset number assigned to the pump station in the IBM Maximo CMMS for maintenance management.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfDutyPumps rdf:type rdf:Property ;
    rdfs:label 'Number Of Duty Pumps' ;
    rdfs:comment 'Count of pumps designated for normal operational duty at the station.' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfPumps rdf:type rdf:Property ;
    rdfs:label 'Number Of Pumps' ;
    rdfs:comment 'Total count of pump units installed at the station, including duty and standby pumps.' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfStandbyPumps rdf:type rdf:Property ;
    rdfs:label 'Number Of Standby Pumps' ;
    rdfs:comment 'Count of pumps designated as standby or backup units for redundancy.' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powerSupplyPhase rdf:type rdf:Property ;
    rdfs:label 'Power Supply Phase' ;
    rdfs:comment 'Electrical power supply phase configuration for the pump station.' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerSupplyVoltage rdf:type rdf:Property ;
    rdfs:label 'Power Supply Voltage' ;
    rdfs:comment 'Electrical power supply voltage specification for the pump station (e.g., 480V, 4160V).' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaIntegrated rdf:type rdf:Property ;
    rdfs:label 'Scada Integrated' ;
    rdfs:comment 'Indicates whether the pump station is integrated with the SCADA system for remote monitoring and control.' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stationCode rdf:type rdf:Property ;
    rdfs:label 'Station Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the pump station for asset tracking and SCADA integration.' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationName rdf:type rdf:Property ;
    rdfs:label 'Station Name' ;
    rdfs:comment 'Business name or designation of the pump station for operational reference and reporting.' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationType rdf:type rdf:Property ;
    rdfs:label 'Station Type' ;
    rdfs:comment 'Classification of the pump station based on its operational function within the distribution network.' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suctionPressurePsi rdf:type rdf:Property ;
    rdfs:label 'Suction Pressure Psi' ;
    rdfs:comment 'Inlet or suction pressure in pounds per square inch (PSI) at the pump station intake.' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDynamicHeadFt rdf:type rdf:Property ;
    rdfs:label 'Total Dynamic Head Ft' ;
    rdfs:comment 'Total dynamic head (TDH) in feet that the pump station must overcome, including elevation and friction losses.' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vfdConfiguration rdf:type rdf:Property ;
    rdfs:label 'Vfd Configuration' ;
    rdfs:comment 'Description of the VFD configuration including number of drives and control strategy.' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vfdEquipped rdf:type rdf:Property ;
    rdfs:label 'Vfd Equipped' ;
    rdfs:comment 'Indicates whether the pump station is equipped with Variable Frequency Drive (VFD) technology for flow and pressure control.' ;
    rdfs:domain ind:PumpStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageTankId rdf:type rdf:Property ;
    rdfs:label 'Storage Tank Id' ;
    rdfs:comment 'Unique identifier for the potable water storage facility. Primary key for the storage tank master record.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageTank .

ind:primaryStorageDistrictMeteredAreaDmaId rdf:type rdf:Property ;
    rdfs:label 'Primary Storage District Metered Area Dma Id' ;
    rdfs:comment 'Reference to the District Metered Area (DMA) that this storage tank serves. DMAs are discrete zones used for water balance analysis and Non-Revenue Water (NRW) management.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dma .

ind:assetCriticalityRating rdf:type rdf:Property ;
    rdfs:label 'Asset Criticality Rating' ;
    rdfs:comment 'Risk-based criticality classification of the storage tank based on consequence of failure analysis considering population served, redundancy, and system impact: critical (single point of failure for large population), high (significant impact), medium (moderate impact), or low (minimal impact with redundancy available).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseElevationFeet rdf:type rdf:Property ;
    rdfs:label 'Base Elevation Feet' ;
    rdfs:comment 'Ground or foundation elevation (in feet above mean sea level or local datum) at the base of the storage tank structure. Used for hydraulic gradient calculations.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityGallons rdf:type rdf:Property ;
    rdfs:label 'Capacity Gallons' ;
    rdfs:comment 'Total storage capacity of the tank measured in gallons. Represents the maximum volume of potable water the tank can hold at overflow elevation.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityMillionGallons rdf:type rdf:Property ;
    rdfs:label 'Capacity Million Gallons' ;
    rdfs:comment 'Total storage capacity expressed in million gallons (MG), the standard unit for water utility storage reporting and system adequacy analysis.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coatingCondition rdf:type rdf:Property ;
    rdfs:label 'Coating Condition' ;
    rdfs:comment 'Assessment of the current condition of the tank\'s protective coating system based on the most recent inspection: excellent (no defects), good (minor wear), fair (localized deterioration), poor (widespread deterioration), or failed (coating breakdown requiring immediate attention).' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyStorageGallons rdf:type rdf:Property ;
    rdfs:label 'Emergency Storage Gallons' ;
    rdfs:comment 'Volume of water (in gallons) reserved for emergency supply during system outages, treatment plant failures, or other contingencies. Separate from fire flow reserve and operational storage.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fireFlowReserveGallons rdf:type rdf:Property ;
    rdfs:label 'Fire Flow Reserve Gallons' ;
    rdfs:comment 'Volume of water (in gallons) reserved in the storage tank to meet fire protection requirements and emergency fire flow demands as defined by local fire codes and insurance standards.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inletPipeDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Inlet Pipe Diameter Inches' ;
    rdfs:comment 'Diameter (in inches) of the primary inlet pipe supplying water to the storage tank. Used for hydraulic modeling and flow capacity analysis.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCleaningDate rdf:type rdf:Property ;
    rdfs:label 'Last Cleaning Date' ;
    rdfs:comment 'Date when the storage tank interior was last drained, cleaned, and disinfected. Regular cleaning is required to maintain water quality and prevent sediment accumulation.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCoatingDate rdf:type rdf:Property ;
    rdfs:label 'Last Coating Date' ;
    rdfs:comment 'Date when the interior or exterior protective coating was last applied or rehabilitated. Coating maintenance is critical for corrosion prevention and structural longevity.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumOperatingLevelFeet rdf:type rdf:Property ;
    rdfs:label 'Maximum Operating Level Feet' ;
    rdfs:comment 'Highest water level (in feet) at which the tank should operate under normal conditions, typically set below overflow elevation to provide freeboard and prevent overflow events.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOperatingLevelFeet rdf:type rdf:Property ;
    rdfs:label 'Minimum Operating Level Feet' ;
    rdfs:comment 'Lowest water level (in feet) at which the tank should operate under normal conditions to maintain adequate system pressure and prevent pump cavitation or structural stress.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mixingSystemInstalled rdf:type rdf:Property ;
    rdfs:label 'Mixing System Installed' ;
    rdfs:comment 'Indicates whether an active mixing system is installed in the storage tank to prevent water age stratification and maintain disinfectant residual throughout the tank volume.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mixingSystemType rdf:type rdf:Property ;
    rdfs:label 'Mixing System Type' ;
    rdfs:comment 'Type of mixing system installed: mechanical (motor-driven mixer), hydraulic (jet mixing using inlet flow), or none (no active mixing).' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outletPipeDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Outlet Pipe Diameter Inches' ;
    rdfs:comment 'Diameter (in inches) of the primary outlet pipe distributing water from the storage tank to the distribution network. Used for hydraulic modeling and flow capacity analysis.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overflowElevationFeet rdf:type rdf:Property ;
    rdfs:label 'Overflow Elevation Feet' ;
    rdfs:comment 'Elevation (in feet above mean sea level or local datum) at which the tank overflow pipe is located. Represents the absolute maximum water level before overflow discharge occurs.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overflowPipeDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Overflow Pipe Diameter Inches' ;
    rdfs:comment 'Diameter (in inches) of the overflow pipe that prevents tank overfilling by discharging excess water when the maximum level is reached.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this storage tank record was first created in the system. Used for data lineage and audit trail purposes.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this storage tank record was last modified. Used for data lineage, change tracking, and audit trail purposes.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Status' ;
    rdfs:comment 'Current compliance status with state drinking water program and EPA inspection requirements: compliant (meets all requirements), non-compliant (deficiencies identified), pending-review (inspection submitted awaiting approval), or not-applicable (exempt from inspection requirements).' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaFlowMeterTag rdf:type rdf:Property ;
    rdfs:label 'Scada Flow Meter Tag' ;
    rdfs:comment 'OSIsoft PI Historian tag name for the flow meter measuring inflow or outflow (GPM or MGD) from this storage tank. Used for demand analysis and water balance calculations.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaLevelSensorTag rdf:type rdf:Property ;
    rdfs:label 'Scada Level Sensor Tag' ;
    rdfs:comment 'OSIsoft PI Historian tag name for the real-time water level sensor monitoring this storage tank. Used to retrieve current level, historical trends, and alarm conditions from the SCADA system.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaPressureSensorTag rdf:type rdf:Property ;
    rdfs:label 'Scada Pressure Sensor Tag' ;
    rdfs:comment 'OSIsoft PI Historian tag name for the pressure sensor monitoring outlet pressure (PSI) from this storage tank. Used for hydraulic performance monitoring and pressure zone management.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securitySystemInstalled rdf:type rdf:Property ;
    rdfs:label 'Security System Installed' ;
    rdfs:comment 'Indicates whether physical security systems (fencing, locks, intrusion detection, surveillance cameras) are installed to protect the storage tank from unauthorized access and potential contamination threats.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:structuralCondition rdf:type rdf:Property ;
    rdfs:label 'Structural Condition' ;
    rdfs:comment 'Overall structural integrity assessment of the storage tank based on the most recent inspection: excellent (no defects), good (minor issues), fair (moderate deterioration), poor (significant deterioration requiring repair), or critical (unsafe condition requiring immediate action).' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tankMaterial rdf:type rdf:Property ;
    rdfs:label 'Tank Material' ;
    rdfs:comment 'Primary construction material of the storage tank structure: steel (welded or bolted), concrete (cast-in-place or precast), prestressed concrete, composite (steel and concrete), or fiberglass.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tankName rdf:type rdf:Property ;
    rdfs:label 'Tank Name' ;
    rdfs:comment 'Common name or designation of the storage tank, often referencing geographic location or service area (e.g., \'Hillside Elevated Tank\', \'Downtown Reservoir\').' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tankNumber rdf:type rdf:Property ;
    rdfs:label 'Tank Number' ;
    rdfs:comment 'Business identifier or asset tag assigned to the storage tank for operational reference and field identification.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tankType rdf:type rdf:Property ;
    rdfs:label 'Tank Type' ;
    rdfs:comment 'Classification of storage tank by structural configuration: elevated (water tower), ground-level (surface reservoir), standpipe (tall cylindrical), reservoir (large capacity ground storage), clearwell (treated water storage at WTP), or hydropneumatic (pressure tank).' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usableCapacityGallons rdf:type rdf:Property ;
    rdfs:label 'Usable Capacity Gallons' ;
    rdfs:comment 'Effective storage capacity available for distribution operations, calculated as the volume between minimum operating level and overflow elevation. Excludes dead storage below minimum operating level.' ;
    rdfs:domain ind:StorageTank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowReadingId rdf:type rdf:Property ;
    rdfs:label 'Flow Reading Id' ;
    rdfs:comment 'Unique identifier for the flow measurement record. Primary key for the flow reading transaction.' ;
    rdfs:domain ind:FlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alarmFlag rdf:type rdf:Property ;
    rdfs:label 'Alarm Flag' ;
    rdfs:comment 'Indicates whether this flow reading triggered an alarm condition in the SCADA system (e.g., flow exceeds threshold, negative flow, meter communication failure).' ;
    rdfs:domain ind:FlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alarmType rdf:type rdf:Property ;
    rdfs:label 'Alarm Type' ;
    rdfs:comment 'Classification of the alarm condition if alarm_flag is true. [ENUM-REF-CANDIDATE: high_flow|low_flow|no_flow|reverse_flow|communication_failure|meter_fault|pressure_deviation|temperature_anomaly|data_gap|validation_failure — promote to reference product]' ;
    rdfs:domain ind:FlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Flag' ;
    rdfs:comment 'Indicates whether this flow reading is used for bulk water billing or wholesale customer invoicing (e.g., inter-utility transfers, industrial bulk customers).' ;
    rdfs:domain ind:FlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'Date of the most recent meter calibration prior to this reading. Used to assess measurement reliability and schedule recalibration.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text field for operator notes, validation comments, or explanations of anomalies in the flow reading. Used for audit trail and troubleshooting.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFlag rdf:type rdf:Property ;
    rdfs:label 'Estimated Flag' ;
    rdfs:comment 'Indicates whether the flow value is an estimated or interpolated value rather than a direct meter reading. True when meter communication fails or reading is missing.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimationMethod rdf:type rdf:Property ;
    rdfs:label 'Estimation Method' ;
    rdfs:comment 'Method used to estimate the flow value when direct measurement is unavailable. None indicates a direct measured value.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowDirection rdf:type rdf:Property ;
    rdfs:label 'Flow Direction' ;
    rdfs:comment 'Direction of water flow at the measurement point. Inflow = water entering the zone/DMA, Outflow = water leaving the zone/DMA, Bidirectional = flow can reverse direction.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowValue rdf:type rdf:Property ;
    rdfs:label 'Flow Value' ;
    rdfs:comment 'The raw flow measurement value as captured by the meter. Represents instantaneous flow rate or cumulative volume depending on measurement type. Used with engineering_unit to interpret the measurement.' ;
    rdfs:domain ind:FlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hydraulicModelFlag rdf:type rdf:Property ;
    rdfs:label 'Hydraulic Model Flag' ;
    rdfs:comment 'Indicates whether this flow reading is used for hydraulic model calibration in Innovyze InfoWater or similar distribution network modeling software.' ;
    rdfs:domain ind:FlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intervalDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Interval Duration Minutes' ;
    rdfs:comment 'Time interval in minutes over which the flow measurement was aggregated or averaged. Common values: 15, 30, 60 minutes for SCADA polling intervals.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'Classification of the flow measurement: instantaneous (real-time snapshot), cumulative (totalizer reading), average (calculated over interval), peak (maximum in interval), or minimum (lowest in interval).' ;
    rdfs:domain ind:FlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterAccuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Meter Accuracy Percent' ;
    rdfs:comment 'The rated accuracy of the flow meter at the time of this reading, expressed as a percentage. Used to calculate measurement uncertainty for water balance calculations.' ;
    rdfs:domain ind:FlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nrwCalculationFlag rdf:type rdf:Property ;
    rdfs:label 'Nrw Calculation Flag' ;
    rdfs:comment 'Indicates whether this flow reading is included in Non-Revenue Water (NRW) or Unaccounted-for Water (UFW) balance calculations for the associated DMA.' ;
    rdfs:domain ind:FlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pressurePsi rdf:type rdf:Property ;
    rdfs:label 'Pressure Psi' ;
    rdfs:comment 'Water pressure measurement in PSI at the flow measurement point, captured concurrently with the flow reading. Used for hydraulic model calibration and pressure zone analysis.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scadaTagName rdf:type rdf:Property ;
    rdfs:label 'Scada Tag Name' ;
    rdfs:comment 'The SCADA system tag or point identifier that sourced this flow reading. Used for traceability back to the PI Historian or SCADA historian database.' ;
    rdfs:domain ind:FlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureF rdf:type rdf:Property ;
    rdfs:label 'Temperature F' ;
    rdfs:comment 'Water temperature in degrees Fahrenheit at the measurement point. Used for flow compensation calculations and water quality correlation analysis.' ;
    rdfs:domain ind:FlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalizerReading rdf:type rdf:Property ;
    rdfs:label 'Totalizer Reading' ;
    rdfs:comment 'Cumulative volume reading from the meter totalizer register. Used to calculate interval consumption by differencing consecutive readings. Typically in gallons or cubic meters.' ;
    rdfs:domain ind:FlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validatedBy rdf:type rdf:Property ;
    rdfs:label 'Validated By' ;
    rdfs:comment 'User ID or system process name that performed the validation of this flow reading. Used for audit trail and accountability.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current validation state of the flow reading. Pending = awaiting review, Validated = approved by operator or automated validation, Rejected = failed validation rules, Corrected = manually adjusted after validation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when the flow reading was validated or reviewed by an operator or automated validation process.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureRecordId rdf:type rdf:Property ;
    rdfs:label 'Failure Record Id' ;
    rdfs:comment 'Foreign key linking to asset.failure_record. Business justification: Main breaks are asset failure events requiring root cause analysis, MTBF/MTTR tracking, failure mode classification, and reliability analysis. Links distribution failures to enterprise failure trackin' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FailureRecord .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Reference to the work order created in the CMMS (Computerized Maintenance Management System) for the repair activity. Links to IBM Maximo Asset Management work order.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:affectedZones rdf:type rdf:Property ;
    rdfs:label 'Affected Zones' ;
    rdfs:comment 'Comma-separated list of affected pressure zones or DMAs' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boilWaterAdvisoryIssued rdf:type rdf:Property ;
    rdfs:label 'Boil Water Advisory Issued' ;
    rdfs:comment 'Indicates whether a boil water advisory was issued to affected customers due to potential water quality compromise. True if advisory was issued, False otherwise.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakNumber rdf:type rdf:Property ;
    rdfs:label 'Break Number' ;
    rdfs:comment 'Business identifier for the main break event, typically formatted as MB-YYYYNNNNNN for external reference and reporting.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakStatus rdf:type rdf:Property ;
    rdfs:label 'Break Status' ;
    rdfs:comment 'Current lifecycle status of the main break event: reported, dispatched, in progress, repaired, closed, or deferred.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakTimestamp rdf:type rdf:Property ;
    rdfs:label 'Break Timestamp' ;
    rdfs:comment 'Date and time when the main break was first detected or reported. Principal business event timestamp for the break occurrence.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breakType rdf:type rdf:Property ;
    rdfs:label 'Break Type' ;
    rdfs:comment 'Classification of the main break failure mode: circumferential crack, longitudinal crack, blowout, joint failure, service line break, or corrosion pinhole.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customersAffectedCount rdf:type rdf:Property ;
    rdfs:label 'Customers Affected Count' ;
    rdfs:comment 'Number of customer accounts impacted by service disruption due to the main break.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispatchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatch Timestamp' ;
    rdfs:comment 'Date and time when field crew was dispatched to the main break location.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedRestorationAt rdf:type rdf:Property ;
    rdfs:label 'Expected Restoration At' ;
    rdfs:comment 'Expected service restoration timestamp' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locationAddress rdf:type rdf:Property ;
    rdfs:label 'Location Address' ;
    rdfs:comment 'Street address or nearest intersection where the main break occurred. Organizational location data classified as confidential.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationLatitude rdf:type rdf:Property ;
    rdfs:label 'Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (decimal degrees) of the main break location for GIS mapping and spatial analysis.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationLongitude rdf:type rdf:Property ;
    rdfs:label 'Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (decimal degrees) of the main break location for GIS mapping and spatial analysis.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipeAgeYears rdf:type rdf:Property ;
    rdfs:label 'Pipe Age Years' ;
    rdfs:comment 'Estimated age of the pipe at the time of break, calculated from installation date to break date, measured in years.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pipeDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Pipe Diameter Inches' ;
    rdfs:comment 'Nominal diameter of the failed pipe in inches.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipeMaterial rdf:type rdf:Property ;
    rdfs:label 'Pipe Material' ;
    rdfs:comment 'Material composition of the failed pipe: cast iron, ductile iron, PVC (polyvinyl chloride), HDPE (high-density polyethylene), steel, concrete, asbestos cement, or copper. [ENUM-REF-CANDIDATE: cast_iron|ductile_iron|pvc|hdpe|steel|concrete|asbestos_cement|copper — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationAtRisk rdf:type rdf:Property ;
    rdfs:label 'Population At Risk' ;
    rdfs:comment 'Estimated population affected by the main break' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryReportRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Required' ;
    rdfs:comment 'Indicates whether the main break requires regulatory reporting to EPA, state primacy agency, or Public Utilities Commission. True if reporting is required, False otherwise.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repairCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Repair Complete Timestamp' ;
    rdfs:comment 'Date and time when repair work was completed and the main was returned to service.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:repairDurationHours rdf:type rdf:Property ;
    rdfs:label 'Repair Duration Hours' ;
    rdfs:comment 'Total duration of the repair activity from start to completion, measured in hours.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repairMethod rdf:type rdf:Property ;
    rdfs:label 'Repair Method' ;
    rdfs:comment 'Method used to repair the main break: clamp, sleeve, pipe replacement, joint repair, valve replacement, or temporary bypass.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Repair Start Timestamp' ;
    rdfs:comment 'Date and time when repair work commenced on the main break.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'Source of the main break report: customer, field crew, SCADA alert, patrol, third party, or internal inspection.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soilCondition rdf:type rdf:Property ;
    rdfs:label 'Soil Condition' ;
    rdfs:comment 'Soil condition at the break location: clay, sand, gravel, rock, mixed, corrosive, saturated, or unknown. Influences corrosion rates and pipe stability. [ENUM-REF-CANDIDATE: clay|sand|gravel|rock|mixed|corrosive|saturated|unknown — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficImpact rdf:type rdf:Property ;
    rdfs:label 'Traffic Impact' ;
    rdfs:comment 'Impact of the main break on traffic and road access: none, lane closure, road closure, detour required, or emergency access restricted.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterLostGallons rdf:type rdf:Property ;
    rdfs:label 'Water Lost Gallons' ;
    rdfs:comment 'Estimated volume of water lost during the break event, measured in gallons. Critical for NRW (Non-Revenue Water) and UFW (Unaccounted-for Water) reporting.' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherCondition rdf:type rdf:Property ;
    rdfs:label 'Weather Condition' ;
    rdfs:comment 'Weather condition at the time of the break: normal, freezing, extreme cold, heavy rain, drought, snow, or extreme heat. Relevant for freeze-thaw and soil movement analysis. [ENUM-REF-CANDIDATE: normal|freezing|extreme_cold|heavy_rain|drought|snow|extreme_heat — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MainBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Primary key' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:billingReadId rdf:type rdf:Property ;
    rdfs:label 'Billing Read Id' ;
    rdfs:comment 'Foreign key linking to metering.read. Business justification: Billing read reconciliation: auditors and regulators require tracing which meter read triggered each invoice. For non-AMI meters, the standard read drives invoice generation. Role-prefix \'billing_\' di' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Read .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Total adjustments applied' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of billing period' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of billing period' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ccrIncluded rdf:type rdf:Property ;
    rdfs:label 'Ccr Included' ;
    rdfs:comment 'Consumer Confidence Report included flag' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conservationMessage rdf:type rdf:Property ;
    rdfs:label 'Conservation Message' ;
    rdfs:comment 'Conservation message text' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO currency code' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Invoice delivery method' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disconnectionDate rdf:type rdf:Property ;
    rdfs:label 'Disconnection Date' ;
    rdfs:comment 'Scheduled disconnection date' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Invoice disputed flag' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Payment due date' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generationMethod rdf:type rdf:Property ;
    rdfs:label 'Generation Method' ;
    rdfs:comment 'Invoice generation method' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Invoice issue date' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Unique invoice number' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Invoice status' ;
