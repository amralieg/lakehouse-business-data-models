    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateComponent .

ind:readId rdf:type rdf:Property ;
    rdfs:label 'Read Id' ;
    rdfs:comment 'Foreign key linking to metering.read. Business justification: Non-AMI invoice lines are calculated from a standard meter read. The existing interval_consumption_id covers AMI data; read_id covers manual/AMR reads. Revenue audits and billing dispute resolution re' ;
