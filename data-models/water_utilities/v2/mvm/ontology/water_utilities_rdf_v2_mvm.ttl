    rdfs:label 'Is Public Notification Required' ;
    rdfs:comment 'Whether public notification is required.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationTier rdf:type rdf:Property ;
    rdfs:label 'Notification Tier' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Penalty amount assessed.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Usd' ;
    rdfs:comment 'Monetary penalty assessed in USD' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:populationAffected rdf:type rdf:Property ;
    rdfs:label 'Population Affected' ;
    rdfs:comment 'Number of people affected.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Public Notification Date' ;
    rdfs:comment 'Date public notification was issued.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicNotificationIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Public Notification Issued Date' ;
    rdfs:comment 'Date public notification was issued' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulationCitation rdf:type rdf:Property ;
    rdfs:label 'Regulation Citation' ;
    rdfs:comment 'Regulatory citation breached.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAgencyNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency Notified Date' ;
    rdfs:comment 'Date the regulatory agency was notified' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryLimit rdf:type rdf:Property ;
    rdfs:label 'Regulatory Limit' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryStandard rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedToEpaDate rdf:type rdf:Property ;
    rdfs:label 'Reported To Epa Date' ;
    rdfs:comment 'Date violation was reported to EPA' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedToStateDate rdf:type rdf:Property ;
    rdfs:label 'Reported To State Date' ;
    rdfs:comment 'Date violation was reported to the state primacy agency' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnToComplianceDate rdf:type rdf:Property ;
    rdfs:label 'Return To Compliance Date' ;
    rdfs:comment 'Date returned to compliance.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rtcDate rdf:type rdf:Property ;
    rdfs:label 'Rtc Date' ;
    rdfs:comment 'Date the system returned to compliance' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Regulatory rule code (e.g., SWTR, LCR, TCR, DBP)' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Full name of the regulatory rule violated.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdwisViolationNumber rdf:type rdf:Property ;
    rdfs:label 'Sdwis Violation Number' ;
    rdfs:comment 'Violation ID in the Safe Drinking Water Information System.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Severity level (Tier 1, Tier 2, Tier 3).' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDate rdf:type rdf:Property ;
    rdfs:label 'Violation Date' ;
    rdfs:comment 'Date the violation occurred.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationNumber rdf:type rdf:Property ;
    rdfs:label 'Violation Number' ;
    rdfs:comment 'Unique violation tracking number.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationStatus rdf:type rdf:Property ;
    rdfs:label 'Violation Status' ;
    rdfs:comment 'Current status (Open, Resolved, Under Review).' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'Type of violation (MCL, Monitoring, Treatment Technique, Reporting).' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionDate rdf:type rdf:Property ;
    rdfs:label 'Action Date' ;
    rdfs:comment 'Action date' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Official enforcement action number or case number assigned by the regulatory agency (EPA, state primacy agency, NPDES authority). This is the externally-known identifier used in all regulatory correspondence and legal documents.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle status of the enforcement action. Tracks progression from issuance through utility response, negotiation, and final resolution.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionSummary rdf:type rdf:Property ;
    rdfs:label 'Action Summary' ;
    rdfs:comment 'Brief summary of the enforcement action, including the nature of the violation, regulatory basis, and key requirements. Provides context for reporting and management review.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Type of formal enforcement action initiated by the regulatory agency. Includes Notice of Violation (NOV), Administrative Order (AO), Consent Order, Compliance Schedule, civil penalty assessment, or criminal referral.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether the utility filed a formal appeal or contested the enforcement action through administrative or judicial proceedings.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealFilingDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filing Date' ;
    rdfs:comment 'Date the utility filed its appeal or petition for review. Null if no appeal was filed.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Board Notification Date' ;
    rdfs:comment 'Date the utility\'s Board of Directors or governing body was notified of the enforcement action. Tracks governance and executive oversight requirements.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:civilPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Civil Penalty Amount' ;
    rdfs:comment 'Monetary penalty amount assessed by the regulatory agency in U.S. dollars. Null if no civil penalty was imposed.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceScheduleFinalDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule Final Deadline' ;
    rdfs:comment 'Final deadline by which all corrective actions and compliance milestones must be completed. Null if no compliance schedule is required.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceScheduleRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule Required Flag' ;
    rdfs:comment 'Indicates whether the enforcement action includes a formal compliance schedule with milestones and deadlines for corrective actions.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Document Reference Number' ;
    rdfs:comment 'Internal document management system reference number for the enforcement action file. Links to stored correspondence, legal documents, and supporting materials.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAgencyRegion rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency Region' ;
    rdfs:comment 'Regional office, district, or jurisdiction of the issuing agency (e.g., EPA Region 5, Northwest Regional Office). Identifies the specific regulatory authority within the agency structure.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselAssigned rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Assigned' ;
    rdfs:comment 'Name of the internal or external legal counsel assigned to manage the utility\'s response to the enforcement action. Business-confidential information.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalFirmName rdf:type rdf:Property ;
    rdfs:label 'Legal Firm Name' ;
    rdfs:comment 'Name of the external law firm representing the utility, if external counsel is engaged. Null if handled internally.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Paid Amount' ;
    rdfs:comment 'Actual amount paid by the utility toward the civil penalty. May differ from assessed amount due to negotiated settlements or payment plans.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Penalty Payment Date' ;
    rdfs:comment 'Date the civil penalty payment was made to the regulatory agency. Tracks compliance with payment deadlines.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Public Notice Date' ;
    rdfs:comment 'Date public notice of the enforcement action was issued. Null if public notice is not required.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicNoticeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Public Notice Required Flag' ;
    rdfs:comment 'Indicates whether the enforcement action requires public notification under regulatory or consent order terms. Drives public communication and transparency obligations.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome of the enforcement action. Indicates how the action was resolved (compliance achieved, consent order executed, penalty paid, dismissed, or under appeal).' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Deadline by which the utility must submit a formal response to the enforcement action. Typically specified in the enforcement notice or calculated based on regulatory timelines.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Date the utility submitted its formal response to the enforcement action. Tracks compliance with response deadlines.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sepDescription rdf:type rdf:Property ;
    rdfs:label 'Sep Description' ;
    rdfs:comment 'Description of the Supplemental Environmental Project (SEP) agreed to as part of the enforcement settlement. Null if no SEP is included.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sepEstimatedCost rdf:type rdf:Property ;
    rdfs:label 'Sep Estimated Cost' ;
    rdfs:comment 'Estimated cost of the Supplemental Environmental Project (SEP) in U.S. dollars. Used to calculate penalty offsets and track SEP investment.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplementalEnvironmentalProjectFlag rdf:type rdf:Property ;
    rdfs:label 'Supplemental Environmental Project Flag' ;
    rdfs:comment 'Indicates whether the enforcement action includes a Supplemental Environmental Project (SEP) as part of the settlement. SEPs are environmentally beneficial projects that go beyond compliance requirements and may offset civil penalties.' ;
    rdfs:domain ind:EnforcementAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Indicates whether corrective actions are required by the utility in response to inspection findings.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionSummary rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Summary' ;
    rdfs:comment 'Summary of the corrective actions required to address deficiencies and achieve compliance.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Deficiency Count' ;
    rdfs:comment 'Total number of deficiencies or non-compliance items identified during the inspection.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'High-level summary of the inspection findings, deficiencies identified, and overall compliance status.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Inspection Required Flag' ;
    rdfs:comment 'Indicates whether a follow-up inspection by the regulatory agency is required to verify corrective action completion.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpInspectionScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Inspection Scheduled Date' ;
    rdfs:comment 'Scheduled date for the follow-up inspection if required.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectingAgency rdf:type rdf:Property ;
    rdfs:label 'Inspecting Agency' ;
    rdfs:comment 'Name of the regulatory body or agency that conducted the inspection (EPA, state primacy agency, local health department, etc.).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'Date on which the regulatory inspection was conducted at the facility.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionEndTime rdf:type rdf:Property ;
    rdfs:label 'Inspection End Time' ;
    rdfs:comment 'Timestamp when the on-site inspection activity concluded.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Internal notes and observations recorded by utility staff during or after the inspection for follow-up and documentation purposes.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Externally-known unique identifier or reference number assigned by the regulatory agency for this inspection.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Received Date' ;
    rdfs:comment 'Date on which the utility received the official inspection report from the regulatory agency.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionReportStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Status' ;
    rdfs:comment 'Current status of the official inspection report (draft, final, under review, accepted, disputed).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionScope rdf:type rdf:Property ;
    rdfs:label 'Inspection Scope' ;
    rdfs:comment 'Description of the areas, processes, or systems covered during the inspection (e.g., treatment processes, discharge monitoring, pretreatment program, laboratory practices).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartTime rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Time' ;
    rdfs:comment 'Timestamp when the on-site inspection activity began.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle status of the inspection (scheduled, in progress, completed, report pending, closed, cancelled).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Classification of the inspection activity (sanitary survey, compliance inspection, pretreatment audit, NPDES inspection, routine inspection, follow-up inspection, complaint investigation). [ENUM-REF-CANDIDATE: sanitary_survey|compliance_inspection|pretreatment_audit|npdes_inspection|routine_inspection|follow_up_inspection|complaint_investigation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Inspector Contact Email' ;
    rdfs:comment 'Email address of the lead inspector for official correspondence.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Inspector Contact Phone' ;
    rdfs:comment 'Phone number of the lead inspector for follow-up communication.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorTitle rdf:type rdf:Property ;
    rdfs:label 'Inspector Title' ;
    rdfs:comment 'Job title or role of the lead inspector (e.g., Environmental Compliance Officer, Sanitary Survey Specialist).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:significantDeficiencyClassification rdf:type rdf:Property ;
    rdfs:label 'Significant Deficiency Classification' ;
    rdfs:comment 'Classification or category of the significant deficiency if identified (e.g., treatment process failure, monitoring inadequacy, operational deficiency).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:significantDeficiencyFlag rdf:type rdf:Property ;
    rdfs:label 'Significant Deficiency Flag' ;
    rdfs:comment 'Indicates whether any significant deficiencies (as defined by SDWA) were identified that could affect water quality or public health.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utilityRepresentativeTitle rdf:type rdf:Property ;
    rdfs:label 'Utility Representative Title' ;
    rdfs:comment 'Job title of the utility representative who coordinated the inspection (e.g., Compliance Manager, Plant Superintendent).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Violation Identified Flag' ;
    rdfs:comment 'Indicates whether any regulatory violations (SDWA, CWA, NPDES permit) were formally identified during the inspection.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalSubmissionRegulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Original Submission Regulatory Submission Id' ;
    rdfs:comment 'Reference to the original submission record if this submission is a correction, amendment, or resubmission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatorySubmission .

ind:acknowledgmentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Received Date' ;
    rdfs:comment 'The date on which the regulatory agency acknowledged receipt of the submission (via NetDMR confirmation, email reply, or other means).' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Reference Number' ;
    rdfs:comment 'The confirmation or tracking number provided by the regulatory agency upon receipt of the submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyComments rdf:type rdf:Property ;
    rdfs:label 'Agency Comments' ;
    rdfs:comment 'Comments, feedback, or instructions provided by the regulatory agency regarding the submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyResponseDate rdf:type rdf:Property ;
    rdfs:label 'Agency Response Date' ;
    rdfs:comment 'The date on which the regulatory agency provided a formal response, feedback, or determination regarding the submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyResponseType rdf:type rdf:Property ;
    rdfs:label 'Agency Response Type' ;
    rdfs:comment 'The type of response or action taken by the regulatory agency in response to the submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Explanation of why the submission was amended or corrected, including the nature of the error or omission in the original submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'The date on which the certifying official signed and certified the submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceedanceCount rdf:type rdf:Property ;
    rdfs:label 'Exceedance Count' ;
    rdfs:comment 'The number of parameter exceedances (values above permit limits but not necessarily violations) reported in this submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAmendment rdf:type rdf:Property ;
    rdfs:label 'Is Amendment' ;
    rdfs:comment 'Indicates whether this submission is an amendment or correction to a previously submitted report.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLateSubmission rdf:type rdf:Property ;
    rdfs:label 'Is Late Submission' ;
    rdfs:comment 'Indicates whether the submission was filed after the regulatory due date, which may trigger enforcement action or violation notices.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noncomplianceExplanation rdf:type rdf:Property ;
    rdfs:label 'Noncompliance Explanation' ;
    rdfs:comment 'Narrative explanation provided by the utility for any violations, exceedances, or non-compliance events reported in the submission, including corrective actions taken or planned.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicNoticeRequired rdf:type rdf:Property ;
    rdfs:label 'Public Notice Required' ;
    rdfs:comment 'Indicates whether this submission requires public notification (e.g., CCR publication, SSO public notice, boil water advisory).' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'The ending date of the time period covered by this regulatory submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'The beginning date of the time period covered by this regulatory submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Resubmission Required' ;
    rdfs:comment 'Indicates whether the regulatory agency has requested a corrected or amended resubmission of the report.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionFileFormat rdf:type rdf:Property ;
    rdfs:label 'Submission File Format' ;
    rdfs:comment 'The file format or media type of the submitted report.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionFilePath rdf:type rdf:Property ;
    rdfs:label 'Submission File Path' ;
    rdfs:comment 'The file system path or document management system reference to the submitted report document (PDF, XML, CSV, etc.).' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionNotes rdf:type rdf:Property ;
    rdfs:label 'Submission Notes' ;
    rdfs:comment 'Internal notes, comments, or additional context regarding the preparation, submission, or follow-up actions for this regulatory submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Number' ;
    rdfs:comment 'Business identifier or tracking number assigned to the regulatory submission, often used for external reference and correspondence with regulatory agencies.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory submission indicating its progress through the submission and review workflow.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionType rdf:type rdf:Property ;
    rdfs:label 'Submission Type' ;
    rdfs:comment 'Category of regulatory submission. DMR = Discharge Monitoring Report, MOR = Monthly Operating Report, CCR = Consumer Confidence Report, SSO = Sanitary Sewer Overflow, CSO = Combined Sewer Overflow, PFAS = Per- and Polyfluoroalkyl Substances, LCRR = Lead and Copper Rule Revisions. [ENUM-REF-CANDIDATE: DMR|MOR|CCR|SSO_notification|CSO_notification|pretreatment_report|annual_report|PFAS_report|LCRR_inventory|permit_application|variance_request|other — promote to reference product]' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCount rdf:type rdf:Property ;
    rdfs:label 'Violation Count' ;
    rdfs:comment 'The number of permit limit violations or non-compliance events reported in this submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentRegulatoryAgencyId rdf:type rdf:Property ;
    rdfs:label 'Parent Regulatory Agency Id' ;
    rdfs:comment 'Self-referencing FK on regulatory_agency (parent_regulatory_agency_id)' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAgency .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line for the regulatory agency headquarters or regional office.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for suite, floor, or building information.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyAcronym rdf:type rdf:Property ;
    rdfs:label 'Agency Acronym' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyCode rdf:type rdf:Property ;
    rdfs:label 'Agency Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the regulatory agency within the utility\'s systems (e.g., EPA_R5, STATE_DNR, PUC_WI).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyLevel rdf:type rdf:Property ;
    rdfs:label 'Agency Level' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyMainEmail rdf:type rdf:Property ;
    rdfs:label 'Agency Main Email' ;
    rdfs:comment 'General inquiry or main email address for the regulatory agency.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyMainPhone rdf:type rdf:Property ;
    rdfs:label 'Agency Main Phone' ;
    rdfs:comment 'Main switchboard or general inquiry phone number for the regulatory agency.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Full legal name of the regulatory agency or governing body (e.g., U.S. Environmental Protection Agency Region 5, Wisconsin Department of Natural Resources).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyShortName rdf:type rdf:Property ;
    rdfs:label 'Agency Short Name' ;
    rdfs:comment 'Abbreviated or commonly used name for the agency (e.g., EPA Region 5, WI DNR, OSHA).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyStatus rdf:type rdf:Property ;
    rdfs:label 'Agency Status' ;
    rdfs:comment 'Current operational status of the regulatory agency (active, inactive, merged, dissolved).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Classification of the regulatory agency by its primary regulatory focus (environmental, health, safety, rate regulatory, labor, quality standards, other). [ENUM-REF-CANDIDATE: environmental|health|safety|rate_regulatory|labor|quality_standards|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Agency Website Url' ;
    rdfs:comment 'Official website URL for the regulatory agency.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessHours rdf:type rdf:Property ;
    rdfs:label 'Business Hours' ;
    rdfs:comment 'Standard business hours of operation for the regulatory agency office (e.g., Monday-Friday 8:00 AM - 5:00 PM PST).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment '24-hour emergency contact phone number for reporting spills, violations, or urgent compliance matters.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Enforcement Authority Level' ;
    rdfs:comment 'Level of enforcement authority this agency holds over the utility (primary, delegated, advisory, none). Primary indicates direct enforcement power; delegated indicates authority granted by a higher-level agency; advisory indicates no direct enforcement.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euDirectiveScope rdf:type rdf:Property ;
    rdfs:label 'Eu Directive Scope' ;
    rdfs:comment 'Comma-separated list of EU directives this agency administers (DWD_2020_2184, REACH, WFD_2000_60, UWWTD_91_271).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euMemberState rdf:type rdf:Property ;
    rdfs:label 'Eu Member State' ;
    rdfs:comment 'For EU-region agencies, the EU member state code (e.g. DE, FR, NL). NULL for non-EU agencies.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euMemberStateCode rdf:type rdf:Property ;
    rdfs:label 'Eu Member State Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 code for EU member state where this agency has competent authority (e.g. DE, FR, NL). NULL for non-EU agencies.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for document submission to the regulatory agency, if applicable.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Months' ;
    rdfs:comment 'Typical frequency in months at which this regulatory agency conducts inspections of utility facilities under its jurisdiction.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionFrequencyTypical rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Typical' ;
    rdfs:comment 'Typical frequency at which this agency conducts inspections or audits of utility facilities (annual, biennial, triennial, as-needed, risk-based).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internationalAgencyFlag rdf:type rdf:Property ;
    rdfs:label 'International Agency Flag' ;
    rdfs:comment 'True for non-US (EU/FR/UK/DE) regulatory agencies.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionGeographicArea rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Geographic Area' ;
    rdfs:comment 'Geographic area or service territory over which the agency has regulatory authority (e.g., EPA Region 5 covers IL, IN, MI, MN, OH, WI; or specific county/municipality names).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'The governmental level at which the agency operates (federal, state, regional, local, international).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDeadlineHours rdf:type rdf:Property ;
    rdfs:label 'Notification Deadline Hours' ;
    rdfs:comment 'Standard number of hours within which the utility must notify this agency of reportable incidents or violations (e.g., 24 hours for SSO events).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npdesAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Npdes Authority Flag' ;
    rdfs:comment 'Indicates whether this agency has authority to issue and enforce NPDES permits under the Clean Water Act. True if authorized, False otherwise.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentRegulatoryAgencyIdLegacy rdf:type rdf:Property ;
    rdfs:label 'Parent Regulatory Agency Id Legacy' ;
    rdfs:comment 'Reference to the parent or umbrella agency if this agency is a regional office, division, or sub-agency (e.g., EPA Region 5 parent is EPA). Null if this is a top-level agency.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pretreatmentAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Pretreatment Authority Flag' ;
    rdfs:comment 'Indicates whether this agency has authority to oversee industrial pretreatment programs. True if authorized, False otherwise.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primacyAgencyFlag rdf:type rdf:Property ;
    rdfs:label 'Primacy Agency Flag' ;
    rdfs:comment 'Indicates whether this agency has primacy authority for Safe Drinking Water Act (SDWA) enforcement in its jurisdiction. True if primacy agency, False otherwise.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primacyStatus rdf:type rdf:Property ;
    rdfs:label 'Primacy Status' ;
    rdfs:comment 'Indicates whether this agency is a primacy agency under the Safe Drinking Water Act (SDWA) or Clean Water Act (CWA), meaning it has been delegated primary enforcement authority by EPA (primacy_agency, non_primacy, not_applicable).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProgram rdf:type rdf:Property ;
    rdfs:label 'Primary Program' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRegulatoryProgram rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Program' ;
    rdfs:comment 'The main regulatory program or statute administered by this agency relevant to water utilities (e.g., SDWA, CWA, NPDES, OSHA, Rate Regulation).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequencyDefault rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency Default' ;
    rdfs:comment 'Default or most common reporting frequency required by this agency for compliance reports (monthly, quarterly, semi-annual, annual, event-driven, as-required).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingSystemName rdf:type rdf:Property ;
    rdfs:label 'Reporting System Name' ;
    rdfs:comment 'Name of the electronic reporting system used by the agency (e.g., NetDMR, SDWIS, state-specific portal).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:state rdf:type rdf:Property ;
    rdfs:label 'State' ;
    rdfs:comment 'Two-letter state or province code where the regulatory agency office is located.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionCredentialsReference rdf:type rdf:Property ;
    rdfs:label 'Submission Credentials Reference' ;
    rdfs:comment 'Reference identifier or location for stored login credentials or API keys used to access the agency\'s submission portal. Should reference a secure credential vault, not store actual credentials.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionPortalName rdf:type rdf:Property ;
    rdfs:label 'Submission Portal Name' ;
    rdfs:comment 'Name of the online submission portal or system (e.g., NetDMR, State Environmental Portal, OSHA Injury Tracking Application).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionPortalUrl rdf:type rdf:Property ;
    rdfs:label 'Submission Portal Url' ;
    rdfs:comment 'URL for the online portal or system used to submit compliance reports, permits, or other regulatory documents to this agency (e.g., NetDMR, state e-reporting system).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
