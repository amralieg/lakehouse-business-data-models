ind:leadCopperResultId rdf:type rdf:Property ;
    rdfs:label 'Lead Copper Result Id' ;
    rdfs:comment 'Unique identifier for the lead and copper sampling result record.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analysisMethod rdf:type rdf:Property ;
    rdfs:label 'Analysis Method' ;
    rdfs:comment 'EPA-approved analytical method used for lead and copper determination (e.g., EPA 200.8 ICP-MS, EPA 200.9 ICP-AES).' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copperActionLevelExceeded rdf:type rdf:Property ;
    rdfs:label 'Copper Action Level Exceeded' ;
    rdfs:comment 'Indicates whether the copper result exceeds the EPA action level of 1300 ppb (1.3 mg/L), triggering potential corrosion control treatment requirements.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copperResultPpb rdf:type rdf:Property ;
    rdfs:label 'Copper Result Ppb' ;
    rdfs:comment 'Measured concentration of copper in the water sample expressed in parts per billion (ppb or µg/L). Used for 90th percentile calculation and action level comparison.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corrosionControlTreatmentStatus rdf:type rdf:Property ;
    rdfs:label 'Corrosion Control Treatment Status' ;
    rdfs:comment 'Status of corrosion control treatment optimization at the time of sampling, indicating whether the water system has optimized corrosion control per LCRR requirements.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent' ;
    rdfs:comment 'Indicates whether the customer was notified of their individual sample result as required by LCRR within 30 days of receiving results.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionLimitCopperPpb rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Copper Ppb' ;
    rdfs:comment 'Minimum concentration of copper that the analytical method can reliably detect and quantify for this sample.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionLimitLeadPpb rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Lead Ppb' ;
    rdfs:comment 'Minimum concentration of lead that the analytical method can reliably detect and quantify for this sample.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingTimeCompliant rdf:type rdf:Property ;
    rdfs:label 'Holding Time Compliant' ;
    rdfs:comment 'Indicates whether the sample was analyzed within the EPA-required holding time (6 months for metals) from collection to analysis.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includedIn90thPercentile rdf:type rdf:Property ;
    rdfs:label 'Included In 90th Percentile' ;
    rdfs:comment 'Indicates whether this result was included in the 90th percentile calculation for LCRR compliance determination. Invalid or QC-failed samples are excluded.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadActionLevelExceeded rdf:type rdf:Property ;
    rdfs:label 'Lead Action Level Exceeded' ;
    rdfs:comment 'Indicates whether the lead result exceeds the EPA action level of 15 ppb, triggering potential corrosion control treatment requirements.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadResultPpb rdf:type rdf:Property ;
    rdfs:label 'Lead Result Ppb' ;
    rdfs:comment 'Measured concentration of lead in the water sample expressed in parts per billion (ppb or µg/L). Used for 90th percentile calculation and action level comparison.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityControlStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Control Status' ;
    rdfs:comment 'Laboratory quality control status indicating whether the sample result passed all QC checks including blanks, duplicates, and spike recoveries.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Status' ;
    rdfs:comment 'Status of this result in the regulatory reporting workflow to state primacy agency and EPA.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text field for additional notes, observations, or special circumstances related to the sample collection or analysis.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Date' ;
    rdfs:comment 'Date when the first-draw water sample was collected at the customer tap.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleCollectionTime rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Time' ;
    rdfs:comment 'Precise timestamp when the first-draw water sample was collected, including time of day to verify minimum stagnation period compliance.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:samplePh rdf:type rdf:Property ;
    rdfs:label 'Sample Ph' ;
    rdfs:comment 'pH measurement of the water sample at collection, relevant for corrosion control assessment.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplePreservationMethod rdf:type rdf:Property ;
    rdfs:label 'Sample Preservation Method' ;
    rdfs:comment 'Method used to preserve the sample for metals analysis, typically acidification with nitric acid to pH < 2.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Sample Temperature C' ;
    rdfs:comment 'Water temperature at the time of sample collection, recorded to document field conditions.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteTier rdf:type rdf:Property ;
    rdfs:label 'Site Tier' ;
    rdfs:comment 'LCRR-mandated tier classification of the sampling site based on service line material and building construction date (Tier 1: lead service lines, Tier 2: lead status unknown, Tier 3: non-lead).' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stagnationTimeHours rdf:type rdf:Property ;
    rdfs:label 'Stagnation Time Hours' ;
    rdfs:comment 'Duration in hours that water remained stagnant in the service line prior to sample collection. LCRR requires minimum 6-hour stagnation for first-draw samples.' ;
    rdfs:domain ind:LeadCopperResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationMethod rdf:type rdf:Property ;
    rdfs:label 'Certification Method' ;
    rdfs:comment 'Method used to submit the CCR certification to the primacy agency. Many states now require electronic submission through online portals.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Certification Submission Date' ;
    rdfs:comment 'Date when the CCR certification was submitted to the primacy agency. Systems must certify delivery of the CCR to customers by October 1.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certifiedByName rdf:type rdf:Property ;
    rdfs:label 'Certified By Name' ;
    rdfs:comment 'Name of the authorized water system official who certified the CCR. Typically the system manager, superintendent, or designated compliance officer.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedByTitle rdf:type rdf:Property ;
    rdfs:label 'Certified By Title' ;
    rdfs:comment 'Job title of the authorized official who certified the CCR.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address for customer inquiries about the CCR. Increasingly included as an additional contact method.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the water system contact person for customer questions about the CCR. Required to be included in the published report.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number for customer inquiries about the CCR. Required to be included in the published report.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customersServedCount rdf:type rdf:Property ;
    rdfs:label 'Customers Served Count' ;
    rdfs:comment 'Total number of customer accounts or service connections served by the water system during the report year. Used to determine CCR distribution requirements.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:detectedContaminantCount rdf:type rdf:Property ;
    rdfs:label 'Detected Contaminant Count' ;
    rdfs:comment 'Total number of regulated contaminants detected in the water system during the report year. Includes contaminants above and below Maximum Contaminant Levels (MCL).' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionMethod rdf:type rdf:Property ;
    rdfs:label 'Distribution Method' ;
    rdfs:comment 'Primary method used to deliver the Consumer Confidence Report to customers. EPA allows mail, electronic delivery, or posting with notification.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFilePath rdf:type rdf:Property ;
    rdfs:label 'Document File Path' ;
    rdfs:comment 'File system path or cloud storage location of the final published CCR document (typically PDF format).' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euArticle17ComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Eu Article 17 Compliance Flag' ;
    rdfs:comment 'Whether this reporting period meets EU DWD 2020/2184 Article 17 requirements for consumer information and online access to water quality data.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:euInformationAccessMethod rdf:type rdf:Property ;
    rdfs:label 'Eu Information Access Method' ;
    rdfs:comment 'Method by which consumer water quality information is made accessible per EU DWD 2020/2184 Art 14 (e.g. online portal, annual mailing, on-request). NULL for US jurisdiction.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euReferencePath rdf:type rdf:Property ;
    rdfs:label 'Eu Reference Path' ;
    rdfs:comment 'EU reference path: Drinking Water Directive 2020/2184; REACH; WFD; UWWTD citation chain.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthEffectsLanguageIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Health Effects Language Included Flag' ;
    rdfs:comment 'Indicates whether mandatory EPA health effects language was included for all detected contaminants. Required for CCR compliance.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionRegion rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Region' ;
    rdfs:comment 'Regulatory region code (US, EU, OTHER) for this consumer confidence report period. US requires annual CCR per SDWA; EU requires equivalent consumer information under Drinking Water Directive 2020/2184 Article 17.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageAccessibilityProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Language Accessibility Provided Flag' ;
    rdfs:comment 'Indicates whether the CCR was made available in languages other than English to serve non-English speaking populations. Required for systems serving significant non-English speaking populations.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadCopperEducationalInformationFlag rdf:type rdf:Property ;
    rdfs:label 'Lead Copper Educational Information Flag' ;
    rdfs:comment 'Indicates whether mandatory lead and copper educational information was included in the CCR. Required under Lead and Copper Rule Revisions (LCRR).' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mclViolationCount rdf:type rdf:Property ;
    rdfs:label 'Mcl Violation Count' ;
    rdfs:comment 'Number of Maximum Contaminant Level violations that occurred during the report year. Must be prominently disclosed in the CCR.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringViolationCount rdf:type rdf:Property ;
    rdfs:label 'Monitoring Violation Count' ;
    rdfs:comment 'Number of monitoring and reporting violations that occurred during the report year. Includes failures to test or report as required.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onlineCcrUrl rdf:type rdf:Property ;
    rdfs:label 'Online Ccr Url' ;
    rdfs:comment 'Web address where the CCR is posted online. Required if using electronic delivery method.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationServedCount rdf:type rdf:Property ;
    rdfs:label 'Population Served Count' ;
    rdfs:comment 'Estimated total population receiving water from the system during the report year. Used for regulatory classification and reporting.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preparationStartDate rdf:type rdf:Property ;
    rdfs:label 'Preparation Start Date' ;
    rdfs:comment 'Date when preparation of the Consumer Confidence Report began. Typically starts in January following the report year.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date when the Consumer Confidence Report was published and made available to customers. Must be by July 1 following the report year per EPA regulations.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pwsid rdf:type rdf:Property ;
    rdfs:label 'Pwsid' ;
    rdfs:comment 'EPA-assigned unique identifier for the public water system. Format: two-letter state code followed by seven digits (e.g., CA1234567).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRegion rdf:type rdf:Property ;
    rdfs:label 'Regulatory Region' ;
    rdfs:comment 'Top-level regulatory region (US, EU, OTHER). US requires annual CCR per SDWA; EU requires real-time online access to water quality data per DWD 2020/2184 Article 17. Allowed regions: US,EU,OTHER.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRegionCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Region Code' ;
    rdfs:comment 'ISO region code identifying the jurisdiction for this consumer confidence / water quality report period (US, EU, OTHER). US uses CCR per SDWA; EU uses DWD 2020/2184 Art 14 consumer information.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the Consumer Confidence Report. Tracks progression from draft through publication and certification to primacy agency.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportYear rdf:type rdf:Property ;
    rdfs:label 'Report Year' ;
    rdfs:comment 'Calendar year for which this Consumer Confidence Report is prepared. CCRs are annual reports covering the previous calendar year\'s water quality data.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceWaterAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Source Water Assessment Summary' ;
    rdfs:comment 'Summary of the source water assessment including susceptibility to contamination and availability information. Required CCR content element.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialNoticesIncluded rdf:type rdf:Property ;
    rdfs:label 'Special Notices Included' ;
    rdfs:comment 'Description of any special notices included in the CCR such as boil water advisories, vulnerable population warnings, or emerging contaminant information.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentTechniqueViolationCount rdf:type rdf:Property ;
    rdfs:label 'Treatment Technique Violation Count' ;
    rdfs:comment 'Number of treatment technique violations that occurred during the report year. Treatment techniques are required processes for contaminants without MCLs.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usReferencePath rdf:type rdf:Property ;
    rdfs:label 'Us Reference Path' ;
    rdfs:comment 'US reference path: EPA/AWWA/NPDWR/UCMR/NPDES citation chain.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationSummary rdf:type rdf:Property ;
    rdfs:label 'Violation Summary' ;
    rdfs:comment 'Narrative summary of all violations that occurred during the report year, including health effects language and corrective actions taken. Required CCR content element.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterSourceSummary rdf:type rdf:Property ;
    rdfs:label 'Water Source Summary' ;
    rdfs:comment 'Narrative description of the water system\'s sources including surface water, groundwater, purchased water, and source water protection information. Required CCR content element.' ;
    rdfs:domain ind:CcrPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentWaterSystemId rdf:type rdf:Property ;
    rdfs:label 'Parent Water System Id' ;
    rdfs:comment 'Self-referencing FK on water_system (parent_water_system_id)' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaterSystem .

ind:averageDailyConsumptionMgd rdf:type rdf:Property ;
    rdfs:label 'Average Daily Consumption Mgd' ;
    rdfs:comment 'Average daily water consumption served by the system.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyProductionMgd rdf:type rdf:Property ;
    rdfs:label 'Average Daily Production Mgd' ;
    rdfs:comment 'Average daily water production volume.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityMgd rdf:type rdf:Property ;
    rdfs:label 'Capacity Mgd' ;
    rdfs:comment 'Maximum designed water flow capacity.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chlorineResidualMgL rdf:type rdf:Property ;
    rdfs:label 'Chlorine Residual Mg L' ;
    rdfs:comment 'Typical residual chlorine concentration.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Ownership and governance classification of the water system.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionDate rdf:type rdf:Property ;
    rdfs:label 'Construction Date' ;
    rdfs:comment 'Date when construction of the water system was completed.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCity rdf:type rdf:Property ;
    rdfs:label 'Location City' ;
    rdfs:comment 'City where the water system is located.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationState rdf:type rdf:Property ;
    rdfs:label 'Location State' ;
    rdfs:comment 'State or province of the water system location.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceSchedule rdf:type rdf:Property ;
    rdfs:label 'Maintenance Schedule' ;
    rdfs:comment 'Textual description of routine maintenance schedule (e.g., quarterly, annual).' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeBetweenFailuresHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures Hours' ;
    rdfs:comment 'Average operational hours between failures.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInspectionDue rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due' ;
    rdfs:comment 'Scheduled date for the next inspection.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerOrganization rdf:type rdf:Property ;
    rdfs:label 'Owner Organization' ;
    rdfs:comment 'Name of the organization that owns the water system.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Permit Expiry Date' ;
    rdfs:comment 'Expiration date of the regulatory permit.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phRange rdf:type rdf:Property ;
    rdfs:label 'Ph Range' ;
    rdfs:comment 'Typical pH range of output water (e.g., 6.5-8.5).' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySourceType rdf:type rdf:Property ;
    rdfs:label 'Primary Source Type' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemCode rdf:type rdf:Property ;
    rdfs:label 'System Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the water system.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemName rdf:type rdf:Property ;
    rdfs:label 'System Name' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemType rdf:type rdf:Property ;
    rdfs:label 'System Type' ;
    rdfs:comment 'Category of the water system based on function.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalColiformsCfu100ml rdf:type rdf:Property ;
    rdfs:label 'Total Coliforms Cfu 100ml' ;
    rdfs:comment 'Typical total coliform count.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentProcesses rdf:type rdf:Property ;
    rdfs:label 'Treatment Processes' ;
    rdfs:comment 'Comma-separated list of treatment processes applied (e.g., coagulation, filtration, disinfection).' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterQualityCategory rdf:type rdf:Property ;
    rdfs:label 'Water Quality Category' ;
    rdfs:comment 'Classification of water quality produced.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterSystemStatus rdf:type rdf:Property ;
    rdfs:label 'Water System Status' ;
    rdfs:comment 'Current operational status of the water system.' ;
    rdfs:domain ind:WaterSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administrativeRecordUrl rdf:type rdf:Property ;
    rdfs:label 'Administrative Record Url' ;
    rdfs:comment 'URL to the administrative record for this permit.' ;
    rdfs:domain ind:CompliancePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'Annual permit fee amount.' ;
    rdfs:domain ind:CompliancePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceScheduleFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule Flag' ;
    rdfs:comment 'Whether permit includes a compliance schedule' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactPersonName rdf:type rdf:Property ;
    rdfs:label 'Contact Person Name' ;
    rdfs:comment 'Primary contact person for the permit' ;
    rdfs:domain ind:CompliancePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euDirectiveBasis rdf:type rdf:Property ;
    rdfs:label 'Eu Directive Basis' ;
    rdfs:comment 'EU directive forming the legal basis for this permit (e.g. DWD 2020/2184 Article 11, WFD 2000/60/EC Article 11, UWWTD 91/271/EEC Article 4).' ;
    rdfs:domain ind:CompliancePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeDueDate rdf:type rdf:Property ;
    rdfs:label 'Fee Due Date' ;
    rdfs:comment 'Due date for the annual permit fee.' ;
    rdfs:domain ind:CompliancePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holder rdf:type rdf:Property ;
    rdfs:label 'Holder' ;
    rdfs:domain ind:CompliancePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date the enforcement action was officially issued or signed by the regulatory agency. This is the principal business event timestamp for the enforcement action lifecycle.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingAgency rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency' ;
    rdfs:comment 'Name of the regulatory agency that issued the permit.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Agency that issued the permit.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionPermitType rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Permit Type' ;
    rdfs:comment 'Jurisdiction-specific permit type classification (e.g. US: Individual/General NPDES; EU: Environmental Permit / Abstraction License).' ;
    rdfs:domain ind:CompliancePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorMinorClassification rdf:type rdf:Property ;
    rdfs:label 'Major Minor Classification' ;
    rdfs:domain ind:CompliancePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorMinorFlag rdf:type rdf:Property ;
    rdfs:label 'Major Minor Flag' ;
    rdfs:comment 'Whether classified as major or minor permit' ;
    rdfs:domain ind:CompliancePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modificationDate rdf:type rdf:Property ;
    rdfs:label 'Modification Date' ;
    rdfs:comment 'Date of the most recent permit modification.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationReason rdf:type rdf:Property ;
    rdfs:label 'Modification Reason' ;
    rdfs:comment 'Reason for the most recent permit modification.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitDescription rdf:type rdf:Property ;
    rdfs:label 'Permit Description' ;
    rdfs:comment 'Detailed description of the permit scope and coverage.' ;
    rdfs:domain ind:CompliancePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedFlowMgd rdf:type rdf:Property ;
    rdfs:label 'Permitted Flow Mgd' ;
    rdfs:comment 'Maximum permitted flow in million gallons per day.' ;
    rdfs:domain ind:CompliancePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitteeName rdf:type rdf:Property ;
    rdfs:label 'Permittee Name' ;
    rdfs:domain ind:CompliancePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:program rdf:type rdf:Property ;
    rdfs:label 'Program' ;
    rdfs:domain ind:CompliancePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicNotificationRequiredFlag rdf:type rdf:Property ;
