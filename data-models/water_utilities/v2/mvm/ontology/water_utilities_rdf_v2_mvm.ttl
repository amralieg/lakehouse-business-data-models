    rdfs:comment 'Service class code' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Special conditions or notes on the agreement' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual termination date if terminated early' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason for termination' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountPersonRelId rdf:type rdf:Property ;
    rdfs:label 'Account Person Rel Id' ;
    rdfs:comment 'Unique identifier for the account-person relationship record. Primary key.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAccountPersonId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Person Id' ;
    rdfs:comment 'Reference to the person entity in this relationship. Links to the individual who has a role on the account.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Person .

ind:accessibilityRequirements rdf:type rdf:Property ;
    rdfs:label 'Accessibility Requirements' ;
    rdfs:comment 'Special accessibility or accommodation needs for this person when communicating about the account. May include requirements for large print, braille, TTY, or other assistive technologies.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'The date when this relationship was formally authorized or approved. Used for audit trail and compliance verification.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Authorization Document Reference' ;
    rdfs:comment 'Reference number or identifier for the legal document or form that authorizes this relationship. May reference a power of attorney, lease agreement, or authorization form.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Authority Flag' ;
    rdfs:comment 'Indicates whether this person has authority to make billing decisions, dispute charges, or modify payment arrangements for the account. True if authorized, false otherwise.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccrDeliveryRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ccr Delivery Required Flag' ;
    rdfs:comment 'Indicates whether this person must receive the annual Consumer Confidence Report for water quality as required by the Safe Drinking Water Act. True if delivery is required, false otherwise.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'The system user ID or username of the person who created this relationship record. Used for audit trail and accountability.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPriority rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Priority' ;
    rdfs:comment 'The order in which this person should be contacted in case of emergency at the service address. Lower numbers indicate higher priority. Null if not an emergency contact.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financialResponsibilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Financial Responsibility Percentage' ;
    rdfs:comment 'The percentage of account charges for which this person is financially responsible. Used in split-billing scenarios or shared responsibility arrangements. Value between 0.00 and 100.00.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landlordTenantIndicator rdf:type rdf:Property ;
    rdfs:label 'Landlord Tenant Indicator' ;
    rdfs:comment 'Specifies whether this person is the property owner (landlord), renter (tenant), owner-occupant, or property manager. Used for billing responsibility determination and compliance reporting.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The system user ID or username of the person who last modified this relationship record. Used for audit trail and accountability.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcrrNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Lcrr Notification Required Flag' ;
    rdfs:comment 'Indicates whether this person must receive mandatory notifications under the EPA Lead and Copper Rule Revisions regarding lead service lines at the service address. True if notification is required, false otherwise.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationPreference rdf:type rdf:Property ;
    rdfs:label 'Notification Preference' ;
    rdfs:comment 'The preferred communication channel for sending notifications to this person regarding the account. Used for outage alerts, billing reminders, and compliance notifications.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipNotes rdf:type rdf:Property ;
    rdfs:label 'Relationship Notes' ;
    rdfs:comment 'Free-form text field for additional information about this account-person relationship. May include special instructions, restrictions, or context relevant to customer service representatives.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle status of the account-person relationship. Indicates whether the relationship is currently in effect or has been terminated.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'The role or capacity in which the person is associated with the account. Defines the nature of the relationship between the person and the service account.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Service Authorization Flag' ;
    rdfs:comment 'Indicates whether this person has authority to request service orders, schedule appointments, or authorize field work for the account. True if authorized, false otherwise.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyPayerFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Payer Flag' ;
    rdfs:comment 'Indicates whether this person is responsible for paying the bill on behalf of the primary account holder. True for third-party payers such as social service agencies or property managers, false otherwise.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date when the person\'s identity and relationship authorization were last verified. Used for periodic re-verification requirements and audit compliance.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'The method used to verify the person\'s identity and authorization for this relationship. Used for audit trail and fraud prevention analysis.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Indicates whether the person\'s identity and authorization for this relationship have been verified. Used for fraud prevention and compliance with customer identification requirements.' ;
    rdfs:domain ind:AccountPersonRel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceApplicationId rdf:type rdf:Property ;
    rdfs:label 'Service Application Id' ;
    rdfs:comment 'Unique identifier for the service application record. Primary key.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicantOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Applicant Organization Id' ;
    rdfs:comment 'Foreign key linking to customer.organization. Business justification: service_application currently has applicant_person_id for individual applicants but no FK for organizational applicants (commercial, industrial, municipal). When a business or municipality applies for' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:applicantPersonId rdf:type rdf:Property ;
    rdfs:label 'Applicant Person Id' ;
    rdfs:comment 'Foreign key linking to customer.person. Business justification: Service applications capture applicant details that should reference the person master record. This eliminates data duplication and ensures applicant identity is properly managed. The person table con' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Person .

ind:pressureZoneId rdf:type rdf:Property ;
    rdfs:label 'Pressure Zone Id' ;
    rdfs:comment 'Foreign key linking to distribution.pressure_zone. Business justification: New service applications require engineering review to verify adequate pressure and capacity in the target pressure zone before approval. Critical for ensuring system can support additional demand wit' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PressureZone .

ind:primaryServiceCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Customer Account Id' ;
    rdfs:comment 'Reference to the customer (applicant) who submitted this service application. Links to the customer master record.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:resultingServiceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Resulting Service Agreement Id' ;
    rdfs:comment 'Foreign key linking to customer.service_agreement. Business justification: A service_application, when approved, results in the creation of a service_agreement. This lifecycle FK links the application record to the agreement it produced, enabling traceability from applicatio' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceAgreement .

ind:tapPipeMainId rdf:type rdf:Property ;
    rdfs:label 'Tap Pipe Main Id' ;
    rdfs:comment 'Foreign key linking to distribution.pipe_main. Business justification: During new service connection approval, engineering must identify the specific pipe main to be tapped. Capacity, material compatibility, and operating pressure of the tap main are reviewed as part of ' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipeMain .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Externally-visible unique application number assigned when the customer submits a service application. Used for customer communication and tracking.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the service application: submitted (initial state), under review (being processed by utility staff), approved (ready for service establishment), rejected (application denied), withdrawn (applicant cancelled), or pending payment (awaiting deposit or connection fee).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Type of service application: new service establishment, transfer of service to new occupant, service upgrade (larger meter or additional service), service downgrade, service termination, or reconnection after disconnection.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date when the service application was approved by the utility, authorizing service establishment.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Precise date and time when the service application was approved.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditCheckResult rdf:type rdf:Property ;
    rdfs:label 'Credit Check Result' ;
    rdfs:comment 'Outcome of the credit check: pass (credit meets utility standards), fail (credit does not meet standards, deposit required), insufficient history (no credit history available), or not applicable (credit check not performed).' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Check Status' ;
    rdfs:comment 'Status of credit check for the applicant: not required (based on service class or policy), pending (credit check requested), completed (credit check results received), or waived (credit check requirement waived by management).' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterSizeRequested rdf:type rdf:Property ;
    rdfs:label 'Meter Size Requested' ;
    rdfs:comment 'Size of water meter requested by the applicant or recommended by utility staff based on anticipated usage (e.g., 5/8 inch, 3/4 inch, 1 inch, 1.5 inch, 2 inch, etc.).' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Priority level assigned to the application for processing: low (standard processing), normal (default priority), high (expedited processing requested), or urgent (emergency service needed).' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingNotes rdf:type rdf:Property ;
    rdfs:label 'Processing Notes' ;
    rdfs:comment 'Free-text notes entered by utility staff during application review and processing, documenting special circumstances, follow-up actions, or additional context.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date when the service application was rejected by the utility. Null if application was not rejected.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed explanation of why the service application was rejected (e.g., failed credit check, incomplete documentation, service not available at address, outstanding balance from previous account).' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code categorizing the reason for application rejection: credit failure, incomplete documentation, service unavailable at location, outstanding balance from prior account, duplicate application, or invalid service address.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedServiceStartDate rdf:type rdf:Property ;
    rdfs:label 'Requested Service Start Date' ;
    rdfs:comment 'Date when the applicant requests water or wastewater service to begin at the service address.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Review Completed Date' ;
    rdfs:comment 'Date when the application review process was completed and a decision (approved or rejected) was made.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'Date when utility staff began reviewing and processing the service application.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceClassRequested rdf:type rdf:Property ;
    rdfs:label 'Service Class Requested' ;
    rdfs:comment 'Customer segment or service class requested: residential (single-family or multi-family), commercial (retail, office), industrial (manufacturing, processing), municipal (government facilities), agricultural (irrigation, livestock), or institutional (schools, hospitals).' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTypeRequested rdf:type rdf:Property ;
    rdfs:label 'Service Type Requested' ;
    rdfs:comment 'Type of utility service requested by the applicant: water only, wastewater (sewer) only, or combined water and wastewater service.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Due Date' ;
    rdfs:comment 'Target date by which the application should be reviewed and processed according to utility service level agreement standards.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Channel through which the customer submitted the service application: online customer portal, phone call to customer service, walk-in at utility office, postal mail, mobile app, or email.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date when the customer submitted the service application.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Precise date and time when the service application was submitted by the customer or entered into the system.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:withdrawnDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawn Date' ;
    rdfs:comment 'Date when the applicant withdrew or cancelled the service application. Null if application was not withdrawn.' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawnReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawn Reason' ;
    rdfs:comment 'Reason provided by the applicant for withdrawing the service application (e.g., changed mind, moved to different location, service no longer needed).' ;
    rdfs:domain ind:ServiceApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Unique identifier for the contact record. Primary key.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Contact Customer Account Id' ;
    rdfs:comment 'Reference to the customer account or person this contact is associated with. Links contact to the customer master record in Oracle Utilities CC&B.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:contactCustomerCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Contact Customer Customer Account Id' ;
    rdfs:comment 'Reference to the customer account or person this contact is associated with. Links contact to the customer master record in Oracle Utilities CC&B.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The communication channel or medium through which this contact point operates. Supports multi-channel customer engagement including Consumer Confidence Report (CCR) delivery, boil-water notices, and outage notifications.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. Active contacts are used for communications; inactive contacts are retained for history; invalid contacts have been identified as unreachable; pending_verification contacts await confirmation.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact purpose. Indicates whether this contact is used for billing correspondence, service notifications, emergency alerts, legal notices, technical communications, or general customer service inquiries.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFailureCount rdf:type rdf:Property ;
    rdfs:label 'Delivery Failure Count' ;
    rdfs:comment 'Count of failed communication delivery attempts to this contact. Used to identify problematic contacts and trigger validation workflows.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliverySuccessCount rdf:type rdf:Property ;
    rdfs:label 'Delivery Success Count' ;
    rdfs:comment 'Count of successful communication deliveries to this contact. Used to calculate contact reliability and quality scores.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doNotContactFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Flag' ;
    rdfs:comment 'Boolean flag indicating customer has requested no contact through this channel except for legally required communications. Overrides opt-in preferences except for emergency and regulatory notifications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invalidDate rdf:type rdf:Property ;
    rdfs:label 'Invalid Date' ;
    rdfs:comment 'Date when this contact was marked as invalid. Used for data quality reporting and contact refresh prioritization.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invalidReason rdf:type rdf:Property ;
    rdfs:label 'Invalid Reason' ;
    rdfs:comment 'Reason why this contact was marked as invalid. Populated when contact_status is set to invalid. Supports data quality improvement and contact cleansing workflows.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary contact point for the associated customer and contact type. Used to determine default communication channel for critical notifications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Boolean flag indicating whether this contact information has been verified as accurate and reachable. Verification may occur through confirmation emails, SMS codes, or postal mail validation.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Human-readable label or nickname for this contact (e.g., \'Home Phone\', \'Work Email\', \'Billing Address\'). Helps users distinguish between multiple contacts of the same type.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date when this contact point was last used for outbound communication. Used to track contact engagement and identify stale contact records.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastContactType rdf:type rdf:Property ;
    rdfs:label 'Last Contact Type' ;
    rdfs:comment 'Type of the last communication sent to this contact (e.g., bill, service alert, CCR, boil-water notice). Supports communication history analysis.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInBilling rdf:type rdf:Property ;
    rdfs:label 'Opt In Billing' ;
    rdfs:comment 'Boolean flag indicating customer consent to receive billing-related communications through this contact channel. Supports compliance with communication preference regulations.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInEmergency rdf:type rdf:Property ;
    rdfs:label 'Opt In Emergency' ;
    rdfs:comment 'Boolean flag indicating customer consent to receive emergency alerts (e.g., boil-water notices, water quality advisories, Sanitary Sewer Overflow (SSO) notifications) through this contact channel. Typically defaults to true for critical public health communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInMarketing rdf:type rdf:Property ;
    rdfs:label 'Opt In Marketing' ;
    rdfs:comment 'Boolean flag indicating customer consent to receive marketing and promotional communications (e.g., conservation programs, new service offerings) through this contact channel.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInService rdf:type rdf:Property ;
    rdfs:label 'Opt In Service' ;
    rdfs:comment 'Boolean flag indicating customer consent to receive service-related communications (e.g., planned outages, maintenance notifications) through this contact channel.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Date' ;
    rdfs:comment 'Date when the customer opted out of communications through this contact channel. Null if customer has not opted out. Used for compliance reporting and communication suppression.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optOutReason rdf:type rdf:Property ;
    rdfs:label 'Opt Out Reason' ;
    rdfs:comment 'Free-text reason provided by customer for opting out of communications. Supports customer experience analysis and communication strategy improvement.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Data quality score for this contact record (0.00 to 100.00). Calculated based on verification status, recency, completeness, and delivery success rate. Used to prioritize contact data cleansing efforts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Unique identifier for this contact in the source system. Enables traceability back to the system of record and supports data reconciliation.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'Time zone associated with this contact location (e.g., America/New_York, America/Los_Angeles). Used to schedule communications at appropriate local times and comply with TCPA calling hour restrictions.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:value rdf:type rdf:Property ;
    rdfs:label 'Value' ;
    rdfs:comment 'The actual contact information value - phone number, email address, mailing address, SMS number, portal username, or fax number. Format varies by contact_channel. This is the primary contact data point.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complaintId rdf:type rdf:Property ;
    rdfs:label 'Complaint Id' ;
    rdfs:comment 'Unique identifier for the customer complaint record. Primary key.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Complaint .

ind:complaintCustomerPersonId rdf:type rdf:Property ;
    rdfs:label 'Complaint Customer Person Id' ;
    rdfs:comment 'FK to person' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Person .

ind:complaintCustomerReportedByPersonId rdf:type rdf:Property ;
    rdfs:label 'Complaint Customer Reported By Person Id' ;
    rdfs:comment 'Foreign key linking to customer.person. Business justification: Complaints capture reporter details that should reference the person master when the reporter is a known person. This eliminates duplication and enables proper reporter tracking. Nullable as some comp' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Person .

ind:mainBreakId rdf:type rdf:Property ;
    rdfs:label 'Main Break Id' ;
    rdfs:comment 'Foreign key linking to distribution.main_break. Business justification: Customer complaints about outages, discoloration, and pressure loss are causally linked to main breaks. Root cause analysis, regulatory CCR reporting, and customer communication workflows require link' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MainBreak .

ind:pipeMainId rdf:type rdf:Property ;
    rdfs:label 'Pipe Main Id' ;
    rdfs:comment 'Foreign key linking to distribution.pipe_main. Business justification: Water quality complaints (taste, odor, discoloration, pressure) routinely reference the specific distribution main where the issue originates. Operations teams use this for targeted flushing, leak det' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipeMain .

ind:primaryCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Account Id' ;
    rdfs:comment 'Reference to the customer account associated with this complaint.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:primaryCustomerWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Work Order Id' ;
    rdfs:comment 'Reference to the work order created to address the physical or operational issue underlying the complaint, such as a repair, inspection, or maintenance activity in IBM Maximo Asset Management (CMMS).' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:regulatoryInspectionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_inspection. Business justification: Water quality or service complaints frequently trigger regulatory inspections. Linking customer_complaint to the resulting regulatory_inspection supports complaint-to-inspection traceability reporting' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryInspection .

ind:serviceLineId rdf:type rdf:Property ;
    rdfs:label 'Service Line Id' ;
    rdfs:comment 'Foreign key linking to distribution.service_line. Business justification: Under EPA LCRR regulations, lead-related customer complaints must be linked to the specific service line for material verification, remediation tracking, and regulatory reporting. Low-pressure and dis' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceLine .

ind:sewerNetworkId rdf:type rdf:Property ;
    rdfs:label 'Sewer Network Id' ;
    rdfs:comment 'Foreign key linking to wastewater.sewer_network. Business justification: Sewer backup, blockage, and SSO complaints must be linked to the specific sewer network segment for field dispatch, root cause analysis, and EPA SSO regulatory reporting. A water utility domain expert' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SewerNetwork .

ind:violationId rdf:type rdf:Property ;
    rdfs:label 'Violation Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_violation. Business justification: Customer complaints (water quality, odor, service issues) can trigger or provide evidence for regulatory violations—documented linkage required for enforcement case files and regulatory reporting.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Violation .

ind:waterSampleId rdf:type rdf:Property ;
    rdfs:label 'Water Sample Id' ;
    rdfs:comment 'Foreign key linking to quality.water_sample. Business justification: Water quality complaints (taste, odor, discoloration) trigger field sampling under LCRR/SDWA. The complaint record must reference the resulting water_sample to close the complaint-to-resolution workfl' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaterSample .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'Actual date when the complaint was resolved and closed.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'Date when the complaint was assigned to a resolution owner.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedToDepartment rdf:type rdf:Property ;
    rdfs:label 'Assigned To Department' ;
    rdfs:comment 'Department or functional area responsible for resolving the complaint, such as Customer Service, Water Quality, Distribution Operations and Maintenance (O&M), Billing, or Laboratory.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Billing Adjustment Amount' ;
    rdfs:comment 'Dollar amount of billing adjustment or credit issued to the customer as a result of the complaint resolution, if applicable.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Provided Flag' ;
    rdfs:comment 'Indicates whether any form of compensation, credit, or goodwill gesture was provided to the customer as part of the complaint resolution.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintDate rdf:type rdf:Property ;
    rdfs:label 'Complaint Date' ;
    rdfs:comment 'Complaint date' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complaintNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Number' ;
    rdfs:comment 'Externally visible unique complaint tracking number assigned by the Customer Information System (CIS) or Customer Care and Billing (CC&B) system.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintStatus rdf:type rdf:Property ;
    rdfs:label 'Complaint Status' ;
    rdfs:comment 'Current lifecycle status of the complaint in the resolution workflow. [ENUM-REF-CANDIDATE: open|in_progress|pending_customer|pending_investigation|resolved|closed|escalated|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintType rdf:type rdf:Property ;
    rdfs:label 'Complaint Type' ;
    rdfs:comment 'Complaint type' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactMethod rdf:type rdf:Property ;
    rdfs:label 'Contact Method' ;
    rdfs:comment 'Channel through which the complaint was received by the utility. [ENUM-REF-CANDIDATE: phone|email|web_portal|mobile_app|in_person|mail|social_media — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Specific corrective action taken to address the root cause and prevent recurrence, such as infrastructure repair, meter replacement, billing adjustment, or process improvement.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerComplaintDescription rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Description' ;
    rdfs:comment 'Attribute description for customer_complaint' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionComments rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Comments' ;
    rdfs:comment 'Free-text feedback provided by the customer regarding their satisfaction with the complaint resolution process and outcome.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Customer satisfaction score provided by the customer after complaint resolution, typically on a scale of 1 to 5 or 1 to 10.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Customer satisfaction score' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysToResolve rdf:type rdf:Property ;
    rdfs:label 'Days To Resolve' ;
    rdfs:comment 'Days to resolve' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed narrative description of the complaint as reported by the customer, including symptoms, duration, and customer concerns.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedFlag rdf:type rdf:Property ;
    rdfs:label 'Escalated Flag' ;
    rdfs:comment 'Escalated flag' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Scheduled date for follow-up action or customer contact to verify sustained resolution.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Indicates whether additional follow-up action or monitoring is required after initial complaint resolution.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal notes and comments for staff use, not visible to the customer, documenting investigation steps, coordination with other departments, and operational context.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Attribute received_date for customer_complaint' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'Name of the regulatory agency involved if the complaint was escalated, such as state Department of Environmental Quality, Public Utilities Commission (PUC), or U.S. Environmental Protection Agency (EPA).' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Case Number' ;
    rdfs:comment 'Case or reference number assigned by the regulatory agency for tracking the escalated complaint.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryEscalationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Escalation Flag' ;
    rdfs:comment 'Indicates whether the complaint was escalated to or originated from a regulatory agency such as state primacy agency, Public Utilities Commission (PUC), or U.S. Environmental Protection Agency (EPA).' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Regulatory reportable flag' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Response Due Date' ;
    rdfs:comment 'Date by which the utility must provide a formal response to the regulatory agency regarding the escalated complaint.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Date when the complaint was first reported to the utility by the customer.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Precise date and time when the complaint was logged into the system, including time zone offset.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Code' ;
    rdfs:comment 'Resolution code' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Resolution date' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed narrative of the actions taken to resolve the complaint, including investigation findings, corrective actions, and customer communication.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Attribute resolution_notes for customer_complaint' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Precise date and time when the complaint was marked as resolved, including time zone offset.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolvedDate rdf:type rdf:Property ;
    rdfs:label 'Resolved Date' ;
    rdfs:comment 'Attribute resolved_date for customer_complaint' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause of the complaint issue, such as main break, meter malfunction, billing system error, water treatment process deviation, or customer misunderstanding.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Source channel' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Detailed subcategory providing additional classification granularity within the primary complaint category. Examples: discoloration, chlorine_odor, high_bill, estimated_read, low_pressure, no_water, meter_leak, service_attitude.' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'Target date by which the complaint should be resolved, based on Service Level Agreement (SLA) commitments and regulatory requirements.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waterQualityRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Water Quality Related Flag' ;
    rdfs:comment 'Water quality related flag' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterQualityTestRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Water Quality Test Required Flag' ;
    rdfs:comment 'Indicates whether a water quality test was required or performed as part of the complaint investigation, particularly for complaints involving taste, odor, discoloration, or suspected contamination.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetOwner rdf:type rdf:Property ;
    rdfs:label 'Asset Owner' ;
    rdfs:comment 'Owner of the pipe asset' ;
    rdfs:domain ind:PipeMain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageDailyFlowGpm rdf:type rdf:Property ;
    rdfs:label 'Average Daily Flow Gpm' ;
    rdfs:comment 'Average daily flow in gallons per minute' ;
    rdfs:domain ind:PipeMain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awwaCSeries rdf:type rdf:Property ;
