ind:rateComponentId rdf:type rdf:Property ;
    rdfs:label 'Rate Component Id' ;
    rdfs:comment 'Foreign key linking to billing.rate_component. Business justification: Each invoice line item is generated by applying a specific rate component (e.g., a volumetric tier, a base charge, a surcharge) from the rate schedule. Linking invoice_line directly to rate_component ' ;
