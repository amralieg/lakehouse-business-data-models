ind:meterInstallationId rdf:type rdf:Property ;
    rdfs:label 'Meter Installation Id' ;
    rdfs:comment 'Foreign key linking to metering.installation. Business justification: An AMI/AMR endpoint device is physically installed at a specific meter installation site. While ami_endpoint already references metering_meter (the device), it does not directly reference the installa' ;
    rdfs:domain ind:WaterUtilities ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Installation .

ind:batteryExpectedLifeYears rdf:type rdf:Property ;
