    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decommissionReason rdf:type rdf:Property ;
    rdfs:label 'Decommission Reason' ;
    rdfs:comment 'Business or technical justification for decommissioning the instrument (e.g., end of life, obsolescence, replacement, irreparable failure).' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the instrument was installed and commissioned for use in the laboratory.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instrumentType rdf:type rdf:Property ;
    rdfs:label 'Instrument Type' ;
    rdfs:comment 'Classification of the instrument by its primary analytical or operational function within the laboratory.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labSection rdf:type rdf:Property ;
    rdfs:label 'Lab Section' ;
    rdfs:comment 'The laboratory department or section to which this instrument is assigned (e.g., Chemistry, Hematology, Microbiology).' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date when the instrument was last calibrated to ensure measurement accuracy and precision.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCalibrationResult rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Result' ;
    rdfs:comment 'Outcome of the most recent calibration verification indicating whether the instrument met accuracy and precision specifications.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCorrectiveMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Corrective Maintenance Date' ;
    rdfs:comment 'Date when the most recent unscheduled corrective maintenance or repair was performed on the instrument.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPreventiveMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Preventive Maintenance Date' ;
    rdfs:comment 'Date when the most recent scheduled preventive maintenance was performed on the instrument.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastQualityControlDate rdf:type rdf:Property ;
    rdfs:label 'Last Quality Control Date' ;
    rdfs:comment 'Date when the most recent quality control testing was performed on the instrument.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastQualityControlResult rdf:type rdf:Property ;
    rdfs:label 'Last Quality Control Result' ;
    rdfs:comment 'Outcome of the most recent quality control testing indicating whether the instrument met performance specifications.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lisConnectivityStatus rdf:type rdf:Property ;
    rdfs:label 'Lis Connectivity Status' ;
    rdfs:comment 'Current status of the bidirectional interface connection between the instrument and the Laboratory Information System.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lisInterfaceCode rdf:type rdf:Property ;
    rdfs:label 'Lis Interface Code' ;
    rdfs:comment 'Unique identifier used by the Laboratory Information System to communicate with and receive results from this instrument.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the company that manufactured the laboratory instrument.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer-assigned model number or designation for the instrument type.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Date' ;
    rdfs:comment 'Scheduled date for the next calibration verification or full calibration of the instrument.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextPreventiveMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Preventive Maintenance Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance service on the instrument.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the instrument indicating its availability for testing and analysis.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveMaintenanceFrequency rdf:type rdf:Property ;
    rdfs:label 'Preventive Maintenance Frequency' ;
    rdfs:comment 'Scheduled frequency at which preventive maintenance must be performed on the instrument per manufacturer specifications or laboratory policy.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlFrequency rdf:type rdf:Property ;
    rdfs:label 'Quality Control Frequency' ;
    rdfs:comment 'Required frequency for running quality control samples on the instrument to verify ongoing analytical performance.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Unique serial number assigned by the manufacturer to this specific instrument unit.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceContractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Service Contract Expiration Date' ;
    rdfs:comment 'Date when the current service or maintenance contract for the instrument expires.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceContractNumber rdf:type rdf:Property ;
    rdfs:label 'Service Contract Number' ;
    rdfs:comment 'Identifier for the active maintenance or service contract covering this instrument.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Downtime Hours' ;
    rdfs:comment 'Cumulative hours the instrument has been non-operational due to maintenance, repair, or malfunction since installation or last reset period.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the manufacturer warranty coverage for the instrument expires.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdmEntryId rdf:type rdf:Property ;
    rdfs:label 'Cdm Entry Id' ;
    rdfs:comment 'Foreign key linking to billing.cdm_entry. Business justification: Charge master maintenance: each orderable lab test in the test catalog maps to a CDM entry for charge capture configuration. Price transparency reporting, billing system setup, and charge master revie' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CdmEntry .

ind:companionNdcDrugId rdf:type rdf:Property ;
    rdfs:label 'Companion Ndc Drug Id' ;
    rdfs:comment 'Foreign key linking to reference.ndc_drug. Business justification: FDA companion diagnostic regulations require linking specific lab tests to their associated drug (e.g., EGFR mutation test linked to erlotinib). This supports formulary-linked test ordering and precis' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NdcDrug .

ind:consentFormTemplateId rdf:type rdf:Property ;
    rdfs:label 'Consent Form Template Id' ;
    rdfs:comment 'Foreign key linking to consent.form_template. Business justification: test_catalog has \'consent_required_flag\' but no FK to the governing consent form. Labs performing genetic, HIV, or research tests must present the correct consent form template at order entry. This li' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormTemplate .

ind:preferredInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Preferred Instrument Id' ;
    rdfs:comment 'Foreign key linking to laboratory.instrument. Business justification: Catalog tests may specify preferred or required instruments. Currently test_catalog has instrument_platform (string) but no FK. Business reality: some tests require specific instruments (e.g., specifi' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:authorizationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Authorization Required Flag' ;
    rdfs:comment 'Indicates whether payer prior authorization is typically required before performing this test due to cost or medical necessity criteria. Supports revenue cycle management.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cliaComplexity rdf:type rdf:Property ;
    rdfs:label 'Clia Complexity' ;
    rdfs:comment 'CLIA complexity classification of the test: waived (simple, low risk), moderate complexity, or high complexity. Determines regulatory requirements and personnel qualifications.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionInstructions rdf:type rdf:Property ;
    rdfs:label 'Collection Instructions' ;
    rdfs:comment 'Detailed instructions for phlebotomy or specimen collection staff, including special handling, order of draw, collection technique, or timing requirements.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Required Flag' ;
    rdfs:comment 'Indicates whether informed patient consent is required before performing this test (e.g., genetic testing, HIV testing, research testing). Supports regulatory compliance and patient rights.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalHighValue rdf:type rdf:Property ;
    rdfs:label 'Critical High Value' ;
    rdfs:comment 'Upper threshold for critical value alerting. Results at or above this value trigger immediate notification to the ordering provider per Joint Commission and patient safety requirements.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalLowValue rdf:type rdf:Property ;
    rdfs:label 'Critical Low Value' ;
    rdfs:comment 'Lower threshold for critical value alerting. Results at or below this value trigger immediate notification to the ordering provider per Joint Commission and patient safety requirements.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumVolume rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume' ;
    rdfs:comment 'Minimum volume of specimen required to perform the test, typically expressed with units (e.g., 2 mL, 5 mL, 0.5 mL). Critical for specimen adequacy assessment.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderableFlag rdf:type rdf:Property ;
    rdfs:label 'Orderable Flag' ;
    rdfs:comment 'Indicates whether this test is currently available for ordering by clinicians through CPOE (Computerized Physician Order Entry) systems. False for retired, suspended, or component-only tests.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderableStatus rdf:type rdf:Property ;
    rdfs:label 'Orderable Status' ;
    rdfs:comment 'Current lifecycle status of the test in the catalog. Active tests are available for ordering; inactive/retired tests are no longer available; suspended tests are temporarily unavailable; pending validation tests are under review.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderingInstructions rdf:type rdf:Property ;
    rdfs:label 'Ordering Instructions' ;
    rdfs:comment 'Special instructions or requirements for ordering this test, including patient preparation (e.g., fasting required, medication restrictions), timing considerations, or authorization requirements.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panicValueFlag rdf:type rdf:Property ;
    rdfs:label 'Panic Value Flag' ;
    rdfs:comment 'Indicates whether this test can produce panic or critical values requiring immediate clinical notification and documentation of provider acknowledgment.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientPreparation rdf:type rdf:Property ;
    rdfs:label 'Patient Preparation' ;
    rdfs:comment 'Specific patient preparation requirements prior to specimen collection (e.g., 8-hour fast, discontinue medications, timed collection, dietary restrictions). Critical for accurate test results.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performingLabLocation rdf:type rdf:Property ;
    rdfs:label 'Performing Lab Location' ;
    rdfs:comment 'Name or identifier of the laboratory location or section that performs this test (e.g., Main Hospital Lab - Chemistry, Regional Reference Lab, Point of Care Testing). Indicates internal vs external testing.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVolume rdf:type rdf:Property ;
    rdfs:label 'Preferred Volume' ;
    rdfs:comment 'Preferred or optimal volume of specimen for best test performance and to allow for repeat testing if needed.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceLabCode rdf:type rdf:Property ;
    rdfs:label 'Reference Lab Code' ;
    rdfs:comment 'Test code used by the external reference laboratory for ordering and tracking. Used for send-out test routing and result reconciliation.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceRangeAdult rdf:type rdf:Property ;
    rdfs:label 'Reference Range Adult' ;
    rdfs:comment 'Normal reference range for adult patients, typically expressed as a range (e.g., 3.5-5.0, <10, negative). May vary by gender and age subgroups.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceRangePediatric rdf:type rdf:Property ;
    rdfs:label 'Reference Range Pediatric' ;
    rdfs:comment 'Normal reference range for pediatric patients. May be age-stratified (e.g., neonate, infant, child, adolescent) due to developmental physiology differences.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultType rdf:type rdf:Property ;
    rdfs:label 'Result Type' ;
    rdfs:comment 'Type of result produced by the test: quantitative (numeric with units), qualitative (positive/negative/detected), semi-quantitative (titers, grades), narrative (free text interpretation), culture results, or microscopic findings.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenContainer rdf:type rdf:Property ;
    rdfs:label 'Specimen Container' ;
    rdfs:comment 'Type of collection container or tube required (e.g., red top, lavender top EDTA, green top heparin, yellow top ACD, sterile container). Includes tube color and additive information.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenStability rdf:type rdf:Property ;
    rdfs:label 'Specimen Stability' ;
    rdfs:comment 'Duration for which the specimen remains stable under specified storage conditions before testing must be performed (e.g., 24 hours at room temperature, 7 days refrigerated).' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperature rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature' ;
    rdfs:comment 'Required storage temperature for the specimen prior to testing (e.g., room temperature, refrigerated 2-8°C, frozen -20°C, frozen -80°C). Critical for specimen stability.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testAbbreviation rdf:type rdf:Property ;
    rdfs:label 'Test Abbreviation' ;
    rdfs:comment 'Short abbreviation or mnemonic for the test used in clinical documentation and reporting (e.g., CBC, BMP, CMP, TSH).' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCategory rdf:type rdf:Property ;
    rdfs:label 'Test Category' ;
    rdfs:comment 'High-level classification of the test by laboratory discipline or department (e.g., chemistry, hematology, microbiology, immunology, molecular diagnostics, anatomic pathology). [ENUM-REF-CANDIDATE: chemistry|hematology|microbiology|immunology|molecular|pathology|blood_bank|coagulation|toxicology|urinalysis — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCode rdf:type rdf:Property ;
    rdfs:label 'Test Code' ;
    rdfs:comment 'Internal laboratory test code used for ordering and identification within the Laboratory Information System (LIS). Unique business identifier for the test or panel.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testName rdf:type rdf:Property ;
    rdfs:label 'Test Name' ;
    rdfs:comment 'Full descriptive name of the laboratory test or panel as displayed to clinicians and in order entry systems.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Indicates whether this catalog entry represents an individual test, a panel (group of related tests), a profile, a reflex test (automatically triggered based on results), or an add-on test.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportConditions rdf:type rdf:Property ;
    rdfs:label 'Transport Conditions' ;
    rdfs:comment 'Special transport requirements for the specimen (e.g., transport on ice, ambient temperature, protect from light, transport immediately). Ensures specimen integrity during transport.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeRoutine rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Routine' ;
    rdfs:comment 'Expected turnaround time for routine test orders from specimen receipt to result availability, typically expressed in hours or days (e.g., 4 hours, 24 hours, 3-5 days).' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeStat rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Stat' ;
    rdfs:comment 'Expected turnaround time for STAT (urgent) test orders requiring expedited processing, typically expressed in minutes or hours (e.g., 30 minutes, 1 hour, 2 hours).' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSetId rdf:type rdf:Property ;
    rdfs:label 'Order Set Id' ;
    rdfs:comment 'Foreign key linking to order.set. Business justification: Appointment types trigger associated order sets at scheduling (e.g., pre-op appointment type auto-populates a pre-op order set). This is a standard EHR clinical decision support workflow — scheduling ' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Set .

ind:requiredFormTemplateId rdf:type rdf:Property ;
    rdfs:label 'Required Form Template Id' ;
    rdfs:comment 'Foreign key linking to consent.form_template. Business justification: Healthcare operations require specific consent form templates per appointment type (e.g., surgical consult, research visit, procedure). This link drives automated consent workflow triggering at schedu' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormTemplate .

ind:allowsSelfScheduling rdf:type rdf:Property ;
    rdfs:label 'Allows Self Scheduling' ;
    rdfs:comment 'Allows self-scheduling flag' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowsTelehealth rdf:type rdf:Property ;
    rdfs:label 'Allows Telehealth' ;
    rdfs:comment 'Allows telehealth flag' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appointmentTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Type Status' ;
    rdfs:comment 'Status' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingClass rdf:type rdf:Property ;
    rdfs:label 'Billing Class' ;
    rdfs:comment 'Billing class' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationNoticeHours rdf:type rdf:Property ;
    rdfs:label 'Cancellation Notice Hours' ;
    rdfs:comment 'Cancellation notice hours' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defaultDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Default Duration Minutes' ;
    rdfs:comment 'Default duration' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Required' ;
    rdfs:comment 'Equipment required' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Maximum Duration Minutes' ;
    rdfs:comment 'Maximum duration' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Minimum Duration Minutes' ;
    rdfs:comment 'Minimum duration' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noShowPenaltyApplies rdf:type rdf:Property ;
    rdfs:label 'No Show Penalty Applies' ;
    rdfs:comment 'No-show penalty applies' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preparationInstructions rdf:type rdf:Property ;
    rdfs:label 'Preparation Instructions' ;
    rdfs:comment 'Preparation instructions' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityMeasureApplicable rdf:type rdf:Property ;
    rdfs:label 'Quality Measure Applicable' ;
    rdfs:comment 'Quality measure applicable' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reminderLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Reminder Lead Time Days' ;
    rdfs:comment 'Reminder lead time days' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresInterpreter rdf:type rdf:Property ;
    rdfs:label 'Requires Interpreter' ;
    rdfs:comment 'Requires interpreter' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresReferral rdf:type rdf:Property ;
    rdfs:label 'Requires Referral' ;
    rdfs:comment 'Requires referral' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roomTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Room Type Required' ;
    rdfs:comment 'Room type required' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rvuMalpractice rdf:type rdf:Property ;
    rdfs:label 'Rvu Malpractice' ;
    rdfs:comment 'RVU malpractice' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rvuPracticeExpense rdf:type rdf:Property ;
    rdfs:label 'Rvu Practice Expense' ;
    rdfs:comment 'RVU practice expense' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:staffRolesRequired rdf:type rdf:Property ;
    rdfs:label 'Staff Roles Required' ;
    rdfs:comment 'Staff roles required' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vibePlaceholder rdf:type rdf:Property ;
    rdfs:label 'Vibe Placeholder' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitlistEligible rdf:type rdf:Property ;
    rdfs:label 'Waitlist Eligible' ;
    rdfs:comment 'Waitlist eligible' ;
    rdfs:domain ind:AppointmentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleTemplateId rdf:type rdf:Property ;
    rdfs:label 'Schedule Template Id' ;
    rdfs:comment 'Primary key for schedule_template' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleTemplate .

ind:schedulableResourceId rdf:type rdf:Property ;
    rdfs:label 'Schedulable Resource Id' ;
    rdfs:comment 'Identifier for the resource (room, equipment, facility) to which this template applies. Null if template applies to a provider.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SchedulableResource .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when this schedule template was approved. Null if not yet approved or approval is not required.' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:autoConfirmFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Confirm Flag' ;
    rdfs:comment 'Indicates whether appointments scheduled under this template are automatically confirmed or require manual confirmation. True auto-confirms; False requires manual review.' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bufferTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Buffer Time Minutes' ;
    rdfs:comment 'Buffer time in minutes added between consecutive appointment slots to allow for provider preparation, documentation, or patient transition.' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Policy Code' ;
    rdfs:comment 'Code identifying the cancellation policy applicable to appointments scheduled under this template (e.g., \'24_HOUR\', \'48_HOUR\', \'NO_SHOW_FEE\').' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Day Of Week' ;
    rdfs:comment 'Comma-separated list of days of the week this template applies to (e.g., \'Monday,Wednesday,Friday\'). Used for weekly recurrence patterns. [ENUM-REF-CANDIDATE: Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday — promote to reference product]' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSlotsPerSession rdf:type rdf:Property ;
    rdfs:label 'Max Slots Per Session' ;
    rdfs:comment 'Maximum number of appointment slots that can be scheduled within a single session. Used for capacity planning and overbooking control.' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noShowTrackingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'No Show Tracking Enabled Flag' ;
    rdfs:comment 'Indicates whether no-show events are tracked for appointments scheduled under this template. True enables tracking; False does not.' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overbookingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Overbooking Allowed Flag' ;
    rdfs:comment 'Indicates whether overbooking (scheduling beyond max_slots_per_session) is permitted for this template. True allows overbooking; False enforces strict capacity limits.' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overbookingLimit rdf:type rdf:Property ;
    rdfs:label 'Overbooking Limit' ;
    rdfs:comment 'Maximum number of additional slots that can be overbooked beyond max_slots_per_session. Null if overbooking is not allowed.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Priority classification for appointments scheduled under this template. Determines scheduling urgency and slot allocation rules.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrencePattern rdf:type rdf:Property ;
    rdfs:label 'Recurrence Pattern' ;
    rdfs:comment 'Defines how the template recurs over time: daily, weekly, biweekly, monthly, rotating shift, or custom pattern.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceRule rdf:type rdf:Property ;
    rdfs:label 'Recurrence Rule' ;
    rdfs:comment 'Detailed recurrence rule in iCalendar RRULE format or system-specific notation defining the exact repeat logic (e.g., \'FREQ=WEEKLY;BYDAY=MO,WE,FR\').' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Reminder Enabled Flag' ;
    rdfs:comment 'Indicates whether automated appointment reminders (SMS, email, phone) are sent for appointments scheduled under this template. True enables reminders; False disables.' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reminderLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Reminder Lead Time Hours' ;
    rdfs:comment 'Number of hours before the appointment when the reminder is sent. Null if reminders are not enabled.' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Session Duration Minutes' ;
    rdfs:comment 'Total duration of the scheduled session in minutes. Calculated as the difference between session start and end times.' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionEndTime rdf:type rdf:Property ;
    rdfs:label 'Session End Time' ;
    rdfs:comment 'Time of day when the scheduled session ends, in HH:MM 24-hour format (e.g., \'17:00\', \'21:00\').' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStartTime rdf:type rdf:Property ;
    rdfs:label 'Session Start Time' ;
    rdfs:comment 'Time of day when the scheduled session begins, in HH:MM 24-hour format (e.g., \'08:00\', \'13:30\').' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slotDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Slot Duration Minutes' ;
    rdfs:comment 'Duration of each individual appointment slot within the session, in minutes (e.g., 15, 30, 60). Determines how many slots are generated per session.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:telehealthEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Telehealth Enabled Flag' ;
    rdfs:comment 'Indicates whether this schedule template supports telehealth/virtual appointments. True enables telehealth; False restricts to in-person only.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Business-friendly name for the schedule template (e.g., \'Dr. Smith Monday Clinic\', \'OR 3 Weekday Block\').' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateStatus rdf:type rdf:Property ;
    rdfs:label 'Template Status' ;
    rdfs:comment 'Current lifecycle status of the schedule template. Active templates are used for slot generation; inactive/retired templates are historical.' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateType rdf:type rdf:Property ;
    rdfs:label 'Template Type' ;
    rdfs:comment 'Classification of the schedule template indicating whether it applies to a provider, resource, facility, equipment, room, or staff member.' ;
    rdfs:domain ind:ScheduleTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitlistEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Waitlist Enabled Flag' ;
    rdfs:comment 'Indicates whether a waitlist is maintained for this schedule template when all slots are filled. True enables waitlist management; False does not.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerAvailabilityId rdf:type rdf:Property ;
    rdfs:label 'Provider Availability Id' ;
    rdfs:comment 'Foreign key linking to scheduling.provider_availability. Business justification: open_slot slots are generated within provider availability windows. Linking open_slot to provider_availability via provider_availability_id establishes the traceability chain: availability window → op' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProviderAvailability .

ind:blockReason rdf:type rdf:Property ;
    rdfs:label 'Block Reason' ;
    rdfs:comment 'Free-text explanation for why the slot is blocked or unavailable. Examples include provider time off, equipment maintenance, facility closure, administrative time. Null if slot is available for booking.' ;
    rdfs:domain ind:OpenSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockType rdf:type rdf:Property ;
    rdfs:label 'Block Type' ;
    rdfs:comment 'Categorization of the reason the slot is blocked. Used for reporting on non-clinical time utilization and capacity planning. Null if slot is not blocked.' ;
    rdfs:domain ind:OpenSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdExpirationDatetime rdf:type rdf:Property ;
    rdfs:label 'Hold Expiration Datetime' ;
    rdfs:comment 'The date and time when a held slot will automatically be released if not confirmed. Null if slot is not currently held. Used to prevent indefinite slot blocking and optimize capacity utilization.' ;
    rdfs:domain ind:OpenSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Free-text explanation for why the slot is held. Examples include pending insurance authorization, awaiting patient callback, reserved for urgent referral. Null if slot is not held.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Indicates whether the slot is currently held for a specific patient or referral. Held slots are temporarily reserved pending confirmation. Expired holds are automatically released after a configured timeout period.' ;
    rdfs:domain ind:OpenSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceEligibility rdf:type rdf:Property ;
    rdfs:label 'Insurance Eligibility' ;
    rdfs:comment 'Comma-separated list of insurance types or payer groups accepted for this slot. Examples include Medicare, Medicaid, commercial, self-pay. Used for payer-specific access management and network compliance.' ;
    rdfs:domain ind:OpenSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedDatetime rdf:type rdf:Property ;
    rdfs:label 'Last Modified Datetime' ;
    rdfs:comment 'The date and time when this slot record was last updated. Tracks changes to slot status, capacity, or configuration. Critical for real-time slot availability synchronization.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Capacity' ;
    rdfs:comment 'The maximum number of appointments that can be booked in this slot. Typically 1 for individual provider appointments, but may be higher for group visits, classes, or high-volume clinics.' ;
    rdfs:domain ind:OpenSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onlineBookingCutoffHours rdf:type rdf:Property ;
    rdfs:label 'Online Booking Cutoff Hours' ;
    rdfs:comment 'The minimum number of hours in advance that a patient must book this slot online. Prevents same-day or last-minute online bookings. Null if no cutoff applies or online booking is disabled.' ;
    rdfs:domain ind:OpenSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onlineBookingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Online Booking Enabled Flag' ;
    rdfs:comment 'Indicates whether this slot is available for patient self-scheduling through online portals such as Epic MyChart or Cerner patient portal. False restricts booking to staff-assisted scheduling only.' ;
    rdfs:domain ind:OpenSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overbookAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Overbook Allowed Flag' ;
    rdfs:comment 'Indicates whether this slot can be overbooked beyond its max_capacity. True allows scheduling additional appointments when slot is full, typically used for urgent or walk-in patients. False enforces strict capacity limits.' ;
    rdfs:domain ind:OpenSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientTypeEligibility rdf:type rdf:Property ;
    rdfs:label 'Patient Type Eligibility' ;
    rdfs:comment 'Defines which patient types can book this slot. Examples include established patient only, new patient only, pediatric, adult, geriatric. Used to enforce age restrictions and patient relationship requirements.' ;
    rdfs:domain ind:OpenSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingCapacity rdf:type rdf:Property ;
    rdfs:label 'Remaining Capacity' ;
    rdfs:comment 'The number of appointments that can still be booked in this slot. Supports overbooking scenarios where multiple patients can be scheduled in the same time slot. Value of 0 indicates slot is fully booked.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slotCategory rdf:type rdf:Property ;
    rdfs:label 'Slot Category' ;
    rdfs:comment 'Broad categorization of the slot for grouping and filtering purposes. Examples include outpatient, surgical, diagnostic, telehealth, emergency. Used for capacity planning and reporting.' ;
    rdfs:domain ind:OpenSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Slot End Datetime' ;
    rdfs:comment 'The date and time when the slot ends. Represents the latest time an appointment can conclude in this slot. Used to calculate slot duration and prevent overbooking.' ;
    rdfs:domain ind:OpenSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slotIdentifier rdf:type rdf:Property ;
    rdfs:label 'Slot Identifier' ;
    rdfs:comment 'Human-readable business identifier for the slot, typically generated from schedule template and date/time. Used for external reference and display in Epic Cadence and Cerner scheduling interfaces.' ;
    rdfs:domain ind:OpenSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Slot Start Datetime' ;
    rdfs:comment 'The date and time when the slot begins. Represents the earliest time an appointment can start in this slot. Critical for patient scheduling and resource allocation.' ;
    rdfs:domain ind:OpenSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slotStatus rdf:type rdf:Property ;
    rdfs:label 'Slot Status' ;
    rdfs:comment 'Current availability status of the slot. Free indicates bookable, busy indicates occupied, busy-unavailable indicates blocked, busy-tentative indicates held pending confirmation. Aligns with HL7 FHIR SlotStatus value set.' ;
    rdfs:domain ind:OpenSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotType rdf:type rdf:Property ;
    rdfs:label 'Slot Type' ;
    rdfs:comment 'Classification of the slot indicating the kind of appointment or service that can be booked. Examples include new patient visit, follow-up, procedure, telehealth, walk-in. Sourced from Epic Cadence visit type or Cerner appointment type configuration.' ;
    rdfs:domain ind:OpenSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockOwnerNpiRegistryId rdf:type rdf:Property ;
    rdfs:label 'Block Owner Npi Registry Id' ;
    rdfs:comment 'Foreign key linking to reference.npi_registry. Business justification: OR block scheduling assigns surgical time to specific providers identified by NPI (`block_owner_npi` is a plain denormalized attr). Linking to npi_registry supports OR block utilization reporting, cre' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NpiRegistry .

ind:claimPriorAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Claim Prior Authorization Id' ;
    rdfs:comment 'Foreign key linking to claim.prior_authorization. Business justification: Surgical procedures routinely require prior authorization. Case coordinators verify authorization approval, approved CPT codes, and unit limits before scheduling OR time. Authorization status is a gat' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriorAuthorization .

ind:preOpDiagnosisIcdCodeId rdf:type rdf:Property ;
    rdfs:label 'Pre Op Diagnosis Icd Code Id' ;
    rdfs:comment 'Foreign key linking to reference.icd_code. Business justification: Pre-operative diagnosis ICD code required for surgical authorization, medical necessity validation, DRG assignment, and clinical documentation. Essential for case scheduling approval and compliance.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcdCode .

ind:primaryProcedureCptCodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Procedure Cpt Code Id' ;
    rdfs:comment 'Foreign key linking to reference.cpt_code. Business justification: Primary procedure CPT lookup required for OR block allocation, case costing, anesthesia base unit calculation, equipment requirements, and surgical billing. Critical for perioperative scheduling and r' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CptCode .

ind:primarySurgeonClinicianId rdf:type rdf:Property ;
    rdfs:label 'Primary Surgeon Clinician Id' ;
    rdfs:comment 'Foreign key linking to provider.clinician. Business justification: Primary surgeon assignment is a core OR scheduling requirement. Direct FK to clinician enables surgical privileging verification, surgeon-level OR utilization reporting, malpractice coverage validatio' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:actualDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Minutes' ;
    rdfs:comment 'Actual length of the surgical procedure in minutes. Calculated from actual start and end times. Used for performance benchmarking and future duration estimation refinement.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual date and time when the surgical procedure concluded. Captured when the patient exits the OR or when closure is complete. Used for duration variance analysis and turnover time calculation.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Actual date and time when the surgical procedure began. Captured when the patient enters the operating room or when incision occurs, depending on institutional policy. Used for on-time start performance measurement.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:addOnCaseIndicator rdf:type rdf:Property ;
    rdfs:label 'Add On Case Indicator' ;
    rdfs:comment 'Indicates whether this case was added to the schedule after the initial scheduling deadline. Add-on cases may indicate urgent needs or scheduling inefficiencies.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockTimeIndicator rdf:type rdf:Property ;
    rdfs:label 'Block Time Indicator' ;
    rdfs:comment 'Indicates whether this case is scheduled within a surgeon\'s allocated block time. Block time is pre-reserved OR time assigned to specific surgeons or services. Used for block utilization reporting.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when the surgical case was cancelled. Used to measure cancellation lead time and assess impact on OR utilization.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the surgical case. Tracks progression from initial request through completion or cancellation. Critical for operational dashboards and capacity planning. [ENUM-REF-CANDIDATE: requested|scheduled|confirmed|in_progress|completed|cancelled|postponed|on_hold — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the surgical case based on patient status and urgency. Determines scheduling priority, resource allocation, and billing rules.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentObtainedIndicator rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Indicator' ;
    rdfs:comment 'Indicates whether informed consent has been obtained from the patient or legal representative. Required before proceeding with surgery. Used for compliance verification.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Date and time when informed consent was obtained. Used for regulatory compliance documentation and pre-operative checklist verification.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:equipmentRequirements rdf:type rdf:Property ;
    rdfs:label 'Equipment Requirements' ;
    rdfs:comment 'Special equipment or instrumentation required for the surgical case. Free-text or structured list of equipment codes. Used for equipment scheduling and availability verification.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Estimated length of the surgical procedure in minutes. Based on historical averages for the procedure type, surgeon, and patient complexity. Used for block time allocation and scheduling optimization.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:implantRequired rdf:type rdf:Property ;
    rdfs:label 'Implant Required' ;
    rdfs:comment 'Indicates whether the surgical case requires implantable devices or hardware. Triggers supply chain coordination and implant tracking requirements.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postOpDiagnosis rdf:type rdf:Property ;
    rdfs:label 'Post Op Diagnosis' ;
    rdfs:comment 'Final clinical diagnosis documented after the surgical procedure. May differ from pre-operative diagnosis based on intra-operative findings. Used for billing and clinical documentation.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresBloodProducts rdf:type rdf:Property ;
    rdfs:label 'Requires Blood Products' ;
    rdfs:comment 'Indicates whether the surgical case requires blood products to be available. Triggers blood bank coordination and type-and-screen orders.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresIcuBed rdf:type rdf:Property ;
    rdfs:label 'Requires Icu Bed' ;
    rdfs:comment 'Indicates whether the patient will require an ICU bed post-operatively. Used for bed management and capacity planning coordination between OR and ICU.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Date on which the surgical procedure is scheduled to occur. Used for day-level capacity planning and patient preparation scheduling.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Anticipated date and time when the surgical case is expected to conclude. Calculated from scheduled start time plus estimated duration. Used for downstream resource planning.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Precise date and time when the surgical case is scheduled to begin. Used for minute-level OR scheduling, staff coordination, and patient arrival instructions.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:siteMarkedIndicator rdf:type rdf:Property ;
    rdfs:label 'Site Marked Indicator' ;
    rdfs:comment 'Indicates whether the surgical site has been marked by the surgeon. Required by the Universal Protocol for procedures involving laterality or multiple structures. Used for pre-operative safety checklist.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialty rdf:type rdf:Property ;
    rdfs:label 'Specialty' ;
    rdfs:comment 'Medical specialty of the primary surgeon or the procedure type. More granular than service line. Used for surgeon credentialing and case mix analysis.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeoutCompletedIndicator rdf:type rdf:Property ;
    rdfs:label 'Timeout Completed Indicator' ;
    rdfs:comment 'Indicates whether the surgical team completed the mandatory pre-incision timeout. Timeout verifies patient identity, procedure, site, and team readiness. Required by The Joint Commission.' ;
    rdfs:domain ind:SurgicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowsOverbooking rdf:type rdf:Property ;
    rdfs:label 'Allows Overbooking' ;
    rdfs:comment 'Indicates whether the resource permits overbooking (scheduling more appointments than standard capacity allows). True if overbooking is permitted, False otherwise.' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:building rdf:type rdf:Property ;
    rdfs:label 'Building' ;
    rdfs:comment 'Building name or number within the facility where the resource is located. Applicable primarily to room and equipment resources.' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultSlotDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Default Slot Duration Minutes' ;
    rdfs:comment 'Standard duration in minutes for a single scheduling slot or appointment block for this resource. Used as the default when creating schedules.' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:floor rdf:type rdf:Property ;
    rdfs:label 'Floor' ;
    rdfs:comment 'Floor number or level within the building where the resource is located. Applicable primarily to room and equipment resources.' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Code representing the specific location, building, or campus where the resource is situated. Used for geographic and logistical scheduling.' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window End' ;
    rdfs:comment 'End date and time of scheduled maintenance or downtime window. Applicable primarily to equipment and room resources.' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maintenanceWindowStart rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window Start' ;
    rdfs:comment 'Start date and time of scheduled maintenance or downtime window during which the resource is unavailable for scheduling. Applicable primarily to equipment and room resources.' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:minimumTurnoverTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Minimum Turnover Time Minutes' ;
    rdfs:comment 'Minimum time in minutes required between consecutive appointments or uses of the resource. Includes cleaning, setup, and preparation time. Critical for scheduling optimization and capacity planning.' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resourceCode rdf:type rdf:Property ;
    rdfs:label 'Resource Code' ;
    rdfs:comment 'Unique business identifier or code for the resource. May be an internal system code, asset tag, or room number depending on resource type.' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceName rdf:type rdf:Property ;
    rdfs:label 'Resource Name' ;
    rdfs:comment 'Human-readable name or title of the schedulable resource. For providers, this is the full name; for rooms, the room designation; for equipment, the equipment name or model.' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceType rdf:type rdf:Property ;
    rdfs:label 'Resource Type' ;
    rdfs:comment 'Classification of the schedulable resource: provider (physicians, APPs, therapists), room (exam, OR suite, procedure, imaging, infusion bay), equipment (MRI, CT, C-arm, surgical robot, laser, perfusion pump), or care team.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomCapacity rdf:type rdf:Property ;
    rdfs:label 'Room Capacity' ;
    rdfs:comment 'Maximum number of patients or occupants that can be accommodated in the room simultaneously. Applicable only to room resources. Null for non-room resources.' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomConfiguration rdf:type rdf:Property ;
    rdfs:label 'Room Configuration' ;
    rdfs:comment 'Physical configuration or layout of the room (e.g., single-bed, multi-bed, open bay, private suite). Applicable only to room resources.' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingConstraints rdf:type rdf:Property ;
    rdfs:label 'Scheduling Constraints' ;
    rdfs:comment 'Free-text description of any special scheduling rules, restrictions, or constraints that apply to this resource (e.g., only available for specific appointment types, requires advance booking, limited to certain patient populations).' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingStatus rdf:type rdf:Property ;
    rdfs:label 'Scheduling Status' ;
    rdfs:comment 'Current availability status of the resource for scheduling purposes. Active resources are available for scheduling; inactive resources are temporarily unavailable; maintenance resources are undergoing service; reserved resources are held for specific purposes; retired resources are permanently removed from service.' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sterilizationCycleRequired rdf:type rdf:Property ;
    rdfs:label 'Sterilization Cycle Required' ;
    rdfs:comment 'Indicates whether the resource requires a sterilization cycle between uses. True if sterilization is required, False otherwise. Applicable primarily to equipment and room resources used in surgical or procedural settings.' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sterilizationDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Sterilization Duration Minutes' ;
    rdfs:comment 'Duration in minutes required to complete the sterilization cycle for the resource. Applicable only when sterilization_cycle_required is True.' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:telehealthEnabled rdf:type rdf:Property ;
    rdfs:label 'Telehealth Enabled' ;
    rdfs:comment 'Indicates whether the resource supports telehealth or virtual visit appointments. True if telehealth is supported, False otherwise. Applicable primarily to provider resources.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unit rdf:type rdf:Property ;
    rdfs:label 'Unit' ;
    rdfs:comment 'Unit, wing, or zone designation within the floor where the resource is located. Applicable primarily to room and equipment resources.' ;
    rdfs:domain ind:SchedulableResource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Resource Assignment Id' ;
    rdfs:comment 'Primary key for resource_assignment' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substituteForResourceAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Substitute For Resource Assignment Id' ;
    rdfs:comment 'Foreign key reference to another resource assignment that this assignment is substituting for. Used when a resource is replaced due to unavailability, conflict, or last-minute changes.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResourceAssignment .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual date and time when the resource assignment concluded. Used to calculate actual duration, resource utilization, and case completion metrics.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual date and time when the resource assignment began. Captures real-world start time for variance analysis, billing accuracy, and operational performance measurement.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text notes or special instructions related to this resource assignment. May include preferences, constraints, special equipment needs, or coordination details.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentPriority rdf:type rdf:Property ;
    rdfs:label 'Assignment Priority' ;
    rdfs:comment 'Priority level for this resource assignment. Determines scheduling precedence and resource allocation urgency, especially critical for Operating Room (OR) and Emergency Department (ED) scheduling.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentRole rdf:type rdf:Property ;
    rdfs:label 'Assignment Role' ;
    rdfs:comment 'Specific role or function the resource performs in this appointment or case. Examples include primary surgeon, co-surgeon, anesthesiologist, Certified Registered Nurse Anesthetist (CRNA), scrub technician, circulating nurse, perfusionist, equipment operator, primary care provider. [ENUM-REF-CANDIDATE: primary_surgeon|co_surgeon|assistant_surgeon|anesthesiologist|crna|scrub_tech|circulating_nurse|perfusionist|equipment_operator|primary_provider|consulting_provider|radiologist|pathologist|respiratory_therapist — promote to reference product]' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billableFlag rdf:type rdf:Property ;
    rdfs:label 'Billable Flag' ;
    rdfs:comment 'Boolean indicator of whether this resource assignment generates a billable charge. Used to determine which assignments flow to revenue cycle and claims processing.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmationDatetime rdf:type rdf:Property ;
    rdfs:label 'Confirmation Datetime' ;
    rdfs:comment 'Date and time when the resource confirmed their assignment. Tracks confirmation lead time and supports compliance with staffing notification requirements.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Indicates whether the assigned resource has confirmed their availability and commitment to this assignment. Critical for surgical case staffing and high-acuity appointments.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictDescription rdf:type rdf:Property ;
    rdfs:label 'Conflict Description' ;
    rdfs:comment 'Free-text description of the nature of the scheduling conflict, if one exists. Provides context for resolution and audit trail of scheduling issues.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Flag' ;
    rdfs:comment 'Boolean indicator of whether this resource assignment has a scheduling conflict with another assignment or unavailability period. Triggers alerts for scheduling coordinators to resolve double-bookings.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:credentialingVerificationDatetime rdf:type rdf:Property ;
    rdfs:label 'Credentialing Verification Datetime' ;
    rdfs:comment 'Date and time when credentialing verification was completed for this assignment. Documents compliance with pre-assignment credentialing checks.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:equipmentAssetTag rdf:type rdf:Property ;
    rdfs:label 'Equipment Asset Tag' ;
    rdfs:comment 'Physical asset tag or serial number of the specific equipment unit assigned. Enables traceability for maintenance, sterilization, and recall management.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentReservationStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Reservation Status' ;
    rdfs:comment 'Current status of equipment reservation for this assignment. Tracks equipment lifecycle from initial reservation through active use and return to inventory.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent preventive or corrective maintenance performed on the assigned equipment. Supports compliance with manufacturer and regulatory maintenance schedules.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceClearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Maintenance Clearance Flag' ;
    rdfs:comment 'Boolean indicator of whether assigned equipment has passed required maintenance checks and is cleared for clinical use. Ensures equipment safety and regulatory compliance.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noShowFlag rdf:type rdf:Property ;
    rdfs:label 'No Show Flag' ;
    rdfs:comment 'Boolean indicator of whether the assigned resource failed to appear for their scheduled assignment. Used for provider and staff attendance tracking and performance management.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryAssignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Assignment Flag' ;
    rdfs:comment 'Boolean indicator of whether this is the primary resource assignment for the appointment or case. Distinguishes the lead provider or primary room from supporting resources.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privilegeCode rdf:type rdf:Property ;
    rdfs:label 'Privilege Code' ;
    rdfs:comment 'Code representing the specific clinical privilege or authorization required and verified for this assignment. Links to the provider\'s credentialed privileges for the procedure or service type.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDatetime rdf:type rdf:Property ;
    rdfs:label 'Requested Datetime' ;
    rdfs:comment 'Date and time when this resource assignment was initially requested or created. Supports lead time analysis and scheduling workflow tracking.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'Planned date and time when the resource assignment is scheduled to conclude. Used for capacity planning and resource turnover scheduling.' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sterilizationBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Sterilization Batch Number' ;
    rdfs:comment 'Batch or lot number from the sterilization process for assigned equipment. Enables traceability in case of sterilization failures or Healthcare-Associated Infection (HAI) investigations.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sterilizationClearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Sterilization Clearance Flag' ;
    rdfs:comment 'Boolean indicator of whether assigned equipment has passed sterilization and is cleared for use. Critical for infection control and patient safety in surgical and procedural settings.' ;
    rdfs:domain ind:ResourceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Id' ;
    rdfs:comment 'Foreign key linking to claim.eligibility. Business justification: Waitlist management requires real-time eligibility verification to prioritize patients with active coverage before offering open slots. Scheduling staff run eligibility checks on waitlisted patients; ' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Eligibility .

ind:indexVisitId rdf:type rdf:Property ;
    rdfs:label 'Index Visit Id' ;
    rdfs:comment 'Foreign key linking to encounter.visit. Business justification: Care coordinators must trace which encounter visit triggered a waitlist placement (e.g., ED visit generating specialist waitlist) for care transition compliance and HRRP root-cause analysis. Role pref' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Visit .

ind:preferredSchedulableResourceId rdf:type rdf:Property ;
    rdfs:label 'Preferred Schedulable Resource Id' ;
    rdfs:comment 'Foreign key linking to scheduling.schedulable_resource. Business justification: waitlist_entry.specialty_required is a STRING capturing the required specialty, but there is no FK to the preferred provider or resource. Adding preferred_schedulable_resource_id to waitlist_entry ide' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SchedulableResource .

ind:primaryWaitlistClinicianId rdf:type rdf:Property ;
    rdfs:label 'Primary Waitlist Clinician Id' ;
    rdfs:comment 'Identifier for the specific provider requested by the patient or referring provider. Null if no specific provider preference. Links to provider master data.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:requestedAppointmentTypeId rdf:type rdf:Property ;
    rdfs:label 'Requested Appointment Type Id' ;
    rdfs:comment 'Identifier for the type of appointment requested by the patient or ordering provider. Links to appointment type master data.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AppointmentType .

ind:visitReasonIcdCodeId rdf:type rdf:Property ;
    rdfs:label 'Visit Reason Icd Code Id' ;
    rdfs:comment 'Foreign key linking to reference.icd_code. Business justification: Waitlist visit reason ICD codes enable clinical prioritization, authorization requirement determination, specialty matching, and quality measure tracking. Critical for access management and care gap c' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcdCode .

ind:entryNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Number' ;
    rdfs:comment 'Business-facing unique identifier or tracking number for the waitlist entry, used for patient communication and scheduling team reference.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current lifecycle status of the waitlist entry: active (awaiting action), offered (appointment offered to patient), accepted (patient accepted offer), expired (entry aged out or SLA missed), removed (manually removed from queue), pending (awaiting information or approval), in_progress (actively being worked by scheduling team), scheduled (appointment successfully scheduled), escalated (escalated due to aging or priority), closed (completed or resolved). [ENUM-REF-CANDIDATE: active|offered|accepted|expired|removed|pending|in_progress|scheduled|escalated|closed — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Classification of the waitlist entry indicating the source or nature of the scheduling request: waitlist (patient-initiated or provider-requested appointment waitlist), referral_queue (unscheduled referral awaiting scheduling), order_based (pending order requiring appointment), recall (recall-driven request for follow-up), surgical_request (surgical scheduling request), work_queue (general scheduling department work item).' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDatetime rdf:type rdf:Property ;
    rdfs:label 'Escalation Datetime' ;
    rdfs:comment 'Date and time when the waitlist entry was escalated. Null if never escalated.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether this waitlist entry has been escalated due to aging, priority, or SLA breach. True if escalated for management attention.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Free-text or coded reason for escalation (e.g., SLA breach, high clinical priority, patient complaint, aging threshold exceeded).' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedWaitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Wait Time Days' ;
    rdfs:comment 'Estimated number of days the patient will wait from queue entry to scheduled appointment, based on current capacity and demand forecasting.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Patient preferred language for communication and care delivery. ISO 639-2 three-letter language code (e.g., eng for English, spa for Spanish).' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOutreachDatetime rdf:type rdf:Property ;
    rdfs:label 'Last Outreach Datetime' ;
    rdfs:comment 'Date and time of the most recent outreach attempt to the patient. Null if no outreach has been attempted.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastOutreachMethod rdf:type rdf:Property ;
    rdfs:label 'Last Outreach Method' ;
    rdfs:comment 'Method used for the most recent outreach attempt: phone call, email, SMS text, patient portal message, postal mail.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outreachAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Outreach Attempt Count' ;
    rdfs:comment 'Number of times the scheduling team has attempted to contact the patient to schedule the appointment. Used for tracking patient engagement and no-contact protocols.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredContactChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Channel' ;
    rdfs:comment 'Patient preferred method of contact for scheduling outreach and appointment notifications: phone, email, SMS text message, patient portal message, postal mail.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDaysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Preferred Days Of Week' ;
    rdfs:comment 'Patient preference for days of the week for scheduling (e.g., Monday, Wednesday, Friday). Stored as comma-separated list or coded representation.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredTimeOfDay rdf:type rdf:Property ;
    rdfs:label 'Preferred Time Of Day' ;
    rdfs:comment 'Patient preference for time of day for scheduling: morning (before noon), afternoon (noon to 5pm), evening (after 5pm), any (no preference).' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queueEntryDatetime rdf:type rdf:Property ;
    rdfs:label 'Queue Entry Datetime' ;
    rdfs:comment 'Date and time when the patient was added to the waitlist or scheduling queue. Used for aging calculations and first-in-first-out queue management.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:removalDatetime rdf:type rdf:Property ;
    rdfs:label 'Removal Datetime' ;
    rdfs:comment 'Date and time when the waitlist entry was removed from the queue without scheduling (e.g., patient declined, no longer needed, duplicate entry). Null if not removed.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Datetime' ;
    rdfs:comment 'Date and time when the appointment was successfully scheduled and the waitlist entry was resolved. Null if not yet scheduled.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaTargetDatetime rdf:type rdf:Property ;
    rdfs:label 'Sla Target Datetime' ;
    rdfs:comment 'Target date and time by which the scheduling action should be completed per organizational or regulatory service level agreement. Used for compliance monitoring and escalation triggers.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:telehealthEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Telehealth Eligible Flag' ;
    rdfs:comment 'Indicates whether the patient is eligible and willing to receive care via telehealth modality for this appointment request. True if telehealth is an acceptable option.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transportationAssistanceNeededFlag rdf:type rdf:Property ;
    rdfs:label 'Transportation Assistance Needed Flag' ;
    rdfs:comment 'Indicates whether the patient requires transportation assistance to attend the appointment. True if transportation support is needed.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visitReason rdf:type rdf:Property ;
    rdfs:label 'Visit Reason' ;
    rdfs:comment 'Free-text description of the clinical reason or chief complaint for the requested appointment.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitReasonCode rdf:type rdf:Property ;
    rdfs:label 'Visit Reason Code' ;
    rdfs:comment 'Coded representation of the visit reason using standard clinical terminology (e.g., SNOMED CT, ICD-10).' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentReminderId rdf:type rdf:Property ;
    rdfs:label 'Appointment Reminder Id' ;
    rdfs:comment 'Primary key for appointment_reminder' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:telehealthSessionId rdf:type rdf:Property ;
    rdfs:label 'Telehealth Session Id' ;
    rdfs:comment 'Foreign key linking to scheduling.telehealth_session. Business justification: Telehealth appointments require specific reminders including session access codes, platform instructions, and technical preparation guidance. appointment_reminder has no FK to telehealth_session. Addi' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TelehealthSession .

ind:actualSendDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Send Datetime' ;
    rdfs:comment 'The actual date and time when the reminder was sent by the messaging system. May differ from scheduled send time due to system delays or batch processing.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Date' ;
    rdfs:comment 'The date of the appointment for which this reminder was sent. Denormalized from the scheduling_appointment product for reporting convenience.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointmentTime rdf:type rdf:Property ;
    rdfs:label 'Appointment Time' ;
    rdfs:comment 'The scheduled start time of the appointment for which this reminder was sent. Denormalized from the scheduling_appointment product for reporting convenience.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:attemptNumber rdf:type rdf:Property ;
    rdfs:label 'Attempt Number' ;
    rdfs:comment 'The sequential attempt number for this reminder (e.g., 1 for first attempt, 2 for second attempt). Supports tracking of retry logic and escalation workflows.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Identifier for the reminder campaign or program under which this reminder was sent (e.g., no-show reduction initiative, seasonal flu shot reminders). Supports program-level analytics.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerReminder rdf:type rdf:Property ;
    rdfs:label 'Cost Per Reminder' ;
    rdfs:comment 'The cost incurred for sending this reminder through the selected delivery channel (e.g., SMS carrier fees, IVR system costs). Supports cost analysis and Return on Investment (ROI) calculation for reminder programs.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'The communication channel through which the reminder was sent (e.g., phone call, SMS text message, email, patient portal message, Interactive Voice Response (IVR), mobile app push notification).' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFailureReason rdf:type rdf:Property ;
    rdfs:label 'Delivery Failure Reason' ;
    rdfs:comment 'Detailed reason for delivery failure if the reminder was not successfully delivered (e.g., invalid phone number, email bounce, patient portal not activated, carrier rejection).' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'The delivery status of the reminder message (e.g., sent, delivered, failed, bounced, undeliverable, pending, cancelled). Indicates whether the message successfully reached the patient. [ENUM-REF-CANDIDATE: sent|delivered|failed|bounced|undeliverable|pending|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'The name of the department where the appointment is scheduled. Denormalized for patient communication and reporting purposes.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'The name of the facility where the appointment is scheduled. Denormalized for patient communication and reporting purposes.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'The two-letter ISO 639-1 language code for the language in which the reminder was sent (e.g., en for English, es for Spanish). Supports multilingual patient communication.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'The number of days before the appointment that this reminder was scheduled to be sent. Supports analysis of optimal reminder timing for no-show reduction.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxAttemptsAllowed rdf:type rdf:Property ;
    rdfs:label 'Max Attempts Allowed' ;
    rdfs:comment 'The maximum number of reminder attempts configured for this appointment type or reminder workflow. Used to determine when to stop retry attempts.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:messageContent rdf:type rdf:Property ;
    rdfs:label 'Message Content' ;
    rdfs:comment 'The full text content of the reminder message sent to the patient. May contain appointment details and instructions. Stored for audit and quality review purposes.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutDatetime rdf:type rdf:Property ;
    rdfs:label 'Opt Out Datetime' ;
    rdfs:comment 'The date and time when the patient opted out of automated reminders, if applicable. Null if patient has not opted out.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Indicates whether the patient has opted out of receiving automated reminders. True if patient has opted out, False otherwise. Supports patient communication preferences and regulatory compliance.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recipientEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Recipient Email Address' ;
    rdfs:comment 'The email address to which the reminder was sent, if delivery channel was email. Protected Health Information (PHI) under HIPAA.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Recipient Phone Number' ;
    rdfs:comment 'The phone number to which the reminder was sent, if delivery channel was phone or SMS. Protected Health Information (PHI) under HIPAA.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderType rdf:type rdf:Property ;
    rdfs:label 'Reminder Type' ;
    rdfs:comment 'The type or sequence of the reminder in the automated reminder workflow (e.g., initial, first reminder, second reminder, final reminder, confirmation request, pre-visit instructions).' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseChannel rdf:type rdf:Property ;
    rdfs:label 'Response Channel' ;
    rdfs:comment 'The channel through which the patient responded to the reminder (e.g., phone call, SMS reply, email reply, patient portal, IVR system, mobile app).' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDatetime rdf:type rdf:Property ;
    rdfs:label 'Response Datetime' ;
    rdfs:comment 'The date and time when the patient responded to the reminder, if applicable. Null if no response was received.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledSendDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Send Datetime' ;
    rdfs:comment 'The date and time when the reminder was scheduled to be sent, based on the reminder lead time configuration and appointment date.' ;
    rdfs:domain ind:AppointmentReminder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distantSiteOrgProviderId rdf:type rdf:Property ;
    rdfs:label 'Distant Site Org Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.org_provider. Business justification: CMS telehealth billing requires identification of the distant site facility. Linking to org_provider enables Medicare/Medicaid distant site billing compliance, state licensure verification for cross-s' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgProvider .

ind:billingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Eligible Flag' ;
    rdfs:comment 'Indicates whether the telehealth session meets all requirements for billing and reimbursement. Based on completion status, duration, documentation, and payer rules.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingModifierCode rdf:type rdf:Property ;
    rdfs:label 'Billing Modifier Code' ;
    rdfs:comment 'CPT or HCPCS modifier code applied to the telehealth session for billing purposes (e.g., GT, 95, GQ). Indicates the service was delivered via telehealth.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDatetime rdf:type rdf:Property ;
    rdfs:label 'Cancellation Datetime' ;
    rdfs:comment 'Date and time when the telehealth session was cancelled, if applicable.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancelledByRole rdf:type rdf:Property ;
    rdfs:label 'Cancelled By Role' ;
    rdfs:comment 'Role of the person or system that initiated the cancellation of the telehealth session.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionQualityScore rdf:type rdf:Property ;
    rdfs:label 'Connection Quality Score' ;
    rdfs:comment 'Numeric score representing the overall quality of the telehealth connection, typically on a scale of 0-100. Based on bandwidth, latency, and stability metrics.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:connectionStatus rdf:type rdf:Property ;
    rdfs:label 'Connection Status' ;
    rdfs:comment 'Technical status of the network connection during the telehealth session. Used to track quality and troubleshoot issues.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDatetime rdf:type rdf:Property ;
    rdfs:label 'Consent Datetime' ;
    rdfs:comment 'Date and time when patient consent for telehealth services was obtained and documented.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interpreterPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Interpreter Present Flag' ;
    rdfs:comment 'Indicates whether an interpreter was actually present and participated in the telehealth session.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originatingSiteCode rdf:type rdf:Property ;
    rdfs:label 'Originating Site Code' ;
    rdfs:comment 'Code identifying the location where the patient is physically located during the telehealth session. Required for certain telehealth billing scenarios.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientBrowser rdf:type rdf:Property ;
    rdfs:label 'Patient Browser' ;
    rdfs:comment 'Web browser used by the patient to access the telehealth session, if applicable. Used for technical support and compatibility tracking.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientDeviceType rdf:type rdf:Property ;
    rdfs:label 'Patient Device Type' ;
    rdfs:comment 'Type of device used by the patient to access the telehealth session. Helps identify technical support needs and access patterns.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientOperatingSystem rdf:type rdf:Property ;
    rdfs:label 'Patient Operating System' ;
    rdfs:comment 'Operating system of the device used by the patient (e.g., iOS, Android, Windows, macOS). Used for troubleshooting and compatibility analysis.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformName rdf:type rdf:Property ;
    rdfs:label 'Platform Name' ;
    rdfs:comment 'Name of the telehealth platform or application used to conduct the session (e.g., Epic MyChart Video, Zoom for Healthcare, Doxy.me).' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformVendor rdf:type rdf:Property ;
    rdfs:label 'Platform Vendor' ;
    rdfs:comment 'Vendor or manufacturer of the telehealth platform used for the session.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerAttestationDatetime rdf:type rdf:Property ;
    rdfs:label 'Provider Attestation Datetime' ;
    rdfs:comment 'Date and time when the provider attested to the completion of the telehealth session.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:providerAttestationFlag rdf:type rdf:Property ;
    rdfs:label 'Provider Attestation Flag' ;
    rdfs:comment 'Indicates whether the provider has attested to the completion and clinical validity of the telehealth session. Required for billing and compliance.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerDeviceType rdf:type rdf:Property ;
    rdfs:label 'Provider Device Type' ;
    rdfs:comment 'Type of device used by the provider to conduct the telehealth session.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Recording Enabled Flag' ;
    rdfs:comment 'Indicates whether the telehealth session was recorded for clinical, educational, or quality purposes. Requires explicit patient consent.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Scheduled Duration Minutes' ;
    rdfs:comment 'Planned duration of the telehealth session in minutes, based on appointment type and clinical requirements.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionAccessCode rdf:type rdf:Property ;
    rdfs:label 'Session Access Code' ;
    rdfs:comment 'PIN or access code required to join the telehealth session. Used for additional security and patient verification.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionNumber rdf:type rdf:Property ;
    rdfs:label 'Session Number' ;
    rdfs:comment 'Human-readable business identifier for the telehealth session, used for tracking and reference purposes.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle status of the telehealth session. Tracks progression from scheduling through completion or cancellation.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionType rdf:type rdf:Property ;
    rdfs:label 'Session Type' ;
    rdfs:comment 'Type of telehealth modality used for the session. Determines workflow, platform requirements, and billing rules.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionUrl rdf:type rdf:Property ;
    rdfs:label 'Session Url' ;
    rdfs:comment 'Web link or URL provided to the patient and provider to access the telehealth session. Confidential to prevent unauthorized access.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalIssueDescription rdf:type rdf:Property ;
    rdfs:label 'Technical Issue Description' ;
    rdfs:comment 'Free-text description of any technical issues encountered during the telehealth session, such as connectivity problems, audio/video quality issues, or platform errors.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalIssueReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Issue Reported Flag' ;
    rdfs:comment 'Indicates whether any technical issues were reported during or after the telehealth session that impacted quality or completion.' ;
    rdfs:domain ind:TelehealthSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
