    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcedureEvent .

ind:carePlanId rdf:type rdf:Property ;
    rdfs:label 'Care Plan Id' ;
    rdfs:comment 'Foreign key linking to clinical.care_plan. Business justification: Procedures are often performed as part of a care plan (e.g., scheduled surgeries, therapeutic procedures, diagnostic workups ordered under a care plan). Adding care_plan_id to procedure_event enables ' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarePlan .

ind:dispenseEventId rdf:type rdf:Property ;
    rdfs:label 'Dispense Event Id' ;
    rdfs:comment 'Foreign key linking to pharmacy.dispense_event. Business justification: Perioperative pharmacy requires linking procedural medication dispense events (anesthesia drugs, contrast agents, procedural sedation) to the procedure that triggered them for charge capture, drug uti' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DispenseEvent .

ind:drugMasterId rdf:type rdf:Property ;
    rdfs:label 'Drug Master Id' ;
    rdfs:comment 'FK to drug master if procedure involved medication administration.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugMaster .

ind:performingGroupId rdf:type rdf:Property ;
    rdfs:label 'Performing Group Id' ;
    rdfs:comment 'Foreign key linking to provider.group. Business justification: Procedures in group practices are billed under a group NPI. MIPS group reporting, group-level quality measure attribution, and billing reconciliation require knowing which provider group performed the' ;
    rdfs:domain ind:ProcedureEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Group .

ind:performingOrgProviderId rdf:type rdf:Property ;
    rdfs:label 'Performing Org Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.org_provider. Business justification: Procedures are performed at a specific facility. CMS quality reporting, Joint Commission accreditation, procedure-level billing reconciliation, and outcomes tracking all require direct facility attrib' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgProvider .

ind:preopLabOrderId rdf:type rdf:Property ;
    rdfs:label 'Preop Lab Order Id' ;
    rdfs:comment 'FK to preoperative lab order.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
