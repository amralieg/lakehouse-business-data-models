    rdfs:comment 'Facility types where this form applies' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableServiceLines rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Lines' ;
    rdfs:comment 'Service lines where this form applies' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthority rdf:type rdf:Property ;
