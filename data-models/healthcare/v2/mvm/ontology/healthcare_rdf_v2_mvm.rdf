    rdfs:range xsd:string .

ind:formName rdf:type rdf:Property ;
    rdfs:label 'Form Name' ;
    rdfs:comment 'Name of form template' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formPurpose rdf:type rdf:Property ;
