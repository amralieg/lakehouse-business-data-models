ind:emergencyExceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Exception Flag' ;
    rdfs:comment 'Indicates whether treatment was provided under emergency exception provisions when informed consent could not be obtained due to the patient\'s condition and no authorized representative was available.' ;
    rdfs:domain ind:TreatmentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyExceptionJustification rdf:type rdf:Property ;
    rdfs:label 'Emergency Exception Justification' ;
    rdfs:comment 'Clinical documentation justifying why treatment was provided without informed consent under emergency exception provisions.' ;
    rdfs:domain ind:TreatmentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interpreterName rdf:type rdf:Property ;
    rdfs:label 'Interpreter Name' ;
    rdfs:comment 'Full name of the medical interpreter who facilitated the consent discussion.' ;
    rdfs:domain ind:TreatmentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Legal Representative Name' ;
