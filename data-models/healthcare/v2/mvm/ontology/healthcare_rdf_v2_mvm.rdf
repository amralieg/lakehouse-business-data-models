    rdfs:range xsd:string .

ind:maxAppointments rdf:type rdf:Property ;
    rdfs:label 'Max Appointments' ;
    rdfs:comment 'The maximum number of appointments that can be scheduled during this availability period. Null indicates no specific limit.' ;
