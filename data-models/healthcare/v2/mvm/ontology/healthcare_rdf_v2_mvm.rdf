    rdfs:domain ind:ProviderAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current status of the availability record in its lifecycle.' ;
    rdfs:domain ind:ProviderAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityType rdf:type rdf:Property ;
    rdfs:label 'Availability Type' ;
    rdfs:comment 'The type of availability record: scheduled (normal working hours), on_call (available for urgent calls), blocked (time blocked for non-clinical work), vacation (time off), cme (Continuing Medical Education), administrative (administrative duties).' ;
    rdfs:domain ind:ProviderAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookedAppointments rdf:type rdf:Property ;
