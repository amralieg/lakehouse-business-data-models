    rdfs:domain ind:Demographics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Unique surrogate identifier for each patient address record in the Master Patient Index (MPI). Primary key for the patient.address data product.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active indicates the address is in use; inactive indicates it has been superseded; undeliverable indicates mail has been returned or the address is not reachable; returned_mail indicates USPS or courier returned correspondence.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classifies the purpose of the address record. Supported types: home (primary residence), mailing (preferred correspondence), temporary (short-term stay), work (employer location), billing (financial correspondence), guarantor (responsible party address). [ENUM-REF-CANDIDATE: home|mailing|temporary|work|billing|guarantor — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaDeprivationIndex rdf:type rdf:Property ;
    rdfs:label 'Area Deprivation Index' ;
    rdfs:comment 'National Area Deprivation Index (ADI) score derived from the census tract of this address, ranging from 1 (least deprived) to 100 (most deprived). Used for SDOH risk stratification, population health segmentation, and value-based care program targeting.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality of the patient address. Used for population health outreach, care gap closure, and Social Determinants of Health (SDOH) stratification.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the address (e.g., USA, CAN, MEX). Supports international patient populations and cross-border care coordination.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:county rdf:type rdf:Property ;
    rdfs:label 'County' ;
    rdfs:comment 'County or parish name associated with the patient address. Used for SDOH stratification, public health reporting, and county-level population health analytics.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countyFipsCode rdf:type rdf:Property ;
    rdfs:label 'County Fips Code' ;
    rdfs:comment 'Five-digit Federal Information Processing Standards (FIPS) code uniquely identifying the county. Enables linkage to census data, Area Deprivation Index (ADI), and federal SDOH datasets for population health management.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:district rdf:type rdf:Property ;
    rdfs:label 'District' ;
    rdfs:comment 'Administrative district or borough associated with the address. Used in urban markets and international patient populations for sub-county geographic segmentation and population health reporting.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContactReason rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Reason' ;
    rdfs:comment 'Free-text or coded reason why the patient has requested no contact at this address (e.g., patient request, domestic violence protection, deceased, address undeliverable). Supports HIPAA confidential communications compliance and patient preference management.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date on which this address record is no longer active for the patient. Null indicates the address is currently active. Supports historical address tracking and transitions of care documentation.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which this address record is considered active and valid for the patient. Supports temporal address management, enabling historical address lookups and point-in-time reporting for care coordination and billing.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geocodePrecision rdf:type rdf:Property ;
    rdfs:label 'Geocode Precision' ;
    rdfs:comment 'Precision level of the geocoded coordinates indicating how accurately the latitude/longitude represents the address. Rooftop is highest precision; ungeocoded indicates geocoding has not been performed or failed.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthServiceArea rdf:type rdf:Property ;
    rdfs:label 'Health Service Area' ;
    rdfs:comment 'Dartmouth Atlas Health Service Area (HSA) or facility-defined service area code associated with the address. Used for population health management, market analysis, and care utilization reporting.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:housingType rdf:type rdf:Property ;
    rdfs:label 'Housing Type' ;
    rdfs:comment 'Categorizes the patient\'s housing situation at this address. Supports Social Determinants of Health (SDOH) screening, housing instability risk stratification, and population health management programs. Aligned with AHRQ SDOH domain of housing instability.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConfidential rdf:type rdf:Property ;
    rdfs:label 'Is Confidential' ;
    rdfs:comment 'Indicates the address is marked confidential and must not be disclosed to unauthorized parties, including family members. Supports domestic violence protections, sensitive patient situations, and HIPAA confidential communications requirements under 45 CFR §164.522(b).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDoNotMail rdf:type rdf:Property ;
    rdfs:label 'Is Do Not Mail' ;
    rdfs:comment 'Indicates the patient has requested that no physical mail be sent to this address. Enforced during population health outreach, care gap closure mailings, and marketing communications to honor patient preferences and comply with HIPAA minimum necessary standards.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this address is the patient\'s primary address of record. Only one address per patient should be flagged as primary at any given time. Used by clinical and billing systems to select the default address for correspondence.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (decimal degrees, WGS84) derived from geocoding the address. Supports spatial analytics, drive-time analysis, care access mapping, and population health outreach routing.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line1' ;
    rdfs:comment 'Primary street address line including house/building number and street name. First line of the patient\'s physical or mailing address as captured in Epic or Cerner registration.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line2' ;
    rdfs:comment 'Secondary address line for apartment, suite, unit, floor, or building designator. Supplements address_line1 for multi-unit dwellings.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (decimal degrees, WGS84) derived from geocoding the address. Supports spatial analytics, drive-time analysis, care access mapping, and population health outreach routing.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moveInDate rdf:type rdf:Property ;
    rdfs:label 'Move In Date' ;
    rdfs:comment 'Date the patient moved into or began residing at this address, as reported by the patient during registration or updated via patient portal. Supports address tenure analysis and SDOH housing stability assessments.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moveOutDate rdf:type rdf:Property ;
    rdfs:label 'Move Out Date' ;
    rdfs:comment 'Date the patient moved out of or ceased residing at this address, as reported during registration update or returned mail processing. Used to close address records and trigger re-registration workflows.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ncoaMatchCode rdf:type rdf:Property ;
    rdfs:label 'Ncoa Match Code' ;
    rdfs:comment 'USPS NCOA match result code indicating the outcome of the change-of-address lookup (e.g., individual match, family match, business match, no match, moved with no forwarding address). Used to assess address currency and trigger update workflows.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncoaUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Ncoa Update Date' ;
    rdfs:comment 'Date on which this address was last updated via USPS National Change of Address (NCOA) processing. Supports address hygiene programs and ensures outreach mailings reach patients who have relocated.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'USPS ZIP or ZIP+4 postal code for the address. Used for geographic routing, population health outreach, and SDOH analysis. Note: Per HIPAA Safe Harbor, full 9-digit ZIP codes for small geographic areas may require de-identification.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1 or ISO 639-2 language code representing the patient\'s preferred language for written communications sent to this address (e.g., en, es, zh). Supports culturally competent outreach and CMS language access requirements.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Integration Flag' ;
    rdfs:comment 'Flag indicating integration with quality extensions' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdohHousingInstabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Sdoh Housing Instability Flag' ;
    rdfs:comment 'Indicates the patient has been identified as experiencing housing instability at this address based on SDOH screening (e.g., PRAPARE, AHC HRSN). Triggers care management interventions and community resource referrals.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdohRiskScore rdf:type rdf:Property ;
    rdfs:label 'Sdoh Risk Score' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemAddressCode rdf:type rdf:Property ;
    rdfs:label 'Source System Address Code' ;
    rdfs:comment 'Native identifier for this address record in the originating operational system (e.g., Epic address record ID, Cerner address sequence number). Supports ETL reconciliation, deduplication, and cross-system traceability.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateCode rdf:type rdf:Property ;
    rdfs:label 'State Code' ;
    rdfs:comment 'Two-letter USPS state or territory abbreviation (e.g., CA, TX, NY). Used for state-level regulatory reporting, licensure verification, and population health segmentation.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'Username or system identifier of the user or automated process that last modified this address record. Supports HIPAA audit trail requirements and data stewardship accountability.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urbanRuralClassification rdf:type rdf:Property ;
    rdfs:label 'Urban Rural Classification' ;
    rdfs:comment 'Classifies the address location as urban, suburban, rural, or frontier based on USDA Rural-Urban Commuting Area (RUCA) codes or HRSA definitions. Used for CMS geographic payment adjustments, rural health program eligibility, and access-to-care analytics.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date on which the address was last validated against USPS or a third-party address verification service. Supports re-validation scheduling and data quality monitoring.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationSource rdf:type rdf:Property ;
    rdfs:label 'Validation Source' ;
    rdfs:comment 'Name of the system or service used to validate the address (e.g., USPS CASS, Melissa Data, SmartyStreets, Epic Address Validation). Supports audit trails for address quality management.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current USPS or third-party address validation status. Validated indicates the address was confirmed deliverable by USPS CASS certification or equivalent. Corrected indicates the address was standardized during validation. Used to ensure accuracy of outreach mailings and care gap closure communications.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vbcEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Vbc Eligible Flag' ;
    rdfs:comment 'Flag indicating VBC eligibility for the address record' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vibeMutationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Vibe Mutation Timestamp' ;
    rdfs:comment 'Timestamp indicating VIBE mutation application' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:insuranceCoverageId rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Id' ;
    rdfs:comment 'Unique surrogate identifier for each insurance coverage record in the patient domain. Primary key for the insurance_coverage data product.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InsuranceCoverage .

ind:coveragePolicyId rdf:type rdf:Property ;
    rdfs:label 'Coverage Policy Id' ;
    rdfs:comment 'Foreign key linking to insurance.coverage_policy. Business justification: Prior authorization processing and claims adjudication require knowing which coverage policy governs a patient\'s specific coverage instance. Medical necessity determinations and appeals processing dep' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoveragePolicy .

ind:payerId rdf:type rdf:Property ;
    rdfs:label 'Payer Id' ;
    rdfs:comment 'Reference to the insurance payer organization responsible for adjudicating claims under this coverage. Aligns with the payer master in the reference data domain.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payer .

ind:primaryInsuranceMemberMpiRecordId rdf:type rdf:Property ;
    rdfs:label 'Primary Insurance Member Mpi Record Id' ;
    rdfs:comment 'The insurance member identification number assigned by the payer to uniquely identify the insured individual. Used in eligibility verification (X12 270/271), claims submission (CMS-1500, UB-04), and Electronic Remittance Advice (ERA) matching.' ;
    rdfs:domain ind:InsuranceCoverage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MpiRecord .

ind:providerNetworkId rdf:type rdf:Property ;
    rdfs:label 'Provider Network Id' ;
    rdfs:comment 'Foreign key linking to insurance.provider_network. Business justification: Network adequacy reporting and in-network provider lookup for a patient\'s coverage require direct linkage to the provider network. Care coordination and referral management depend on knowing which net' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProviderNetwork .

ind:subscriberId rdf:type rdf:Property ;
    rdfs:label 'Subscriber Id' ;
    rdfs:comment 'The insurance member ID of the primary subscriber (policyholder) when the patient is a dependent. Distinct from member_id when subscriber_relationship is not \'self\'. Required for dependent eligibility verification.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:benefitYearEnd rdf:type rdf:Property ;
    rdfs:label 'Benefit Year End' ;
    rdfs:comment 'The end date of the insurance plan\'s benefit year (plan year). Used to reset deductible and out-of-pocket accumulator tracking and to identify coverage renewal requirements.' ;
    rdfs:domain ind:InsuranceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefitYearStart rdf:type rdf:Property ;
    rdfs:label 'Benefit Year Start' ;
    rdfs:comment 'The start date of the insurance plan\'s benefit year (plan year). Used to reset deductible and out-of-pocket accumulator tracking. May differ from the coverage effective date for mid-year enrollments.' ;
    rdfs:domain ind:InsuranceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobPriority rdf:type rdf:Property ;
    rdfs:label 'Cob Priority' ;
    rdfs:comment 'Numeric priority order for Coordination of Benefits (COB) when a patient has multiple insurance coverages. 1 = primary payer, 2 = secondary payer, 3 = tertiary payer. Governs claim submission sequencing and payment responsibility allocation.' ;
    rdfs:domain ind:InsuranceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coinsuranceRate rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Rate' ;
    rdfs:comment 'The percentage of covered service costs the patient is responsible for after the deductible is met, expressed as a decimal (e.g., 0.2000 = 20%). Used in patient financial counseling and Revenue Cycle Management (RCM) estimation.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Amount' ;
    rdfs:comment 'The fixed dollar amount the patient is required to pay at the time of service for a covered visit or procedure (e.g., $25 primary care, $50 specialist). Used in point-of-service collection and patient financial counseling.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Current lifecycle status of the insurance coverage record. Drives eligibility verification workflows, claim submission eligibility, and front-end Revenue Cycle Management (RCM) processes. Active = currently valid; Pending = awaiting confirmation; Terminated = coverage ended; Suspended = temporarily inactive.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'The annual deductible amount the patient must pay out-of-pocket before the insurance plan begins covering costs. Expressed in USD. Used in patient financial counseling, prior authorization, and Revenue Cycle Management (RCM) workflows.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductibleMetAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Met Amount' ;
    rdfs:comment 'The year-to-date amount the patient has applied toward their annual deductible. Sourced from real-time eligibility verification (X12 271) responses. Used in patient financial counseling and point-of-service collection.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date on which the insurance coverage becomes effective and claims may be submitted. Used in eligibility verification and coordination of benefits (COB) sequencing. Aligns with X12 271 DTP*356 segment.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityResponseCode rdf:type rdf:Property ;
    rdfs:label 'Eligibility Response Code' ;
    rdfs:comment 'The X12 271 AAA or EB segment response code returned by the payer during eligibility verification, indicating the specific eligibility status or rejection reason (e.g., \'1\' = Active Coverage, \'AAA\' = Rejection). Supports denial prevention and RCM analytics.' ;
    rdfs:domain ind:InsuranceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Eligibility Transaction Number' ;
    rdfs:comment 'The unique transaction control number (TCN) or trace number assigned to the X12 270/271 eligibility verification transaction or FHIR CoverageEligibilityRequest. Enables end-to-end audit trail and transaction reconciliation.' ;
    rdfs:domain ind:InsuranceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verification Method' ;
    rdfs:comment 'The method used to perform the most recent eligibility verification for this coverage. Supports audit trail requirements and verification workflow analytics. EDI_270_271 = X12 batch or real-time transaction; portal = payer web portal; phone = verbal verification; real_time_API = FHIR-based real-time check.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verification Status' ;
    rdfs:comment 'The current status of the most recent eligibility verification transaction for this coverage record. Reflects the outcome of X12 270/271 EDI, portal, or phone-based verification. Drives front-end Revenue Cycle Management (RCM) workflows and claim denial prevention.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityVerifiedBy rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verified By' ;
    rdfs:comment 'The name or system identifier of the staff member, automated process, or clearinghouse that performed the most recent eligibility verification. Supports audit trail and accountability for Revenue Cycle Management (RCM) workflows.' ;
    rdfs:domain ind:InsuranceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verified Timestamp' ;
    rdfs:comment 'The date and time when the most recent eligibility verification was completed. Used in the eligibility verification audit trail and to determine whether re-verification is required based on payer-specific or organizational SLA policies.' ;
    rdfs:domain ind:InsuranceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:groupNumber rdf:type rdf:Property ;
    rdfs:label 'Group Number' ;
    rdfs:comment 'The employer or group plan number assigned by the payer that identifies the specific group policy under which the member is covered. Required for claims submission and eligibility verification.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCardBackUrl rdf:type rdf:Property ;
    rdfs:label 'Insurance Card Back Url' ;
    rdfs:comment 'Secure URL or document reference to the scanned or photographed back of the patient\'s insurance card. Stored in a HIPAA-compliant document management system. Contains payer contact information and claims submission instructions.' ;
    rdfs:domain ind:InsuranceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCardFrontUrl rdf:type rdf:Property ;
    rdfs:label 'Insurance Card Front Url' ;
    rdfs:comment 'Secure URL or document reference to the scanned or photographed front of the patient\'s insurance card. Stored in a HIPAA-compliant document management system. Used for manual verification and patient registration workflows.' ;
    rdfs:domain ind:InsuranceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicaidStateCode rdf:type rdf:Property ;
    rdfs:label 'Medicaid State Code' ;
    rdfs:comment 'Two-letter US state code identifying the state Medicaid program under which the patient is enrolled. Null for non-Medicaid plans. Required for Medicaid claim submission and state-specific billing rules.' ;
    rdfs:domain ind:InsuranceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicarePart rdf:type rdf:Property ;
    rdfs:label 'Medicare Part' ;
    rdfs:comment 'For Medicare coverage, identifies the specific Medicare part: A (Hospital Insurance), B (Medical Insurance), C (Medicare Advantage/HMO), or D (Prescription Drug Coverage). Null for non-Medicare plans. Drives CMS billing rules and claim form selection.' ;
    rdfs:domain ind:InsuranceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkStatus rdf:type rdf:Property ;
    rdfs:label 'Network Status' ;
    rdfs:comment 'Indicates whether the patient\'s coverage is being used within the payer\'s contracted provider network (in-network) or outside it (out-of-network). Affects patient cost-sharing, claim adjudication rates, and denial risk.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfPocketMax rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Max' ;
    rdfs:comment 'The maximum annual amount the patient is required to pay out-of-pocket for covered services, after which the plan covers 100% of costs. Used in patient financial counseling and Revenue Cycle Management (RCM) workflows.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outOfPocketMetAmount rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Met Amount' ;
    rdfs:comment 'The year-to-date amount the patient has applied toward their annual out-of-pocket maximum. Sourced from real-time eligibility verification (X12 271) responses. Informs point-of-service collection decisions.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payerElectronicNumber rdf:type rdf:Property ;
    rdfs:label 'Payer Electronic Number' ;
    rdfs:comment 'The electronic payer identification number used for submitting X12 EDI transactions (270/271 eligibility, 837 claims). Also known as the EDI payer ID or clearinghouse payer ID. Distinct from the NPI.' ;
    rdfs:domain ind:InsuranceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'The commercial name of the insurance plan as designated by the payer (e.g., \'Blue Shield PPO Gold\', \'Aetna HMO Select\'). Used for patient-facing communications and Revenue Cycle Management (RCM) workflows.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the insurance plan type indicating the network and coverage structure. Drives prior authorization requirements, referral rules, and claim adjudication logic. [ENUM-REF-CANDIDATE: HMO|PPO|POS|EPO|Medicare|Medicaid|self_pay|TRICARE|CHIP|workers_comp|commercial — promote to reference product]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthRequired rdf:type rdf:Property ;
    rdfs:label 'Prior Auth Required' ;
    rdfs:comment 'Indicates whether the insurance plan requires prior authorization (pre-authorization) before certain services, procedures, or medications are covered. Drives pre-authorization workflows in Order Management and Surgical/Procedural Scheduling.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralRequired rdf:type rdf:Property ;
    rdfs:label 'Referral Required' ;
    rdfs:comment 'Indicates whether the insurance plan requires a referral from a Primary Care Physician (PCP) before the patient can see a specialist. Applicable primarily to Health Maintenance Organization (HMO) and Point of Service (POS) plans.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rxBin rdf:type rdf:Property ;
    rdfs:label 'Rx Bin' ;
    rdfs:comment 'The 6-digit Bank Identification Number (BIN) used to route pharmacy claims to the correct Pharmacy Benefit Manager (PBM). Printed on the insurance card and required for real-time pharmacy eligibility and adjudication via NCPDP SCRIPT standard.' ;
    rdfs:domain ind:InsuranceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rxGroup rdf:type rdf:Property ;
    rdfs:label 'Rx Group' ;
    rdfs:comment 'The pharmacy benefit group number used to identify the specific pharmacy benefit plan within the Pharmacy Benefit Manager (PBM) system. Printed on the insurance card alongside RxBIN and PCN.' ;
    rdfs:domain ind:InsuranceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rxPcn rdf:type rdf:Property ;
    rdfs:label 'Rx Pcn' ;
    rdfs:comment 'The Processor Control Number (PCN) used in conjunction with the RxBIN to route pharmacy claims to the correct sub-processor within the Pharmacy Benefit Manager (PBM). Required for pharmacy eligibility verification.' ;
    rdfs:domain ind:InsuranceCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The native primary key or record identifier for this coverage record in the originating operational system (e.g., Epic coverage record ID, Cerner insurance record ID). Enables traceability from the Silver layer back to the system of record.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberRelationship rdf:type rdf:Property ;
    rdfs:label 'Subscriber Relationship' ;
    rdfs:comment 'The relationship of the patient (beneficiary) to the primary insurance subscriber. Determines coordination of benefits (COB) rules and claim filing requirements. \'Self\' indicates the patient is the primary subscriber.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'The date on which the insurance coverage ends or is terminated. Null indicates open-ended active coverage. Used to prevent claim submission for services rendered outside the coverage period. Aligns with X12 271 DTP*357 segment.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guarantorId rdf:type rdf:Property ;
    rdfs:label 'Guarantor Id' ;
    rdfs:comment 'Unique surrogate identifier for the financial guarantor record within the patient accounting system. Primary key for the guarantor entity; referenced by patient account and billing records across the Revenue Cycle Management (RCM) domain.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Guarantor .

ind:accountBalance rdf:type rdf:Property ;
    rdfs:label 'Account Balance' ;
    rdfs:comment 'Current outstanding balance owed by the guarantor on the patient account in USD. Represents the net self-pay balance after insurance adjudication, contractual adjustments, and payments applied. Core metric for RCM self-pay collection and patient financial counseling.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-known patient accounting number assigned to the guarantor account in the EHR revenue cycle or patient accounting system (e.g., Epic Resolute HB guarantor account number). Used by billing staff, financial counselors, and self-pay collection teams to identify and reference the account.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the guarantor account within the Revenue Cycle Management (RCM) workflow. Drives billing, collection, and write-off processes. [ENUM-REF-CANDIDATE: active|inactive|collections|bad_debt|deceased|bankruptcy — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line of the guarantor\'s mailing or billing address. Used for billing statement delivery, collection correspondence, and address verification in RCM workflows.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for the guarantor (apartment, suite, unit, floor, PO Box). Supplements address_line1 for complete mailing address used in billing and collection correspondence.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualIncome rdf:type rdf:Property ;
    rdfs:label 'Annual Income' ;
    rdfs:comment 'Self-reported or verified annual gross income of the guarantor in USD. Used for financial assistance (charity care) eligibility screening, sliding-scale fee determination, and payment plan structuring per CMS and ACA financial assistance requirements.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:badDebtFlag rdf:type rdf:Property ;
    rdfs:label 'Bad Debt Flag' ;
    rdfs:comment 'Indicates whether the guarantor account balance has been written off as bad debt in the patient accounting system. Supports financial reporting, bad debt reserve calculations, and RAC audit documentation per GAAP and CMS guidelines.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bankruptcyFlag rdf:type rdf:Property ;
    rdfs:label 'Bankruptcy Flag' ;
    rdfs:comment 'Indicates whether the guarantor has filed for bankruptcy protection. When True, all collection activities must cease immediately per the automatic stay provisions of the U.S. Bankruptcy Code (11 U.S.C. §362) and the account is flagged for legal review.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionAgencyFlag rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Flag' ;
    rdfs:comment 'Indicates whether the guarantor account has been referred to an external collection agency for bad debt recovery. When True, direct billing and collection activities by the healthcare organization are suspended per FDCPA requirements.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotContactFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Flag' ;
    rdfs:comment 'Indicates whether the guarantor has requested cessation of all billing and collection contact. When True, all outreach activities are suppressed in compliance with FDCPA cease-and-desist provisions and HIPAA patient rights.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employerName rdf:type rdf:Property ;
    rdfs:label 'Employer Name' ;
    rdfs:comment 'Name of the guarantor\'s current employer. Used in financial counseling, self-pay collection assessments, and financial assistance (charity care) eligibility screening to evaluate ability to pay.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerPhone rdf:type rdf:Property ;
    rdfs:label 'Employer Phone' ;
    rdfs:comment 'Phone number of the guarantor\'s employer. Used in self-pay collection processes and financial counseling to verify employment status and facilitate payment arrangements.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current employment status of the guarantor. Used in financial assistance (charity care) eligibility determination, payment plan structuring, and self-pay collection risk stratification. [ENUM-REF-CANDIDATE: employed_full_time|employed_part_time|self_employed|unemployed|retired|student|disabled — promote to reference product]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estatementConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Estatement Consent Flag' ;
    rdfs:comment 'Indicates whether the guarantor has consented to receive electronic billing statements (e-statements) via email or patient portal in lieu of paper statements. Supports paperless billing initiatives and reduces statement delivery costs in RCM.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:federalPovertyLevelPct rdf:type rdf:Property ;
    rdfs:label 'Federal Poverty Level Pct' ;
    rdfs:comment 'Calculated Federal Poverty Level (FPL) percentage for the guarantor\'s household based on annual income and household size. Determines eligibility tier for financial assistance programs, charity care, and sliding-scale discounts per ACA Section 501(r) and CMS guidelines.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialAssistanceStatus rdf:type rdf:Property ;
    rdfs:label 'Financial Assistance Status' ;
    rdfs:comment 'Current status of the guarantor\'s financial assistance (charity care) application. Drives billing hold, discount application, and collection suspension workflows in the RCM system. Supports ACA Section 501(r) compliance reporting.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAssistanceType rdf:type rdf:Property ;
    rdfs:label 'Financial Assistance Type' ;
    rdfs:comment 'Type of financial assistance program approved or applied for by the guarantor. Determines the discount percentage, payment schedule, and billing workflow applied to the account. [ENUM-REF-CANDIDATE: charity_care|sliding_scale|payment_plan|hardship|medicaid_pending — promote to reference product]' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Legal first (given) name of the guarantor individual. Used in billing correspondence, patient financial counseling communications, and self-pay collection outreach. Protected Health Information (PHI) under HIPAA when linked to patient account data.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guarantorType rdf:type rdf:Property ;
    rdfs:label 'Guarantor Type' ;
    rdfs:comment 'Classification of the guarantor indicating whether the responsible party is the patient themselves, a family member, a legal guardian, an estate, or an organization. Determines billing workflow routing and financial counseling approach. [ENUM-REF-CANDIDATE: self|parent|spouse|legal_guardian|estate|organization — promote to reference product if additional types are required]' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homePhone rdf:type rdf:Property ;
    rdfs:label 'Home Phone' ;
    rdfs:comment 'Home telephone number of the guarantor. Primary contact channel for billing inquiries, financial counseling outreach, and self-pay collection calls. Stored in compliance with HIPAA and Telephone Consumer Protection Act (TCPA) requirements.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdSize rdf:type rdf:Property ;
    rdfs:label 'Household Size' ;
    rdfs:comment 'Number of individuals in the guarantor\'s household. Used in conjunction with annual income to determine Federal Poverty Level (FPL) percentage for financial assistance (charity care) eligibility and sliding-scale fee calculations.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Legal last (family) name of the guarantor individual. Used in billing correspondence, collection letters, and identity verification for patient financial services.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Dollar amount of the most recent payment received from the guarantor in USD. Used alongside last_payment_date for payment plan compliance monitoring, collection risk assessment, and RCM reporting.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent payment received from the guarantor toward the outstanding account balance. Used in collection aging analysis, payment plan compliance monitoring, and bad debt risk stratification.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastStatementDate rdf:type rdf:Property ;
    rdfs:label 'Last Statement Date' ;
    rdfs:comment 'Date on which the most recent billing statement was generated and sent to the guarantor. Used to track billing cycle compliance, manage statement frequency, and support collection escalation timelines in RCM.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile/cell phone number of the guarantor. Supports SMS billing notifications, payment reminders, and collection outreach. Consent for text messaging must be captured separately per TCPA requirements.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationName rdf:type rdf:Property ;
    rdfs:label 'Organization Name' ;
    rdfs:comment 'Legal name of the organization acting as guarantor when the responsible party is a business entity, estate, or institution rather than an individual. Populated when guarantor_type is \'organization\' or \'estate\'.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPlanAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Amount' ;
    rdfs:comment 'Agreed monthly payment amount under the guarantor\'s active payment plan arrangement in USD. Used by RCM billing staff to monitor payment plan compliance and trigger collection escalation if payments are missed.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Flag' ;
    rdfs:comment 'Indicates whether the guarantor has an active payment plan arrangement for the outstanding account balance. When True, collection activities are suspended and the account follows the payment plan schedule in the RCM system.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Guarantor\'s preferred method of contact for billing statements, payment reminders, and financial counseling communications. Drives outreach channel selection in RCM workflows and patient financial services.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipToPatient rdf:type rdf:Property ;
    rdfs:label 'Relationship To Patient' ;
    rdfs:comment 'Describes the guarantor\'s relationship to the patient as defined in the EHR patient accounting module. Used for financial counseling, billing correspondence, and HIPAA-compliant disclosure of account information. [ENUM-REF-CANDIDATE: self|spouse|parent|child|sibling|grandparent|legal_guardian|other — promote to reference product]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibilityPct rdf:type rdf:Property ;
    rdfs:label 'Responsibility Pct' ;
    rdfs:comment 'Percentage of the total patient account balance for which this guarantor is financially responsible. Supports scenarios where multiple guarantors share responsibility for a single patient account (e.g., divorced parents of a minor patient). Value range: 0.00 to 100.00.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sinceDate rdf:type rdf:Property ;
    rdfs:label 'Since Date' ;
    rdfs:comment 'Date on which the individual or organization was first established as the financial guarantor for the patient account. Marks the effective start of financial responsibility and is used in RCM aging analysis and financial counseling workflows.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:smsConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Sms Consent Flag' ;
    rdfs:comment 'Indicates whether the guarantor has provided explicit written consent to receive SMS/text message billing notifications and payment reminders. Required for TCPA compliance before sending automated text messages to the guarantor\'s mobile phone.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ssnMasked rdf:type rdf:Property ;
    rdfs:label 'Ssn Masked' ;
    rdfs:comment 'Masked Social Security Number (SSN) of the guarantor, displaying only the last four digits (format: XXX-XX-NNNN). Used for identity verification in self-pay collections, financial assistance screening, and credit bureau reporting. Full SSN must never be stored in the Silver layer per HIPAA and PCI DSS data minimization requirements.' ;
    rdfs:domain ind:Guarantor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:state rdf:type rdf:Property ;
    rdfs:label 'State' ;
    rdfs:comment 'Two-letter US state or territory code of the guarantor\'s billing or mailing address (e.g., CA, TX, NY). Used for billing correspondence, state-specific financial assistance program eligibility, and regulatory reporting.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhone rdf:type rdf:Property ;
    rdfs:label 'Work Phone' ;
    rdfs:comment 'Work telephone number of the guarantor. Used as an alternate contact channel for billing and collection communications when home phone is unavailable. Stored in compliance with HIPAA and TCPA.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactId rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Id' ;
    rdfs:comment 'Unique surrogate identifier for the emergency contact record in the Master Patient Index (MPI) system. Primary key for the emergency_contact data product.' ;
    rdfs:domain ind:EmergencyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'The date on which the patient provided consent to designate this individual as an emergency contact and/or authorized recipient of PHI. Required for HIPAA audit trails and regulatory compliance.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentObtainedBy rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained By' ;
    rdfs:comment 'Name or identifier of the staff member (e.g., registration clerk, nurse) who obtained the patient\'s consent to designate this emergency contact. Supports HIPAA audit trail requirements and accountability in the registration workflow.' ;
    rdfs:domain ind:EmergencyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the emergency contact record. Active = currently valid and reachable; Inactive = no longer applicable (e.g., relationship ended); Deceased = contact has died; Unverified = contact information has not been confirmed with the patient.' ;
    rdfs:domain ind:EmergencyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact\'s role relative to the patient. Determines the scope of authority and notification priority. Values include emergency_contact (general notification), healthcare_proxy (authorized to make medical decisions), legal_guardian (legal authority over patient), authorized_representative (authorized to receive PHI per HIPAA), next_of_kin (biological/legal family), guarantor (financial responsibility). [ENUM-REF-CANDIDATE: emergency_contact|healthcare_proxy|legal_guardian|authorized_representative|next_of_kin|guarantor — promote to reference product]' ;
    rdfs:domain ind:EmergencyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthcareProxyFlag rdf:type rdf:Property ;
    rdfs:label 'Healthcare Proxy Flag' ;
    rdfs:comment 'Indicates whether this contact has been designated as the patient\'s healthcare proxy (durable power of attorney for healthcare decisions). When True, this individual is legally authorized to make medical decisions on behalf of the patient if the patient is incapacitated. Distinct from phi_disclosure_authorized.' ;
    rdfs:domain ind:EmergencyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalGuardianFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Guardian Flag' ;
    rdfs:comment 'Indicates whether this contact holds legal guardianship over the patient (e.g., parent of a minor, court-appointed guardian for an incapacitated adult). When True, this individual has legal authority over the patient\'s care decisions and access to medical records.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:livesWithPatient rdf:type rdf:Property ;
    rdfs:label 'Lives With Patient' ;
    rdfs:comment 'Indicates whether the emergency contact resides in the same household as the patient. Relevant for discharge planning, home care coordination, and Social Determinants of Health (SDOH) assessments.' ;
    rdfs:domain ind:EmergencyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for additional clinical or administrative notes about this emergency contact (e.g., \'Contact is deaf — use text messaging only\', \'Contact travels frequently — try mobile first\'). Supports nuanced care coordination and communication planning.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Consent Flag' ;
    rdfs:comment 'Indicates whether the patient has explicitly consented to this contact being notified in the event of an emergency, admission, or discharge. Supports EMTALA compliance and HIPAA-compliant notification workflows.' ;
    rdfs:domain ind:EmergencyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phiDisclosureAuthorized rdf:type rdf:Property ;
    rdfs:label 'Phi Disclosure Authorized' ;
    rdfs:comment 'Indicates whether the patient has authorized this contact to receive Protected Health Information (PHI) about their care. Critical for HIPAA compliance — clinical staff must verify this flag before disclosing any PHI to the contact. True = authorized; False = not authorized.' ;
    rdfs:domain ind:EmergencyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityOrder rdf:type rdf:Property ;
    rdfs:label 'Priority Order' ;
    rdfs:comment 'Numeric rank indicating the order in which this contact should be notified in an emergency (1 = first contact, 2 = second, etc.). Supports triage and discharge planning workflows where multiple contacts exist for a single patient.' ;
    rdfs:domain ind:EmergencyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proxyDocumentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Proxy Document Effective Date' ;
    rdfs:comment 'The date on which the proxy authorization document (e.g., durable power of attorney, healthcare proxy form) became legally effective. Used to validate the currency of the authorization during care decisions.' ;
    rdfs:domain ind:EmergencyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proxyDocumentExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Proxy Document Expiration Date' ;
    rdfs:comment 'The date on which the proxy authorization document expires, if applicable. Null indicates the document is open-ended with no expiration. Clinical staff must verify this date before acting on proxy authority.' ;
    rdfs:domain ind:EmergencyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proxyDocumentType rdf:type rdf:Property ;
    rdfs:label 'Proxy Document Type' ;
    rdfs:comment 'Type of legal document on file that establishes this contact\'s authority as a healthcare proxy or legal guardian. Required for clinical staff to verify decision-making authority before acting on the contact\'s instructions.' ;
    rdfs:domain ind:EmergencyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'The personal or familial relationship between the emergency contact and the patient (e.g., spouse, parent, sibling). Used for care coordination, discharge planning, and EMTALA compliance. Distinct from contact_type which captures the legal/functional role. [ENUM-REF-CANDIDATE: spouse|parent|child|sibling|domestic_partner|grandparent|aunt_uncle|friend|employer|other — promote to reference product]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemContactCode rdf:type rdf:Property ;
    rdfs:label 'Source System Contact Code' ;
    rdfs:comment 'The native identifier assigned to this emergency contact record in the originating source system (e.g., Epic contact ID, Cerner relationship ID). Used for cross-system reconciliation, ETL traceability, and Health Information Exchange (HIE) matching.' ;
    rdfs:domain ind:EmergencyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the staff member who last verified the accuracy of this emergency contact\'s information. Supports accountability and data quality governance in the patient registration process.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedDate rdf:type rdf:Property ;
    rdfs:label 'Verified Date' ;
    rdfs:comment 'The most recent date on which the emergency contact\'s information was verified with the patient or the contact directly. Supports data quality management and ensures contact information is current for emergency use.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workPhoneExtension rdf:type rdf:Property ;
    rdfs:label 'Work Phone Extension' ;
    rdfs:comment 'Extension number associated with the contact\'s work phone. Required for routing calls within large organizations where the contact is employed.' ;
    rdfs:domain ind:EmergencyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcpAttributionId rdf:type rdf:Property ;
    rdfs:label 'Pcp Attribution Id' ;
    rdfs:comment 'Unique surrogate identifier for each PCP attribution record in the Master Patient Index (MPI) attribution registry. Serves as the primary key for all downstream joins across population health, HEDIS, and value-based care reporting.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributedOrgProviderId rdf:type rdf:Property ;
    rdfs:label 'Attributed Org Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.org_provider. Business justification: Value-based care and ACO contracts attribute patients to a practice/facility, not just an individual clinician. HEDIS, MIPS group reporting, and network adequacy analysis require the attributed org_pr' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgProvider .

ind:attributedSpecialtyId rdf:type rdf:Property ;
    rdfs:label 'Attributed Specialty Id' ;
    rdfs:comment 'Foreign key linking to provider.specialty. Business justification: PCP attribution requires tracking the specialty of the attributed provider for network adequacy reporting, panel composition analysis, primary care vs specialist attribution rules, and risk-adjusted q' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specialty .

ind:careTeamId rdf:type rdf:Property ;
    rdfs:label 'Care Team Id' ;
    rdfs:comment 'Reference to the care team record when attribution is assigned to a multidisciplinary care team rather than a single PCP. Supports Accountable Care Organization (ACO) and Patient-Centered Medical Home (PCMH) attribution models where team-based care is the unit of attribution.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CareTeam .

ind:clinicianId rdf:type rdf:Property ;
    rdfs:label 'Clinician Id' ;
    rdfs:comment 'Reference to the clinician record for the Primary Care Physician (PCP) or care team lead to whom the patient is attributed. Used to resolve provider demographics, specialty, and panel capacity from the provider domain.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:healthPlanId rdf:type rdf:Property ;
    rdfs:label 'Health Plan Id' ;
    rdfs:comment 'Reference to the payer insurance plan record associated with this attribution. Attribution rules and measurement periods vary by plan type (ACO, HMO, PPO, POS). Links to the billing and revenue cycle domain for plan-specific attribution logic.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthPlan .

ind:memberEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Member Enrollment Id' ;
    rdfs:comment 'Foreign key linking to insurance.member_enrollment. Business justification: PCP attribution is driven by the specific enrollment period — attribution is valid only during active enrollment. Value-based care reporting (HEDIS, MIPS) requires linking attribution records to the e' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberEnrollment .

ind:payerContractId rdf:type rdf:Property ;
    rdfs:label 'Payer Contract Id' ;
    rdfs:comment 'Foreign key linking to insurance.payer_contract. Business justification: PCP attribution in value-based care is governed by payer contracts (ACO, capitation, shared savings agreements). The aco_contract_number field is a denormalized reference to payer_contract. Proper FK ' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayerContract .

ind:attributedProviderNpi rdf:type rdf:Property ;
    rdfs:label 'Attributed Provider Npi' ;
    rdfs:comment '10-digit National Provider Identifier (NPI) of the attributed Primary Care Physician (PCP) or care team lead as registered with the National Plan and Provider Enumeration System (NPPES). Required for HEDIS, MIPS, and CMS value-based care reporting submissions.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Attribution Confidence Score' ;
    rdfs:comment 'Numeric score (0.00–100.00) representing the statistical confidence level of the attribution assignment. Higher scores indicate stronger evidence of the patient-PCP relationship based on visit frequency, claims history, or enrollment data. Used to prioritize manual review of low-confidence attributions and to weight population health analytics.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributionMethod rdf:type rdf:Property ;
    rdfs:label 'Attribution Method' ;
    rdfs:comment 'The methodology used to assign the patient to the PCP or care team. Claims-based attribution uses historical utilization patterns; enrollment-based uses payer plan enrollment data; manual is provider-assigned; algorithm-based uses predictive models; hybrid combines multiple methods; empanelment is practice-panel assignment. Drives HEDIS, MIPS, and ACO reporting logic.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Attribution Override Reason' ;
    rdfs:comment 'Free-text or coded reason when an attribution assignment has been manually overridden from the algorithm-generated or payer-assigned attribution. Documents the clinical or administrative justification for the override, supporting audit trails and compliance with CMS and NCQA attribution integrity requirements.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionRank rdf:type rdf:Property ;
    rdfs:label 'Attribution Rank' ;
    rdfs:comment 'Ordinal rank (1 = primary) when a patient has multiple concurrent attribution records across different payers or plans. Rank 1 designates the primary PCP attribution used for population health management and HEDIS reporting. Higher ranks indicate secondary or supplemental attributions.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionReviewDate rdf:type rdf:Property ;
    rdfs:label 'Attribution Review Date' ;
    rdfs:comment 'Scheduled or completed date for the next periodic review of this attribution record. Attribution records are reviewed quarterly or annually per payer contract requirements to ensure accuracy of panel rosters and compliance with HEDIS and MIPS reporting periods.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attributionSegment rdf:type rdf:Property ;
    rdfs:label 'Attribution Segment' ;
    rdfs:comment 'Insurance coverage segment of the attributed patient. Determines applicable attribution methodology, quality measure set, and regulatory reporting requirements. Dual eligible patients (Medicare and Medicaid) require special attribution handling per CMS duals coordination rules.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionSource rdf:type rdf:Property ;
    rdfs:label 'Attribution Source' ;
    rdfs:comment 'The operational system of record from which this attribution record was sourced. Identifies whether the attribution originated from Epic Healthy Planet, Cerner Millennium, a payer attribution feed, manual entry, HL7 FHIR interface, or a population health management platform. Critical for data lineage and ETL reconciliation.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionStatus rdf:type rdf:Property ;
    rdfs:label 'Attribution Status' ;
    rdfs:comment 'Current lifecycle status of the PCP attribution record. Active indicates a current, valid attribution; pending indicates awaiting confirmation; disputed indicates a payer or provider challenge; terminated indicates the attribution period has ended; under_review indicates compliance or audit review in progress.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:careManagementEnrolled rdf:type rdf:Property ;
    rdfs:label 'Care Management Enrolled' ;
    rdfs:comment 'Indicates whether the attributed patient is currently enrolled in a care management or disease management program under the attributed PCP or ACO. True = enrolled in care management. Used for population health program tracking and HEDIS care management measure reporting.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentOnFile rdf:type rdf:Property ;
    rdfs:label 'Consent On File' ;
    rdfs:comment 'Indicates whether the patient has provided documented consent for their health information to be shared with the attributed PCP, care team, and ACO for care coordination and population health management purposes. Required for HIPAA-compliant data sharing under ACO and HIE participation agreements.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingOptOut rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Opt Out' ;
    rdfs:comment 'Indicates whether the patient has exercised their right to opt out of data sharing with the ACO or population health program under CMS beneficiary notification and opt-out requirements. True = patient has opted out. Patients who opt out must be excluded from ACO attribution and shared data feeds.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disenrollmentReason rdf:type rdf:Property ;
    rdfs:label 'Disenrollment Reason' ;
    rdfs:comment 'Coded reason for the termination of the PCP attribution. Used for panel management analytics, provider turnover reporting, and population health program evaluation. [ENUM-REF-CANDIDATE: provider_change|plan_disenrollment|patient_request|provider_termination|death|moved_out_of_area|other — promote to reference product]' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The calendar date on which the PCP attribution terminates. Null indicates an open-ended, currently active attribution. Used to calculate attribution duration, panel turnover, and to exclude patients from measurement periods after disenrollment or provider change.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region or service area associated with this attribution record, typically aligned with CMS Hospital Referral Regions (HRR) or payer-defined service areas. Used for population health geographic analysis, regional quality benchmarking, and ACO regional benchmark calculations.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hccRiskScore rdf:type rdf:Property ;
    rdfs:label 'Hcc Risk Score' ;
    rdfs:comment 'CMS Hierarchical Condition Category (HCC) risk adjustment score for the attributed patient at the time of attribution. Used in Medicare Advantage and ACO shared savings calculations to adjust expected expenditures for patient complexity. Sourced from CMS risk adjustment data or population health platform.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedisEligible rdf:type rdf:Property ;
    rdfs:label 'Hedis Eligible' ;
    rdfs:comment 'Indicates whether this attribution record qualifies the patient for inclusion in HEDIS (Healthcare Effectiveness Data and Information Set) measure calculations for the current measurement year. Eligibility is determined by continuous enrollment criteria, plan type, and attribution method per NCQA HEDIS Technical Specifications.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryAttribution rdf:type rdf:Property ;
    rdfs:label 'Is Primary Attribution' ;
    rdfs:comment 'Indicates whether this attribution record is the patient\'s primary PCP attribution used as the single source of truth (SSOT) for population health management, HEDIS measurement, and MIPS performance reporting. True = primary attribution; False = secondary or supplemental attribution.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Visit Date' ;
    rdfs:comment 'Date of the most recent qualifying primary care visit between the patient and the attributed PCP within the attribution lookback period. Used to assess recency of the patient-provider relationship and to support attribution validation and panel management.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lookbackPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Lookback Period Months' ;
    rdfs:comment 'The number of months in the historical claims lookback window used to determine claims-based attribution. Standard values are 12 or 24 months per CMS and NCQA attribution methodologies. Stored to support audit and reproducibility of attribution assignments.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementYear rdf:type rdf:Property ;
    rdfs:label 'Measurement Year' ;
    rdfs:comment 'The calendar year for which this attribution record is applicable for quality measurement reporting (HEDIS, MIPS, ACO quality measures). Attribution records are typically finalized at the start of each measurement year and used throughout the performance period.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mipsEligible rdf:type rdf:Property ;
    rdfs:label 'Mips Eligible' ;
    rdfs:comment 'Indicates whether the attributed provider qualifies for Merit-based Incentive Payment System (MIPS) performance measurement under MACRA for this attribution record. Eligibility is based on provider NPI, patient volume thresholds, and billing thresholds per CMS MIPS eligibility criteria.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideAuthorizedBy rdf:type rdf:Property ;
    rdfs:label 'Override Authorized By' ;
    rdfs:comment 'Name or identifier of the clinical or administrative staff member who authorized a manual attribution override. Required for audit trail integrity and compliance with CMS and NCQA attribution override documentation requirements.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideDate rdf:type rdf:Property ;
    rdfs:label 'Override Date' ;
    rdfs:comment 'Date on which the manual attribution override was authorized and applied. Used in conjunction with override_authorized_by and attribution_override_reason to maintain a complete audit trail of attribution changes.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:panelAssignmentDate rdf:type rdf:Property ;
    rdfs:label 'Panel Assignment Date' ;
    rdfs:comment 'Date the patient was formally added to the attributed PCP\'s patient panel in the practice management or population health system (e.g., Epic Healthy Planet empanelment). May differ from the attribution effective date when payer attribution and practice empanelment are managed separately.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payerAttributionNumber rdf:type rdf:Property ;
    rdfs:label 'Payer Attribution Number' ;
    rdfs:comment 'The external attribution identifier assigned by the payer or managed care organization in their attribution feed. Used to reconcile internal attribution records with payer-issued attribution rosters and to resolve attribution disputes with payers.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerName rdf:type rdf:Property ;
    rdfs:label 'Payer Name' ;
    rdfs:comment 'Name of the health insurance payer or managed care organization that issued the attribution assignment. Used for payer-specific attribution reconciliation, HEDIS reporting submissions, and value-based contract performance tracking.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskStratificationTier rdf:type rdf:Property ;
    rdfs:label 'Risk Stratification Tier' ;
    rdfs:comment 'Patient risk stratification tier assigned at the time of attribution, based on clinical complexity, chronic condition burden, and Social Determinants of Health (SDOH) factors. Used by the attributed PCP and care team to prioritize outreach, care management intensity, and resource allocation in population health programs.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdohFlag rdf:type rdf:Property ;
    rdfs:label 'Sdoh Flag' ;
    rdfs:comment 'Indicates whether the patient has documented Social Determinants of Health (SDOH) risk factors (e.g., food insecurity, housing instability, transportation barriers) that require care coordination support from the attributed PCP or care team. True = SDOH risk factors present.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceFeedDate rdf:type rdf:Property ;
    rdfs:label 'Source Feed Date' ;
    rdfs:comment 'Date of the payer attribution feed or population health system extract from which this attribution record was loaded. Used for data currency validation, ETL reconciliation, and to identify stale attribution records that require refresh from the source system.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visitCountLookback rdf:type rdf:Property ;
    rdfs:label 'Visit Count Lookback' ;
    rdfs:comment 'Number of qualifying primary care visits with the attributed provider during the claims-based attribution lookback period (typically 24 months). Used to validate and support claims-based attribution assignments and to calculate attribution confidence scores per CMS and NCQA methodologies.' ;
    rdfs:domain ind:PcpAttribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibilityCheckId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Check Id' ;
    rdfs:comment 'Unique surrogate identifier for each insurance eligibility verification transaction record in the Silver layer lakehouse.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EligibilityCheck .

ind:orderingClinicianId rdf:type rdf:Property ;
    rdfs:label 'Ordering Clinician Id' ;
    rdfs:comment 'Foreign key linking to provider.clinician. Business justification: Eligibility verifications are often triggered by specific provider orders or referrals. Tracking the ordering clinician supports prior authorization workflows, audit trails for medical necessity, and ' ;
    rdfs:domain ind:EligibilityCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:priorAuthRuleId rdf:type rdf:Property ;
    rdfs:label 'Prior Auth Rule Id' ;
    rdfs:comment 'Foreign key linking to insurance.prior_auth_rule. Business justification: Eligibility checks determine prior authorization requirements. Linking to the specific prior_auth_rule that triggered the PA requirement enables PA workflow automation, denial management, and complian' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriorAuthRule .

ind:registrationEventId rdf:type rdf:Property ;
    rdfs:label 'Registration Event Id' ;
    rdfs:comment 'Foreign key linking to patient.registration_event. Business justification: Insurance eligibility verification is routinely triggered by patient registration events (pre-registration, admission, pre-authorization workflows). Linking eligibility_check to the registration_event' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegistrationEvent .

ind:visitId rdf:type rdf:Property ;
    rdfs:label 'Visit Id' ;
    rdfs:comment 'Reference to the clinical encounter or scheduled appointment that triggered this eligibility verification. Nullable when verification is performed outside of a specific encounter context (e.g., batch eligibility runs).' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Visit .

ind:clearinghouseName rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Name' ;
    rdfs:comment 'The name of the EDI clearinghouse (e.g., Change Healthcare, Availity, Waystar) used to route the 270/271 eligibility transaction between the provider and the payer. Null for direct payer connections.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coinsurancePercent rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Percent' ;
    rdfs:comment 'The percentage of covered service costs the patient is responsible for after the deductible is met, as confirmed in the eligibility response (e.g., 20.00 for a 20% patient coinsurance obligation).' ;
    rdfs:domain ind:EligibilityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coordinationOfBenefitsFlag rdf:type rdf:Property ;
    rdfs:label 'Coordination Of Benefits Flag' ;
    rdfs:comment 'Indicates whether the patient has multiple insurance coverages requiring Coordination of Benefits (COB) processing. True = secondary or tertiary payer exists and COB rules must be applied during claims adjudication.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageType rdf:type rdf:Property ;
    rdfs:label 'Coverage Type' ;
    rdfs:comment 'Indicates the order of coverage for this payer relative to other payers the patient may have. \'primary\' = first-pay payer; \'secondary\' = pays after primary; \'tertiary\' = pays after secondary.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyDeductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Family Deductible Amount' ;
    rdfs:comment 'The annual family deductible amount for the patient\'s insurance plan as confirmed in the eligibility response. Applicable when the patient is covered under a family plan.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:individualDeductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Individual Deductible Amount' ;
    rdfs:comment 'The annual individual deductible amount for the patient\'s insurance plan as confirmed in the eligibility response. Represents the amount the patient must pay out-of-pocket before insurance begins covering costs.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:individualDeductibleMetAmount rdf:type rdf:Property ;
    rdfs:label 'Individual Deductible Met Amount' ;
    rdfs:comment 'The year-to-date amount of the individual deductible that the patient has already satisfied as of the verification date. Used to calculate remaining patient financial responsibility.' ;
    rdfs:domain ind:EligibilityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:individualOutOfPocketMax rdf:type rdf:Property ;
    rdfs:label 'Individual Out Of Pocket Max' ;
    rdfs:comment 'The annual individual out-of-pocket maximum (OOPM) for the patient\'s plan as confirmed in the eligibility response. Once met, the insurer covers 100% of covered services for the remainder of the benefit year.' ;
    rdfs:domain ind:EligibilityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:individualOutOfPocketMet rdf:type rdf:Property ;
    rdfs:label 'Individual Out Of Pocket Met' ;
    rdfs:comment 'The year-to-date amount applied toward the patient\'s individual out-of-pocket maximum as of the verification date. Used to determine remaining patient financial liability.' ;
    rdfs:domain ind:EligibilityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOverride rdf:type rdf:Property ;
    rdfs:label 'Is Override' ;
    rdfs:comment 'Indicates whether the eligibility verification result was manually overridden by a staff member, superseding the automated payer response. True = result was overridden; False = result reflects the original payer response.' ;
    rdfs:domain ind:EligibilityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text reason documented when a staff member manually overrides the eligibility verification result (e.g., patient confirmed coverage verbally, payer system outage). Supports audit trail for compliance.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthNumber rdf:type rdf:Property ;
    rdfs:label 'Prior Auth Number' ;
    rdfs:comment 'The prior authorization number issued by the payer for the specific service, if authorization has already been obtained at the time of eligibility verification. Null if no prior auth exists or is not yet required.' ;
    rdfs:domain ind:EligibilityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'The ASC X12 AAA reject reason code returned by the payer when the eligibility inquiry could not be processed (e.g., \'15\' = Required information missing, \'72\' = Invalid/missing subscriber/insured ID). Null when verification is successful.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Human-readable description of the rejection reason returned by the payer or clearinghouse when the eligibility inquiry failed. Supports staff workflow resolution and denial prevention.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'The exact date and time when the payer returned the eligibility response (271 transaction or portal/phone response). Used to calculate verification turnaround time for SLA monitoring.' ;
    rdfs:domain ind:EligibilityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceDate rdf:type rdf:Property ;
    rdfs:label 'Service Date' ;
    rdfs:comment 'The date of service for which eligibility is being verified. May be the date of an upcoming appointment or the date of a completed encounter. Used to confirm coverage was active on the specific date of care.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceTypeCode rdf:type rdf:Property ;
    rdfs:label 'Service Type Code' ;
    rdfs:comment 'The ASC X12 service type code indicating the category of healthcare service for which eligibility was verified (e.g., \'30\' = Health Benefit Plan Coverage, \'98\' = Professional Physician Visit, \'48\' = Hospital Inpatient). Aligns with the 271 EB01 element.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionControlNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Control Number' ;
    rdfs:comment 'Unique control number assigned to the 270/271 EDI eligibility inquiry and response transaction set. Used for end-to-end transaction tracing and reconciliation with payer acknowledgments.' ;
    rdfs:domain ind:EligibilityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'The method used to perform the eligibility verification. \'edi_270_271\' = HIPAA-compliant EDI transaction; \'portal\' = payer web portal; \'phone\' = telephone inquiry; \'fax\' = fax-based verification; \'real_time_api\' = real-time API call (e.g., FHIR-based); \'batch\' = overnight batch eligibility run.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Current lifecycle status of the eligibility verification transaction as returned by the payer. \'active\' = patient is currently covered; \'inactive\' = coverage lapsed; \'pending\' = awaiting payer response; \'error\' = transaction failed; \'partial\' = incomplete response received; \'not_found\' = member not found in payer system.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'The exact date and time when the eligibility verification request was initiated and submitted to the payer. Serves as the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:verificationType rdf:type rdf:Property ;
    rdfs:label 'Verification Type' ;
    rdfs:comment 'Indicates whether the eligibility check was performed in real-time at point of service, as part of a scheduled batch run (e.g., night-before appointment verification), or manually initiated by a staff member.' ;
    rdfs:domain ind:EligibilityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Verified By User' ;
    rdfs:comment 'The username or staff identifier of the person who performed or confirmed the eligibility verification, applicable for manual or portal-based verifications. Null for fully automated EDI or batch verifications.' ;
    rdfs:domain ind:EligibilityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drgId rdf:type rdf:Property ;
    rdfs:label 'Drg Id' ;
    rdfs:comment 'Foreign key linking to reference.drg. Business justification: Inpatient registration events are assigned a DRG for CMS reimbursement, case-mix reporting, and expected LOS calculation. Every hospital billing and utilization management workflow depends on this lin' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Drg .

ind:orgProviderId rdf:type rdf:Property ;
    rdfs:label 'Org Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.org_provider. Business justification: Every ADT registration event occurs at a specific facility. ADT processing, facility-level census reporting, revenue cycle, and CMS condition-of-participation compliance all require knowing which org_' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgProvider .

ind:primaryRegistrationClinicianId rdf:type rdf:Property ;
    rdfs:label 'Primary Registration Clinician Id' ;
    rdfs:comment 'Reference to the attending clinician assigned to the patient at the time of registration. Corresponds to HL7 PV1-7 Attending Doctor. Used for care team attribution and provider-level registration analytics.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:primaryRegistrationMpiRecordId rdf:type rdf:Property ;
    rdfs:label 'Primary Registration Mpi Record Id' ;
    rdfs:comment 'Reference to the patient master record in the Master Patient Index (MPI) for whom this registration event was generated. Links every registration event to the canonical patient identity.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MpiRecord .

ind:tertiaryRegistrationPcpProviderClinicianId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Registration Pcp Provider Clinician Id' ;
    rdfs:comment 'Reference to the patient\'s designated Primary Care Physician (PCP) at the time of registration. Used for care coordination, referral authorization, and population health management.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:admissionType rdf:type rdf:Property ;
    rdfs:label 'Admission Type' ;
    rdfs:comment 'Classifies the urgency and nature of the patient\'s admission at registration. Aligns with UB-04 Form Locator 14 and CMS billing requirements. Drives DRG grouping and reimbursement logic.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admitReason rdf:type rdf:Property ;
    rdfs:label 'Admit Reason' ;
    rdfs:comment 'Free-text or coded description of the chief complaint or reason for the patient\'s registration or admission at this event. Corresponds to HL7 PV2-3 Admit Reason. Supports clinical documentation and triage analytics.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adtMessageType rdf:type rdf:Property ;
    rdfs:label 'Adt Message Type' ;
    rdfs:comment 'The HL7 Admit Discharge Transfer (ADT) message type code that triggered or corresponds to this registration event (e.g., A01, A04, A08, A28, A31, A40). Provides direct traceability to the source HL7 message for interoperability and audit purposes.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advanceDirectiveFlag rdf:type rdf:Property ;
    rdfs:label 'Advance Directive Flag' ;
    rdfs:comment 'Indicates whether the patient has an advance directive (e.g., living will, healthcare proxy, DNR order) on file at the time of this registration event. Required by the Patient Self-Determination Act and CMS Conditions of Participation.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completenessScore rdf:type rdf:Property ;
    rdfs:label 'Completeness Score' ;
    rdfs:comment 'A numeric score (0.00–100.00) representing the percentage of required registration data fields that were populated at the time of this event. Used to identify incomplete registrations requiring follow-up and to measure registration quality across facilities and staff.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Flag' ;
    rdfs:comment 'Indicates whether the patient\'s general consent for treatment was obtained and documented during this registration event. Required for HIPAA compliance and The Joint Commission accreditation standards.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dischargeDisposition rdf:type rdf:Property ;
    rdfs:label 'Discharge Disposition' ;
    rdfs:comment 'The patient\'s discharge disposition code at the time of a discharge-related registration update event (e.g., home, skilled nursing facility, expired, AMA). Corresponds to UB-04 Form Locator 17 and HL7 PV1-36. Null for non-discharge events. [ENUM-REF-CANDIDATE: home|snf|rehab|expired|ama|transfer|hospice|ltac — promote to reference product]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duplicateFlag rdf:type rdf:Property ;
    rdfs:label 'Duplicate Flag' ;
    rdfs:comment 'Indicates whether this registration event was identified as a potential duplicate patient record in the Master Patient Index (MPI). Triggers MPI duplicate review and merge workflow. Critical for patient safety and data integrity.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verification Timestamp' ;
    rdfs:comment 'The date and time at which insurance eligibility was electronically verified for this registration event. Used for revenue cycle audit trails and payer dispute resolution.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eligibilityVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verified Flag' ;
    rdfs:comment 'Indicates whether the patient\'s insurance eligibility was verified in real-time during this registration event via electronic eligibility transaction (HIPAA 270/271). Supports revenue cycle management and denial prevention.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current workflow status of the registration event. Completed indicates the event was fully processed and committed to the MPI. Pending indicates the event is awaiting verification or approval. Failed indicates a system or validation error prevented completion.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The precise date and time at which the registration event occurred in the source system. Represents the real-world business event time, not the record audit timestamp. Used for MPI audit trail sequencing and regulatory reporting.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classifies the type of registration lifecycle event: new_registration (first-time patient identity creation), pre_registration (advance registration before arrival), update (demographic or insurance data change), merge (two patient records combined in MPI), unmerge (previously merged records separated). Drives MPI audit trail logic.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedLosDays rdf:type rdf:Property ;
    rdfs:label 'Expected Los Days' ;
    rdfs:comment 'The anticipated Length of Stay (LOS) in days estimated at the time of registration or admission. Used for bed management, discharge planning, and case management workflows. Supports Average Length of Stay (ALOS) benchmarking.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialClass rdf:type rdf:Property ;
    rdfs:label 'Financial Class' ;
    rdfs:comment 'The patient\'s financial classification at the time of registration, indicating the primary payer category (e.g., Medicare, Medicaid, Commercial, Self-Pay, Charity). Drives revenue cycle routing, eligibility verification, and billing workflows. [ENUM-REF-CANDIDATE: medicare|medicaid|commercial|self_pay|charity|workers_comp|tricare — promote to reference product]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaNoticeDeliveredFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Notice Delivered Flag' ;
    rdfs:comment 'Indicates whether the HIPAA Notice of Privacy Practices (NPP) was delivered to the patient during this registration event, as required by the HIPAA Privacy Rule. Supports OCR audit readiness.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identityVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Method' ;
    rdfs:comment 'The method used to verify the patient\'s identity at the time of registration. Options include government-issued photo ID, insurance card, biometric scan, passport, self-reported (no verification), or none. Critical for fraud prevention, HIPAA compliance, and MPI accuracy.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this registration event record is the current active version in the silver layer. Set to False for records superseded by subsequent updates, merges, or corrections. Supports slowly changing dimension (SCD) pattern for MPI history.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mpiMatchScore rdf:type rdf:Property ;
    rdfs:label 'Mpi Match Score' ;
    rdfs:comment 'The probabilistic match score (0.00–100.00) assigned by the MPI algorithm when this registration event was processed, indicating the confidence level of patient identity matching. Scores above threshold trigger auto-merge; scores in range trigger manual review.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mpiMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Mpi Match Status' ;
    rdfs:comment 'The outcome of the MPI identity matching process for this registration event. Indicates whether the patient was identified as a new patient, automatically matched to an existing record, flagged for manual review, automatically merged, or returned no match.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Pre Authorization Number' ;
    rdfs:comment 'The prior authorization number obtained from the payer at the time of registration for planned services. Required for revenue cycle management and claim adjudication. Null if no prior authorization was required or obtained.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorMrn rdf:type rdf:Property ;
    rdfs:label 'Prior Mrn' ;
    rdfs:comment 'The Medical Record Number of the patient record that was merged or unmerged in this event. Preserved for MPI audit trail and downstream system reconciliation. Null for non-merge events.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'The calendar date on which the patient registration event was initiated. Used for day-level reporting, scheduling, and operational analytics distinct from the precise event timestamp.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationSource rdf:type rdf:Property ;
    rdfs:label 'Registration Source' ;
    rdfs:comment 'The channel or pathway through which the patient registration was initiated. Examples include Emergency Department (ED) walk-in, scheduled appointment, inpatient transfer, online pre-registration portal, referral, or direct admission. Supports operational throughput and access analytics. [ENUM-REF-CANDIDATE: ed_walk_in|scheduled|transfer|online_pre_registration|referral|direct_admit — promote to reference product]' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedRecordFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Record Flag' ;
    rdfs:comment 'Indicates whether this patient\'s record has been flagged for restricted access beyond standard role-based controls (e.g., sensitive diagnoses, employee patient, domestic violence victim). Enforces HIPAA minimum necessary and break-the-glass access policies.' ;
    rdfs:domain ind:RegistrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemEventCode rdf:type rdf:Property ;
    rdfs:label 'Source System Event Code' ;
    rdfs:comment 'The native identifier of this registration event in the originating source system (e.g., Epic ADT event ID, Cerner encounter number). Enables bidirectional traceability between the lakehouse silver layer and the operational EHR system.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalAccountId rdf:type rdf:Property ;
    rdfs:label 'Portal Account Id' ;
    rdfs:comment 'Unique surrogate identifier for the patient portal account record. Primary key for the portal_account data product. Role classification: MASTER_AGREEMENT — represents a long-running digital engagement relationship between a patient and the healthcare organization\'s portal platform.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortalAccount .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the portal account indicating whether it is a direct patient account, a proxy account (parent, guardian, caregiver, healthcare POA), or a shared account. Determines applicable access rules and HIPAA authorization requirements. Satisfies MASTER_AGREEMENT CLASSIFICATION_OR_TYPE category.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Calendar date on which the patient first activated and verified their portal account. Distinct from created_date — an account may be created by staff but not activated by the patient until later. Key metric for digital front door strategy and patient engagement KPIs.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activationMethod rdf:type rdf:Property ;
    rdfs:label 'Activation Method' ;
    rdfs:comment 'Method by which the patient portal account was activated. Supports analysis of activation channel effectiveness for digital front door strategy and patient engagement programs.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appLinkDate rdf:type rdf:Property ;
    rdfs:label 'App Link Date' ;
    rdfs:comment 'Date on which the patient first linked a third-party digital health application to their portal account. Used for interoperability adoption tracking and CMS Promoting Interoperability reporting.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointmentSchedulingEnabled rdf:type rdf:Property ;
    rdfs:label 'Appointment Scheduling Enabled' ;
    rdfs:comment 'Indicates whether the patient has been enabled for self-service appointment scheduling through the portal. Supports digital front door strategy, patient access analytics, and operational capacity planning.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Calendar date on which the portal account was first created in the portal platform. Used for cohort analysis, onboarding funnel reporting, and MIPS Promoting Interoperability measure denominators. Satisfies MASTER_AGREEMENT EFFECTIVE_FROM category.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Calendar date on which the portal account was deactivated or terminated. Null for currently active accounts. Used for access revocation auditing and HIPAA compliance reporting. Satisfies MASTER_AGREEMENT EFFECTIVE_UNTIL category.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:digitalHealthAppLinked rdf:type rdf:Property ;
    rdfs:label 'Digital Health App Linked' ;
    rdfs:comment 'Indicates whether the patient has linked one or more third-party digital health applications (e.g., Apple Health, Google Fit, wearable device apps) to their portal account via FHIR API. Supports CMS Interoperability Final Rule compliance and patient-generated health data ingestion.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identityVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identity Verified Date' ;
    rdfs:comment 'Date on which the patient\'s identity was formally verified. Supports audit trail requirements and periodic re-verification workflows per NIST identity assurance standards.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identityVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Identity Verified Flag' ;
    rdfs:comment 'Indicates whether the patient\'s identity has been formally verified during portal account setup (e.g., via in-person verification, identity proofing service, or government ID check). Supports NIST identity assurance level requirements and HIPAA access control.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastLoginDate rdf:type rdf:Property ;
    rdfs:label 'Last Login Date' ;
    rdfs:comment 'Most recent calendar date on which the patient successfully authenticated and logged into the portal. Used for patient engagement analytics, dormant account identification, and MIPS Promoting Interoperability active patient measures.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastLoginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Login Timestamp' ;
    rdfs:comment 'Precise date and time of the most recent successful patient authentication to the portal. Provides granular session tracking for security auditing and HIPAA access log compliance beyond the date-level last_login_date.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loginFailureCount rdf:type rdf:Property ;
    rdfs:label 'Login Failure Count' ;
    rdfs:comment 'Number of consecutive failed authentication attempts since the last successful login. Used to trigger account lockout policies per HIPAA security rule requirements and NIST password management guidelines.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:messagingOptIn rdf:type rdf:Property ;
    rdfs:label 'Messaging Opt In' ;
    rdfs:comment 'Indicates whether the patient has opted in to receive secure portal messages from care team members. Supports patient engagement workflows, care coordination, and MIPS Promoting Interoperability secure messaging measures.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationEmail rdf:type rdf:Property ;
    rdfs:label 'Notification Email' ;
    rdfs:comment 'Email address used for portal notification delivery. May differ from the patient\'s primary contact email on file. Used for account activation links, secure message alerts, appointment reminders, and test result notifications.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationMobilePhone rdf:type rdf:Property ;
    rdfs:label 'Notification Mobile Phone' ;
    rdfs:comment 'Mobile phone number used for SMS-based portal notifications and two-factor authentication. May differ from the patient\'s primary contact phone on file. Subject to TCPA consent requirements.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPreference rdf:type rdf:Property ;
    rdfs:label 'Notification Preference' ;
    rdfs:comment 'Patient\'s preferred channel for receiving portal notifications (e.g., new messages, appointment reminders, test results). Drives outbound communication workflows and patient engagement strategy.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Portal Account Number' ;
    rdfs:comment 'Externally-known unique alphanumeric identifier assigned to the portal account by the portal platform (e.g., Epic MyChart account number, Cerner HealtheLife account ID). Used for cross-system reconciliation and patient-facing reference. Satisfies MASTER_AGREEMENT BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalPlatform rdf:type rdf:Property ;
    rdfs:label 'Portal Platform' ;
    rdfs:comment 'Name of the patient portal platform hosting this account (e.g., Epic MyChart, Cerner HealtheLife). Identifies the source system for digital engagement and determines applicable integration patterns for FHIR-based data exchange.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proxyAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Proxy Access Flag' ;
    rdfs:comment 'Indicates whether this portal account has been granted proxy access to another patient\'s health record (e.g., parent accessing a minor child\'s record, adult caregiver accessing an elderly patient\'s record). When true, proxy-specific fields are populated.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proxyAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Proxy Access Level' ;
    rdfs:comment 'Scope of access granted to the proxy account holder. \'full\' allows all portal functions including messaging and scheduling; \'limited\' restricts to specific record sections; \'view_only\' allows read-only access to designated information. Enforces HIPAA minimum necessary standard.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proxyAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Proxy Authorization Date' ;
    rdfs:comment 'Date on which proxy access was formally authorized and granted. Establishes the start of the proxy access period for audit and compliance purposes.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proxyDateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Proxy Date Of Birth' ;
    rdfs:comment 'Date of birth of the proxy account holder. Used for identity verification during proxy access setup and to confirm the proxy is a legal adult where required (e.g., adult caregiver, healthcare POA).' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proxyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Proxy Expiration Date' ;
    rdfs:comment 'Date on which the proxy access authorization expires. Null for indefinite authorizations. System should automatically revoke access on this date. Critical for HIPAA compliance and time-limited proxy arrangements (e.g., temporary caregiver).' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proxyFirstName rdf:type rdf:Property ;
    rdfs:label 'Proxy First Name' ;
    rdfs:comment 'First (given) name of the proxy account holder who has been granted access to the patient\'s portal record. Required for identity verification and HIPAA-compliant proxy access management.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proxyLastName rdf:type rdf:Property ;
    rdfs:label 'Proxy Last Name' ;
    rdfs:comment 'Last (family) name of the proxy account holder who has been granted access to the patient\'s portal record. Required for identity verification and HIPAA-compliant proxy access management.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proxyLegalDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Proxy Legal Document Reference' ;
    rdfs:comment 'Reference identifier or URL to the supporting legal documentation (e.g., court order number, POA document ID, scanned document storage path) that authorizes the proxy access. Supports HIPAA audit and legal compliance.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proxyLegalDocumentType rdf:type rdf:Property ;
    rdfs:label 'Proxy Legal Document Type' ;
    rdfs:comment 'Type of legal documentation supporting the proxy access authorization. Required for healthcare POA and legal guardian proxy relationships. Supports HIPAA compliance and legal defensibility of proxy access grants.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proxyRelationshipType rdf:type rdf:Property ;
    rdfs:label 'Proxy Relationship Type' ;
    rdfs:comment 'Type of relationship between the proxy account holder and the patient whose record is being accessed. Determines applicable HIPAA authorization requirements and access scope. Aligned with HL7 FHIR RelatedPerson.relationship value set.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proxyRevocationDate rdf:type rdf:Property ;
    rdfs:label 'Proxy Revocation Date' ;
    rdfs:comment 'Date on which proxy access was explicitly revoked before its natural expiration. Null if access was not revoked early. Supports HIPAA audit trail requirements for access termination events.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proxyRevocationReason rdf:type rdf:Property ;
    rdfs:label 'Proxy Revocation Reason' ;
    rdfs:comment 'Reason code for early revocation of proxy access. Supports compliance auditing and legal documentation requirements. \'age_of_majority\' applies when a minor patient reaches adulthood and proxy parental access is automatically terminated.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rxRenewalRequestEnabled rdf:type rdf:Property ;
    rdfs:label 'Rx Renewal Request Enabled' ;
    rdfs:comment 'Indicates whether the patient is enabled to submit prescription renewal requests through the portal. Supports pharmacy engagement workflows and MIPS Promoting Interoperability measures for patient-generated health data.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemAccountCode rdf:type rdf:Property ;
    rdfs:label 'Source System Account Code' ;
    rdfs:comment 'Native account identifier from the originating portal system (e.g., Epic MyChart internal account ID, Cerner HealtheLife user GUID). Enables bidirectional reconciliation between the lakehouse silver layer and the operational system of record.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAcceptedDate rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted Date' ;
    rdfs:comment 'Date on which the patient accepted the portal terms of use and privacy notice. Supports HIPAA Notice of Privacy Practices compliance documentation and legal audit trail.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termsAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted Flag' ;
    rdfs:comment 'Indicates whether the patient has accepted the portal terms of use and privacy notice. Required for account activation. Supports HIPAA Notice of Privacy Practices acknowledgment tracking.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsVersion rdf:type rdf:Property ;
    rdfs:label 'Terms Version' ;
    rdfs:comment 'Version identifier of the portal terms of use and privacy notice that the patient accepted. Enables tracking of re-consent requirements when terms are updated, supporting HIPAA Notice of Privacy Practices compliance.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultNotificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Test Result Notification Enabled' ;
    rdfs:comment 'Indicates whether the patient has enabled portal notifications for new laboratory or radiology test results. Supports patient engagement, timely result delivery, and 21st Century Cures Act information blocking compliance.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:twoFactorAuthEnrolled rdf:type rdf:Property ;
    rdfs:label 'Two Factor Auth Enrolled' ;
    rdfs:comment 'Indicates whether the patient has enrolled in two-factor authentication (2FA) for portal access. Supports HIPAA security rule compliance, NIST identity assurance level requirements, and organizational security policy enforcement.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:twoFactorAuthMethod rdf:type rdf:Property ;
    rdfs:label 'Two Factor Auth Method' ;
    rdfs:comment 'The specific method used for two-factor authentication when enrolled. Supports security posture analysis and patient experience optimization for authentication workflows.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrnCrosswalkId rdf:type rdf:Property ;
    rdfs:label 'Mrn Crosswalk Id' ;
    rdfs:comment 'Surrogate primary key for each MRN crosswalk entry.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMrnMpiRecordId rdf:type rdf:Property ;
    rdfs:label 'Primary Mrn Mpi Record Id' ;
    rdfs:comment 'FK to the enterprise MPI golden record that this identifier maps to. Core linkage for identity resolution.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MpiRecord .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates if the CDM entry is currently active.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adtEventType rdf:type rdf:Property ;
    rdfs:label 'Adt Event Type' ;
    rdfs:comment 'HL7 ADT event type (A01, A04, A08, etc.) that triggered creation or update of this crosswalk entry.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adtMessageControlNumber rdf:type rdf:Property ;
    rdfs:label 'Adt Message Control Number' ;
    rdfs:comment 'HL7 message control ID for audit trail back to the originating ADT transaction.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigningAuthority rdf:type rdf:Property ;
    rdfs:label 'Assigning Authority' ;
    rdfs:comment 'OID or namespace of the authority that assigned this identifier (e.g., facility OID, payer system).' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cernerEuid rdf:type rdf:Property ;
    rdfs:label 'Cerner Euid' ;
    rdfs:comment 'Cerner Enterprise Unique Identifier if the source system is Oracle Health/Cerner.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crosswalkStatus rdf:type rdf:Property ;
    rdfs:label 'Crosswalk Status' ;
    rdfs:comment 'Status of this crosswalk entry (ACTIVE, INACTIVE, MERGED, PENDING_REVIEW, DEPRECATED).' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Computed data quality score (0.0000-1.0000) reflecting completeness and consistency of this identifier record.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epicEmpiNumber rdf:type rdf:Property ;
    rdfs:label 'Epic Empi Number' ;
    rdfs:comment 'Epic Enterprise Master Patient Index number if the source system is Epic.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityMrn rdf:type rdf:Property ;
    rdfs:label 'Facility Mrn' ;
    rdfs:comment 'Facility-specific Medical Record Number assigned at the local site level.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fhirPatientReference rdf:type rdf:Property ;
    rdfs:label 'Fhir Patient Reference' ;
    rdfs:comment 'FHIR Patient resource reference URI for interoperability with FHIR-based systems.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hieNetworkName rdf:type rdf:Property ;
    rdfs:label 'Hie Network Name' ;
    rdfs:comment 'Name of the Health Information Exchange network that assigned this patient identifier.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierSystemOid rdf:type rdf:Property ;
    rdfs:label 'Identifier System Oid' ;
    rdfs:comment 'OID (Object Identifier) of the identifier system namespace per HL7/FHIR standards.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierType rdf:type rdf:Property ;
    rdfs:label 'Identifier Type' ;
    rdfs:comment 'Type classification of this identifier (MRN, EMPI, HIE, PAYER_MEMBER, SSN, PASSPORT, etc.).' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGoldenRecord rdf:type rdf:Property ;
    rdfs:label 'Is Golden Record' ;
    rdfs:comment 'Indicates whether this crosswalk entry represents the designated golden/authoritative record for this patient.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryIdentifier rdf:type rdf:Property ;
    rdfs:label 'Is Primary Identifier' ;
    rdfs:comment 'Indicates whether this is the primary identifier for the patient at the given facility/system.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryMrn rdf:type rdf:Property ;
    rdfs:label 'Is Primary Mrn' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAdtEventDate rdf:type rdf:Property ;
    rdfs:label 'Last Adt Event Date' ;
    rdfs:comment 'Date of the most recent ADT event that referenced this identifier, indicating recency of use.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Match Algorithm' ;
    rdfs:comment 'Name/version of the matching algorithm that established this crosswalk linkage.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Status of the identity match (CONFIRMED, PROBABLE, PENDING_REVIEW, REJECTED).' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchType rdf:type rdf:Property ;
    rdfs:label 'Match Type' ;
    rdfs:comment 'Type of matching performed (DETERMINISTIC, PROBABILISTIC, MANUAL, REFERENTIAL).' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meditechPatientNumber rdf:type rdf:Property ;
    rdfs:label 'Meditech Patient Number' ;
    rdfs:comment 'MEDITECH system patient number if the source system is MEDITECH.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mergeStatus rdf:type rdf:Property ;
    rdfs:label 'Merge Status' ;
    rdfs:comment 'Merge status of this MRN' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrnStatus rdf:type rdf:Property ;
    rdfs:label 'Mrn Status' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrnType rdf:type rdf:Property ;
    rdfs:label 'Mrn Type' ;
    rdfs:comment 'Type of MRN (facility/enterprise/HIE/payer)' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overlayRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Overlay Risk Flag' ;
    rdfs:comment 'Flag indicating this crosswalk entry has characteristics suggesting potential patient identity overlay risk.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payerMemberNumber rdf:type rdf:Property ;
    rdfs:label 'Payer Member Number' ;
    rdfs:comment 'Insurance payer member/subscriber number associated with this patient identity.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewReason rdf:type rdf:Property ;
    rdfs:label 'Review Reason' ;
    rdfs:comment 'Reason this crosswalk entry was flagged for manual review (e.g., LOW_CONFIDENCE, DEMOGRAPHIC_MISMATCH).' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Source Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the last update in the source system for this identifier record.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceMrn rdf:type rdf:Property ;
    rdfs:label 'Source Mrn' ;
    rdfs:comment 'Source Mrn for mrn crosswalk.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemIdentifier rdf:type rdf:Property ;
    rdfs:label 'Source System Identifier' ;
    rdfs:comment 'The actual identifier value as stored in the source system.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPatientIdentifier rdf:type rdf:Property ;
    rdfs:label 'Source System Patient Identifier' ;
    rdfs:comment 'Source system patient identifier - PHI' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Verified Flag' ;
    rdfs:comment 'Boolean indicating whether this crosswalk linkage has been verified by a human reviewer or automated verification process.' ;
    rdfs:domain ind:MrnCrosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentReferenceId rdf:type rdf:Property ;
    rdfs:label 'Consent Reference Id' ;
    rdfs:comment 'Unique identifier for the consent reference record. Primary key.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentReference .

ind:consentDomainRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Domain Record Id' ;
    rdfs:comment 'FK to consent.record (cross-domain reference)' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Record .

ind:primaryConsentClinicianId rdf:type rdf:Property ;
    rdfs:label 'Primary Consent Clinician Id' ;
    rdfs:comment 'Foreign key reference to the provider who obtained or witnessed the consent from the patient.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:recordId rdf:type rdf:Property ;
    rdfs:label 'Record Id' ;
    rdfs:comment 'Foreign key reference to the consent master record in the consent domain SSOT. Enables cross-domain joins to full consent details.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Record .

ind:supersededConsentReferenceId rdf:type rdf:Property ;
    rdfs:label 'Superseded Consent Reference Id' ;
    rdfs:comment 'Self-referencing FK on consent_reference (superseded_consent_reference_id)' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentReference .

ind:auditTrailFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Flag' ;
    rdfs:comment 'Indicates whether a detailed audit trail exists for this consent reference in the consent domain SSOT. True if audit trail is available, False otherwise.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Consent Effective Date' ;
    rdfs:comment 'The date when the consent becomes effective and enforceable. Denormalized from consent master for quick filtering and reporting.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiration Date' ;
    rdfs:comment 'The date when the consent expires and is no longer valid. Null if the consent has no expiration. Denormalized from consent master for quick filtering.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'The method by which the consent was obtained from the patient (e.g., written signature, verbal acknowledgment, electronic signature via patient portal, implied consent).' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentObtainedDate rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Date' ;
    rdfs:comment 'The date when the consent was originally obtained from the patient or their authorized representative.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentRevocationDate rdf:type rdf:Property ;
    rdfs:label 'Consent Revocation Date' ;
    rdfs:comment 'The date when the patient revoked their consent. Null if the consent has not been revoked.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Textual description of the scope or boundaries of the consent. Describes what specific activities, data types, or purposes are covered by this consent.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle status of the consent reference. Indicates whether the consent is currently active, has been revoked by the patient, has expired, is pending approval, or has been superseded by a newer consent.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'The category of consent being referenced. Indicates the purpose or scope of the consent (e.g., treatment, research participation, marketing communications, PHI disclosure, HIE participation, telehealth services).' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Document Reference Number' ;
    rdfs:comment 'Reference identifier to the physical or electronic consent document stored in the document management system. Enables retrieval of the original signed consent form.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Expiration Date for consent reference.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianName rdf:type rdf:Property ;
    rdfs:label 'Guardian Name' ;
    rdfs:comment 'Full name of the legal guardian or authorized representative who provided consent on behalf of the patient. Null if patient provided consent directly.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianRelationship rdf:type rdf:Property ;
    rdfs:label 'Guardian Relationship' ;
    rdfs:comment 'The relationship of the guardian or authorized representative to the patient (e.g., parent, spouse, healthcare proxy, power of attorney).' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hieParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Hie Participation Flag' ;
    rdfs:comment 'Indicates whether the patient has consented to participate in Health Information Exchange networks for sharing their medical records across organizations. True if HIE participation is authorized, False otherwise.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interpreterUsedFlag rdf:type rdf:Property ;
    rdfs:label 'Interpreter Used Flag' ;
    rdfs:comment 'Indicates whether a medical interpreter was used during the consent process. True if an interpreter was present, False otherwise.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageOfConsent rdf:type rdf:Property ;
    rdfs:label 'Language Of Consent' ;
    rdfs:comment 'The language in which the consent was presented to and obtained from the patient. Important for compliance with language access requirements.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Flag' ;
    rdfs:comment 'Indicates whether the patient has opted in to receive marketing communications. True if patient opted in, False otherwise.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phiDisclosureAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Phi Disclosure Authorized Flag' ;
    rdfs:comment 'Indicates whether this consent authorizes disclosure of Protected Health Information to third parties. True if PHI disclosure is authorized, False otherwise.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referencePriority rdf:type rdf:Property ;
    rdfs:label 'Reference Priority' ;
    rdfs:comment 'Priority order of this consent reference when multiple consents of the same type exist for a patient. Lower numbers indicate higher priority. Used for determining which consent applies in conflict scenarios.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:researchParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Research Participation Flag' ;
    rdfs:comment 'Indicates whether this consent includes authorization for the patient to participate in research studies. True if research participation is authorized, False otherwise.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Source System Reference Code' ;
    rdfs:comment 'The unique identifier for this consent reference record in the source system. Used for data lineage and reconciliation.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verified Timestamp' ;
    rdfs:comment 'The date and time when this consent reference record was verified. Null if not yet verified.' ;
    rdfs:domain ind:ConsentReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:witnessRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Witness Required Flag' ;
    rdfs:comment 'Indicates whether a witness signature was required for this consent based on regulatory or organizational policy. True if witness was required, False otherwise.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appointmentTypeId rdf:type rdf:Property ;
    rdfs:label 'Appointment Type Id' ;
    rdfs:comment 'Foreign key linking to scheduling.appointment_type. Business justification: Service line analytics and payer contract reporting require correlating appointment type (telehealth, office, procedure) with encounter outcomes (LOS, DRG, readmission). visit.visit_type_code is a den' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AppointmentType .

ind:principalIcdCodeId rdf:type rdf:Property ;
    rdfs:label 'Principal Icd Code Id' ;
    rdfs:comment 'Foreign key linking to reference.icd_code. Business justification: The principal ICD-10 diagnosis on a visit drives DRG grouping, HRRP quality measure categorization, and CMS billing. A domain expert expects visit to carry a validated FK to the ICD code reference tab' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcdCode .

ind:tertiaryVisitDischargingProviderClinicianId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Visit Discharging Provider Clinician Id' ;
    rdfs:comment 'Reference to the clinician who authorized and completed the patient discharge. Used for care transition accountability, discharge instruction tracking, and quality audits.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:admissionSource rdf:type rdf:Property ;
    rdfs:label 'Admission Source' ;
    rdfs:comment 'Indicates the origin point from which the patient entered the facility for this visit. Required for UB-04 billing, readmission analysis, and care transition reporting. [ENUM-REF-CANDIDATE: emergency_department|direct_admission|transfer|referral|birth|court_law|information_not_available — promote to reference product]' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Admission Timestamp' ;
    rdfs:comment 'Date and time the patient was formally admitted to the facility or the visit began. Principal business event timestamp for the encounter lifecycle. Used for LOS calculation, throughput analytics, and regulatory reporting.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:admittingDiagnosisCode rdf:type rdf:Property ;
    rdfs:label 'Admitting Diagnosis Code' ;
    rdfs:comment 'ICD-10-CM code representing the condition documented at the time of admission, before full workup. May differ from the principal discharge diagnosis. Required on UB-04 for inpatient claims.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:careSetting rdf:type rdf:Property ;
    rdfs:label 'Care Setting' ;
    rdfs:comment 'Specific clinical environment within the facility where the patient received care during this visit. More granular than visit type; used for staffing, capacity management, and HAI surveillance. [ENUM-REF-CANDIDATE: inpatient_ward|icu|ed|or|observation_unit|outpatient_clinic|telehealth|labor_delivery|nicu|step_down — promote to reference product]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:careTransitionPlanCompleted rdf:type rdf:Property ;
    rdfs:label 'Care Transition Plan Completed' ;
    rdfs:comment 'Indicates whether a formal care transition plan was completed and communicated to the receiving provider or care setting at discharge. Required for CMS Transitional Care Management billing and TJC accreditation.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentObtained rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained' ;
    rdfs:comment 'Indicates whether informed consent for treatment was obtained and documented at the time of admission or prior to procedure. Required for TJC accreditation and HIPAA compliance.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:convertedToInpatient rdf:type rdf:Property ;
    rdfs:label 'Converted To Inpatient' ;
    rdfs:comment 'Indicates whether an observation encounter was subsequently converted to a formal inpatient admission. Triggers billing reclassification and DRG assignment workflows.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dischargeInstructionsIssued rdf:type rdf:Property ;
    rdfs:label 'Discharge Instructions Issued' ;
    rdfs:comment 'Indicates whether written discharge instructions were provided to the patient or caregiver at the time of discharge. Required for TJC accreditation, HCAHPS scoring, and CMS Conditions of Participation.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dischargeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discharge Timestamp' ;
    rdfs:comment 'Date and time the patient was formally discharged or the visit concluded. Used for LOS calculation, bed management, and revenue cycle close-out. Null for visits still in progress.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:drgType rdf:type rdf:Property ;
    rdfs:label 'Drg Type' ;
    rdfs:comment 'Identifies the DRG classification system used for this encounter (Medicare Severity DRG, All Patient Refined DRG, or All Patient DRG). Determines reimbursement methodology and payer applicability.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drgWeight rdf:type rdf:Property ;
    rdfs:label 'Drg Weight' ;
    rdfs:comment 'Numeric relative weight assigned to the DRG, reflecting the average resource intensity of cases in that group. Used to calculate expected reimbursement and Case Mix Index (CMI) contribution for the facility.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emtalaCompliant rdf:type rdf:Property ;
    rdfs:label 'Emtala Compliant' ;
    rdfs:comment 'Indicates whether EMTALA obligations were assessed and met for this visit, including medical screening examination and stabilization requirements. Critical for ED visits and transfer scenarios. Required for OIG compliance audits.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encounterNumber rdf:type rdf:Property ;
    rdfs:label 'Encounter Number' ;
    rdfs:comment 'Human-readable, externally-known visit or encounter number assigned by the source EHR system (e.g., Epic CSN — Contact Serial Number, or Cerner FIN — Financial Identification Number). Used in billing, claims, and patient communications.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpScheduled rdf:type rdf:Property ;
    rdfs:label 'Follow Up Scheduled' ;
    rdfs:comment 'Indicates whether a follow-up appointment was scheduled prior to or at the time of discharge. Used for care transition quality metrics, readmission prevention programs, and HEDIS measure compliance.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inpatientConversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inpatient Conversion Timestamp' ;
    rdfs:comment 'Date and time an observation status encounter was formally converted to inpatient admission. Used for LOS recalculation, billing reclassification, and two-midnight rule compliance documentation.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lengthOfStayDays rdf:type rdf:Property ;
    rdfs:label 'Length Of Stay Days' ;
    rdfs:comment 'Total number of inpatient days from admission to discharge, calculated as discharge date minus admission date. Key operational and financial metric used for ALOS benchmarking, CMI analysis, and VBP performance.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moonDeliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Moon Delivered Timestamp' ;
    rdfs:comment 'Date and time the Medicare Outpatient Observation Notice (MOON) was delivered to the patient, as required by the NOTICE Act for Medicare beneficiaries receiving observation services exceeding 24 hours.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:observationHours rdf:type rdf:Property ;
    rdfs:label 'Observation Hours' ;
    rdfs:comment 'Total number of hours the patient spent under outpatient observation status during this visit. Used for two-midnight rule compliance assessment, MOON trigger evaluation, and Medicare billing.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:observationStatus rdf:type rdf:Property ;
    rdfs:label 'Observation Status' ;
    rdfs:comment 'Indicates whether the patient is classified under outpatient observation status rather than formal inpatient admission. Drives MOON delivery requirement, two-midnight rule assessment, and Medicare Part A vs Part B billing determination.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointOfServiceCode rdf:type rdf:Property ;
    rdfs:label 'Point Of Service Code' ;
    rdfs:comment 'CMS two-digit Place of Service code indicating the setting where the professional service was rendered. Required on CMS-1500 professional claims for correct reimbursement routing.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Readmission Flag' ;
    rdfs:comment 'Indicates whether this visit is classified as an unplanned readmission within 30 days of a prior discharge. Used for CMS Hospital Readmissions Reduction Program (HRRP) reporting and VBP performance measurement.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:readmissionRiskScore rdf:type rdf:Property ;
    rdfs:label 'Readmission Risk Score' ;
    rdfs:comment 'Numeric risk score (e.g., LACE, HOSPITAL score) predicting the probability of unplanned 30-day readmission. Used by care management teams to prioritize post-discharge follow-up and care transition interventions.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceEncounterCode rdf:type rdf:Property ;
    rdfs:label 'Source Encounter Code' ;
    rdfs:comment 'Native encounter identifier from the originating EHR system (e.g., Epic CSN, Cerner Encounter ID). Preserved for cross-system reconciliation, HIE interoperability, and FHIR API mapping.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telehealthConnectionQuality rdf:type rdf:Property ;
    rdfs:label 'Telehealth Connection Quality' ;
    rdfs:comment 'Assessed quality of the audio/video connection during a telehealth visit. Used for patient experience reporting, platform SLA monitoring, and identifying visits that may require follow-up due to technical issues.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telehealthPlatform rdf:type rdf:Property ;
    rdfs:label 'Telehealth Platform' ;
    rdfs:comment 'Name of the telehealth technology platform used to conduct the virtual visit (e.g., Epic MyChart Video, Zoom for Healthcare, Teladoc). Required for telehealth billing modifier application and platform performance reporting.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:twoMidnightCompliant rdf:type rdf:Property ;
    rdfs:label 'Two Midnight Compliant' ;
    rdfs:comment 'Indicates whether the inpatient admission meets CMS two-midnight rule criteria, requiring the admitting physician to expect the patient to require hospital care spanning at least two midnights. Critical for Medicare inpatient billing compliance and RAC audit defense.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vibeAddedFlag rdf:type rdf:Property ;
    rdfs:label 'Vibe Added Flag' ;
    rdfs:comment 'Flag added by VIBE mutator to ensure change' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vibeProductListVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Vibe Product List Verified Flag' ;
    rdfs:comment 'Marker confirming canonical product list verification pass.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visitStatus rdf:type rdf:Property ;
    rdfs:label 'Visit Status' ;
    rdfs:comment 'Current lifecycle state of the visit from scheduling through discharge. Drives ADT event processing, bed management, and revenue cycle workflows in Epic ADT and Cerner PowerChart.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitType rdf:type rdf:Property ;
    rdfs:label 'Visit Type' ;
    rdfs:comment 'Classification of the patient-provider interaction by care setting and service modality. Drives billing rules, regulatory requirements, and clinical workflow routing. [ENUM-REF-CANDIDATE: inpatient|outpatient|emergency|observation|telehealth|ambulatory|surgical|preventive — promote to reference product]' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adtEventId rdf:type rdf:Property ;
    rdfs:label 'Adt Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each ADT event record in the silver layer. Primary key for the adt_event data product. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdtEvent .

ind:priorEventAdtEventId rdf:type rdf:Property ;
    rdfs:label 'Prior Event Adt Event Id' ;
    rdfs:comment 'Reference to the immediately preceding ADT event in the same encounter\'s event chain. Enables reconstruction of the full ADT event sequence and care pathway for LOS milestone tracking and transitions-of-care analysis.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdtEvent .

ind:transferringOrgProviderId rdf:type rdf:Property ;
    rdfs:label 'Transferring Org Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.org_provider. Business justification: ADT transfer events require identification of the sending/receiving facility for EMTALA compliance tracking, inter-facility patient flow management, and transfer center operations. sending_facility is' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgProvider .

ind:acceptingProviderNpi rdf:type rdf:Property ;
    rdfs:label 'Accepting Provider Npi' ;
    rdfs:comment '10-digit National Provider Identifier (NPI) of the provider accepting responsibility for the patient at the destination care setting during a transfer event. Required for EMTALA transfer compliance documentation and inter-facility transfer records.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admissionSourceCode rdf:type rdf:Property ;
    rdfs:label 'Admission Source Code' ;
    rdfs:comment 'Standardized code indicating the source from which the patient was admitted (e.g., physician referral, emergency room, transfer from another facility, birth). Corresponds to PV1-14 (Admit Source) in HL7 v2.x and UB-04 field 15. Used for DRG grouping and regulatory reporting. [ENUM-REF-CANDIDATE: 1|2|3|4|5|6|7|8|9 — promote to reference product per UB-04 Admit Source codes]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amaFlag rdf:type rdf:Property ;
    rdfs:label 'Ama Flag' ;
    rdfs:comment 'Indicates whether the patient was discharged Against Medical Advice (AMA). Populated for discharge events (A03). Relevant for discharge disposition coding, liability documentation, and readmission risk analysis.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bedAssignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Bed Assigned Timestamp' ;
    rdfs:comment 'Date and time a specific bed was assigned to the patient as part of this ADT event. Used to calculate bed assignment turnaround time and support capacity management analytics.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bedRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Bed Request Timestamp' ;
    rdfs:comment 'Date and time a bed was requested for the patient as part of this ADT event. Used to calculate bed placement turnaround time and support real-time bed management KPIs.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancelReason rdf:type rdf:Property ;
    rdfs:label 'Cancel Reason' ;
    rdfs:comment 'Free-text or coded reason for cancellation when event_status is \'cancelled\'. Captures clinical or administrative rationale for reversing an ADT event (e.g., \'Patient not admitted\', \'Duplicate registration\'). Corresponds to EVN-4 in HL7 v2.x.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalReasonForTransfer rdf:type rdf:Property ;
    rdfs:label 'Clinical Reason For Transfer' ;
    rdfs:comment 'Free-text or coded clinical justification for a patient transfer event (e.g., \'Requires ICU-level monitoring\', \'Specialist not available at sending facility\'). Populated for transfer and inter-facility transition events. Supports EMTALA compliance documentation and care transitions analysis.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeDispositionCode rdf:type rdf:Property ;
    rdfs:label 'Discharge Disposition Code' ;
    rdfs:comment 'Standardized code indicating the patient\'s status or destination at discharge (e.g., home, skilled nursing facility, expired, AMA). Corresponds to PV1-36 (Discharge Disposition) in HL7 v2.x and UB-04 field 17. Required for DRG assignment, readmission risk, and CMS quality reporting. [ENUM-REF-CANDIDATE: 01|02|03|04|05|06|07|20|30|43|50|51|61|62|63|64|65|66|69|70|71|72 — promote to reference product per NUBC Patient Discharge Status codes]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emtalaTransferFormCompleted rdf:type rdf:Property ;
    rdfs:label 'Emtala Transfer Form Completed' ;
    rdfs:comment 'Indicates whether the required EMTALA transfer certification form was completed and signed by the responsible physician prior to inter-facility transfer. Supports OIG audit readiness and EMTALA compliance tracking.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventRecordedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Recorded Timestamp' ;
    rdfs:comment 'The date and time the ADT event was recorded or entered into the source system (Epic or Cerner). May differ from event_timestamp when events are back-entered. Corresponds to EVN-4 (Event Recorded Date/Time) in HL7 v2.x.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventTypeCode rdf:type rdf:Property ;
    rdfs:label 'Event Type Code' ;
    rdfs:comment 'HL7 ADT event type code identifying the nature of the ADT transaction. Standard HL7 v2.x event codes include A01 (Admit), A02 (Transfer), A03 (Discharge), A04 (Register Outpatient), A05 (Pre-Admit), A06 (Change Outpatient to Inpatient), A07 (Change Inpatient to Outpatient), A08 (Update Patient Info), A11 (Cancel Admit), A12 (Cancel Transfer), A13 (Cancel Discharge), A21 (Patient Goes on Leave of Absence), A22 (Patient Returns from Leave of Absence), among others. [ENUM-REF-CANDIDATE: A01|A02|A03|A04|A05|A06|A07|A08|A09|A10|A11|A12|A13|A21|A22 — promote to reference product]' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Event Type Description' ;
    rdfs:comment 'Human-readable description of the ADT event type corresponding to the event_type_code (e.g., \'Admit a Patient\', \'Transfer a Patient\', \'Discharge/End Visit\'). Sourced from HL7 ADT event type table.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromBedCode rdf:type rdf:Property ;
    rdfs:label 'From Bed Code' ;
    rdfs:comment 'Specific bed identifier from which the patient is being transferred or discharged. Supports real-time bed management and occupancy tracking. Corresponds to PV1-3 (Prior Patient Location) bed component in HL7 v2.x.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromUnitCode rdf:type rdf:Property ;
    rdfs:label 'From Unit Code' ;
    rdfs:comment 'Code identifying the nursing unit, care area, or department from which the patient is being transferred or discharged. For admission events, this represents the originating unit (e.g., ED). Corresponds to PV1-3 prior location in HL7 v2.x.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isolationFlag rdf:type rdf:Property ;
    rdfs:label 'Isolation Flag' ;
    rdfs:comment 'Indicates whether the patient requires isolation precautions at the time of this ADT event (e.g., contact, droplet, airborne precautions). Drives bed assignment logic, infection control workflows, and HAI prevention protocols.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isolationType rdf:type rdf:Property ;
    rdfs:label 'Isolation Type' ;
    rdfs:comment 'Type of isolation precaution required for the patient at the time of this ADT event. Values: contact, droplet, airborne, protective (reverse isolation), none. Populated when isolation_flag is true. Supports infection control and bed management workflows.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveOfAbsenceReason rdf:type rdf:Property ;
    rdfs:label 'Leave Of Absence Reason' ;
    rdfs:comment 'Reason for a patient leave of absence event (HL7 A21). Captures the clinical or administrative justification when a patient temporarily leaves the facility (e.g., therapeutic pass, family visit). Null for non-leave events.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelOfCareCode rdf:type rdf:Property ;
    rdfs:label 'Level Of Care Code' ;
    rdfs:comment 'Code representing the clinical level of care at the destination unit for this ADT event. Values: ICU (Intensive Care Unit), PCU (Progressive Care Unit), MED_SURG (Medical-Surgical), ED (Emergency Department), OR (Operating Room), PACU (Post-Anesthesia Care Unit), OBS (Observation), TELE (Telemetry), NICU (Neonatal ICU), PICU (Pediatric ICU). Supports LOS milestone tracking and level-of-care transition analysis. [ENUM-REF-CANDIDATE: ICU|PCU|MED_SURG|ED|OR|PACU|OBS|TELE|NICU|PICU — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientClassCode rdf:type rdf:Property ;
    rdfs:label 'Patient Class Code' ;
    rdfs:comment 'HL7 patient class code indicating the care setting type at the time of this ADT event. Values: I=Inpatient, O=Outpatient, E=Emergency, B=Obstetrics, C=Commercial Account, N=Not Applicable, R=Recurring Patient, U=Unknown. Corresponds to PV1-2 in HL7 v2.x. Drives billing, regulatory reporting, and LOS calculations. [ENUM-REF-CANDIDATE: I|O|E|B|C|N|R|U — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientStabilityScore rdf:type rdf:Property ;
    rdfs:label 'Patient Stability Score' ;
    rdfs:comment 'Clinical assessment of patient stability at the time of a transfer event. Values: stable, guarded, critical, unstable. Required for EMTALA transfer compliance documentation and supports risk stratification for inter-facility transfers.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readmissionRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Readmission Risk Flag' ;
    rdfs:comment 'Indicates whether the patient has been flagged as high-risk for readmission at the time of this discharge ADT event. Populated by predictive risk models or clinical decision support tools. Supports CMS Hospital Readmissions Reduction Program (HRRP) compliance and care transitions planning.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sendingApplication rdf:type rdf:Property ;
    rdfs:label 'Sending Application' ;
    rdfs:comment 'Name of the source application that generated the HL7 ADT message (e.g., \'EPIC\', \'CERNER\'). Corresponds to MSH-3 (Sending Application) in HL7 v2.x. Supports source system traceability and ETL lineage.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingFacility rdf:type rdf:Property ;
    rdfs:label 'Sending Facility' ;
    rdfs:comment 'Name or identifier of the facility or system that originated the HL7 ADT message. Corresponds to MSH-4 (Sending Facility) in HL7 v2.x. Used for multi-facility environments and HIE routing.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordinal sequence number of this ADT event within the encounter\'s event chain. Enables chronological ordering of all ADT events for a given encounter when timestamps alone are insufficient (e.g., same-second events).' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemName rdf:type rdf:Property ;
    rdfs:label 'Source System Name' ;
    rdfs:comment 'Name of the operational EHR system that is the authoritative source for this ADT event record. Values: EPIC (Epic EHR ADT), CERNER (Cerner Millennium ADT), MEDITECH (MEDITECH Expanse). Supports multi-system environments and data lineage.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toBedCode rdf:type rdf:Property ;
    rdfs:label 'To Bed Code' ;
    rdfs:comment 'Specific bed identifier to which the patient is being admitted or transferred. Supports real-time bed management, housekeeping workflows, and infection control tracking. Corresponds to PV1-3 assigned bed component in HL7 v2.x.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toRoomCode rdf:type rdf:Property ;
    rdfs:label 'To Room Code' ;
    rdfs:comment 'Room identifier within the destination unit to which the patient is assigned. Complements to_bed_code for full location resolution. Corresponds to PV1-3 room component in HL7 v2.x.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toUnitCode rdf:type rdf:Property ;
    rdfs:label 'To Unit Code' ;
    rdfs:comment 'Code identifying the nursing unit, care area, or department to which the patient is being admitted or transferred. Corresponds to PV1-3 (Assigned Patient Location) in HL7 v2.x. Central to real-time bed management and capacity planning.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionType rdf:type rdf:Property ;
    rdfs:label 'Transition Type' ;
    rdfs:comment 'Classification of the care setting transition for transfer events. Values: inter_unit (within same facility, same level of care), level_of_care_change (e.g., floor to ICU), inter_facility (between different facilities), internal_transfer, external_transfer. Null for non-transfer events. Supports transitions-of-care quality measures.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Mode of transport used for patient transfer between care settings or facilities. Applicable for transfer and discharge events. Values include ambulance, helicopter, wheelchair, stretcher, ambulatory, private_vehicle. Null for non-transfer events.' ;
    rdfs:domain ind:AdtEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitTypeCode rdf:type rdf:Property ;
    rdfs:label 'Visit Type Code' ;
    rdfs:comment 'Classification of the visit type associated with this ADT event (e.g., inpatient, outpatient, emergency, observation, telehealth, ambulatory). Complements patient_class_code with business-level visit categorization used in analytics and reporting.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitProviderId rdf:type rdf:Property ;
    rdfs:label 'Visit Provider Id' ;
    rdfs:comment 'Unique surrogate identifier for each visit-provider association record in the Silver layer lakehouse. Primary key for this junction entity linking a provider to a specific patient visit with a defined role.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groupId rdf:type rdf:Property ;
    rdfs:label 'Group Id' ;
    rdfs:comment 'Foreign key linking to provider.group. Business justification: Provider group attribution on a visit assignment is required for group-level billing (group NPI on claims), payer contract application, and MIPS group reporting. billing_provider_npi is a denormalized' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Group .

ind:networkAffiliationId rdf:type rdf:Property ;
    rdfs:label 'Network Affiliation Id' ;
    rdfs:comment 'Foreign key linking to provider.network_affiliation. Business justification: Links provider assignment to specific network participation record for the visit\'s payer. Essential for determining in-network vs out-of-network status, calculating patient cost-sharing, and supportin' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkAffiliation .

ind:primaryVisitClinicianId rdf:type rdf:Property ;
    rdfs:label 'Primary Visit Clinician Id' ;
    rdfs:comment 'Reference to the clinician or provider record assigned to this visit. Links to the provider domain clinician master record.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:referralOrderId rdf:type rdf:Property ;
    rdfs:label 'Referral Order Id' ;
    rdfs:comment 'Reference to the formal consultation order or request that triggered this provider\'s assignment to the visit. Applicable when assignment_type is \'consult_request\'. Links to the order management domain.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReferralOrder .

ind:specialtyId rdf:type rdf:Property ;
    rdfs:label 'Specialty Id' ;
    rdfs:comment 'Foreign key linking to provider.specialty. Business justification: specialty_at_assignment is a denormalized text column on visit_provider. Normalizing to provider.specialty supports specialty-level utilization reporting, network adequacy analysis, and payer credenti' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specialty .

ind:tertiaryVisitSupervisingProviderClinicianId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Visit Supervising Provider Clinician Id' ;
    rdfs:comment 'Reference to the supervising or attending physician responsible for overseeing this provider\'s participation in the visit. Required for resident, student, and mid-level provider assignments per CMS teaching physician billing guidelines.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:admissionSourceRole rdf:type rdf:Property ;
    rdfs:label 'Admission Source Role' ;
    rdfs:comment 'Indicates whether this provider served as the admitting, referring, or transferring physician at the time of patient admission. Relevant for ADT (Admit, Discharge, Transfer) event documentation and CMS admission source reporting.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment End Timestamp' ;
    rdfs:comment 'Date and time when the provider\'s active participation in this visit ended. Null if the provider is still actively assigned. Used for LOS (Length of Stay) attribution, handoff documentation, and coverage gap analysis.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Timestamp' ;
    rdfs:comment 'Date and time when the provider\'s active participation in this visit began. Used for time-bounded care team tracking, shift coverage analysis, and provider performance analytics per encounter.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the provider\'s assignment to this visit. \'active\' indicates current participation; \'transferred\' indicates a handoff to another provider has occurred; \'cancelled\' indicates the assignment was voided.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Indicates how the provider came to be assigned to this visit — whether through scheduled care, unscheduled walk-in, emergency response, on-call coverage, or formal consult request. Supports operational staffing and care coordination analytics.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingProviderNpi rdf:type rdf:Property ;
    rdfs:label 'Billing Provider Npi' ;
    rdfs:comment 'The NPI (National Provider Identifier) used specifically for billing and claims submission for services rendered by this provider during this visit. May differ from the rendering provider NPI when billing under a group practice or supervising physician.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:careTeamSequence rdf:type rdf:Property ;
    rdfs:label 'Care Team Sequence' ;
    rdfs:comment 'Ordinal sequence number indicating the order in which this provider was added to the visit care team. Used to reconstruct care team composition history and identify primary vs. secondary team members in chronological order.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text comments or notes entered by clinical staff regarding this provider\'s assignment to the visit. May include coverage rationale, special instructions, or handoff context not captured in structured fields.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cosignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Cosignature Required' ;
    rdfs:comment 'Indicates whether the provider\'s clinical documentation for this visit requires co-signature by a supervising physician (e.g., resident or student notes requiring attending co-signature). Supports CDI (Clinical Documentation Improvement) workflow and compliance.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:credentialingVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Credentialing Verified Flag' ;
    rdfs:comment 'Indicates whether the provider\'s credentials and privileges were verified as current and active at the time of this visit assignment. Supports Joint Commission credentialing compliance and risk management.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drgAttributionFlag rdf:type rdf:Property ;
    rdfs:label 'Drg Attribution Flag' ;
    rdfs:comment 'Indicates whether this provider\'s assignment is attributed to the DRG (Diagnosis-Related Group) assignment for inpatient billing purposes. The attending of record\'s DRG attribution drives inpatient reimbursement under CMS IPPS.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handoffReference rdf:type rdf:Property ;
    rdfs:label 'Handoff Reference' ;
    rdfs:comment 'Reference identifier or note key pointing to the handoff documentation record created when this provider transferred care responsibility to another provider. Supports care continuity, patient safety, and Joint Commission handoff communication standards.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAttendingOfRecord rdf:type rdf:Property ;
    rdfs:label 'Is Attending Of Record' ;
    rdfs:comment 'Indicates whether this provider is designated as the attending physician of record for the visit. The attending of record bears overall clinical and legal responsibility for the patient\'s care and is reported on all billing claims.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryProvider rdf:type rdf:Property ;
    rdfs:label 'Is Primary Provider' ;
    rdfs:comment 'Indicates whether this provider holds primary clinical and billing responsibility for the visit. Only one provider per visit should have this flag set to True. Drives attending physician attribution on claims, UB-04, and CMS-1500 forms.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locumTenensFlag rdf:type rdf:Property ;
    rdfs:label 'Locum Tenens Flag' ;
    rdfs:comment 'Indicates whether the provider is serving in a locum tenens (temporary substitute) capacity for this visit. Locum tenens billing has specific CMS rules requiring the Q6 modifier on claims.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mipsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Mips Eligible Flag' ;
    rdfs:comment 'Indicates whether this provider\'s participation in this visit is eligible for MIPS (Merit-based Incentive Payment System) performance measurement under MACRA (Medicare Access and CHIP Reauthorization Act). Drives quality measure attribution.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noteCount rdf:type rdf:Property ;
    rdfs:label 'Note Count' ;
    rdfs:comment 'Number of clinical notes authored or co-signed by this provider for this visit. Supports CDI (Clinical Documentation Improvement) completeness tracking and provider documentation compliance reporting.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npi rdf:type rdf:Property ;
    rdfs:label 'Npi' ;
    rdfs:comment 'The 10-digit National Provider Identifier (NPI) of the assigned provider as issued by CMS. Captured at time of assignment to support billing, claims adjudication, and RVU (Relative Value Unit) attribution independent of provider master record changes.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onCallFlag rdf:type rdf:Property ;
    rdfs:label 'On Call Flag' ;
    rdfs:comment 'Indicates whether this provider was assigned to the visit as part of an on-call coverage rotation rather than a scheduled or direct assignment. Supports on-call scheduling analytics and EMTALA (Emergency Medical Treatment and Labor Act) compliance tracking.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderCount rdf:type rdf:Property ;
    rdfs:label 'Order Count' ;
    rdfs:comment 'Number of clinical orders (lab, radiology, pharmacy, procedures) placed by this provider via CPOE (Computerized Physician Order Entry) for this visit. Supports provider ordering pattern analytics and CPOE adoption reporting.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participationDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Participation Duration Minutes' ;
    rdfs:comment 'Total number of minutes the provider was actively engaged in this visit, calculated from assignment_start_timestamp to assignment_end_timestamp. Used for time-based billing (e.g., anesthesia, critical care), provider productivity reporting, and staffing analytics.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:placeOfServiceCode rdf:type rdf:Property ;
    rdfs:label 'Place Of Service Code' ;
    rdfs:comment 'Two-digit CMS Place of Service (POS) code indicating the setting where the provider rendered services during this visit (e.g., 11=Office, 21=Inpatient Hospital, 23=Emergency Room, 02=Telehealth). Required on CMS-1500 professional claims.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privilegeType rdf:type rdf:Property ;
    rdfs:label 'Privilege Type' ;
    rdfs:comment 'The type of clinical privileges held by the provider at the facility for this visit assignment (e.g., full, provisional, temporary, locum tenens, telemedicine). Determines scope of permissible clinical activities.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerRole rdf:type rdf:Property ;
    rdfs:label 'Provider Role' ;
    rdfs:comment 'Clinical role of the provider for this specific visit assignment (e.g., attending, consulting, admitting, covering, resident, hospitalist, surgeon, anesthesiologist, PCP). Determines care team hierarchy, billing responsibility, and RVU attribution. [ENUM-REF-CANDIDATE: attending|consulting|admitting|covering|resident|hospitalist|surgeon|anesthesiologist|pcp|co_surgeon|scrub_tech|circulating_nurse|care_coordinator — promote to reference product]' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'Classification of the provider\'s credential type for this assignment (e.g., physician, NP (Nurse Practitioner), PA (Physician Assistant), resident, fellow, student, RN, CRNA). Determines billing rules, supervision requirements, and scope of practice. [ENUM-REF-CANDIDATE: physician|np|pa|resident|fellow|student|rn|crna|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renderingProviderNpi rdf:type rdf:Property ;
    rdfs:label 'Rendering Provider Npi' ;
    rdfs:comment 'The NPI (National Provider Identifier) of the individual clinician who actually rendered the service during this visit. Distinct from billing_provider_npi when services are billed under a group or supervising provider.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rvuCreditFlag rdf:type rdf:Property ;
    rdfs:label 'Rvu Credit Flag' ;
    rdfs:comment 'Indicates whether this provider assignment is eligible to receive RVU (Relative Value Unit) credit for services rendered during this visit. Used in provider productivity reporting, compensation modeling, and MIPS (Merit-based Incentive Payment System) performance tracking.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rvuWorkUnits rdf:type rdf:Property ;
    rdfs:label 'Rvu Work Units' ;
    rdfs:comment 'The physician work RVU (wRVU) value attributed to this provider for services rendered during this visit assignment. Sourced from CMS RBRVS fee schedule and used for provider productivity measurement and compensation calculations.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:telehealthFlag rdf:type rdf:Property ;
    rdfs:label 'Telehealth Flag' ;
    rdfs:comment 'Indicates whether the provider\'s participation in this visit was conducted via telehealth modality. Affects billing modifier requirements, place of service codes, and state telehealth licensure compliance.' ;
    rdfs:domain ind:VisitProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drgAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Drg Assignment Id' ;
    rdfs:comment 'Primary key for drg_assignment' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrgAssignment .

ind:principalVisitDiagnosisId rdf:type rdf:Property ;
    rdfs:label 'Principal Visit Diagnosis Id' ;
    rdfs:comment 'Foreign key linking to encounter.visit_diagnosis. Business justification: DRG assignment is fundamentally driven by the principal diagnosis. The drg_assignment table currently stores principal_diagnosis_code and principal_diagnosis_description as denormalized strings. Addin' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VisitDiagnosis .

ind:principalVisitProcedureId rdf:type rdf:Property ;
    rdfs:label 'Principal Visit Procedure Id' ;
    rdfs:comment 'Foreign key linking to encounter.visit_procedure. Business justification: DRG assignment for surgical DRGs is driven by the principal procedure. The drg_assignment table currently stores principal_procedure_code as a denormalized string. Adding principal_visit_procedure_id ' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VisitProcedure .

ind:actualLos rdf:type rdf:Property ;
    rdfs:label 'Actual Los' ;
    rdfs:comment 'The actual number of days the patient was hospitalized for this encounter, calculated from admission to discharge. Compared against geometric and arithmetic mean LOS for efficiency and outlier analysis.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:admitSourceCode rdf:type rdf:Property ;
    rdfs:label 'Admit Source Code' ;
    rdfs:comment 'The UB-04 admission source code indicating how the patient was admitted (e.g., 1=Physician Referral, 4=Transfer from Hospital, 7=Emergency Room). Influences DRG grouping logic for certain MDCs.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'Current status of any payer or RAC appeal related to this DRG assignment. Tracks the outcome of reimbursement disputes through the appeals process.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arithmeticMeanLos rdf:type rdf:Property ;
    rdfs:label 'Arithmetic Mean Los' ;
    rdfs:comment 'The arithmetic mean length of stay in days for the assigned DRG, published by CMS. Used alongside geometric mean LOS for outlier threshold determination and payer contract benchmarking.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basePaymentRate rdf:type rdf:Property ;
    rdfs:label 'Base Payment Rate' ;
    rdfs:comment 'The hospital-specific or payer-contracted base payment rate (in USD) applied to the DRG weight to calculate expected reimbursement. Reflects IPPS standardized amount or negotiated payer contract rate.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccMccFlag rdf:type rdf:Property ;
    rdfs:label 'Cc Mcc Flag' ;
    rdfs:comment 'Indicates whether the encounter qualifies for a Complication and Comorbidity (CC) or Major Complication and Comorbidity (MCC) designation, which elevates the DRG tier and associated reimbursement weight. Critical CDI target for revenue optimization.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdiQueryCount rdf:type rdf:Property ;
    rdfs:label 'Cdi Query Count' ;
    rdfs:comment 'The number of CDI queries issued to the attending physician for this encounter to clarify or improve clinical documentation supporting the DRG assignment. Key CDI productivity and impact metric.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdiQueryResponseFlag rdf:type rdf:Property ;
    rdfs:label 'Cdi Query Response Flag' ;
    rdfs:comment 'Indicates whether at least one CDI query for this encounter received a physician response that resulted in a documentation change affecting the DRG assignment. Measures CDI program effectiveness.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dischargeStatusCode rdf:type rdf:Property ;
    rdfs:label 'Discharge Status Code' ;
    rdfs:comment 'The UB-04 patient discharge status code (01–99) indicating the disposition of the patient at discharge (e.g., 01=Home, 02=SNF, 20=Expired). Affects DRG payment under post-acute care transfer rules.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drgChangedFlag rdf:type rdf:Property ;
    rdfs:label 'Drg Changed Flag' ;
    rdfs:comment 'Indicates whether the DRG code was changed from the initial working DRG to the final assigned DRG, typically as a result of CDI query responses or coding review. Tracks CDI program impact on reimbursement.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drgDescription rdf:type rdf:Property ;
    rdfs:label 'Drg Description' ;
    rdfs:comment 'Full text description of the assigned DRG code (e.g., \'SIMPLE PNEUMONIA AND PLEURISY W MCC\'). Used in clinical documentation improvement workflows and reimbursement reporting.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drgVersion rdf:type rdf:Property ;
    rdfs:label 'Drg Version' ;
    rdfs:comment 'The DRG classification system version used for grouping: MS-DRG (Medicare Severity), APR-DRG (All Patient Refined), or IR-DRG (International Refined). Determines the applicable reimbursement methodology and payer contract.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drgVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Drg Version Number' ;
    rdfs:comment 'The specific fiscal year or release version of the DRG grouper applied (e.g., \'v41\' for MS-DRG Version 41). Required for audit trails and reimbursement reconciliation across fiscal year transitions.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReimbursement rdf:type rdf:Property ;
    rdfs:label 'Expected Reimbursement' ;
    rdfs:comment 'The calculated expected reimbursement amount (in USD) derived from DRG weight multiplied by the base payment rate, before outlier adjustments. Used for revenue forecasting and variance analysis against actual payments.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Finalized Timestamp' ;
    rdfs:comment 'The date and time when the DRG assignment was finalized by the coding team, triggering claim submission eligibility. Key milestone in the revenue cycle management workflow.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:geometricMeanLos rdf:type rdf:Property ;
    rdfs:label 'Geometric Mean Los' ;
    rdfs:comment 'The geometric mean length of stay in days for the assigned DRG, published by CMS. Used as a benchmark for LOS efficiency analysis and outlier payment threshold calculations.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grouperSoftware rdf:type rdf:Property ;
    rdfs:label 'Grouper Software' ;
    rdfs:comment 'Name of the DRG grouper software used to assign the DRG (e.g., \'3M Grouper Plus\', \'OptumInsight Encoder\'). Required for audit trails and reimbursement dispute resolution.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grouperSoftwareVersion rdf:type rdf:Property ;
    rdfs:label 'Grouper Software Version' ;
    rdfs:comment 'The specific release version of the grouper software applied (e.g., \'3M Grouper Plus v32.1\'). Critical for audit compliance and reimbursement reconciliation when grouper logic changes between versions.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupingDate rdf:type rdf:Property ;
    rdfs:label 'Grouping Date' ;
    rdfs:comment 'The calendar date on which the DRG grouper software was executed and the DRG code was assigned. Used for tracking CDI workflow timelines and coding productivity.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initialDrgCode rdf:type rdf:Property ;
    rdfs:label 'Initial Drg Code' ;
    rdfs:comment 'The DRG code assigned at the initial working grouping (typically at admission or during the stay), before final coding and CDI review. Compared against the final DRG to measure CDI program impact and reimbursement uplift.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialDrgWeight rdf:type rdf:Property ;
    rdfs:label 'Initial Drg Weight' ;
    rdfs:comment 'The DRG relative weight associated with the initial working DRG code. Used to calculate the reimbursement uplift achieved through CDI and coding optimization.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOutlier rdf:type rdf:Property ;
    rdfs:label 'Is Outlier' ;
    rdfs:comment 'Indicates whether this encounter qualifies as a cost outlier under CMS IPPS policy, triggering additional outlier payment beyond the standard DRG payment. True when actual costs exceed the fixed-loss threshold.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mdcCode rdf:type rdf:Property ;
    rdfs:label 'Mdc Code' ;
    rdfs:comment 'The Major Diagnostic Category code (01–25 plus PRE for pre-MDC) that serves as the primary clinical grouping tier above the DRG. Derived from the principal diagnosis and used for service-line analytics and CMI benchmarking.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdcDescription rdf:type rdf:Property ;
    rdfs:label 'Mdc Description' ;
    rdfs:comment 'Full text description of the MDC (e.g., \'Diseases and Disorders of the Respiratory System\'). Supports service-line reporting and clinical program analytics.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outlierPayment rdf:type rdf:Property ;
    rdfs:label 'Outlier Payment' ;
    rdfs:comment 'Additional payment amount (in USD) approved for high-cost outlier cases where actual costs exceed the fixed-loss outlier threshold. Applicable under CMS IPPS cost outlier policy.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patientType rdf:type rdf:Property ;
    rdfs:label 'Patient Type' ;
    rdfs:comment 'Classifies the encounter type for DRG assignment purposes: inpatient (full admission), observation (outpatient observation status), or short_stay. Determines DRG applicability and reimbursement methodology.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureCount rdf:type rdf:Property ;
    rdfs:label 'Procedure Count' ;
    rdfs:comment 'The total number of ICD-10-PCS procedure codes submitted on the claim. Surgical procedures drive DRG assignment into surgical partitions, significantly affecting reimbursement weight.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:racReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Rac Review Flag' ;
    rdfs:comment 'Indicates whether this DRG assignment has been selected for review by a Recovery Audit Contractor (RAC) under the CMS RAC program. Triggers additional documentation retention and appeal workflow.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferCaseFlag rdf:type rdf:Property ;
    rdfs:label 'Transfer Case Flag' ;
    rdfs:comment 'Indicates whether this encounter is a transfer case subject to the post-acute care transfer (PACT) policy, which may reduce DRG payment when the patient is transferred to a post-acute care setting before the geometric mean LOS.' ;
    rdfs:domain ind:DrgAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visitDiagnosisId rdf:type rdf:Property ;
    rdfs:label 'Visit Diagnosis Id' ;
    rdfs:comment 'Unique surrogate identifier for each visit diagnosis record in the Silver layer lakehouse. Primary key for this encounter-level diagnosis entity. Role: TRANSACTION_LINE — this record is a line-level diagnosis attached to a parent encounter/visit header.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VisitDiagnosis .

ind:icdCodeId rdf:type rdf:Property ;
    rdfs:label 'Icd Code Id' ;
    rdfs:comment 'Foreign key linking to reference.icd_code. Business justification: Core clinical coding workflow—every diagnosis on a visit must reference the official ICD-10 code set for billing compliance, quality reporting, HCC risk adjustment, and clinical documentation integrit' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcdCode .

ind:snomedConceptId rdf:type rdf:Property ;
    rdfs:label 'Snomed Concept Id' ;
    rdfs:comment 'Foreign key linking to reference.snomed_concept. Business justification: Clinical terminology mapping—SNOMED codes on diagnoses must reference the official SNOMED CT concept for interoperability, clinical decision support, quality measure reporting, and data exchange with ' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SnomedConcept .

ind:billIndicator rdf:type rdf:Property ;
    rdfs:label 'Bill Indicator' ;
    rdfs:comment 'Indicates whether this diagnosis code is included on the claim submitted to the payer. True = included on the claim. Some diagnoses may be documented clinically but excluded from billing (e.g., working diagnoses, non-billable codes). Drives UB-04 and CMS-1500 claim form population.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccMccIndicator rdf:type rdf:Property ;
    rdfs:label 'Cc Mcc Indicator' ;
    rdfs:comment 'Classifies this diagnosis as a Complication/Comorbidity (CC), Major Complication/Comorbidity (MCC), Hospital-Acquired Condition (HAC), or none. Directly impacts MS-DRG assignment and inpatient reimbursement under IPPS. Sourced from 3M HIS grouper output and CMS CC/MCC exclusion lists.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chronicConditionFlag rdf:type rdf:Property ;
    rdfs:label 'Chronic Condition Flag' ;
    rdfs:comment 'Indicates whether this diagnosis represents a chronic condition as defined by CMS Chronic Condition Warehouse (CCW) or clinical classification standards. True = chronic condition. Supports population health management, care management program enrollment, HEDIS chronic disease measure attribution, and SDOH analysis.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codedDate rdf:type rdf:Property ;
    rdfs:label 'Coded Date' ;
    rdfs:comment 'The date on which the ICD-10-CM code was assigned to this diagnosis by the HIM coding team. Used for coding productivity tracking, CDI program metrics, and revenue cycle timeliness reporting. Sourced from 3M HIS and Epic Resolute coding workflows.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:codingProviderNpi rdf:type rdf:Property ;
    rdfs:label 'Coding Provider Npi' ;
    rdfs:comment 'The 10-digit National Provider Identifier (NPI) of the clinician or coder who assigned or attested this diagnosis code. Used for audit trails, CDI accountability, RAC audit defense, and provider-level coding quality reporting. Sourced from 3M HIS and Epic ClinDoc coding workflows.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codingStatus rdf:type rdf:Property ;
    rdfs:label 'Coding Status' ;
    rdfs:comment 'Current workflow status of this diagnosis record within the HIM/CDI coding lifecycle. \'pending\' indicates awaiting coder review; \'coded\' indicates initial code assignment; \'validated\' indicates coder-confirmed; \'queried\' indicates a CDI query has been issued; \'amended\' indicates a post-bill correction; \'final\' indicates billing-ready. Drives revenue cycle workflow and CDI query management in 3M HIS and Epic Resolute.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisRank rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Rank' ;
    rdfs:comment 'Clinical ranking of this diagnosis by severity or clinical significance within the encounter, as assigned by the coding team or clinical documentation system. Distinct from diagnosis_seq_num (billing sequence); this rank reflects clinical priority for care management and quality reporting purposes.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:diagnosisSeqNum rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Seq Num' ;
    rdfs:comment 'Ordinal position of this diagnosis within the encounter\'s diagnosis list. Sequence 1 typically denotes the principal diagnosis. Used for claim form ordering (UB-04 diagnosis fields), DRG grouping logic, and quality measure attribution. Aligns with LINE_SEQUENCE canonical category.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:diagnosisSource rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Source' ;
    rdfs:comment 'Identifies who or what originated this diagnosis record. \'physician\' = entered by the treating clinician; \'coder\' = assigned by HIM coding staff; \'cdi_specialist\' = added via CDI query resolution; \'system\' = auto-populated by clinical decision support; \'imported\' = received via HIE or external system. Supports audit trail and coding accountability.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisType rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Type' ;
    rdfs:comment 'Classification of the diagnosis role within the encounter. \'admitting\' is the reason for admission; \'principal\' is the condition chiefly responsible for the stay after study; \'secondary\' are comorbidities and complications; \'discharge\' is the final coded diagnosis at discharge; \'working\' is a provisional diagnosis during the encounter; \'final\' is the confirmed diagnosis post-workup. Drives DRG assignment and UB-04/CMS-1500 claim form population.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drgCode rdf:type rdf:Property ;
    rdfs:label 'Drg Code' ;
    rdfs:comment 'The MS-DRG or APR-DRG code assigned to the encounter as influenced by this diagnosis. Populated after DRG grouping by 3M HIS or CMS grouper. Central to inpatient reimbursement under IPPS and case mix index (CMI) calculation.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drgRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Drg Relevance Flag' ;
    rdfs:comment 'Indicates whether this diagnosis code contributes to the DRG assignment for this encounter. True = this diagnosis is a complication/comorbidity (CC) or major complication/comorbidity (MCC) that affects DRG grouping and reimbursement. Critical for revenue cycle optimization and CDI program targeting.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encounterDiagnosisComment rdf:type rdf:Property ;
    rdfs:label 'Encounter Diagnosis Comment' ;
    rdfs:comment 'Free-text clinical comment or qualifier associated with this diagnosis record, as entered by the coding team or clinician. May include specificity notes, CDI query resolution rationale, or coding clarifications. Classified as restricted PHI per HIPAA.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encounterDiagnosisSourceCode rdf:type rdf:Property ;
    rdfs:label 'Encounter Diagnosis Source Code' ;
    rdfs:comment 'The native identifier for this diagnosis record in the source operational system (e.g., Epic ClinDoc diagnosis ID or Cerner PowerChart diagnosis ID). Supports ETL lineage, data reconciliation, and source system audit trails in the Silver layer.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCauseCode rdf:type rdf:Property ;
    rdfs:label 'External Cause Code' ;
    rdfs:comment 'ICD-10-CM external cause code (V, W, X, Y codes) documenting the cause, place of occurrence, activity, and status for injury and poisoning diagnoses. Required for trauma registries, injury surveillance, workers\' compensation claims, and public health reporting.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haiFlag rdf:type rdf:Property ;
    rdfs:label 'Hai Flag' ;
    rdfs:comment 'Indicates whether this diagnosis represents a healthcare-associated infection (HAI) such as CLABSI, CAUTI, or SSI. True = HAI diagnosis. Triggers HAI surveillance workflows, CMS HAC Reduction Program payment adjustments, and TJC infection control reporting.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hccCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Hcc Category Code' ;
    rdfs:comment 'The specific CMS HCC category code to which this ICD-10-CM diagnosis maps. Populated only when hcc_flag is True. Used for risk score calculation in Medicare Advantage, ACO, and MIPS/APM programs. Sourced from CMS HCC mapping crosswalk tables.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hccFlag rdf:type rdf:Property ;
    rdfs:label 'Hcc Flag' ;
    rdfs:comment 'Indicates whether this ICD-10-CM diagnosis code maps to a CMS Hierarchical Condition Category (HCC) used for risk adjustment in Medicare Advantage and ACO programs. True = this diagnosis contributes to the patient\'s HCC risk score. Critical for population health management, value-based care contracting, and capitation payment accuracy.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icd10Code rdf:type rdf:Property ;
    rdfs:label 'Icd10 Code' ;
    rdfs:comment 'The ICD-10-CM diagnosis code assigned to this visit. Drives DRG grouping, quality measure attribution, risk adjustment (HCC mapping), and medical billing. Sourced from Epic ClinDoc and validated through 3M HIS coding workflows. Conforms to WHO ICD-10-CM code format.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icd10Description rdf:type rdf:Property ;
    rdfs:label 'Icd10 Description' ;
    rdfs:comment 'Full clinical description of the ICD-10-CM diagnosis code as defined by the WHO/CMS code set. Provides human-readable context for the coded diagnosis. Used in clinical documentation, reporting, and CDI workflows.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icd10Version rdf:type rdf:Property ;
    rdfs:label 'Icd10 Version' ;
    rdfs:comment 'The fiscal year version of the ICD-10-CM code set used to assign this diagnosis code (e.g., FY2024). ICD-10-CM is updated annually by CMS/CDC. Ensures accurate code interpretation across fiscal year transitions and supports historical data analysis.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mentalHealthFlag rdf:type rdf:Property ;
    rdfs:label 'Mental Health Flag' ;
    rdfs:comment 'Indicates whether this diagnosis is classified as a mental health or behavioral health condition per ICD-10-CM Chapter 5 (F-codes). True = mental/behavioral health diagnosis. Supports behavioral health program management, parity compliance reporting, and population health segmentation.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onsetDate rdf:type rdf:Property ;
    rdfs:label 'Onset Date' ;
    rdfs:comment 'The date on which the diagnosed condition first manifested or was first identified, as documented in the clinical record. Supports longitudinal disease tracking, chronic condition management, POA determination, and population health analytics. Aligns with BUSINESS_EVENT_TIMESTAMP canonical category.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poaIndicator rdf:type rdf:Property ;
    rdfs:label 'Poa Indicator' ;
    rdfs:comment 'Indicates whether the diagnosis condition was present at the time of inpatient admission. Values: Y=Yes (present on admission), N=No (not present on admission), U=Unknown, W=Clinically undetermined, 1=Exempt from POA reporting. Required by CMS for inpatient claims on UB-04. Impacts HAI reporting, VBP penalties, and hospital-acquired condition (HAC) payment adjustments.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDiagnosisFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Diagnosis Flag' ;
    rdfs:comment 'Indicates whether this diagnosis is designated as the primary/principal diagnosis for the encounter. True = primary diagnosis. Provides a quick boolean filter for analytics and reporting without requiring sequence number logic. Complements diagnosis_seq_num and diagnosis_type.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityMeasureFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Measure Flag' ;
    rdfs:comment 'Indicates whether this diagnosis contributes to one or more quality measure denominators or numerators (e.g., HEDIS, MIPS, VBP, TJC core measures). True = this diagnosis is relevant to at least one active quality measure. Supports quality reporting, MIPS scoring, and VBP program management.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportableConditionFlag rdf:type rdf:Property ;
    rdfs:label 'Reportable Condition Flag' ;
    rdfs:comment 'Indicates whether this diagnosis is a notifiable/reportable condition requiring mandatory reporting to public health authorities (e.g., state health departments, CDC). True = reportable. Supports public health surveillance, regulatory compliance, and HIE reporting obligations.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolvedDate rdf:type rdf:Property ;
    rdfs:label 'Resolved Date' ;
    rdfs:comment 'The date on which the diagnosed condition was resolved, abated, or no longer active, as documented in the clinical record. Null if the condition is ongoing. Used for chronic disease management, care plan updates, and longitudinal patient health tracking.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:snomedCode rdf:type rdf:Property ;
    rdfs:label 'Snomed Code' ;
    rdfs:comment 'The SNOMED CT concept identifier mapped to this ICD-10-CM diagnosis code. Supports clinical interoperability, HL7 FHIR-based HIE data exchange, and clinical decision support. Populated via ICD-10 to SNOMED CT crosswalk. Used in FHIR Condition resources for interoperability.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceUseFlag rdf:type rdf:Property ;
    rdfs:label 'Substance Use Flag' ;
    rdfs:comment 'Indicates whether this diagnosis represents a substance use disorder (SUD) per ICD-10-CM codes. True = substance use disorder diagnosis. Supports SUD program management, 42 CFR Part 2 confidentiality compliance, and population health analytics.' ;
    rdfs:domain ind:VisitDiagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visitProcedureId rdf:type rdf:Property ;
    rdfs:label 'Visit Procedure Id' ;
    rdfs:comment 'Unique surrogate identifier for each procedure record performed during a patient visit. Primary key for the visit_procedure data product in the encounter domain.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VisitProcedure .

ind:clinicalProcedureEventId rdf:type rdf:Property ;
    rdfs:label 'Clinical Procedure Event Id' ;
    rdfs:comment 'Foreign key linking to clinical.procedure_event. Business justification: Charge capture reconciliation requires linking the billed procedure (visit_procedure) to the clinical procedure documentation (procedure_event). Surgical quality reporting, CDI, and charge integrity a' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcedureEvent .

ind:cptCodeId rdf:type rdf:Property ;
    rdfs:label 'Cpt Code Id' ;
    rdfs:comment 'Foreign key linking to reference.cpt_code. Business justification: Essential procedure coding workflow—every CPT code on a visit procedure must validate against the official CPT reference for claims submission, reimbursement calculation, RVU assignment, and NCCI edit' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CptCode .

ind:feeScheduleLineId rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Line Id' ;
    rdfs:comment 'Foreign key linking to insurance.fee_schedule_line. Business justification: Revenue cycle charge capture: each procedure\'s expected reimbursement is calculated against a specific fee schedule line (CPT/HCPCS + payer contract rate). Healthcare revenue cycle teams require this ' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeeScheduleLine .

ind:hcpcsCodeId rdf:type rdf:Property ;
    rdfs:label 'Hcpcs Code Id' ;
    rdfs:comment 'Foreign key linking to reference.hcpcs_code. Business justification: Required for HCPCS procedure coding—DME, supplies, drugs, and non-physician services must reference official HCPCS codes for billing, coverage determination, and reimbursement. Critical for outpatient' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HcpcsCode .

ind:privilegingId rdf:type rdf:Property ;
    rdfs:label 'Privileging Id' ;
    rdfs:comment 'Foreign key linking to provider.privileging. Business justification: Enables retrospective verification that performing clinician held valid privileges for the specific procedure at the facility on the procedure date. Required for peer review, quality assurance audits,' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Privileging .

ind:anesthesiaType rdf:type rdf:Property ;
    rdfs:label 'Anesthesia Type' ;
    rdfs:comment 'Type of anesthesia administered during the procedure. Drives anesthesia CPT code selection, anesthesia time unit billing, ASA physical status documentation, and OR case complexity classification.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asaClass rdf:type rdf:Property ;
    rdfs:label 'Asa Class' ;
    rdfs:comment 'ASA physical status classification assigned by the anesthesiologist prior to the procedure, reflecting the patient\'s overall health status. Used for anesthesia risk stratification, surgical case complexity scoring, and outcomes risk adjustment.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodySite rdf:type rdf:Property ;
    rdfs:label 'Body Site' ;
    rdfs:comment 'Anatomical location or body site where the procedure was performed, coded using SNOMED CT body structure concepts. Supports surgical safety documentation, quality measure stratification, and clinical analytics.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Reason code or description explaining why a scheduled procedure was cancelled (e.g., patient not ready, equipment unavailable, surgeon unavailable, insurance denial). Populated only when is_cancelled is true. Supports root cause analysis and OR efficiency improvement.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeAmount rdf:type rdf:Property ;
    rdfs:label 'Charge Amount' ;
    rdfs:comment 'Gross charge amount posted to the patient account for this procedure based on the CDM. Represents the billed amount before contractual adjustments, payer discounts, or patient responsibility. Used in revenue cycle management and financial reporting.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeCode rdf:type rdf:Property ;
    rdfs:label 'Charge Code' ;
    rdfs:comment 'Internal charge code from the Charge Description Master (CDM) mapped to this procedure. Links the clinical procedure to the revenue cycle for charge capture, pricing, and claim generation in Epic Resolute or Cerner Revenue Cycle.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complicationDescription rdf:type rdf:Property ;
    rdfs:label 'Complication Description' ;
    rdfs:comment 'Free-text or coded description of the complication that occurred during or after the procedure. Populated only when complication_flag is true. Used for clinical documentation, quality review, and risk management reporting.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complicationFlag rdf:type rdf:Property ;
    rdfs:label 'Complication Flag' ;
    rdfs:comment 'Indicates whether a complication was documented as occurring during or immediately following the procedure. Triggers CDI query workflow, quality event review, and HAI/PSI surveillance reporting.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cptCode rdf:type rdf:Property ;
    rdfs:label 'Cpt Code' ;
    rdfs:comment 'AMA CPT code identifying the procedure for professional billing, charge capture, and payer adjudication. Required on CMS-1500 claims. Drives RVU calculation and reimbursement.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cptModifier1 rdf:type rdf:Property ;
    rdfs:label 'Cpt Modifier 1' ;
    rdfs:comment 'Primary CPT modifier appended to the procedure code to indicate special circumstances (e.g., 50=bilateral, LT=left side, RT=right side, 22=increased procedural services, 59=distinct procedural service). Required for accurate claim adjudication.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cptModifier2 rdf:type rdf:Property ;
    rdfs:label 'Cpt Modifier 2' ;
    rdfs:comment 'Secondary CPT modifier providing additional claim specificity when a single modifier is insufficient. Used in conjunction with cpt_modifier_1 for complex billing scenarios per CMS Correct Coding Initiative.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drgRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Drg Relevant Flag' ;
    rdfs:comment 'Indicates whether this procedure influences the DRG assignment for the inpatient encounter. Flagged by the 3M grouper or equivalent DRG grouping engine. Critical for inpatient revenue integrity and CDI prioritization.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hcpcsCode rdf:type rdf:Property ;
    rdfs:label 'Hcpcs Code' ;
    rdfs:comment 'HCPCS Level II code used when a CPT code is not applicable, primarily for supplies, durable medical equipment, and non-physician services billed to Medicare/Medicaid. Complements CPT on UB-04 and CMS-1500 claims.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icd10PcsCode rdf:type rdf:Property ;
    rdfs:label 'Icd10 Pcs Code' ;
    rdfs:comment 'ICD-10-PCS code assigned for inpatient procedures. Required for inpatient DRG grouping, UB-04 institutional claims, and CMS inpatient prospective payment system (IPPS) reimbursement. Not applicable for outpatient encounters.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implantFlag rdf:type rdf:Property ;
    rdfs:label 'Implant Flag' ;
    rdfs:comment 'Indicates whether a medical device or implant was used during the procedure. Triggers UDI (Unique Device Identifier) documentation requirements per FDA regulations and supply chain charge capture workflows.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCancelled rdf:type rdf:Property ;
    rdfs:label 'Is Cancelled' ;
    rdfs:comment 'Indicates whether a scheduled procedure was cancelled before execution. Used for OR cancellation rate reporting, scheduling efficiency analysis, and revenue impact assessment.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isElective rdf:type rdf:Property ;
    rdfs:label 'Is Elective' ;
    rdfs:comment 'Indicates whether the procedure was scheduled as elective (non-urgent) versus emergent or urgent. Supports surgical scheduling analytics, OR block time management, and payer prior authorization workflows.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrincipalProcedure rdf:type rdf:Property ;
    rdfs:label 'Is Principal Procedure' ;
    rdfs:comment 'Indicates whether this is the principal procedure performed for the encounter, as defined by the Uniform Hospital Discharge Data Set (UHDDS). The principal procedure is the one most closely related to the principal diagnosis and drives DRG assignment for inpatient cases.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laterality rdf:type rdf:Property ;
    rdfs:label 'Laterality' ;
    rdfs:comment 'Body side on which the procedure was performed. Required for correct CPT modifier assignment (RT/LT/50), surgical safety checklists, and wrong-site surgery prevention per The Joint Commission Universal Protocol.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performingProviderNpi rdf:type rdf:Property ;
    rdfs:label 'Performing Provider Npi' ;
    rdfs:comment '10-digit NPI of the performing provider as required on CMS-1500 and UB-04 claims. Stored denormalized here for claim generation and audit purposes, as the NPI is a regulatory billing requirement independent of the provider master record.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureDate rdf:type rdf:Property ;
    rdfs:label 'Procedure Date' ;
    rdfs:comment 'Calendar date on which the procedure was performed. Used for charge capture date-of-service, quality measure denominator identification, and surgical case scheduling analytics.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:procedureDescription rdf:type rdf:Property ;
    rdfs:label 'Procedure Description' ;
    rdfs:comment 'Full clinical description of the procedure as documented in the source system (Epic ClinDoc, OpTime, or Cerner SurgiNet). Provides human-readable context for the CPT/HCPCS/ICD-10-PCS code.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Procedure End Timestamp' ;
    rdfs:comment 'Date and time when the procedure was completed (closure for surgical cases, or final clinical action for non-surgical). Combined with start timestamp to derive procedure duration for OR utilization and case costing.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:procedureNumber rdf:type rdf:Property ;
    rdfs:label 'Procedure Number' ;
    rdfs:comment 'Externally visible, human-readable identifier assigned to this procedure record within the source system (e.g., Epic OpTime case number or Cerner SurgiNet procedure order number). Used for cross-system reconciliation and audit.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Procedure Start Timestamp' ;
    rdfs:comment 'Date and time when the procedure began (knife-to-skin for surgical cases, or first clinical action for non-surgical). Used for OR utilization analysis, case duration calculation, and scheduling efficiency reporting.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:procedureStatus rdf:type rdf:Property ;
    rdfs:label 'Procedure Status' ;
    rdfs:comment 'Current workflow status of the procedure record per HL7 FHIR Procedure.status value set. Drives charge capture eligibility, quality measure inclusion/exclusion, and CDI workflow routing.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureType rdf:type rdf:Property ;
    rdfs:label 'Procedure Type' ;
    rdfs:comment 'High-level classification of the procedure category. Supports operational reporting, OR scheduling, charge master (CDM) mapping, and departmental cost allocation. [ENUM-REF-CANDIDATE: surgical|diagnostic|therapeutic|anesthesia|radiology|laboratory|nursing|other — promote to reference product]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Number of times this procedure was performed or units billed within the encounter. Used for charge capture accuracy, claim line quantity reporting, and utilization analysis.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rvuTotal rdf:type rdf:Property ;
    rdfs:label 'Rvu Total' ;
    rdfs:comment 'Total RVU for the procedure, comprising work RVU, practice expense RVU, and malpractice RVU components per the CMS Physician Fee Schedule. Used for overall provider productivity benchmarking and reimbursement modeling.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rvuWork rdf:type rdf:Property ;
    rdfs:label 'Rvu Work' ;
    rdfs:comment 'Physician work RVU assigned to this procedure per the CMS Physician Fee Schedule. Represents the time, skill, and intensity of the physician\'s work. Used for provider productivity measurement, compensation modeling, and MIPS performance reporting.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Source System Procedure Code' ;
    rdfs:comment 'Native identifier of this procedure record in the originating source system (e.g., Epic OpTime case ID, Cerner SurgiNet order ID). Enables bidirectional traceability between the lakehouse silver layer and the operational EHR system.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surgicalApproach rdf:type rdf:Property ;
    rdfs:label 'Surgical Approach' ;
    rdfs:comment 'Method or technique used to access the operative site. Drives ICD-10-PCS character 5 (approach) coding, surgical case complexity classification, and outcomes benchmarking.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeoutPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Timeout Performed Flag' ;
    rdfs:comment 'Indicates whether the pre-procedure surgical time-out (Universal Protocol) was performed and documented, confirming correct patient, site, and procedure. Required by The Joint Commission Universal Protocol for preventing wrong-site surgery.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:udi rdf:type rdf:Property ;
    rdfs:label 'Udi' ;
    rdfs:comment 'FDA-assigned Unique Device Identifier for any medical device or implant used during the procedure. Required for FDA MDR (Medical Device Reporting), recall management, and supply chain traceability. Populated only when implant_flag is true.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:woundClass rdf:type rdf:Property ;
    rdfs:label 'Wound Class' ;
    rdfs:comment 'CDC wound classification assigned at the time of surgery, indicating the degree of microbial contamination. Used for SSI (Surgical Site Infection) risk stratification, HAI surveillance, and quality reporting to NHSN.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bedAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Bed Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each bed assignment record in the lakehouse Silver layer. Primary key for the bed_assignment data product.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openSlotId rdf:type rdf:Property ;
    rdfs:label 'Open Slot Id' ;
    rdfs:comment 'Foreign key linking to scheduling.open_slot. Business justification: Elective and pre-scheduled admissions are driven by a booked open slot; linking bed_assignment to the originating open_slot enables bed management capacity planning, request-to-assignment time analyti' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OpenSlot .

ind:admissionDate rdf:type rdf:Property ;
    rdfs:label 'Admission Date' ;
    rdfs:comment 'Calendar date of the patient\'s hospital admission associated with this bed assignment. Used for LOS (Length of Stay) calculation, DRG (Diagnosis-Related Group) assignment, and CMS reporting.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Externally visible, human-readable identifier for this bed assignment event as generated by the ADT (Admit, Discharge, Transfer) system. Used for operational tracking and audit trails.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'Clinical or operational reason for this specific bed assignment event. \'admission\' = initial placement upon admission; \'transfer\' = moved from another bed/unit; \'upgrade\' = moved to higher acuity bed; \'downgrade\' = moved to lower acuity bed; \'isolation_precaution\' = placed for infection control; \'overflow\' = placed due to capacity constraints; \'elective\' = planned placement. [ENUM-REF-CANDIDATE: admission|transfer|upgrade|downgrade|isolation_precaution|overflow|elective|post_procedure|observation_conversion — promote to reference product]' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bedClass rdf:type rdf:Property ;
    rdfs:label 'Bed Class' ;
    rdfs:comment 'Regulatory classification of the bed for CMS (Centers for Medicare and Medicaid Services) reporting and reimbursement purposes. Determines whether the bed counts toward licensed inpatient capacity or outpatient/observation capacity. [ENUM-REF-CANDIDATE: inpatient|outpatient|observation|emergency|behavioral_health|rehabilitation|long_term_care|skilled_nursing — promote to reference product]' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bedGenderDesignation rdf:type rdf:Property ;
    rdfs:label 'Bed Gender Designation' ;
    rdfs:comment 'Gender designation of the bed for patient placement purposes. \'male\' = designated for male patients; \'female\' = designated for female patients; \'any\' = no gender restriction. Used for bed placement rules and patient privacy compliance.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bedHoldReason rdf:type rdf:Property ;
    rdfs:label 'Bed Hold Reason' ;
    rdfs:comment 'Reason the bed is being held for a patient who is temporarily off the unit (e.g., for a procedure, imaging, or therapy). \'none\' indicates no hold is in effect. Used for bed availability accuracy and capacity management.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bedLabel rdf:type rdf:Property ;
    rdfs:label 'Bed Label' ;
    rdfs:comment 'Human-readable label or name of the bed as displayed in the ADT system (e.g., \'4B-12A\'). Used by nursing staff and bed coordinators for operational identification.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bedRequestSource rdf:type rdf:Property ;
    rdfs:label 'Bed Request Source' ;
    rdfs:comment 'Origin point from which the bed request was initiated. \'ed\' = Emergency Department; \'or\' = Operating Room post-procedure; \'icu\' = ICU step-down; \'direct_admit\' = direct admission from clinic or physician office; \'transfer_center\' = inter-facility transfer; \'observation\' = conversion from observation status; \'pacu\' = Post-Anesthesia Care Unit. Used for bed flow analysis and throughput optimization. [ENUM-REF-CANDIDATE: ed|or|icu|direct_admit|transfer_center|observation|pacu — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bedType rdf:type rdf:Property ;
    rdfs:label 'Bed Type' ;
    rdfs:comment 'Clinical classification of the bed based on care intensity and equipment capability. \'icu\' = Intensive Care Unit bed; \'telemetry\' = cardiac monitoring bed; \'med_surg\' = medical-surgical bed; \'isolation\' = negative pressure or contact precaution bed; \'observation\' = short-stay observation bed; \'step_down\' = intermediate care bed. Drives staffing ratios, reimbursement, and HAI (Healthcare-Associated Infection) tracking.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeDate rdf:type rdf:Property ;
    rdfs:label 'Discharge Date' ;
    rdfs:comment 'Calendar date of the patient\'s discharge from the facility associated with this bed assignment. Null if the patient is still admitted. Used for ALOS (Average Length of Stay) reporting and DRG (Diagnosis-Related Group) reimbursement.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedDischargeDate rdf:type rdf:Property ;
    rdfs:label 'Expected Discharge Date' ;
    rdfs:comment 'Clinician-estimated date of patient discharge from this bed assignment. Used for discharge planning, bed availability forecasting, and ALOS (Average Length of Stay) management. Sourced from Epic Discharge Planning or Cerner Millennium care management workflows.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:floorNumber rdf:type rdf:Property ;
    rdfs:label 'Floor Number' ;
    rdfs:comment 'Physical floor or level of the facility building where the bed is located. Used for facility management, emergency evacuation planning, and environmental services routing.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:housekeepingStatusAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Housekeeping Status At Assignment' ;
    rdfs:comment 'Environmental services (EVS) status of the bed at the moment of patient assignment. \'clean\' = bed was verified clean and ready; \'dirty\' = bed had not yet been cleaned (emergency placement); \'in_progress\' = cleaning was underway; \'inspected\' = cleaning completed and inspected; \'out_of_service\' = bed was flagged as unavailable. Critical for HAI (Healthcare-Associated Infection) prevention audits and EVS performance measurement.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIsolationBed rdf:type rdf:Property ;
    rdfs:label 'Is Isolation Bed' ;
    rdfs:comment 'Indicates whether this bed is designated as a negative pressure or isolation room capable of supporting infection control precautions. True = isolation-capable bed; False = standard bed. Used for capacity planning of isolation-capable beds and HAI (Healthcare-Associated Infection) compliance reporting.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isObservationStatus rdf:type rdf:Property ;
    rdfs:label 'Is Observation Status' ;
    rdfs:comment 'Indicates whether the patient is under CMS observation status (rather than formal inpatient admission) during this bed assignment. True = observation status; False = inpatient or other status. Critical for CMS Two-Midnight Rule compliance, Medicare Part A vs. Part B billing, and patient financial counseling obligations under the NOTICE Act.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrivateRoom rdf:type rdf:Property ;
    rdfs:label 'Is Private Room' ;
    rdfs:comment 'Indicates whether the bed is located in a private single-occupancy room. True = private room; False = semi-private or multi-bed room. Relevant for infection control, patient satisfaction (CAHPS), and revenue for private room upgrades.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTelemetryMonitored rdf:type rdf:Property ;
    rdfs:label 'Is Telemetry Monitored' ;
    rdfs:comment 'Indicates whether the patient in this bed assignment is connected to continuous cardiac telemetry monitoring. True = telemetry active; False = no telemetry. Used for telemetry capacity management and nursing workload planning.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:losDays rdf:type rdf:Property ;
    rdfs:label 'Los Days' ;
    rdfs:comment 'Number of days the patient occupied this specific bed assignment, calculated as the difference between assignment end and start timestamps expressed in fractional days. Supports ALOS (Average Length of Stay) benchmarking, CMI (Case Mix Index) analysis, and capacity planning. Note: this is bed-level LOS, not encounter-level LOS.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nursingStationCode rdf:type rdf:Property ;
    rdfs:label 'Nursing Station Code' ;
    rdfs:comment 'Code identifying the nursing station responsible for this bed. Used for nursing assignment, medication administration routing (MAR), and staffing ratio compliance reporting.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Date and time when the bed request was initiated by the clinical team or bed coordinator. Used to calculate bed request-to-assignment elapsed time, a key operational KPI (Key Performance Indicator) for bed management efficiency.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestToAssignmentMinutes rdf:type rdf:Property ;
    rdfs:label 'Request To Assignment Minutes' ;
    rdfs:comment 'Elapsed time in minutes between the bed request timestamp and the assignment start timestamp. Key operational KPI (Key Performance Indicator) for bed management throughput and ED (Emergency Department) boarding reduction. Sourced from Epic ADT or Cerner Bed Board workflow timestamps.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomNumber rdf:type rdf:Property ;
    rdfs:label 'Room Number' ;
    rdfs:comment 'Room number within the unit or ward where the bed is located. Used for wayfinding, nursing assignments, and infection control zone tracking.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'Sequential ordinal number of this bed assignment within the patient\'s encounter, starting at 1 for the first bed assignment. Used to reconstruct the patient\'s bed movement history throughout a visit and calculate total number of transfers.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemAssignmentCode rdf:type rdf:Property ;
    rdfs:label 'Source System Assignment Code' ;
    rdfs:comment 'Native identifier of this bed assignment record in the originating operational system (Epic ADT, Cerner Millennium, or MEDITECH Expanse). Used for cross-system reconciliation, data lineage tracing, and support of HIE (Health Information Exchange) integrations.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Standardized alphanumeric code identifying the clinical unit or ward in the facility\'s master data. Used for cross-system reporting and integration with billing and staffing systems.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Name of the clinical unit or ward where the bed is located (e.g., \'Medical ICU\', \'4 North Med-Surg\', \'ED Observation\'). Used for unit-level capacity planning and staffing analytics.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wingOrPod rdf:type rdf:Property ;
    rdfs:label 'Wing Or Pod' ;
    rdfs:comment 'Sub-unit designation within a nursing unit identifying the wing, pod, or cluster where the bed is located (e.g., \'North Wing\', \'Pod A\'). Used for nursing assignment optimization and infection control zone management.' ;
    rdfs:domain ind:BedAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitInsuranceId rdf:type rdf:Property ;
    rdfs:label 'Visit Insurance Id' ;
    rdfs:comment 'Unique surrogate identifier for the visit insurance record. Primary key for the visit_insurance data product within the encounter domain.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VisitInsurance .

ind:authorizationId rdf:type rdf:Property ;
    rdfs:label 'Authorization Id' ;
    rdfs:comment 'Foreign key linking to encounter.encounter_authorization. Business justification: Visit insurance records carry authorization details (authorization_number, authorization_status, authorization_effective_date, authorization_expiration_date) that are fully owned by the encounter_auth' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Authorization .

ind:primaryVisitMemberMpiRecordId rdf:type rdf:Property ;
    rdfs:label 'Primary Visit Member Mpi Record Id' ;
    rdfs:comment 'Unique member identification number assigned by the payer to identify the insured individual on the insurance card and in payer systems. Required for eligibility verification and claims submission.' ;
    rdfs:domain ind:VisitInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MpiRecord .

ind:billingNpi rdf:type rdf:Property ;
    rdfs:label 'Billing Npi' ;
    rdfs:comment 'National Provider Identifier (NPI) of the billing provider or organization submitted to the payer for this visit. Required on CMS-1500 and UB-04 claim forms.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimFormType rdf:type rdf:Property ;
    rdfs:label 'Claim Form Type' ;
    rdfs:comment 'Type of claim form used to bill the payer for this visit. CMS_1500 = professional/physician claims; UB_04 = institutional/facility claims; ELECTRONIC_837P = electronic professional claim; ELECTRONIC_837I = electronic institutional claim.' ;
    rdfs:domain ind:VisitInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobNotes rdf:type rdf:Property ;
    rdfs:label 'Cob Notes' ;
    rdfs:comment 'Free-text notes related to coordination of benefits (COB) for this visit, capturing special instructions, payer-specific COB rules, or manual overrides documented by revenue cycle staff.' ;
    rdfs:domain ind:VisitInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Effective Date' ;
    rdfs:comment 'Date on which the patient\'s insurance coverage under this plan became effective. Used to confirm coverage was active at the time of the visit.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageSequence rdf:type rdf:Property ;
    rdfs:label 'Coverage Sequence' ;
    rdfs:comment 'Coordination of Benefits (COB) sequence number indicating the order in which payers are billed. 1 = primary, 2 = secondary, 3 = tertiary. Governs payer billing priority per COB rules.' ;
    rdfs:domain ind:VisitInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Termination Date' ;
    rdfs:comment 'Date on which the patient\'s insurance coverage under this plan ends or was terminated. Null if coverage is open-ended or still active. Used to validate coverage at time of service.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Status' ;
    rdfs:comment 'Current status of the insurance eligibility verification for this visit. Indicates whether the patient\'s coverage has been confirmed active with the payer at the time of service.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verified Date' ;
    rdfs:comment 'Date on which the patient\'s insurance eligibility was last verified with the payer for this visit. Used to confirm coverage was active at the time of service.' ;
    rdfs:domain ind:VisitInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceTypeCode rdf:type rdf:Property ;
    rdfs:label 'Insurance Type Code' ;
    rdfs:comment 'Standardized payer-assigned or industry-standard code identifying the type of insurance (e.g., Medicare Part A, Medicare Part B, Medicaid, CHAMPUS/TRICARE, FECA Black Lung, Group Health Plan). Corresponds to Box 1 on CMS-1500.' ;
    rdfs:domain ind:VisitInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceVerificationSource rdf:type rdf:Property ;
    rdfs:label 'Insurance Verification Source' ;
    rdfs:comment 'Source system or clearinghouse used to perform the insurance eligibility verification for this visit. Supports audit trail and troubleshooting of eligibility discrepancies.' ;
    rdfs:domain ind:VisitInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerPhone rdf:type rdf:Property ;
    rdfs:label 'Payer Phone' ;
    rdfs:comment 'Primary contact phone number for the insurance payer\'s provider services or claims department. Used by revenue cycle staff for eligibility verification and claims follow-up.' ;
    rdfs:domain ind:VisitInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preauthRequired rdf:type rdf:Property ;
    rdfs:label 'Preauth Required' ;
    rdfs:comment 'Indicates whether the payer requires prior authorization for the services rendered during this visit. True = pre-authorization is required; False = no pre-authorization needed.' ;
    rdfs:domain ind:VisitInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralNumber rdf:type rdf:Property ;
    rdfs:label 'Referral Number' ;
    rdfs:comment 'Referral authorization number issued by the patient\'s Primary Care Physician (PCP) or gatekeeper for HMO/POS plans requiring referrals for specialist or facility services during this visit.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementMethod rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Method' ;
    rdfs:comment 'Expected payment methodology under which the payer will reimburse the provider for this visit. FFS = Fee-For-Service; CAPITATION = per-member per-month; BUNDLED = bundled payment; VBP = Value-Based Purchasing; DRG = Diagnosis-Related Group; PER_DIEM = daily rate.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberDob rdf:type rdf:Property ;
    rdfs:label 'Subscriber Dob' ;
    rdfs:comment 'Date of birth of the primary policyholder (subscriber). Used for eligibility verification and claims adjudication when the patient is a dependent.' ;
    rdfs:domain ind:VisitInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indicationSnomedConceptId rdf:type rdf:Property ;
    rdfs:label 'Indication Snomed Concept Id' ;
    rdfs:comment 'Foreign key linking to reference.snomed_concept. Business justification: Prior authorization submissions to payers require standardized clinical indication coding. SNOMED CT is the standard for clinical indication in FHIR CoverageEligibilityRequest and X12 278 transactions' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SnomedConcept .

ind:appealDecision rdf:type rdf:Property ;
    rdfs:label 'Appeal Decision' ;
    rdfs:comment 'Outcome of the payer appeal review. Upheld: original denial maintained; Overturned: denial reversed, services approved; Partial: partial approval granted on appeal; Pending: appeal under review. Drives denial overturn rate KPI reporting.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Decision Date' ;
    rdfs:comment 'Date when the payer rendered a decision on the appeal.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFiledDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Date' ;
    rdfs:comment 'Date when an appeal was filed with the payer for a denied or partially approved authorization.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Submitted Date' ;
    rdfs:comment 'Date on which a formal appeal of the payer denial was submitted. Populated when authorization_status is appealed. Used to track appeal filing deadlines and payer response timelines.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedQuantity rdf:type rdf:Property ;
    rdfs:label 'Approved Quantity' ;
    rdfs:comment 'Quantity of services, visits, units, or procedures approved by the payer. May represent number of visits, units of service, or treatment sessions.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Approved Quantity Unit' ;
    rdfs:comment 'Unit of measure for the approved quantity (e.g., visits, units, sessions, days).' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Number' ;
    rdfs:comment 'Externally assigned authorization reference number issued by the payer upon approval or acknowledgment of the prior authorization request. Required on claims submission to validate covered services. Sourced from Epic Resolute HB payer portal integration.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current workflow state of the prior authorization request. Drives revenue cycle integrity, denial management workflows, and utilization management escalation. Key values: approved (payer approved services), denied (payer denied services), pending (awaiting payer decision), appealed (denial under appeal), retro_authorized (authorization obtained after service delivery), cancelled (request withdrawn).' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationType rdf:type rdf:Property ;
    rdfs:label 'Authorization Type' ;
    rdfs:comment 'Classification of the authorization request by timing relative to service delivery. Prior: requested before service; Concurrent: requested during ongoing inpatient stay (utilization review); Retrospective: requested after service delivery; Expedited: urgent/emergent prior authorization with accelerated payer review timeline.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedAmount rdf:type rdf:Property ;
    rdfs:label 'Authorized Amount' ;
    rdfs:comment 'Dollar amount of services approved by the payer under this authorization. Used for revenue cycle forecasting, expected reimbursement calculation, and payer contract compliance monitoring.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedDays rdf:type rdf:Property ;
    rdfs:label 'Authorized Days' ;
    rdfs:comment 'Number of inpatient days or service days approved by the payer for the authorized admission or ongoing care episode. Critical for concurrent review, length-of-stay management, and discharge planning. Distinct from authorized_units which applies to discrete service counts.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedUnits rdf:type rdf:Property ;
    rdfs:label 'Authorized Units' ;
    rdfs:comment 'Number of service units (e.g., therapy visits, procedure units, infusion doses) approved by the payer for the authorized service. Used for utilization tracking against approved quantities and denial prevention.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clinicalIndication rdf:type rdf:Property ;
    rdfs:label 'Clinical Indication' ;
    rdfs:comment 'Narrative description of the medical necessity justification submitted to the payer supporting the authorization request. Documents the clinical rationale, patient condition, and treatment plan context. Used by CDI teams for documentation improvement and appeal preparation.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalNotes rdf:type rdf:Property ;
    rdfs:label 'Clinical Notes' ;
    rdfs:comment 'Free-text clinical notes or justification provided to support the authorization request.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:context rdf:type rdf:Property ;
    rdfs:label 'Context' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysUsed rdf:type rdf:Property ;
    rdfs:label 'Days Used' ;
    rdfs:comment 'Number of authorized inpatient days actually consumed against this authorization. Compared against authorized_days for concurrent review, length-of-stay management, and proactive extension request triggering.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decisionDatetime rdf:type rdf:Property ;
    rdfs:label 'Decision Datetime' ;
    rdfs:comment 'Date and time when the payer rendered the authorization decision (approved, denied, or partial).' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:denialReasonCode rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Code' ;
    rdfs:comment 'Payer-issued standardized code identifying the reason for authorization denial (e.g., not medically necessary, experimental/investigational, out-of-network, missing documentation, benefit exclusion). Used for denial management root cause analysis and appeal strategy. Populated only when authorization_status is denied or appealed.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Description' ;
    rdfs:comment 'Free-text or payer-provided narrative description of the denial rationale. Supplements the denial_reason_code with additional clinical or administrative context. Used by CDI and RCM teams for appeal letter preparation.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Extension Authorization Number' ;
    rdfs:comment 'Payer-issued authorization number for an approved extension of the original authorization period or unit count. Links the extension approval to the parent authorization record for complete authorization chain tracking.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Requested Flag' ;
    rdfs:comment 'Indicates whether an extension of the original authorization (additional days or units) has been requested from the payer. True = extension request submitted. Supports concurrent review workflow management and LOS management reporting.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Type of care setting or facility for which the authorization was requested. Inpatient: acute hospital admission; Outpatient: ambulatory services; ED: emergency department; Observation: observation status; SNF: skilled nursing facility; Home Health: home-based services; Telehealth: virtual care services. [ENUM-REF-CANDIDATE: inpatient|outpatient|ed|observation|snf|home_health|telehealth — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icd10DiagnosisCode rdf:type rdf:Property ;
    rdfs:label 'Icd10 Diagnosis Code' ;
    rdfs:comment 'Primary ICD-10-CM diagnosis code submitted as clinical indication supporting the medical necessity of the requested service. Required by most payers for authorization adjudication. Sourced from Epic ClinDoc clinical documentation.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mergedWithOrderOrderAuthorization rdf:type rdf:Property ;
    rdfs:label 'Merged With Order Order Authorization' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvmAliasName rdf:type rdf:Property ;
    rdfs:label 'Mvm Alias Name' ;
    rdfs:comment 'MVM-tier alias name (authorization) for this ECM product, ensuring ECM is a true superset of the MVM.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvmEcmReconciledFlag rdf:type rdf:Property ;
    rdfs:label 'Mvm Ecm Reconciled Flag' ;
    rdfs:comment 'True when this ECM product has been reconciled against its MVM alias.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payerAuthorizationReference rdf:type rdf:Property ;
    rdfs:label 'Payer Authorization Reference' ;
    rdfs:comment 'Payer-assigned internal tracking or case reference number for the authorization request, distinct from the final authorization_number. Used for payer portal follow-up, status inquiries, and audit trail documentation during the pending review period.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerDecisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payer Decision Timestamp' ;
    rdfs:comment 'Date and time the payer issued its authorization decision (approval, denial, or partial approval). Used to calculate payer turnaround time, measure compliance with CMS prior authorization timelines, and support denial management workflows.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payerReviewerName rdf:type rdf:Property ;
    rdfs:label 'Payer Reviewer Name' ;
    rdfs:comment 'Name of the payer clinical reviewer or medical director who adjudicated the authorization request. Used for peer-to-peer review scheduling, appeal escalation, and payer relationship management.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerReviewerNpi rdf:type rdf:Property ;
    rdfs:label 'Payer Reviewer Npi' ;
    rdfs:comment 'National Provider Identifier of the payer medical director or clinical reviewer who adjudicated the authorization. Required for peer-to-peer review documentation and regulatory audit trails.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peerToPeerConducted rdf:type rdf:Property ;
    rdfs:label 'Peer To Peer Conducted' ;
    rdfs:comment 'Indicates whether a peer-to-peer clinical review was conducted between the requesting provider and payer medical director.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peerToPeerDate rdf:type rdf:Property ;
    rdfs:label 'Peer To Peer Date' ;
    rdfs:comment 'Date when the peer-to-peer clinical review was conducted.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:peerToPeerOutcome rdf:type rdf:Property ;
    rdfs:label 'Peer To Peer Outcome' ;
    rdfs:comment 'Result of the peer-to-peer clinical review with the payer medical director. Approved: payer reversed denial after P2P; Denied: payer upheld denial after P2P; Partial: partial approval granted; Pending: outcome not yet determined.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peerToPeerReviewDate rdf:type rdf:Property ;
    rdfs:label 'Peer To Peer Review Date' ;
    rdfs:comment 'Date on which the peer-to-peer clinical review between the requesting provider and payer medical director was conducted. Populated when peer_to_peer_review_flag is True.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:peerToPeerReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Peer To Peer Review Flag' ;
    rdfs:comment 'Indicates whether a peer-to-peer clinical review was requested or conducted between the requesting provider and the payer medical director to contest a denial or support authorization. True = P2P review requested/completed. Key metric for utilization management and denial overturn tracking.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level of the authorization request indicating urgency (e.g., routine, urgent, stat, emergent).' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciledFromMvm rdf:type rdf:Property ;
    rdfs:label 'Reconciled From Mvm' ;
    rdfs:comment 'Indicates source MVM table reconciled into ECM' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationSource rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Source' ;
    rdfs:comment 'Source MVM table: encounter.authorization' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDatetime rdf:type rdf:Property ;
    rdfs:label 'Request Datetime' ;
    rdfs:comment 'Date and time when the prior authorization request was submitted to the payer. Represents the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Submitted Timestamp' ;
    rdfs:comment 'Date and time the prior authorization request was formally submitted to the payer. Principal business event timestamp for the authorization lifecycle. Used for turnaround time measurement and payer SLA compliance tracking.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity' ;
    rdfs:comment 'Quantity of services, visits, or units originally requested in the authorization submission.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestingProviderName rdf:type rdf:Property ;
    rdfs:label 'Requesting Provider Name' ;
    rdfs:comment 'Full name of the provider who submitted the authorization request.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingProviderNpi rdf:type rdf:Property ;
    rdfs:label 'Requesting Provider Npi' ;
    rdfs:comment 'National Provider Identifier (NPI) of the provider who requested the authorization.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retroAuthorizationReason rdf:type rdf:Property ;
    rdfs:label 'Retro Authorization Reason' ;
    rdfs:comment 'Documented reason why authorization was obtained retrospectively after service delivery (e.g., emergency admission, system downtime, payer portal unavailability, clinical urgency). Required for retro-authorization requests and RAC audit defense. Populated when authorization_type is retrospective.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Name of the payer representative or medical reviewer who processed the authorization request.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'High-level category of the clinical service requiring authorization (e.g., inpatient, outpatient, lab, radiology, pharmacy, DME). [ENUM-REF-CANDIDATE: inpatient|outpatient|laboratory|radiology|pharmacy|dme|home_health|skilled_nursing — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Category of clinical service or care setting for which authorization is being requested (e.g., inpatient admission, outpatient surgery, skilled nursing facility, home health, durable medical equipment, specialty referral, imaging, infusion therapy). Sourced from payer-specific service type codes. [ENUM-REF-CANDIDATE: inpatient|outpatient_surgery|skilled_nursing|home_health|dme|specialty_referral|imaging|infusion|behavioral_health|physical_therapy — promote to reference product]' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicingFacilityName rdf:type rdf:Property ;
    rdfs:label 'Servicing Facility Name' ;
    rdfs:comment 'Name of the facility where the authorized service will be performed.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicingProviderNpi rdf:type rdf:Property ;
    rdfs:label 'Servicing Provider Npi' ;
    rdfs:comment 'National Provider Identifier (NPI) of the provider who will perform the authorized service.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemAuthCode rdf:type rdf:Property ;
    rdfs:label 'Source System Auth Code' ;
    rdfs:comment 'Native authorization record identifier from the originating source system (e.g., Epic Resolute HB authorization ID or payer portal case ID). Enables cross-system reconciliation, ETL traceability, and audit trail back to the system of record.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssotCanonicalReference rdf:type rdf:Property ;
    rdfs:label 'Ssot Canonical Reference' ;
    rdfs:comment 'Reference to the canonical SSOT record when this record is deprecated or merged' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssotReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Ssot Reconciliation Status' ;
    rdfs:comment 'Status indicating reconciliation state with related SSOT entity: ACTIVE, DEPRECATED, MERGED, SUPERSEDED' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'First date on which the authorized services may be rendered under this authorization. Services delivered before this date are not covered and may result in claim denial. Sourced from payer authorization response.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Channel through which the prior authorization request was submitted to the payer. Electronic: automated EDI 278 transaction; Phone: verbal submission via payer call center; Fax: paper-based fax submission; Portal: payer web portal submission; EDI: direct EDI integration. Used for operational efficiency analysis and automation opportunity identification.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeHours rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Hours' ;
    rdfs:comment 'Elapsed time in hours between authorization request submission and payer decision. Used for performance monitoring and SLA tracking.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsUsed rdf:type rdf:Property ;
    rdfs:label 'Units Used' ;
    rdfs:comment 'Number of authorized service units actually consumed against this authorization. Compared against authorized_units to monitor utilization, prevent over-utilization, and trigger re-authorization workflows when approaching the authorized limit.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:urgencyLevel rdf:type rdf:Property ;
    rdfs:label 'Urgency Level' ;
    rdfs:comment 'Clinical urgency classification of the authorization request. Routine: standard processing timeline; Urgent: accelerated review required within 72 hours; Emergent: immediate review required; Expedited: CMS-defined expedited review for life-threatening conditions. Drives payer SLA requirements and processing priority.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vibeReconciledFlag rdf:type rdf:Property ;
    rdfs:label 'Vibe Reconciled Flag' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triageAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Triage Assessment Id' ;
    rdfs:comment 'Unique surrogate identifier for the triage assessment record in the Silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chiefComplaintSnomedConceptId rdf:type rdf:Property ;
    rdfs:label 'Chief Complaint Snomed Concept Id' ;
    rdfs:comment 'Foreign key linking to reference.snomed_concept. Business justification: Chief complaint coding via SNOMED CT is standard in ED triage for clinical decision support, sepsis/stroke alert triggering, and FHIR Condition resource generation. triage_assessment.chief_complaint_c' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SnomedConcept .

ind:loincCodeId rdf:type rdf:Property ;
    rdfs:label 'Loinc Code Id' ;
    rdfs:comment 'Foreign key linking to reference.loinc_code. Business justification: Triage vital signs (heart rate, SpO2, temperature, BP) are LOINC-coded observations in HL7 FHIR and CDA clinical documents. Linking triage_assessment to the LOINC reference table supports interoperabi' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoincCode .

ind:priorTriageAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Prior Triage Assessment Id' ;
    rdfs:comment 'Reference to the original triage assessment record when this record is a reassessment. Enables linkage of reassessment chains for acuity escalation tracking and waiting room safety analytics.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TriageAssessment .

ind:triageObservationId rdf:type rdf:Property ;
    rdfs:label 'Triage Observation Id' ;
    rdfs:comment 'Foreign key linking to clinical.observation. Business justification: ED triage generates structured clinical observations (ESI scoring, pain assessments, sepsis/stroke screening). Linking triage_assessment to the clinical observation record supports ED quality reportin' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Observation .

ind:acuityChangeReason rdf:type rdf:Property ;
    rdfs:label 'Acuity Change Reason' ;
    rdfs:comment 'Free-text or structured reason documented by the triage nurse when the ESI acuity level is changed during a reassessment. PHI under HIPAA. Used for clinical quality review and patient safety event analysis.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalMode rdf:type rdf:Property ;
    rdfs:label 'Arrival Mode' ;
    rdfs:comment 'Method by which the patient arrived at the ED or urgent care facility. Includes ground ambulance, air transport (helicopter), walk-in, police transport, private vehicle, or inter-facility transfer. Used for EMTALA compliance, acuity benchmarking, and EMS coordination analytics.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chiefComplaint rdf:type rdf:Property ;
    rdfs:label 'Chief Complaint' ;
    rdfs:comment 'Free-text or structured description of the patient\'s primary reason for presenting to the ED or urgent care, as stated by the patient or documented by the triage nurse. Protected Health Information (PHI) under HIPAA. Used for clinical documentation, coding, and population health analytics.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chiefComplaintCode rdf:type rdf:Property ;
    rdfs:label 'Chief Complaint Code' ;
    rdfs:comment 'Standardized SNOMED CT (Systematized Nomenclature of Medicine Clinical Terms) code representing the chief complaint. Enables structured clinical analytics, interoperability, and population health reporting across systems.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diastolicBpMmhg rdf:type rdf:Property ;
    rdfs:label 'Diastolic Bp Mmhg' ;
    rdfs:comment 'Diastolic blood pressure measurement recorded at triage, expressed in millimeters of mercury (mmHg). Used alongside systolic BP for hemodynamic assessment and ESI acuity scoring. PHI under HIPAA.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doorArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Door Arrival Timestamp' ;
    rdfs:comment 'Date and time the patient physically arrived at the ED or urgent care facility (door time). Used as the baseline for door-to-triage and door-to-provider time quality measures reported to CMS.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:esiLevel rdf:type rdf:Property ;
    rdfs:label 'Esi Level' ;
    rdfs:comment 'Emergency Severity Index (ESI) triage acuity score assigned by the triage nurse, ranging from 1 (most critical/immediate) to 5 (least urgent/non-urgent). Drives resource allocation, bed assignment priority, and ED throughput analytics. Defined by AHRQ ESI Triage Algorithm.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glasgowComaScore rdf:type rdf:Property ;
    rdfs:label 'Glasgow Coma Score' ;
    rdfs:comment 'Total Glasgow Coma Scale (GCS) score assessed at triage, ranging from 3 (deep unconsciousness) to 15 (fully alert). Used for neurological status assessment, ESI acuity determination, and trauma triage protocols. PHI under HIPAA.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:heartRateBpm rdf:type rdf:Property ;
    rdfs:label 'Heart Rate Bpm' ;
    rdfs:comment 'Heart rate (pulse) measured at triage, expressed in beats per minute (BPM). Key vital sign for ESI acuity determination and identification of hemodynamic instability. PHI under HIPAA.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interpreterLanguage rdf:type rdf:Property ;
    rdfs:label 'Interpreter Language' ;
    rdfs:comment 'Primary language for which interpretation services are required, using ISO 639-1 two-letter language codes (e.g., \'es\' for Spanish, \'zh\' for Chinese). Supports LEP compliance reporting and interpreter resource planning.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isolationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Isolation Required Flag' ;
    rdfs:comment 'Indicates whether the patient requires isolation precautions at triage (e.g., airborne, droplet, contact, or neutropenic precautions). Drives bed assignment workflows, infection control protocols, and Healthcare-Associated Infection (HAI) prevention measures.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lwbsFlag rdf:type rdf:Property ;
    rdfs:label 'Lwbs Flag' ;
    rdfs:comment 'Indicates whether the patient left the ED without being seen by a provider after triage (LWBS). Key ED throughput quality metric reported to CMS and used for EMTALA compliance monitoring and operational improvement initiatives.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lwbsTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lwbs Timestamp' ;
    rdfs:comment 'Date and time the patient departed the ED without being seen by a provider, when the LWBS flag is true. Used to calculate time-to-LWBS and identify peak demand periods contributing to patient walkouts.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:painScaleType rdf:type rdf:Property ;
    rdfs:label 'Pain Scale Type' ;
    rdfs:comment 'Type of validated pain assessment scale used to obtain the pain score at triage. Distinguishes between numeric rating scale (NRS), Wong-Baker FACES (pediatric), FLACC (non-verbal), verbal descriptor, or behavioral observation scales.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:painScore rdf:type rdf:Property ;
    rdfs:label 'Pain Score' ;
    rdfs:comment 'Patient-reported pain intensity score at triage, typically on a 0–10 numeric rating scale (NRS) or equivalent validated scale (e.g., Wong-Baker FACES for pediatric patients). Used for ESI acuity determination and Joint Commission pain management compliance. PHI under HIPAA.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Date and time when this triage assessment record was first created in the source system. Used for audit trail, data lineage, and Silver layer ingestion tracking.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Date and time when this triage assessment record was most recently modified in the source system. Used for change detection, incremental ETL processing, and audit compliance.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:respiratoryRateBpm rdf:type rdf:Property ;
    rdfs:label 'Respiratory Rate Bpm' ;
    rdfs:comment 'Respiratory rate measured at triage, expressed in breaths per minute. Used for ESI acuity scoring and identification of respiratory distress. PHI under HIPAA.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sepsisAlertFlag rdf:type rdf:Property ;
    rdfs:label 'Sepsis Alert Flag' ;
    rdfs:comment 'Indicates whether a sepsis screening alert was triggered at triage based on vital signs and clinical criteria (e.g., SIRS criteria, qSOFA). Supports SEP-1 bundle compliance reporting to CMS and Joint Commission sepsis quality measures.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spo2Percent rdf:type rdf:Property ;
    rdfs:label 'Spo2 Percent' ;
    rdfs:comment 'Peripheral oxygen saturation (SpO2) measured by pulse oximetry at triage, expressed as a percentage. Critical indicator for respiratory status and ESI acuity level assignment. PHI under HIPAA.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strokeAlertFlag rdf:type rdf:Property ;
    rdfs:label 'Stroke Alert Flag' ;
    rdfs:comment 'Indicates whether a stroke alert protocol was activated at triage based on presenting symptoms (e.g., FAST criteria). Supports door-to-CT and door-to-needle time quality measures for stroke care reported to The Joint Commission and CMS.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systolicBpMmhg rdf:type rdf:Property ;
    rdfs:label 'Systolic Bp Mmhg' ;
    rdfs:comment 'Systolic blood pressure measurement recorded at triage, expressed in millimeters of mercury (mmHg). Critical vital sign for ESI acuity determination and clinical decision support. PHI under HIPAA.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Body temperature measured at triage, expressed in degrees Celsius. Used for ESI acuity determination, sepsis screening, and infection surveillance. PHI under HIPAA.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRoute rdf:type rdf:Property ;
    rdfs:label 'Temperature Route' ;
    rdfs:comment 'Anatomical route used to obtain the body temperature measurement at triage (e.g., oral, rectal, axillary, tympanic, temporal). Affects clinical interpretation of temperature values.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traumaActivationFlag rdf:type rdf:Property ;
    rdfs:label 'Trauma Activation Flag' ;
    rdfs:comment 'Indicates whether a trauma team activation was initiated at or following triage. Used for trauma registry reporting, ACS trauma center verification, and ED resource utilization analytics.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:traumaLevel rdf:type rdf:Property ;
    rdfs:label 'Trauma Level' ;
    rdfs:comment 'Level of trauma team activation triggered at triage (Level 1 = full activation for most critical injuries, Level 2 = partial activation, Level 3 = consult/standby). Drives resource deployment and trauma registry classification.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageCategory rdf:type rdf:Property ;
    rdfs:label 'Triage Category' ;
    rdfs:comment 'Categorical classification of triage acuity corresponding to the ESI level. Supports ED throughput reporting, staffing models, and payer analytics. Values align with standard ED triage nomenclature.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Triage Completed Timestamp' ;
    rdfs:comment 'Date and time when the triage assessment was fully documented and completed by the triage nurse. Used to calculate triage duration and nurse productivity metrics.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:triageNumber rdf:type rdf:Property ;
    rdfs:label 'Triage Number' ;
    rdfs:comment 'Externally visible, human-readable identifier for the triage assessment record as assigned by the source system (Epic ClinDoc or Cerner PowerChart ED). Used for cross-system reconciliation and audit trails.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageNurseNpi rdf:type rdf:Property ;
    rdfs:label 'Triage Nurse Npi' ;
    rdfs:comment 'National Provider Identifier (NPI) of the licensed nurse or clinician who performed the triage assessment. Required for EMTALA compliance documentation and provider-level quality reporting. Sourced from Epic ClinDoc or Cerner PowerChart ED.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageReassessmentFlag rdf:type rdf:Property ;
    rdfs:label 'Triage Reassessment Flag' ;
    rdfs:comment 'Indicates whether this triage record represents a reassessment of a previously triaged patient (e.g., patient condition changed while waiting). Supports tracking of acuity escalation events and waiting room safety monitoring.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triageStatus rdf:type rdf:Property ;
    rdfs:label 'Triage Status' ;
    rdfs:comment 'Current workflow state of the triage assessment record. Indicates whether triage documentation is in progress, finalized, subsequently amended, or voided.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Triage Timestamp' ;
    rdfs:comment 'Date and time when the triage assessment was initiated by the triage nurse. This is the principal business event timestamp used to calculate door-to-triage time and ED throughput quality measures.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Patient weight measured or reported at triage, expressed in kilograms. Used for medication dosing calculations, pediatric weight-based protocols, and clinical decision support. PHI under HIPAA.' ;
    rdfs:domain ind:TriageAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readmissionId rdf:type rdf:Property ;
    rdfs:label 'Readmission Id' ;
    rdfs:comment 'Unique surrogate identifier for the readmission tracking record linking an index encounter to a subsequent readmission encounter.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexClinicalDiagnosisId rdf:type rdf:Property ;
    rdfs:label 'Index Clinical Diagnosis Id' ;
    rdfs:comment 'Foreign key linking to clinical.diagnosis. Business justification: HRRP (Hospital Readmissions Reduction Program) CMS reporting requires linking readmission events to the clinical diagnosis driving the index admission. Supports penalty calculation, root cause analysi' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Diagnosis .

ind:indexDrgId rdf:type rdf:Property ;
    rdfs:label 'Index Drg Id' ;
    rdfs:comment 'Foreign key linking to reference.drg. Business justification: Readmission tracking—index admission DRG must reference official DRG definition for HRRP penalty calculation, excess readmission ratio reporting, and quality measure validation. Required for CMS readm' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Drg .

ind:primaryReadmissionEncounterVisitId rdf:type rdf:Property ;
    rdfs:label 'Primary Readmission Encounter Visit Id' ;
    rdfs:comment 'Foreign key reference to the subsequent encounter that qualifies as a readmission within the defined time window following the index discharge.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Visit .

ind:waitlistEntryId rdf:type rdf:Property ;
    rdfs:label 'Waitlist Entry Id' ;
    rdfs:comment 'Foreign key linking to scheduling.waitlist_entry. Business justification: HRRP regulatory reporting requires identifying whether a failed or incomplete waitlist/follow-up scheduling event contributed to a readmission. Linking readmission to the post-discharge waitlist_entry' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaitlistEntry .

ind:acoAttributed rdf:type rdf:Property ;
    rdfs:label 'Aco Attributed' ;
    rdfs:comment 'Indicates whether the patient was attributed to an Accountable Care Organization (ACO) at the time of the index encounter. ACO-attributed readmissions have direct financial implications under shared savings and risk-based contracts.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:admitSource rdf:type rdf:Property ;
    rdfs:label 'Admit Source' ;
    rdfs:comment 'Source through which the patient was admitted for the readmission encounter (e.g., Emergency Department, physician referral, transfer from another facility). Supports analysis of care transition failure points.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:careGapIdentified rdf:type rdf:Property ;
    rdfs:label 'Care Gap Identified' ;
    rdfs:comment 'Specific care gap identified during readmission review that contributed to the readmission event. Used to drive post-discharge intervention program design and care management outreach. [ENUM-REF-CANDIDATE: no_follow_up_appointment|medication_reconciliation_gap|no_discharge_instructions|no_post_acute_referral|no_care_gap — promote to reference product]' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToReadmission rdf:type rdf:Property ;
    rdfs:label 'Days To Readmission' ;
    rdfs:comment 'Number of calendar days elapsed between the index discharge date and the readmission admission date. Core metric for HRRP cohort assignment and post-discharge intervention effectiveness analysis.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Penalty Amount' ;
    rdfs:comment 'Estimated financial penalty amount (in USD) attributable to this readmission under the CMS Hospital Readmissions Reduction Program. Used for revenue cycle impact analysis and CFO-level financial reporting. Confidential business financial data.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpAppointmentDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Appointment Date' ;
    rdfs:comment 'Scheduled date of the first post-discharge follow-up appointment after the index encounter. Used to assess timeliness of follow-up care and its correlation with readmission prevention.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAppointmentScheduled rdf:type rdf:Property ;
    rdfs:label 'Follow Up Appointment Scheduled' ;
    rdfs:comment 'Indicates whether a follow-up outpatient appointment was scheduled prior to or at the time of index discharge. A key care gap indicator; absence is associated with higher 30-day readmission risk.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hrrpExcessReadmissionRatio rdf:type rdf:Property ;
    rdfs:label 'Hrrp Excess Readmission Ratio' ;
    rdfs:comment 'CMS-calculated ratio of predicted to expected readmissions for the applicable HRRP measure category. A ratio greater than 1.0 indicates excess readmissions subject to payment penalty. Sourced from CMS IPPS final rule calculations.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hrrpMeasureCategory rdf:type rdf:Property ;
    rdfs:label 'Hrrp Measure Category' ;
    rdfs:comment 'CMS HRRP condition-specific measure category assigned to the readmission. AMI=Acute Myocardial Infarction, HF=Heart Failure, PN=Pneumonia, COPD=Chronic Obstructive Pulmonary Disease, THA_TKA=Total Hip/Knee Arthroplasty, CABG=Coronary Artery Bypass Graft, other=does not fall under a specific HRRP measure. Drives CMS penalty calculation and quality reporting. [ENUM-REF-CANDIDATE: AMI|HF|PN|COPD|THA_TKA|CABG|other — promote to reference product]' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexDischargeDate rdf:type rdf:Property ;
    rdfs:label 'Index Discharge Date' ;
    rdfs:comment 'Date the patient was discharged from the index (original) inpatient encounter. Serves as the start of the readmission measurement window per CMS HRRP methodology.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indexDischargeDisposition rdf:type rdf:Property ;
    rdfs:label 'Index Discharge Disposition' ;
    rdfs:comment 'Discharge disposition code from the index encounter indicating where the patient was discharged to. Critical for identifying post-acute care failures as a readmission root cause and for HRRP exclusion logic (e.g., AMA, expired). [ENUM-REF-CANDIDATE: home|home_health|snf|ltach|rehab|hospice|ama|expired — promote to reference product]' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexLosDays rdf:type rdf:Property ;
    rdfs:label 'Index Los Days' ;
    rdfs:comment 'Number of inpatient days for the index encounter. Used in readmission risk stratification and to assess whether short LOS contributed to the readmission.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexPrimaryIcd10Code rdf:type rdf:Property ;
    rdfs:label 'Index Primary Icd10 Code' ;
    rdfs:comment 'Primary ICD-10-CM diagnosis code from the index encounter. Used to determine HRRP measure category eligibility and to analyze clinical patterns driving readmissions.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHrrpApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Hrrp Applicable' ;
    rdfs:comment 'Indicates whether this readmission is subject to CMS HRRP penalty calculation. False when the readmission meets CMS exclusion criteria (e.g., planned readmission, transfer, AMA discharge, death during index stay).' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRelatedToIndex rdf:type rdf:Property ;
    rdfs:label 'Is Related To Index' ;
    rdfs:comment 'Indicates whether the readmission diagnosis is clinically related to the index encounter\'s principal diagnosis, as determined by clinical documentation review or CDI query outcome. Supports root cause analysis and preventability assessment.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicationReconciliationCompleted rdf:type rdf:Property ;
    rdfs:label 'Medication Reconciliation Completed' ;
    rdfs:comment 'Indicates whether medication reconciliation was completed at the time of index discharge. Medication discrepancies are a leading cause of preventable readmissions; this flag supports MAR audit and quality reporting.' ;
    rdfs:domain ind:Encounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payerType rdf:type rdf:Property ;
    rdfs:label 'Payer Type' ;
    rdfs:comment 'Classification of the payer for the index encounter. Medicare is the primary payer subject to CMS HRRP penalties. Segmentation by payer type enables value-based contract performance analysis across HMO, PPO, ACO, and government programs.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventabilityAssessment rdf:type rdf:Property ;
    rdfs:label 'Preventability Assessment' ;
    rdfs:comment 'Clinical determination of whether the readmission was potentially preventable through improved care coordination, discharge planning, or post-discharge follow-up. Drives care management program targeting and quality improvement initiatives.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Readmission Status' ;
    rdfs:comment 'Current workflow status of the readmission record within the quality review and HRRP adjudication process. \'pending_review\' indicates awaiting clinical validation; \'confirmed\' indicates validated readmission; \'excluded\' indicates meets CMS exclusion criteria; \'appealed\' indicates under payer or CMS appeal; \'closed\' indicates final disposition reached.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readmissionType rdf:type rdf:Property ;
    rdfs:label 'Readmission Type' ;
    rdfs:comment 'Classification of the readmission as planned or unplanned per CMS HRRP methodology. Planned readmissions (e.g., scheduled chemotherapy, elective procedures) are excluded from HRRP penalty calculations. Unplanned readmissions are subject to CMS penalty assessment.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Review Completed Date' ;
    rdfs:comment 'Date on which the clinical quality review of this readmission record was completed by the quality or CDI team. Supports workflow management and regulatory reporting timeliness tracking.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerNotes rdf:type rdf:Property ;
    rdfs:label 'Reviewer Notes' ;
    rdfs:comment 'Free-text clinical notes entered by the quality reviewer documenting the rationale for preventability assessment, root cause determination, and any care gaps identified during the readmission review process.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Numeric risk score assigned to the patient at the time of index discharge predicting likelihood of 30-day readmission (e.g., LACE score, HOSPITAL score, Epic readmission risk model output). Used for care management program targeting and post-discharge intervention prioritization.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskScoreModel rdf:type rdf:Property ;
    rdfs:label 'Risk Score Model' ;
    rdfs:comment 'Name of the validated risk stratification model used to generate the readmission risk score. LACE=Length of stay, Acuity, Comorbidities, ED visits; HOSPITAL=Hemoglobin, Oncology, Sodium, Procedure, Index admission type, Type of admission, number of Admissions, Length of stay.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Categorized root cause of the readmission as identified through clinical review. Supports targeted quality improvement interventions and population health management. [ENUM-REF-CANDIDATE: medication_issue|care_coordination_gap|patient_non_compliance|inadequate_discharge_planning|disease_progression|social_determinants|post_acute_care_failure — promote to reference product]' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Externally visible business identifier for this readmission record, used in care management workflows, quality reporting submissions, and cross-system reconciliation (e.g., Epic Healthy Planet case reference).' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionOfCareCompleted rdf:type rdf:Property ;
    rdfs:label 'Transition Of Care Completed' ;
    rdfs:comment 'Indicates whether a formal transition of care communication (e.g., discharge summary transmitted to PCP, care transition call completed) was documented following the index discharge. Supports HEDIS Transitions of Care measure compliance.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:window rdf:type rdf:Property ;
    rdfs:label 'Window' ;
    rdfs:comment 'Defined time window within which the readmission occurred relative to the index discharge. \'7_day\' supports high-acuity post-discharge monitoring; \'30_day\' is the primary CMS HRRP measurement window; \'90_day\' supports extended care management program targeting.' ;
    rdfs:domain ind:Readmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeSummaryId rdf:type rdf:Property ;
    rdfs:label 'Discharge Summary Id' ;
    rdfs:comment 'Unique identifier for the discharge summary record. Primary key.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DischargeSummary .

ind:addendedDischargeSummaryId rdf:type rdf:Property ;
    rdfs:label 'Addended Discharge Summary Id' ;
    rdfs:comment 'Self-referencing FK on discharge_summary (addended_discharge_summary_id)' ;
    rdfs:domain ind:DischargeSummary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DischargeSummary .

ind:primaryDischargeClinicianId rdf:type rdf:Property ;
    rdfs:label 'Primary Discharge Clinician Id' ;
    rdfs:comment 'Reference to the provider who authorized and completed the patient discharge.' ;
    rdfs:domain ind:DischargeSummary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:tertiaryDischargeFollowUpProviderClinicianId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Discharge Follow Up Provider Clinician Id' ;
    rdfs:comment 'Reference to the provider with whom the follow-up appointment is scheduled.' ;
    rdfs:domain ind:DischargeSummary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:activityRestrictions rdf:type rdf:Property ;
    rdfs:label 'Activity Restrictions' ;
    rdfs:comment 'Physical activity limitations and restrictions prescribed at discharge including weight-bearing, lifting, and exercise guidelines.' ;
    rdfs:domain ind:DischargeSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the discharge summary was completed within the required timeframe per organizational policy and regulatory requirements.' ;
    rdfs:domain ind:DischargeSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dietInstructions rdf:type rdf:Property ;
    rdfs:label 'Diet Instructions' ;
    rdfs:comment 'Dietary recommendations and restrictions provided to the patient at discharge.' ;
    rdfs:domain ind:DischargeSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeCondition rdf:type rdf:Property ;
    rdfs:label 'Discharge Condition' ;
    rdfs:comment 'The patients clinical condition at the time of discharge compared to admission status.' ;
    rdfs:domain ind:DischargeSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

