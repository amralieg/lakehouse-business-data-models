ind:compensationDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Disclosure Flag' ;
    rdfs:comment 'True if compensation was disclosed' ;
    rdfs:domain ind:HipaaAuthorization ;
