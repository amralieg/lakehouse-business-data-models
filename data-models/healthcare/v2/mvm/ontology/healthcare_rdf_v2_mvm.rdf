    rdfs:comment 'The current count of appointments already booked during this availability period. Used for capacity management.' ;
    rdfs:domain ind:ProviderAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageArea rdf:type rdf:Property ;
    rdfs:label 'Coverage Area' ;
    rdfs:comment 'Geographic or organizational coverage area for on-call availability. Examples: entire hospital, specific units, regional coverage.' ;
    rdfs:domain ind:ProviderAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDatetime rdf:type rdf:Property ;
    rdfs:label 'End Datetime' ;
    rdfs:comment 'The date and time when the provider availability period ends. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
