ind:disclosingOrgProviderId rdf:type rdf:Property ;
    rdfs:label 'Disclosing Org Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.org_provider. Business justification: HIPAA authorizations identify the covered entity releasing PHI. disclosing_party_name and disclosing_party_npi are denormalized org_provider attributes. Normalizing via FK supports payer enrollment va' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgProvider .

ind:disclosingPartyNpiRegistryId rdf:type rdf:Property ;
    rdfs:label 'Disclosing Party Npi Registry Id' ;
    rdfs:comment 'Foreign key linking to reference.npi_registry. Business justification: HIPAA authorization compliance audits and breach investigations require identifying the disclosing party via their NPI registry record. disclosing_party_npi is a plain-text denormalization of the NPI ' ;
    rdfs:domain ind:HipaaAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NpiRegistry .

ind:supersededHipaaAuthorizationId rdf:type rdf:Property ;
