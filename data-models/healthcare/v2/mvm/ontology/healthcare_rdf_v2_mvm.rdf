ind:consentDocumentLocation rdf:type rdf:Property ;
    rdfs:label 'Consent Document Location' ;
    rdfs:comment 'Reference to the location or system where the signed consent document is stored (e.g., EMR document ID, scanned document repository path).' ;
    rdfs:domain ind:TreatmentConsent ;
    rdf:type owl:DatatypeProperty ;
