ind:renderingProviderNpiRegistryId rdf:type rdf:Property ;
    rdfs:label 'Rendering Provider Npi Registry Id' ;
    rdfs:comment 'Foreign key linking to reference.npi_registry. Business justification: HIPAA claim submission and payer credentialing validation require the rendering provider NPI on each claim line to be validated against the NPPES NPI Registry. rendering_provider_npi on invoice_line i' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NpiRegistry .

ind:adjudicatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjudicated Timestamp' ;
    rdfs:comment 'Timestamp when the line was adjudicated by payer.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:claimAdjustmentGroupCode rdf:type rdf:Property ;
    rdfs:label 'Claim Adjustment Group Code' ;
    rdfs:comment 'CARC group code (e.g., CO=Contractual Obligation).' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimAdjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Claim Adjustment Reason Code' ;
    rdfs:comment 'CARC reason code for adjustment.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractualAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Contractual Adjustment Amount' ;
    rdfs:comment 'Contractual adjustment amount per payer contract.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drugQuantity rdf:type rdf:Property ;
    rdfs:label 'Drug Quantity' ;
    rdfs:comment 'Quantity of medication dispensed.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number on the invoice.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Status of the line item (e.g., Billed, Paid, Denied, Adjusted).' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Amount paid by payer for this line.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Paid Timestamp' ;
    rdfs:comment 'Timestamp when payment was received.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:patientResponsibilityAmount rdf:type rdf:Property ;
    rdfs:label 'Patient Responsibility Amount' ;
    rdfs:comment 'Patient responsibility amount for this line.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceAdviceRemarkCode rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Remark Code' ;
    rdfs:comment 'RARC code from payer remittance.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLocationCode rdf:type rdf:Property ;
    rdfs:label 'Service Location Code' ;
    rdfs:comment 'Code for the service location.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceToDate rdf:type rdf:Property ;
    rdfs:label 'Service To Date' ;
    rdfs:comment 'End date of service period.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Timestamp when the line was submitted to payer.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:units rdf:type rdf:Property ;
    rdfs:label 'Units' ;
    rdfs:comment 'Number of units of service.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codingAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Coding Assignment Id' ;
    rdfs:comment 'Unique identifier for each coding assignment.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hccProblemId rdf:type rdf:Property ;
    rdfs:label 'Hcc Problem Id' ;
    rdfs:comment 'Foreign key linking to clinical.problem. Business justification: HCC/risk adjustment coding: chronic conditions on the problem list drive HCC category capture for value-based payment programs (Medicare Advantage, ACO). Coding assignments must reference the specific' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Problem .

ind:principalDiagnosisIcdCodeId rdf:type rdf:Property ;
    rdfs:label 'Principal Diagnosis Icd Code Id' ;
    rdfs:comment 'Principal diagnosis code assigned.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcdCode .

ind:principalProcedureCptCodeId rdf:type rdf:Property ;
    rdfs:label 'Principal Procedure Cpt Code Id' ;
    rdfs:comment 'Principal procedure code assigned.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CptCode .

ind:principalProcedureEventId rdf:type rdf:Property ;
    rdfs:label 'Principal Procedure Event Id' ;
    rdfs:comment 'Foreign key linking to clinical.procedure_event. Business justification: DRG grouping requires the principal procedure to be traceable to the actual procedure_event record. Coding accuracy audits and CDI reviews verify that the coded principal procedure matches the documen' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcedureEvent .

ind:responsibleClinicianId rdf:type rdf:Property ;
    rdfs:label 'Responsible Clinician Id' ;
    rdfs:comment 'Foreign key linking to provider.clinician. Business justification: CDI physician queries (cdi_physician_response, cdi_query_date on coding_assignment) are directed at the responsible attending physician. HIM departments require clinician-level coding accuracy scoring' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:sourceNoteId rdf:type rdf:Property ;
    rdfs:label 'Source Note Id' ;
    rdfs:comment 'Foreign key linking to clinical.note. Business justification: CDI query workflow: coding specialists reference specific clinical notes (H&P, discharge summary, operative notes) as the documentation basis for coding assignments. Regulatory audits (RAC, OIG) requi' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Note .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'Timestamp when coding was assigned.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Flag' ;
    rdfs:comment 'Indicates if this coding was audited.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdiDrgImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Cdi Drg Impact Amount' ;
    rdfs:comment 'Financial impact of CDI query on DRG assignment.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdiPhysicianResponse rdf:type rdf:Property ;
    rdfs:label 'Cdi Physician Response' ;
    rdfs:comment 'Physician response to CDI query.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiQueryDate rdf:type rdf:Property ;
    rdfs:label 'Cdi Query Date' ;
    rdfs:comment 'Date CDI query was issued.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdiQueryTopic rdf:type rdf:Property ;
    rdfs:label 'Cdi Query Topic' ;
    rdfs:comment 'Topic of the CDI query.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiQueryType rdf:type rdf:Property ;
    rdfs:label 'Cdi Query Type' ;
    rdfs:comment 'Type of CDI query (e.g., Leading, Multiple Choice, Open-Ended).' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiResponseDate rdf:type rdf:Property ;
    rdfs:label 'Cdi Response Date' ;
    rdfs:comment 'Date physician responded to CDI query.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdiResponseDeadline rdf:type rdf:Property ;
    rdfs:label 'Cdi Response Deadline' ;
    rdfs:comment 'Deadline for physician response to CDI query.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdiResultingCodeChange rdf:type rdf:Property ;
    rdfs:label 'Cdi Resulting Code Change' ;
    rdfs:comment 'Code change resulting from CDI query.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codingAccuracyScore rdf:type rdf:Property ;
    rdfs:label 'Coding Accuracy Score' ;
    rdfs:comment 'Accuracy score for this coding assignment.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codingMethod rdf:type rdf:Property ;
    rdfs:label 'Coding Method' ;
    rdfs:comment 'Method of coding (e.g., Manual, CAC-Assisted, Automated).' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grouperVersion rdf:type rdf:Property ;
    rdfs:label 'Grouper Version' ;
    rdfs:comment 'Version of DRG grouper software used.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpcsCodes rdf:type rdf:Property ;
    rdfs:label 'Hcpcs Codes' ;
    rdfs:comment 'HCPCS codes assigned (comma-separated).' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorComplicationComorbidityFlag rdf:type rdf:Property ;
    rdfs:label 'Major Complication Comorbidity Flag' ;
    rdfs:comment 'Indicates presence of MCC.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outlierThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Outlier Threshold Amount' ;
    rdfs:comment 'Outlier threshold amount for high-cost cases.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:presentOnAdmissionIndicators rdf:type rdf:Property ;
    rdfs:label 'Present On Admission Indicators' ;
    rdfs:comment 'POA indicators for each diagnosis (Y/N/U/W).' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique identifier for the payment transaction. Primary key for the payment record.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payerInsuranceCoverageId rdf:type rdf:Property ;
    rdfs:label 'Payer Insurance Coverage Id' ;
    rdfs:comment 'Foreign key linking to patient.insurance_coverage. Business justification: Insurance payments must link to the specific coverage policy under which payment was remitted for EOB reconciliation, contract rate verification, and coordination of benefits processing. Essential for' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InsuranceCoverage .

ind:paymentPlanId rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Id' ;
    rdfs:comment 'Foreign key linking to billing.payment_plan. Business justification: Payments made as part of a payment plan should link to the plan. FK allows tracking which payments are plan installments vs. ad-hoc payments. Cardinality: N payments : 1 payment plan (one plan receive' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentPlan .

ind:remittanceId rdf:type rdf:Property ;
    rdfs:label 'Remittance Id' ;
    rdfs:comment 'Foreign key linking to claim.remittance. Business justification: Payments are posted from remittance advices (835 transactions). Cash application, payment reconciliation, and bank deposit matching require linking payments to the remittance that authorized them. Ess' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Remittance .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The total monetary amount of the payment received, in US dollars (USD). This is the gross payment before any adjustments or allocations.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'The portion of the payment amount that has been applied or allocated to specific charges or account balances, in US dollars (USD).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'The identifier of the payment batch or deposit batch in which this payment was grouped for processing and reconciliation.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The interface or channel through which the payment was received: web portal, mobile app, mail, in-person at facility, phone, or lockbox service.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'The check number for payments made by check. Null for non-check payment methods.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCardLastFour rdf:type rdf:Property ;
    rdfs:label 'Credit Card Last Four' ;
    rdfs:comment 'The last four digits of the credit or debit card number used for the payment, stored for reference and reconciliation purposes. Full card numbers are never stored per PCI DSS compliance.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCardType rdf:type rdf:Property ;
    rdfs:label 'Credit Card Type' ;
    rdfs:comment 'The type or brand of credit or debit card used for the payment: Visa, MasterCard, American Express, Discover, or other. Null for non-card payment methods.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Date' ;
    rdfs:comment 'The date on which the payment was deposited into the healthcare organization\'s bank account or financial system.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eftTraceNumber rdf:type rdf:Property ;
    rdfs:label 'Eft Trace Number' ;
    rdfs:comment 'The trace or reference number for Electronic Funds Transfer (EFT) payments, used for reconciliation and tracking. Null for non-EFT payment methods.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eraFileReference rdf:type rdf:Property ;
    rdfs:label 'Era File Reference' ;
    rdfs:comment 'The identifier of the ERA 835 file from which this payment record was extracted, used for audit and reconciliation purposes.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockboxNumber rdf:type rdf:Property ;
    rdfs:label 'Lockbox Number' ;
    rdfs:comment 'The identifier of the lockbox service or location through which the payment was received, if applicable. Null for non-lockbox payments.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the payment transaction, used for tracking and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'The current lifecycle status of the payment: pending (received but not yet posted), posted (recorded in system), applied (allocated to charges), reversed (payment reversed), refunded (payment returned to payer), or voided (payment cancelled).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'The classification or category of the payment: standard (regular payment against charges), prepayment (payment before service), overpayment (excess payment requiring refund), adjustment (correction or write-off), or settlement (negotiated payment).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'The status of the payment posting and application process: unposted (not yet recorded), posted (recorded but not applied), partially applied (some amount applied), or fully applied (entire amount allocated).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'The amount of this payment that has been refunded to the payer or patient, in US dollars (USD). Null if no refund has been issued.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundDate rdf:type rdf:Property ;
    rdfs:label 'Refund Date' ;
    rdfs:comment 'The date on which the refund was issued to the payer or patient. Null if no refund has been issued.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Flag' ;
    rdfs:comment 'Indicates whether a refund has been issued for this payment. True if refunded, False otherwise.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundReason rdf:type rdf:Property ;
    rdfs:label 'Refund Reason' ;
    rdfs:comment 'The business reason or explanation for issuing the refund, such as overpayment, duplicate payment, or service cancellation. Null if no refund has been issued.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which the payment was reversed or cancelled. Null if the payment has not been reversed.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this payment has been reversed or cancelled. True if reversed, False otherwise.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'The business reason or explanation for reversing the payment, such as duplicate payment, incorrect amount, or payer request. Null if the payment has not been reversed.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'The portion of the payment amount that remains unapplied or unallocated to specific charges, held as credit on the account, in US dollars (USD).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'Unique identifier for the financial adjustment record. Primary key.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealId rdf:type rdf:Property ;
    rdfs:label 'Appeal Id' ;
    rdfs:comment 'Foreign key linking to claim.appeal. Business justification: Appeal resolution workflow: a successful appeal outcome triggers a billing adjustment to reverse a prior write-off or post recovered amounts. Revenue cycle operations require appeal-to-adjustment link' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appeal .

ind:denialId rdf:type rdf:Property ;
    rdfs:label 'Denial Id' ;
    rdfs:comment 'Foreign key linking to claim.denial. Business justification: Denial management workflow: when a denial is resolved via write-off or partial recovery, a billing adjustment is created referencing the originating denial. Denial-to-adjustment traceability is requir' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Denial .

ind:originalAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Original Adjustment Id' ;
    rdfs:comment 'Reference to the original adjustment record that this transaction reverses, if this is a reversal adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:remittanceLineId rdf:type rdf:Property ;
    rdfs:label 'Remittance Line Id' ;
    rdfs:comment 'Foreign key linking to claim.remittance_line. Business justification: ERA posting workflow: each contractual adjustment in billing is sourced from a specific remittance line\'s CARC/RARC codes. Revenue cycle analysts require this link for underpayment variance analysis a' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RemittanceLine .

ind:adjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Adjustment Date' ;
    rdfs:comment 'The business date on which the adjustment was applied to the account, used for financial period assignment and reporting.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Business-facing unique identifier or control number for the adjustment transaction, used for tracking and reconciliation.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle status of the adjustment transaction, indicating whether it is pending approval, posted, reversed, or reconciled.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'High-level classification of the adjustment indicating the nature of the balance modification (contractual write-down, bad debt write-off, charity care, etc.). [ENUM-REF-CANDIDATE: contractual|administrative|bad_debt|charity_care|small_balance|courtesy_discount|recoupment|refund|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Flag' ;
    rdfs:comment 'Indicates whether this adjustment is subject to an active appeal or dispute process. True if under appeal, False otherwise.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Approval or authorization code assigned when the adjustment was authorized, used for audit trail and compliance.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:badDebtReferralDate rdf:type rdf:Property ;
    rdfs:label 'Bad Debt Referral Date' ;
    rdfs:comment 'The date the account was referred to collections or classified as bad debt, relevant for bad debt write-off adjustments.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractRate rdf:type rdf:Property ;
    rdfs:label 'Contract Rate' ;
    rdfs:comment 'The contracted reimbursement rate or allowed amount that drove the contractual adjustment, used for rate variance analysis.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractualPayerName rdf:type rdf:Property ;
    rdfs:label 'Contractual Payer Name' ;
    rdfs:comment 'Name of the insurance payer or contract under which a contractual adjustment was applied, used for variance analysis and contract performance tracking.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eraTraceNumber rdf:type rdf:Property ;
    rdfs:label 'Era Trace Number' ;
    rdfs:comment 'Trace or reference number from the payer\'s Electronic Remittance Advice (ERA) or Explanation of Benefits (EOB) that corresponds to this adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffClassification rdf:type rdf:Property ;
    rdfs:label 'Write Off Classification' ;
    rdfs:comment 'Specific classification for write-off adjustments, distinguishing between bad debt, charity care, small balance write-offs, RAC recoupments, and other categories.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPatientMpiRecordId rdf:type rdf:Property ;
    rdfs:label 'Primary Patient Mpi Record Id' ;
    rdfs:comment 'FK to patient.mpi_record.mpi_record_id — Patient financial accounts must link to the patient master for statement generation, collections, and financial counseling workflows.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MpiRecord .

ind:accountClosedDate rdf:type rdf:Property ;
    rdfs:label 'Account Closed Date' ;
    rdfs:comment 'Date when this patient financial account was closed due to zero balance, write-off, or administrative closure.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Account Opened Date' ;
    rdfs:comment 'Date when this patient financial account was first established in the billing system.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Classification of account receivable age based on days outstanding since last statement or service date, used for collections prioritization.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Approved Discount Percentage' ;
    rdfs:comment 'Percentage discount approved for this account under the financial assistance program, applied to eligible charges.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:badDebtWriteOffDate rdf:type rdf:Property ;
    rdfs:label 'Bad Debt Write Off Date' ;
    rdfs:comment 'Date when the outstanding balance on this account was written off as uncollectible bad debt.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionAgencyName rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Name' ;
    rdfs:comment 'Name of the external collection agency currently handling this account.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionRecallDate rdf:type rdf:Property ;
    rdfs:label 'Collection Recall Date' ;
    rdfs:comment 'Date when this account was recalled from the external collection agency back to internal management.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionRecallReason rdf:type rdf:Property ;
    rdfs:label 'Collection Recall Reason' ;
    rdfs:comment 'Business reason for recalling the account from external collections, such as payment arrangement, dispute resolution, or financial assistance approval.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionReferralDate rdf:type rdf:Property ;
    rdfs:label 'Collection Referral Date' ;
    rdfs:comment 'Date when this account was referred to an external collection agency for recovery of outstanding balance.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Outstanding' ;
    rdfs:comment 'Number of days since the first unpaid charge on this account, used to calculate aging and collection priority.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:familySize rdf:type rdf:Property ;
    rdfs:label 'Family Size' ;
    rdfs:comment 'Number of individuals in the household used to calculate Federal Poverty Level (FPL) percentage for financial assistance eligibility.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financialAssistanceApplicationDate rdf:type rdf:Property ;
    rdfs:label 'Financial Assistance Application Date' ;
    rdfs:comment 'Date when the patient or guarantor submitted an application for charity care or financial assistance for this account.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialAssistanceApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Financial Assistance Approval Status' ;
    rdfs:comment 'Final determination status of the financial assistance application for this account.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAssistanceEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Financial Assistance Effective Date' ;
    rdfs:comment 'Date when the approved financial assistance discount becomes effective for charges on this account.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialAssistanceEligibility rdf:type rdf:Property ;
    rdfs:label 'Financial Assistance Eligibility' ;
    rdfs:comment 'Current determination status of the patient or guarantor eligibility for charity care or financial assistance programs.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAssistanceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Financial Assistance Expiration Date' ;
    rdfs:comment 'Date when the approved financial assistance eligibility expires and must be re-evaluated.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fplPercentage rdf:type rdf:Property ;
    rdfs:label 'Fpl Percentage' ;
    rdfs:comment 'Calculated percentage of the Federal Poverty Level based on household income and family size, used to determine financial assistance eligibility tier.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdIncome rdf:type rdf:Property ;
    rdfs:label 'Household Income' ;
    rdfs:comment 'Total annual household income reported by the patient or guarantor for financial assistance eligibility determination.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceBalance rdf:type rdf:Property ;
    rdfs:label 'Insurance Balance' ;
    rdfs:comment 'Portion of the account balance that is the responsibility of insurance payers.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irs501rComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Irs 501r Compliance Flag' ;
    rdfs:comment 'Indicator of whether all IRS 501(r) requirements have been met for this account, including financial assistance screening and extraordinary collection action restrictions.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalBalance rdf:type rdf:Property ;
    rdfs:label 'Original Balance' ;
    rdfs:comment 'Initial total charges assigned to this account before any payments or adjustments.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patientBalance rdf:type rdf:Property ;
    rdfs:label 'Patient Balance' ;
    rdfs:comment 'Portion of the account balance that is the direct financial responsibility of the patient or guarantor.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveredAmount rdf:type rdf:Property ;
    rdfs:label 'Recovered Amount' ;
    rdfs:comment 'Total dollar amount successfully recovered by the collection agency on this account to date.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referredBalance rdf:type rdf:Property ;
    rdfs:label 'Referred Balance' ;
    rdfs:comment 'Dollar amount of the outstanding balance that was referred to the collection agency at the time of referral.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAdjustments rdf:type rdf:Property ;
    rdfs:label 'Total Adjustments' ;
    rdfs:comment 'Cumulative sum of all contractual adjustments, write-offs, and other balance reductions applied to this account.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPayments rdf:type rdf:Property ;
    rdfs:label 'Total Payments' ;
    rdfs:comment 'Cumulative sum of all payments received on this account from all sources since account inception.' ;
    rdfs:domain ind:PatientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statementId rdf:type rdf:Property ;
    rdfs:label 'Statement Id' ;
    rdfs:comment 'Unique identifier for the patient billing statement. Primary key.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentsApplied rdf:type rdf:Property ;
    rdfs:label 'Adjustments Applied' ;
    rdfs:comment 'Total adjustments (credits, write-offs, contractual adjustments) applied during the current statement cycle.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line 1' ;
    rdfs:comment 'The first line of the guarantor or patient billing address to which the statement was sent.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line 2' ;
    rdfs:comment 'The second line of the guarantor or patient billing address (apartment, suite, unit number).' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'The city of the guarantor or patient billing address.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'The three-letter ISO country code of the guarantor or patient billing address.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'The postal code or ZIP code of the guarantor or patient billing address.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingState rdf:type rdf:Property ;
    rdfs:label 'Billing State' ;
    rdfs:comment 'The state or province of the guarantor or patient billing address.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentCharges rdf:type rdf:Property ;
    rdfs:label 'Current Charges' ;
    rdfs:comment 'New charges added during the current statement cycle that are included in this statement.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycle rdf:type rdf:Property ;
    rdfs:label 'Cycle' ;
    rdfs:comment 'The billing cycle or period identifier for this statement (e.g., monthly cycle, weekly cycle, ad-hoc).' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'The method or channel used to deliver the statement to the guarantor or patient.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The date and time when the statement was delivered or sent to the guarantor or patient.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:financialAssistanceFlag rdf:type rdf:Property ;
    rdfs:label 'Financial Assistance Flag' ;
    rdfs:comment 'Indicates whether the guarantor or patient has been approved for financial assistance or charity care that applies to this statement.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insurancePending rdf:type rdf:Property ;
    rdfs:label 'Insurance Pending' ;
    rdfs:comment 'Amount currently pending adjudication or payment from insurance payers, not yet reflected in patient responsibility.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:message rdf:type rdf:Property ;
    rdfs:label 'Message' ;
    rdfs:comment 'Custom message or note printed on the statement for the guarantor or patient (e.g., payment reminders, financial assistance information).' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPaymentDue rdf:type rdf:Property ;
    rdfs:label 'Minimum Payment Due' ;
    rdfs:comment 'The minimum payment amount requested from the guarantor or patient for this statement cycle.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which payment is requested or expected from the guarantor or patient.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentsReceived rdf:type rdf:Property ;
    rdfs:label 'Payments Received' ;
    rdfs:comment 'Total payments received from the guarantor or patient during the current statement cycle.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'The contact phone number of the guarantor or patient for statement inquiries and follow-up.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousBalance rdf:type rdf:Property ;
    rdfs:label 'Previous Balance' ;
    rdfs:comment 'The outstanding balance carried forward from the prior statement cycle before current charges and payments.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnedMailDate rdf:type rdf:Property ;
    rdfs:label 'Returned Mail Date' ;
    rdfs:comment 'The date when a mailed statement was returned as undeliverable.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnedMailFlag rdf:type rdf:Property ;
    rdfs:label 'Returned Mail Flag' ;
    rdfs:comment 'Indicates whether a mailed paper statement was returned as undeliverable by the postal service.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnedMailReason rdf:type rdf:Property ;
    rdfs:label 'Returned Mail Reason' ;
    rdfs:comment 'The reason provided by the postal service for returning the statement (e.g., address unknown, moved, refused).' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'Externally-known unique statement number printed on the billing statement and used for patient reference and payment tracking.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementStatus rdf:type rdf:Property ;
    rdfs:label 'Statement Status' ;
    rdfs:comment 'Current lifecycle status of the statement indicating its processing and delivery state. [ENUM-REF-CANDIDATE: generated|sent|delivered|returned|paid|partial_paid|outstanding — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementType rdf:type rdf:Property ;
    rdfs:label 'Statement Type' ;
    rdfs:comment 'The format or medium of the statement delivery (paper mailed, electronic via portal, email, SMS notification).' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression Flag' ;
    rdfs:comment 'Indicates whether statement generation and delivery has been suppressed for this account due to patient request, legal hold, or other reason.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'The reason why statement delivery was suppressed (e.g., patient request, deceased, legal hold, bankruptcy).' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBalanceDue rdf:type rdf:Property ;
    rdfs:label 'Total Balance Due' ;
    rdfs:comment 'The total outstanding balance owed by the guarantor or patient as of the statement date, including all charges, adjustments, and prior payments.' ;
    rdfs:domain ind:Statement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when the payment plan was completed, either through full payment or early payoff. Null if plan is still active or was cancelled/defaulted.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementSignedDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Signed Date' ;
    rdfs:comment 'Date when the payment plan agreement was signed by the patient or guarantor.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementSignedFlag rdf:type rdf:Property ;
    rdfs:label 'Agreement Signed Flag' ;
    rdfs:comment 'Indicates whether the patient or guarantor has signed the payment plan agreement. True means a signed agreement is on file, false means signature is pending or not required.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoPayFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Flag' ;
    rdfs:comment 'Indicates whether automatic recurring payments are enabled for this payment plan. True means installments are automatically charged to the stored payment method on the due date, false means manual payment is required.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date when the payment plan was cancelled by either the patient or the healthcare organization.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defaultDate rdf:type rdf:Property ;
    rdfs:label 'Default Date' ;
    rdfs:comment 'Date when the payment plan was declared in default due to missed payments exceeding the grace period.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defaultReason rdf:type rdf:Property ;
    rdfs:label 'Default Reason' ;
    rdfs:comment 'Explanation of why the payment plan defaulted, such as consecutive missed payments, insufficient funds, or patient non-response.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Down Payment Amount' ;
    rdfs:comment 'Initial payment made at the time of plan enrollment, if required. This amount is applied to the balance before installments begin. Expressed in USD.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Channel through which the patient or guarantor enrolled in the payment plan. Patient portal indicates online self-service enrollment, phone indicates enrollment via call center, in-person indicates enrollment at a facility registration or billing desk, mail indicates paper application, email indicates enrollment via email correspondence, and mobile app indicates enrollment through a mobile application.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date when the patient or guarantor enrolled in the payment plan.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financeChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Finance Charge Amount' ;
    rdfs:comment 'Total finance charges or interest applied to the payment plan over its lifetime. Zero for interest-free plans. Expressed in USD.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialAssistanceProgramCode rdf:type rdf:Property ;
    rdfs:label 'Financial Assistance Program Code' ;
    rdfs:comment 'Code identifying the financial assistance or charity care program under which this payment plan was approved, if applicable. Links to the organizations financial assistance policy and eligibility criteria.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of days after the installment due date during which a late payment can be made without penalty or default.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installmentAmount rdf:type rdf:Property ;
    rdfs:label 'Installment Amount' ;
    rdfs:comment 'Fixed amount due for each scheduled installment payment. Expressed in USD.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Installment Frequency' ;
    rdfs:comment 'Frequency at which installment payments are scheduled. Weekly indicates every 7 days, biweekly every 14 days, monthly on the same day each month, quarterly every 3 months, and custom indicates a non-standard schedule.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installmentsPaid rdf:type rdf:Property ;
    rdfs:label 'Installments Paid' ;
    rdfs:comment 'Count of installment payments that have been successfully received and posted to date.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installmentsRemaining rdf:type rdf:Property ;
    rdfs:label 'Installments Remaining' ;
    rdfs:comment 'Count of installment payments still outstanding to complete the payment plan.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interestRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Percentage' ;
    rdfs:comment 'Annual percentage rate (APR) applied to the payment plan balance, if applicable. Zero for interest-free plans. Expressed as a percentage (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Late Fee Amount' ;
    rdfs:comment 'Standard late fee charged for each missed or late installment payment, as defined in the payment plan agreement. Expressed in USD.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:missedPaymentsCount rdf:type rdf:Property ;
    rdfs:label 'Missed Payments Count' ;
    rdfs:comment 'Total number of installment payments that were missed or not received by the due date during the life of the payment plan.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextPaymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Payment Due Date' ;
    rdfs:comment 'Date when the next scheduled installment payment is due. Null if plan is completed, cancelled, or defaulted.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfInstallments rdf:type rdf:Property ;
    rdfs:label 'Number Of Installments' ;
    rdfs:comment 'Total number of scheduled installment payments required to complete the payment plan.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Original Balance Amount' ;
    rdfs:comment 'Total outstanding patient balance at the time the payment plan was established. This is the starting principal amount before any plan payments are applied. Expressed in USD.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Primary payment instrument used for installment payments. Credit card and debit card indicate card-based payments, ACH (Automated Clearing House) indicates electronic bank transfer, check indicates paper check, cash indicates in-person cash payment, and money order indicates certified payment instrument.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

