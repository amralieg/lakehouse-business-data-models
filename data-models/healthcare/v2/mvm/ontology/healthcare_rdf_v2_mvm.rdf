    rdfs:range xsd:string .

ind:legalRepresentativePhone rdf:type rdf:Property ;
    rdfs:label 'Legal Representative Phone' ;
    rdfs:comment 'Contact phone number for the legal representative or authorized decision-maker.' ;
    rdfs:domain ind:TreatmentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalRepresentativeRelationship rdf:type rdf:Property ;
