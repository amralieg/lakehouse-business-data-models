    rdfs:range xsd:boolean .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Total cost paid to acquire the instrument, including purchase price, shipping, installation, and initial setup fees. Expressed in USD.' ;
