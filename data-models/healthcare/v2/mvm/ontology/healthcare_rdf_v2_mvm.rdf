    rdfs:domain ind:TreatmentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalRepresentativeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Representative Required Flag' ;
    rdfs:comment 'Indicates whether a legal representative or authorized decision-maker was required to provide consent on behalf of the patient due to lack of capacity.' ;
    rdfs:domain ind:TreatmentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientQuestionsAddressedFlag rdf:type rdf:Property ;
    rdfs:label 'Patient Questions Addressed Flag' ;
    rdfs:comment 'Indicates whether the patient or authorized representative had the opportunity to ask questions and all questions were addressed prior to obtaining consent.' ;
    rdfs:domain ind:TreatmentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientQuestionsNotes rdf:type rdf:Property ;
    rdfs:label 'Patient Questions Notes' ;
    rdfs:comment 'Free-text documentation of specific questions asked by the patient or authorized representative and the responses provided.' ;
    rdfs:domain ind:TreatmentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revokedByName rdf:type rdf:Property ;
    rdfs:label 'Revoked By Name' ;
    rdfs:comment 'Name of the individual (patient or authorized representative) who revoked the consent.' ;
    rdfs:domain ind:TreatmentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:risksDocumented rdf:type rdf:Property ;
    rdfs:label 'Risks Documented' ;
    rdfs:comment 'Narrative documentation of the material risks of the procedure or treatment that were disclosed to and discussed with the patient or authorized representative.' ;
    rdfs:domain ind:TreatmentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessRole rdf:type rdf:Property ;
    rdfs:label 'Witness Role' ;
    rdfs:comment 'The role or title of the witness (e.g., registered nurse, social worker, patient advocate).' ;
    rdfs:domain ind:TreatmentConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationId rdf:type rdf:Property ;
    rdfs:label 'Revocation Id' ;
    rdfs:comment 'Unique identifier for the consent revocation record. Primary key for the consent revocation entity.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorRevocationId rdf:type rdf:Property ;
    rdfs:label 'Prior Revocation Id' ;
    rdfs:comment 'Self-referencing FK on revocation (prior_revocation_id)' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Revocation .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking to detailed audit trail records for all actions taken in response to this revocation, maintained for regulatory compliance.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Internal notes regarding compliance considerations, special handling requirements, or regulatory reporting obligations related to this revocation.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataAccessRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Data Access Restricted Flag' ;
    rdfs:comment 'Indicates whether data access controls have been updated to restrict access based on the revoked consent.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataAccessRestrictedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Access Restricted Timestamp' ;
    rdfs:comment 'The date and time when data access restrictions were implemented in response to the consent revocation.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disclosuresHaltedFlag rdf:type rdf:Property ;
    rdfs:label 'Disclosures Halted Flag' ;
    rdfs:comment 'Indicates whether ongoing or future disclosures of Protected Health Information (PHI) have been halted as a result of this revocation.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disclosuresHaltedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disclosures Halted Timestamp' ;
    rdfs:comment 'The date and time when disclosure processes were halted in response to the consent revocation.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:irrevocableActionsDescription rdf:type rdf:Property ;
    rdfs:label 'Irrevocable Actions Description' ;
    rdfs:comment 'Free-text description of any actions taken under the original consent that cannot be reversed or undone despite the revocation (e.g., data already shared with third parties, research already conducted).' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completed Flag' ;
    rdfs:comment 'Indicates whether required legal review has been completed for this revocation.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required Flag' ;
    rdfs:comment 'Indicates whether this revocation requires legal review before being processed (e.g., complex partial revocations, disputes, or high-risk scenarios).' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Legal Review Timestamp' ;
    rdfs:comment 'The date and time when legal review of the revocation was completed.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalReviewerNotes rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer Notes' ;
    rdfs:comment 'Confidential notes from legal counsel regarding the revocation review, including any special handling instructions or risk assessments.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether notification of the revocation was sent to relevant parties (providers, research teams, business associates, etc.).' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'The date and time when notifications regarding the consent revocation were sent to affected parties.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partialRevocationDetails rdf:type rdf:Property ;
    rdfs:label 'Partial Revocation Details' ;
    rdfs:comment 'Free-text description of which specific portions of the consent are being revoked when revocation_scope is partial. Null when revocation is full.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Patient Notification Sent Flag' ;
    rdfs:comment 'Indicates whether confirmation notification was sent to the patient acknowledging receipt and processing of their revocation.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Patient Notification Timestamp' ;
    rdfs:comment 'The date and time when confirmation notification was sent to the patient regarding their consent revocation.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorDisclosuresCount rdf:type rdf:Property ;
    rdfs:label 'Prior Disclosures Count' ;
    rdfs:comment 'The number of disclosures that occurred under the original consent prior to revocation and that cannot be undone or recalled.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorDisclosuresSummary rdf:type rdf:Property ;
    rdfs:label 'Prior Disclosures Summary' ;
    rdfs:comment 'Summary description of disclosures that occurred prior to revocation and cannot be undone, maintained for legal audit trail and patient notification.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Optional free-text explanation provided by the patient describing why they are revoking consent. May be blank if patient chose not to provide a reason.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationNumber rdf:type rdf:Property ;
    rdfs:label 'Revocation Number' ;
    rdfs:comment 'Business-facing unique identifier or tracking number assigned to this consent revocation for reference and audit purposes.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationStatus rdf:type rdf:Property ;
    rdfs:label 'Revocation Status' ;
    rdfs:comment 'Current processing status of the consent revocation within the organization\'s workflow (e.g., pending review, processed and effective, rejected due to invalid submission).' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Revocation Timestamp' ;
    rdfs:comment 'The precise date and time when the consent revocation was submitted or recorded in the system. Provides exact temporal audit trail for legal compliance.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'Indicates whether the revocation applies to the entire consent (full) or only specific portions of the consent (partial).' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessSignatureFlag rdf:type rdf:Property ;
    rdfs:label 'Witness Signature Flag' ;
    rdfs:comment 'Indicates whether a witness signature was obtained on the revocation document.' ;
    rdfs:domain ind:Revocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acknowledgingOrgProviderId rdf:type rdf:Property ;
    rdfs:label 'Acknowledging Org Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.org_provider. Business justification: HIPAA requires covered entities to document NPP acknowledgment at each facility location (45 CFR 164.520). Multi-facility compliance reporting and OCR audit responses require knowing which org_provide' ;
    rdfs:domain ind:NppAcknowledgment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgProvider .

ind:primaryPreviousNppAcknowledgmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Previous Npp Acknowledgment Id' ;
    rdfs:comment 'Identifier of the previous NPP acknowledgment record for this patient, if this is a re-acknowledgment following a material change.' ;
    rdfs:domain ind:NppAcknowledgment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NppAcknowledgment .

ind:accessibilityAccommodation rdf:type rdf:Property ;
    rdfs:label 'Accessibility Accommodation' ;
    rdfs:comment 'Description of any accessibility accommodations provided (e.g., large print, Braille, audio recording, sign language interpreter).' ;
    rdfs:domain ind:NppAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentLocation rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Location' ;
    rdfs:comment 'Physical or virtual location where the acknowledgment was obtained. [ENUM-REF-CANDIDATE: registration_desk|patient_room|emergency_department|outpatient_clinic|patient_portal|home|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NppAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentMethod rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Method' ;
    rdfs:comment 'Method by which the patient provided acknowledgment (paper signature, electronic signature, patient portal click-through, email confirmation, kiosk acceptance, verbal acknowledgment documented by staff).' ;
    rdfs:domain ind:NppAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Timestamp' ;
    rdfs:comment 'Precise date and time when the patient acknowledged receipt of the NPP, particularly important for electronic acknowledgments.' ;
    rdfs:domain ind:NppAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:goodFaithEffortDocumentation rdf:type rdf:Property ;
    rdfs:label 'Good Faith Effort Documentation' ;
    rdfs:comment 'Free-text documentation of the good-faith effort made to obtain acknowledgment when it could not be secured.' ;
    rdfs:domain ind:NppAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodFaithEffortReason rdf:type rdf:Property ;
    rdfs:label 'Good Faith Effort Reason' ;
    rdfs:comment 'Reason why acknowledgment could not be obtained despite good-faith effort, as permitted under 45 CFR 164.520(c)(2)(ii).' ;
    rdfs:domain ind:NppAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interpreterUsed rdf:type rdf:Property ;
    rdfs:label 'Interpreter Used' ;
    rdfs:comment 'Indicates whether an interpreter was used to explain the NPP to the patient.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address from which the electronic acknowledgment was submitted, for audit trail purposes.' ;
    rdfs:domain ind:NppAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFirstServiceAcknowledgment rdf:type rdf:Property ;
    rdfs:label 'Is First Service Acknowledgment' ;
    rdfs:comment 'Indicates whether this acknowledgment was obtained at the first service delivery as required by 45 CFR 164.520(c)(1).' ;
    rdfs:domain ind:NppAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialChangeAcknowledgment rdf:type rdf:Property ;
    rdfs:label 'Material Change Acknowledgment' ;
    rdfs:comment 'Indicates whether this acknowledgment was obtained following a material change to the NPP, requiring re-acknowledgment.' ;
    rdfs:domain ind:NppAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:representativeAuthorityDocumented rdf:type rdf:Property ;
    rdfs:label 'Representative Authority Documented' ;
    rdfs:comment 'Indicates whether the authority of a personal representative to act on behalf of the patient was documented and verified.' ;
    rdfs:domain ind:NppAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Signature Captured' ;
    rdfs:comment 'Indicates whether a patient or representative signature was captured as part of the acknowledgment.' ;
    rdfs:domain ind:NppAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureType rdf:type rdf:Property ;
    rdfs:label 'Signature Type' ;
    rdfs:comment 'Type of signature captured (wet ink on paper, electronic stylus, digital certificate-based, biometric, or none if acknowledgment was obtained without signature).' ;
    rdfs:domain ind:NppAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signerName rdf:type rdf:Property ;
    rdfs:label 'Signer Name' ;
    rdfs:comment 'Full name of the individual who signed the acknowledgment (patient or authorized representative).' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signerRelationship rdf:type rdf:Property ;
    rdfs:label 'Signer Relationship' ;
    rdfs:comment 'Relationship of the signer to the patient (self if patient signed, or representative role). [ENUM-REF-CANDIDATE: self|parent|legal_guardian|power_of_attorney|healthcare_proxy|personal_representative|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededRestrictionRequestId rdf:type rdf:Property ;
    rdfs:label 'Superseded Restriction Request Id' ;
    rdfs:comment 'Self-referencing FK on restriction_request (superseded_restriction_request_id)' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RestrictionRequest .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'The date of the most recent compliance review of this restriction request to ensure ongoing adherence to HIPAA and HITECH requirements.' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionMadeBy rdf:type rdf:Property ;
    rdfs:label 'Decision Made By' ;
    rdfs:comment 'The name or role of the individual or committee who made the decision on the restriction request (e.g., Privacy Officer, HIM Director).' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'The business and regulatory rationale for the organization\'s decision to accept or deny the restriction request. Required for audit and patient communication.' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalInstructions rdf:type rdf:Property ;
    rdfs:label 'Operational Instructions' ;
    rdfs:comment 'Detailed operational instructions for clinical, billing, and administrative staff on how to honor the restriction across Electronic Health Record (EHR), Revenue Cycle Management (RCM), Health Information Exchange (HIE), and other systems.' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationDecision rdf:type rdf:Property ;
    rdfs:label 'Organization Decision' ;
    rdfs:comment 'The covered entity\'s decision on whether to accept or deny the restriction request. HITECH out-of-pocket restrictions must be accepted; other restrictions are discretionary.' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfPocketPaymentVerified rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Payment Verified' ;
    rdfs:comment 'Indicates whether the patient\'s claim of out-of-pocket payment has been verified for HITECH mandatory restrictions. True if verified, False if not applicable or not verified.' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Patient Notification Date' ;
    rdfs:comment 'The date the patient was notified of the organization\'s decision on the restriction request or any subsequent changes to the restriction status.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patientNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Patient Notification Method' ;
    rdfs:comment 'The method used to notify the patient of the decision or status change. [ENUM-REF-CANDIDATE: mail|email|patient_portal|phone|in_person|secure_message|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Payment Verification Date' ;
    rdfs:comment 'The date the out-of-pocket payment was verified for HITECH mandatory restrictions, if applicable.' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestMethod rdf:type rdf:Property ;
    rdfs:label 'Request Method' ;
    rdfs:comment 'The method by which the patient submitted the restriction request. [ENUM-REF-CANDIDATE: written_form|verbal|patient_portal|email|fax|mail|in_person|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Business-assigned unique identifier for the restriction request, used for tracking and reference in correspondence and workflows.' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingPartyRelationship rdf:type rdf:Property ;
    rdfs:label 'Requesting Party Relationship' ;
    rdfs:comment 'The relationship of the individual submitting the restriction request to the patient, if not the patient themselves.' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedPhiCategory rdf:type rdf:Property ;
    rdfs:label 'Restricted Phi Category' ;
    rdfs:comment 'The category of Protected Health Information (PHI) the patient is requesting to restrict. Used for operational filtering and enforcement. [ENUM-REF-CANDIDATE: all_phi|diagnosis_codes|procedure_codes|lab_results|radiology_reports|medication_records|mental_health_records|substance_abuse_records|genetic_information|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedPurpose rdf:type rdf:Property ;
    rdfs:label 'Restricted Purpose' ;
    rdfs:comment 'The purpose of use or disclosure that the patient is requesting to restrict (e.g., restrict disclosure for payment purposes to a specific payer). [ENUM-REF-CANDIDATE: treatment|payment|healthcare_operations|research|public_health|all_purposes|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedRecipientName rdf:type rdf:Property ;
    rdfs:label 'Restricted Recipient Name' ;
    rdfs:comment 'The specific name of the individual, organization, or health plan to whom the restriction applies, if identified by the patient.' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedRecipientType rdf:type rdf:Property ;
    rdfs:label 'Restricted Recipient Type' ;
    rdfs:comment 'The type of recipient or entity to whom the patient is requesting disclosure restrictions apply. [ENUM-REF-CANDIDATE: health_plan|family_member|employer|specific_provider|health_information_exchange|research_entity|public_health_authority|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionScope rdf:type rdf:Property ;
    rdfs:label 'Restriction Scope' ;
    rdfs:comment 'Detailed narrative describing the scope of the requested restriction, including specific Protected Health Information (PHI) data elements, recipients, purposes, or time periods the patient wishes to restrict.' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionStatus rdf:type rdf:Property ;
    rdfs:label 'Restriction Status' ;
    rdfs:comment 'The current lifecycle status of the restriction. Active restrictions must be enforced across all clinical and administrative systems.' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'The category of restriction requested by the patient. HITECH out-of-pocket payer restriction is mandatory per 45 CFR 164.522(a)(1)(vi); other types are discretionary.' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationMethod rdf:type rdf:Property ;
    rdfs:label 'Revocation Method' ;
    rdfs:comment 'The method by which the patient revoked the restriction, if applicable. [ENUM-REF-CANDIDATE: written_form|verbal|patient_portal|email|fax|mail|in_person|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Reference' ;
    rdfs:comment 'Reference identifier or location of supporting documentation submitted with the restriction request (e.g., signed forms, proof of out-of-pocket payment for HITECH restrictions).' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'System Enforcement Flag' ;
    rdfs:comment 'Indicates whether the restriction is actively enforced through automated system controls (True) or requires manual staff intervention (False).' ;
    rdfs:domain ind:RestrictionRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disclosingClinicianId rdf:type rdf:Property ;
    rdfs:label 'Disclosing Clinician Id' ;
    rdfs:comment 'Foreign key linking to provider.clinician. Business justification: HIPAA accounting of disclosures (45 CFR 164.528) requires identifying which clinician released PHI. Compliance audits and breach investigations depend on this link. disclosure_initiated_by_role confir' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:disclosureRecordId rdf:type rdf:Property ;
    rdfs:label 'Disclosure Record Id' ;
    rdfs:comment 'Reference to the consent or authorization record under which this disclosure was made. Links to the consent product.' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Record .

ind:parentDisclosureLogId rdf:type rdf:Property ;
    rdfs:label 'Parent Disclosure Log Id' ;
    rdfs:comment 'Self-referencing FK on disclosure_log (related_disclosure_log_id)' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisclosureLog .

ind:primaryDisclosureConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Primary Disclosure Consent Record Id' ;
    rdfs:comment 'Foreign key linking to consent.consent_record. Business justification: The consent_record product description explicitly states it is \'Referenced by disclosure_consent_record_id\', and disclosure_log records every PHI disclosure made under a patient consent or authorizati' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Record .

ind:recipientNpiRegistryId rdf:type rdf:Property ;
    rdfs:label 'Recipient Npi Registry Id' ;
    rdfs:comment 'Foreign key linking to reference.npi_registry. Business justification: HIPAA accounting of disclosures requires identifying NPI-registered recipients (covered entities, business associates). Linking disclosure_log to npi_registry enables automated compliance reports and ' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NpiRegistry .

ind:disclosureDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Date' ;
    rdfs:comment 'The date on which the Protected Health Information (PHI) disclosure occurred. Required for HIPAA Accounting of Disclosures per 45 CFR 164.528.' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disclosureInitiatedBy rdf:type rdf:Property ;
    rdfs:label 'Disclosure Initiated By' ;
    rdfs:comment 'The name or identifier of the individual or system that initiated the disclosure. Supports audit trail and accountability.' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureInitiatedByRole rdf:type rdf:Property ;
    rdfs:label 'Disclosure Initiated By Role' ;
    rdfs:comment 'The role or job title of the individual who initiated the disclosure, such as physician, nurse, HIM specialist, or system administrator. Supports role-based access auditing.' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureMethod rdf:type rdf:Property ;
    rdfs:label 'Disclosure Method' ;
    rdfs:comment 'The method or channel by which the Protected Health Information (PHI) was disclosed. Supports security analysis and breach risk assessment. [ENUM-REF-CANDIDATE: electronic|paper|verbal|fax|secure_email|hie|api|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureNotes rdf:type rdf:Property ;
    rdfs:label 'Disclosure Notes' ;
    rdfs:comment 'Additional notes, comments, or context regarding the disclosure. Provides supplementary information for audit and compliance review.' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosurePurpose rdf:type rdf:Property ;
    rdfs:label 'Disclosure Purpose' ;
    rdfs:comment 'The stated purpose or reason for the Protected Health Information (PHI) disclosure. Required for HIPAA Accounting of Disclosures per 45 CFR 164.528.' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosurePurposeCategory rdf:type rdf:Property ;
    rdfs:label 'Disclosure Purpose Category' ;
    rdfs:comment 'The standardized category of the disclosure purpose. Enables aggregation and reporting of disclosures by purpose type for compliance and analytics. [ENUM-REF-CANDIDATE: treatment|payment|operations|research|public_health|legal|patient_request|court_order|law_enforcement|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Disclosure Status' ;
    rdfs:comment 'The current status of the disclosure transaction. Tracks the lifecycle state of the disclosure event.' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disclosure Timestamp' ;
    rdfs:comment 'The precise date and time when the Protected Health Information (PHI) disclosure occurred. Provides granular audit trail for compliance and security investigations.' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAccountingRequired rdf:type rdf:Property ;
    rdfs:label 'Is Accounting Required' ;
    rdfs:comment 'Indicates whether this disclosure must be included in the HIPAA Accounting of Disclosures report provided to patients upon request. Non-TPO disclosures are subject to accounting per 45 CFR 164.528.' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTpoDisclosure rdf:type rdf:Property ;
    rdfs:label 'Is Tpo Disclosure' ;
    rdfs:comment 'Indicates whether the disclosure was made for Treatment, Payment, or Operations (TPO) purposes. TPO disclosures are exempt from HIPAA Accounting of Disclosures requirements per 45 CFR 164.528.' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The legal or regulatory basis that permitted or required the disclosure, such as court order, subpoena, public health reporting requirement, or patient authorization.' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumNecessaryApplied rdf:type rdf:Property ;
    rdfs:label 'Minimum Necessary Applied' ;
    rdfs:comment 'Indicates whether the minimum necessary standard was applied to limit the Protected Health Information (PHI) disclosed to only what was reasonably necessary for the stated purpose, as required by 45 CFR 164.502(b).' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Patient Notification Required' ;
    rdfs:comment 'Indicates whether the patient must be notified of this disclosure under HIPAA or organizational policy. Certain disclosures require patient notification.' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phiElementsDisclosed rdf:type rdf:Property ;
    rdfs:label 'Phi Elements Disclosed' ;
    rdfs:comment 'Description of the specific Protected Health Information (PHI) elements or data categories that were disclosed. Required for HIPAA Accounting of Disclosures.' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientIdentifier rdf:type rdf:Property ;
    rdfs:label 'Recipient Identifier' ;
    rdfs:comment 'The unique identifier for the recipient, such as National Provider Identifier (NPI), Tax ID, or organizational identifier. Enables precise tracking of disclosure recipients.' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientType rdf:type rdf:Property ;
    rdfs:label 'Recipient Type' ;
    rdfs:comment 'The category of recipient to whom the Protected Health Information (PHI) was disclosed. Supports classification and reporting of disclosure patterns. [ENUM-REF-CANDIDATE: individual|organization|government_agency|health_plan|clearinghouse|business_associate|research_institution|public_health_authority|law_enforcement|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingOrgProviderId rdf:type rdf:Property ;
    rdfs:label 'Issuing Org Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.org_provider. Business justification: Consent records are issued under a specific facility\'s authority and retention policies. Multi-facility health systems require facility-level consent tracking for state regulatory compliance, retentio' ;
    rdfs:domain ind:Record ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgProvider .

ind:obtainingClinicianId rdf:type rdf:Property ;
    rdfs:label 'Obtaining Clinician Id' ;
    rdfs:comment 'Foreign key linking to provider.clinician. Business justification: Joint Commission and CMS Conditions of Participation require documenting which clinician obtained informed consent. Credentialing reviews, malpractice defense, and consent validity audits depend on th' ;
    rdfs:domain ind:Record ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:primarySupersededByConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Consent Record Id' ;
    rdfs:comment 'Self-reference to the consent record that replaces this one when a patient re-consents or updates their authorization, preserving consent version lineage.' ;
    rdfs:domain ind:Record ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Record .

ind:appliesToMinor rdf:type rdf:Property ;
    rdfs:label 'Applies To Minor' ;
    rdfs:comment 'Indicates whether the consent pertains to a minor patient, triggering guardian-consent and age-of-majority transition handling.' ;
    rdfs:domain ind:Record ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:canRevoke rdf:type rdf:Property ;
    rdfs:label 'Can Revoke' ;
    rdfs:comment 'Indicates whether the patient retains the right to revoke this consent, noting that some research and prior-disclosure consents are not fully revocable.' ;
    rdfs:domain ind:Record ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentDirection rdf:type rdf:Property ;
    rdfs:label 'Consent Direction' ;
    rdfs:comment 'Indicates whether the consent grants (permit) or restricts (deny) the described activity, supporting opt-in versus opt-out semantics for HIE and data sharing.' ;
    rdfs:domain ind:Record ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentNumber rdf:type rdf:Property ;
    rdfs:label 'Consent Number' ;
    rdfs:comment 'Externally-known human-readable business reference number for the consent record, used on documents and in patient communications.' ;
    rdfs:domain ind:Record ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Record Status' ;
    rdfs:comment 'Current lifecycle state of the consent record, driving whether the consent is enforceable for data access, treatment, or disclosure decisions.' ;
    rdfs:domain ind:Record ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUri rdf:type rdf:Property ;
    rdfs:label 'Document Uri' ;
    rdfs:comment 'Storage location reference for the scanned or electronic signed consent document, enabling retrieval of the original legal artifact.' ;
    rdfs:domain ind:Record ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includesSensitiveData rdf:type rdf:Property ;
    rdfs:label 'Includes Sensitive Data' ;
    rdfs:comment 'Indicates whether the consent covers specially-protected sensitive information such as substance use, behavioral health, or HIV status requiring heightened controls.' ;
    rdfs:domain ind:Record ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLegallyAuthorizedRepresentative rdf:type rdf:Property ;
    rdfs:label 'Is Legally Authorized Representative' ;
    rdfs:comment 'Indicates whether the consent was provided by a legally authorized representative on behalf of the patient, requiring documentation of authority.' ;
    rdfs:domain ind:Record ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purposeOfUse rdf:type rdf:Property ;
    rdfs:label 'Purpose Of Use' ;
    rdfs:comment 'Authorized purpose for which the protected health information may be used or disclosed under this consent, aligned with HIPAA permitted-purpose categories.' ;
    rdfs:domain ind:Record ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Narrative description of the specific information categories, purposes, and recipients covered by this consent, defining the permitted use boundary.' ;
    rdfs:domain ind:Record ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date the patient or authorized representative signed and executed the consent, establishing the principal real-world consent event.' ;
    rdfs:domain ind:Record ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Date on which the patient revoked or withdrew the consent; nullable while consent remains active.' ;
    rdfs:domain ind:Record ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalMethod rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Method' ;
    rdfs:comment 'Channel through which the patient communicated their revocation, supporting validity verification of the withdrawal.' ;
    rdfs:domain ind:Record ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Documented reason the patient provided for revoking the consent, supporting audit and patient-rights reporting.' ;
    rdfs:domain ind:Record ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessSignedDate rdf:type rdf:Property ;
    rdfs:label 'Witness Signed Date' ;
    rdfs:comment 'Date the witness signed and attested to the consent execution.' ;
    rdfs:domain ind:Record ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lasaPairId rdf:type rdf:Property ;
    rdfs:label 'Lasa Pair Id' ;
    rdfs:comment 'Primary key for the lasa_pair association' ;
    rdfs:domain ind:LasaPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lasaDrugMasterId rdf:type rdf:Property ;
    rdfs:label 'Lasa Drug Master Id' ;
    rdfs:comment 'Foreign key linking to the first drug in the LASA pair (Drug A). The pairing is symmetric — Drug A and Drug B roles are interchangeable by convention.' ;
    rdfs:domain ind:LasaPair ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugMaster .

ind:primaryLasaPartnerDrugMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Lasa Partner Drug Master Id' ;
    rdfs:comment 'Foreign key linking to the second drug in the LASA pair (Drug B / the LASA partner). Distinct attribute name used to disambiguate the two FK references to the same table.' ;
    rdfs:domain ind:LasaPair ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugMaster .

ind:alertLevel rdf:type rdf:Property ;
    rdfs:label 'Alert Level' ;
    rdfs:comment 'The severity level of the LASA alert triggered when either drug in the pair is ordered or dispensed. Drives clinical decision support alert thresholds in prescribing and dispensing workflows.' ;
    rdfs:domain ind:LasaPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inactiveDate rdf:type rdf:Property ;
    rdfs:label 'Inactive Date' ;
    rdfs:comment 'The date on which this LASA pair designation was retired or deactivated. Null if the pair is currently active. Supports historical audit of pair lifecycle changes.' ;
    rdfs:domain ind:LasaPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ismpReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Ismp Reported Flag' ;
    rdfs:comment 'Indicates whether this specific LASA pair has been formally reported and published on the ISMP LASA drug list. Pairs not on the ISMP list may be organization-defined local pairs.' ;
    rdfs:domain ind:LasaPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lasaDrugPairs rdf:type rdf:Property ;
    rdfs:label 'Lasa Drug Pairs' ;
    rdfs:comment 'Comma-separated list of drug names that are commonly confused with this drug due to similar appearance or pronunciation, used for clinical decision support and error prevention. [Moved from drug_master: This denormalized STRING column stores comma-separated LASA partner drug names on drug_master. It cannot support proper querying, alerting, or historical tracking. All LASA pair information is now fully represented in the lasa_pair association product with proper FK references and pair-level attributes. This column should be deprecated and removed from drug_master.]' ;
    rdfs:domain ind:LasaPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pairType rdf:type rdf:Property ;
    rdfs:label 'Pair Type' ;
    rdfs:comment 'Classifies whether the LASA confusion risk is due to visual similarity (look-alike), phonetic similarity (sound-alike), or both. Drives alert presentation in dispensing and prescribing systems.' ;
    rdfs:domain ind:LasaPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
