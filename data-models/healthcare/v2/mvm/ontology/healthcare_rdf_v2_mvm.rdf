ind:onCallType rdf:type rdf:Property ;
    rdfs:label 'On Call Type' ;
    rdfs:comment 'The type of on-call availability when availability_type is on_call: primary (first responder), backup (secondary coverage), home (available from home), hospital (on-site coverage).' ;
