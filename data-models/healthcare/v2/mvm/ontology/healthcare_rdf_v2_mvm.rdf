ind:principalDiagnosisId rdf:type rdf:Property ;
    rdfs:label 'Principal Diagnosis Id' ;
    rdfs:comment 'Foreign key linking to clinical.diagnosis. Business justification: Clinical notes (discharge summaries, H&P, progress notes) are often written in the context of a principal diagnosis. note.principal_diagnosis_code (STRING) stores this as a denormalized code. Replacin' ;
