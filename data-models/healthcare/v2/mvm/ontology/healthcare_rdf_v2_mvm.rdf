ind:patientAccountId rdf:type rdf:Property ;
    rdfs:label 'Patient Account Id' ;
    rdfs:comment 'Foreign key linking to billing.patient_account. Business justification: Charges are posted to patient financial accounts in RCM systems (Epic Resolute, Cerner Revenue Cycle). The patient_account is the financial aggregation entity that tracks all charges, payments, and ad' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatientAccount .

ind:primaryChargeClinicianId rdf:type rdf:Property ;
