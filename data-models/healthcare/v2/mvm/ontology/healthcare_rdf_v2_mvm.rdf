ind:ageRangeMax rdf:type rdf:Property ;
    rdfs:label 'Age Range Max' ;
    rdfs:comment 'Maximum patient age (in years) that the provider accepts within this network affiliation. Null indicates no upper age limit. Used for provider directory filtering and patient-to-provider matching.' ;
    rdfs:domain ind:NetworkAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeMin rdf:type rdf:Property ;
    rdfs:label 'Age Range Min' ;
    rdfs:comment 'Minimum patient age (in years) that the provider accepts within this network affiliation. Used for provider directory filtering and patient-to-provider matching in managed care systems.' ;
    rdfs:domain ind:NetworkAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:directoryPublishedFlag rdf:type rdf:Property ;
    rdfs:label 'Directory Published Flag' ;
    rdfs:comment 'Indicates whether this provider network affiliation record has been published in the payer\'s public-facing provider directory. CMS requires accurate and up-to-date provider directories for all Medicare Advantage and Marketplace plans.' ;
    rdfs:domain ind:NetworkAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderServed rdf:type rdf:Property ;
    rdfs:label 'Gender Served' ;
    rdfs:comment 'Indicates the patient gender population served by the provider within this network (e.g., all genders, male only, female only, pediatric). Used for provider directory accuracy and patient matching.' ;
    rdfs:domain ind:NetworkAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicServiceArea rdf:type rdf:Property ;
    rdfs:label 'Geographic Service Area' ;
    rdfs:comment 'Description of the geographic region or service area covered by this network affiliation (e.g., state name, county, metropolitan statistical area, or CMS-defined service area). Used for network adequacy geographic analysis and CMS service area filings.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handicapAccessible rdf:type rdf:Property ;
    rdfs:label 'Handicap Accessible' ;
    rdfs:comment 'Indicates whether the provider\'s practice location associated with this network affiliation is handicap accessible per ADA requirements. Required for CMS provider directory accuracy and ADA compliance reporting.' ;
    rdfs:domain ind:NetworkAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hospitalAffiliationFlag rdf:type rdf:Property ;
    rdfs:label 'Hospital Affiliation Flag' ;
    rdfs:comment 'Indicates whether this network affiliation record pertains to a hospital or facility provider (as opposed to an individual clinician). Used to distinguish facility-level from practitioner-level network participation in directory and adequacy reporting.' ;
    rdfs:domain ind:NetworkAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagesSpoken rdf:type rdf:Property ;
    rdfs:label 'Languages Spoken' ;
    rdfs:comment 'Comma-separated list of languages spoken by the provider at this network location, using ISO 639-1 language codes. Required for provider directory accuracy and CMS language access compliance under Section 1557 of the ACA.' ;
    rdfs:domain ind:NetworkAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkTier rdf:type rdf:Property ;
    rdfs:label 'Network Tier' ;
    rdfs:comment 'Tiered network designation indicating the provider\'s cost and quality tier within the payer\'s network structure. Tier 1 typically represents highest-value providers with lowest patient cost-sharing; higher tiers carry greater patient out-of-pocket costs.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelCapacity rdf:type rdf:Property ;
    rdfs:label 'Panel Capacity' ;
    rdfs:comment 'Maximum number of patients the provider is willing to accept within this network. Used for network adequacy analysis and patient assignment in managed care models such as HMO and ACO.' ;
    rdfs:domain ind:NetworkAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:panelCurrentCount rdf:type rdf:Property ;
    rdfs:label 'Panel Current Count' ;
    rdfs:comment 'Current number of attributed or assigned patients on the provider\'s panel within this network. Used alongside panel_capacity to determine panel availability and support network adequacy reporting.' ;
    rdfs:domain ind:NetworkAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:panelStatus rdf:type rdf:Property ;
    rdfs:label 'Panel Status' ;
    rdfs:comment 'Indicates whether the provider\'s patient panel is open to new patients, closed, or accepting only limited new patients within this network. Critical for network adequacy reporting and patient access compliance required by CMS.' ;
    rdfs:domain ind:NetworkAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationType rdf:type rdf:Property ;
    rdfs:label 'Participation Type' ;
    rdfs:comment 'Defines the provider\'s participation classification within the network. Determines patient cost-sharing levels and reimbursement rates. \'preferred\' indicates a higher-tier in-network designation with lower patient cost-sharing.' ;
    rdfs:domain ind:NetworkAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementModel rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Model' ;
    rdfs:comment 'The payment model under which the provider is reimbursed for services rendered to patients in this network. Drives financial analytics and value-based care program tracking. [ENUM-REF-CANDIDATE: fee_for_service|capitation|bundled_payment|value_based|salary|per_diem — promote to reference product if additional models are needed]' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaState rdf:type rdf:Property ;
    rdfs:label 'Service Area State' ;
    rdfs:comment 'Two-letter US state code for the primary state in which the provider participates in this network. Used for state-level network adequacy reporting and licensure validation.' ;
    rdfs:domain ind:NetworkAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaZipCode rdf:type rdf:Property ;
    rdfs:label 'Service Area Zip Code' ;
    rdfs:comment 'Primary ZIP code of the provider\'s practice location within this network affiliation. Used for geographic network adequacy analysis, time-and-distance standards compliance, and provider directory accuracy.' ;
    rdfs:domain ind:NetworkAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason code for the termination of the provider\'s network affiliation. Used for network management analytics, OIG compliance monitoring, and understanding provider attrition patterns.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npiRegistryId rdf:type rdf:Property ;
    rdfs:label 'Npi Registry Id' ;
    rdfs:comment 'Foreign key linking to reference.npi_registry. Business justification: Medical group NPIs must be validated against the NPPES NPI registry for payer enrollment, network directory publishing, and CMS compliance. The plain `npi` column is a denormalized reference to npi_re' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NpiRegistry .

ind:acoParticipant rdf:type rdf:Property ;
    rdfs:label 'Aco Participant' ;
    rdfs:comment 'Indicates whether the provider group is a participating entity in a CMS Accountable Care Organization (ACO) program such as the Medicare Shared Savings Program (MSSP). Drives value-based care reporting and shared savings calculations.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adminContactEmail rdf:type rdf:Property ;
    rdfs:label 'Admin Contact Email' ;
    rdfs:comment 'Primary administrative email address for the provider group used for credentialing correspondence, payer enrollment notifications, and contract communications. Not a patient-facing address.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingEntityName rdf:type rdf:Property ;
    rdfs:label 'Billing Entity Name' ;
    rdfs:comment 'The legal name of the billing entity through which the provider group submits professional claims (CMS-1500 / 837P). May differ from the group name when a management services organization (MSO) or billing company handles claims on behalf of the group.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date on which the provider group\'s primary payer or health system contract became effective. Used for billing eligibility validation, retroactive claim adjudication, and contract lifecycle management.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Termination Date' ;
    rdfs:comment 'Date on which the provider group\'s primary contract was or is scheduled to be terminated. Null if the contract is open-ended or currently active. Used for claims eligibility cutoff and network directory updates.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fqhcDesignation rdf:type rdf:Property ;
    rdfs:label 'Fqhc Designation' ;
    rdfs:comment 'Indicates whether the provider group holds an active FQHC (Federally Qualified Health Center) designation from HRSA. FQHC status triggers specific CMS cost-based reimbursement rates and grant eligibility under Section 330 of the Public Health Service Act.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groupStatus rdf:type rdf:Property ;
    rdfs:label 'Group Status' ;
    rdfs:comment 'Current lifecycle status of the provider group record. Active indicates the group is operational and credentialed; pending indicates enrollment or credentialing in progress; suspended indicates temporary hold; terminated indicates the group is no longer operational or contracted.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupType rdf:type rdf:Property ;
    rdfs:label 'Group Type' ;
    rdfs:comment 'Categorical classification of the provider group\'s organizational model. Single-specialty groups focus on one clinical discipline; multi-specialty groups span multiple disciplines; FQHC (Federally Qualified Health Center) and RHC (Rural Health Clinic) designations carry specific CMS reimbursement implications; IPA (Independent Practice Association) and ACO (Accountable Care Organization) reflect value-based care structures. [ENUM-REF-CANDIDATE: single_specialty|multi_specialty|fqhc|rhc|independent_practice_association|accountable_care_organization|other — promote to reference product]' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hl7FhirOrganizationReference rdf:type rdf:Property ;
    rdfs:label 'Hl7 Fhir Organization Reference' ;
    rdfs:comment 'The FHIR (Fast Healthcare Interoperability Resources) Organization resource ID for this provider group, used in HL7 FHIR R4 API exchanges with payers, HIEs (Health Information Exchanges), and external systems. Supports interoperability under the CMS Interoperability and Patient Access Rule.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hospitalAffiliation rdf:type rdf:Property ;
    rdfs:label 'Hospital Affiliation' ;
    rdfs:comment 'Name of the primary hospital or health system with which the provider group is affiliated for admitting privileges and care coordination. Used for referral routing, care transitions, and network directory accuracy.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagesSupported rdf:type rdf:Property ;
    rdfs:label 'Languages Supported' ;
    rdfs:comment 'Comma-delimited list of languages (ISO 639-1 codes) spoken by clinical staff within the provider group. Used for patient-provider matching, CLAS (Culturally and Linguistically Appropriate Services) compliance, and SDOH-informed care access reporting.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCredentialingDate rdf:type rdf:Property ;
    rdfs:label 'Last Credentialing Date' ;
    rdfs:comment 'Date on which the most recent credentialing or recredentialing review was completed and approved for the provider group. Used for audit trails and NCQA compliance reporting.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicaidEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Medicaid Enrollment Status' ;
    rdfs:comment 'Enrollment status of the provider group with the state Medicaid program. Determines eligibility to bill Medicaid for covered services. Managed at the state level through state Medicaid Management Information Systems (MMIS).' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicareEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Medicare Enrollment Status' ;
    rdfs:comment 'Enrollment status of the provider group with the Medicare program as reported in PECOS (Provider Enrollment, Chain, and Ownership System). Determines eligibility to bill Medicare Part B for professional services.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mipsGroupReporting rdf:type rdf:Property ;
    rdfs:label 'Mips Group Reporting' ;
    rdfs:comment 'Indicates whether the provider group has elected to report MIPS quality measures at the group level (using the group NPI/TIN) rather than at the individual clinician level. Affects CMS payment adjustment calculations.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryFax rdf:type rdf:Property ;
    rdfs:label 'Primary Fax' ;
    rdfs:comment 'Primary fax number for the provider group used for clinical communications, referral transmissions, and credentialing document exchange. Fax remains a HIPAA-compliant PHI transmission method in healthcare.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryServiceAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Primary Service Address Line1' ;
    rdfs:comment 'Street address line 1 of the provider group\'s primary service location. Used for payer directory listings, credentialing applications, and patient-facing location data.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryServiceCity rdf:type rdf:Property ;
    rdfs:label 'Primary Service City' ;
    rdfs:comment 'City of the provider group\'s primary service location. Used for geographic network analysis, payer directory accuracy, and regulatory reporting.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryServiceState rdf:type rdf:Property ;
    rdfs:label 'Primary Service State' ;
    rdfs:comment 'Two-letter US state code of the provider group\'s primary service location. Drives state licensure validation, Medicaid enrollment, and network adequacy reporting by state.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryServiceZip rdf:type rdf:Property ;
    rdfs:label 'Primary Service Zip' ;
    rdfs:comment 'US ZIP or ZIP+4 postal code of the provider group\'s primary service location. Used for geographic network adequacy analysis, HEDIS reporting, and SDOH (Social Determinants of Health) stratification.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rhcDesignation rdf:type rdf:Property ;
    rdfs:label 'Rhc Designation' ;
    rdfs:comment 'Indicates whether the provider group holds an active RHC (Rural Health Clinic) designation from CMS. RHC status triggers specific cost-based reimbursement rates and rural access requirements under 42 CFR § 491.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Total number of active clinicians (physicians, APPs, and allied health professionals) affiliated with the provider group. Used for network adequacy assessments, contracting tiers, and population health capacity planning.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemGroupReference rdf:type rdf:Property ;
    rdfs:label 'Source System Group Reference' ;
    rdfs:comment 'The native identifier for this provider group in the originating source system (e.g., Epic provider group ID, Cerner organization ID, Symplr group record ID). Used for ETL cross-reference, reconciliation, and bi-directional system integration.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telehealthCapable rdf:type rdf:Property ;
    rdfs:label 'Telehealth Capable' ;
    rdfs:comment 'Indicates whether the provider group offers telehealth or virtual care services. Used for network directory accuracy, patient access reporting, and CMS telehealth billing eligibility under 42 CFR § 410.78.' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vibeMutatedFlag rdf:type rdf:Property ;
    rdfs:label 'Vibe Mutated Flag' ;
    rdfs:domain ind:Group ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groupMembershipId rdf:type rdf:Property ;
    rdfs:label 'Group Membership Id' ;
    rdfs:comment 'Unique surrogate identifier for each clinician-to-organization affiliation or employment record. Primary key for the group_membership data product.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryGroupClinicianId rdf:type rdf:Property ;
    rdfs:label 'Primary Group Clinician Id' ;
    rdfs:comment 'Reference to the individual clinician or healthcare professional whose organizational affiliation or employment relationship is being recorded. Links to the provider master record.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:primaryGroupOrgProviderId rdf:type rdf:Property ;
    rdfs:label 'Primary Group Org Provider Id' ;
    rdfs:comment 'Reference to the organizational entity (group practice, hospital, health system, academic medical center, FQHC, etc.) with which the provider is affiliated or employed.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgProvider .

ind:academicAppointmentRank rdf:type rdf:Property ;
    rdfs:label 'Academic Appointment Rank' ;
    rdfs:comment 'The academic faculty rank held by the provider within an affiliated academic medical center or teaching institution. Applicable only for academic affiliations. Null for non-academic organizations.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acoParticipation rdf:type rdf:Property ;
    rdfs:label 'Aco Participation' ;
    rdfs:comment 'Indicates whether the provider participates in an Accountable Care Organization (ACO) arrangement under this organizational affiliation. Relevant for value-based care attribution, MIPS reporting, and CMS Shared Savings Program compliance.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'The end date of the formal employment or affiliation contract. Null for open-ended contracts. Used for contract renewal tracking, workforce planning, and credentialing continuity management.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'The reference number of the employment or affiliation contract governing this provider-organization relationship. Links to the contract management system for terms, compensation, and obligations.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'The start date of the formal employment or affiliation contract governing this provider-organization relationship. May differ from the effective_date if there is a gap between contract execution and service commencement.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The financial cost center code associated with this provider\'s organizational affiliation. Used for financial attribution, RVU-based compensation modeling, and departmental budget reporting in SAP S/4HANA.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'The clinical or administrative department within the organization to which the provider is assigned under this affiliation (e.g., Department of Medicine, Department of Surgery, Emergency Department). Used for workforce planning and operational reporting.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureReason rdf:type rdf:Property ;
    rdfs:label 'Departure Reason' ;
    rdfs:comment 'Coded reason for the provider\'s departure or separation from the organizational affiliation. Required for NPDB adverse action reporting context, workforce analytics, and credentialing work history verification. [ENUM-REF-CANDIDATE: resignation|retirement|termination|contract_end|relocation|deceased|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteAllocation rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation' ;
    rdfs:comment 'The proportion of the provider\'s full-time equivalent effort allocated to this organizational affiliation, expressed as a decimal (e.g., 1.0 = full-time, 0.5 = half-time). Used for workforce planning, productivity analysis, and RVU attribution.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAcceptingPatients rdf:type rdf:Property ;
    rdfs:label 'Is Accepting Patients' ;
    rdfs:comment 'Indicates whether the provider is currently accepting new patients under this organizational affiliation. Used for patient access management, referral routing, and provider directory accuracy per CMS and NCQA requirements.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryAffiliation rdf:type rdf:Property ;
    rdfs:label 'Is Primary Affiliation' ;
    rdfs:comment 'Indicates whether this organizational affiliation is the provider\'s primary or principal employment relationship (True) versus a secondary or concurrent affiliation (False). Used for billing attribution, PCP panel assignment, and workforce reporting.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVoluntarySeparation rdf:type rdf:Property ;
    rdfs:label 'Is Voluntary Separation' ;
    rdfs:comment 'Indicates whether the provider\'s separation from the organization was voluntary (True) or involuntary (False). Critical for NPDB adverse action reporting — involuntary separations related to clinical competence or conduct must be reported to the NPDB.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalStaffCategory rdf:type rdf:Property ;
    rdfs:label 'Medical Staff Category' ;
    rdfs:comment 'The medical staff membership category assigned to the provider by the hospital or health system\'s medical staff office. Governs clinical privileges, voting rights, and committee eligibility per medical staff bylaws. [ENUM-REF-CANDIDATE: active|associate|courtesy|consulting|honorary|provisional|affiliate — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipRole rdf:type rdf:Property ;
    rdfs:label 'Membership Role' ;
    rdfs:comment 'The provider\'s functional role or relationship type within the organization. Determines billing attribution rules, malpractice coverage applicability, and credentialing pathway. [ENUM-REF-CANDIDATE: owner|partner|employee|contractor|attending|consulting|locum_tenens|volunteer — promote to reference product]' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle state of the provider\'s affiliation or employment relationship with the organization. Drives access control, billing eligibility, and credentialing verification workflows.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privilegingStatus rdf:type rdf:Property ;
    rdfs:label 'Privileging Status' ;
    rdfs:comment 'Current clinical privileging status for this provider at the affiliated organization. Clinical privileges define the specific procedures and services the provider is authorized to perform. Distinct from credentialing status.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisionLevel rdf:type rdf:Property ;
    rdfs:label 'Supervision Level' ;
    rdfs:comment 'The level of supervision required for the provider under this organizational affiliation. Relevant for advanced practice providers (NPs, PAs) whose scope of practice may require physician oversight per state law and organizational policy.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deaRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Dea Registration Id' ;
    rdfs:comment 'Unique surrogate identifier for each DEA controlled substance registration record in the enterprise data platform. Primary key for the dea_registration data product.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeaRegistration .

ind:businessActivityType rdf:type rdf:Property ;
    rdfs:label 'Business Activity Type' ;
    rdfs:comment 'The DEA-defined category of business activity for which the registration is issued. Determines the type of controlled substance activities the registrant is authorized to perform. Practitioner covers physicians, dentists, and veterinarians; mid-level practitioner covers nurse practitioners and physician assistants; hospital and pharmacy cover institutional registrants. [ENUM-REF-CANDIDATE: practitioner|mid-level_practitioner|hospital|pharmacy|researcher|manufacturer|distributor|importer|exporter|reverse_distributor|narcotic_treatment_program — promote to reference product]' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysUntilExpiration rdf:type rdf:Property ;
    rdfs:label 'Days Until Expiration' ;
    rdfs:comment 'The number of calendar days remaining until the DEA registration expires, calculated as of the most recent data refresh date. Supports proactive credentialing management and pharmacy compliance dashboards. Note: This is a point-in-time snapshot value loaded during ETL; it is not a real-time computed field.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expirationAlertDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Alert Date' ;
    rdfs:comment 'The date on which the expiration alert notification was sent to the provider and/or credentialing staff. Null if no alert has been sent. Used for credentialing workflow audit trails.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationAlertSent rdf:type rdf:Property ;
    rdfs:label 'Expiration Alert Sent' ;
    rdfs:comment 'Indicates whether an expiration alert notification has been sent to the provider and/or credentialing staff regarding the upcoming expiration of this DEA registration. Supports proactive renewal workflow management.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'The registration fee paid to the DEA for the current registration period, in U.S. dollars. DEA registration fees vary by registrant type and are set by federal regulation. Used for credentialing cost tracking and budget reconciliation.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeExempt rdf:type rdf:Property ;
    rdfs:label 'Fee Exempt' ;
    rdfs:comment 'Indicates whether the registrant is exempt from DEA registration fees. Fee exemptions apply to federal, state, and local government practitioners, as well as certain public health service providers. Relevant for registration cost tracking and compliance.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date on which the DEA registration fee was paid for the current registration period. Used for financial reconciliation and credentialing audit trails.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pdmpReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Pdmp Reporting Required' ;
    rdfs:comment 'Indicates whether the provider holding this DEA registration is subject to mandatory Prescription Drug Monitoring Program (PDMP) reporting requirements in the registered state. PDMP reporting obligations vary by state and practitioner type.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:practitionerTypeCode rdf:type rdf:Property ;
    rdfs:label 'Practitioner Type Code' ;
    rdfs:comment 'DEA-assigned code identifying the specific practitioner type category (e.g., MD, DO, DDS, DVM, NP, PA, CRNA). Determines prescribing authority scope and schedule authorization eligibility. Sourced from DEA registration application form. [ENUM-REF-CANDIDATE: MD|DO|DDS|DMD|DVM|NP|PA|CRNA|CNM|PharmD|RPh|ND|OD|DPM|PhD — promote to reference product]' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'Primary street address line of the practice location registered with the DEA. The DEA registration is location-specific; a provider with multiple practice sites may require separate registrations per location.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'Secondary address line (suite, floor, unit number) of the practice location registered with the DEA. Supplements the primary address line for precise location identification.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'City of the practice location registered with the DEA for this controlled substance registration.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredName rdf:type rdf:Property ;
    rdfs:label 'Registered Name' ;
    rdfs:comment 'The full legal name of the individual practitioner or organization as it appears on the DEA registration certificate. May differ from the provider\'s operational display name. Used for verification against DEA public registry and pharmacy dispensing records.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredZipCode rdf:type rdf:Property ;
    rdfs:label 'Registered Zip Code' ;
    rdfs:comment 'U.S. ZIP or ZIP+4 postal code of the practice location registered with the DEA. Used for geographic analysis of controlled substance prescribing patterns and regulatory reporting.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationState rdf:type rdf:Property ;
    rdfs:label 'Registration State' ;
    rdfs:comment 'The U.S. state or territory in which the DEA registration is valid and the provider is authorized to prescribe controlled substances. DEA registrations are state-specific; a provider practicing in multiple states requires a separate DEA registration for each state. Represented as a two-letter USPS state abbreviation.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationType rdf:type rdf:Property ;
    rdfs:label 'Registration Type' ;
    rdfs:comment 'Indicates whether the DEA registration is held by an individual practitioner or by an institutional entity (e.g., hospital, clinic, pharmacy). Institutional registrations cover all authorized practitioners operating under the institution\'s DEA number.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalApplicationDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Application Date' ;
    rdfs:comment 'The date on which the provider submitted a renewal application to the DEA for continuation of the controlled substance registration. DEA regulations require renewal applications to be submitted at least 45 days before expiration. Used for credentialing workflow tracking in Symplr.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Renewal Confirmation Number' ;
    rdfs:comment 'The confirmation or tracking number issued by the DEA upon receipt of a renewal application. Used to track the status of pending renewals and follow up with the DEA Diversion Control Division.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleIiAuthorized rdf:type rdf:Property ;
    rdfs:label 'Schedule Ii Authorized' ;
    rdfs:comment 'Indicates whether the DEA registration authorizes the provider to prescribe Schedule II controlled substances (e.g., opioids such as oxycodone, stimulants such as amphetamine). Schedule II substances have high abuse potential with severe psychological or physical dependence. Required for CPOE validation in Epic Willow and Cerner PharmNet.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleIiiAuthorized rdf:type rdf:Property ;
    rdfs:label 'Schedule Iii Authorized' ;
    rdfs:comment 'Indicates whether the DEA registration authorizes the provider to prescribe Schedule III controlled substances (e.g., anabolic steroids, buprenorphine combinations). Schedule III substances have moderate to low physical dependence potential.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleIinAuthorized rdf:type rdf:Property ;
    rdfs:label 'Schedule Iin Authorized' ;
    rdfs:comment 'Indicates whether the DEA registration authorizes the provider to prescribe Schedule IIN non-narcotic controlled substances (e.g., stimulants such as methylphenidate, Adderall). Distinct from Schedule IIN narcotic authorizations for pharmacy dispensing and order validation purposes.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleIvAuthorized rdf:type rdf:Property ;
    rdfs:label 'Schedule Iv Authorized' ;
    rdfs:comment 'Indicates whether the DEA registration authorizes the provider to prescribe Schedule IV controlled substances (e.g., benzodiazepines, tramadol). Schedule IV substances have lower abuse potential relative to Schedule III.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleVAuthorized rdf:type rdf:Property ;
    rdfs:label 'Schedule V Authorized' ;
    rdfs:comment 'Indicates whether the DEA registration authorizes the provider to prescribe Schedule V controlled substances (e.g., cough preparations with less than 200mg of codeine per 100mL). Schedule V substances have the lowest abuse potential among controlled substances.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surrenderDate rdf:type rdf:Property ;
    rdfs:label 'Surrender Date' ;
    rdfs:comment 'The date on which the provider voluntarily surrendered the DEA registration to the Drug Enforcement Administration. Voluntary surrender may occur upon retirement, change of practice, or in lieu of revocation proceedings.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The most recent date on which the DEA registration was verified against the DEA Diversion Control Division public registry or through a primary source verification process. Required for Joint Commission and NCQA credentialing compliance.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:xWaiverAuthorized rdf:type rdf:Property ;
    rdfs:label 'X Waiver Authorized' ;
    rdfs:comment 'Indicates whether the provider holds a DATA 2000 waiver (formerly X-waiver) authorizing the prescribing of buprenorphine for opioid use disorder treatment in an office-based setting. As of the SUPPORT Act (2023), the X-waiver requirement was eliminated, but this flag tracks historical and current waiver status for compliance and analytics.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:xWaiverPatientLimit rdf:type rdf:Property ;
    rdfs:label 'X Waiver Patient Limit' ;
    rdfs:comment 'The maximum number of patients the provider is authorized to treat with buprenorphine for opioid use disorder under the DATA 2000 waiver. Common limits are 30, 100, or 275 patients depending on provider type and waiver tier. Null if x_waiver_authorized is false or not applicable.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Board Certification Status' ;
    rdfs:comment 'Status for board certification.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'The unique alphanumeric certificate number issued by the certifying board to the provider upon successful completion of board examination and certification requirements. Used as the externally-known business identifier for this certification record in credentialing and payer enrollment workflows.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the board certification. Active = valid and in good standing; Expired = past expiration date without renewal; Revoked = rescinded by certifying board due to disciplinary action or fraud; Suspended = temporarily inactive; Pending = examination passed but certificate not yet issued; Lapsed = MOC requirements not met within required window.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Indicates whether this certification record represents an initial board certification, a recertification cycle, an added qualification (subspecialty), or a Maintenance of Certification (MOC) milestone. Drives credentialing workflow routing and expiration tracking logic.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBoard rdf:type rdf:Property ;
    rdfs:label 'Certifying Board' ;
    rdfs:comment 'Certifying Board for board certification.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBoardCode rdf:type rdf:Property ;
    rdfs:label 'Certifying Board Code' ;
    rdfs:comment 'Standardized short code or abbreviation identifying the certifying board (e.g., ABIM for American Board of Internal Medicine, ABS for American Board of Surgery). Used in downstream credentialing systems and payer enrollment data exchanges.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingOrganizationType rdf:type rdf:Property ;
    rdfs:label 'Certifying Organization Type' ;
    rdfs:comment 'Classification of the umbrella organization under which the certifying board operates. ABMS = American Board of Medical Specialties (allopathic physicians), AOA = American Osteopathic Association (osteopathic physicians), ANCC = American Nurses Credentialing Center, AANP = American Association of Nurse Practitioners, AAPA = American Academy of Physician Associates.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examAttemptNumber rdf:type rdf:Property ;
    rdfs:label 'Exam Attempt Number' ;
    rdfs:comment 'The sequential attempt number on which the provider passed the board certification examination. A value of 1 indicates first-attempt pass. Used in quality and credentialing analytics to assess examination performance.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:examPassDate rdf:type rdf:Property ;
    rdfs:label 'Exam Pass Date' ;
    rdfs:comment 'The date on which the provider successfully passed the board certification examination administered by the certifying board. Distinct from initial_certification_date, which reflects when the certificate was formally issued.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initialCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Initial Certification Date' ;
    rdfs:comment 'The calendar date on which the provider first achieved board certification in this specialty from this certifying board. Represents the effective start of the agreement/credential. Used to calculate years of board certification and tenure in credentialing analytics.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isActivePrivilegesRequired rdf:type rdf:Property ;
    rdfs:label 'Is Active Privileges Required' ;
    rdfs:comment 'Indicates whether active hospital privileges in this specialty are required to be maintained in conjunction with this board certification per the organization\'s medical staff bylaws or credentialing policies.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLifetimeCertification rdf:type rdf:Property ;
    rdfs:label 'Is Lifetime Certification' ;
    rdfs:comment 'Indicates whether this board certification was issued as a lifetime (non-time-limited) certificate, typically granted to physicians who achieved certification prior to the introduction of time-limited recertification requirements by ABMS member boards. When True, expiration_date is expected to be null.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimarySpecialty rdf:type rdf:Property ;
    rdfs:label 'Is Primary Specialty' ;
    rdfs:comment 'Indicates whether this board certification represents the provider\'s primary specialty designation. A provider may hold multiple board certifications; this flag identifies the principal specialty used for provider directory listings, referral routing, and quality reporting.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mocDueDate rdf:type rdf:Property ;
    rdfs:label 'Moc Due Date' ;
    rdfs:comment 'The deadline by which the provider must complete all required Maintenance of Certification (MOC) activities to maintain certification in good standing. Used for proactive credentialing alerts and compliance tracking.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mocEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Moc Enrollment Date' ;
    rdfs:comment 'The date on which the provider enrolled in the Maintenance of Certification (MOC) program associated with this board certification. Used to track MOC program participation timelines and compliance windows.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mocProgramName rdf:type rdf:Property ;
    rdfs:label 'Moc Program Name' ;
    rdfs:comment 'Name of the specific Maintenance of Certification (MOC) program the provider is enrolled in for this certification (e.g., ABIM MOC, ABS Continuous Certification). Different boards operate distinct MOC programs with varying requirements.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerEnrollmentRequired rdf:type rdf:Property ;
    rdfs:label 'Payer Enrollment Required' ;
    rdfs:comment 'Indicates whether this board certification is required as a condition of the provider\'s enrollment with one or more payers (e.g., Medicare, Medicaid, commercial insurers). Drives payer enrollment workflow triggers when certification status changes.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recertificationCycleYears rdf:type rdf:Property ;
    rdfs:label 'Recertification Cycle Years' ;
    rdfs:comment 'The number of years in the recertification cycle for this board certification as defined by the certifying board (e.g., 10 years for ABIM, 6 years for ABS). Used to project next recertification due dates and plan credentialing renewal workflows.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recertificationDate rdf:type rdf:Property ;
    rdfs:label 'Recertification Date' ;
    rdfs:comment 'The date on which the provider most recently completed recertification for this specialty board certification. Null for initial certifications that have not yet undergone a recertification cycle.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subspecialtyCode rdf:type rdf:Property ;
    rdfs:label 'Subspecialty Code' ;
    rdfs:comment 'Standardized code for the subspecialty or added qualification certification, aligned with NUCC taxonomy or ABMS subspecialty codes. Null if no subspecialty applies to this certification record.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subspecialtyName rdf:type rdf:Property ;
    rdfs:label 'Subspecialty Name' ;
    rdfs:comment 'Full name of the subspecialty or added qualification for which the provider holds certification, if applicable (e.g., Interventional Cardiology within Cardiology, Pediatric Critical Care within Pediatrics). Null if no subspecialty certification exists for this record.' ;
    rdfs:domain ind:BoardCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'The second level of the NUCC taxonomy hierarchy representing the provider\'s primary discipline or specialty grouping within the provider type (e.g., \'Family Medicine\', \'Internal Medicine\', \'Pediatrics\'). Used in payer enrollment and claims adjudication to route claims to appropriate fee schedules.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsSpecialtyDescription rdf:type rdf:Property ;
    rdfs:label 'Cms Specialty Description' ;
    rdfs:comment 'The descriptive label associated with the CMS specialty code crosswalk for this taxonomy entry (e.g., \'General Practice\', \'Cardiology\', \'Pathology\'). Supports reporting and validation in Medicare claims adjudication workflows.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deaRegistrationApplicable rdf:type rdf:Property ;
    rdfs:label 'Dea Registration Applicable' ;
    rdfs:comment 'Indicates whether providers with this taxonomy code are typically required or eligible to obtain a DEA registration number for prescribing controlled substances. Supports credentialing completeness checks and compliance monitoring.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:definition rdf:type rdf:Property ;
    rdfs:label 'Definition' ;
    rdfs:comment 'The official NUCC narrative definition describing the scope of practice, training requirements, and clinical activities associated with this taxonomy code. Used by credentialing staff and payer enrollment teams to validate appropriate taxonomy selection.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayName rdf:type rdf:Property ;
    rdfs:label 'Display Name' ;
    rdfs:comment 'The full human-readable display name for the taxonomy code as published by NUCC, combining provider type, classification, and specialization into a single descriptive label used in UI dropdowns, reports, and provider directories.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:individualOrOrganization rdf:type rdf:Property ;
    rdfs:label 'Individual Or Organization' ;
    rdfs:comment 'Indicates whether this taxonomy code applies to an individual healthcare professional (Type 1 NPI) or an organizational/group provider (Type 2 NPI). Drives NPI enumeration type selection and payer enrollment form routing.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicaidEnrollmentEligible rdf:type rdf:Property ;
    rdfs:label 'Medicaid Enrollment Eligible' ;
    rdfs:comment 'Indicates whether providers with this taxonomy code are eligible to enroll as Medicaid providers. Supports state Medicaid agency enrollment workflows and payer credentialing validation.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npiType rdf:type rdf:Property ;
    rdfs:label 'Npi Type' ;
    rdfs:comment 'The NPI enumeration type associated with this taxonomy code: Type 1 for individual healthcare providers and Type 2 for organizational providers. Determines the NPI application process and NPPES registry classification.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nuccGrouping rdf:type rdf:Property ;
    rdfs:label 'Nucc Grouping' ;
    rdfs:comment 'The broad grouping category assigned by NUCC above the provider type level, used to segment taxonomy codes into major provider categories such as \'Individual\', \'Non-Individual\', or specific functional groupings (e.g., \'Behavioral Health & Social Service Providers\', \'Dental Providers\'). Supports high-level analytics and network adequacy reporting.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pecosEnrollmentEligible rdf:type rdf:Property ;
    rdfs:label 'Pecos Enrollment Eligible' ;
    rdfs:comment 'Indicates whether providers with this taxonomy code are eligible to enroll in Medicare through the PECOS system. Used by revenue cycle and credentialing teams to determine Medicare participation eligibility during provider onboarding.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replacementTaxonomyCode rdf:type rdf:Property ;
    rdfs:label 'Replacement Taxonomy Code' ;
    rdfs:comment 'The NUCC taxonomy code that replaces this code when it has been retired or deprecated. Enables automated migration of provider taxonomy assignments during NUCC code set updates and supports backward compatibility in claims processing.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialization rdf:type rdf:Property ;
    rdfs:label 'Specialization' ;
    rdfs:comment 'The third and most granular level of the NUCC taxonomy hierarchy representing a specific area of practice within the classification (e.g., \'Adolescent Medicine\', \'Geriatric Medicine\', \'Sports Medicine\'). May be null for taxonomy codes that do not have a defined specialization.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyStatus rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Status' ;
    rdfs:comment 'The current lifecycle status of this taxonomy code as maintained by NUCC: Active (valid for current use), Retired (no longer valid for new enrollments), or Deprecated (superseded by a replacement code). Drives validation rules in NPI enrollment and claims editing systems.' ;
    rdfs:domain ind:Taxonomy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'The version number of the NUCC Health Care Provider Taxonomy Code Set from which this taxonomy code was sourced (e.g., \'23.1\', \'24.0\'). NUCC releases updates twice per year; version tracking ensures claims and enrollment systems use the correct code set.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisId rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Id' ;
    rdfs:comment 'Unique identifier for each diagnosis record.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Diagnosis .

ind:clinicalOrderId rdf:type rdf:Property ;
    rdfs:label 'Clinical Order Id' ;
    rdfs:comment 'FK to the clinical order that triggered or documented this diagnosis.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalOrder .

ind:admitDiagnosisFlag rdf:type rdf:Property ;
    rdfs:label 'Admit Diagnosis Flag' ;
    rdfs:comment 'Indicates if this diagnosis was the reason for admission.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdiQueryFlag rdf:type rdf:Property ;
    rdfs:label 'Cdi Query Flag' ;
    rdfs:comment 'Indicates if a CDI query was issued for this diagnosis.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdiQueryStatus rdf:type rdf:Property ;
    rdfs:label 'Cdi Query Status' ;
    rdfs:comment 'Status of the CDI query (pending, answered, escalated, etc.).' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalStatus rdf:type rdf:Property ;
    rdfs:label 'Clinical Status' ;
    rdfs:comment 'Clinical status of the diagnosis (active, resolved, recurrence, etc.).' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codingDate rdf:type rdf:Property ;
    rdfs:label 'Coding Date' ;
    rdfs:comment 'Date the diagnosis was coded.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complicationComorbidityFlag rdf:type rdf:Property ;
    rdfs:label 'Complication Comorbidity Flag' ;
    rdfs:comment 'Indicates if this diagnosis is a complication or comorbidity (CC/MCC) for DRG assignment.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diagnosisDate rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Date' ;
    rdfs:comment 'Date the diagnosis was made.' ;
    rdfs:domain ind:Healthcare ;
