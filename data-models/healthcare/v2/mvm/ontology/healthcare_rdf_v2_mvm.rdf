ind:supportingObservationId rdf:type rdf:Property ;
    rdfs:label 'Supporting Observation Id' ;
    rdfs:comment 'Foreign key linking to clinical.observation. Business justification: Prior auth decisions for procedures like bariatric surgery or cardiac interventions are driven by specific clinical observations (assessment scores, functional status). Linking the triggering observat' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Observation .

ind:approvedEndDate rdf:type rdf:Property ;
    rdfs:label 'Approved End Date' ;
    rdfs:comment 'Approved end date.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedStartDate rdf:type rdf:Property ;
    rdfs:label 'Approved Start Date' ;
    rdfs:comment 'Approved start date.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedUnits rdf:type rdf:Property ;
    rdfs:label 'Approved Units' ;
    rdfs:comment 'Approved units.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationNotes rdf:type rdf:Property ;
    rdfs:label 'Authorization Notes' ;
    rdfs:comment 'Authorization notes.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationSource rdf:type rdf:Property ;
    rdfs:label 'Authorization Source' ;
    rdfs:comment 'Authorization source.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Decision date.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:peerReviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Peer Review Completed Date' ;
    rdfs:comment 'Peer review completed date.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedServiceCptCode rdf:type rdf:Property ;
    rdfs:label 'Requested Service Cpt Code' ;
    rdfs:comment 'Requested service CPT code.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedUnits rdf:type rdf:Property ;
    rdfs:label 'Requested Units' ;
    rdfs:comment 'Requested units.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceSetting rdf:type rdf:Property ;
    rdfs:label 'Service Setting' ;
    rdfs:comment 'Service setting.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsConsumed rdf:type rdf:Property ;
    rdfs:label 'Units Consumed' ;
    rdfs:comment 'Units consumed.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dependentId rdf:type rdf:Property ;
    rdfs:label 'Dependent Id' ;
    rdfs:comment 'Foreign key linking to insurance.dependent. Business justification: When the patient is a dependent, eligibility verification is performed against the dependent\'s record to confirm coverage status, relationship type, and effective dates. Dependent-level eligibility is' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dependent .

ind:eligibilityMemberMpiRecordId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Member Mpi Record Id' ;
    rdfs:comment 'Member MPI record.' ;
    rdfs:domain ind:Eligibility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MpiRecord .

ind:eligibilityMpiRecordId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Mpi Record Id' ;
    rdfs:comment 'MPI record.' ;
    rdfs:domain ind:Eligibility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MpiRecord .

ind:pcpNpiRegistryId rdf:type rdf:Property ;
    rdfs:label 'Pcp Npi Registry Id' ;
    rdfs:comment 'Foreign key linking to reference.npi_registry. Business justification: Eligibility verification requires validating the patient\'s assigned PCP NPI against the authoritative registry to confirm active status, network participation, and correct taxonomy. pcp_npi is a denor' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NpiRegistry .

ind:coinsurancePercentage rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Percentage' ;
    rdfs:comment 'Coinsurance percentage.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coordinationOfBenefitsOrder rdf:type rdf:Property ;
    rdfs:label 'Coordination Of Benefits Order' ;
    rdfs:comment 'COB order.' ;
    rdfs:domain ind:Eligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageLevel rdf:type rdf:Property ;
    rdfs:label 'Coverage Level' ;
    rdfs:comment 'Coverage level.' ;
    rdfs:domain ind:Eligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleRemainingAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Remaining Amount' ;
    rdfs:comment 'Deductible remaining amount.' ;
    rdfs:domain ind:Eligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outOfPocketMaximum rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Maximum' ;
    rdfs:comment 'Out of pocket maximum.' ;
    rdfs:domain ind:Eligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pcpName rdf:type rdf:Property ;
    rdfs:label 'Pcp Name' ;
    rdfs:comment 'PCP name.' ;
    rdfs:domain ind:Eligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseCode rdf:type rdf:Property ;
    rdfs:label 'Response Code' ;
    rdfs:comment 'Response code.' ;
    rdfs:domain ind:Eligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDescription rdf:type rdf:Property ;
    rdfs:label 'Response Description' ;
    rdfs:comment 'Response description.' ;
    rdfs:domain ind:Eligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Request Timestamp' ;
    rdfs:comment 'Verification request timestamp.' ;
    rdfs:domain ind:Eligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:verificationResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Response Timestamp' ;
    rdfs:comment 'Verification response timestamp.' ;
    rdfs:domain ind:Eligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:verificationTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Verification Transaction Number' ;
    rdfs:comment 'Verification transaction number.' ;
    rdfs:domain ind:Eligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobId rdf:type rdf:Property ;
    rdfs:label 'Cob Id' ;
    rdfs:comment 'Unique identifier for the COB record.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:birthdayRuleApplied rdf:type rdf:Property ;
    rdfs:label 'Birthday Rule Applied' ;
    rdfs:comment 'Indicates birthday rule applied.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobStatus rdf:type rdf:Property ;
    rdfs:label 'Cob Status' ;
    rdfs:comment 'COB status.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossoverClaimIndicator rdf:type rdf:Property ;
    rdfs:label 'Crossover Claim Indicator' ;
    rdfs:comment 'Indicates crossover claim.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:determinationDate rdf:type rdf:Property ;
    rdfs:label 'Determination Date' ;
    rdfs:comment 'Determination date.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:determinationMethod rdf:type rdf:Property ;
    rdfs:label 'Determination Method' ;
    rdfs:comment 'Determination method.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duplicatePaymentPreventionFlag rdf:type rdf:Property ;
    rdfs:label 'Duplicate Payment Prevention Flag' ;
    rdfs:comment 'Indicates duplicate payment prevention.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderRuleApplied rdf:type rdf:Property ;
    rdfs:label 'Gender Rule Applied' ;
    rdfs:comment 'Indicates gender rule applied.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mspIndicator rdf:type rdf:Property ;
    rdfs:label 'Msp Indicator' ;
    rdfs:comment 'Medicare Secondary Payer indicator.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mspTypeCode rdf:type rdf:Property ;
    rdfs:label 'Msp Type Code' ;
    rdfs:comment 'MSP type code.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSequence rdf:type rdf:Property ;
    rdfs:label 'Order Sequence' ;
    rdfs:comment 'Order sequence.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Primary Adjustment Amount' ;
    rdfs:comment 'Primary adjustment amount.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryAdjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Primary Adjustment Reason Code' ;
    rdfs:comment 'Primary adjustment reason code.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAllowedAmount rdf:type rdf:Property ;
    rdfs:label 'Primary Allowed Amount' ;
    rdfs:comment 'Primary allowed amount.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryBilledAmount rdf:type rdf:Property ;
    rdfs:label 'Primary Billed Amount' ;
    rdfs:comment 'Primary billed amount.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Primary Paid Amount' ;
    rdfs:comment 'Primary paid amount.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryPatientResponsibilityAmount rdf:type rdf:Property ;
    rdfs:label 'Primary Patient Responsibility Amount' ;
    rdfs:comment 'Primary patient responsibility amount.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tertiaryBilledAmount rdf:type rdf:Property ;
    rdfs:label 'Tertiary Billed Amount' ;
    rdfs:comment 'Tertiary billed amount.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tertiaryPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Tertiary Paid Amount' ;
    rdfs:comment 'Tertiary paid amount.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codeSetVersionId rdf:type rdf:Property ;
    rdfs:label 'Code Set Version Id' ;
    rdfs:comment 'Foreign key linking to reference.code_set_version. Business justification: ICD-10-CM and ICD-10-PCS codes are published annually by CMS with version-specific effective/expiration dates. The icd_code table has version (STRING) and status attributes that should be normalized t' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeSetVersion .

ind:ageHigh rdf:type rdf:Property ;
    rdfs:label 'Age High' ;
    rdfs:comment 'The maximum patient age (in years) for which this ICD code is clinically appropriate. Used for coding validation and quality checks. Null if no maximum age restriction applies.' ;
    rdfs:domain ind:IcdCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageLow rdf:type rdf:Property ;
    rdfs:label 'Age Low' ;
    rdfs:comment 'The minimum patient age (in years) for which this ICD code is clinically appropriate. Used for coding validation and quality checks. Null if no minimum age restriction applies.' ;
    rdfs:domain ind:IcdCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ccFlag rdf:type rdf:Property ;
    rdfs:label 'Cc Flag' ;
    rdfs:comment 'Indicates whether this diagnosis code is classified as a Complication or Comorbidity (CC) for DRG assignment and severity adjustment purposes.' ;
    rdfs:domain ind:IcdCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chapter rdf:type rdf:Property ;
    rdfs:label 'Chapter' ;
    rdfs:comment 'The ICD-10 chapter to which this code belongs, representing the highest-level clinical category (e.g., Chapter 1: Certain infectious and parasitic diseases, Chapter 9: Diseases of the circulatory system).' ;
    rdfs:domain ind:IcdCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chapterCode rdf:type rdf:Property ;
    rdfs:label 'Chapter Code' ;
    rdfs:comment 'The alphanumeric range defining the chapter boundaries (e.g., A00-B99 for infectious diseases). Used for hierarchical grouping and reporting.' ;
    rdfs:domain ind:IcdCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeType rdf:type rdf:Property ;
    rdfs:label 'Code Type' ;
    rdfs:comment 'Indicates whether this code represents a diagnosis (ICD-10-CM) or a procedure (ICD-10-PCS).' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etiologyCodeFlag rdf:type rdf:Property ;
    rdfs:label 'Etiology Code Flag' ;
    rdfs:comment 'Indicates whether this code represents the underlying etiology or cause of a condition and should be sequenced before manifestation codes per ICD-10-CM coding conventions.' ;
    rdfs:domain ind:IcdCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderSpecificFlag rdf:type rdf:Property ;
    rdfs:label 'Gender Specific Flag' ;
    rdfs:comment 'Indicates whether this ICD code is applicable only to male patients, only to female patients, or to both. Used for clinical validation and coding accuracy.' ;
    rdfs:domain ind:IcdCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:longDescription rdf:type rdf:Property ;
    rdfs:label 'Long Description' ;
    rdfs:comment 'Full clinical description of the diagnosis or procedure code, providing comprehensive detail for clinical documentation, coding accuracy, and medical record completeness.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestationCodeFlag rdf:type rdf:Property ;
    rdfs:label 'Manifestation Code Flag' ;
    rdfs:comment 'Indicates whether this code represents a manifestation of an underlying disease and must be sequenced after the underlying condition code per ICD-10-CM coding conventions.' ;
    rdfs:domain ind:IcdCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:poaExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Poa Exempt Flag' ;
    rdfs:comment 'Indicates whether this diagnosis code is exempt from the CMS Present on Admission (POA) reporting requirement for inpatient claims. POA-exempt codes do not require a POA indicator on UB-04 claims.' ;
    rdfs:domain ind:IcdCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replacementCode rdf:type rdf:Property ;
    rdfs:label 'Replacement Code' ;
    rdfs:comment 'The ICD code that replaces this code if the code has been retired or superseded. Used for code mapping and historical claims reprocessing.' ;
    rdfs:domain ind:IcdCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unacceptablePrincipalDxFlag rdf:type rdf:Property ;
    rdfs:label 'Unacceptable Principal Dx Flag' ;
    rdfs:comment 'Indicates whether this diagnosis code is prohibited from being used as the principal diagnosis on an inpatient claim per CMS coding guidelines.' ;
    rdfs:domain ind:IcdCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validForCodingFlag rdf:type rdf:Property ;
    rdfs:label 'Valid For Coding Flag' ;
    rdfs:comment 'Indicates whether this code is valid for use in clinical documentation and coding. Codes may be invalid due to retirement, replacement, or administrative reasons.' ;
    rdfs:domain ind:IcdCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ageRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Age Range High' ;
    rdfs:comment 'Maximum patient age (in years) for which the CPT code is clinically appropriate. Null if no upper age restriction applies. Used for claims editing and clinical decision support.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeLow rdf:type rdf:Property ;
    rdfs:label 'Age Range Low' ;
    rdfs:comment 'Minimum patient age (in years) for which the CPT code is clinically appropriate. Null if no lower age restriction applies. Used for claims editing and clinical decision support.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:anesthesiaBaseUnits rdf:type rdf:Property ;
    rdfs:label 'Anesthesia Base Units' ;
    rdfs:comment 'Base unit value assigned to anesthesia CPT codes, representing the complexity and risk of the anesthesia service. Used in anesthesia billing formulas along with time units and modifying factors.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clinicalFamily rdf:type rdf:Property ;
    rdfs:label 'Clinical Family' ;
    rdfs:comment 'Grouping of clinically related CPT codes, such as all codes for a specific type of surgery or diagnostic test. Used for clinical pathway design, order sets, and utilization management.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionFactor rdf:type rdf:Property ;
    rdfs:label 'Conversion Factor' ;
    rdfs:comment 'Dollar amount multiplied by total RVU to calculate Medicare payment. Updated annually by CMS. Used in revenue cycle forecasting and contract modeling.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cptCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Cpt Code Status' ;
    rdfs:comment 'Current lifecycle status of the CPT code. Active codes are valid for billing. Inactive codes have been retired but retained for historical claims. Deleted codes are no longer recognized. Pending codes are scheduled for future activation.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Facility Indicator' ;
    rdfs:comment 'Indicates whether the CPT code is typically performed in a facility setting (hospital, ASC) or non-facility setting (physician office). Affects practice expense RVU calculation.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullDescriptor rdf:type rdf:Property ;
    rdfs:label 'Full Descriptor' ;
    rdfs:comment 'Complete clinical description of the procedure or service, including anatomical site, approach, and any modifiers or conditions. Used for clinical documentation, coding review, and CDI workflows.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderSpecific rdf:type rdf:Property ;
    rdfs:label 'Gender Specific' ;
    rdfs:comment 'Indicates whether the procedure is anatomically or clinically specific to male or female patients. Used for claims editing and clinical decision support.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalPeriod rdf:type rdf:Property ;
    rdfs:label 'Global Period' ;
    rdfs:comment 'Number of days of post-operative care included in the procedure payment. 000 = endoscopic or minor procedure with 0-day follow-up. 010 = minor procedure with 10-day follow-up. 090 = major surgery with 90-day follow-up. XXX = global concept does not apply. YYY = carrier determines global period. ZZZ = add-on code. MMM = maternity codes with global period. [ENUM-REF-CANDIDATE: 000|010|090|XXX|YYY|ZZZ|MMM — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:malpracticeRvu rdf:type rdf:Property ;
    rdfs:label 'Malpractice Rvu' ;
    rdfs:comment 'Relative Value Unit representing the professional liability insurance component. Reflects the relative risk and cost of malpractice insurance for the service.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicallyUnlikelyEditValue rdf:type rdf:Property ;
    rdfs:label 'Medically Unlikely Edit Value' ;
    rdfs:comment 'Maximum number of units of service that CMS considers medically reasonable for a single patient on a single date of service. Used for claims editing and fraud detection.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifierIndicator rdf:type rdf:Property ;
    rdfs:label 'Modifier Indicator' ;
    rdfs:comment 'Indicates whether bilateral surgery, assistant surgeon, or co-surgeon modifiers are applicable. 0 = not subject to modifier rules. 1 = bilateral surgery applies. 2 = assistant surgeon may not be paid. 3 = assistant surgeon and co-surgeon rules apply. 9 = concept does not apply.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multipleProcedureIndicator rdf:type rdf:Property ;
    rdfs:label 'Multiple Procedure Indicator' ;
    rdfs:comment 'Indicates payment adjustment rules when multiple procedures are performed in the same session. 0 = no payment adjustment. 1 = standard payment adjustment applies. 2 = bilateral adjustment applies. 3 = assistant surgeon adjustment. 4 = diagnostic imaging adjustment. 5 = therapy adjustment. 9 = concept does not apply. [ENUM-REF-CANDIDATE: 0|1|2|3|4|5|9 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'National Payment Amount' ;
    rdfs:comment 'National average Medicare payment amount for the CPT code, calculated as total RVU multiplied by the conversion factor. Actual payment varies by geographic locality. Used for budgeting and benchmarking.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ncciEditIndicator rdf:type rdf:Property ;
    rdfs:label 'Ncci Edit Indicator' ;
    rdfs:comment 'Indicates whether this CPT code is subject to National Correct Coding Initiative edits, which prevent inappropriate code combinations from being billed together. Used for claims scrubbing and compliance.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicianSupervisionRequired rdf:type rdf:Property ;
    rdfs:label 'Physician Supervision Required' ;
    rdfs:comment 'Level of physician supervision required for the service to be billable. Direct = physician must be present in the room. General = physician must be immediately available. Personal = physician must perform the service. None = no supervision required.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfServiceRestriction rdf:type rdf:Property ;
    rdfs:label 'Place Of Service Restriction' ;
    rdfs:comment 'Comma-separated list of valid CMS Place of Service codes where this CPT code may be performed and billed. Used for claims editing and compliance validation.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceExpenseRvu rdf:type rdf:Property ;
    rdfs:label 'Practice Expense Rvu' ;
    rdfs:comment 'Relative Value Unit representing the practice expense component, including clinical staff, medical supplies, and equipment costs. Varies by facility vs non-facility setting.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:section rdf:type rdf:Property ;
    rdfs:label 'Section' ;
    rdfs:comment 'High-level section of the CPT code set to which this code belongs, such as Evaluation and Management, Anesthesia, Surgery, Radiology, Pathology and Laboratory, or Medicine. Used for reporting and analytics grouping.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortDescriptor rdf:type rdf:Property ;
    rdfs:label 'Short Descriptor' ;
    rdfs:comment 'Abbreviated description of the procedure or service, typically 28 characters or fewer, used in billing systems and charge capture interfaces for space-constrained displays.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subsection rdf:type rdf:Property ;
    rdfs:label 'Subsection' ;
    rdfs:comment 'Subsection within the CPT section, providing more granular classification such as Digestive System, Cardiovascular System, or Office Visits. Used for clinical analytics and charge capture workflows.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telemedicineEligible rdf:type rdf:Property ;
    rdfs:label 'Telemedicine Eligible' ;
    rdfs:comment 'Indicates whether the service can be delivered via telemedicine or telehealth platforms and remain eligible for reimbursement. Updated based on CMS and payer policies.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalRvu rdf:type rdf:Property ;
    rdfs:label 'Total Rvu' ;
    rdfs:comment 'Sum of work RVU, practice expense RVU, and malpractice RVU. Used to calculate Medicare reimbursement and benchmark physician productivity.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workRvu rdf:type rdf:Property ;
    rdfs:label 'Work Rvu' ;
    rdfs:comment 'Relative Value Unit representing the physician work component, including time, technical skill, physical effort, mental effort, and judgment required to perform the service. Used in MIPS reporting and physician compensation models.' ;
    rdfs:domain ind:CptCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ageRestriction rdf:type rdf:Property ;
    rdfs:label 'Age Restriction' ;
    rdfs:comment 'Indicates any age-based coverage restrictions for this HCPCS code (e.g., pediatric only, adult only, age 65+). Defines patient age eligibility criteria.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ascPaymentIndicator rdf:type rdf:Property ;
    rdfs:label 'Asc Payment Indicator' ;
    rdfs:comment 'Indicates the payment methodology for this HCPCS code when performed in an Ambulatory Surgical Center setting. Defines whether the code is separately payable, bundled, or excluded from ASC payment.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistantSurgeonIndicator rdf:type rdf:Property ;
    rdfs:label 'Assistant Surgeon Indicator' ;
    rdfs:comment 'Indicates whether an assistant surgeon is allowed for this HCPCS code and the applicable payment percentage for assistant surgeon services.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bilateralSurgeryIndicator rdf:type rdf:Property ;
    rdfs:label 'Bilateral Surgery Indicator' ;
    rdfs:comment 'Indicates whether this HCPCS code is eligible for bilateral surgery payment adjustment when performed on both sides of the body during the same operative session.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coSurgeonIndicator rdf:type rdf:Property ;
    rdfs:label 'Co Surgeon Indicator' ;
    rdfs:comment 'Indicates whether co-surgeons are allowed for this HCPCS code, where two surgeons perform distinct portions of a complex procedure.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageIndicator rdf:type rdf:Property ;
    rdfs:label 'Coverage Indicator' ;
    rdfs:comment 'Indicates whether the HCPCS code is covered by Medicare: covered codes are reimbursable, not_covered codes are excluded, carrier_discretion allows local Medicare Administrative Contractor (MAC) determination, bundled codes are included in other services, conditional codes require specific clinical criteria.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisRequirementIndicator rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Requirement Indicator' ;
    rdfs:comment 'Indicates whether this HCPCS code requires specific ICD-10 diagnosis codes for coverage. True if diagnosis-based medical necessity criteria apply, false otherwise.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dmeIndicator rdf:type rdf:Property ;
    rdfs:label 'Dme Indicator' ;
    rdfs:comment 'Indicates whether this HCPCS code represents durable medical equipment as defined by Medicare. True for DME items (typically E-codes), false for other categories.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drugIndicator rdf:type rdf:Property ;
    rdfs:label 'Drug Indicator' ;
    rdfs:comment 'Indicates whether this HCPCS code represents a pharmaceutical drug or biological product (typically J-codes). True for drug codes, false for equipment, supplies, and services.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyLimit rdf:type rdf:Property ;
    rdfs:label 'Frequency Limit' ;
    rdfs:comment 'The maximum frequency at which this HCPCS code can be billed (e.g., once per year, once per lifetime, twice per month). Defines time-based coverage restrictions.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intraoperativePercentage rdf:type rdf:Property ;
    rdfs:label 'Intraoperative Percentage' ;
    rdfs:comment 'The percentage of the total payment allocated to intraoperative services for this HCPCS code within the global surgical package.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'The date on which this HCPCS code record was last modified in the reference data system, reflecting the most recent change to code attributes, descriptions, or coverage indicators.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifierRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Modifier Required Indicator' ;
    rdfs:comment 'Indicates whether a modifier is required when billing this HCPCS code. True if a modifier is mandatory for proper claims adjudication, false otherwise.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndcCrosswalkIndicator rdf:type rdf:Property ;
    rdfs:label 'Ndc Crosswalk Indicator' ;
    rdfs:comment 'Indicates whether this HCPCS code has an associated NDC crosswalk mapping. True for drug codes that map to specific NDC products, false otherwise.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oppsPaymentIndicator rdf:type rdf:Property ;
    rdfs:label 'Opps Payment Indicator' ;
    rdfs:comment 'Indicates the payment status for this HCPCS code under the Hospital Outpatient Prospective Payment System. Defines whether the code is separately payable, packaged, or excluded from OPPS payment.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postoperativePercentage rdf:type rdf:Property ;
    rdfs:label 'Postoperative Percentage' ;
    rdfs:comment 'The percentage of the total payment allocated to postoperative services for this HCPCS code within the global surgical package.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preoperativePercentage rdf:type rdf:Property ;
    rdfs:label 'Preoperative Percentage' ;
    rdfs:comment 'The percentage of the total payment allocated to preoperative services for this HCPCS code within the global surgical package.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingIndicator rdf:type rdf:Property ;
    rdfs:label 'Pricing Indicator' ;
    rdfs:comment 'Indicates the pricing methodology for the HCPCS code: fee_schedule uses CMS published rates, asc uses Ambulatory Surgical Center payment, reasonable_charge uses historical pricing, not_priced has no established rate, contractor_priced is determined by local MAC.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthorizationIndicator rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Indicator' ;
    rdfs:comment 'Indicates whether this HCPCS code requires prior authorization from the payer before services can be rendered. True if pre-approval is required, false otherwise.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:professionalComponentIndicator rdf:type rdf:Property ;
    rdfs:label 'Professional Component Indicator' ;
    rdfs:comment 'Indicates whether this HCPCS code has separate professional and technical components (e.g., for radiology and pathology services). Defines billing options for split or global billing.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamSurgeryIndicator rdf:type rdf:Property ;
    rdfs:label 'Team Surgery Indicator' ;
    rdfs:comment 'Indicates whether team surgery is allowed for this HCPCS code, where multiple surgeons of different specialties are medically necessary.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalComponentIndicator rdf:type rdf:Property ;
    rdfs:label 'Technical Component Indicator' ;
    rdfs:comment 'Indicates whether this HCPCS code includes a technical component representing facility resources, equipment, and supplies.' ;
    rdfs:domain ind:HcpcsCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complicationLevel rdf:type rdf:Property ;
    rdfs:label 'Complication Level' ;
    rdfs:comment 'Indicates the severity level of complications or comorbidities included in this DRG definition: without CC/MCC, with CC (moderate complications), or with MCC (major complications). Drives relative weight differentiation.' ;
    rdfs:domain ind:Drg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOutlierThreshold rdf:type rdf:Property ;
    rdfs:label 'Cost Outlier Threshold' ;
    rdfs:comment 'The dollar threshold above which a case qualifies for additional outlier payment. Calculated as: (DRG payment × fixed loss ratio) + fixed loss amount.' ;
    rdfs:domain ind:Drg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grouperSystem rdf:type rdf:Property ;
    rdfs:label 'Grouper System' ;
    rdfs:comment 'The DRG grouper classification system under which this DRG is defined: MS-DRG (Medicare Severity), AP-DRG (All Patient), APR-DRG (All Patient Refined), or IR-DRG (International Refined).' ;
    rdfs:domain ind:Drg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalAverageCharges rdf:type rdf:Property ;
    rdfs:label 'National Average Charges' ;
    rdfs:comment 'The national average total charges (not payments) for cases in this DRG. Used for charge benchmarking and cost-to-charge ratio analysis.' ;
    rdfs:domain ind:Drg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nationalAveragePayment rdf:type rdf:Property ;
    rdfs:label 'National Average Payment' ;
    rdfs:comment 'The national average Medicare payment amount for this DRG, calculated as: national base rate × relative weight. Used for benchmarking and financial forecasting.' ;
    rdfs:domain ind:Drg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nationalCaseVolume rdf:type rdf:Property ;
    rdfs:label 'National Case Volume' ;
    rdfs:comment 'The total number of Medicare cases nationally that grouped to this DRG in the most recent fiscal year. Used for prevalence analysis and market sizing.' ;
    rdfs:domain ind:Drg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingRoomProcedureFlag rdf:type rdf:Property ;
    rdfs:label 'Operating Room Procedure Flag' ;
    rdfs:comment 'Indicates whether this DRG is classified as an OR procedure DRG, which affects payment and resource allocation.' ;
    rdfs:domain ind:Drg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postAcuteTransferFlag rdf:type rdf:Property ;
    rdfs:label 'Post Acute Transfer Flag' ;
    rdfs:comment 'Indicates whether this DRG is subject to the post-acute care transfer policy, which adjusts payment when a patient is discharged to a post-acute care setting (SNF, IRF, LTCH, HHA) before the geometric mean LOS.' ;
    rdfs:domain ind:Drg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:principalDiagnosisRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Principal Diagnosis Range End' ;
    rdfs:comment 'The ending ICD-10-CM diagnosis code in the range of principal diagnoses that can group to this DRG.' ;
    rdfs:domain ind:Drg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalDiagnosisRangeStart rdf:type rdf:Property ;
    rdfs:label 'Principal Diagnosis Range Start' ;
    rdfs:comment 'The starting ICD-10-CM diagnosis code in the range of principal diagnoses that can group to this DRG. Used for grouper logic validation and clinical documentation improvement.' ;
    rdfs:domain ind:Drg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Procedure Requirement Flag' ;
    rdfs:comment 'Indicates whether this DRG requires the presence of a specific ICD-10-PCS procedure code to group (true for surgical DRGs, false for medical DRGs).' ;
    rdfs:domain ind:Drg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:readmissionPenaltyFlag rdf:type rdf:Property ;
    rdfs:label 'Readmission Penalty Flag' ;
    rdfs:comment 'Indicates whether this DRG is included in the Hospital Readmissions Reduction Program (HRRP) and subject to payment penalties for excess readmissions.' ;
    rdfs:domain ind:Drg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relativeWeight rdf:type rdf:Property ;
    rdfs:label 'Relative Weight' ;
    rdfs:comment 'The DRG relative weight representing the average resource intensity for cases in this DRG compared to the national average (1.0000). Used to calculate expected reimbursement: base rate × relative weight.' ;
    rdfs:domain ind:Drg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialPayFlag rdf:type rdf:Property ;
    rdfs:label 'Special Pay Flag' ;
    rdfs:comment 'Indicates whether this DRG has special payment rules or adjustments (e.g., new technology add-on payments, device-intensive procedures).' ;
    rdfs:domain ind:Drg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cptMapTargetCptCodeId rdf:type rdf:Property ;
    rdfs:label 'Cpt Map Target Cpt Code Id' ;
    rdfs:comment 'Foreign key linking to reference.cpt_code. Business justification: snomed_concept has a cpt_map_target STRING column that stores a CPT code string representing the mapped CPT procedure code for this clinical concept. The cpt_code table is the authoritative CPT master' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CptCode .

ind:loincMapTargetLoincCodeId rdf:type rdf:Property ;
    rdfs:label 'Loinc Map Target Loinc Code Id' ;
    rdfs:comment 'Foreign key linking to reference.loinc_code. Business justification: snomed_concept has a loinc_map_target STRING column that stores a LOINC code string representing the mapped LOINC observation code for this clinical concept. The loinc_code table is the authoritative ' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoincCode .

ind:parentConceptSnomedConceptId rdf:type rdf:Property ;
    rdfs:label 'Parent Concept Snomed Concept Id' ;
    rdfs:comment 'Identifier of the immediate parent concept in the SNOMED CT IS-A hierarchy. Used to navigate the taxonomy and determine subsumption relationships. A concept may have multiple parents in a polyhierarchy.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SnomedConcept .

ind:clinicalDocumentationSection rdf:type rdf:Property ;
    rdfs:label 'Clinical Documentation Section' ;
    rdfs:comment 'The typical section(s) of clinical documentation where this concept is used (e.g., \'Problem List\', \'Allergies\', \'Past Medical History\', \'Assessment\', \'Plan\', \'Procedures\'). Supports context-aware search and documentation templates.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conceptClass rdf:type rdf:Property ;
    rdfs:label 'Concept Class' ;
    rdfs:comment 'Additional classification of the concept beyond the semantic tag, used for grouping and filtering (e.g., \'diagnosis\', \'symptom\', \'surgical procedure\', \'medication\', \'laboratory test\'). May be derived from semantic tag or additional metadata.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conceptDefinition rdf:type rdf:Property ;
    rdfs:label 'Concept Definition' ;
    rdfs:comment 'A formal textual definition of the concept providing clinical context and meaning. May be sourced from SNOMED International or supplemented with organizational definitions for clarity.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conceptStatus rdf:type rdf:Property ;
    rdfs:label 'Concept Status' ;
    rdfs:comment 'Current lifecycle status of the SNOMED CT concept. Active concepts are available for use in clinical documentation; inactive concepts are deprecated and should not be used for new entries but may appear in historical data.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionStatus rdf:type rdf:Property ;
    rdfs:label 'Definition Status' ;
    rdfs:comment 'Indicates whether the concept is primitive (defined only by its stated relationships) or fully defined (sufficient conditions provided for automated classification). Fully defined concepts can be automatically classified by description logic reasoners.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveTime rdf:type rdf:Property ;
    rdfs:label 'Effective Time' ;
    rdfs:comment 'The date on which this version of the concept became effective in the SNOMED CT release. Represents the snapshot date of the concept state in the release cycle (typically in YYYYMMDD format in source, stored as DATE).' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fhirValueSetMembership rdf:type rdf:Property ;
    rdfs:label 'Fhir Value Set Membership' ;
    rdfs:comment 'Comma-separated list of FHIR value set identifiers (URIs) to which this concept belongs. Used to support FHIR-based interoperability and constrain coded elements in FHIR resources.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullySpecifiedName rdf:type rdf:Property ;
    rdfs:label 'Fully Specified Name' ;
    rdfs:comment 'The complete, unambiguous name of the SNOMED CT concept including the semantic tag in parentheses (e.g., \'Pneumonia (disorder)\'). The FSN uniquely identifies the concept and includes the semantic category to distinguish homonyms.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'The depth of this concept in the SNOMED CT hierarchy, with the root concept at level 0. Used for hierarchy traversal, rollup queries, and determining concept granularity.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:icd10MapCorrelation rdf:type rdf:Property ;
    rdfs:label 'Icd10 Map Correlation' ;
    rdfs:comment 'The correlation type between the SNOMED CT concept and the ICD-10 map target, indicating the semantic equivalence of the mapping (e.g., exact match, SNOMED concept is narrower than ICD-10 code, SNOMED concept is broader, partial overlap, or not mappable).' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icd10MapTarget rdf:type rdf:Property ;
    rdfs:label 'Icd10 Map Target' ;
    rdfs:comment 'The ICD-10 code(s) to which this SNOMED CT concept is mapped, if applicable. Supports billing, reporting, and interoperability with systems that use ICD-10 for diagnosis coding. Multiple codes may be pipe-separated.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEhrPreferred rdf:type rdf:Property ;
    rdfs:label 'Is Ehr Preferred' ;
    rdfs:comment 'Boolean flag indicating whether this concept is designated as a preferred term for use in the organization\'s EHR system. Preferred concepts are promoted in search results and pick lists to standardize documentation.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeafConcept rdf:type rdf:Property ;
    rdfs:label 'Is Leaf Concept' ;
    rdfs:comment 'Boolean flag indicating whether this concept is a leaf node in the hierarchy (has no child concepts). Leaf concepts represent the most granular clinical terms available.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimitive rdf:type rdf:Property ;
    rdfs:label 'Is Primitive' ;
    rdfs:comment 'Boolean flag indicating whether the concept is primitive (true) or fully defined (false). Primitive concepts require manual classification; fully defined concepts can be automatically classified by reasoners.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReportable rdf:type rdf:Property ;
    rdfs:label 'Is Reportable' ;
    rdfs:comment 'Boolean flag indicating whether this concept represents a condition that must be reported to public health authorities (e.g., notifiable diseases, healthcare-associated infections). Used to trigger automated reporting workflows.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'The most recent date on which this concept was used in clinical documentation within the organization. Used to identify obsolete or rarely used concepts for potential retirement or training needs.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moduleCode rdf:type rdf:Property ;
    rdfs:label 'Module Code' ;
    rdfs:comment 'Identifier of the SNOMED CT module (namespace) to which this concept belongs. Modules represent different editions or extensions (e.g., International Edition, US Edition, UK Edition) and control versioning and governance.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patientFriendlyTerm rdf:type rdf:Property ;
    rdfs:label 'Patient Friendly Term' ;
    rdfs:comment 'A simplified, patient-friendly description of the concept for use in patient portals, after-visit summaries, and patient education materials. Avoids medical jargon and uses plain language.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredTerm rdf:type rdf:Property ;
    rdfs:label 'Preferred Term' ;
    rdfs:comment 'The preferred human-readable term for the concept in the default language (typically English). This is the term most commonly used in clinical documentation and user interfaces, without the semantic tag.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityMeasureInclusion rdf:type rdf:Property ;
    rdfs:label 'Quality Measure Inclusion' ;
    rdfs:comment 'Comma-separated list of quality measure identifiers (e.g., HEDIS, CMS, MIPS) for which this concept is included in the numerator, denominator, or exclusion criteria. Supports automated quality reporting and value-based care programs.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipCount rdf:type rdf:Property ;
    rdfs:label 'Relationship Count' ;
    rdfs:comment 'The total number of active relationships (both stated and inferred) associated with this concept. Relationships define the concept\'s meaning and position in the ontology.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rxnormMapTarget rdf:type rdf:Property ;
    rdfs:label 'Rxnorm Map Target' ;
    rdfs:comment 'The RxNorm code(s) to which this SNOMED CT pharmaceutical/biologic product concept is mapped, if applicable. Enables medication interoperability and e-prescribing by linking to the NLM RxNorm drug terminology.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:semanticTag rdf:type rdf:Property ;
    rdfs:label 'Semantic Tag' ;
    rdfs:comment 'The high-level semantic category of the concept extracted from the FSN (e.g., \'disorder\', \'procedure\', \'finding\', \'body structure\', \'substance\', \'organism\'). Used to classify concepts into broad clinical domains.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyRelevance rdf:type rdf:Property ;
    rdfs:label 'Specialty Relevance' ;
    rdfs:comment 'Comma-separated list of medical specialties for which this concept is particularly relevant (e.g., \'Cardiology\', \'Oncology\', \'Pediatrics\', \'Emergency Medicine\'). Used to customize pick lists and search results by provider specialty.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synonymCount rdf:type rdf:Property ;
    rdfs:label 'Synonym Count' ;
    rdfs:comment 'The number of active synonym descriptions associated with this concept. Synonyms provide alternative terms for the same concept to support varied clinical documentation styles and search.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:topLevelHierarchy rdf:type rdf:Property ;
    rdfs:label 'Top Level Hierarchy' ;
    rdfs:comment 'The top-level SNOMED CT hierarchy to which this concept belongs (e.g., \'Clinical Finding\', \'Procedure\', \'Body Structure\', \'Pharmaceutical / Biologic Product\', \'Organism\', \'Substance\', \'Physical Object\', \'Qualifier Value\', \'Observable Entity\', \'Situation\', \'Event\', \'Environment\', \'Social Context\', \'Staging and Scales\', \'Linkage Concept\', \'Special Concept\', \'Navigational Concept\', \'Record Artifact\'). Derived from the root ancestor in the IS-A hierarchy.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageFrequencyRank rdf:type rdf:Property ;
    rdfs:label 'Usage Frequency Rank' ;
    rdfs:comment 'Rank of this concept based on usage frequency in clinical documentation within the organization. Lower numbers indicate higher usage. Used to prioritize search results and optimize user interfaces.' ;
    rdfs:domain ind:SnomedConcept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:class rdf:type rdf:Property ;
    rdfs:label 'Class' ;
    rdfs:comment 'The high-level category or domain of the observation (e.g., CHEM=Chemistry, HEM/BC=Hematology/Blood Count, MICRO=Microbiology, RAD=Radiology, VITALS=Vital Signs).' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:component rdf:type rdf:Property ;
    rdfs:label 'Component' ;
    rdfs:comment 'The substance or entity being measured or observed (e.g., Glucose, Hemoglobin, Creatinine). This is the analyte, the target of the measurement.' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerName rdf:type rdf:Property ;
    rdfs:label 'Consumer Name' ;
    rdfs:comment 'A patient-friendly, lay-language name for the observation or test, used in patient portals and consumer-facing applications.' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecatedDate rdf:type rdf:Property ;
    rdfs:label 'Deprecated Date' ;
    rdfs:comment 'The date when this LOINC code was deprecated or retired. Null if the code is still active.' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exampleUcumUnits rdf:type rdf:Property ;
    rdfs:label 'Example Ucum Units' ;
    rdfs:comment 'The standardized UCUM representation of the example units. Used for interoperability and unit conversion.' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exampleUnits rdf:type rdf:Property ;
    rdfs:label 'Example Units' ;
    rdfs:comment 'Common units of measure for this observation (e.g., mg/dL, mmol/L, %). Provides guidance for result reporting.' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCopyrightNotice rdf:type rdf:Property ;
    rdfs:label 'External Copyright Notice' ;
    rdfs:comment 'Copyright or licensing information for LOINC codes that incorporate third-party content (e.g., SNOMED CT, CPT). Required for compliance with external terminology licenses.' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hl7FieldSubfieldCode rdf:type rdf:Property ;
    rdfs:label 'Hl7 Field Subfield Code' ;
    rdfs:comment 'The HL7 v2.x message field identifier where this LOINC code is typically used (e.g., OBX-3 for observation identifier). Supports HL7 message mapping.' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hl7V3CodeSystemOid rdf:type rdf:Property ;
    rdfs:label 'Hl7 V3 Code System Oid' ;
    rdfs:comment 'The HL7 v3 object identifier for the LOINC code system (typically 2.16.840.1.113883.6.1). Used in CDA documents and HL7 v3 messages.' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loincNumber rdf:type rdf:Property ;
    rdfs:label 'Loinc Number' ;
    rdfs:comment 'The unique LOINC code identifier assigned by Regenstrief Institute. Format: numeric-numeric (e.g., 2345-7). This is the authoritative external identifier for the observation or test.' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longCommonName rdf:type rdf:Property ;
    rdfs:label 'Long Common Name' ;
    rdfs:comment 'The full, human-readable display name for the LOINC code. This is the primary display term used in clinical systems and reports.' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodType rdf:type rdf:Property ;
    rdfs:label 'Method Type' ;
    rdfs:comment 'The method or technique used to make the observation or measurement (e.g., Electrophoresis, Immunoassay, Microscopy). May be null if method is not specified.' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderObservationFlag rdf:type rdf:Property ;
    rdfs:label 'Order Observation Flag' ;
    rdfs:comment 'Indicates whether this LOINC code is used for ordering tests, recording observations, or both. Order=orderable panel or test, Observation=result only, Both=can be used for ordering and results.' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:panelType rdf:type rdf:Property ;
    rdfs:label 'Panel Type' ;
    rdfs:comment 'Indicates if this LOINC code represents a panel (group of related tests), battery (predefined test group), or set (collection of observations). Null for individual observations.' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:property rdf:type rdf:Property ;
    rdfs:label 'Property' ;
    rdfs:comment 'The characteristic or attribute of the analyte being measured (e.g., Mass Concentration, Substance Concentration, Presence, Volume).' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleType rdf:type rdf:Property ;
    rdfs:label 'Scale Type' ;
    rdfs:comment 'The scale of measurement for the observation result. Qn=Quantitative (numeric), Ord=Ordinal (ranked), Nom=Nominal (named categories), Nar=Narrative (free text), Doc=Document (attached file).' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'An abbreviated display name for the LOINC code, used when space is limited in user interfaces or reports.' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyQuestionSource rdf:type rdf:Property ;
    rdfs:label 'Survey Question Source' ;
    rdfs:comment 'The source instrument or questionnaire from which the survey question originates (e.g., PHQ-9, PROMIS, CAHPS).' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyQuestionText rdf:type rdf:Property ;
    rdfs:label 'Survey Question Text' ;
    rdfs:comment 'For LOINC codes representing survey or assessment questions, this field contains the full question text as presented to the patient or clinician.' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:system rdf:type rdf:Property ;
    rdfs:label 'System' ;
    rdfs:comment 'The specimen or body system from which the observation was made (e.g., Blood, Serum, Urine, Plasma, Cerebrospinal fluid).' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeAspect rdf:type rdf:Property ;
    rdfs:label 'Time Aspect' ;
    rdfs:comment 'The time dimension of the measurement (e.g., Point in time, 24 hour, 8 hour). Indicates whether the observation is a single point measurement or collected over a time interval.' ;
    rdfs:domain ind:LoincCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeIngredient rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient' ;
    rdfs:comment 'The chemical substance or compound responsible for the therapeutic effect of the drug.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'The FDA application number associated with the drug approval (e.g., NDA number, ANDA number, BLA number).' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biosimilarFlag rdf:type rdf:Property ;
    rdfs:label 'Biosimilar Flag' ;
    rdfs:comment 'Indicates whether the drug is a biosimilar product, highly similar to an already-approved biological product.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fhirMedicationCode rdf:type rdf:Property ;
    rdfs:label 'Fhir Medication Code' ;
    rdfs:comment 'The standardized medication code used in FHIR MedicationRequest and Medication resources for interoperability.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpiCode rdf:type rdf:Property ;
    rdfs:label 'Gpi Code' ;
    rdfs:comment 'The Medi-Span Generic Product Identifier, a 14-character hierarchical classification code used in pharmacy systems.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highAlertMedicationFlag rdf:type rdf:Property ;
    rdfs:label 'High Alert Medication Flag' ;
    rdfs:comment 'Indicates whether the drug is classified as a high-alert medication by ISMP, requiring special handling and verification procedures.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelerName rdf:type rdf:Property ;
    rdfs:label 'Labeler Name' ;
    rdfs:comment 'The name of the company or entity that manufactures, repackages, or distributes the drug product.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingCategory rdf:type rdf:Property ;
    rdfs:label 'Marketing Category' ;
    rdfs:comment 'The regulatory pathway under which the drug was approved (e.g., NDA, ANDA, BLA, OTC Monograph).' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingEndDate rdf:type rdf:Property ;
    rdfs:label 'Marketing End Date' ;
    rdfs:comment 'The date on which the drug product was discontinued or withdrawn from the market. Null if still active.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingStartDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Start Date' ;
    rdfs:comment 'The date on which the drug product was first marketed or made available for distribution.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonproprietaryName rdf:type rdf:Property ;
    rdfs:label 'Nonproprietary Name' ;
    rdfs:comment 'The generic or non-proprietary name of the drug, typically the active ingredient name established by the United States Adopted Names (USAN) Council.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orangeBookCode rdf:type rdf:Property ;
    rdfs:label 'Orange Book Code' ;
    rdfs:comment 'The therapeutic equivalence code from the FDA Orange Book, indicating whether a generic drug is therapeutically equivalent to the brand-name drug.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overTheCounterFlag rdf:type rdf:Property ;
    rdfs:label 'Over The Counter Flag' ;
    rdfs:comment 'Indicates whether the drug is available for purchase without a prescription.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageDescription rdf:type rdf:Property ;
    rdfs:label 'Package Description' ;
    rdfs:comment 'A textual description of the package size and configuration (e.g., bottle of 100 tablets, box of 10 vials).' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageQuantity rdf:type rdf:Property ;
    rdfs:label 'Package Quantity' ;
    rdfs:comment 'The numeric quantity of units contained in the package.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageUnit rdf:type rdf:Property ;
    rdfs:label 'Package Unit' ;
    rdfs:comment 'The unit of measure for the package quantity (e.g., tablet, capsule, mL, vial).' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'The full product name as registered with the FDA, including strength and dosage form.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proprietaryName rdf:type rdf:Property ;
    rdfs:label 'Proprietary Name' ;
    rdfs:comment 'The brand or trade name under which the drug is marketed to consumers and healthcare providers.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rxcui rdf:type rdf:Property ;
    rdfs:label 'Rxcui' ;
    rdfs:comment 'The RxNorm Concept Unique Identifier assigned by the National Library of Medicine, providing a normalized drug concept mapping for interoperability.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rxnormName rdf:type rdf:Property ;
    rdfs:label 'Rxnorm Name' ;
    rdfs:comment 'The normalized drug name as defined in RxNorm, representing the clinical drug concept.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rxnormSourceVocabulary rdf:type rdf:Property ;
    rdfs:label 'Rxnorm Source Vocabulary' ;
    rdfs:comment 'The source vocabulary from which the RxNorm concept was derived (e.g., RXNORM, VANDF, MMSL, NDDF).' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rxnormSuppressFlag rdf:type rdf:Property ;
    rdfs:label 'Rxnorm Suppress Flag' ;
    rdfs:comment 'Indicates whether the RxNorm concept is suppressed from use (N=not suppressed, Y=suppressed, O=obsolete, E=entry term).' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rxnormTermType rdf:type rdf:Property ;
    rdfs:label 'Rxnorm Term Type' ;
    rdfs:comment 'The RxNorm term type classification (e.g., IN for ingredient, BN for brand name, SCD for semantic clinical drug, GPCK for generic pack).' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthUnit rdf:type rdf:Property ;
    rdfs:label 'Strength Unit' ;
    rdfs:comment 'The unit of measure for the drug strength (e.g., mg, mL, mcg, IU, %).' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticClass rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Class' ;
    rdfs:comment 'The therapeutic or pharmacological classification of the drug (e.g., antibiotic, antihypertensive, analgesic).' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uniiCode rdf:type rdf:Property ;
    rdfs:label 'Unii Code' ;
    rdfs:comment 'The FDA Unique Ingredient Identifier code for the active ingredient, used for substance identification.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaccineFlag rdf:type rdf:Property ;
    rdfs:label 'Vaccine Flag' ;
    rdfs:comment 'Indicates whether the drug product is a vaccine used for immunization.' ;
    rdfs:domain ind:NdcDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizedOfficialFirstName rdf:type rdf:Property ;
    rdfs:label 'Authorized Official First Name' ;
    rdfs:comment 'The first name of the authorized official for the organizational provider (Type 2 NPIs only). Used for credentialing verification and organizational accountability.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedOfficialLastName rdf:type rdf:Property ;
    rdfs:label 'Authorized Official Last Name' ;
    rdfs:comment 'The last name of the authorized official who is legally responsible for the organizational provider (Type 2 NPIs only). This individual has authority to bind the organization and attest to the accuracy of NPI application information.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedOfficialMiddleName rdf:type rdf:Property ;
    rdfs:label 'Authorized Official Middle Name' ;
    rdfs:comment 'The middle name of the authorized official for the organizational provider (Type 2 NPIs only). Optional field for complete identification.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedOfficialTelephoneNumber rdf:type rdf:Property ;
    rdfs:label 'Authorized Official Telephone Number' ;
    rdfs:comment 'The telephone number of the authorized official for the organizational provider. Used for credentialing verification, attestation confirmation, and regulatory inquiries.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedOfficialTitle rdf:type rdf:Property ;
    rdfs:label 'Authorized Official Title' ;
    rdfs:comment 'The job title or position of the authorized official within the organization (e.g., CEO, CFO, Administrator, President, Medical Director). Used to verify organizational authority and credentialing compliance.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Employer Identification Number' ;
    rdfs:comment 'The IRS Employer Identification Number (EIN) for organizational providers (Type 2 only). Used for tax reporting and organizational identification. Also known as Federal Tax ID.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Entity Type Code' ;
    rdfs:comment 'Indicates whether the NPI is assigned to an individual provider (Type 1) or an organization (Type 2). Type 1 = Individual healthcare provider (physician, nurse, therapist). Type 2 = Healthcare organization (hospital, clinic, group practice, pharmacy).' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enumerationDate rdf:type rdf:Property ;
    rdfs:label 'Enumeration Date' ;
    rdfs:comment 'The date the NPI was originally assigned to the provider by NPPES. Represents the providers initial enrollment in the national provider registry. Critical for credentialing timelines and provider history tracking.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Update Date' ;
    rdfs:comment 'The date the NPI record was last updated in NPPES. Reflects the most recent change to provider demographic information, address, taxonomy, or other registry data. Used to track data freshness and trigger downstream updates.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mailingAddressCity rdf:type rdf:Property ;
    rdfs:label 'Mailing Address City' ;
    rdfs:comment 'The city name for the providers mailing address. Used for geographic segmentation and correspondence routing.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressCountryCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Country Code' ;
    rdfs:comment 'The three-letter ISO country code for the providers mailing address (e.g., USA, CAN, MEX). Used for international provider tracking and cross-border claims.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressFaxNumber rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Fax Number' ;
    rdfs:comment 'The fax number associated with the providers mailing address. Used for document transmission during credentialing, prior authorization, and claims correspondence.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line 1' ;
    rdfs:comment 'The first line of the providers mailing address (street address, PO Box, or suite number). Used for official correspondence, credentialing documents, and regulatory communications.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line 2' ;
    rdfs:comment 'The second line of the providers mailing address (apartment, suite, building, floor). Optional field for additional address detail.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Postal Code' ;
    rdfs:comment 'The ZIP code or ZIP+4 code for the providers mailing address. Used for mail delivery, geographic analysis, and service area determination.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressState rdf:type rdf:Property ;
    rdfs:label 'Mailing Address State' ;
    rdfs:comment 'The two-letter state or territory code for the providers mailing address (e.g., CA, NY, TX). Used for state-level reporting and regulatory compliance.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressTelephoneNumber rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Telephone Number' ;
    rdfs:comment 'The telephone number associated with the providers mailing address. Used for provider contact and verification during credentialing and claims inquiries.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationOtherName rdf:type rdf:Property ;
    rdfs:label 'Organization Other Name' ;
    rdfs:comment 'Alternate name, trade name, or doing-business-as (DBA) name for the healthcare organization. Used when the organization operates under a name different from its legal name.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceLocationAddressCountryCode rdf:type rdf:Property ;
    rdfs:label 'Practice Location Address Country Code' ;
    rdfs:comment 'The three-letter ISO country code for the providers practice location (e.g., USA, CAN, MEX). Used for international provider tracking and cross-border service delivery.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceLocationAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Practice Location Address Line 1' ;
    rdfs:comment 'The first line of the providers primary practice location address (street address, suite number). This is the physical location where the provider sees patients or delivers services. Used for provider directories, patient navigation, and service area mapping.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceLocationAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Practice Location Address Line 2' ;
    rdfs:comment 'The second line of the providers practice location address (apartment, suite, building, floor). Optional field for additional address detail.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceLocationFaxNumber rdf:type rdf:Property ;
    rdfs:label 'Practice Location Fax Number' ;
    rdfs:comment 'The fax number for the providers practice location. Used for medical records transmission, referral coordination, and prior authorization requests.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceLocationTelephoneNumber rdf:type rdf:Property ;
    rdfs:label 'Practice Location Telephone Number' ;
    rdfs:comment 'The telephone number for the providers practice location. Used for patient appointment scheduling, provider directory listings, and referral coordination.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTaxonomyCode rdf:type rdf:Property ;
    rdfs:label 'Primary Taxonomy Code' ;
    rdfs:comment 'The primary NUCC Health Care Provider Taxonomy code assigned to this NPI. A 10-digit alphanumeric code that classifies the providers type, classification, and specialization (e.g., 207Q00000X = Family Medicine, 208D00000X = General Practice). This is the providers main specialty for claims submission and network assignment.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTaxonomySwitch rdf:type rdf:Property ;
    rdfs:label 'Primary Taxonomy Switch' ;
    rdfs:comment 'Indicates whether the taxonomy code is designated as the providers primary taxonomy. Y = Yes (primary), N = No (secondary). Used to distinguish the main specialty from additional specialties for claims routing and network credentialing.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerCredential rdf:type rdf:Property ;
    rdfs:label 'Provider Credential' ;
    rdfs:comment 'The professional credential or designation of the individual provider (e.g., MD, DO, RN, DDS, PharmD, PhD, LCSW). Indicates the providers professional qualifications and licensure type.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerFirstName rdf:type rdf:Property ;
    rdfs:label 'Provider First Name' ;
    rdfs:comment 'The legal first name (given name) of the individual healthcare provider for Type 1 NPIs. Used for provider identification, credentialing, and claims submission.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerGenderCode rdf:type rdf:Property ;
    rdfs:label 'Provider Gender Code' ;
    rdfs:comment 'The gender of the individual provider for Type 1 NPIs. M = Male, F = Female. Used for provider demographic reporting and patient preference matching.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerLastName rdf:type rdf:Property ;
    rdfs:label 'Provider Last Name' ;
    rdfs:comment 'The legal last name (family name or surname) of the individual healthcare provider for Type 1 NPIs. Used for provider identification, credentialing, and claims submission.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerMiddleName rdf:type rdf:Property ;
    rdfs:label 'Provider Middle Name' ;
    rdfs:comment 'The middle name of the individual healthcare provider for Type 1 NPIs. Optional field used for complete provider identification.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerNamePrefix rdf:type rdf:Property ;
    rdfs:label 'Provider Name Prefix' ;
    rdfs:comment 'The name prefix or title for the individual provider (e.g., Dr., Mr., Ms., Rev.). Used for formal provider identification and correspondence.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerNameSuffix rdf:type rdf:Property ;
    rdfs:label 'Provider Name Suffix' ;
    rdfs:comment 'The name suffix for the individual provider (e.g., Jr., Sr., II, III). Used for complete provider identification and to distinguish between providers with similar names.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerOtherCredential rdf:type rdf:Property ;
    rdfs:label 'Provider Other Credential' ;
    rdfs:comment 'An alternate or additional professional credential for the individual provider. Used when a provider holds multiple credentials or has changed credentials.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerOtherFirstName rdf:type rdf:Property ;
    rdfs:label 'Provider Other First Name' ;
    rdfs:comment 'An alternate or previous first name for the individual provider. Used to track provider name changes and maintain historical continuity.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerOtherLastName rdf:type rdf:Property ;
    rdfs:label 'Provider Other Last Name' ;
    rdfs:comment 'An alternate or previous last name for the individual provider (e.g., maiden name, former married name). Used to track provider name changes and maintain historical continuity.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerOtherMiddleName rdf:type rdf:Property ;
    rdfs:label 'Provider Other Middle Name' ;
    rdfs:comment 'An alternate or previous middle name for the individual provider. Used to track provider name changes and maintain historical continuity.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerOtherNamePrefix rdf:type rdf:Property ;
    rdfs:label 'Provider Other Name Prefix' ;
    rdfs:comment 'An alternate name prefix for the individual provider. Used to track provider name changes.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerOtherNameSuffix rdf:type rdf:Property ;
    rdfs:label 'Provider Other Name Suffix' ;
    rdfs:comment 'An alternate name suffix for the individual provider. Used to track provider name changes.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactivationDate rdf:type rdf:Property ;
    rdfs:label 'Reactivation Date' ;
    rdfs:comment 'The date a previously deactivated NPI was reactivated. Indicates the provider has resumed use of this identifier. Used to track provider status changes and maintain accurate active provider lists.' ;
    rdfs:domain ind:NpiRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supersededByVersionCodeSetVersionId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Version Code Set Version Id' ;
    rdfs:comment 'Reference to the code_set_version_id of the newer version that replaces this one. Nullable if this is the current active version.' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeSetVersion .

ind:checksumAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Checksum Algorithm' ;
    rdfs:comment 'The cryptographic hash algorithm used to generate the file_hash for integrity verification: MD5, SHA256, or SHA512.' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeSetName rdf:type rdf:Property ;
    rdfs:label 'Code Set Name' ;
    rdfs:comment 'The name of the reference code set (e.g., ICD-10-CM, CPT, HCPCS, SNOMED CT, LOINC, NDC, RxNorm, DRG Grouper, HL7 Value Set, FHIR Value Set).' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeSetType rdf:type rdf:Property ;
    rdfs:label 'Code Set Type' ;
    rdfs:comment 'The functional category of the code set: diagnosis (ICD-10), procedure (CPT/HCPCS), drug (NDC/RxNorm), observation (LOINC), terminology (SNOMED CT), or grouper (DRG/APR-DRG).' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceYear rdf:type rdf:Property ;
    rdfs:label 'Compliance Year' ;
    rdfs:comment 'The fiscal or calendar year for which this code set version is required for regulatory compliance and reimbursement (e.g., 2024 for FY2024 ICD-10-CM).' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:copyrightNotice rdf:type rdf:Property ;
    rdfs:label 'Copyright Notice' ;
    rdfs:comment 'Legal copyright and licensing information for this code set version, including usage restrictions and attribution requirements.' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downloadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Download Timestamp' ;
    rdfs:comment 'The date and time when this code set version file was downloaded from the source authority.' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fileHash rdf:type rdf:Property ;
    rdfs:label 'File Hash' ;
    rdfs:comment 'Cryptographic hash (SHA-256 or MD5) of the source file, used to verify data integrity and detect unauthorized modifications.' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'The name of the source file or package containing this code set version (e.g., icd10cm_tabular_2024.xml, cpt_codes_2024.csv).' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'The file format or data structure of the source code set: csv (comma-separated values), xml (extensible markup language), json (JavaScript object notation), fhir (FHIR CodeSystem resource), hl7 (HL7 v2 table), proprietary (vendor-specific format).' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHipaaCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Hipaa Compliant' ;
    rdfs:comment 'Indicates whether this code set version meets HIPAA transaction and code set standards for electronic healthcare transactions.' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'The licensing model governing the use of this code set: public_domain (freely available), proprietary (commercial license required), open_source (open license with attribution), restricted (limited use agreement).' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadStatus rdf:type rdf:Property ;
    rdfs:label 'Load Status' ;
    rdfs:comment 'The current status of the ETL process for loading this code set version into the enterprise data platform: pending (queued), in_progress (loading), completed (successfully loaded), failed (load error), validated (post-load quality checks passed).' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Load Timestamp' ;
    rdfs:comment 'The date and time when this code set version was successfully loaded into the enterprise reference data repository.' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'The official date on which the source authority published or released this code set version.' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordCount rdf:type rdf:Property ;
    rdfs:label 'Record Count' ;
    rdfs:comment 'The total number of individual codes or entries contained in this code set version.' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releaseNotes rdf:type rdf:Property ;
    rdfs:label 'Release Notes' ;
    rdfs:comment 'Summary of changes, additions, deletions, and updates included in this code set version compared to the previous version.' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceAuthority rdf:type rdf:Property ;
    rdfs:label 'Source Authority' ;
    rdfs:comment 'The governing body or organization that publishes and maintains this code set (e.g., WHO, AMA, CMS, SNOMED International, Regenstrief Institute, FDA, NLM).' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceUrl rdf:type rdf:Property ;
    rdfs:label 'Source Url' ;
    rdfs:comment 'The official download or reference URL from which this code set version was obtained.' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageScope rdf:type rdf:Property ;
    rdfs:label 'Usage Scope' ;
    rdfs:comment 'The primary business domain(s) for which this code set version is intended: clinical (EHR documentation), billing (claims and revenue cycle), research (clinical trials and studies), quality (HEDIS/quality reporting), or all (enterprise-wide).' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'The date and time when data quality validation was performed on this code set version.' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:versionIdentifier rdf:type rdf:Property ;
    rdfs:label 'Version Identifier' ;
    rdfs:comment 'The official version number or release identifier assigned by the source authority (e.g., 2024, v3.5, FY2024, 20240101).' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of this code set version: draft (not yet effective), active (currently in use), superseded (replaced by newer version), retired (no longer valid), deprecated (scheduled for retirement).' ;
    rdfs:domain ind:CodeSetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crosswalkId rdf:type rdf:Property ;
    rdfs:label 'Crosswalk Id' ;
    rdfs:comment 'Unique identifier for the terminology crosswalk mapping record.' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approximateFlag rdf:type rdf:Property ;
    rdfs:label 'Approximate Flag' ;
    rdfs:comment 'Indicates whether the mapping is an approximate or inexact match (True) requiring clinical review, or an exact semantic match (False).' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:choiceListIndicator rdf:type rdf:Property ;
    rdfs:label 'Choice List Indicator' ;
    rdfs:comment 'Indicates whether the target code is one of multiple valid choices for the source code, requiring clinical judgment to select the most appropriate target.' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinationFlag rdf:type rdf:Property ;
    rdfs:label 'Combination Flag' ;
    rdfs:comment 'Indicates whether this mapping requires multiple target codes to fully represent the source code (True) or is a single 1:1 or 1:0 mapping (False).' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:directionality rdf:type rdf:Property ;
    rdfs:label 'Directionality' ;
    rdfs:comment 'Indicates whether the mapping is valid in one direction (forward: source to target only, backward: target to source only) or both directions (bidirectional).' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastValidatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Validated Date' ;
    rdfs:comment 'The most recent date on which this mapping was reviewed and validated by clinical or coding subject matter experts.' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mapGroup rdf:type rdf:Property ;
    rdfs:label 'Map Group' ;
    rdfs:comment 'Grouping identifier for related mappings that should be considered together (e.g., all mappings for a specific clinical domain or use case).' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mapPriority rdf:type rdf:Property ;
    rdfs:label 'Map Priority' ;
    rdfs:comment 'Numeric ranking indicating the preferred order when multiple target codes are valid for a single source code (lower numbers indicate higher priority).' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mappingAuthority rdf:type rdf:Property ;
    rdfs:label 'Mapping Authority' ;
    rdfs:comment 'The authoritative source or organization that published or validated this mapping (e.g., CMS, NLM, SNOMED International, Regenstrief Institute, internal clinical terminology team).' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingPurpose rdf:type rdf:Property ;
    rdfs:label 'Mapping Purpose' ;
    rdfs:comment 'The intended use case or business purpose for this mapping (e.g., claims submission, clinical documentation, quality reporting, SDOH screening, interoperability, legacy system migration).' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingQuality rdf:type rdf:Property ;
    rdfs:label 'Mapping Quality' ;
    rdfs:comment 'The confidence or precision level of the mapping: exact (perfect semantic match), high (strong clinical equivalence), moderate (acceptable with context), low (weak or conditional match).' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingRule rdf:type rdf:Property ;
    rdfs:label 'Mapping Rule' ;
    rdfs:comment 'Textual description of any conditional logic, clinical context, or business rules that govern when and how this mapping should be applied.' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingType rdf:type rdf:Property ;
    rdfs:label 'Mapping Type' ;
    rdfs:comment 'The semantic relationship between source and target codes: equivalent (1:1 exact match), broader (source is more specific than target), narrower (source is more general than target), related (associated but not hierarchical), inexact (approximate match), unmatched (no suitable target).' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noMapFlag rdf:type rdf:Property ;
    rdfs:label 'No Map Flag' ;
    rdfs:comment 'Indicates whether the source code has no suitable equivalent in the target code system (True) or a valid mapping exists (False).' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scenarioFlag rdf:type rdf:Property ;
    rdfs:label 'Scenario Flag' ;
    rdfs:comment 'Identifies specific clinical or billing scenarios where this mapping applies (e.g., inpatient vs outpatient, primary vs secondary diagnosis).' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceCode rdf:type rdf:Property ;
    rdfs:label 'Source Code' ;
    rdfs:comment 'The specific code value in the source code system being mapped from (e.g., E11.9 for ICD-10, 73211009 for SNOMED CT).' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceCodeDisplay rdf:type rdf:Property ;
    rdfs:label 'Source Code Display' ;
    rdfs:comment 'Human-readable display text or description for the source code.' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceCodeSystem rdf:type rdf:Property ;
    rdfs:label 'Source Code System' ;
    rdfs:comment 'The originating terminology or code system from which the mapping is derived (e.g., ICD-10-CM, SNOMED CT, CPT, LOINC, NDC, RxNorm).' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'The specific code value in the target code system being mapped to (e.g., 73211009 for SNOMED CT, 99213 for CPT).' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCodeDisplay rdf:type rdf:Property ;
    rdfs:label 'Target Code Display' ;
    rdfs:comment 'Human-readable display text or description for the target code.' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCodeSystem rdf:type rdf:Property ;
    rdfs:label 'Target Code System' ;
    rdfs:comment 'The destination terminology or code system to which the mapping is made (e.g., ICD-10-CM, SNOMED CT, CPT, LOINC, NDC, RxNorm).' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedBy rdf:type rdf:Property ;
    rdfs:label 'Validated By' ;
    rdfs:comment 'The name or identifier of the clinical or coding expert who last validated this mapping.' ;
    rdfs:domain ind:Crosswalk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPayerId rdf:type rdf:Property ;
    rdfs:label 'Parent Payer Id' ;
    rdfs:comment 'Reference to parent payer organization in a hierarchy.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payer .

ind:primarySuccessorPayerId rdf:type rdf:Property ;
    rdfs:label 'Primary Successor Payer Id' ;
    rdfs:comment 'Reference to the payer that succeeded this one after merger or acquisition.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payer .

ind:acceptsAssignment rdf:type rdf:Property ;
    rdfs:label 'Accepts Assignment' ;
    rdfs:comment 'Indicates whether the payer accepts assignment of benefits.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealLimitDays rdf:type rdf:Property ;
    rdfs:label 'Appeal Limit Days' ;
    rdfs:comment 'Number of days allowed for filing an appeal.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether contracts auto-renew.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimScrubbingVendor rdf:type rdf:Property ;
    rdfs:label 'Claim Scrubbing Vendor' ;
    rdfs:comment 'Name of the claim scrubbing vendor used.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsInquiryPhone rdf:type rdf:Property ;
    rdfs:label 'Claims Inquiry Phone' ;
    rdfs:comment 'Phone number for claims inquiries.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsSubmissionEndpoint rdf:type rdf:Property ;
    rdfs:label 'Claims Submission Endpoint' ;
    rdfs:comment 'URL or EDI endpoint for claim submission.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearinghouseCode rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Code' ;
    rdfs:comment 'Code identifying the clearinghouse used.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinationOfBenefitsRequired rdf:type rdf:Property ;
    rdfs:label 'Coordination Of Benefits Required' ;
    rdfs:comment 'Indicates whether coordination of benefits is required.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerServicePhone rdf:type rdf:Property ;
    rdfs:label 'Customer Service Phone' ;
    rdfs:comment 'Customer service phone number.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediPayerCode rdf:type rdf:Property ;
    rdfs:label 'Edi Payer Code' ;
    rdfs:comment 'EDI payer identification code.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicFundsTransferFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Funds Transfer Flag' ;
    rdfs:comment 'Indicates whether electronic funds transfer is supported.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:idExternal rdf:type rdf:Property ;
    rdfs:label 'Id External' ;
    rdfs:comment 'External system identifier for the payer.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inactivationDate rdf:type rdf:Property ;
    rdfs:label 'Inactivation Date' ;
    rdfs:comment 'Date when the payer was inactivated.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inactivationReason rdf:type rdf:Property ;
    rdfs:label 'Inactivation Reason' ;
    rdfs:comment 'Reason for payer inactivation.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days for payment terms.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portalUrl rdf:type rdf:Property ;
    rdfs:label 'Portal Url' ;
    rdfs:comment 'URL of the payer\'s provider portal.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerRelationsEmail rdf:type rdf:Property ;
    rdfs:label 'Provider Relations Email' ;
    rdfs:comment 'Email address for provider relations.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Remittance Address Line1' ;
    rdfs:comment 'First line of remittance address.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Remittance Address Line2' ;
    rdfs:comment 'Second line of remittance address.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceCity rdf:type rdf:Property ;
    rdfs:label 'Remittance City' ;
    rdfs:comment 'City for remittance address.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Remittance Delivery Method' ;
    rdfs:comment 'Method of remittance delivery (e.g., mail, electronic).' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittancePostalCode rdf:type rdf:Property ;
    rdfs:label 'Remittance Postal Code' ;
    rdfs:comment 'Postal code for remittance address.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceState rdf:type rdf:Property ;
    rdfs:label 'Remittance State' ;
    rdfs:comment 'State for remittance address.' ;
    rdfs:domain ind:Payer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timelyFilingLimitDays rdf:type rdf:Property ;
    rdfs:label 'Timely Filing Limit Days' ;
    rdfs:comment 'Number of days for timely filing of claims.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentConsentFormTemplateId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Consent Form Template Id' ;
    rdfs:comment 'Foreign key linking to consent.form_template. Business justification: Health plans mandate specific consent form templates for member enrollment (plan-specific HIPAA NPP, terms of coverage). Payer operations configure which form template applies per health plan. Role-pr' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormTemplate .

ind:predecessorHealthPlanId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Health Plan Id' ;
    rdfs:comment 'Reference to the predecessor plan if this plan replaced another.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthPlan .

ind:benefitYear rdf:type rdf:Property ;
    rdfs:label 'Benefit Year' ;
    rdfs:comment 'Calendar year for which benefits apply.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cmsContractNumber rdf:type rdf:Property ;
    rdfs:label 'Cms Contract Number' ;
    rdfs:comment 'CMS contract number for Medicare Advantage or Part D plans.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobOrder rdf:type rdf:Property ;
    rdfs:label 'Cob Order' ;
    rdfs:comment 'Coordination of benefits order (primary, secondary, tertiary).' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyRoomCopayAmount rdf:type rdf:Property ;
    rdfs:label 'Emergency Room Copay Amount' ;
    rdfs:comment 'Copay amount for emergency room visits.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:familyOopMaxAmount rdf:type rdf:Property ;
    rdfs:label 'Family Oop Max Amount' ;
    rdfs:comment 'Annual family out-of-pocket maximum.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fsaEligible rdf:type rdf:Property ;
    rdfs:label 'Fsa Eligible' ;
    rdfs:comment 'Indicates whether the plan is FSA-eligible.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fundingType rdf:type rdf:Property ;
    rdfs:label 'Funding Type' ;
    rdfs:comment 'Funding type (e.g., fully insured, self-funded).' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hraEligible rdf:type rdf:Property ;
    rdfs:label 'Hra Eligible' ;
    rdfs:comment 'Indicates whether the plan is HRA-eligible.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hsaEligible rdf:type rdf:Property ;
    rdfs:label 'Hsa Eligible' ;
    rdfs:comment 'Indicates whether the plan is HSA-eligible.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:individualOopMaxAmount rdf:type rdf:Property ;
    rdfs:label 'Individual Oop Max Amount' ;
    rdfs:comment 'Annual individual out-of-pocket maximum.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inpatientHospitalCopayAmount rdf:type rdf:Property ;
    rdfs:label 'Inpatient Hospital Copay Amount' ;
    rdfs:comment 'Copay amount for inpatient hospital stays.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuerState rdf:type rdf:Property ;
    rdfs:label 'Issuer State' ;
    rdfs:comment 'State where the plan is issued.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metalTier rdf:type rdf:Property ;
    rdfs:label 'Metal Tier' ;
    rdfs:comment 'ACA metal tier (Bronze, Silver, Gold, Platinum).' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openEnrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment End Date' ;
    rdfs:comment 'End date of open enrollment period.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openEnrollmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment Start Date' ;
    rdfs:comment 'Start date of open enrollment period.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outOfNetworkCoverage rdf:type rdf:Property ;
    rdfs:label 'Out Of Network Coverage' ;
    rdfs:comment 'Indicates whether out-of-network coverage is available.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outOfNetworkDeductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Out Of Network Deductible Amount' ;
    rdfs:comment 'Annual out-of-network deductible amount.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outOfNetworkOopMaxAmount rdf:type rdf:Property ;
    rdfs:label 'Out Of Network Oop Max Amount' ;
    rdfs:comment 'Annual out-of-network out-of-pocket maximum.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Plan Document Url' ;
    rdfs:comment 'URL to the plan document or summary of benefits.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planIdentifier rdf:type rdf:Property ;
    rdfs:label 'Plan Identifier' ;
    rdfs:comment 'External plan identifier or code.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionTier1CopayAmount rdf:type rdf:Property ;
    rdfs:label 'Prescription Tier1 Copay Amount' ;
    rdfs:comment 'Copay amount for tier 1 prescriptions.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prescriptionTier2CopayAmount rdf:type rdf:Property ;
    rdfs:label 'Prescription Tier2 Copay Amount' ;
    rdfs:comment 'Copay amount for tier 2 prescriptions.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prescriptionTier3CopayAmount rdf:type rdf:Property ;
    rdfs:label 'Prescription Tier3 Copay Amount' ;
    rdfs:comment 'Copay amount for tier 3 prescriptions.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prescriptionTier4CopayAmount rdf:type rdf:Property ;
    rdfs:label 'Prescription Tier4 Copay Amount' ;
    rdfs:comment 'Copay amount for tier 4 prescriptions.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preventiveCareCovered rdf:type rdf:Property ;
    rdfs:label 'Preventive Care Covered' ;
    rdfs:comment 'Indicates whether preventive care is covered at 100%.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryCareCopayAmount rdf:type rdf:Property ;
    rdfs:label 'Primary Care Copay Amount' ;
    rdfs:comment 'Copay amount for primary care visits.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresPcpSelection rdf:type rdf:Property ;
    rdfs:label 'Requires Pcp Selection' ;
    rdfs:comment 'Indicates whether members must select a primary care physician.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresReferralForSpecialist rdf:type rdf:Property ;
    rdfs:label 'Requires Referral For Specialist' ;
    rdfs:comment 'Indicates whether referrals are required for specialist visits.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceAreaDescription rdf:type rdf:Property ;
    rdfs:label 'Service Area Description' ;
    rdfs:comment 'Description of the geographic service area.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialistCopayAmount rdf:type rdf:Property ;
    rdfs:label 'Specialist Copay Amount' ;
    rdfs:comment 'Copay amount for specialist visits.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateFilingNumber rdf:type rdf:Property ;
    rdfs:label 'State Filing Number' ;
    rdfs:comment 'State regulatory filing number.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgentCareCopayAmount rdf:type rdf:Property ;
    rdfs:label 'Urgent Care Copay Amount' ;
    rdfs:comment 'Copay amount for urgent care visits.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentBenefitId rdf:type rdf:Property ;
    rdfs:label 'Parent Benefit Id' ;
    rdfs:comment 'Self-referencing FK on benefit (parent_benefit_id)' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Benefit .

ind:procedureHcpcsCodeId rdf:type rdf:Property ;
    rdfs:label 'Procedure Hcpcs Code Id' ;
    rdfs:comment 'Foreign key linking to reference.hcpcs_code. Business justification: Benefits for DME, supplies, and non-physician services are defined by HCPCS codes. Essential for benefit determination, prior authorization rules, and claims payment calculation in healthcare payer op' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HcpcsCode .

ind:allowedAmountBasis rdf:type rdf:Property ;
    rdfs:label 'Allowed Amount Basis' ;
    rdfs:comment 'Method used to determine the allowed amount for benefit adjudication. Defines how the plan calculates the maximum payable amount for a service.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitStatus rdf:type rdf:Property ;
    rdfs:label 'Benefit Status' ;
    rdfs:comment 'Current lifecycle status of the benefit component. Active benefits are available for adjudication; inactive benefits are historical or discontinued.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSharingTier rdf:type rdf:Property ;
    rdfs:label 'Cost Sharing Tier' ;
    rdfs:comment 'Actuarial value tier of the benefit indicating the percentage of costs the plan covers on average. Used for ACA marketplace plans.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Coverage Percentage' ;
    rdfs:comment 'Percentage of allowed amount the plan pays for this benefit. Expressed as percentage (e.g., 80.00 for 80% plan payment). Inverse of coinsurance_percentage.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dayLimitCount rdf:type rdf:Property ;
    rdfs:label 'Day Limit Count' ;
    rdfs:comment 'Maximum number of days covered per benefit period for services measured in days (e.g., 90 days skilled nursing facility per benefit period). Null if no day limit applies.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayLimitPeriod rdf:type rdf:Property ;
    rdfs:label 'Day Limit Period' ;
    rdfs:comment 'Time period over which the day limit count applies. Example: per_admission for inpatient stays, per_year for annual day limits.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAppliesFlag rdf:type rdf:Property ;
    rdfs:label 'Deductible Applies Flag' ;
    rdfs:comment 'Indicates whether the plan deductible must be met before this benefit pays. True if deductible applies, False if benefit is not subject to deductible (e.g., preventive services).' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diagnosisCodeType rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Code Type' ;
    rdfs:comment 'Type of diagnosis coding system used for medical necessity determination and benefit eligibility. ICD-10-CM is current standard in US; ICD-9-CM is legacy.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dollarLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Dollar Limit Amount' ;
    rdfs:comment 'Maximum dollar amount the plan will pay for this benefit per limit period. Null if no dollar limit applies. Note: ACA prohibits lifetime and annual dollar limits on essential health benefits.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dollarLimitPeriod rdf:type rdf:Property ;
    rdfs:label 'Dollar Limit Period' ;
    rdfs:comment 'Time period over which the dollar limit amount applies. Used for non-essential benefits where dollar limits are permitted.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:essentialHealthBenefitFlag rdf:type rdf:Property ;
    rdfs:label 'Essential Health Benefit Flag' ;
    rdfs:comment 'Indicates whether this benefit is classified as an Essential Health Benefit under ACA. EHBs cannot have annual or lifetime dollar limits.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusionsText rdf:type rdf:Property ;
    rdfs:label 'Exclusions Text' ;
    rdfs:comment 'Narrative description of services or conditions explicitly excluded from this benefit. Critical for claims denial and member communication.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyTier rdf:type rdf:Property ;
    rdfs:label 'Formulary Tier' ;
    rdfs:comment 'Pharmacy formulary tier for drug benefits indicating cost-sharing level. Tier 1 typically generic, Tier 2 preferred brand, Tier 3 non-preferred brand, Tier 4 specialty drugs.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Hsa Eligible Flag' ;
    rdfs:comment 'Indicates whether this benefit is compatible with Health Savings Account (HSA) requirements. True if benefit meets HSA-qualified high-deductible health plan (HDHP) rules.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limitationsText rdf:type rdf:Property ;
    rdfs:label 'Limitations Text' ;
    rdfs:comment 'Narrative description of limitations, restrictions, or conditions that apply to this benefit beyond the structured limit fields.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailOrderAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Mail Order Available Flag' ;
    rdfs:comment 'Indicates whether this pharmacy benefit can be fulfilled through mail order pharmacy with potentially different cost-sharing. True if mail order option available.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkType rdf:type rdf:Property ;
    rdfs:label 'Network Type' ;
    rdfs:comment 'Indicates whether this benefit applies to in-network providers, out-of-network providers, or both. Critical for cost-sharing calculation and provider network adjudication.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfPocketAppliesFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Applies Flag' ;
    rdfs:comment 'Indicates whether member cost-sharing for this benefit counts toward the annual out-of-pocket maximum. True if it counts, False if excluded (e.g., non-covered services).' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveCareFlag rdf:type rdf:Property ;
    rdfs:label 'Preventive Care Flag' ;
    rdfs:comment 'Indicates whether this benefit is classified as preventive care under ACA requirements. Preventive services must be covered at 100% with no cost-sharing when delivered in-network.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:procedureCodeType rdf:type rdf:Property ;
    rdfs:label 'Procedure Code Type' ;
    rdfs:comment 'Type of procedure coding system used to identify services covered by this benefit. CPT for physician services, HCPCS for supplies and equipment, ICD-10-PCS for inpatient procedures, CDT for dental.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityLimitFlag rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Flag' ;
    rdfs:comment 'Indicates whether this benefit has quantity or frequency limits (e.g., maximum number of visits, days supply, units per fill). True if limits apply.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Referral Required Flag' ;
    rdfs:comment 'Indicates whether a referral from Primary Care Physician (PCP) is required to access this benefit. Common in Health Maintenance Organization (HMO) plans.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepTherapyRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Required Flag' ;
    rdfs:comment 'Indicates whether step therapy protocol must be followed (trying lower-cost alternatives before higher-cost treatments). Primarily used for pharmacy benefits.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vibeMutationMarker rdf:type rdf:Property ;
    rdfs:label 'Vibe Mutation Marker' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitLimitCount rdf:type rdf:Property ;
    rdfs:label 'Visit Limit Count' ;
    rdfs:comment 'Maximum number of visits or services allowed per benefit period (e.g., 20 physical therapy visits per year). Null if no visit limit applies.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitLimitPeriod rdf:type rdf:Property ;
    rdfs:label 'Visit Limit Period' ;
    rdfs:comment 'Time period over which the visit limit count applies. Example: per_year for annual limits, per_lifetime for lifetime maximums.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentNetworkProviderNetworkId rdf:type rdf:Property ;
    rdfs:label 'Parent Network Provider Network Id' ;
    rdfs:comment 'Identifier of the parent or umbrella network if this network is a subset or regional variant. Used for hierarchical network structures where a national network has regional sub-networks. Null for top-level networks.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProviderNetwork .

ind:parentProviderNetworkId rdf:type rdf:Property ;
    rdfs:label 'Parent Provider Network Id' ;
    rdfs:comment 'Self-referencing FK on provider_network (parent_provider_network_id)' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProviderNetwork .

ind:acceptingNewPatientsFlag rdf:type rdf:Property ;
    rdfs:label 'Accepting New Patients Flag' ;
    rdfs:comment 'Indicates whether the network as a whole has capacity to accept new members. True if sufficient providers are accepting new patients. False if network is at capacity. Used for enrollment management.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adequacyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Adequacy Review Date' ;
    rdfs:comment 'Date of the most recent network adequacy assessment by CMS or state regulators. Networks must be reviewed annually or when material changes occur.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:behavioralHealthIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Behavioral Health Included Flag' ;
    rdfs:comment 'Indicates whether this network includes behavioral health and mental health providers. True if behavioral health services are covered. False if behavioral health is carved out to a separate network.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmsApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Cms Approval Date' ;
    rdfs:comment 'Date when CMS approved the network adequacy filing. Null if not yet approved or not required.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cmsFilingDate rdf:type rdf:Property ;
    rdfs:label 'Cms Filing Date' ;
    rdfs:comment 'Date when the network adequacy filing was submitted to CMS. Required for Medicare Advantage and Marketplace plans.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cmsFilingStatus rdf:type rdf:Property ;
    rdfs:label 'Cms Filing Status' ;
    rdfs:comment 'Status of the network adequacy filing with CMS for Medicare Advantage or Marketplace plans. Filed indicates submission. Approved indicates CMS acceptance. Rejected indicates CMS denial. Pending indicates under CMS review. Not required for non-CMS regulated plans.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Payment model used for provider contracts in this network. Fee-for-service pays per service. Capitation pays per member per month. Shared savings shares cost savings with providers. Bundled payment pays fixed amount for episode of care. Value-based ties payment to quality and outcomes. Hybrid combines multiple models.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialingStandard rdf:type rdf:Property ;
    rdfs:label 'Credentialing Standard' ;
    rdfs:comment 'Accreditation or regulatory standard used for provider credentialing in this network. NCQA (National Committee for Quality Assurance) is most common. URAC is utilization review accreditation. AAAHC (Accreditation Association for Ambulatory Health Care) for ambulatory settings. TJC (The Joint Commission) for hospitals. State-specific for state-mandated standards. Internal for payer-defined standards.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dentalNetworkIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Dental Network Included Flag' ;
    rdfs:comment 'Indicates whether this network includes dental providers or if dental benefits are managed separately. True if dental is included. False if dental is carved out.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:directoryLastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Directory Last Updated Date' ;
    rdfs:comment 'Date when the provider directory was last updated with current network participation information. CMS requires directories to be updated at least monthly.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilityCount rdf:type rdf:Property ;
    rdfs:label 'Facility Count' ;
    rdfs:comment 'Total number of facilities (hospitals, clinics, surgery centers, imaging centers) participating in this network. Used for network adequacy assessment and member communications.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkAdequacyStatus rdf:type rdf:Property ;
    rdfs:label 'Network Adequacy Status' ;
    rdfs:comment 'Assessment of whether the provider network meets regulatory standards for provider availability, geographic access, and appointment wait times. Adequate networks meet all standards. Inadequate networks require corrective action. Conditionally adequate networks meet standards with exceptions.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCode rdf:type rdf:Property ;
    rdfs:label 'Network Code' ;
    rdfs:comment 'Business identifier for the provider network, used externally by payers, providers, and members. May be referenced on insurance cards and claim submissions.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkDescription rdf:type rdf:Property ;
    rdfs:label 'Network Description' ;
    rdfs:comment 'Detailed description of the provider network, including key features, geographic coverage, specialty availability, and member benefits. Used in plan marketing materials and member communications.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkDirectoryUrl rdf:type rdf:Property ;
    rdfs:label 'Network Directory Url' ;
    rdfs:comment 'Web address of the online provider directory for this network. Members use this to search for in-network providers. Required by CMS for Medicare Advantage and Marketplace plans.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkModel rdf:type rdf:Property ;
    rdfs:label 'Network Model' ;
    rdfs:comment 'Organizational structure of the provider network. Staff model employs providers directly. Group model contracts with multi-specialty groups. Network model contracts with multiple IPAs. IPA (Independent Practice Association) is a physician-owned network. Direct contract is payer-to-provider agreements. Rental network leases access to another payers network.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkName rdf:type rdf:Property ;
    rdfs:label 'Network Name' ;
    rdfs:comment 'Human-readable name of the provider network, used in member communications, plan documents, and provider directories.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcpCount rdf:type rdf:Property ;
    rdfs:label 'Pcp Count' ;
    rdfs:comment 'Total number of primary care physicians in this network. Critical metric for HMO and POS networks that require PCP selection. Used for network adequacy assessment.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pharmacyNetworkIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Network Included Flag' ;
    rdfs:comment 'Indicates whether this network includes pharmacy providers or if pharmacy benefits are managed separately. True if pharmacy is included. False if pharmacy is carved out.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerCount rdf:type rdf:Property ;
    rdfs:label 'Provider Count' ;
    rdfs:comment 'Total number of individual providers (physicians, specialists, allied health professionals) participating in this network. Used for network adequacy assessment and member communications.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityTierMethodology rdf:type rdf:Property ;
    rdfs:label 'Quality Tier Methodology' ;
    rdfs:comment 'Description of the methodology used to assign providers to quality or performance tiers within this network. May reference HEDIS measures, patient satisfaction scores, cost efficiency, or clinical outcomes. Used in tiered network designs.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recredentialingCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Recredentialing Cycle Months' ;
    rdfs:comment 'Number of months between provider recredentialing reviews. Typically 24 or 36 months per NCQA standards. Used to schedule provider credential verification and quality reviews.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskArrangement rdf:type rdf:Property ;
    rdfs:label 'Risk Arrangement' ;
    rdfs:comment 'Financial risk-sharing arrangement between payer and network providers. Full risk transfers all financial risk to providers. Shared risk splits risk between payer and providers. Upside only allows providers to share savings but not losses. Downside risk requires providers to cover losses. No risk is traditional fee-for-service.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaType rdf:type rdf:Property ;
    rdfs:label 'Service Area Type' ;
    rdfs:comment 'Classification of the geographic service area scope. Statewide covers entire state. Regional covers multiple counties or regions. County covers specific counties. ZIP code covers specific ZIP codes. MSA (Metropolitan Statistical Area) covers census-defined metro areas. National covers multiple states or entire country.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialistCount rdf:type rdf:Property ;
    rdfs:label 'Specialist Count' ;
    rdfs:comment 'Total number of specialist physicians in this network. Used for network adequacy assessment and member communications.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visionNetworkIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Vision Network Included Flag' ;
    rdfs:comment 'Indicates whether this network includes vision providers or if vision benefits are managed separately. True if vision is included. False if vision is carved out.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primarySupersededByCoveragePolicyId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Coverage Policy Id' ;
    rdfs:comment 'Reference to the coverage policy that replaces this policy when it is retired or superseded. Nullable if the policy is still active or has not been replaced.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoveragePolicy .

ind:ageRestrictions rdf:type rdf:Property ;
    rdfs:label 'Age Restrictions' ;
    rdfs:comment 'Age-based limitations or requirements for coverage under this policy (e.g., \'covered for patients 18 years and older\', \'pediatric use only\').' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealsAllowed rdf:type rdf:Property ;
    rdfs:label 'Appeals Allowed' ;
    rdfs:comment 'Indicates whether coverage denials based on this policy can be appealed by the provider or patient. True = appeals allowed; False = no appeals allowed.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealsProcessDescription rdf:type rdf:Property ;
    rdfs:label 'Appeals Process Description' ;
    rdfs:comment 'Detailed description of the appeals process for coverage denials based on this policy, including timelines, required documentation, and contact information.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalEvidenceSource rdf:type rdf:Property ;
    rdfs:label 'Clinical Evidence Source' ;
    rdfs:comment 'Reference to the clinical evidence, guidelines, or literature that supports the coverage determination (e.g., \'NCCN Guidelines\', \'FDA approval\', \'peer-reviewed clinical trial\').' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageDetermination rdf:type rdf:Property ;
    rdfs:label 'Coverage Determination' ;
    rdfs:comment 'Final determination of whether the service, procedure, or technology is covered under this policy. Covered = reimbursable; Non-Covered = not reimbursable; Conditional = covered only if specific criteria met; Investigational/Experimental = not covered due to lack of evidence; Not Medically Necessary = does not meet medical necessity criteria.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'Specific services, procedures, diagnoses, or circumstances that are explicitly excluded from coverage under this policy.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyLimitations rdf:type rdf:Property ;
    rdfs:label 'Frequency Limitations' ;
    rdfs:comment 'Limitations on how often the service or procedure can be performed and reimbursed within a specified time period (e.g., \'once per calendar year\', \'maximum 12 visits per year\').' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderRestrictions rdf:type rdf:Property ;
    rdfs:label 'Gender Restrictions' ;
    rdfs:comment 'Gender-based limitations or requirements for coverage under this policy (e.g., \'female patients only\', \'male patients only\', \'no gender restrictions\').' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalNecessityCriteria rdf:type rdf:Property ;
    rdfs:label 'Medical Necessity Criteria' ;
    rdfs:comment 'Clinical criteria defining when the service or procedure is considered medically necessary and therefore eligible for coverage under this policy.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkRestrictions rdf:type rdf:Property ;
    rdfs:label 'Network Restrictions' ;
    rdfs:comment 'Indicates whether the service or procedure must be performed by an in-network provider to be covered. In-Network Only = only in-network providers eligible; Out-of-Network Allowed = both in-network and out-of-network providers eligible (may have different reimbursement); No Restriction = network status does not affect coverage.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfServiceRestrictions rdf:type rdf:Property ;
    rdfs:label 'Place Of Service Restrictions' ;
    rdfs:comment 'Restrictions on where the service or procedure can be performed to be eligible for coverage (e.g., \'inpatient hospital only\', \'outpatient facility or office\', \'home health setting\').' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Policy Approval Date' ;
    rdfs:comment 'Date on which the coverage policy was formally approved by the payer\'s medical policy committee or equivalent governance body.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Policy Approved By' ;
    rdfs:comment 'Name or identifier of the individual or committee that approved the coverage policy.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyCategory rdf:type rdf:Property ;
    rdfs:label 'Policy Category' ;
    rdfs:comment 'High-level categorization of the coverage policy by clinical domain or service type (e.g., \'Radiology\', \'Pharmacy\', \'Surgical Procedures\', \'Durable Medical Equipment\').' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed narrative description of the coverage policy, including the clinical rationale, scope of coverage, and any special conditions or limitations.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'Externally-known unique identifier for the coverage policy, used in prior authorization and claims adjudication workflows.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyOwner rdf:type rdf:Property ;
    rdfs:label 'Policy Owner' ;
    rdfs:comment 'Name or identifier of the individual or department responsible for maintaining and updating this coverage policy.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the coverage policy. Active = in effect and enforceable; Inactive = temporarily suspended; Draft = not yet finalized; Under Review = being evaluated or updated; Retired = no longer in use; Superseded = replaced by a newer policy version.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyTitle rdf:type rdf:Property ;
    rdfs:label 'Policy Title' ;
    rdfs:comment 'Human-readable title or name of the coverage policy, describing the service or condition covered.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the coverage policy. Medical Policy = internal payer medical necessity policy; Coverage Determination = specific coverage decision; LCD = Local Coverage Determination (Medicare contractor-specific); NCD = National Coverage Determination (CMS national policy); Administrative Policy = non-clinical coverage rule; Clinical Guideline = evidence-based clinical criteria.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyVersion rdf:type rdf:Property ;
    rdfs:label 'Policy Version' ;
    rdfs:comment 'Version number of the coverage policy, used to track revisions and updates over time (e.g., \'1.0\', \'2.3\').' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthorizationCriteria rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Criteria' ;
    rdfs:comment 'Detailed clinical and administrative criteria that must be met to obtain prior authorization for the service or procedure covered by this policy.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerSpecialtyRestrictions rdf:type rdf:Property ;
    rdfs:label 'Provider Specialty Restrictions' ;
    rdfs:comment 'Restrictions on which provider specialties are authorized to perform the service or procedure under this policy (e.g., \'board-certified cardiologist only\', \'licensed physical therapist\').' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityLimitations rdf:type rdf:Property ;
    rdfs:label 'Quantity Limitations' ;
    rdfs:comment 'Limitations on the quantity or dosage of the service, supply, or medication that can be provided and reimbursed under this policy (e.g., \'maximum 30-day supply\', \'up to 10 units per month\').' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'Reference to the regulatory or statutory basis for the coverage policy (e.g., \'CMS NCD 210.1\', \'State Medicaid Manual Section 4.5\', \'ACA Essential Health Benefits\').' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Scheduled date for the next policy review or update cycle, ensuring the policy remains aligned with current clinical evidence and regulatory requirements.' ;
    rdfs:domain ind:CoveragePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stepTherapyCriteria rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Criteria' ;
    rdfs:comment 'Detailed criteria defining the step therapy requirements, including which treatments must be tried first and the conditions under which step therapy can be bypassed.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nppAcknowledgmentId rdf:type rdf:Property ;
    rdfs:label 'Npp Acknowledgment Id' ;
    rdfs:comment 'Foreign key linking to consent.npp_acknowledgment. Business justification: HIPAA requires NPP acknowledgment at first service or enrollment. Linking member_enrollment to npp_acknowledgment enables compliance reporting confirming each enrolled member acknowledged the NPP. CMS' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NppAcknowledgment .

ind:pcpClinicianId rdf:type rdf:Property ;
    rdfs:label 'Pcp Clinician Id' ;
    rdfs:comment 'Foreign key linking to provider.clinician. Business justification: PCP assignment is a core enrollment operation: member_enrollment tracks pcp_assignment_date but stores only a denormalized NPI. A proper FK to clinician supports PCP panel management, HEDIS attributio' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clinician .

ind:primaryMemberSubscriberId rdf:type rdf:Property ;
    rdfs:label 'Primary Member Subscriber Id' ;
    rdfs:comment 'External subscriber identifier assigned by the payer or health plan. Used for eligibility verification and claim adjudication.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:priorMemberEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Prior Member Enrollment Id' ;
    rdfs:comment 'Self-referencing FK on member_enrollment (prior_member_enrollment_id)' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberEnrollment .

ind:benefitPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Benefit Period End Date' ;
    rdfs:comment 'End date of the benefit period for deductible and out-of-pocket maximum tracking. Resets accumulators for next period.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefitPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Benefit Period Start Date' ;
    rdfs:comment 'Start date of the benefit period for deductible and out-of-pocket maximum tracking. Typically calendar year or plan year.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobraIndicator rdf:type rdf:Property ;
    rdfs:label 'Cobra Indicator' ;
    rdfs:comment 'Indicates whether this enrollment is a COBRA continuation coverage following employment termination.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobraQualifyingEventDate rdf:type rdf:Property ;
    rdfs:label 'Cobra Qualifying Event Date' ;
    rdfs:comment 'Date of the qualifying event that triggered COBRA eligibility (e.g., employment termination, divorce). Nullable for non-COBRA enrollments.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'Coverage tier indicating the scope of family members covered under this enrollment. Affects premium calculation.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verification Date' ;
    rdfs:comment 'Date when member eligibility was last verified with the payer. Used for real-time eligibility checks.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Created Timestamp' ;
    rdfs:comment 'Timestamp when this enrollment record was first created in the system. Used for audit and data lineage tracking.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:enrollmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Effective Date' ;
    rdfs:comment 'Date when the member coverage becomes effective and benefits are available. Used for eligibility determination.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentNotes rdf:type rdf:Property ;
    rdfs:label 'Enrollment Notes' ;
    rdfs:comment 'Free-text notes or comments related to this enrollment. Used for documenting special circumstances or exceptions.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSource rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source' ;
    rdfs:comment 'Source system or channel through which the enrollment was initiated. [ENUM-REF-CANDIDATE: employer_group|aca_exchange|medicare_cms|medicaid_agency|direct_enrollment|broker|navigator|other — promote to reference product]' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source System' ;
    rdfs:comment 'Name of the source system that originated this enrollment record. Used for data lineage and reconciliation.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Termination Date' ;
    rdfs:comment 'Date when the member coverage ends and benefits are no longer available. Nullable for active enrollments.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Type' ;
    rdfs:comment 'Type of enrollment event that initiated this coverage. Determines eligibility rules and enrollment period constraints.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Updated Timestamp' ;
    rdfs:comment 'Timestamp when this enrollment record was last modified. Used for audit and change tracking.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastPremiumPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Premium Payment Date' ;
    rdfs:comment 'Date of the most recent premium payment received for this enrollment. Used for grace period and termination calculations.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicarePartAEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Medicare Part A Effective Date' ;
    rdfs:comment 'Effective date of Medicare Part A coverage for dual-eligible members. Used for coordination of benefits.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicarePartBEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Medicare Part B Effective Date' ;
    rdfs:comment 'Effective date of Medicare Part B coverage for dual-eligible members. Used for coordination of benefits.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pcpAssignmentDate rdf:type rdf:Property ;
    rdfs:label 'Pcp Assignment Date' ;
    rdfs:comment 'Date when the primary care physician was assigned to this member. Used for continuity of care tracking.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:premiumAmount rdf:type rdf:Property ;
    rdfs:label 'Premium Amount' ;
    rdfs:comment 'Monthly premium amount for this member enrollment. May be employer-paid, member-paid, or split.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumPaymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Premium Payment Frequency' ;
    rdfs:comment 'Frequency at which premium payments are due for this enrollment.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Premium Payment Status' ;
    rdfs:comment 'Current status of premium payments for this enrollment. Affects coverage eligibility and claim payment.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipToSubscriber rdf:type rdf:Property ;
    rdfs:label 'Relationship To Subscriber' ;
    rdfs:comment 'Relationship of the member to the primary subscriber. Determines dependent status and coverage eligibility rules.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subsidyAmount rdf:type rdf:Property ;
    rdfs:label 'Subsidy Amount' ;
    rdfs:comment 'Monthly premium subsidy or tax credit amount applied to this enrollment. Applicable for ACA marketplace plans.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subsidyType rdf:type rdf:Property ;
    rdfs:label 'Subsidy Type' ;
    rdfs:comment 'Type of premium subsidy or cost-sharing reduction applied to this enrollment. APTC = Advanced Premium Tax Credit, CSR = Cost-Sharing Reduction.' ;
    rdfs:domain ind:MemberEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorSubscriberId rdf:type rdf:Property ;
    rdfs:label 'Prior Subscriber Id' ;
    rdfs:comment 'Self-referencing FK on subscriber (prior_subscriber_id)' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line for the subscriber\'s residence.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line (apartment, suite, unit number) for the subscriber\'s residence.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligible Flag' ;
    rdfs:comment 'Indicates whether the subscriber is eligible for COBRA continuation coverage after employment termination. True=eligible, False=not eligible.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobraEndDate rdf:type rdf:Property ;
    rdfs:label 'Cobra End Date' ;
    rdfs:comment 'Date when COBRA continuation coverage ends, if applicable. Null if not on COBRA or coverage is ongoing.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobraStartDate rdf:type rdf:Property ;
    rdfs:label 'Cobra Start Date' ;
    rdfs:comment 'Date when COBRA continuation coverage began, if applicable. Null if not on COBRA.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dualEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dual Eligible Flag' ;
    rdfs:comment 'Indicates whether the subscriber is dually eligible for both Medicare and Medicaid. True=dual eligible, False=not dual eligible. Critical for coordination of benefits and cost-sharing determination.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicaidEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Medicaid Eligible Flag' ;
    rdfs:comment 'Indicates whether the subscriber is eligible for Medicaid coverage. True=eligible, False=not eligible. Used for coordination of benefits and dual eligibility determination.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicareEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Medicare Eligible Flag' ;
    rdfs:comment 'Indicates whether the subscriber is eligible for Medicare coverage. True=eligible, False=not eligible. Used for coordination of benefits.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicareNumber rdf:type rdf:Property ;
    rdfs:label 'Medicare Number' ;
    rdfs:comment 'Medicare Beneficiary Identifier (MBI) assigned by CMS, if the subscriber is Medicare-eligible. Used for coordination of benefits between Medicare and commercial insurance.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumFrequency rdf:type rdf:Property ;
    rdfs:label 'Premium Frequency' ;
    rdfs:comment 'Frequency at which the subscriber pays premiums.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipToInsured rdf:type rdf:Property ;
    rdfs:label 'Relationship To Insured' ;
    rdfs:comment 'Relationship of the subscriber to the primary insured. For subscriber records, this is typically \'self\' since the subscriber IS the insured party. Used when subscriber may be a dependent on another policy.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssn rdf:type rdf:Property ;
    rdfs:label 'Ssn' ;
    rdfs:comment 'Social Security Number of the subscriber. Stored in masked or encrypted format per HIPAA security requirements. Used for identity verification and coordination of benefits.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suffix rdf:type rdf:Property ;
    rdfs:label 'Suffix' ;
    rdfs:comment 'Name suffix of the subscriber (Jr, Sr, II, III, etc.), if applicable.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependentMemberMpiRecordId rdf:type rdf:Property ;
    rdfs:label 'Dependent Member Mpi Record Id' ;
    rdfs:comment 'Unique member identifier assigned by the health plan to this dependent for eligibility verification and claims processing.' ;
    rdfs:domain ind:Dependent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MpiRecord .

ind:dependentMpiRecordId rdf:type rdf:Property ;
    rdfs:label 'Dependent Mpi Record Id' ;
    rdfs:comment 'Foreign key linking to patient.mpi_record. Business justification: Dependents are patients with MPI records. Business process: dependent enrollment creates patient identity; clinical care delivery, scheduling, and medical records require linking insurance dependent t' ;
    rdfs:domain ind:Dependent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MpiRecord .

ind:primaryDependentId rdf:type rdf:Property ;
    rdfs:label 'Primary Dependent Id' ;
    rdfs:comment 'Self-referencing FK on dependent (primary_dependent_id)' ;
    rdfs:domain ind:Dependent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dependent .

ind:disabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Disability Status' ;
    rdfs:comment 'Indicates whether the dependent has a qualifying disability that extends eligibility beyond standard age or relationship limits.' ;
    rdfs:domain ind:Dependent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disabilityVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Disability Verification Date' ;
    rdfs:comment 'Date when the dependents disability status was last verified for extended eligibility purposes.' ;
    rdfs:domain ind:Dependent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastEligibilityVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Eligibility Verification Date' ;
    rdfs:comment 'Date when the dependents eligibility was last verified by the health plan.' ;
    rdfs:domain ind:Dependent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studentStatus rdf:type rdf:Property ;
    rdfs:label 'Student Status' ;
    rdfs:comment 'Indicates whether the dependent is a full-time or part-time student, which may extend eligibility beyond standard age limits (e.g., up to age 26).' ;
    rdfs:domain ind:Dependent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studentVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Student Verification Date' ;
    rdfs:comment 'Date when the dependents student status was last verified for eligibility extension purposes.' ;
    rdfs:domain ind:Dependent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tobaccoUseIndicator rdf:type rdf:Property ;
    rdfs:label 'Tobacco Use Indicator' ;
    rdfs:comment 'Indicates whether the dependent uses tobacco products, which may affect premium calculations.' ;
    rdfs:domain ind:Dependent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewedPayerContractId rdf:type rdf:Property ;
    rdfs:label 'Renewed Payer Contract Id' ;
    rdfs:comment 'Self-referencing FK on payer_contract (renewed_payer_contract_id)' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayerContract .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Number of amendments or modifications made to this contract since its original execution.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseReimbursementPercentage rdf:type rdf:Property ;
    rdfs:label 'Base Reimbursement Percentage' ;
    rdfs:comment 'The baseline percentage rate applied to charges or fee schedules for reimbursement calculation (e.g., 110% of Medicare rates). Null if reimbursement method is not percentage-based.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carveOutServices rdf:type rdf:Property ;
    rdfs:label 'Carve Out Services' ;
    rdfs:comment 'Description or list of services explicitly excluded from this contract and reimbursed under separate arrangements (e.g., behavioral health, pharmacy, transplant services).' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsSubmissionMethod rdf:type rdf:Property ;
    rdfs:label 'Claims Submission Method' ;
    rdfs:comment 'The method by which claims under this contract must be submitted to the payer for adjudication.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractAdministratorEmail rdf:type rdf:Property ;
    rdfs:label 'Contract Administrator Email' ;
    rdfs:comment 'Email address of the internal contract administrator for operational communication regarding this contract.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractAdministratorName rdf:type rdf:Property ;
    rdfs:label 'Contract Administrator Name' ;
    rdfs:comment 'Name of the internal staff member or department responsible for managing and administering this payer contract.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentLocation rdf:type rdf:Property ;
    rdfs:label 'Contract Document Location' ;
    rdfs:comment 'File path, URL, or document management system reference to the signed contract document for audit and reference purposes.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractName rdf:type rdf:Property ;
    rdfs:label 'Contract Name' ;
    rdfs:comment 'Human-readable name or title of the payer contract for identification and reporting purposes.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the payer contract. Draft indicates contract under negotiation; pending approval awaiting internal or payer sign-off; active means contract is in force; suspended indicates temporary hold; terminated means contract ended before expiration; expired means contract reached its end date.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialingRequired rdf:type rdf:Property ;
    rdfs:label 'Credentialing Required' ;
    rdfs:comment 'Indicates whether individual providers must be credentialed and enrolled with the payer to bill under this contract.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Reference' ;
    rdfs:comment 'Reference identifier to the base fee schedule or rate table that governs reimbursement rates for services under this contract (e.g., Medicare Fee Schedule, custom negotiated rates).' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Description of the geographic region or service area covered by this contract (e.g., statewide, multi-state, specific counties).' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or modification to this contract.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityBonusEligible rdf:type rdf:Property ;
    rdfs:label 'Quality Bonus Eligible' ;
    rdfs:comment 'Indicates whether this contract includes provisions for quality-based bonus payments tied to performance metrics such as Healthcare Effectiveness Data and Information Set (HEDIS) scores or Merit-based Incentive Payment System (MIPS) performance.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityMeasureSet rdf:type rdf:Property ;
    rdfs:label 'Quality Measure Set' ;
    rdfs:comment 'Identifier or name of the quality measure set or program used to evaluate performance under this contract (e.g., HEDIS, MIPS, hospital-acquired infection rates).' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityPenaltyEligible rdf:type rdf:Property ;
    rdfs:label 'Quality Penalty Eligible' ;
    rdfs:comment 'Indicates whether this contract includes provisions for quality-based penalties or payment reductions for failure to meet performance thresholds.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationFrequency rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Frequency' ;
    rdfs:comment 'The frequency at which financial reconciliation and settlement occurs between provider and payer for shared savings, risk adjustments, or quality bonuses.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Reference' ;
    rdfs:comment 'Reference number or identifier assigned by the regulatory body for this contracts filing or approval.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required' ;
    rdfs:comment 'Indicates whether this contract must be filed with state insurance departments or other regulatory bodies for approval or compliance purposes.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days advance notice required to terminate or renegotiate the contract before auto-renewal occurs.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskArrangementType rdf:type rdf:Property ;
    rdfs:label 'Risk Arrangement Type' ;
    rdfs:comment 'Defines the financial risk-sharing model between provider and payer. No risk means traditional fee-for-service; upside only allows provider to share in savings; downside only exposes provider to penalties; two-sided risk includes both savings and penalties; full risk transfers all financial risk to provider.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopLossThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Stop Loss Threshold Amount' ;
    rdfs:comment 'The dollar amount threshold above which stop-loss or reinsurance provisions apply, protecting the provider or payer from catastrophic claims costs. Null if no stop-loss provision exists.' ;
    rdfs:domain ind:PayerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryPredecessorScheduleFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Primary Predecessor Schedule Fee Schedule Id' ;
    rdfs:comment 'Reference to the previous version of this fee schedule, enabling version history tracking and audit trails.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeeSchedule .

ind:annualInflationRate rdf:type rdf:Property ;
    rdfs:label 'Annual Inflation Rate' ;
    rdfs:comment 'The annual percentage rate applied for inflation adjustments, if applicable. Expressed as a decimal (e.g., 3.50 for 3.5%).' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billedChargesPercentage rdf:type rdf:Property ;
    rdfs:label 'Billed Charges Percentage' ;
    rdfs:comment 'The percentage of billed charges used as the basis for reimbursement when rate_basis is percent_of_billed_charges. Expressed as a decimal (e.g., 80.00 for 80% of billed charges).' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the fee schedule: draft (under development), active (in use), suspended (temporarily inactive), terminated (ended by agreement), expired (past termination date), or pending approval (awaiting authorization).' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Reference Number' ;
    rdfs:comment 'The reference number assigned by the regulatory authority when this fee schedule was filed for approval.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Geographic Adjustment Factor' ;
    rdfs:comment 'Geographic adjustment factor applied to base rates to account for regional cost variations. Based on CMS Geographic Practice Cost Index (GPCI) methodology.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic applicability of the fee schedule: national, regional, state-level, county-level, zip code-level, or facility-specific.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inflationAdjustmentMethod rdf:type rdf:Property ;
    rdfs:label 'Inflation Adjustment Method' ;
    rdfs:comment 'The method used for annual inflation adjustments to fee schedule rates: Consumer Price Index (CPI), Medical CPI, fixed percentage, none, or custom methodology.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Interest Penalty Rate' ;
    rdfs:comment 'The annual interest rate applied to late payments as a penalty for exceeding payment terms. Expressed as a decimal (e.g., 10.00 for 10%).' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localityCode rdf:type rdf:Property ;
    rdfs:label 'Locality Code' ;
    rdfs:comment 'CMS locality code used for Medicare geographic adjustment purposes, defining the specific payment locality.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicarePercentage rdf:type rdf:Property ;
    rdfs:label 'Medicare Percentage' ;
    rdfs:comment 'The percentage of Medicare allowable rates used as the basis for reimbursement when rate_basis is percent_of_medicare. Expressed as a decimal (e.g., 110.00 for 110% of Medicare).' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outlierPaymentThreshold rdf:type rdf:Property ;
    rdfs:label 'Outlier Payment Threshold' ;
    rdfs:comment 'The cost threshold above which outlier payments are triggered for exceptionally high-cost cases, typically in DRG-based reimbursement.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityAdjustmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Quality Adjustment Percentage' ;
    rdfs:comment 'The maximum percentage adjustment (positive or negative) that can be applied to base rates based on quality performance metrics.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityIncentiveEligible rdf:type rdf:Property ;
    rdfs:label 'Quality Incentive Eligible' ;
    rdfs:comment 'Indicates whether this fee schedule is eligible for quality-based incentive payments under value-based purchasing or pay-for-performance programs.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateBasis rdf:type rdf:Property ;
    rdfs:label 'Rate Basis' ;
    rdfs:comment 'The methodology used to determine reimbursement rates: percentage of Medicare rates, percentage of billed charges, case rate, per diem, fee-for-service, or capitation.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the fee schedule for system identification and cross-referencing.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Business-friendly name or title of the fee schedule, used for identification and reporting purposes.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the fee schedule by service category: professional services, facility services, durable medical equipment (DME), laboratory, pharmacy, or radiology.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopLossThreshold rdf:type rdf:Property ;
    rdfs:label 'Stop Loss Threshold' ;
    rdfs:comment 'The dollar amount threshold above which stop-loss provisions apply, limiting payer liability for high-cost cases.' ;
    rdfs:domain ind:Insurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primarySupersededByFeeScheduleLineId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Fee Schedule Line Id' ;
    rdfs:comment 'Reference to the fee_schedule_line_id that replaces this line when status is superseded. Enables tracking of rate history and lineage.' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeeScheduleLine .

ind:assistantSurgeonAllowed rdf:type rdf:Property ;
    rdfs:label 'Assistant Surgeon Allowed' ;
    rdfs:comment 'Indicates whether an assistant surgeon is allowed for this procedure and will be separately reimbursed according to the fee schedule.' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bilateralIndicator rdf:type rdf:Property ;
    rdfs:label 'Bilateral Indicator' ;
    rdfs:comment 'Indicates whether the procedure can be performed bilaterally (on both sides of the body) and how it affects reimbursement.' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundledIndicator rdf:type rdf:Property ;
    rdfs:label 'Bundled Indicator' ;
    rdfs:comment 'Indicates whether this procedure code is part of a bundled payment arrangement where multiple services are reimbursed as a single package. True means this is bundled.' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseRateAmount rdf:type rdf:Property ;
    rdfs:label 'Case Rate Amount' ;
    rdfs:comment 'When rate_basis is case_rate, this field contains the bundled payment amount for an entire episode of care or procedure (e.g., DRG-based payment, bundled surgical package).' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'External reference number or identifier linking this fee schedule line to the source contract document or agreement section.' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate Amount' ;
    rdfs:comment 'The negotiated reimbursement amount for this specific procedure code and modifier combination. Represents the dollar amount the payer will reimburse for the service.' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeScheduleLineStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Line Status' ;
    rdfs:comment 'Current lifecycle status of the fee schedule line item: active (in use), inactive (not in use), pending (approved but not yet effective), superseded (replaced by newer version), expired (past termination date), or suspended (temporarily disabled).' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicModifier rdf:type rdf:Property ;
    rdfs:label 'Geographic Modifier' ;
    rdfs:comment 'Two-digit code representing the geographic locality for Medicare GPCI adjustments. Used to adjust RVU-based payments for regional cost variations.' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Global Period Days' ;
    rdfs:comment 'Number of days in the global surgical period during which follow-up care is included in the procedure payment and not separately reimbursable. Common values are 0, 10, or 90 days.' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumReimbursement rdf:type rdf:Property ;
    rdfs:label 'Maximum Reimbursement' ;
    rdfs:comment 'The ceiling amount for reimbursement regardless of calculation method. Caps the payment level for the service.' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumReimbursement rdf:type rdf:Property ;
    rdfs:label 'Minimum Reimbursement' ;
    rdfs:comment 'The floor amount for reimbursement regardless of calculation method. Ensures a minimum payment level for the service.' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:multipleProcedureReduction rdf:type rdf:Property ;
    rdfs:label 'Multiple Procedure Reduction' ;
    rdfs:comment 'Percentage reduction applied when multiple procedures are performed in the same session (e.g., 50.00 means second procedure is reimbursed at 50% of the fee schedule rate).' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perDiemRate rdf:type rdf:Property ;
    rdfs:label 'Per Diem Rate' ;
    rdfs:comment 'When rate_basis is per_diem, this field contains the daily rate amount for inpatient or long-term care services.' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentOfCharges rdf:type rdf:Property ;
    rdfs:label 'Percent Of Charges' ;
    rdfs:comment 'When rate_basis is percent_of_charges, this field contains the percentage multiplier applied to the provider\'s billed charges (e.g., 65.00 means 65% of charges).' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentOfMedicare rdf:type rdf:Property ;
    rdfs:label 'Percent Of Medicare' ;
    rdfs:comment 'When rate_basis is percent_of_medicare, this field contains the percentage multiplier applied to the Medicare allowable amount (e.g., 110.00 means 110% of Medicare rates).' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Reporting Required' ;
    rdfs:comment 'Indicates whether quality measure reporting is required for this service as part of value-based payment programs (e.g., MIPS, APM).' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateVersion rdf:type rdf:Property ;
    rdfs:label 'Rate Version' ;
    rdfs:comment 'Version number tracking changes to this specific fee schedule line over time. Increments with each rate update or modification.' ;
    rdfs:domain ind:FeeScheduleLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededPriorAuthRuleId rdf:type rdf:Property ;
    rdfs:label 'Superseded Prior Auth Rule Id' ;
    rdfs:comment 'Self-referencing FK on prior_auth_rule (superseded_prior_auth_rule_id)' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriorAuthRule .

ind:ageMaximum rdf:type rdf:Property ;
    rdfs:label 'Age Maximum' ;
    rdfs:comment 'Maximum patient age in years for which this prior authorization rule applies. Null if no age restriction.' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageMinimum rdf:type rdf:Property ;
    rdfs:label 'Age Minimum' ;
    rdfs:comment 'Minimum patient age in years for which this prior authorization rule applies. Null if no age restriction.' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealProcessDescription rdf:type rdf:Property ;
    rdfs:label 'Appeal Process Description' ;
    rdfs:comment 'Description of the process for appealing a prior authorization denial under this rule, including timelines and contact information.' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoApprovalCriteria rdf:type rdf:Property ;
    rdfs:label 'Auto Approval Criteria' ;
    rdfs:comment 'Description of the criteria that must be met for automated approval of the prior authorization request.' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoApprovalEligible rdf:type rdf:Property ;
    rdfs:label 'Auto Approval Eligible' ;
    rdfs:comment 'Indicates whether this prior authorization rule supports automated approval based on predefined criteria without manual review.' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clinicalCriteriaReference rdf:type rdf:Property ;
    rdfs:label 'Clinical Criteria Reference' ;
    rdfs:comment 'Reference to the clinical guideline, medical policy, or evidence-based criteria document that defines the medical necessity standards for this prior authorization rule.' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFax rdf:type rdf:Property ;
    rdfs:label 'Contact Fax' ;
    rdfs:comment 'Payer fax number for prior authorization document submission related to this rule.' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Payer contact phone number for prior authorization inquiries and submissions related to this rule.' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRequired rdf:type rdf:Property ;
    rdfs:label 'Documentation Required' ;
    rdfs:comment 'List or description of clinical documentation that must be submitted with the prior authorization request (e.g., chart notes, lab results, imaging reports).' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exception Criteria' ;
    rdfs:comment 'Description of circumstances under which exceptions to the prior authorization requirement may be granted (e.g., emergency situations, continuity of care).' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyLimitPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Frequency Limit Period Days' ;
    rdfs:comment 'Time period in days over which the frequency limit is measured. Null if no period applies.' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicalPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Medical Policy Number' ;
    rdfs:comment 'Payer-specific medical policy document number or identifier that governs this prior authorization rule.' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paRequirementType rdf:type rdf:Property ;
    rdfs:label 'Pa Requirement Type' ;
    rdfs:comment 'Classification of the prior authorization requirement level: required (mandatory PA), not required, clinical review (medical necessity review), peer-to-peer (physician discussion), notification only, or retrospective review.' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Auth Rule Status' ;
    rdfs:comment 'Current lifecycle status of the prior authorization rule: active (in effect), inactive (not enforced), pending (scheduled for activation), suspended (temporarily paused), or retired (permanently discontinued).' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityLimitPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Period Days' ;
    rdfs:comment 'Time period in days over which the quantity limit is measured (e.g., 30 days, 90 days). Null if no period applies.' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Unique business identifier code for this prior authorization rule, used for external reference and reporting.' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable descriptive name of the prior authorization rule for display and reporting purposes.' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgentTurnaroundTimeHours rdf:type rdf:Property ;
    rdfs:label 'Urgent Turnaround Time Hours' ;
    rdfs:comment 'Expedited turnaround time in hours for urgent or emergent prior authorization requests under this rule.' ;
    rdfs:domain ind:PriorAuthRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySupersededByFormTemplateId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Form Template Id' ;
    rdfs:comment 'FK to newer version of this form template' ;
    rdfs:domain ind:FormTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormTemplate .

ind:applicableFacilityTypes rdf:type rdf:Property ;
