ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: A charge is the atomic billable unit that gets rolled up onto an invoice during the billing cycle. In RCM, charges are captured first (at time of service) and then invoiced. Adding invoice_id to charg' ;
    rdfs:domain ind:Healthcare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:originalChargeId rdf:type rdf:Property ;
    rdfs:label 'Original Charge Id' ;
