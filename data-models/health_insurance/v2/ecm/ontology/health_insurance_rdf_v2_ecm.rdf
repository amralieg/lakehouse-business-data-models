ind:runCode rdf:type rdf:Property ;
    rdfs:label 'Run Code' ;
    rdfs:comment 'Business identifier code for the run, often used in reporting and audit logs.' ;
    rdfs:domain ind:ScoreRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runDescription rdf:type rdf:Property ;
