    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceNpiRegistrySyncId rdf:type rdf:Property ;
    rdfs:label 'Source Npi Registry Sync Id' ;
    rdfs:comment 'Foreign key to provider.npi_registry_sync.npi_registry_sync_id' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:providerDirectoryVerificationId rdf:type rdf:Property ;
    rdfs:label 'Provider Directory Verification Id' ;
    rdfs:comment 'System-generated unique identifier for each provider directory verification record.' ;
    rdfs:domain ind:ProviderDirectoryVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldsVerified rdf:type rdf:Property ;
    rdfs:label 'Fields Verified' ;
    rdfs:comment 'Pipe-separated list of provider directory fields that were verified in this event (e.g., address|phone|specialty|accepting_patients).' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Next Verification Date' ;
    rdfs:comment 'Scheduled future date for the next required verification of this provider\'s directory information.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationNumber rdf:type rdf:Property ;
    rdfs:label 'Verification Number' ;
    rdfs:comment 'Business-visible sequential number assigned to the verification event for tracking and reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Verification Outcome' ;
    rdfs:comment 'Result of the verification activity indicating whether the record was confirmed, required an update, could not be reached, or the provider was removed from the directory.' ;
    rdfs:domain ind:ProviderDirectoryVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Exact date-time when the verification activity was performed.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:providerOutreachId rdf:type rdf:Property ;
    rdfs:label 'Provider Outreach Id' ;
    rdfs:comment 'Unique identifier for the provider outreach event. Primary key for the provider outreach data product.' ;
    rdfs:domain ind:ProviderOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptingPatientsVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Accepting Patients Verified Flag' ;
    rdfs:comment 'Indicator of whether the provider accepting new patients status was verified during this outreach event.' ;
    rdfs:domain ind:ProviderOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Address Verified Flag' ;
    rdfs:comment 'Indicator of whether the provider practice address was verified during this outreach event.' ;
    rdfs:domain ind:ProviderOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attemptCount rdf:type rdf:Property ;
    rdfs:label 'Attempt Count' ;
    rdfs:comment 'Number of outreach attempts made for this specific outreach event or campaign, tracking persistence in reaching the provider.' ;
    rdfs:domain ind:ProviderOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attestationReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Attestation Received Flag' ;
    rdfs:comment 'Indicator of whether a formal attestation or confirmation document was received from the provider during this outreach event.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceQuarter rdf:type rdf:Property ;
    rdfs:label 'Compliance Quarter' ;
    rdfs:comment 'Fiscal or calendar quarter for which this outreach event supports directory accuracy compliance reporting (e.g., Q1 2024).' ;
