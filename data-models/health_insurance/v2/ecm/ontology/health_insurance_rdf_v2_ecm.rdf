ind:editDescription rdf:type rdf:Property ;
    rdfs:label 'Edit Description' ;
    rdfs:comment 'Human-readable description of the edit.' ;
    rdfs:domain ind:Adjudication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editOutcome rdf:type rdf:Property ;
    rdfs:label 'Edit Outcome' ;
    rdfs:comment 'Result of the edit evaluation.' ;
    rdfs:domain ind:Adjudication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editOverrideAuthority rdf:type rdf:Property ;
    rdfs:label 'Edit Override Authority' ;
