    rdfs:domain ind:CommitteeType ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommitteeType .

ind:allowsVirtualParticipation rdf:type rdf:Property ;
    rdfs:label 'Allows Virtual Participation' ;
    rdfs:comment 'Indicates whether members of this committee type are permitted to participate and vote remotely via teleconference or video, per organizational bylaws and applicable state regulations.' ;
    rdfs:domain ind:CommitteeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorityLevel rdf:type rdf:Property ;
    rdfs:label 'Authority Level' ;
    rdfs:comment 'Indicates the decision-making authority of this committee type — whether it renders final credentialing decisions, makes recommendations to a higher body, serves in an advisory capacity, or operates under delegated authority from the governing board.' ;
    rdfs:domain ind:CommitteeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Committee Type Category' ;
    rdfs:comment 'High-level functional category grouping committee types for reporting and governance purposes. Distinguishes credentialing decision-making committees from peer review, quality oversight, advisory, and appeals bodies.' ;
    rdfs:domain ind:CommitteeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeTypeCode rdf:type rdf:Property ;
    rdfs:label 'Committee Type Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the committee type, used as a business-facing natural key in credentialing workflows and system integrations (e.g., CRED_COMM, PEER_REV, MED_ADV).' ;
    rdfs:domain ind:CommitteeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Committee Type Status' ;
    rdfs:comment 'Current lifecycle status of this committee type reference record. Active types are available for assignment to credentialing workflows; inactive or deprecated types are retained for historical reference but cannot be assigned to new committees.' ;
    rdfs:domain ind:CommitteeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Committee Type Description' ;
    rdfs:comment 'Detailed narrative describing the purpose, scope, and responsibilities of this committee type within the credentialing and provider oversight lifecycle.' ;
    rdfs:domain ind:CommitteeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Numeric sort order controlling the presentation sequence of committee types in user interfaces, dropdown lists, and reports. Lower values appear first.' ;
    rdfs:domain ind:CommitteeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meetingFrequency rdf:type rdf:Property ;
    rdfs:label 'Meeting Frequency' ;
    rdfs:comment 'Standard frequency at which this committee type convenes to review credentialing files and render decisions. NCQA requires timely processing, so meeting cadence directly impacts credentialing cycle time.' ;
    rdfs:domain ind:CommitteeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumQuorumCount rdf:type rdf:Property ;
    rdfs:label 'Minimum Quorum Count' ;
    rdfs:comment 'The minimum number of voting members required to be present for the committee to conduct official business and render binding credentialing decisions, per organizational bylaws and NCQA standards.' ;
    rdfs:domain ind:CommitteeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:committeeTypeName rdf:type rdf:Property ;
    rdfs:label 'Committee Type Name' ;
    rdfs:comment 'Human-readable display name for the committee type (e.g., \'Credentials Committee\', \'Peer Review Committee\', \'Medical Advisory Committee\', \'Quality Improvement Committee\').' ;
    rdfs:domain ind:CommitteeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncqaRequired rdf:type rdf:Property ;
    rdfs:label 'Ncqa Required' ;
    rdfs:comment 'Indicates whether this committee type is explicitly required by NCQA credentialing accreditation standards. Used to distinguish mandatory committee structures from optional or organization-specific governance bodies.' ;
    rdfs:domain ind:CommitteeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPhysicianChair rdf:type rdf:Property ;
    rdfs:label 'Requires Physician Chair' ;
    rdfs:comment 'Indicates whether this committee type requires a licensed physician (MD/DO) to serve as chairperson, as mandated by NCQA credentialing standards and many state regulations for credentialing decision-making bodies.' ;
    rdfs:domain ind:CommitteeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:votingMethod rdf:type rdf:Property ;
    rdfs:label 'Voting Method' ;
    rdfs:comment 'The voting methodology used by this committee type to reach credentialing decisions — simple majority, supermajority (two-thirds), unanimous, or consensus-based.' ;
    rdfs:domain ind:CommitteeType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

