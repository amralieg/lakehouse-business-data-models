    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfpStatus rdf:type rdf:Property ;
    rdfs:label 'Rfp Status' ;
    rdfs:comment 'Current lifecycle status of the solicitation.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitationNumber rdf:type rdf:Property ;
    rdfs:label 'Solicitation Number' ;
    rdfs:comment 'External business identifier assigned to the solicitation for tracking and reference.' ;
