ind:incidentId rdf:type rdf:Property ;
    rdfs:label 'Incident Id' ;
    rdfs:comment 'Unique system-generated identifier for each vendor incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentIncidentId rdf:type rdf:Property ;
    rdfs:label 'Parent Incident Id' ;
    rdfs:comment 'Self-referencing FK on incident (parent_incident_id)' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:breachNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Date' ;
    rdfs:comment 'Calendar date when members received breach notification.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breachNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Sent' ;
    rdfs:comment 'True if affected members were notified per breach-notification rules.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactedFunctions rdf:type rdf:Property ;
    rdfs:label 'Impacted Functions' ;
    rdfs:comment 'Comma-separated list of health-plan functions (e.g., claims processing, member portal) affected.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Calendar date on which the incident was first observed.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Human-readable incident number assigned by the vendor management process.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current processing state of the incident within the incident management workflow.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Category describing the nature of the vendor incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPhiInvolved rdf:type rdf:Property ;
    rdfs:label 'Is Phi Involved' ;
    rdfs:comment 'True if the incident involved protected health information as defined by HIPAA.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date the required regulatory body was notified.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'True when the incident triggers mandatory reporting under HIPAA, CMS, or other regulations.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingChannel rdf:type rdf:Property ;
    rdfs:label 'Reporting Channel' ;
    rdfs:comment 'Method used to submit the incident report.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorResponseDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Response Date' ;
    rdfs:comment 'Date the vendor acknowledged the incident and supplied an initial response.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Id' ;
    rdfs:comment 'System-generated unique identifier for each vendor onboarding record.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentOnboardingId rdf:type rdf:Property ;
    rdfs:label 'Parent Onboarding Id' ;
    rdfs:comment 'Self-referencing FK on onboarding (parent_onboarding_id)' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Onboarding .

ind:checklistBaaExecuted rdf:type rdf:Property ;
    rdfs:label 'Checklist Baa Executed' ;
    rdfs:comment 'Indicates whether a Business Associate Agreement has been executed with the vendor.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checklistDiversityCertVerified rdf:type rdf:Property ;
    rdfs:label 'Checklist Diversity Cert Verified' ;
    rdfs:comment 'Indicates whether the vendor\'s diversity certification has been verified.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checklistFinancialDueDiligence rdf:type rdf:Property ;
    rdfs:label 'Checklist Financial Due Diligence' ;
    rdfs:comment 'Indicates whether financial due diligence on the vendor has been completed.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checklistInsuranceVerified rdf:type rdf:Property ;
    rdfs:label 'Checklist Insurance Verified' ;
    rdfs:comment 'Indicates whether the vendor\'s insurance certificate has been verified.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checklistSecurityQuestionnaire rdf:type rdf:Property ;
    rdfs:label 'Checklist Security Questionnaire' ;
    rdfs:comment 'Indicates whether the vendor\'s security questionnaire has been completed.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checklistW9Received rdf:type rdf:Property ;
    rdfs:label 'Checklist W9 Received' ;
    rdfs:comment 'Indicates whether the vendor\'s W-9 tax form has been received.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestorDepartment rdf:type rdf:Property ;
    rdfs:label 'Requestor Department' ;
    rdfs:comment 'Internal department that initiated the vendor onboarding request.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage of the onboarding workflow.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOnboardingCost rdf:type rdf:Property ;
    rdfs:label 'Total Onboarding Cost' ;
    rdfs:comment 'Aggregated monetary cost incurred during the onboarding process.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfpId rdf:type rdf:Property ;
    rdfs:label 'Rfp Id' ;
    rdfs:comment 'System-generated unique identifier for the RFP record.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfp .

ind:awardedVendorId rdf:type rdf:Property ;
    rdfs:label 'Awarded Vendor Id' ;
    rdfs:comment 'Reference to the vendor that was awarded the contract, if any.' ;
