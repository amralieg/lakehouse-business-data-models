    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hccCategory rdf:type rdf:Property ;
    rdfs:label 'Hcc Category' ;
    rdfs:comment 'HCC category code used for risk-adjustment and RAF calculations.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icd10Code rdf:type rdf:Property ;
    rdfs:label 'Icd10 Code' ;
    rdfs:comment 'Standard ICD-10 diagnosis code associated with the mapping.' ;
