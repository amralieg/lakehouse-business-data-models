    rdfs:comment 'True when the event causes loss of Medicaid eligibility.' ;
    rdfs:domain ind:MemberLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicareEntitlementFlag rdf:type rdf:Property ;
    rdfs:label 'Medicare Entitlement Flag' ;
    rdfs:comment 'True if the event confers Medicare entitlement.' ;
    rdfs:domain ind:MemberLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberLifecycleEventStatus rdf:type rdf:Property ;
    rdfs:label 'Member Lifecycle Event Status' ;
    rdfs:comment 'Current lifecycle status of the event record.' ;
    rdfs:domain ind:MemberLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planTerminationFlag rdf:type rdf:Property ;
    rdfs:label 'Plan Termination Flag' ;
    rdfs:comment 'Indicates whether the event is due to termination of the member\'s health plan.' ;
    rdfs:domain ind:MemberLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualifiedLifeEventFlag rdf:type rdf:Property ;
    rdfs:label 'Qualified Life Event Flag' ;
    rdfs:comment 'True if the event qualifies as a life event for enrollment changes (e.g., marriage, birth).' ;
    rdfs:domain ind:MemberLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relocationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Relocation Effective Date' ;
    rdfs:comment 'Date the member\'s relocation becomes effective for eligibility purposes.' ;
    rdfs:domain ind:MemberLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relocationStateCode rdf:type rdf:Property ;
    rdfs:label 'Relocation State Code' ;
    rdfs:comment 'Two-letter state abbreviation where the member is relocating, if applicable.' ;
    rdfs:domain ind:MemberLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'Identifier of the original record in the source system.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialEnrollmentPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Special Enrollment Period Flag' ;
    rdfs:comment 'Indicates whether the event creates a Special Enrollment Period under ACA regulations.' ;
    rdfs:domain ind:MemberLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberCommunicationId rdf:type rdf:Property ;
    rdfs:label 'Member Communication Id' ;
    rdfs:comment 'Unique surrogate key for each communication record.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberCommunication .

ind:pharmacyVendorId rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Vendor Id' ;
    rdfs:comment 'Foreign key linking to vendor.vendor. Business justification: PHARMACY_BENEFIT_MANAGEMENT: Member pharmacy BIN/PCN data must be linked to the contracted pharmacy vendor for claim routing and CMS reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:sentByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sent By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Communications to members are often sent by a staff employee; tracking sender supports compliance and quality monitoring.' ;
    rdfs:domain ind:MemberCommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Status' ;
    rdfs:comment 'Indicates whether the member has acknowledged receipt of the communication.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:body rdf:type rdf:Property ;
    rdfs:label 'Body' ;
    rdfs:comment 'Full textual content of the communication (may be truncated for storage).' ;
    rdfs:domain ind:MemberCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardStatus rdf:type rdf:Property ;
    rdfs:label 'Card Status' ;
    rdfs:comment 'Current lifecycle status of the ID card.' ;
    rdfs:domain ind:MemberCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationNumber rdf:type rdf:Property ;
    rdfs:label 'Communication Number' ;
    rdfs:comment 'Human-readable identifier assigned to the communication for tracking and reference.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationType rdf:type rdf:Property ;
    rdfs:label 'Communication Type' ;
    rdfs:comment 'Category of the outbound/inbound communication (e.g., Explanation of Benefits, Welcome Kit, ID Card, Annual Notice of Change, Evidence of Coverage, Summary of Benefits and Coverage).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryConfirmation rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmation' ;
    rdfs:comment 'True when delivery of the communication has been confirmed (e.g., signed receipt).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Date-time when the communication was successfully delivered to the member (if applicable).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 code representing the language of the communication.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberCommunicationStatus rdf:type rdf:Property ;
    rdfs:label 'Member Communication Status' ;
    rdfs:comment 'Current processing state of the communication.' ;
    rdfs:domain ind:MemberCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberIdDisplayed rdf:type rdf:Property ;
    rdfs:label 'Member Id Displayed' ;
    rdfs:comment 'Member identifier printed on the ID card (may be masked for privacy).' ;
    rdfs:domain ind:MemberCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Flag' ;
    rdfs:comment 'True when the communication satisfies a mandatory regulatory requirement (e.g., CMS-mandated notice).' ;
    rdfs:domain ind:MemberCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Send Timestamp' ;
    rdfs:comment 'Date-time when the communication was sent or initiated.' ;
    rdfs:domain ind:MemberCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Subject line or title of the communication.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateVersion rdf:type rdf:Property ;
    rdfs:label 'Template Version' ;
    rdfs:comment 'Version identifier of the communication template used.' ;
    rdfs:domain ind:MemberCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberGrievance2Id rdf:type rdf:Property ;
    rdfs:label 'Member Grievance2 Id' ;
    rdfs:comment 'System-generated unique identifier for each grievance record.' ;
    rdfs:domain ind:MemberGrievance2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealGrievanceId rdf:type rdf:Property ;
    rdfs:label 'Appeal Grievance Id' ;
    rdfs:comment 'Foreign key linking this domain-specific grievance record to the single source of truth in appeal.appeal_grievance' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AppealGrievance2 .

ind:benefitPackageId rdf:type rdf:Property ;
    rdfs:label 'Benefit Package Id' ;
    rdfs:comment 'Identifier of the specific benefit package linked to the member\'s coverage.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPackage .

ind:cmsReportableIndicator rdf:type rdf:Property ;
    rdfs:label 'Cms Reportable Indicator' ;
    rdfs:comment 'True if the grievance is reportable under CMS grievance reporting requirements (e.g., Medicare Advantage).' ;
    rdfs:domain ind:MemberGrievance2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'Monetary amount that the member is contesting, if applicable (e.g., billing dispute).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grievanceNumber rdf:type rdf:Property ;
    rdfs:label 'Grievance Number' ;
    rdfs:comment 'Business-visible identifier assigned to the grievance, often used in member communications and regulatory reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceSource rdf:type rdf:Property ;
    rdfs:label 'Grievance Source' ;
    rdfs:comment 'Channel through which the grievance was received.' ;
    rdfs:domain ind:MemberGrievance2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation End Timestamp' ;
    rdfs:comment 'Date-time when the investigation concluded.' ;
    rdfs:domain ind:MemberGrievance2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Timestamp' ;
    rdfs:comment 'Date-time when the investigation of the grievance began.' ;
    rdfs:domain ind:MemberGrievance2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:issueCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Issue Category Code' ;
    rdfs:comment 'More granular classification of the grievance issue within the selected grievance type.' ;
    rdfs:domain ind:MemberGrievance2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberGrievanceStatus rdf:type rdf:Property ;
    rdfs:label 'Member Grievance Status' ;
    rdfs:comment 'Current lifecycle state of the grievance.' ;
    rdfs:domain ind:MemberGrievance2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Member Satisfaction Score' ;
    rdfs:comment 'Member-reported satisfaction rating of the grievance resolution on a 1-5 scale.' ;
    rdfs:domain ind:MemberGrievance2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Exact date-time when the grievance was first recorded in the system.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether the grievance must be reported to regulatory bodies (true) or not (false).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Calendar date on which the grievance was formally resolved.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Narrative details of the actions taken or explanation provided to resolve the grievance.' ;
    rdfs:domain ind:MemberGrievance2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTypeCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Type Code' ;
    rdfs:comment 'Indicates how the grievance was addressed, e.g., corrective action, explanation, refund, no action, or other.' ;
    rdfs:domain ind:MemberGrievance2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeCode rdf:type rdf:Property ;
    rdfs:label 'Type Code' ;
    rdfs:comment 'Categorizes the grievance by primary concern area such as quality of care, access, provider attitude, billing/financial, or benefit/coverage.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carePlanId rdf:type rdf:Property ;
    rdfs:label 'Care Plan Id' ;
    rdfs:comment 'Foreign key linking to care.care_plan. Business justification: Each enrollment transaction can generate a Care Plan; linking enables cost, outcome, and compliance reporting per transaction.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarePlan .

ind:enrollmentBatchId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Batch Id' ;
    rdfs:comment 'Identifier of the batch job that processed this enrollment transaction.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Batch .

ind:enrollmentOpenEnrollmentPeriodId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Open Enrollment Period Id' ;
    rdfs:comment 'Foreign key linking to enrollment.open_enrollment_period. Business justification: Each enrollment transaction occurs within a defined open enrollment period; linking transaction to period enables period-based reporting and ensures the period is not a silo.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OpenEnrollmentPeriod .

ind:groupContactId rdf:type rdf:Property ;
    rdfs:label 'Group Contact Id' ;
    rdfs:comment 'Foreign key linking to employer.group_contact. Business justification: Required for audit of enrollment approvals: employer\'s designated contact must be recorded per ACA compliance reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupContact .

ind:groupRenewalId rdf:type rdf:Property ;
    rdfs:label 'Group Renewal Id' ;
    rdfs:comment 'Foreign key linking to employer.group_renewal. Business justification: Financial reconciliation requires associating each enrollment transaction with the employer\'s renewal cycle.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupRenewal .

ind:memberGroupId rdf:type rdf:Property ;
    rdfs:label 'Member Group Id' ;
    rdfs:comment 'Identifier of the employer group or line of business to which the member belongs.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Group .

ind:rapsSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Raps Submission Id' ;
    rdfs:comment 'Foreign key linking to risk.raps_submission. Business justification: During enrollment processing, a RAPS risk-adjustment submission may be generated; linking provides audit trail for regulatory reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RapsSubmission .

ind:rateId rdf:type rdf:Property ;
    rdfs:label 'Rate Id' ;
    rdfs:comment 'Foreign key linking to plan.plan_rate. Business justification: Required for premium audit reports that must trace each enrollment transaction to the exact rate applied for regulatory compliance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rate .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Monetary adjustment (e.g., discount, surcharge) applied to the gross premium.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Standard code describing why a financial or coverage adjustment was made.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or role of the individual or system that approved the enrollment change.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditUserRole rdf:type rdf:Property ;
    rdfs:label 'Audit User Role' ;
    rdfs:comment 'Role of the audit user (e.g., admin, operator, system).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsReprocessFlag rdf:type rdf:Property ;
    rdfs:label 'Claims Reprocess Flag' ;
    rdfs:comment 'True if the enrollment change requires downstream claims to be re-processed.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of the transaction with applicable regulations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveragePeriodType rdf:type rdf:Property ;
    rdfs:label 'Coverage Period Type' ;
    rdfs:comment 'Indicates whether the coverage is continuous, intermittent, or contains a gap.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransactionId rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Id' ;
    rdfs:comment 'add column edi_transaction_id (BIGINT) with FK to enrollment.edi_transaction.edi_transaction_id - many transactions originate as 834 EDIs' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdiTransaction .

ind:enrollmentComment rdf:type rdf:Property ;
    rdfs:label 'Enrollment Comment' ;
    rdfs:comment 'Free-form text field for notes or comments entered by the processor.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentEligibilitySpanId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Eligibility Span Id' ;
    rdfs:comment 'Identifier of the eligibility span generated from this transaction.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnrollmentEligibilitySpan .

ind:enrollmentOrigin rdf:type rdf:Property ;
    rdfs:label 'Enrollment Origin' ;
    rdfs:comment 'Channel through which the enrollment was initiated.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Transaction Number' ;
    rdfs:comment 'External business identifier assigned to the enrollment transaction, used for tracking and reference.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Standardized error code returned when processing fails (e.g., X12 validation error).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorDescription rdf:type rdf:Property ;
    rdfs:label 'Error Description' ;
    rdfs:comment 'Human-readable description of the processing error.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeCode rdf:type rdf:Property ;
    rdfs:label 'Exchange Code' ;
    rdfs:comment 'Identifier of the marketplace exchange where the member enrolled.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Original filename of the inbound 834 transaction as received from the EDI gateway.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Flag' ;
    rdfs:comment 'True when the enrollment change has a direct impact on premium billing or financial reporting.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gracePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Grace Period End Date' ;
    rdfs:comment 'Date when the applicable grace period expires.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total premium amount before any adjustments for the enrollment period.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthPlanType rdf:type rdf:Property ;
    rdfs:label 'Health Plan Type' ;
    rdfs:comment 'Classification of the health plan (e.g., HMO, PPO, EPO, POS, HDHP).' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hiosCode rdf:type rdf:Property ;
    rdfs:label 'Hios Code' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGracePeriod rdf:type rdf:Property ;
    rdfs:label 'Is Grace Period' ;
    rdfs:comment 'True if the enrollment is being processed within a grace period after termination.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:masterEntityCode rdf:type rdf:Property ;
    rdfs:label 'Master Entity Code' ;
    rdfs:comment 'Cross-domain master/golden entity key for SSOT resolution.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Final premium amount after adjustments, representing the amount to be billed.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalTerminationReference rdf:type rdf:Property ;
    rdfs:label 'Original Termination Reference' ;
    rdfs:comment 'Reference to the prior termination transaction that is being reinstated.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorAuthorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Required' ;
    rdfs:comment 'Indicates whether the enrollment change triggers a prior authorization requirement.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current processing stage of the transaction within the enrollment workflow.' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactivationDate rdf:type rdf:Property ;
    rdfs:label 'Reactivation Date' ;
    rdfs:comment 'Effective date of coverage reactivation for reinstatement events.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retroactiveAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Retroactive Adjustment Flag' ;
    rdfs:comment 'Flag indicating whether the transaction represents a retroactive adjustment to prior coverage dates.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the enrollment transaction.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventId rdf:type rdf:Property ;
    rdfs:label 'Event Id' ;
    rdfs:comment 'System-generated unique identifier for each enrollment event record.' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Event .

ind:groupPlanOfferingId rdf:type rdf:Property ;
    rdfs:label 'Group Plan Offering Id' ;
    rdfs:comment 'Foreign key linking to employer.group_plan_offering. Business justification: Event tracking reports must reference the exact plan offering the change relates to for employer-level reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupPlanOffering .

ind:riskUnderwritingCaseId rdf:type rdf:Property ;
    rdfs:label 'Risk Underwriting Case Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_underwriting_case. Business justification: Event-driven underwriting decisions are recorded; linking supports the \'Underwriting Decision Audit\' report.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskUnderwritingCase .

ind:actorType rdf:type rdf:Property ;
    rdfs:label 'Actor Type' ;
    rdfs:comment 'Classifies the party that triggered the event.' ;
