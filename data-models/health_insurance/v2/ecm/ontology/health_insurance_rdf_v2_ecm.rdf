    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:parentRfpId rdf:type rdf:Property ;
    rdfs:label 'Parent Rfp Id' ;
    rdfs:comment 'Self-referencing FK on rfp (parent_rfp_id)' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfp .

ind:awardAmount rdf:type rdf:Property ;
    rdfs:label 'Award Amount' ;
    rdfs:comment 'Final monetary amount of the awarded contract.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardCurrency rdf:type rdf:Property ;
    rdfs:label 'Award Currency' ;
    rdfs:comment 'Currency in which the award amount is expressed.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardStatus rdf:type rdf:Property ;
    rdfs:label 'Award Status' ;
    rdfs:comment 'Current status of the award decision.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndEstimate rdf:type rdf:Property ;
    rdfs:label 'Contract End Estimate' ;
    rdfs:comment 'Projected end date of the contract based on the term.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartEstimate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Estimate' ;
    rdfs:comment 'Projected start date of the contract once awarded.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfpDescription rdf:type rdf:Property ;
    rdfs:label 'Rfp Description' ;
    rdfs:comment 'Detailed narrative describing the goods or services being sourced.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Value' ;
    rdfs:comment 'Projected monetary value of the contract before award.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'Set of criteria used to assess vendor responses (e.g., cost, compliance, capability).' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invitedVendorCount rdf:type rdf:Property ;
    rdfs:label 'Invited Vendor Count' ;
    rdfs:comment 'Count of distinct vendors that were invited to participate in the solicitation.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivedResponseCount rdf:type rdf:Property ;
    rdfs:label 'Received Response Count' ;
    rdfs:comment 'Count of vendor responses received by the response due date.' ;
