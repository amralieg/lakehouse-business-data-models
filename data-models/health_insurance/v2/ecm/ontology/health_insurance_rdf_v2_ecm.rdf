    rdfs:range xsd:string .

ind:cybersecurityScore rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Score' ;
    rdfs:comment 'Numeric score (0-100) assessing the vendor\'s cybersecurity posture.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
