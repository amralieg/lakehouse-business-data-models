    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPrice rdf:type rdf:Property ;
    rdfs:label 'Total Price' ;
    rdfs:comment 'Total monetary amount proposed by the vendor before discounts, taxes, or adjustments.' ;
