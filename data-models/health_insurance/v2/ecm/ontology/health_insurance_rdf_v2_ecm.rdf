    rdfs:range xsd:integer .

ind:parentPoLineId rdf:type rdf:Property ;
    rdfs:label 'Parent Po Line Id' ;
    rdfs:comment 'Self-referencing FK on po_line (parent_po_line_id)' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Date the goods or service were actually received.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:catalogItemCode rdf:type rdf:Property ;
    rdfs:label 'Catalog Item Code' ;
    rdfs:comment 'Identifier of the catalog item or service being procured on this line.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isTaxExempt rdf:type rdf:Property ;
    rdfs:label 'Is Tax Exempt' ;
    rdfs:comment 'True if the line is exempt from tax.' ;
