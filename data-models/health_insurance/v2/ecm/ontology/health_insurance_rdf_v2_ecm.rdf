ind:mlrReportingEntityHealthPlanId rdf:type rdf:Property ;
    rdfs:label 'Mlr Reporting Entity Health Plan Id' ;
    rdfs:comment 'Foreign key to the health plan for which the MLR is being calculated.' ;
    rdfs:domain ind:MlrCalculation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthPlan .

ind:earnedPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Earned Premium Amount' ;
    rdfs:comment 'Total earned premium dollars for the reporting period, forming the MLR denominator.' ;
