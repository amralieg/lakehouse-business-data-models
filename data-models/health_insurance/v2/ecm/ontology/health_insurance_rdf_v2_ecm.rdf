ind:settlementNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Number' ;
    rdfs:comment 'External settlement reference number assigned by the finance system.' ;
    rdfs:domain ind:VbcSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current lifecycle status of the settlement transaction.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Timestamp' ;
    rdfs:comment 'Date and time when the settlement was executed in the real world.' ;
    rdfs:domain ind:VbcSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementType rdf:type rdf:Property ;
    rdfs:label 'Settlement Type' ;
    rdfs:comment 'Classification of the settlement based on contract model.' ;
    rdfs:domain ind:VbcSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlrFinancialEntryId rdf:type rdf:Property ;
    rdfs:label 'Mlr Financial Entry Id' ;
    rdfs:comment 'Unique surrogate key for each MLR financial entry record.' ;
    rdfs:domain ind:MlrFinancialEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doiSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Doi Submission Id' ;
    rdfs:comment 'Unique identifier assigned by the state Department of Insurance to the submitted MLR report.' ;
    rdfs:domain ind:MlrFinancialEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:mlrCalculationId rdf:type rdf:Property ;
    rdfs:label 'Mlr Calculation Id' ;
    rdfs:comment 'Foreign key linking to compliance.mlr_calculation. Business justification: MLR financial entry must be tied to the exact MLR calculation for accurate reporting and audit.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MlrCalculation .

ind:auditUserUpdate rdf:type rdf:Property ;
    rdfs:label 'Audit User Update' ;
    rdfs:comment 'Identifier of the user who performed the most recent update to the MLR entry.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'Date on which the MLR calculation was performed.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mlrFinancialEntryDescription rdf:type rdf:Property ;
    rdfs:label 'Mlr Financial Entry Description' ;
    rdfs:comment 'Free-form text for any supplemental information about the MLR entry.' ;
    rdfs:domain ind:MlrFinancialEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incurredClaimsAmount rdf:type rdf:Property ;
    rdfs:label 'Incurred Claims Amount' ;
    rdfs:comment 'Total dollar amount of claims incurred during the reporting period.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumMlrThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Mlr Threshold' ;
    rdfs:comment 'Regulatory minimum MLR threshold that must be met for the jurisdiction.' ;
    rdfs:domain ind:MlrFinancialEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mlrFinancialEntryStatus rdf:type rdf:Property ;
    rdfs:label 'Mlr Financial Entry Status' ;
    rdfs:comment 'Current lifecycle status of the MLR entry.' ;
    rdfs:domain ind:MlrFinancialEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Liability Amount' ;
    rdfs:comment 'Dollar amount of rebate liability owed to members if MLR falls below the minimum threshold.' ;
    rdfs:domain ind:MlrFinancialEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEarnedPremium rdf:type rdf:Property ;
    rdfs:label 'Total Earned Premium' ;
    rdfs:comment 'Total earned premium revenue for the reporting period, used as the MLR denominator.' ;
    rdfs:domain ind:MlrFinancialEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actuarialReserveId rdf:type rdf:Property ;
    rdfs:label 'Actuarial Reserve Id' ;
    rdfs:comment 'Primary key for actuarial_reserve' ;
    rdfs:domain ind:ActuarialReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actuarialReserveStatus rdf:type rdf:Property ;
    rdfs:label 'Actuarial Reserve Status' ;
    rdfs:comment 'Current lifecycle status of the reserve record.' ;
    rdfs:domain ind:ActuarialReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actuaryName rdf:type rdf:Property ;
    rdfs:label 'Actuary Name' ;
    rdfs:comment 'Full legal name of the certified actuary responsible for the reserve estimate.' ;
    rdfs:domain ind:ActuarialReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actuarySignatureDate rdf:type rdf:Property ;
    rdfs:label 'Actuary Signature Date' ;
    rdfs:comment 'Date and time when the actuary signed off on the reserve estimate.' ;
    rdfs:domain ind:ActuarialReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confidenceIntervalHigh rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval High' ;
    rdfs:comment 'Upper bound of the statistical confidence interval for the reserve estimate.' ;
    rdfs:domain ind:ActuarialReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceIntervalLow rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Low' ;
    rdfs:comment 'Lower bound of the statistical confidence interval for the reserve estimate.' ;
    rdfs:domain ind:ActuarialReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentMethod rdf:type rdf:Property ;
    rdfs:label 'Development Method' ;
    rdfs:comment 'Actuarial technique used to project the reserve (e.g., Chain-Ladder, Bornhuetter-Ferguson, Frequency-Severity).' ;
    rdfs:domain ind:ActuarialReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingReference rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Reference' ;
    rdfs:comment 'Reference identifier linking the reserve to the corresponding GL posting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paidClaimsAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Claims Amount' ;
    rdfs:comment 'Cumulative amount of claims that have been paid to date for the period.' ;
    rdfs:domain ind:ActuarialReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidLaeAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Lae Amount' ;
    rdfs:comment 'Cumulative amount of loss-adjustment expenses that have been paid to date.' ;
    rdfs:domain ind:ActuarialReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reserveEstimateAmount rdf:type rdf:Property ;
    rdfs:label 'Reserve Estimate Amount' ;
    rdfs:comment 'Actuarial estimate of the liability for the reserve period before adding confidence bounds.' ;
    rdfs:domain ind:ActuarialReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservePeriod rdf:type rdf:Property ;
    rdfs:label 'Reserve Period' ;
    rdfs:comment 'First day of the accounting period to which the reserve estimate applies.' ;
    rdfs:domain ind:ActuarialReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reserveType rdf:type rdf:Property ;
    rdfs:label 'Reserve Type' ;
    rdfs:comment 'Category of reserve: Incurred But Not Reported (IBNR), Allocated Loss Adjustment Expense (ALAE), or Unallocated Loss Adjustment Expense (ULAE).' ;
    rdfs:domain ind:ActuarialReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Total Liability Amount' ;
    rdfs:comment 'Sum of paid amounts and reserve estimate representing the total projected liability.' ;
    rdfs:domain ind:ActuarialReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryBudgetApprovalUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Budget Approval User Employee Id' ;
    rdfs:comment 'Identifier of the user who performed the approval.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalUserName rdf:type rdf:Property ;
    rdfs:label 'Approval User Name' ;
    rdfs:comment 'Full name of the user who approved the budget.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Human-readable budget number assigned by finance for tracking and reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle state of the budget.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Category of the budget indicating planning horizon.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetDescription rdf:type rdf:Property ;
    rdfs:label 'Budget Description' ;
    rdfs:comment 'Narrative description of the budget purpose and scope.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Full name of the budget owner.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorYearActualAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Year Actual Amount' ;
    rdfs:comment 'Actual spend recorded for the same fiscal period in the previous year.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAdjustedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Adjusted Amount' ;
    rdfs:comment 'Sum of all approved adjustments (increases or decreases) to the original budget.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBudgetedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budgeted Amount' ;
    rdfs:comment 'Aggregate amount originally budgeted for the period.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:year rdf:type rdf:Property ;
    rdfs:label 'Year' ;
    rdfs:comment 'Four-digit fiscal year to which the budget applies.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Unique system-generated identifier for each budget line item.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetLine .

ind:accountCode rdf:type rdf:Property ;
    rdfs:label 'Account Code' ;
    rdfs:comment 'Chart of accounts code that the budget amount is charged to.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetLineStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Line Status' ;
    rdfs:comment 'Operational status of the budget line item.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Period within the fiscal year (e.g., 2024-01 for January 2024).' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isForecast rdf:type rdf:Property ;
    rdfs:label 'Is Forecast' ;
    rdfs:comment 'True if the line reflects a forecasted adjustment rather than an approved budget.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resourceType rdf:type rdf:Property ;
    rdfs:label 'Resource Type' ;
    rdfs:comment 'Category of the resource (e.g., expense, revenue, capital) that the line supports.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePercent rdf:type rdf:Property ;
    rdfs:label 'Variance Percent' ;
    rdfs:comment 'Percentage representation of the variance amount.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumRevenueId rdf:type rdf:Property ;
    rdfs:label 'Premium Revenue Id' ;
    rdfs:comment 'System-generated unique identifier for the premium revenue record.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:underwriterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Underwriter Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Underwriting profit and loss analysis depends on linking premium revenue records to the underwriter employee responsible for the policy.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capitationAmount rdf:type rdf:Property ;
    rdfs:label 'Capitation Amount' ;
    rdfs:comment 'Fixed amount paid under a capitation arrangement for the period.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coveragePeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Coverage Period Months' ;
    rdfs:comment 'Length of the coverage period in months.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deficiencyReserve rdf:type rdf:Property ;
    rdfs:label 'Deficiency Reserve' ;
    rdfs:comment 'Reserve for potential shortfalls in premium collection or underwriting loss.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnedPremium rdf:type rdf:Property ;
    rdfs:label 'Earned Premium' ;
    rdfs:comment 'Portion of written premium that has been earned based on coverage elapsed.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mlrDenominatorFlag rdf:type rdf:Property ;
    rdfs:label 'Mlr Denominator Flag' ;
    rdfs:comment 'Indicates whether this premium is included in the Medical Loss Ratio denominator.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netEarnedPremium rdf:type rdf:Property ;
    rdfs:label 'Net Earned Premium' ;
    rdfs:comment 'Earned premium after deducting reserves, adjustments, and reinsurance.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Premium Record Number' ;
    rdfs:comment 'External business identifier assigned to the premium revenue record.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumRevenueStatus rdf:type rdf:Property ;
    rdfs:label 'Premium Revenue Status' ;
    rdfs:comment 'Current lifecycle status of the premium revenue record.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumTaxBase rdf:type rdf:Property ;
    rdfs:label 'Premium Tax Base' ;
    rdfs:comment 'Base amount used for calculating premium taxes.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinsuranceCededPremium rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Ceded Premium' ;
    rdfs:comment 'Portion of premium transferred to reinsurance carriers.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Date' ;
    rdfs:comment 'Date on which the premium revenue was recognized according to ASC 606.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskCorridorAdjustment rdf:type rdf:Property ;
    rdfs:label 'Risk Corridor Adjustment' ;
    rdfs:comment 'Adjustment amount resulting from the risk corridor (3Rs) mechanism.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unearnedPremiumReserve rdf:type rdf:Property ;
    rdfs:label 'Unearned Premium Reserve' ;
    rdfs:comment 'Liability reserve for the portion of premium not yet earned.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vbcSharedSavingsAmount rdf:type rdf:Property ;
    rdfs:label 'Vbc Shared Savings Amount' ;
    rdfs:comment 'Amount of shared savings distributed under VBC contracts.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writtenPremium rdf:type rdf:Property ;
    rdfs:label 'Written Premium' ;
    rdfs:comment 'Total premium amount written for the coverage period before any earnings or adjustments.' ;
    rdfs:domain ind:PremiumRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinsuranceTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Transaction Id' ;
    rdfs:comment 'System-generated unique identifier for the reinsurance transaction record.' ;
    rdfs:domain ind:ReinsuranceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryReinsuranceVendorId rdf:type rdf:Property ;
    rdfs:label 'Primary Reinsurance Vendor Id' ;
    rdfs:comment 'Primary key of the reinsurer party involved in the transaction.' ;
    rdfs:domain ind:ReinsuranceTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:cededLossAmount rdf:type rdf:Property ;
    rdfs:label 'Ceded Loss Amount' ;
    rdfs:comment 'Loss amount the insurer cedes to the reinsurer.' ;
    rdfs:domain ind:ReinsuranceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cededPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Ceded Premium Amount' ;
    rdfs:comment 'Premium amount transferred to the reinsurer under the treaty.' ;
    rdfs:domain ind:ReinsuranceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinsuranceTransactionDescription rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Transaction Description' ;
    rdfs:comment 'Free-form text describing the purpose or details of the transaction.' ;
    rdfs:domain ind:ReinsuranceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAssumed rdf:type rdf:Property ;
    rdfs:label 'Is Assumed' ;
    rdfs:comment 'True if the transaction represents an assumed reinsurance amount.' ;
    rdfs:domain ind:ReinsuranceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCeded rdf:type rdf:Property ;
    rdfs:label 'Is Ceded' ;
    rdfs:comment 'True if the transaction represents a ceded amount to a reinsurer.' ;
    rdfs:domain ind:ReinsuranceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExcess rdf:type rdf:Property ;
    rdfs:label 'Is Excess' ;
    rdfs:comment 'True if the transaction is part of an excess-of-loss reinsurance treaty.' ;
    rdfs:domain ind:ReinsuranceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialSettlement rdf:type rdf:Property ;
    rdfs:label 'Is Partial Settlement' ;
    rdfs:comment 'True if the settlement covers only a portion of the total amount.' ;
    rdfs:domain ind:ReinsuranceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuotaShare rdf:type rdf:Property ;
    rdfs:label 'Is Quota Share' ;
    rdfs:comment 'True if the transaction pertains to a quota-share arrangement.' ;
    rdfs:domain ind:ReinsuranceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStopLoss rdf:type rdf:Property ;
    rdfs:label 'Is Stop Loss' ;
    rdfs:comment 'True if the transaction is related to a stop-loss reinsurance treaty.' ;
    rdfs:domain ind:ReinsuranceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rbcCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Rbc Credit Amount' ;
    rdfs:comment 'Amount of RBC credit recognized from the reinsurance transaction.' ;
    rdfs:domain ind:ReinsuranceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Amount' ;
    rdfs:comment 'Amount recovered from the reinsurer for previously ceded losses.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingCategory rdf:type rdf:Property ;
    rdfs:label 'Reporting Category' ;
    rdfs:comment 'Category used for internal and regulatory financial reporting.' ;
    rdfs:domain ind:ReinsuranceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskFactorCode rdf:type rdf:Property ;
    rdfs:label 'Risk Factor Code' ;
    rdfs:comment 'Code representing the specific risk factor applied to the transaction.' ;
    rdfs:domain ind:ReinsuranceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapScheduleFFlag rdf:type rdf:Property ;
    rdfs:label 'Sap Schedule F Flag' ;
    rdfs:comment 'Indicator required for SAP statutory Schedule F reporting (Y/N).' ;
    rdfs:domain ind:ReinsuranceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTypeCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Type Code' ;
    rdfs:comment 'System code representing the transaction type for integration purposes.' ;
    rdfs:domain ind:ReinsuranceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'System-generated unique identifier for the intercompany transaction record.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originatingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Originating Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: intercompany_transaction has originating_entity_code BIGINT representing the legal entity initiating the transaction. Adding originating_legal_entity_id FK normalizes this to the legal_entity master. ' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:reversalTransactionIntercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reversal Transaction Intercompany Transaction Id' ;
    rdfs:comment 'Identifier of the transaction that reverses this one, if applicable.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntercompanyTransaction .

ind:amountAdjustment rdf:type rdf:Property ;
    rdfs:label 'Amount Adjustment' ;
    rdfs:comment 'Sum of taxes, fees, discounts, or other adjustments applied to the gross amount.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountGross rdf:type rdf:Property ;
    rdfs:label 'Amount Gross' ;
    rdfs:comment 'Total monetary amount before any adjustments, in the transaction currency.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountNet rdf:type rdf:Property ;
    rdfs:label 'Amount Net' ;
    rdfs:comment 'Final amount after adjustments, representing the amount to be settled.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

