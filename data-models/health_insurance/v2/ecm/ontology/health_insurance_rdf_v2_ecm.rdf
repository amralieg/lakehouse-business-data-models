    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surgeonName rdf:type rdf:Property ;
    rdfs:label 'Surgeon Name' ;
    rdfs:comment 'Full name of the surgeon who performed the procedure.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsBilled rdf:type rdf:Property ;
    rdfs:label 'Units Billed' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjudicationId rdf:type rdf:Property ;
    rdfs:label 'Adjudication Id' ;
    rdfs:comment 'System-generated unique identifier for the adjudication record.' ;
    rdfs:domain ind:Adjudication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eobId rdf:type rdf:Property ;
    rdfs:label 'Eob Id' ;
    rdfs:comment 'add column eob_id (BIGINT) with FK to claim.eob.eob_id - adjudication produces an EOB' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Eob .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: GL posting of adjudication results requires a journal entry; finance team uses journal_entry to record each adjudication for audit and reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:accumulatorDeductibleImpact rdf:type rdf:Property ;
    rdfs:label 'Accumulator Deductible Impact' ;
    rdfs:comment 'Impact on the member\'s deductible accumulator from this adjudication.' ;
    rdfs:domain ind:Adjudication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accumulatorOopImpact rdf:type rdf:Property ;
    rdfs:label 'Accumulator Oop Impact' ;
    rdfs:comment 'Impact on the member\'s out-of-pocket accumulator.' ;
    rdfs:domain ind:Adjudication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjudicationNumber rdf:type rdf:Property ;
    rdfs:label 'Adjudication Number' ;
    rdfs:comment 'External reference number assigned to the adjudication for audit and communication purposes.' ;
    rdfs:domain ind:Adjudication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjudicationStatus rdf:type rdf:Property ;
    rdfs:label 'Adjudication Status' ;
    rdfs:comment 'Current status of the adjudication decision.' ;
    rdfs:domain ind:Adjudication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjudicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjudication Timestamp' ;
    rdfs:comment 'Date and time when the adjudication decision was generated.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allowedAmountMethod rdf:type rdf:Property ;
    rdfs:label 'Allowed Amount Method' ;
    rdfs:comment 'Methodology used to calculate the allowed amount.' ;
