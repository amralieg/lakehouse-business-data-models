ind:assignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned To Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Maps dispute cases to the employee handling them; required for dispute resolution workflow and performance metrics.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedServicePeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Affected Service Period End' ;
    rdfs:comment 'End date of the service period or contract period affected by the dispute.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedServicePeriodStart rdf:type rdf:Property ;
    rdfs:label 'Affected Service Period Start' ;
    rdfs:comment 'Start date of the service period or contract period affected by the dispute.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:arbitrationCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Arbitration Case Number' ;
    rdfs:comment 'External arbitration case number assigned by the arbitration body if the dispute is escalated to arbitration.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractAmendmentRequired rdf:type rdf:Property ;
    rdfs:label 'Contract Amendment Required' ;
    rdfs:comment 'Indicates whether the dispute resolution requires a formal contract amendment to be executed (True/False).' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractClauseReference rdf:type rdf:Property ;
    rdfs:label 'Contract Clause Reference' ;
    rdfs:comment 'Specific contract section, clause, or amendment number cited by the provider as the basis for the dispute.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRepositoryPath rdf:type rdf:Property ;
    rdfs:label 'Document Repository Path' ;
    rdfs:comment 'File system or document management system path where dispute-related documents are stored.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiationDate rdf:type rdf:Property ;
    rdfs:label 'Initiation Date' ;
    rdfs:comment 'Date when the provider formally filed the dispute with the health plan.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalCounselInvolved rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Involved' ;
    rdfs:comment 'Indicates whether legal counsel (internal or external) is involved in the dispute resolution process (True/False).' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalCounselName rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Name' ;
    rdfs:comment 'Name of the legal counsel or law firm representing the health plan in the dispute.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAdjustmentRequired rdf:type rdf:Property ;
    rdfs:label 'Payment Adjustment Required' ;
    rdfs:comment 'Indicates whether a retroactive payment adjustment or reprocessing of claims is required as a result of the dispute resolution (True/False).' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Provider Contact Email' ;
    rdfs:comment 'Email address of the provider representative handling the dispute.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerContactName rdf:type rdf:Property ;
    rdfs:label 'Provider Contact Name' ;
    rdfs:comment 'Name of the provider representative or contact person handling the dispute on behalf of the provider.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Provider Contact Phone' ;
    rdfs:comment 'Phone number of the provider representative handling the dispute.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether the dispute must be reported to state Department of Insurance (DOI) or other regulatory bodies (True/False).' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionAmount rdf:type rdf:Property ;
    rdfs:label 'Resolution Amount' ;
    rdfs:comment 'Final monetary settlement amount agreed upon or awarded as part of the dispute resolution.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the dispute was resolved within the SLA timeframe (True/False).' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaResolutionDays rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Days' ;
    rdfs:comment 'Number of calendar days within which the dispute must be resolved per contractual or regulatory SLA requirements.' ;
    rdfs:domain ind:ContractDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportingDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Count' ;
    rdfs:comment 'Number of supporting documents (contracts, invoices, correspondence, clinical documentation) submitted as evidence for the dispute.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractLifecycleEvent2Id rdf:type rdf:Property ;
    rdfs:label 'Contract Lifecycle Event2 Id' ;
    rdfs:comment 'Unique surrogate identifier for each contract lifecycle event record in the silver layer. Primary key for this entity.' ;
    rdfs:domain ind:ContractLifecycleEvent2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractingAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contracting Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Tracks Contract Lifecycle Analyst responsible for each event; essential for event-level reporting and audit trails.' ;
    rdfs:domain ind:ContractLifecycleEvent2 ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event required formal approval before being applied to the contract. Drives approval workflow routing and audit trail completeness validation.' ;
    rdfs:domain ind:ContractLifecycleEvent2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time at which the required approval for this lifecycle event was granted. Null when approval is not required or not yet obtained. Used for approval turnaround time analytics and SLA monitoring.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Name or employee identifier of the individual who approved this lifecycle event in the approval chain. Null when approval is not required or not yet obtained. Supports governance audit trail.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Human-readable, externally referenceable identifier for this lifecycle event, used in provider relations correspondence, audit reports, and regulatory examination submissions. Format: EVT-YYYY-NNNNNN.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current processing status of this lifecycle event record, indicating whether the event has been fully processed, is still in progress, or was cancelled or failed during execution.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newContractStatus rdf:type rdf:Property ;
    rdfs:label 'New Contract Status' ;
    rdfs:comment 'The contract status immediately after this lifecycle event was applied. Together with prior_contract_status, documents the complete state transition for compliance audit trail and regulatory examination readiness. [ENUM-REF-CANDIDATE: draft|pending_execution|active|suspended|terminated|expired|under_renegotiation|in_dispute — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContractLifecycleEvent2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'New Effective Date' ;
    rdfs:comment 'For renewal and renegotiation events, the start date of the new contract term resulting from this event. Distinct from effective_date (when the event itself takes effect) — this captures the new contract period start date for renewal pipeline tracking.' ;
    rdfs:domain ind:ContractLifecycleEvent2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:newExpirationDate rdf:type rdf:Property ;
    rdfs:label 'New Expiration Date' ;
    rdfs:comment 'For renewal and renegotiation events, the end date of the new contract term established by this event. Used for proactive contract management, renewal pipeline tracking, and expiration alerts.' ;
    rdfs:domain ind:ContractLifecycleEvent2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticeSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notice Sent Flag' ;
    rdfs:comment 'Indicates whether the required contractual or regulatory notice was sent to the provider for this lifecycle event (e.g., termination notice, suspension notice, renewal notice). Critical for compliance with notice period requirements under state DOI regulations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorContractStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Contract Status' ;
    rdfs:comment 'The contract status immediately before this lifecycle event was applied. Captured at the time of the event to support full audit trail reconstruction and state-transition compliance reporting. [ENUM-REF-CANDIDATE: draft|pending_execution|active|suspended|terminated|expired|under_renegotiation|in_dispute — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContractLifecycleEvent2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerRelationsCaseRef rdf:type rdf:Property ;
    rdfs:label 'Provider Relations Case Ref' ;
    rdfs:comment 'Reference number or identifier from the Provider Relations case management system (e.g., Salesforce Health Cloud or Pega) associated with this lifecycle event, particularly for dispute, termination, and escalation events. Enables cross-system traceability.' ;
    rdfs:domain ind:ContractLifecycleEvent2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'For renewal lifecycle events, specifies the mechanism by which the contract was renewed: automatic (auto-renewal clause triggered), renegotiated (new terms agreed), evergreen (continuous rolling renewal), or manual (explicit renewal action). Null for non-renewal events.' ;
    rdfs:domain ind:ContractLifecycleEvent2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceEventReference rdf:type rdf:Property ;
    rdfs:label 'Source Event Reference' ;
    rdfs:comment 'The native identifier of this lifecycle event in the originating operational system of record (e.g., Facets contract event ID, QNXT transaction ID, Pega case number). Enables cross-system traceability and reconciliation between the lakehouse silver layer and source systems.' ;
    rdfs:domain ind:ContractLifecycleEvent2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeredByType rdf:type rdf:Property ;
    rdfs:label 'Triggered By Type' ;
    rdfs:comment 'Indicates whether this lifecycle event was triggered by a human user action, an automated system process (e.g., auto-renewal scheduler), an external party (e.g., provider-initiated termination), or a regulatory mandate. Supports audit trail and accountability tracking.' ;
    rdfs:domain ind:ContractLifecycleEvent2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeredByUser rdf:type rdf:Property ;
    rdfs:label 'Triggered By User' ;
    rdfs:comment 'Username or system account identifier of the user or automated process that initiated this lifecycle event. Supports accountability, audit trail, and compliance examination readiness. Null when triggered_by_type is \'system\' or \'scheduler\' with no associated user.' ;
    rdfs:domain ind:ContractLifecycleEvent2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Unique identifier for the contract compliance audit record. Primary key.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when the audit was completed and findings were issued.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when the audit fieldwork or review commenced.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditorType rdf:type rdf:Property ;
    rdfs:label 'Auditor Type' ;
    rdfs:comment 'Classification of the auditor: internal (health plan staff), external (contracted audit firm), regulatory (CMS or state DOI), or third-party (independent reviewer).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRating rdf:type rdf:Property ;
    rdfs:label 'Compliance Rating' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Due Date' ;
    rdfs:comment 'Date by which the provider must submit a Corrective Action Plan addressing audit findings.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlanReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Received Date' ;
    rdfs:comment 'Date when the provider submitted the Corrective Action Plan.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Required' ;
    rdfs:comment 'Indicates whether a formal Corrective Action Plan is required from the provider based on audit findings.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
