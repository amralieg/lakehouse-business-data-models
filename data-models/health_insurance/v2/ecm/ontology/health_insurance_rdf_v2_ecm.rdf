    rdfs:comment 'Current lifecycle status of the model configuration.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalizationFactor rdf:type rdf:Property ;
    rdfs:label 'Normalization Factor' ;
    rdfs:comment 'Scalar applied to model outputs to align with enterprise scoring conventions.' ;
    rdfs:domain ind:Risk ;
