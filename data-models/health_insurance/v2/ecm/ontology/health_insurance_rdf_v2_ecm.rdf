    rdfs:comment 'True if the calculated MLR exceeds the regulatory threshold and a rebate is required.' ;
    rdfs:domain ind:MlrCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountableOwner rdf:type rdf:Property ;
    rdfs:label 'Accountable Owner' ;
    rdfs:comment 'Full name of the person or team accountable for the accreditation.' ;
