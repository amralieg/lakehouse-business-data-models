    rdfs:comment 'Category of the appeal based on procedural pathway.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ground rdf:type rdf:Property ;
