ind:relationshipOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Relationship Owner Employee Id' ;
    rdfs:comment 'add column relationship_owner_employee_id (BIGINT) with FK to workforce.employee.employee_id - vendor relationships have an internal owner' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relationshipCode rdf:type rdf:Property ;
    rdfs:label 'Relationship Code' ;
    rdfs:comment 'External business identifier or code used to reference the vendor relationship in contracts and reports.' ;
    rdfs:domain ind:Relationship ;
    rdf:type owl:DatatypeProperty ;
