    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitationType rdf:type rdf:Property ;
    rdfs:label 'Solicitation Type' ;
    rdfs:comment 'Indicates whether the solicitation is a Request for Proposal, Request for Information, or Request for Quote.' ;
    rdfs:domain ind:Rfp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpResponseId rdf:type rdf:Property ;
    rdfs:label 'Rfp Response Id' ;
    rdfs:comment 'System-generated unique identifier for the RFP response record.' ;
