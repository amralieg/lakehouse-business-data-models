    rdfs:domain ind:RfpResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfpResponse .

ind:commercialScore rdf:type rdf:Property ;
    rdfs:label 'Commercial Score' ;
    rdfs:comment 'Numeric score (0-100) reflecting the commercial/price competitiveness of the proposal.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationComments rdf:type rdf:Property ;
    rdfs:label 'Evaluation Comments' ;
    rdfs:comment 'Detailed comments from the evaluator explaining the scores and decision rationale.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Final monetary amount after discounts and taxes (total_price - discount_amount + tax_amount).' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Proposal Reference Number' ;
    rdfs:comment 'External reference number assigned to the vendor\'s proposal for tracking and audit.' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseType rdf:type rdf:Property ;
    rdfs:label 'Response Type' ;
    rdfs:comment 'Type of solicitation the response addresses: Request for Proposal (RFP), Request for Information (RFI), or Request for Quote (RFQ).' ;
    rdfs:domain ind:RfpResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortListFlag rdf:type rdf:Property ;
    rdfs:label 'Short List Flag' ;
    rdfs:comment 'Indicates whether the response was placed on the short-list for further consideration.' ;
    rdfs:domain ind:RfpResponse ;
