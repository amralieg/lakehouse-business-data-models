ind:isMedicaidEligible rdf:type rdf:Property ;
    rdfs:label 'Is Medicaid Eligible' ;
    rdfs:comment 'Indicates if the service area is eligible for Medicaid plans.' ;
    rdfs:domain ind:PlanServiceArea ;
