    rdfs:comment 'Prior carrier loss experience' ;
    rdfs:domain ind:UnderwritingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteExpirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Quote Expiration Timestamp' ;
    rdfs:comment 'Quote expiration timestamp' ;
    rdfs:domain ind:UnderwritingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quoteGeneratedTimestamp rdf:type rdf:Property ;
