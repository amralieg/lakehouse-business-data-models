ind:parIndicator rdf:type rdf:Property ;
    rdfs:label 'Par Indicator' ;
    rdfs:comment 'Participating indicator.' ;
    rdfs:domain ind:ProviderNetworkParticipation2 ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:participationRole rdf:type rdf:Property ;
    rdfs:label 'Participation Role' ;
    rdfs:comment 'Role within the network (PCP, specialist, ancillary).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

