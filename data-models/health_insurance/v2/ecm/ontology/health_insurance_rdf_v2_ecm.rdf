    rdfs:range xsd:integer .

ind:parentSpendCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Spend Category Id' ;
    rdfs:comment 'Self-referencing FK on spend_category (parent_spend_category_id)' ;
    rdfs:domain ind:SpendCategory ;
