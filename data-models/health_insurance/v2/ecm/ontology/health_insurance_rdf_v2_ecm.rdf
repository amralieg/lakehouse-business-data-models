ind:financialStabilityScore rdf:type rdf:Property ;
    rdfs:label 'Financial Stability Score' ;
    rdfs:comment 'Numeric score (0-100) reflecting the vendor\'s financial health.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inherentRiskRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Rating' ;
    rdfs:comment 'Rating of the vendor\'s risk before controls are applied.' ;
