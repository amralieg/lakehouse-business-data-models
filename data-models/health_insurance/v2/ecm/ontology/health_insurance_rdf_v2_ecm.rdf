    rdfs:range xsd:boolean .

ind:controlEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Control Effectiveness Rating' ;
    rdfs:comment 'Rating of the effectiveness of existing controls mitigating the inherent risk.' ;
