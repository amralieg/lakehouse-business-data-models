    rdfs:range xsd:boolean .

ind:isRegulatoryCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Compliant' ;
    rdfs:comment 'Indicates whether the service area meets all regulatory requirements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStateFunded rdf:type rdf:Property ;
    rdfs:label 'Is State Funded' ;
