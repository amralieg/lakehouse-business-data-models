    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Market Segment Code' ;
    rdfs:comment 'Code representing the market segment (e.g., individual, group, Medicare) to which the calculation applies.' ;
    rdfs:domain ind:MlrCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlrCalculationStatus rdf:type rdf:Property ;
    rdfs:label 'Mlr Calculation Status' ;
    rdfs:comment 'Current processing status of the MLR calculation.' ;
    rdfs:domain ind:MlrCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityImprovementExpensesAmount rdf:type rdf:Property ;
    rdfs:label 'Quality Improvement Expenses Amount' ;
    rdfs:comment 'Dollar amount spent on quality improvement activities that count toward the MLR denominator.' ;
    rdfs:domain ind:MlrCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateDisbursementDate rdf:type rdf:Property ;
    rdfs:label 'Rebate Disbursement Date' ;
    rdfs:comment 'Date on which the rebate payment was or will be disbursed.' ;
    rdfs:domain ind:MlrCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rebateDisbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Rebate Disbursement Status' ;
    rdfs:comment 'Current status of the rebate payment process.' ;
    rdfs:domain ind:MlrCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateEligibilityFlag rdf:type rdf:Property ;
