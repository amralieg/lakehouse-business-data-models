ind:quoteStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Status' ;
    rdfs:comment 'Quote status' ;
    rdfs:domain ind:UnderwritingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPremiumEstimate rdf:type rdf:Property ;
    rdfs:label 'Total Premium Estimate' ;
    rdfs:comment 'Total premium estimate' ;
    rdfs:domain ind:UnderwritingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwritingDecision rdf:type rdf:Property ;
    rdfs:label 'Underwriting Decision' ;
    rdfs:comment 'Underwriting decision' ;
    rdfs:domain ind:UnderwritingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwritingStatus rdf:type rdf:Property ;
    rdfs:label 'Underwriting Status' ;
    rdfs:comment 'Underwriting status' ;
    rdfs:domain ind:UnderwritingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerContractId rdf:type rdf:Property ;
    rdfs:label 'Employer Contract Id' ;
    rdfs:comment 'Primary key for employer_contract' ;
    rdfs:domain ind:EmployerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partyId rdf:type rdf:Property ;
    rdfs:label 'Party Id' ;
    rdfs:comment 'Unique surrogate identifier for each party record in the provider contract domain. Serves as the primary key for all contractual party references across the health plan enterprise.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:acoIndicator rdf:type rdf:Property ;
    rdfs:label 'Aco Indicator' ;
    rdfs:comment 'Indicates whether this party is an Accountable Care Organization (ACO) participating in a value-based care (VBC) arrangement. Triggers ACO-specific contract terms, shared savings calculations, and CMS reporting requirements.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitationEligibleIndicator rdf:type rdf:Property ;
    rdfs:label 'Capitation Eligible Indicator' ;
    rdfs:comment 'Indicates whether this party is eligible to receive capitation payments (Per Member Per Month - PMPM) under the contract. Drives capitation payment processing and actuarial PMPM rate application.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractPartyNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Party Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to this party within the contract management system (e.g., Cactus or ProviderSource provider contract number). Used for cross-system reconciliation, EDI transactions, and provider directory publication.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:malpracticeCoverageIndicator rdf:type rdf:Property ;
    rdfs:label 'Malpractice Coverage Indicator' ;
    rdfs:comment 'Indicates whether the party maintains active professional liability (malpractice) insurance coverage as required by the contract. Failure to maintain coverage may trigger contract suspension or termination per NCQA credentialing standards.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:malpracticeExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Malpractice Expiration Date' ;
    rdfs:comment 'Date on which the party\'s professional liability (malpractice) insurance policy expires. Triggers credentialing re-verification and contract compliance monitoring workflows.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npiType rdf:type rdf:Property ;
    rdfs:label 'Npi Type' ;
    rdfs:comment 'Indicates whether the NPI is Type 1 (individual/solo practitioner) or Type 2 (organizational entity such as group practice, hospital, or IPA). Determines credentialing requirements and contract structure.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oigExclusionIndicator rdf:type rdf:Property ;
    rdfs:label 'Oig Exclusion Indicator' ;
    rdfs:comment 'Indicates whether the party appears on the OIG List of Excluded Individuals/Entities (LEIE). Excluded parties are prohibited from participating in Medicare, Medicaid, and other federal healthcare programs. Checked monthly per CMS compliance requirements.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partyRole rdf:type rdf:Property ;
    rdfs:label 'Party Role' ;
    rdfs:comment 'Functional role of this party within the contract relationship. Identifies whether the party is the health plan (payer), a contracting provider, a delegated entity, an Independent Practice Association (IPA), an Accountable Care Organization (ACO), a hospital system, or a group practice. [ENUM-REF-CANDIDATE: payer|provider|delegated_entity|ipa|aco|hospital_system|group_practice — promote to reference product]' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyStatus rdf:type rdf:Property ;
    rdfs:label 'Party Status' ;
    rdfs:comment 'Current lifecycle status of the party within the contract. Indicates whether the party is actively bound by the contract, pending execution, suspended, terminated, or inactive. Drives eligibility verification and claims adjudication routing.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyType rdf:type rdf:Property ;
    rdfs:label 'Party Type' ;
    rdfs:comment 'Classifies the party as an individual (natural person, e.g., solo practitioner with individual NPI) or an organization (legal entity, e.g., group practice, hospital, IPA, ACO). Drives NPI type assignment and credentialing workflow.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySpecialtyCode rdf:type rdf:Property ;
    rdfs:label 'Primary Specialty Code' ;
    rdfs:comment 'NUCC Health Care Provider Taxonomy Code representing the party\'s primary clinical specialty. Used for network adequacy analysis, claims routing, prior authorization rules, and provider directory classification.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rafApplicableIndicator rdf:type rdf:Property ;
    rdfs:label 'Raf Applicable Indicator' ;
    rdfs:comment 'Indicates whether Risk Adjustment Factor (RAF) scoring applies to this party\'s contract arrangement. Relevant for Medicare Advantage and ACA marketplace contracts where Hierarchical Condition Category (HCC) risk scores drive capitation payments.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleCode rdf:type rdf:Property ;
    rdfs:label 'Role Code' ;
    rdfs:comment 'Role of the party in the contract' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionIndicator rdf:type rdf:Property ;
    rdfs:label 'Sanction Indicator' ;
    rdfs:comment 'Indicates whether the party has an active sanction, exclusion, or adverse action recorded by OIG, SAM, or state licensing boards. A true value triggers contract suspension review and claims payment hold per CMS and HIPAA compliance requirements.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondarySpecialtyCode rdf:type rdf:Property ;
    rdfs:label 'Secondary Specialty Code' ;
    rdfs:comment 'NUCC Health Care Provider Taxonomy Code representing the party\'s secondary clinical specialty, if applicable. Supports multi-specialty provider contracting and network adequacy reporting.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaState rdf:type rdf:Property ;
    rdfs:label 'Service Area State' ;
    rdfs:comment 'Two-letter USPS state abbreviation representing the primary state in which this party provides services under the contract. Used for network adequacy reporting, state regulatory compliance, and geographic claims routing.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaZipCode rdf:type rdf:Property ;
    rdfs:label 'Service Area Zip Code' ;
    rdfs:comment 'Primary ZIP code of the party\'s principal service location. Used for network adequacy geo-mapping, member-to-provider distance calculations, and CMS network adequacy submissions.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Signatory Title' ;
    rdfs:comment 'Official title or position of the authorized signatory (e.g., Chief Executive Officer, Medical Director, Contracting Officer). Validates the authority level of the individual executing the contract on behalf of the party.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPartyReference rdf:type rdf:Property ;
    rdfs:label 'Source System Party Reference' ;
    rdfs:comment 'The native identifier of this party record in the originating operational system (e.g., Cactus provider ID, ProviderSource contract party key). Enables cross-system reconciliation and traceability from the Silver Layer back to the system of record.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax identification number' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vbcArrangementType rdf:type rdf:Property ;
    rdfs:label 'Vbc Arrangement Type' ;
    rdfs:comment 'Specifies the payment methodology or value-based care arrangement type applicable to this party under the contract. Drives reimbursement calculation logic, risk-sharing model application, and financial reporting. [ENUM-REF-CANDIDATE: fee_for_service|capitation|bundled_payment|shared_savings|global_risk — promote to reference product]' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termId rdf:type rdf:Property ;
    rdfs:label 'Term Id' ;
    rdfs:comment 'Unique surrogate identifier for a contract term record in the provider contract management system (Facets/QNXT or Provider Management System). Serves as the primary key for the term entity.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditRightsPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Period Years' ;
    rdfs:comment 'The number of years the health plan retains the right to audit provider records under this audit rights term. Typically 7 years per HIPAA and CMS requirements. Applicable when term_type is \'audit_rights\'.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenew rdf:type rdf:Property ;
    rdfs:label 'Auto Renew' ;
    rdfs:comment 'Indicates whether this term automatically renews upon expiration without requiring renegotiation (True). Supports contract lifecycle management and renewal notification workflows.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitationRate rdf:type rdf:Property ;
    rdfs:label 'Capitation Rate' ;
    rdfs:comment 'The Per Member Per Month (PMPM) capitation rate defined by this term when payment_methodology is capitation. Represents the fixed monthly payment per enrolled member to the provider regardless of services rendered. Classified confidential as proprietary pricing.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCheckpointDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Checkpoint Date' ;
    rdfs:comment 'The scheduled date for the next compliance review or audit checkpoint associated with this term. Used by the compliance team to track regulatory obligations, CMS audit readiness, and DOI examination preparation.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cptRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Cpt Range End' ;
    rdfs:comment 'The ending CPT or HCPCS procedure code of the range to which this reimbursement rule term applies. Used in conjunction with cpt_range_start to define the applicable procedure code range for adjudication.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cptRangeStart rdf:type rdf:Property ;
    rdfs:label 'Cpt Range Start' ;
    rdfs:comment 'The starting CPT or HCPCS procedure code of the range to which this reimbursement rule term applies. Used in conjunction with cpt_range_end to define the applicable procedure code range for adjudication.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'The contractually agreed method for resolving disputes arising under this term: Arbitration, Mediation, Litigation, or Internal Review. Applicable for hold-harmless, indemnification, and audit rights terms.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drgGrouperVersion rdf:type rdf:Property ;
    rdfs:label 'Drg Grouper Version' ;
    rdfs:comment 'The DRG grouper version (e.g., \'MS-DRG v41.0\', \'APR-DRG v39\') applicable to this term when payment_methodology is \'drg_based\'. Ensures adjudication uses the correct DRG weight tables for inpatient reimbursement.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingState rdf:type rdf:Property ;
    rdfs:label 'Governing State' ;
    rdfs:comment 'The two-letter US state code whose laws govern this contract term. Determines applicable state DOI regulations, insurance code requirements, and state-specific provider contract mandates.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaBaaRequired rdf:type rdf:Property ;
    rdfs:label 'Hipaa Baa Required' ;
    rdfs:comment 'Indicates whether this term constitutes or requires a HIPAA Business Associate Agreement (BAA) (True). Triggers compliance tracking and ensures Protected Health Information (PHI) handling obligations are documented per HIPAA 45 CFR Part 164.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAdjudicationRule rdf:type rdf:Property ;
    rdfs:label 'Is Adjudication Rule' ;
    rdfs:comment 'Indicates whether this term directly drives claims adjudication logic in Facets/QNXT (True). When True, the term\'s reimbursement_policy_subtype, cpt_range_start/end, and reduction_percentage are loaded into the adjudication engine.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNegotiable rdf:type rdf:Property ;
    rdfs:label 'Is Negotiable' ;
    rdfs:comment 'Indicates whether this contract term is open to negotiation (True) or is standard non-negotiable boilerplate language (False). Supports contract negotiation workflow and template management.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStandardBoilerplate rdf:type rdf:Property ;
    rdfs:label 'Is Standard Boilerplate' ;
    rdfs:comment 'Indicates whether this term is sourced from the organization\'s standard contract template library (True) or is a custom-negotiated term specific to this contract (False). Supports template governance and deviation tracking.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:macPricingBasis rdf:type rdf:Property ;
    rdfs:label 'Mac Pricing Basis' ;
    rdfs:comment 'The drug pricing benchmark used for pharmacy reimbursement terms: Average Wholesale Price (AWP), Wholesale Acquisition Cost (WAC), Maximum Allowable Cost (MAC), National Average Drug Acquisition Cost (NADAC), or a custom contracted rate. Applicable for terms covering pharmacy benefits.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodology rdf:type rdf:Property ;
    rdfs:label 'Payment Methodology' ;
    rdfs:comment 'The reimbursement payment methodology defined by this term when term_type is \'payment_methodology\' or \'reimbursement_rule\'. Drives adjudication logic in Facets/QNXT. Includes Fee-for-Service (FFS), Capitation, Bundled Payment, Case Rate, Per Diem, Diagnosis Related Group (DRG)-based, Reference Based Pricing (RBP), and Value-Based Care (VBC). [ENUM-REF-CANDIDATE: fee_for_service|capitation|bundled_payment|case_rate|per_diem|drg_based|rbp|vbc — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posCode rdf:type rdf:Property ;
    rdfs:label 'Pos Code' ;
    rdfs:comment 'The CMS Place of Service (POS) code to which this term\'s reimbursement differential applies, when reimbursement_policy_subtype is \'pos_differential\'. Two-digit code per CMS POS code set (e.g., \'11\' for Office, \'21\' for Inpatient Hospital).' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityMetricThreshold rdf:type rdf:Property ;
    rdfs:label 'Quality Metric Threshold' ;
    rdfs:comment 'The minimum quality performance threshold (expressed as a percentage or score) that the provider must achieve to qualify for incentive payments or avoid penalties under quality incentive terms. Linked to HEDIS or STAR measures.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Reduction Percentage' ;
    rdfs:comment 'The percentage reduction applied to the allowed amount under this reimbursement rule term (e.g., 50.00 for a 50% reduction on secondary procedures under multiple procedure reduction policy). Applicable when reimbursement_policy_subtype is set. Classified confidential as it represents proprietary pricing.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementPolicySubtype rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Policy Subtype' ;
    rdfs:comment 'Granular sub-classification of the reimbursement rule when term_type is \'reimbursement_rule\'. Specifies the specific adjudication policy: Multiple Procedure Reduction, Bilateral Procedure, Assistant Surgeon, Global Surgery, Unbundling Rules, Place-of-Service (POS) Differential, or Modifier Impact. Directly maps to adjudication logic in Facets/QNXT. [ENUM-REF-CANDIDATE: multiple_procedure_reduction|bilateral_procedure|assistant_surgeon|global_surgery|unbundling|pos_differential|modifier_impact — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSharingModel rdf:type rdf:Property ;
    rdfs:label 'Risk Sharing Model' ;
    rdfs:comment 'Defines the risk-sharing arrangement under Value-Based Care (VBC) or Accountable Care Organization (ACO) contract terms. Specifies whether the provider participates in shared savings only (upside), shared risk (two-sided), or full risk (global capitation).' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemTermRef rdf:type rdf:Property ;
    rdfs:label 'Source System Term Ref' ;
    rdfs:comment 'The native identifier of this term record in the originating operational system (e.g., Cactus contract clause ID, QNXT reimbursement rule ID, or ProviderSource term reference). Supports data lineage and reconciliation with source systems.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Plain-language operational summary of the term\'s intent and impact, authored by the contracting team. Used for training, audits, and quick reference without reading full legal text.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termNumber rdf:type rdf:Property ;
    rdfs:label 'Term Number' ;
    rdfs:comment 'Human-readable external identifier for the term, typically formatted as a section or clause reference (e.g., \'TERM-2024-0042\' or \'Section 4.2.1\'). Used in contract documents and correspondence.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termStatus rdf:type rdf:Property ;
    rdfs:label 'Term Status' ;
    rdfs:comment 'Current lifecycle state of the contract term. \'active\' indicates the term is currently in force; \'superseded\' indicates it has been replaced by an amendment; \'expired\' indicates the effective period has lapsed.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termType rdf:type rdf:Property ;
    rdfs:label 'Term Type' ;
    rdfs:comment 'Categorical classification of the contract term defining its legal or operational purpose. Drives downstream adjudication logic and compliance tracking. [ENUM-REF-CANDIDATE: reimbursement_rule|payment_methodology|exclusivity|termination_clause|audit_rights|hold_harmless|indemnification|confidentiality|hipaa_baa|quality_incentive — promote to reference product]' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationCauseType rdf:type rdf:Property ;
    rdfs:label 'Termination Cause Type' ;
    rdfs:comment 'Specifies the basis under which termination is permitted by this term: For Cause (material breach, fraud, license revocation), Without Cause (convenience), Mutual Agreement, or Regulatory (required by law or CMS/DOI directive).' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:text rdf:type rdf:Property ;
    rdfs:label 'Text' ;
    rdfs:comment 'Full verbatim legal text of the contract term as negotiated and executed. Contains the binding contractual language. Classified confidential as it represents proprietary reimbursement and legal obligations.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Withhold Percentage' ;
    rdfs:comment 'The percentage of reimbursement withheld from provider payments pending quality performance or risk settlement under VBC or capitation arrangements. Classified confidential as proprietary financial terms.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Contract Amendment Id' ;
    rdfs:comment 'Unique system-generated identifier for each provider contract amendment record. Primary key for the amendment entity.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded Amendment Id' ;
    rdfs:comment 'Reference to a prior amendment record that this amendment replaces or supersedes. Enables traversal of the full amendment history chain for a given contract. Null if this is the first amendment or does not supersede a prior amendment.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAmendment .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'The date on which the amendment received final internal approval from all required approvers. Distinct from execution date which reflects provider countersignature.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capitationRatePmpm rdf:type rdf:Property ;
    rdfs:label 'Capitation Rate Pmpm' ;
    rdfs:comment 'The Per Member Per Month (PMPM) capitation rate established or modified by this amendment for capitation-based payment arrangements. Applicable when payment_methodology is capitation. Confidential commercial negotiation data.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimsReprocessRequired rdf:type rdf:Property ;
    rdfs:label 'Claims Reprocess Required' ;
    rdfs:comment 'Indicates whether claims adjudicated under prior contract terms must be reprocessed following execution of this amendment. Triggers downstream claims reprocessing workflows in Facets/QNXT.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formularyImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Formulary Impact Flag' ;
    rdfs:comment 'Indicates whether this amendment affects pharmacy formulary terms, drug reimbursement rates, or Pharmacy Benefit Management (PBM) arrangements. Triggers updates to the PBM system (RxClaim/Argus).' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatingParty rdf:type rdf:Property ;
    rdfs:label 'Initiating Party' ;
    rdfs:comment 'Identifies which party initiated the amendment request — the health plan, the provider, a regulatory mandate, or a mutual agreement. Used for negotiation analytics and contract management reporting.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationNotes rdf:type rdf:Property ;
    rdfs:label 'Negotiation Notes' ;
    rdfs:comment 'Free-text narrative capturing key negotiation points, concessions, and outcomes during the amendment negotiation process. Confidential commercial information used for internal reference and future renegotiation strategy.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationOutcome rdf:type rdf:Property ;
    rdfs:label 'Negotiation Outcome' ;
    rdfs:comment 'The result of the contract negotiation process leading to this amendment. Indicates whether terms were mutually agreed, required counter-proposals, or were resolved through arbitration or mediation. Confidential commercial negotiation data.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Plan Signatory Name' ;
    rdfs:comment 'Name of the authorized representative of the health plan who executed the amendment on behalf of the health plan. Required for legal enforceability of the amendment.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Auth Impact Flag' ;
    rdfs:comment 'Indicates whether this amendment modifies Prior Authorization (PA) requirements for services rendered by the provider. Triggers updates to Utilization Management (UM) system configurations in InterQual/MCG.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Provider Signatory Name' ;
    rdfs:comment 'Name of the authorized representative of the provider organization who executed the amendment on behalf of the provider. Required for legal enforceability of the amendment.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateChangePct rdf:type rdf:Property ;
    rdfs:label 'Rate Change Pct' ;
    rdfs:comment 'The percentage increase or decrease in reimbursement rates resulting from this amendment. Expressed as a signed decimal (positive for increases, negative for decreases). Applicable when amendment_type is rate_change. Confidential commercial negotiation data.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Rate Effective Date' ;
    rdfs:comment 'The specific date on which revised reimbursement rates established by this amendment take effect in the claims adjudication system. May differ from the overall amendment effective date for phased implementations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retroactiveFlag rdf:type rdf:Property ;
    rdfs:label 'Retroactive Flag' ;
    rdfs:comment 'Indicates whether the amendment has a retroactive effective date that precedes the execution date. Retroactive amendments require claims reprocessing and financial reconciliation activities.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retroactiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Retroactive Start Date' ;
    rdfs:comment 'The earliest date from which retroactive amendment terms apply, when retroactive_flag is true. Defines the claims reprocessing window for financial reconciliation.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskSharePct rdf:type rdf:Property ;
    rdfs:label 'Risk Share Pct' ;
    rdfs:comment 'The percentage of financial risk shared between the health plan and the provider under risk-sharing or Value-Based Care (VBC) arrangements established by this amendment. Confidential commercial negotiation data.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sectionsModified rdf:type rdf:Property ;
    rdfs:label 'Sections Modified' ;
    rdfs:comment 'Comma-delimited list or narrative description of the specific contract sections, exhibits, or schedules modified by this amendment (e.g., \'Exhibit A - Fee Schedule, Section 4.2 - Term\'). Supports targeted audit and compliance review.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'The date on which the amendment was formally submitted for internal review and approval. Marks the start of the amendment approval workflow.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vbcTargetMetric rdf:type rdf:Property ;
    rdfs:label 'Vbc Target Metric' ;
    rdfs:comment 'The primary quality or cost performance metric targeted under a Value-Based Care (VBC) or Accountable Care Organization (ACO) arrangement established by this amendment (e.g., HEDIS measure, readmission rate, cost per episode). Applicable when payment_methodology is vbc.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Fee Schedule Id' ;
    rdfs:comment 'Reference to the fee_schedule_id of the newer fee schedule that replaced this one when schedule_status is \'superseded\'. Enables fee schedule version chain navigation and historical rate lookups.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeeSchedule .

ind:anesthesiaApplicable rdf:type rdf:Property ;
    rdfs:label 'Anesthesia Applicable' ;
    rdfs:comment 'Indicates whether this fee schedule includes anesthesia service reimbursement, which uses base units plus time units multiplied by a conversion factor rather than standard CPT-based rates.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:anesthesiaConversionFactor rdf:type rdf:Property ;
    rdfs:label 'Anesthesia Conversion Factor' ;
    rdfs:comment 'Dollar amount per anesthesia unit (base units + time units) used to calculate anesthesia reimbursement when anesthesia_applicable is True. Negotiated rate specific to this fee schedule.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmsFeeScheduleYear rdf:type rdf:Property ;
    rdfs:label 'Cms Fee Schedule Year' ;
    rdfs:comment 'The CMS Medicare fee schedule calendar year used as the basis or benchmark for this fee schedule when fee_schedule_source is \'cms_medicare\'. Enables tracking of which CMS annual update cycle the rates are derived from.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionFactor rdf:type rdf:Property ;
    rdfs:label 'Conversion Factor' ;
    rdfs:comment 'Dollar amount multiplied by the total Relative Value Units (RVUs) to calculate the reimbursement amount for RVU-based fee schedules. Applicable when payment_basis is \'rvu_based\'. Sourced from CMS RBRVS conversion factor or negotiated contract rate.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coordinationOfBenefitsApplicable rdf:type rdf:Property ;
    rdfs:label 'Coordination Of Benefits Applicable' ;
    rdfs:comment 'Indicates whether Coordination of Benefits (COB) rules apply to claims adjudicated under this fee schedule. When True, COB logic determines primary vs. secondary payer responsibilities.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cptCodeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Cpt Code Range End' ;
    rdfs:comment 'Ending CPT procedure code in the range of services covered by this fee schedule. Used in conjunction with cpt_code_range_start to define the scope of applicable procedure codes.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cptCodeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Cpt Code Range Start' ;
    rdfs:comment 'Starting CPT procedure code in the range of services covered by this fee schedule. Used in conjunction with cpt_code_range_end to define the scope of applicable procedure codes. Null if the fee schedule applies to all CPT codes or uses ICD/DRG-based scoping.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeScheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Description' ;
    rdfs:comment 'Free-text narrative description of the fee schedule, including its purpose, scope, special provisions, or notes relevant to adjudication staff and contract analysts.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drgApplicable rdf:type rdf:Property ;
    rdfs:label 'Drg Applicable' ;
    rdfs:comment 'Indicates whether this fee schedule uses Diagnosis Related Group (DRG)-based reimbursement for inpatient facility claims. When True, DRG weights and base rates govern payment rather than individual procedure codes.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drgBaseRate rdf:type rdf:Property ;
    rdfs:label 'Drg Base Rate' ;
    rdfs:comment 'The negotiated base dollar rate per DRG weight unit used for inpatient facility reimbursement when drg_applicable is True. Multiplied by the DRG relative weight to calculate the total inpatient payment.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeProviderContractId rdf:type rdf:Property ;
    rdfs:label 'Fee Provider Contract Id' ;
    rdfs:comment 'FK to contract.provider_contract.provider_contract_id — Fee schedules must resolve to their governing provider contract for rate lookup during claim adjudication and contract compliance auditing.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicModifierApplicable rdf:type rdf:Property ;
    rdfs:label 'Geographic Modifier Applicable' ;
    rdfs:comment 'Indicates whether geographic adjustment factors (e.g., CMS Geographic Practice Cost Indices - GPCI) are applied to rates under this fee schedule. True when locality-based adjustments are in effect; False for flat national rates.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:globalSurgeryApplicable rdf:type rdf:Property ;
    rdfs:label 'Global Surgery Applicable' ;
    rdfs:comment 'Indicates whether global surgery payment rules apply under this fee schedule, bundling pre-operative, intra-operative, and post-operative services into a single reimbursement amount.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localityCode rdf:type rdf:Property ;
    rdfs:label 'Locality Code' ;
    rdfs:comment 'CMS Medicare locality code identifying the geographic pricing area applicable to this fee schedule when geographic_modifier_applicable is True. Used to apply GPCI adjustments to RVU-based rates.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicareCrossoverApplicable rdf:type rdf:Property ;
    rdfs:label 'Medicare Crossover Applicable' ;
    rdfs:comment 'Indicates whether this fee schedule applies to Medicare crossover claims where Medicare is the primary payer and the health plan is the secondary payer. Relevant for Medicare Advantage and Medigap plans.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifierApplicable rdf:type rdf:Property ;
    rdfs:label 'Modifier Applicable' ;
    rdfs:comment 'Indicates whether CPT or HCPCS modifiers affect reimbursement rates under this fee schedule (e.g., modifier 26 for professional component, modifier TC for technical component, modifier 50 for bilateral procedures).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outlierThresholdAmt rdf:type rdf:Property ;
    rdfs:label 'Outlier Threshold Amt' ;
    rdfs:comment 'Dollar threshold above which a claim qualifies as a cost outlier, triggering additional reimbursement beyond the standard DRG or bundled payment. Applicable for institutional fee schedules with outlier payment provisions.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBasis rdf:type rdf:Property ;
    rdfs:label 'Payment Basis' ;
    rdfs:comment 'The methodology used to calculate reimbursement amounts under this fee schedule. Options include: pct_medicare (percentage of Medicare allowable), pct_billed_charges (percentage of provider billed charges), flat_rate (fixed dollar amount per service), rvu_based (Relative Value Unit-based), bundled (bundled payment for episode of care), capitation (per-member per-month), rbp (Reference Based Pricing). [ENUM-REF-CANDIDATE: pct_medicare|pct_billed_charges|flat_rate|rvu_based|bundled|capitation|rbp — promote to reference product]' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBasisPct rdf:type rdf:Property ;
    rdfs:label 'Payment Basis Pct' ;
    rdfs:comment 'The percentage rate applied when payment_basis is \'pct_medicare\' or \'pct_billed_charges\' (e.g., 110.0000 for 110% of Medicare). Null when payment_basis is flat_rate, rvu_based, bundled, or capitation. Stored as a decimal percentage value.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle state of the fee schedule. \'draft\' indicates under review; \'active\' indicates currently in use for adjudication; \'suspended\' indicates temporarily inactive; \'terminated\' indicates permanently closed; \'superseded\' indicates replaced by a newer version.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Categorizes the fee schedule by the type of services covered: professional (physician/practitioner), institutional (hospital/facility), ancillary (therapy/home health), DME (Durable Medical Equipment), lab (laboratory), or pharmacy. Drives claim adjudication logic in Facets/QNXT.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopLossApplicable rdf:type rdf:Property ;
    rdfs:label 'Stop Loss Applicable' ;
    rdfs:comment 'Indicates whether a stop-loss provision applies to this fee schedule, capping the health plan\'s reimbursement liability per claim or per member. Relevant for risk-sharing and capitation arrangements.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stopLossThresholdAmt rdf:type rdf:Property ;
    rdfs:label 'Stop Loss Threshold Amt' ;
    rdfs:comment 'Dollar amount per claim or per member above which the stop-loss provision activates, limiting the health plan\'s reimbursement exposure. Applicable when stop_loss_applicable is True.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeScheduleRateId rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Rate Id' ;
    rdfs:comment 'Unique surrogate identifier for each fee schedule rate line record in the contract domain. Primary key for this entity.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorRateFeeScheduleRateId rdf:type rdf:Property ;
    rdfs:label 'Prior Rate Fee Schedule Rate Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the previous version of this rate record that was superseded by the current record. Enables full rate history chain traversal for audit and compliance purposes.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeeScheduleRate .

ind:awpPercent rdf:type rdf:Property ;
    rdfs:label 'Awp Percent' ;
    rdfs:comment 'When rate_derivation_method is AWP_PCT, this field stores the percentage of the Average Wholesale Price (AWP) used to derive the drug or supply reimbursement rate. For example, 0.8500 represents AWP minus 15%. Commonly used in pharmacy and DME fee schedules.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bilateralIndicator rdf:type rdf:Property ;
    rdfs:label 'Bilateral Indicator' ;
    rdfs:comment 'Indicates whether this rate applies to a bilateral procedure (performed on both sides of the body). When true, the allowed amount may be adjusted per CMS bilateral surgery payment rules (150% of the unilateral rate).' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bundledPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Bundled Payment Amount' ;
    rdfs:comment 'Single episode-of-care payment amount covering all services within a defined clinical episode (e.g., joint replacement, maternity). Applicable when payment_methodology is BUNDLED. Supports Value-Based Care (VBC) and ACO payment models.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region or market area to which this rate applies. Rates may vary by state, CMS locality, metropolitan statistical area (MSA), or health plan-defined region. Expressed as a state code, CMS locality code, or internal region identifier.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalSurgeryDays rdf:type rdf:Property ;
    rdfs:label 'Global Surgery Days' ;
    rdfs:comment 'Number of days in the global surgery period for surgical procedure codes. Defines the pre-operative and post-operative period during which related services are bundled into the surgical payment (0=endoscopic/minor, 10=minor, 90=major surgery).' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:macAmount rdf:type rdf:Property ;
    rdfs:label 'Mac Amount' ;
    rdfs:comment 'The Maximum Allowable Cost (MAC) dollar amount set as the ceiling for reimbursement of a specific drug or service. When rate_derivation_method is MAC, this value represents the maximum the plan will pay regardless of billed charges.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxUnitsPerDay rdf:type rdf:Property ;
    rdfs:label 'Max Units Per Day' ;
    rdfs:comment 'Maximum number of units of this procedure code that will be reimbursed per day per member. Used to enforce utilization limits during claims adjudication and prevent overbilling.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxUnitsPerYear rdf:type rdf:Property ;
    rdfs:label 'Max Units Per Year' ;
    rdfs:comment 'Maximum number of units of this procedure code that will be reimbursed per benefit year per member. Enforces annual utilization limits during adjudication for services with frequency restrictions.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicareFeeSchedulePct rdf:type rdf:Property ;
    rdfs:label 'Medicare Fee Schedule Pct' ;
    rdfs:comment 'When rate_derivation_method is MEDICARE_PCT, this field stores the percentage of the applicable Medicare fee schedule rate used to derive the allowed amount. For example, 1.1500 represents 115% of Medicare. Used for rate benchmarking and contract analytics.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ncciEditIndicator rdf:type rdf:Property ;
    rdfs:label 'Ncci Edit Indicator' ;
    rdfs:comment 'Indicates whether this procedure code is subject to National Correct Coding Initiative (NCCI) bundling edits during claims adjudication. When true, the adjudication system will apply NCCI column 1/column 2 and mutually exclusive code edits.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perDiemRate rdf:type rdf:Property ;
    rdfs:label 'Per Diem Rate' ;
    rdfs:comment 'Daily reimbursement rate paid to a facility provider for each day of an inpatient or residential stay. Applicable when payment_methodology is PER_DIEM. May vary by level of care (e.g., ICU vs. medical/surgical).' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procedureCodeType rdf:type rdf:Property ;
    rdfs:label 'Procedure Code Type' ;
    rdfs:comment 'Classifies the coding system used for the procedure_code field. Distinguishes between CPT (physician services), HCPCS Level II (supplies/DME), CDT (dental), ICD-10-PCS (inpatient procedures), Revenue Code (facility billing), DRG (diagnosis-related group), APC (ambulatory payment classification), or NDC (drug). [ENUM-REF-CANDIDATE: CPT|HCPCS_II|CDT|ICD_PCS|REVENUE|DRG|APC|NDC — promote to reference product]' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureModifier1 rdf:type rdf:Property ;
    rdfs:label 'Procedure Modifier 1' ;
    rdfs:comment 'First CPT or HCPCS modifier code appended to the procedure code to indicate special circumstances affecting the service (e.g., bilateral procedure, assistant surgeon, professional component). Modifiers can alter the allowed reimbursement amount.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureModifier2 rdf:type rdf:Property ;
    rdfs:label 'Procedure Modifier 2' ;
    rdfs:comment 'Second CPT or HCPCS modifier code when multiple modifiers apply to the same procedure code. Used in conjunction with procedure_modifier_1 for complex billing scenarios.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'The health plan product type to which this rate applies. HMO=Health Maintenance Organization, PPO=Preferred Provider Organization, EPO=Exclusive Provider Organization, POS=Point of Service, HDHP=High Deductible Health Plan, INDEMNITY=traditional indemnity plan. Rates may vary by product type.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateDerivationMethod rdf:type rdf:Property ;
    rdfs:label 'Rate Derivation Method' ;
    rdfs:comment 'Describes how the allowed amount was derived or calculated. MEDICARE_PCT=percentage of Medicare fee schedule, AWP_PCT=percentage of Average Wholesale Price, WAC_PCT=percentage of Wholesale Acquisition Cost, MAC=Maximum Allowable Cost, RBP=Reference Based Pricing benchmark, NEGOTIATED=directly negotiated flat rate, COST_PLUS=cost plus margin, BILLED_PCT=percent of billed charges. Critical for audit and rate validation. [ENUM-REF-CANDIDATE: MEDICARE_PCT|AWP_PCT|WAC_PCT|MAC|RBP|NEGOTIATED|COST_PLUS|BILLED_PCT — promote to reference product]' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLineNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Line Number' ;
    rdfs:comment 'Sequential line number identifying the position of this rate record within the parent fee schedule. Used for ordering and referencing individual rate lines.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateNote rdf:type rdf:Property ;
    rdfs:label 'Rate Note' ;
    rdfs:comment 'Free-text notes or comments providing additional context about this fee schedule rate, such as special billing instructions, exceptions, or conditions under which the rate applies. Used by contracting and claims operations staff.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePercentOfBilled rdf:type rdf:Property ;
    rdfs:label 'Rate Percent Of Billed' ;
    rdfs:comment 'Reimbursement rate expressed as a percentage of the provider\'s billed charges, used when the payment methodology is percent-of-billed rather than a fixed allowed amount. For example, 0.8500 represents 85% of billed charges.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateVersion rdf:type rdf:Property ;
    rdfs:label 'Rate Version' ;
    rdfs:comment 'Incrementing version number tracking amendments and updates to this fee schedule rate line. Version 1 is the original rate; subsequent amendments increment this counter. Supports rate history and audit trail requirements.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rbpReferenceAmount rdf:type rdf:Property ;
    rdfs:label 'Rbp Reference Amount' ;
    rdfs:comment 'The benchmark dollar amount used as the basis for Reference Based Pricing (RBP) reimbursement. Typically anchored to Medicare rates or a cost-based benchmark. The actual allowed amount is derived as a percentage of this reference amount.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitationArrangementId rdf:type rdf:Property ;
    rdfs:label 'Capitation Arrangement Id' ;
    rdfs:comment 'Unique surrogate identifier for the capitation arrangement record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitationArrangement .

ind:acoArrangementFlag rdf:type rdf:Property ;
    rdfs:label 'Aco Arrangement Flag' ;
    rdfs:comment 'Indicates whether this capitation arrangement is part of an Accountable Care Organization (ACO) or integrated delivery network model, which may have additional shared savings or risk-sharing components.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aggregateStopLossThreshold rdf:type rdf:Property ;
    rdfs:label 'Aggregate Stop Loss Threshold' ;
    rdfs:comment 'Total dollar amount for the attributed member population above which the health plan assumes financial responsibility for claims costs. Protects the provider from population-level adverse risk. Expressed in USD.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRateEscalator rdf:type rdf:Property ;
    rdfs:label 'Annual Rate Escalator' ;
    rdfs:comment 'Contractually agreed annual percentage increase applied to the PMPM rate at each rate renewal period (e.g., 3.50 for 3.5% annual escalation). Used for multi-year capitation arrangements.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee identifier of the contracting authority who approved this capitation arrangement. Supports audit trail and delegation-of-authority compliance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionMethod rdf:type rdf:Property ;
    rdfs:label 'Attribution Method' ;
    rdfs:comment 'Methodology used to attribute members to this capitation arrangement. PCP assignment uses enrollment data; claims-based uses plurality of visits; voluntary selection allows member choice; geographic assigns by service area.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carveOutServices rdf:type rdf:Property ;
    rdfs:label 'Carve Out Services' ;
    rdfs:comment 'Description of services explicitly excluded from the capitation scope and reimbursed separately (e.g., \'Mental Health, Substance Abuse, Transplants, Neonatal ICU\'). Carve-outs are paid fee-for-service or under separate capitation arrangements.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:individualStopLossThreshold rdf:type rdf:Property ;
    rdfs:label 'Individual Stop Loss Threshold' ;
    rdfs:comment 'Dollar amount per member per year above which the health plan assumes financial responsibility for claims costs, protecting the provider from catastrophic individual member costs. Expressed in USD.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pmpmRateCurrency rdf:type rdf:Property ;
    rdfs:label 'Pmpm Rate Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the PMPM rate (typically USD for domestic health plans). Required for multi-currency reporting and regulatory submissions.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityWithholdReleaseCriteria rdf:type rdf:Property ;
    rdfs:label 'Quality Withhold Release Criteria' ;
    rdfs:comment 'Description of the quality performance benchmarks or HEDIS/STAR measure thresholds that must be met for the provider to receive release of withheld capitation amounts. Defines the performance contract terms.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rafAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Raf Adjustment Factor' ;
    rdfs:comment 'Multiplier applied to the base PMPM rate to account for the relative health risk of the attributed member population. A RAF above 1.0 indicates a sicker-than-average population; below 1.0 indicates healthier-than-average.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Rate Expiration Date' ;
    rdfs:comment 'Date on which the current PMPM rate expires and is subject to renegotiation or automatic escalation. Null if the rate is open-ended for the arrangement term.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskAdjustmentApplicable rdf:type rdf:Property ;
    rdfs:label 'Risk Adjustment Applicable' ;
    rdfs:comment 'Indicates whether the PMPM rate is subject to risk adjustment based on the attributed member population\'s Hierarchical Condition Category (HCC) Risk Adjustment Factor (RAF) scores. Applicable primarily for Medicare Advantage and ACA Exchange arrangements.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskPoolParticipant rdf:type rdf:Property ;
    rdfs:label 'Risk Pool Participant' ;
    rdfs:comment 'Indicates whether the provider participates in a shared risk pool under this capitation arrangement. Risk pool participants share in surpluses or deficits relative to the capitation budget.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Risk Share Percentage' ;
    rdfs:comment 'Percentage of risk pool surplus or deficit allocated to the provider under this capitation arrangement. Expressed as a percentage (0.00–100.00). Applicable only when risk_pool_participant is True.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Service Category Scope' ;
    rdfs:comment 'Comma-delimited list or narrative description of the covered service categories included under this capitation arrangement (e.g., \'Primary Care, Preventive Services, Lab, Radiology\'). Defines the scope of services the provider is financially responsible for under capitation.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'Native record identifier from the operational source system (Facets, QNXT, or Provider Management System) for this capitation arrangement. Supports data lineage, reconciliation, and back-referencing to the system of record.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopLossType rdf:type rdf:Property ;
    rdfs:label 'Stop Loss Type' ;
    rdfs:comment 'Type of stop-loss protection included in the capitation arrangement. Individual stop-loss limits exposure per member; aggregate stop-loss limits total population exposure; both applies both thresholds.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitationPaymentId rdf:type rdf:Property ;
    rdfs:label 'Capitation Payment Id' ;
    rdfs:comment 'Unique surrogate identifier for each capitation payment disbursement record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Ensures each capitation payment is tied to the employee who authorized it, supporting payment audit and regulatory compliance.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:originalPaymentCapitationPaymentId rdf:type rdf:Property ;
    rdfs:label 'Original Payment Capitation Payment Id' ;
    rdfs:comment 'Reference to the original capitation payment record that this record adjusts, reverses, or supplements. Populated only when prior_period_adjustment_flag is True. Enables audit trail linking of adjustment chains.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitationPayment .

ind:apVoucherNumber rdf:type rdf:Property ;
    rdfs:label 'Ap Voucher Number' ;
    rdfs:comment 'Accounts Payable (AP) voucher or invoice number assigned in Oracle Financials when the capitation payment is posted as a payable. Links the capitation disbursement to the AP subledger for financial reporting and audit trail.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitationRateTier rdf:type rdf:Property ;
    rdfs:label 'Capitation Rate Tier' ;
    rdfs:comment 'Rate tier or member category applied to determine the PMPM rate for this payment (e.g., adult, pediatric, senior, ESRD, dual-eligible). Different member demographics may attract different PMPM rates under the same contract.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkEftTraceNumber rdf:type rdf:Property ;
    rdfs:label 'Check Eft Trace Number' ;
    rdfs:comment 'Check number or EFT/ACH trace number assigned by the financial institution for the actual disbursement of this capitation payment. Used for bank reconciliation in Oracle Financials (AP module) and provider payment dispute resolution.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Enrollment Adjustment Amount' ;
    rdfs:comment 'Dollar adjustment to the gross payment resulting from retroactive enrollment changes (late enrollments, disenrollments, or eligibility corrections) identified after the initial payment calculation. Can be positive (additional payment) or negative (recoupment).' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glCostCenter rdf:type rdf:Property ;
    rdfs:label 'Gl Cost Center' ;
    rdfs:comment 'General Ledger (GL) cost center code in Oracle Financials to which this capitation payment expense is allocated. Supports financial reporting by LOB, product, and organizational unit per GAAP and SAP statutory reporting requirements.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'Final net amount disbursed to the provider after all adjustments: gross_payment_amount + enrollment_adjustment_amount - risk_pool_withhold_amount + stop_loss_recovery_amount + other_adjustment_amount. This is the actual amount reflected in the 835 ERA remittance advice.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Other Adjustment Amount' ;
    rdfs:comment 'Catch-all adjustment amount for miscellaneous contractual adjustments not captured in enrollment, risk pool, or stop-loss categories. Includes quality bonus payments, performance incentive adjustments, or administrative fee offsets per contract terms.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Payment Approval Date' ;
    rdfs:comment 'Date on which the capitation payment was formally approved for disbursement by the authorized approver in the billing or finance system. Supports segregation of duties controls and audit trail requirements.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Payment Period End Date' ;
    rdfs:comment 'Last day of the coverage month or period for which this capitation payment is being made. Typically the last day of the calendar month in monthly capitation cycles.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Payment Period Start Date' ;
    rdfs:comment 'First day of the coverage month or period for which this capitation payment is being made. Typically the first day of the calendar month in monthly capitation cycles.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentRunNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Run Number' ;
    rdfs:comment 'Identifier of the capitation payment run or batch cycle that generated this payment record. Used to group all payments processed in the same cycle for reconciliation, audit, and reprocessing purposes in the Core Administration Platform (Facets/QNXT).' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Period Adjustment Flag' ;
    rdfs:comment 'Indicates whether this capitation payment includes or represents an adjustment to a prior payment period. True when the payment corrects or supplements a previously issued capitation payment due to retroactive enrollment changes or rate corrections.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityWithholdAmount rdf:type rdf:Property ;
    rdfs:label 'Quality Withhold Amount' ;
    rdfs:comment 'Amount withheld from the capitation payment pending achievement of quality performance targets (e.g., HEDIS measures, STAR ratings thresholds). Released or forfeited at the end of the performance measurement period based on provider quality scores.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskAdjustedPmpmRate rdf:type rdf:Property ;
    rdfs:label 'Risk Adjusted Pmpm Rate' ;
    rdfs:comment 'PMPM rate after application of the risk adjustment factor (RAF score) to the base contractual PMPM rate. Reflects the risk-adjusted capitation amount per member per month for Medicare Advantage or risk-adjusted commercial arrangements.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskPoolWithholdAmount rdf:type rdf:Property ;
    rdfs:label 'Risk Pool Withhold Amount' ;
    rdfs:comment 'Amount withheld from the gross capitation payment and placed into a shared risk pool per the contract terms. Risk pool withholds are held and distributed (or forfeited) at the end of the risk settlement period based on actual utilization versus targets.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemPaymentReference rdf:type rdf:Property ;
    rdfs:label 'Source System Payment Reference' ;
    rdfs:comment 'Native identifier of this capitation payment record in the originating operational system (Facets, QNXT, or HealthEdge). Used for cross-system reconciliation and data lineage tracing between the Silver Layer and the system of record.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopLossRecoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Stop Loss Recovery Amount' ;
    rdfs:comment 'Amount recovered from or credited to the provider under stop-loss provisions of the capitation contract. Positive values indicate plan reimbursement to provider for catastrophic cases exceeding the stop-loss threshold; negative values indicate provider liability adjustments.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vbcContractFlag rdf:type rdf:Property ;
    rdfs:label 'Vbc Contract Flag' ;
    rdfs:comment 'Indicates whether this capitation payment is made under a Value-Based Care (VBC) or Accountable Care Organization (ACO) contract arrangement, as opposed to a standard fee-for-service capitation. Drives VBC performance reporting and quality incentive calculations.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vbcContractId rdf:type rdf:Property ;
    rdfs:label 'Vbc Contract Id' ;
    rdfs:comment 'Unique surrogate identifier for the Value-Based Care (VBC) contract record in the Silver layer lakehouse. Primary key for all VBC contract master records including ACO agreements, shared savings, bundled payment, and risk-sharing arrangements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VbcContract .

ind:acoCmsIdentifier rdf:type rdf:Property ;
    rdfs:label 'Aco Cms Identifier' ;
    rdfs:comment 'CMS-assigned unique identifier for the ACO participating in the Medicare Shared Savings Program (MSSP) or other CMS Innovation Center models. Required for RAPS/EDPS submissions and CMS regulatory reporting.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acoEntityName rdf:type rdf:Property ;
    rdfs:label 'Aco Entity Name' ;
    rdfs:comment 'Legal name of the ACO, IPA, or provider organization that is the counterparty to this VBC contract. Used for regulatory reporting to CMS, network directory maintenance, and reconciliation settlement correspondence.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acoEntityTin rdf:type rdf:Property ;
    rdfs:label 'Aco Entity Tin' ;
    rdfs:comment 'Federal Tax Identification Number (TIN/EIN) of the ACO or IPA entity party to this contract. Required for CMS regulatory submissions, 1099 reporting, and settlement payment processing.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualExpenditure rdf:type rdf:Property ;
    rdfs:label 'Actual Expenditure' ;
    rdfs:comment 'Total actual claims expenditure (in USD) incurred by attributed members or episode participants during the performance period. Compared against the benchmark expenditure target to determine shared savings or shared loss amounts.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkExpenditureTarget rdf:type rdf:Property ;
    rdfs:label 'Benchmark Expenditure Target' ;
    rdfs:comment 'The risk-adjusted, trend-adjusted target expenditure amount (in USD) against which actual expenditures are compared during reconciliation. Calculated using historical claims data, risk scores (HCC/RAF), and applicable trend factors per the contract methodology.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmsProgramTrack rdf:type rdf:Property ;
    rdfs:label 'Cms Program Track' ;
    rdfs:comment 'Specific CMS Innovation Center program track or model under which this contract operates (e.g., \'MSSP_BASIC_A\', \'MSSP_BASIC_E\', \'MSSP_ENHANCED\', \'BPCI_A\', \'CJR\', \'PCF\'). Null for commercial VBC contracts not affiliated with a CMS program. [ENUM-REF-CANDIDATE: MSSP_BASIC_A|MSSP_BASIC_B|MSSP_BASIC_C|MSSP_BASIC_D|MSSP_BASIC_E|MSSP_ENHANCED|BPCI_A|CJR|PCF|DCE — promote to reference product]' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractAmendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Amendment Number' ;
    rdfs:comment 'Sequential identifier for the most recent amendment to this VBC contract (e.g., \'AMD-003\'). Tracks contract modifications including rate changes, term extensions, quality measure updates, and risk arrangement adjustments. Null for original, unamended contracts.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeTargetPrice rdf:type rdf:Property ;
    rdfs:label 'Episode Target Price' ;
    rdfs:comment 'The risk-adjusted target price (in USD) for a single bundled payment episode. Calculated from historical claims data with applicable discounts and trend adjustments. Actual episode expenditures are compared to this target for reconciliation. Null for non-bundled VBC models.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:episodeTriggerCode rdf:type rdf:Property ;
    rdfs:label 'Episode Trigger Code' ;
    rdfs:comment 'The CPT procedure code or DRG (Diagnosis Related Group) code that initiates a bundled payment episode. For example, DRG 470 triggers a major joint replacement episode under BPCI-A. Null for non-bundled VBC models.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeType rdf:type rdf:Property ;
    rdfs:label 'Episode Type' ;
    rdfs:comment 'For bundled payment contracts, the clinical episode category being bundled (e.g., \'joint_replacement\', \'cardiac_surgery\', \'maternity\', \'hip_fracture\', \'spinal_fusion\'). Null for non-bundled VBC models. Determines the trigger event, episode window, and target price methodology. [ENUM-REF-CANDIDATE: joint_replacement|cardiac_surgery|maternity|hip_fracture|spinal_fusion|pneumonia|copd|stroke — promote to reference product]' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeWindowDays rdf:type rdf:Property ;
    rdfs:label 'Episode Window Days' ;
    rdfs:comment 'Total number of days in the bundled payment episode window, measured from the trigger event (e.g., 90 days post-discharge for BPCI-A). Defines the period during which all included services are attributed to the bundle for reconciliation.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hedisMeasureTargets rdf:type rdf:Property ;
    rdfs:label 'Hedis Measure Targets' ;
    rdfs:comment 'Pipe-delimited list of HEDIS or CMS STAR measure identifiers and their contractual target thresholds included as quality gate requirements for this VBC contract (e.g., \'CBP:75.0|CDC-HbA1c:80.0|W34:85.0\'). Supports quality performance monitoring and NCQA reporting.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSharedLossRate rdf:type rdf:Property ;
    rdfs:label 'Max Shared Loss Rate' ;
    rdfs:comment 'The maximum percentage of benchmark expenditure (expressed as a decimal) that can be assessed as shared loss against the ACO/provider entity. Caps the provider\'s downside financial exposure in two-sided risk arrangements.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxSharedSavingsRate rdf:type rdf:Property ;
    rdfs:label 'Max Shared Savings Rate' ;
    rdfs:comment 'The maximum percentage of benchmark expenditure (expressed as a decimal) that can be distributed as shared savings to the ACO/provider entity, regardless of actual savings achieved. Caps the health plan\'s financial exposure on the upside.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performancePeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Performance Period End' ;
    rdfs:comment 'End date of the current performance measurement period. Marks the close of the measurement window after which actual expenditures are compared to the benchmark target for reconciliation and settlement.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performancePeriodStart rdf:type rdf:Property ;
    rdfs:label 'Performance Period Start' ;
    rdfs:comment 'Start date of the current performance measurement period for this VBC contract. Defines the window during which attributed member expenditures, quality scores, and utilization are measured against the benchmark.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityGateMet rdf:type rdf:Property ;
    rdfs:label 'Quality Gate Met' ;
    rdfs:comment 'Indicates whether the ACO/provider entity met the minimum quality performance threshold (quality gate) required to be eligible for shared savings distribution. True = quality gate satisfied; False = quality gate not met, shared savings withheld or reduced.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityGateThreshold rdf:type rdf:Property ;
    rdfs:label 'Quality Gate Threshold' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationMethodology rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Methodology' ;
    rdfs:comment 'Approach used to calculate and settle financial performance under this VBC contract. Prospective: target price set in advance; Retrospective: actual costs compared to historical benchmark after the period; Hybrid: combination of prospective target with retrospective quality adjustment.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskArrangementType rdf:type rdf:Property ;
    rdfs:label 'Risk Arrangement Type' ;
    rdfs:comment 'Specifies the financial risk-sharing structure between the health plan and the provider/ACO entity. Upside_only: provider shares in savings only; two_sided: provider shares in both savings and losses; full_risk: provider assumes full financial risk (global capitation); partial_risk: provider assumes a defined portion of risk.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCorridorLower rdf:type rdf:Property ;
    rdfs:label 'Risk Corridor Lower' ;
    rdfs:comment 'Lower bound of the risk corridor (expressed as a decimal percentage below benchmark) within which no financial settlement occurs. Protects both parties from small random expenditure variations. Equivalent to the Minimum Savings Rate in MSSP terminology.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskCorridorUpper rdf:type rdf:Property ;
    rdfs:label 'Risk Corridor Upper' ;
    rdfs:comment 'Upper bound of the risk corridor (expressed as a decimal percentage above benchmark) beyond which the health plan absorbs excess losses (stop-loss protection). Limits the provider\'s maximum financial exposure in two-sided risk arrangements.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:savingsSharingRate rdf:type rdf:Property ;
    rdfs:label 'Savings Sharing Rate' ;
    rdfs:comment 'The percentage (expressed as a decimal, e.g., 0.50 = 50%) of qualifying shared savings that is distributed to the ACO/provider entity. Negotiated contractually and may vary by quality score tier or performance band.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sharedLossPercentage rdf:type rdf:Property ;
    rdfs:label 'Shared Loss Percentage' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sharedSavingsAmount rdf:type rdf:Property ;
    rdfs:label 'Shared Savings Amount' ;
    rdfs:comment 'Net shared savings (positive) or shared loss (negative) amount in USD calculated after reconciliation. Represents the financial settlement due to or owed by the ACO/provider entity based on performance against the benchmark. Positive = savings distribution; negative = loss recoupment.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sharedSavingsPercentage rdf:type rdf:Property ;
    rdfs:label 'Shared Savings Percentage' ;
    rdfs:comment 'Percentage of the savings amount that is shared with the provider/ACO.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stopLossThreshold rdf:type rdf:Property ;
    rdfs:label 'Stop Loss Threshold' ;
    rdfs:comment 'Maximum dollar amount of shared loss that the ACO/provider entity is obligated to repay in a given performance period. Provides downside protection and is a key negotiated term in two-sided risk VBC contracts.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCostTarget rdf:type rdf:Property ;
    rdfs:label 'Total Cost Target' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vbcModelType rdf:type rdf:Property ;
    rdfs:label 'Vbc Model Type' ;
    rdfs:comment 'Classification of the VBC payment model governing this contract. Determines the financial risk structure and reconciliation methodology: shared_savings (upside only), shared_risk (two-sided), full_capitation (global budget), bundled_payment (episode-based), pay_for_performance (quality incentive). [ENUM-REF-CANDIDATE: shared_savings|shared_risk|full_capitation|bundled_payment|pay_for_performance|global_budget — promote to reference product if additional models are needed]' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vbcPerformancePeriodId rdf:type rdf:Property ;
    rdfs:label 'Vbc Performance Period Id' ;
    rdfs:comment 'Unique surrogate identifier for a VBC performance period record within the contract domain. Primary key for this entity.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acoIdentifier rdf:type rdf:Property ;
    rdfs:label 'Aco Identifier' ;
    rdfs:comment 'Reference to the Accountable Care Organization (ACO) participating in this performance period. Supports CMS MSSP and commercial ACO reporting.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualPmpm rdf:type rdf:Property ;
    rdfs:label 'Actual Pmpm' ;
    rdfs:comment 'Actual expenditure expressed on a Per Member Per Month (PMPM) basis in USD. Compared against benchmark PMPM to assess cost efficiency of the ACO or provider entity.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkPmpm rdf:type rdf:Property ;
    rdfs:label 'Benchmark Pmpm' ;
    rdfs:comment 'Benchmark expenditure expressed on a Per Member Per Month (PMPM) basis in USD. Normalizes the benchmark for population size and enables cross-period and cross-ACO comparisons.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkUpdateMethod rdf:type rdf:Property ;
    rdfs:label 'Benchmark Update Method' ;
    rdfs:comment 'Methodology used to update or set the expenditure benchmark for this performance period (e.g., historical trend, regional average, blended, prospective). Affects benchmark accuracy and ACO incentive alignment.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cahpsCompositeScore rdf:type rdf:Property ;
    rdfs:label 'Cahps Composite Score' ;
    rdfs:comment 'Composite CAHPS survey score reflecting member experience with care during this performance period. Contributes to quality gate assessment and CMS Star Ratings.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmsSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Cms Submission Date' ;
    rdfs:comment 'Date on which performance period data was submitted to CMS for MSSP or other federal VBC program reporting. Required for regulatory compliance tracking.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expenditureVariance rdf:type rdf:Property ;
    rdfs:label 'Expenditure Variance' ;
    rdfs:comment 'Difference between benchmark expenditure target and actual expenditure (in USD). Positive value indicates savings; negative value indicates losses. Drives shared savings or shared loss determination.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hccCaptureRate rdf:type rdf:Property ;
    rdfs:label 'Hcc Capture Rate' ;
    rdfs:comment 'Percentage of expected Hierarchical Condition Category (HCC) diagnoses that were documented and coded during the performance period. Impacts RAF score accuracy and benchmark integrity.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedisCompositeScore rdf:type rdf:Property ;
    rdfs:label 'Hedis Composite Score' ;
    rdfs:comment 'Composite HEDIS measure score for the attributed population during this performance period. Contributes to the overall quality score and CMS quality reporting requirements.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ibnrReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Ibnr Reserve Amount' ;
    rdfs:comment 'Actuarial reserve (in USD) for claims Incurred But Not Reported (IBNR) as of the performance period end date. Included in actual expenditure calculations to ensure completeness of cost measurement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Amount' ;
    rdfs:comment 'Final net dollar amount payable to or recoverable from the ACO or provider entity after applying shared savings, shared losses, quality adjustments, and any withholds. Positive = payment to provider; negative = recovery from provider.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentModel rdf:type rdf:Property ;
    rdfs:label 'Payment Model' ;
    rdfs:comment 'Reimbursement methodology governing this performance period. Determines how savings, losses, and risk are allocated between the health plan and the ACO or provider entity. [ENUM-REF-CANDIDATE: shared_savings|shared_risk|capitation|bundled|global_budget|fee_for_service — promote to reference product if additional models are needed]' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performancePeriodNumber rdf:type rdf:Property ;
    rdfs:label 'Performance Period Number' ;
    rdfs:comment 'Externally-known business identifier for this performance period, formatted as PP-YYYY-NNN. Used in CMS submissions, ACO reporting, and contract correspondence.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Current lifecycle state of the performance period. Tracks progression from open measurement through reconciliation, settlement, and potential dispute resolution.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Classification of the measurement period (e.g., annual, semi-annual, quarterly, interim, final). Determines the reconciliation cadence and reporting obligations.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodAdjustment rdf:type rdf:Property ;
    rdfs:label 'Prior Period Adjustment' ;
    rdfs:comment 'Dollar amount of adjustments applied to this performance period resulting from corrections or true-ups from a prior performance period. Positive = additional payment; negative = recovery.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sharedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Shared Loss Amount' ;
    rdfs:comment 'Calculated dollar amount of shared losses owed by the ACO or provider entity for this performance period (in USD). Positive value only; zero if loss threshold not met or one-sided model.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdAmount rdf:type rdf:Property ;
    rdfs:label 'Withhold Amount' ;
    rdfs:comment 'Dollar amount withheld from shared savings distribution pending quality performance validation or regulatory review. Released upon satisfaction of quality gate or other contractual conditions.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:anchorSetting rdf:type rdf:Property ;
    rdfs:label 'Anchor Setting' ;
    rdfs:comment 'Care setting in which the anchor/trigger event must occur to initiate the episode. Inpatient episodes are typically DRG-triggered; outpatient episodes are procedure-triggered.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsEpisodeCode rdf:type rdf:Property ;
    rdfs:label 'Cms Episode Code' ;
    rdfs:comment 'Official CMS-assigned identifier for this episode type under CMS BPCI-A or other CMS bundled payment programs. Used for CMS submission, reporting, and reconciliation with CMS systems.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeCode rdf:type rdf:Property ;
    rdfs:label 'Episode Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this bundled payment episode definition (e.g., BPCI-JOINT-2024, COMM-CARDIAC-001). Used in EDI transactions and contract references.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeName rdf:type rdf:Property ;
    rdfs:label 'Episode Name' ;
    rdfs:comment 'Human-readable name of the bundled payment episode (e.g., \'Lower Extremity Joint Replacement\', \'Coronary Artery Bypass Graft\', \'Maternity Global\'). Used in reporting and member communications.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeStatus rdf:type rdf:Property ;
    rdfs:label 'Episode Status' ;
    rdfs:comment 'Current lifecycle status of the bundled payment episode definition. Controls whether new episodes can be triggered and whether reconciliation is active.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excludedServicesDescription rdf:type rdf:Property ;
    rdfs:label 'Excluded Services Description' ;
    rdfs:comment 'Narrative description of service categories explicitly excluded from the bundled payment episode (e.g., unrelated readmissions, trauma services, transplants, Part B drugs). Excluded services are reimbursed separately under standard fee-for-service.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gainSharingRate rdf:type rdf:Property ;
    rdfs:label 'Gain Sharing Rate' ;
    rdfs:comment 'Proportion of savings (actual spend below target price) shared with the participating provider or ACO. Expressed as a decimal (e.g., 0.5000 = 50%). Incentivizes cost-efficient care delivery.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:includedServicesDescription rdf:type rdf:Property ;
    rdfs:label 'Included Services Description' ;
    rdfs:comment 'Narrative description of service categories included within the bundled payment episode (e.g., acute inpatient stay, SNF, home health, outpatient rehab, physician services, DME). Defines the scope of the bundle.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossSharingRate rdf:type rdf:Property ;
    rdfs:label 'Loss Sharing Rate' ;
    rdfs:comment 'Proportion of losses (actual spend above target price) borne by the participating provider or ACO. Expressed as a decimal (e.g., 0.2000 = 20%). Defines downside risk exposure.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumEpisodeVolume rdf:type rdf:Property ;
    rdfs:label 'Minimum Episode Volume' ;
    rdfs:comment 'Minimum number of episodes a provider must trigger within a performance period to be eligible for reconciliation and gain/loss sharing. Prevents statistical noise from low-volume providers.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outlierExclusionThreshold rdf:type rdf:Property ;
    rdfs:label 'Outlier Exclusion Threshold' ;
    rdfs:comment 'Dollar threshold above which an individual episode\'s actual expenditure is classified as a high-cost outlier and excluded from reconciliation calculations. Protects against distortion from catastrophic cases.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postTriggerWindowDays rdf:type rdf:Property ;
    rdfs:label 'Post Trigger Window Days' ;
    rdfs:comment 'Number of days following the anchor/trigger event included in the episode window for attribution of post-acute and follow-up services (e.g., 90 days post-discharge). Standard CMS BPCI-A windows are 30, 60, or 90 days.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preTriggerWindowDays rdf:type rdf:Property ;
    rdfs:label 'Pre Trigger Window Days' ;
    rdfs:comment 'Number of days prior to the anchor/trigger event included in the episode window for attribution of pre-episode services (e.g., pre-operative workup). Typically 0–30 days.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityGateRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Gate Required' ;
    rdfs:comment 'Indicates whether the provider must meet minimum quality performance thresholds before any gain sharing payments are released. True = quality gate is a prerequisite for gain sharing.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityWithholdRate rdf:type rdf:Property ;
    rdfs:label 'Quality Withhold Rate' ;
    rdfs:comment 'Percentage of the target price withheld pending quality performance. Released to the provider upon meeting quality thresholds. Aligns financial incentives with quality outcomes (e.g., 0.0300 = 3% withhold).' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readmissionIncluded rdf:type rdf:Property ;
    rdfs:label 'Readmission Included' ;
    rdfs:comment 'Indicates whether related inpatient readmissions occurring within the episode window are attributed to and included in the bundled payment. Unrelated readmissions are typically excluded.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAdjustmentApplied rdf:type rdf:Property ;
    rdfs:label 'Risk Adjustment Applied' ;
    rdfs:comment 'Indicates whether the target price is adjusted for patient risk (e.g., HCC-based Risk Adjustment Factor) to account for case mix differences across providers and performance periods.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:snfIncluded rdf:type rdf:Property ;
    rdfs:label 'Snf Included' ;
    rdfs:comment 'Indicates whether Skilled Nursing Facility (SNF) post-acute care services are included within the episode bundle. SNF inclusion significantly impacts target price and provider risk.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stopGainThreshold rdf:type rdf:Property ;
    rdfs:label 'Stop Gain Threshold' ;
    rdfs:comment 'Maximum dollar amount of savings the provider can earn per episode. Caps upside gain sharing to prevent windfall payments from outlier low-cost episodes.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPrice rdf:type rdf:Property ;
    rdfs:label 'Target Price' ;
    rdfs:comment 'The all-inclusive target price for the bundled payment episode in USD. Represents the maximum total reimbursement for all covered services within the episode window. Basis for reconciliation and gain/loss sharing calculations.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPriceBasis rdf:type rdf:Property ;
    rdfs:label 'Target Price Basis' ;
    rdfs:comment 'Methodology used to establish the target price. Historical claims-based uses the provider\'s own prior utilization; regional/national benchmarks use market comparators; negotiated is a contractually agreed fixed amount.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPriceEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Target Price Effective Date' ;
    rdfs:comment 'Date from which the current target price is applicable. Target prices are typically updated annually or per performance period.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetPriceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Target Price Expiration Date' ;
    rdfs:comment 'Date on which the current target price expires and must be renegotiated or updated. Null indicates the target price is open-ended until superseded.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggerCode rdf:type rdf:Property ;
    rdfs:label 'Trigger Code' ;
    rdfs:comment 'The specific procedure code (CPT/HCPCS), DRG number, or ICD code that triggers the episode window. For multi-code triggers, stores the primary anchor code; supplemental codes managed in a related reference table.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerCodeType rdf:type rdf:Property ;
    rdfs:label 'Trigger Code Type' ;
    rdfs:comment 'Classification system for the trigger code. Indicates whether the trigger_code is a Current Procedural Terminology (CPT), Healthcare Common Procedure Coding System (HCPCS), Diagnosis Related Group (DRG), or ICD-10 code.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerEventType rdf:type rdf:Property ;
    rdfs:label 'Trigger Event Type' ;
    rdfs:comment 'Type of clinical event that initiates the bundled payment episode window. Determines whether the anchor event is identified by a CPT/HCPCS procedure code, DRG, ICD diagnosis code, or inpatient admission.' ;
    rdfs:domain ind:BundledPaymentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementPolicyId rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Policy Id' ;
    rdfs:comment 'Unique surrogate identifier for the reimbursement policy record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededPolicyReimbursementPolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded Policy Reimbursement Policy Id' ;
    rdfs:comment 'Reference to the prior reimbursement policy record that this policy replaces or supersedes. Enables policy lineage tracking and ensures historical adjudication records can be traced to the correct policy version.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReimbursementPolicy .

ind:appliesToFacility rdf:type rdf:Property ;
    rdfs:label 'Applies To Facility' ;
    rdfs:comment 'Indicates whether this reimbursement policy applies to facility (institutional) claims (CMS-1450/UB-04). When True, the policy is enforced on facility claims submitted via 837I transactions.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToProfessional rdf:type rdf:Property ;
    rdfs:label 'Applies To Professional' ;
    rdfs:comment 'Indicates whether this reimbursement policy applies to professional (physician) claims (CMS-1500). When True, the policy is enforced on professional claims submitted via 837P transactions.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diagnosisCodeRequired rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Code Required' ;
    rdfs:comment 'Indicates whether a specific ICD diagnosis code must be present on the claim for this reimbursement policy to apply. When True, the adjudication engine validates the presence of qualifying diagnosis codes before applying the policy.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eobMessageCode rdf:type rdf:Property ;
    rdfs:label 'Eob Message Code' ;
    rdfs:comment 'Code referencing the EOB message displayed to members when a claim is adjusted or denied under this reimbursement policy. Ensures member-facing communications are clear and compliant with ACA transparency requirements.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facetsPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Facets Policy Code' ;
    rdfs:comment 'System-specific policy code as configured in the Facets or QNXT core administration platform. Used to map this Silver Layer record back to the source adjudication system configuration for reconciliation and troubleshooting.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalSurgeryPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Global Surgery Period Days' ;
    rdfs:comment 'Number of days in the global surgery package period during which related pre-operative and post-operative services are bundled into the surgical reimbursement. Standard CMS values are 0, 10, or 90 days. Applies only to global surgery policy types.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxProceduresAllowed rdf:type rdf:Property ;
    rdfs:label 'Max Procedures Allowed' ;
    rdfs:comment 'Maximum number of procedures that can be reimbursed under this policy in a single claim or service encounter. Procedures exceeding this limit are denied or reduced per adjudication rules. Null indicates no limit.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifierCode rdf:type rdf:Property ;
    rdfs:label 'Modifier Code' ;
    rdfs:comment 'CPT or HCPCS modifier code associated with this reimbursement policy (e.g., 50=Bilateral, 51=Multiple Procedures, 80=Assistant Surgeon, 62=Two Surgeons). Triggers or qualifies the policy application during claims adjudication.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncciEditType rdf:type rdf:Property ;
    rdfs:label 'Ncci Edit Type' ;
    rdfs:comment 'Indicates the NCCI edit category applicable to this reimbursement policy. Column 1/Column 2 edits identify procedure code pairs where one code is a component of another. Mutually exclusive edits identify code pairs that cannot be billed together. Used for unbundling policy enforcement.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Override Allowed' ;
    rdfs:comment 'Indicates whether a manual override of this reimbursement policy is permitted during claims adjudication (e.g., by a claims examiner or medical reviewer). When True, authorized users may bypass the policy with documented justification.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideRequiresAuth rdf:type rdf:Property ;
    rdfs:label 'Override Requires Auth' ;
    rdfs:comment 'Indicates whether overriding this reimbursement policy requires a prior authorization (PA) or supervisory approval. When True, an authorization reference must be documented before the override is accepted in Facets/QNXT.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed narrative description of the reimbursement policy, including the business rationale, adjudication logic, and any exceptions or special conditions. Used for provider communications, EOB narratives, and internal training documentation.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policySource rdf:type rdf:Property ;
    rdfs:label 'Policy Source' ;
    rdfs:comment 'Originating authority or source that defines this reimbursement policy. Distinguishes between federally mandated policies (CMS NCCI, MPPR), AMA CPT guidelines, state-mandated rules, and internally plan-defined or contract-specific policies.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyVersion rdf:type rdf:Property ;
    rdfs:label 'Policy Version' ;
    rdfs:comment 'Version identifier for this reimbursement policy, incremented when the policy terms are amended (e.g., \'1.0\', \'2.3\'). Supports policy lifecycle management and historical adjudication audits by identifying which version was active at a given service date.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProcedureRank rdf:type rdf:Property ;
    rdfs:label 'Primary Procedure Rank' ;
    rdfs:comment 'Ranking order used to determine which procedure is designated as the primary (highest-paid) procedure when multiple procedures are performed. The procedure with rank 1 is reimbursed at 100%; subsequent ranks receive the reduction percentage. Applies to multiple procedure reduction policies.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reductionPct rdf:type rdf:Property ;
    rdfs:label 'Reduction Pct' ;
    rdfs:comment 'Percentage by which the allowed amount is reduced when this policy is triggered during claims adjudication. For example, a value of 50.00 indicates the secondary procedure is reimbursed at 50% of the contracted rate. Applies to policies such as multiple procedure reduction and assistant surgeon.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retroactiveAdjustmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Retroactive Adjustment Allowed' ;
    rdfs:comment 'Indicates whether this reimbursement policy can be applied retroactively to previously adjudicated claims when the policy is newly activated or amended. When True, claims reprocessing may be triggered for the applicable service date range.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueCodeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Revenue Code Range End' ;
    rdfs:comment 'Ending UB-04 revenue code in the range to which this reimbursement policy applies for facility claims. Used in conjunction with revenue_code_range_start to define applicable revenue code ranges for institutional claim adjudication.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCodeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Revenue Code Range Start' ;
    rdfs:comment 'Starting UB-04 revenue code in the range to which this reimbursement policy applies for facility claims. Used in conjunction with revenue_code_range_end to define applicable revenue code ranges for institutional claim adjudication.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceScopeId rdf:type rdf:Property ;
    rdfs:label 'Service Scope Id' ;
    rdfs:comment 'Unique identifier for the service scope record. Primary key.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByServiceScopeId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Service Scope Id' ;
    rdfs:comment 'Reference to the service scope record that supersedes this one, used to maintain historical lineage when scope definitions are updated or replaced.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceScope .

ind:carveOutIndicator rdf:type rdf:Property ;
    rdfs:label 'Carve Out Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this service scope represents a carve-out arrangement where specific services are managed or reimbursed separately from the main contract (e.g., behavioral health carve-out, pharmacy carve-out).' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drgRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Drg Range End' ;
    rdfs:comment 'Ending DRG code in the range of inpatient diagnosis-related groups covered or excluded by this service scope.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drgRangeStart rdf:type rdf:Property ;
    rdfs:label 'Drg Range Start' ;
    rdfs:comment 'Starting DRG code in the range of inpatient diagnosis-related groups covered or excluded by this service scope.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icdCodeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Icd Code Range End' ;
    rdfs:comment 'Ending ICD-10 diagnosis code in the range of diagnoses for which services are covered or excluded under this scope.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icdCodeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Icd Code Range Start' ;
    rdfs:comment 'Starting ICD-10 diagnosis code in the range of diagnoses for which services are covered or excluded under this scope.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Inclusion Exclusion Flag' ;
    rdfs:comment 'Indicates whether this scope definition specifies services that are included (covered) or excluded (not covered) under the contract.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementRatePct rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Rate Pct' ;
    rdfs:comment 'Percentage of a reference fee schedule (e.g., Medicare, billed charges) used to calculate reimbursement for services within this scope. Applicable when payment methodology is percentage-based.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scopeCode rdf:type rdf:Property ;
    rdfs:label 'Scope Code' ;
    rdfs:comment 'Unique alphanumeric code identifying this service scope within the contract management system.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeName rdf:type rdf:Property ;
    rdfs:label 'Scope Name' ;
    rdfs:comment 'Business-friendly name or title for this service scope definition.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeStatus rdf:type rdf:Property ;
    rdfs:label 'Scope Status' ;
    rdfs:comment 'Current lifecycle status of the service scope definition.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegatingSignatoryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Delegating Signatory Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Legal delegation requires linking delegating signatory to an employee for signature authority verification.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryDelegationPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Delegation Party Id' ;
    rdfs:comment 'Identifier of the health plan or entity delegating specific functions to another organization.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:supersededByDelegationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Delegation Agreement Id' ;
    rdfs:comment 'Reference to the new delegation agreement that replaces this one when a new version is executed.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DelegationAgreement .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name of the delegation agreement for business reference and reporting.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsOversightRequired rdf:type rdf:Property ;
    rdfs:label 'Cms Oversight Required' ;
    rdfs:comment 'Indicates whether this delegation agreement requires Centers for Medicare and Medicaid Services (CMS) oversight and reporting for Medicare or Medicaid programs.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delegateSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Delegate Signatory Name' ;
    rdfs:comment 'Name of the authorized representative who signed the delegation agreement on behalf of the delegate entity.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegateSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Delegate Signatory Title' ;
    rdfs:comment 'Title or position of the authorized representative who signed on behalf of the delegate entity.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegatedFunctionType rdf:type rdf:Property ;
    rdfs:label 'Delegated Function Type' ;
    rdfs:comment 'Specific function or set of functions delegated under this agreement. [ENUM-REF-CANDIDATE: credentialing|recredentialing|utilization_management|prior_authorization|claims_adjudication|claims_payment|member_services|care_management|disease_management|case_management|pharmacy_benefits|provider_network_management|quality_improvement|appeals_grievances — promote to reference product]' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegatingSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Delegating Signatory Title' ;
    rdfs:comment 'Title or position of the authorized representative who signed on behalf of the delegating entity.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialArrangementType rdf:type rdf:Property ;
    rdfs:label 'Financial Arrangement Type' ;
    rdfs:comment 'Type of financial arrangement governing payment to the delegate entity for delegated functions.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next delegation audit to ensure ongoing compliance and performance monitoring.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oversightRequirement rdf:type rdf:Property ;
    rdfs:label 'Oversight Requirement' ;
    rdfs:comment 'Detailed description of the delegating entity\'s oversight responsibilities, monitoring activities, and reporting requirements for the delegate.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceStandard rdf:type rdf:Property ;
    rdfs:label 'Performance Standard' ;
    rdfs:comment 'Documented performance standards and quality metrics that the delegate entity must meet, including Healthcare Effectiveness Data and Information Set (HEDIS) measures, turnaround times, and accuracy thresholds.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskShareApplicable rdf:type rdf:Property ;
    rdfs:label 'Risk Share Applicable' ;
    rdfs:comment 'Indicates whether the delegation agreement includes risk-sharing arrangements between the delegating entity and delegate.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uracComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Urac Compliance Flag' ;
    rdfs:comment 'Indicates whether this delegation agreement meets URAC delegation standards for health care accreditation.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveArrangementId rdf:type rdf:Property ;
    rdfs:label 'Incentive Arrangement Id' ;
    rdfs:comment 'Unique identifier for the performance-linked financial arrangement within a provider contract. Primary key.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountForfeited rdf:type rdf:Property ;
    rdfs:label 'Amount Forfeited' ;
    rdfs:comment 'Dollar amount of withheld funds forfeited by the provider due to failure to meet performance criteria. Expressed in USD.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountReleased rdf:type rdf:Property ;
    rdfs:label 'Amount Released' ;
    rdfs:comment 'Dollar amount of withheld funds released back to the provider upon meeting performance criteria. Expressed in USD.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnedStatus rdf:type rdf:Property ;
    rdfs:label 'Earned Status' ;
    rdfs:comment 'Indicates whether the provider has earned the incentive or withhold release based on performance evaluation results.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumIncentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Incentive Amount' ;
    rdfs:comment 'Maximum financial incentive or bonus amount that can be earned by the provider under this arrangement. Expressed in USD.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Penalty Amount' ;
    rdfs:comment 'Maximum financial penalty that can be assessed against the provider for non-performance under this arrangement. Expressed in USD.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payoutSchedule rdf:type rdf:Property ;
    rdfs:label 'Payout Schedule' ;
    rdfs:comment 'Frequency at which incentive payments or withhold releases are distributed to the provider.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceThresholdTier rdf:type rdf:Property ;
    rdfs:label 'Performance Threshold Tier' ;
    rdfs:comment 'Tiered performance level definition (e.g., bronze, silver, gold, platinum) that determines incentive payout or withhold release amounts.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency at which performance reports are generated and shared with the provider for transparency and tracking purposes.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCommitment rdf:type rdf:Property ;
    rdfs:label 'Sla Commitment' ;
    rdfs:comment 'Specific service level agreement commitments that the provider must meet as part of this incentive arrangement (e.g., appointment availability, response time, member satisfaction).' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetric rdf:type rdf:Property ;
    rdfs:label 'Target Metric' ;
    rdfs:comment 'Specific performance metric or key performance indicator (KPI) that the provider must achieve (e.g., readmission rate, preventive care completion, cost per member per month).' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Total Withheld Amount' ;
    rdfs:comment 'Total dollar amount withheld from provider reimbursement during the measurement period. Expressed in USD.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vbcProgramName rdf:type rdf:Property ;
    rdfs:label 'Vbc Program Name' ;
    rdfs:comment 'Name of the value-based care program under which this incentive arrangement is established (e.g., Medicare Shared Savings Program, Commercial Quality Incentive Program).' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdPoolType rdf:type rdf:Property ;
    rdfs:label 'Withhold Pool Type' ;
    rdfs:comment 'Classification of the withhold pool indicating whether it is for quality performance, utilization management, risk-sharing, or a combined pool.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdReleaseCriteria rdf:type rdf:Property ;
    rdfs:label 'Withhold Release Criteria' ;
    rdfs:comment 'Business rules and conditions that must be met for withheld amounts to be released to the provider (quality gates, utilization targets, shared risk thresholds).' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNetworkParticipationId rdf:type rdf:Property ;
    rdfs:label 'Contract Network Participation Id' ;
    rdfs:comment 'Unique identifier for the network participation record. Primary key for this entity.' ;
    rdfs:domain ind:ContractNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimsAdjudicationPriority rdf:type rdf:Property ;
    rdfs:label 'Claims Adjudication Priority' ;
    rdfs:comment 'Numeric priority ranking used by claims processing systems when multiple network participations exist for the same provider, with lower numbers indicating higher priority.' ;
    rdfs:domain ind:ContractNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outOfNetworkFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Network Flag' ;
    rdfs:comment 'Boolean indicator whether this provider arrangement allows out-of-network benefits and reimbursement under specific circumstances.' ;
    rdfs:domain ind:ContractNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:participationNumber rdf:type rdf:Property ;
    rdfs:label 'Participation Number' ;
    rdfs:comment 'Business identifier for this network participation arrangement, used for operational reference and tracking.' ;
    rdfs:domain ind:ContractNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcpAssignmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Pcp Assignment Eligible Flag' ;
    rdfs:comment 'Boolean indicator whether this provider can be assigned as a Primary Care Physician for members in HMO or POS plans requiring PCP selection.' ;
    rdfs:domain ind:ContractNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceAreaCounty rdf:type rdf:Property ;
    rdfs:label 'Service Area County' ;
    rdfs:comment 'County name or FIPS code defining the local geographic area covered by this network participation arrangement.' ;
    rdfs:domain ind:ContractNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaZipCodes rdf:type rdf:Property ;
    rdfs:label 'Service Area Zip Codes' ;
    rdfs:comment 'Comma-separated list or range of ZIP codes where this network participation is valid for member access and claims processing.' ;
    rdfs:domain ind:ContractNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telehealthEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Telehealth Eligible Flag' ;
    rdfs:comment 'Indicator whether this provider is eligible to deliver covered telehealth or virtual care services under this network participation.' ;
    rdfs:domain ind:ContractNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialSummaryId rdf:type rdf:Property ;
    rdfs:label 'Financial Summary Id' ;
    rdfs:comment 'System-generated unique identifier for the financial summary record.' ;
    rdfs:domain ind:FinancialSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentFinancialSummaryId rdf:type rdf:Property ;
    rdfs:label 'Parent Financial Summary Id' ;
    rdfs:comment 'Self-referencing FK on financial_summary (parent_financial_summary_id)' ;
    rdfs:domain ind:FinancialSummary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialSummary .

ind:capitationAccrualBalance rdf:type rdf:Property ;
    rdfs:label 'Capitation Accrual Balance' ;
    rdfs:comment 'Outstanding capitation accruals that have been earned but not yet paid.' ;
    rdfs:domain ind:FinancialSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimCount rdf:type rdf:Property ;
    rdfs:label 'Claim Count' ;
    rdfs:domain ind:FinancialSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

