    rdfs:comment 'Indicates whether delivery confirmation was received.' ;
    rdfs:domain ind:BreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationObligation rdf:type rdf:Property ;
    rdfs:label 'Notification Obligation' ;
    rdfs:comment 'Regulatory notification obligations triggered by the breach.' ;
    rdfs:domain ind:BreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRecipientCount rdf:type rdf:Property ;
    rdfs:label 'Notification Recipient Count' ;
    rdfs:comment 'Number of recipients who received the notification.' ;
    rdfs:domain ind:BreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfIndividualsAffected rdf:type rdf:Property ;
    rdfs:label 'Number Of Individuals Affected' ;
    rdfs:comment 'Count of distinct individuals whose PHI was compromised.' ;
    rdfs:domain ind:BreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfRecordsAffected rdf:type rdf:Property ;
    rdfs:label 'Number Of Records Affected' ;
    rdfs:comment 'Total number of PHI records impacted.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskAssessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Method' ;
    rdfs:comment 'Methodology used for risk assessment.' ;
    rdfs:domain ind:BreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Score' ;
    rdfs:comment 'Quantitative risk score resulting from breach risk assessment.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateNotificationDate rdf:type rdf:Property ;
    rdfs:label 'State Notification Date' ;
    rdfs:comment 'Date the state authority was notified.' ;
    rdfs:domain ind:BreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stateNotified rdf:type rdf:Property ;
    rdfs:label 'State Notified' ;
    rdfs:comment 'Indicates if the relevant state authority was notified.' ;
    rdfs:domain ind:BreachIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachNotificationId rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Id' ;
    rdfs:comment 'Unique surrogate key for breach notification record.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Notification Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory breach notifications are issued by a designated employee; links notification to responsible staff.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedProviderCount rdf:type rdf:Property ;
    rdfs:label 'Affected Provider Count' ;
    rdfs:comment 'Number of providers affected by the breach.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachCategory rdf:type rdf:Property ;
    rdfs:label 'Breach Category' ;
    rdfs:comment 'Category of the breach incident.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Breach Disclosure Date' ;
    rdfs:comment 'Date the breach was disclosed internally.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breachNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Status' ;
    rdfs:comment 'Current lifecycle status of the notification record.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentVersion rdf:type rdf:Property ;
    rdfs:label 'Content Version' ;
    rdfs:comment 'Version identifier of the notification content used.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineMet rdf:type rdf:Property ;
    rdfs:label 'Deadline Met' ;
    rdfs:comment 'Flag indicating if the notification was sent on or before the deadline.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaOutletName rdf:type rdf:Property ;
    rdfs:label 'Media Outlet Name' ;
    rdfs:comment 'Name of media outlet notified, if applicable.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationContentHash rdf:type rdf:Property ;
    rdfs:label 'Notification Content Hash' ;
    rdfs:comment 'Hash of the notification content for audit purposes.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'Exact timestamp when the notification was sent.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:numberOfRecipients rdf:type rdf:Property ;
    rdfs:label 'Number Of Recipients' ;
    rdfs:comment 'Count of individuals or entities who received the notification.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryBodyNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Notified' ;
    rdfs:comment 'Regulatory authority or entity that was notified.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaPrivacyRequestId rdf:type rdf:Property ;
    rdfs:label 'Hipaa Privacy Request Id' ;
    rdfs:comment 'System-generated unique identifier for the HIPAA privacy request record.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HipaaPrivacyRequest .

ind:processingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Processing Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Each HIPAA privacy request is processed by a compliance employee; required for audit trails.' ;
    rdfs:domain ind:HipaaPrivacyRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:disclosureAuthorizationBasis rdf:type rdf:Property ;
    rdfs:label 'Disclosure Authorization Basis' ;
    rdfs:comment 'Legal basis authorizing the PHI disclosure.' ;
    rdfs:domain ind:HipaaPrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Date' ;
    rdfs:comment 'Timestamp of the PHI disclosure, if one occurred.' ;
    rdfs:domain ind:HipaaPrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disclosureLogged rdf:type rdf:Property ;
    rdfs:label 'Disclosure Logged' ;
    rdfs:comment 'Indicates whether a PHI disclosure related to this request has been logged.' ;
    rdfs:domain ind:HipaaPrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disclosurePhicategories rdf:type rdf:Property ;
    rdfs:label 'Disclosure Phicategories' ;
    rdfs:comment 'Comma-separated list of PHI categories disclosed (e.g., diagnosis, treatment, payment).' ;
    rdfs:domain ind:HipaaPrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosurePurpose rdf:type rdf:Property ;
    rdfs:label 'Disclosure Purpose' ;
    rdfs:comment 'Business or legal purpose for which the PHI was disclosed.' ;
    rdfs:domain ind:HipaaPrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureRecipientType rdf:type rdf:Property ;
    rdfs:label 'Disclosure Recipient Type' ;
    rdfs:comment 'Category of the entity receiving the disclosed PHI.' ;
    rdfs:domain ind:HipaaPrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAppealed rdf:type rdf:Property ;
    rdfs:label 'Is Appealed' ;
    rdfs:comment 'Indicates whether the member has appealed the request decision.' ;
    rdfs:domain ind:HipaaPrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConfidentialCommunication rdf:type rdf:Property ;
    rdfs:label 'Is Confidential Communication' ;
    rdfs:comment 'True when the member requests that communications be handled confidentially.' ;
    rdfs:domain ind:HipaaPrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestDescription rdf:type rdf:Property ;
    rdfs:label 'Request Description' ;
    rdfs:comment 'Free-text description provided by the member detailing the request.' ;
    rdfs:domain ind:HipaaPrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSource rdf:type rdf:Property ;
    rdfs:label 'Request Source' ;
    rdfs:comment 'Channel through which the request was received (e.g., member portal, email, phone).' ;
    rdfs:domain ind:HipaaPrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current processing state of the privacy request.' ;
    rdfs:domain ind:HipaaPrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiDisclosureLogId rdf:type rdf:Property ;
    rdfs:label 'Phi Disclosure Log Id' ;
    rdfs:comment 'Unique surrogate identifier for each PHI disclosure event.' ;
    rdfs:domain ind:PhiDisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyDocumentId rdf:type rdf:Property ;
    rdfs:label 'Policy Document Id' ;
    rdfs:comment 'External document identifier that substantiates the disclosure (e.g., subpoena number).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PolicyDocument .

ind:authorizationBasis rdf:type rdf:Property ;
    rdfs:label 'Authorization Basis' ;
    rdfs:comment 'Legal justification permitting the disclosure, per HIPAA regulations.' ;
    rdfs:domain ind:PhiDisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureMethod rdf:type rdf:Property ;
    rdfs:label 'Disclosure Method' ;
    rdfs:comment 'Means by which the protected health information was delivered to the recipient.' ;
    rdfs:domain ind:PhiDisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Disclosure Status' ;
    rdfs:comment 'Lifecycle state of the disclosure event for audit tracking.' ;
    rdfs:domain ind:PhiDisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disclosure Timestamp' ;
    rdfs:comment 'Date and time when the PHI disclosure occurred, recorded in UTC.' ;
    rdfs:domain ind:PhiDisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAuthorized rdf:type rdf:Property ;
    rdfs:label 'Is Authorized' ;
    rdfs:comment 'True if the disclosure complied with the documented authorization basis; otherwise false.' ;
    rdfs:domain ind:PhiDisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phiCategory rdf:type rdf:Property ;
    rdfs:label 'Phi Category' ;
    rdfs:comment 'Standard classification of the type(s) of protected health information disclosed.' ;
    rdfs:domain ind:PhiDisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purposeOfDisclosure rdf:type rdf:Property ;
    rdfs:label 'Purpose Of Disclosure' ;
    rdfs:comment 'Narrative description of the reason for disclosing the PHI (e.g., public health reporting, law enforcement request).' ;
    rdfs:domain ind:PhiDisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'Legal name of the entity or person that received the protected health information.' ;
    rdfs:domain ind:PhiDisclosureLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRights rdf:type rdf:Property ;
    rdfs:label 'Audit Rights' ;
    rdfs:comment 'Rights granted to the health plan to audit the associate\'s compliance with the BAA.' ;
    rdfs:domain ind:Baa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachNotificationRequirements rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Requirements' ;
    rdfs:comment 'Procedures and timelines the associate must follow to notify the health plan of a PHI breach.' ;
    rdfs:domain ind:Baa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAssociateName rdf:type rdf:Property ;
    rdfs:label 'Business Associate Name' ;
    rdfs:comment 'Legal name of the vendor, TPA, PBM, clearinghouse, or other entity that receives PHI under the agreement.' ;
    rdfs:domain ind:Baa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAssociateType rdf:type rdf:Property ;
    rdfs:label 'Business Associate Type' ;
    rdfs:comment 'Category of the business associate indicating the nature of the relationship.' ;
    rdfs:domain ind:Baa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataDisposalMethod rdf:type rdf:Property ;
    rdfs:label 'Data Disposal Method' ;
    rdfs:comment 'Method the associate must use to dispose of retained PHI after the retention period.' ;
    rdfs:domain ind:Baa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Months' ;
    rdfs:comment 'Number of months the associate must retain PHI before disposal.' ;
    rdfs:domain ind:Baa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction governing the agreement (e.g., state law, federal HIPAA).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment to the BAA.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permittedPhis rdf:type rdf:Property ;
    rdfs:label 'Permitted Phis' ;
    rdfs:comment 'List or description of specific PHI categories the associate may handle (e.g., claims, enrollment, clinical data).' ;
    rdfs:domain ind:Baa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Period Days' ;
    rdfs:comment 'Number of days prior to expiration that the health plan must provide notice to renew.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalOption rdf:type rdf:Property ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Specifies whether the BAA renews automatically, requires manual action, or does not renew.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfPhiUse rdf:type rdf:Property ;
    rdfs:label 'Scope Of Phi Use' ;
    rdfs:comment 'Narrative description of permitted uses and disclosures of Protected Health Information under the agreement.' ;
    rdfs:domain ind:Baa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityObligations rdf:type rdf:Property ;
    rdfs:label 'Security Obligations' ;
    rdfs:comment 'Detailed security controls and safeguards the associate must implement to protect PHI.' ;
    rdfs:domain ind:Baa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorAllowed rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Allowed' ;
    rdfs:comment 'Indicates whether the business associate may engage subcontractors to perform PHI-related services.' ;
    rdfs:domain ind:Baa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subcontractorDetails rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Details' ;
    rdfs:comment 'Description of any approved subcontractors, their roles, and required safeguards.' ;
    rdfs:domain ind:Baa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Text describing conditions under which the BAA may be terminated by either party.' ;
    rdfs:domain ind:Baa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fwaCaseId rdf:type rdf:Property ;
    rdfs:label 'Fwa Case Id' ;
    rdfs:comment 'Unique system-generated identifier for the FWA case.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FwaCase .

ind:allegationDescription rdf:type rdf:Property ;
    rdfs:label 'Allegation Description' ;
    rdfs:comment 'Detailed description of the alleged fraud, waste, or abuse.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditLogUrl rdf:type rdf:Property ;
    rdfs:label 'Audit Log Url' ;
    rdfs:comment 'Link to the immutable audit log for this case.' ;
    rdfs:domain ind:FwaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseDisposition rdf:type rdf:Property ;
    rdfs:label 'Case Disposition' ;
    rdfs:comment 'Final outcome of the case after investigation.' ;
    rdfs:domain ind:FwaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReference rdf:type rdf:Property ;
    rdfs:label 'Compliance Reference' ;
    rdfs:comment 'Reference identifier used in external compliance filings (e.g., CMS FWA program ID).' ;
    rdfs:domain ind:FwaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Exposure Amount' ;
    rdfs:comment 'Projected monetary loss associated with the alleged activity.' ;
    rdfs:domain ind:FwaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHighRisk rdf:type rdf:Property ;
    rdfs:label 'Is High Risk' ;
    rdfs:comment 'Flag indicating the case is considered high risk based on internal scoring.' ;
    rdfs:domain ind:FwaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subjectReference rdf:type rdf:Property ;
    rdfs:label 'Subject Reference' ;
    rdfs:comment 'Identifier of the subject (member, provider, or employer group) under investigation.' ;
    rdfs:domain ind:FwaCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectType rdf:type rdf:Property ;
    rdfs:label 'Subject Type' ;
    rdfs:comment 'Entity type that is the subject of the investigation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageOutcome rdf:type rdf:Property ;
    rdfs:label 'Triage Outcome' ;
    rdfs:comment 'Result of the initial triage review, indicating next steps.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fwaReferralId rdf:type rdf:Property ;
    rdfs:label 'Fwa Referral Id' ;
    rdfs:comment 'System-generated unique identifier for the FWA referral record.' ;
    rdfs:domain ind:FwaReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFwaEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Fwa Employee Id' ;
    rdfs:comment 'Identifier of the employee who is the subject of the referral, when applicable.' ;
    rdfs:domain ind:FwaReferral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:estimatedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Loss Amount' ;
    rdfs:comment 'Monetary estimate of potential loss associated with the alleged activity.' ;
    rdfs:domain ind:FwaReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fwaReferralStatus rdf:type rdf:Property ;
    rdfs:label 'Fwa Referral Status' ;
    rdfs:comment 'Current lifecycle status of the referral within the investigation workflow.' ;
    rdfs:domain ind:FwaReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralNumber rdf:type rdf:Property ;
    rdfs:label 'Referral Number' ;
    rdfs:comment 'Business identifier assigned to the referral for tracking and reporting.' ;
    rdfs:domain ind:FwaReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralType rdf:type rdf:Property ;
    rdfs:label 'Referral Type' ;
    rdfs:comment 'Category of the alleged wrongdoing.' ;
    rdfs:domain ind:FwaReferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Calculated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: MLR calculations are performed by a specific analyst; needed for audit of financial compliance.' ;
    rdfs:domain ind:MlrCalculation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:mlrProductLineHealthPlanId rdf:type rdf:Property ;
    rdfs:label 'Mlr Product Line Health Plan Id' ;
    rdfs:comment 'Foreign key to the insurance product (e.g., specific benefit design) tied to the calculation.' ;
    rdfs:domain ind:MlrCalculation ;
    rdf:type owl:ObjectProperty ;
