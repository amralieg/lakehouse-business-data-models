    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modelCategory rdf:type rdf:Property ;
    rdfs:label 'Model Category' ;
    rdfs:comment 'Higher-level grouping of the model (e.g., actuarial, underwriting, risk-adjustment).' ;
    rdfs:domain ind:ProspectiveRiskModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelCode rdf:type rdf:Property ;
    rdfs:label 'Model Code' ;
    rdfs:comment 'Business identifier or catalog code assigned to the model for reference in downstream systems.' ;
    rdfs:domain ind:ProspectiveRiskModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelStatus rdf:type rdf:Property ;
