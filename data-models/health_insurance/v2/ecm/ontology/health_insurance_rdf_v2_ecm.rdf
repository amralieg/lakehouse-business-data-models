ind:keyRiskFindings rdf:type rdf:Property ;
    rdfs:label 'Key Risk Findings' ;
    rdfs:comment 'Summary of the most significant risk issues identified during the assessment. [CONFIDENTIAL – business-sensitive information].' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallResidualScore rdf:type rdf:Property ;
    rdfs:label 'Overall Residual Score' ;
    rdfs:comment 'Aggregated residual risk score after weighting all risk domains.' ;
