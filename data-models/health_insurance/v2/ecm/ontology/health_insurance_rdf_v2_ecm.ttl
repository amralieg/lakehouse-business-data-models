    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVoided rdf:type rdf:Property ;
    rdfs:label 'Is Voided' ;
    rdfs:comment 'True if the payment was voided after issuance.' ;
