ind:auditUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this event record (e.g., after correction or annotation).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventSource rdf:type rdf:Property ;
    rdfs:label 'Event Source' ;
    rdfs:comment 'Originating system that generated the status event (e.g., EDI gateway, core claims engine, pharmacy benefit manager).' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatusCode rdf:type rdf:Property ;
    rdfs:label 'Previous Status Code' ;
    rdfs:comment 'Code representing the claim\'s status before this transition.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusCode rdf:type rdf:Property ;
    rdfs:label 'Status Code' ;
    rdfs:comment 'Code representing the claim\'s new lifecycle status after the transition.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userRole rdf:type rdf:Property ;
    rdfs:label 'User Role' ;
    rdfs:comment 'Role of the actor initiating the transition (system process, internal operator, provider, or member).' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimPayerId rdf:type rdf:Property ;
    rdfs:label 'Claim Payer Id' ;
    rdfs:comment 'Primary key for payer' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryPayerId rdf:type rdf:Property ;
    rdfs:label 'Secondary Payer Id' ;
    rdfs:comment 'Single-source-of-truth reference to canonical payer record.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingPayer .

ind:payerAccountBalance rdf:type rdf:Property ;
    rdfs:label 'Payer Account Balance' ;
    rdfs:comment 'Current balance of the payer\'s account.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payerAccountCurrency rdf:type rdf:Property ;
    rdfs:label 'Payer Account Currency' ;
    rdfs:comment 'ISO 4217 currency code for the payer\'s account.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Payer Account Number' ;
    rdfs:comment 'Bank account number used for payments to the payer.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Payer Account Status' ;
    rdfs:comment 'Lifecycle status of the payer\'s account.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Payer Address Line1' ;
    rdfs:comment 'First line of the payer\'s address.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Payer Address Line2' ;
    rdfs:comment 'Second line of the payer\'s address, if applicable.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerBusinessNumber rdf:type rdf:Property ;
    rdfs:label 'Payer Business Number' ;
    rdfs:comment 'Business registration number for the payer.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerCity rdf:type rdf:Property ;
    rdfs:label 'Payer City' ;
    rdfs:comment 'City of the payer\'s address.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Payer Contact Email' ;
    rdfs:comment 'Primary email address for contacting the payer.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerContactName rdf:type rdf:Property ;
    rdfs:label 'Payer Contact Name' ;
    rdfs:comment 'Name of the primary contact person for the payer.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Payer Contact Phone' ;
    rdfs:comment 'Primary phone number for contacting the payer.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerContractEndDate rdf:type rdf:Property ;
    rdfs:label 'Payer Contract End Date' ;
    rdfs:comment 'End date of the payer\'s contract.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payerContractNumber rdf:type rdf:Property ;
    rdfs:label 'Payer Contract Number' ;
    rdfs:comment 'Identifier for the payer\'s contract with the insurer.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerContractStartDate rdf:type rdf:Property ;
    rdfs:label 'Payer Contract Start Date' ;
    rdfs:comment 'Start date of the payer\'s contract.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payerContractStatus rdf:type rdf:Property ;
    rdfs:label 'Payer Contract Status' ;
    rdfs:comment 'Current status of the payer\'s contract.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerCountry rdf:type rdf:Property ;
    rdfs:label 'Payer Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the payer\'s address.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerCoverageEndDate rdf:type rdf:Property ;
    rdfs:label 'Payer Coverage End Date' ;
    rdfs:comment 'End date of coverage provided by the payer.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payerCoverageStartDate rdf:type rdf:Property ;
    rdfs:label 'Payer Coverage Start Date' ;
    rdfs:comment 'Start date of coverage provided by the payer.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payerCreatedAt rdf:type rdf:Property ;
    rdfs:label 'Payer Created At' ;
    rdfs:comment 'Timestamp when the payer record was first created.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payerDeletedAt rdf:type rdf:Property ;
    rdfs:label 'Payer Deleted At' ;
    rdfs:comment 'Timestamp when the payer record was soft-deleted.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payerLei rdf:type rdf:Property ;
    rdfs:label 'Payer Lei' ;
    rdfs:comment 'Legal Entity Identifier for the payer.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerLogoUrl rdf:type rdf:Property ;
    rdfs:label 'Payer Logo Url' ;
    rdfs:comment 'URL to the payer\'s logo image.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerNotes rdf:type rdf:Property ;
    rdfs:label 'Payer Notes' ;
    rdfs:comment 'Additional notes or remarks about the payer.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerPaymentCycle rdf:type rdf:Property ;
    rdfs:label 'Payer Payment Cycle' ;
    rdfs:comment 'Description of the payment cycle for the payer.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payerPaymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payer Payment Frequency' ;
    rdfs:comment 'Frequency of payments to the payer.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payerPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payer Payment Method' ;
    rdfs:comment 'Preferred method of payment to the payer.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payerPaymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payer Payment Terms' ;
    rdfs:comment 'Payment terms agreed with the payer.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerRating rdf:type rdf:Property ;
    rdfs:label 'Payer Rating' ;
    rdfs:comment 'Rating assigned to the payer by the insurer.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerRatingSource rdf:type rdf:Property ;
    rdfs:label 'Payer Rating Source' ;
    rdfs:comment 'Source of the rating for the payer.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Payer Risk Category' ;
    rdfs:comment 'Risk category classification for the payer.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerRiskScore rdf:type rdf:Property ;
    rdfs:label 'Payer Risk Score' ;
    rdfs:comment 'Quantitative risk score assigned to the payer.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payerState rdf:type rdf:Property ;
    rdfs:label 'Payer State' ;
    rdfs:comment 'State or province abbreviation of the payer\'s address.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerStatus rdf:type rdf:Property ;
    rdfs:label 'Payer Status' ;
    rdfs:comment 'Current lifecycle status of the payer.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Payer Tax Number' ;
    rdfs:comment 'Employer Identification Number (EIN) for the payer.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerType rdf:type rdf:Property ;
    rdfs:label 'Payer Type' ;
    rdfs:comment 'Category of the payer entity.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerUpdatedAt rdf:type rdf:Property ;
    rdfs:label 'Payer Updated At' ;
    rdfs:comment 'Timestamp of the most recent update to the payer record.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payerWebsite rdf:type rdf:Property ;
    rdfs:label 'Payer Website' ;
    rdfs:comment 'Official website URL of the payer.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerZip rdf:type rdf:Property ;
    rdfs:label 'Payer Zip' ;
    rdfs:comment 'ZIP or postal code of the payer\'s address.' ;
    rdfs:domain ind:ClaimPayer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugMasterId rdf:type rdf:Property ;
    rdfs:label 'Drug Master Id' ;
    rdfs:comment 'Unique surrogate identifier for each drug master record in the lakehouse Silver layer. Serves as the primary key for all downstream joins across formulary, claims, DUR, rebate contracting, and PBM adjudication.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugMaster .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Data governance requires tracking which employee entered or updated drug master records.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:atcCode rdf:type rdf:Property ;
    rdfs:label 'Atc Code' ;
    rdfs:comment 'The WHO Anatomical Therapeutic Chemical (ATC) classification code at the 5th level, identifying the drug\'s anatomical main group, therapeutic subgroup, pharmacological subgroup, chemical subgroup, and chemical substance. Used for therapeutic class reporting, HEDIS pharmacy measures, population health analytics, and international drug classification alignment.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awpEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Awp Effective Date' ;
    rdfs:comment 'The date on which the current AWP unit price became effective. Used to apply the correct AWP for historical claims repricing, audit reconciliation, and retroactive rebate calculations.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awpUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Awp Unit Price' ;
    rdfs:comment 'The Average Wholesale Price (AWP) per unit of the drug as published by First Databank or Medi-Span. AWP is the benchmark pricing reference used in pharmacy reimbursement calculations, MAC pricing comparisons, and rebate contract negotiations. Expressed in USD per unit (tablet, mL, gram, etc.).' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'The proprietary trade name under which the drug is marketed by the manufacturer (e.g., Lipitor, Humira). Used in formulary tier assignment, rebate contracting, member communications, and brand vs. generic substitution logic in PBM adjudication.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledSubstanceSchedule rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Schedule' ;
    rdfs:comment 'The DEA controlled substance schedule classification (I through V) indicating the drug\'s potential for abuse and accepted medical use. Schedule II-V drugs require enhanced DUR edits, quantity limits, early refill restrictions, and special handling in PBM adjudication. Not_scheduled indicates no DEA restriction.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deaNumberRequired rdf:type rdf:Property ;
    rdfs:label 'Dea Number Required' ;
    rdfs:comment 'Indicates whether a valid DEA registration number is required on the prescription for this drug due to its controlled substance classification. Drives prescription validation edits in PBM adjudication and pharmacy dispensing workflows.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dosageForm rdf:type rdf:Property ;
    rdfs:label 'Dosage Form' ;
    rdfs:comment 'The physical form in which the drug is dispensed (e.g., tablet, capsule, solution, injection, patch, inhaler). Critical for formulary configuration, quantity limit rules, step therapy protocols, and DUR screening in RxClaim/Argus. [ENUM-REF-CANDIDATE: tablet|capsule|solution|injection|patch|inhaler|cream|ointment|suspension|powder — promote to reference product]' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugClassCode rdf:type rdf:Property ;
    rdfs:label 'Drug Class Code' ;
    rdfs:comment 'The classification code for the drug class within the GPI or ETC hierarchy, representing a more granular grouping below therapeutic subclass (e.g., specific statin subtype). Used in formulary step therapy rules, DUR clinical edits, and rebate tier segmentation in PBM systems.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugClassName rdf:type rdf:Property ;
    rdfs:label 'Drug Class Name' ;
    rdfs:comment 'The human-readable name of the drug class corresponding to the drug_class_code. Provides the most granular named classification level in the therapeutic hierarchy for formulary configuration and clinical reporting.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugName rdf:type rdf:Property ;
    rdfs:label 'Drug Name' ;
    rdfs:comment 'The full proprietary or established name of the drug as it appears on the FDA-approved label and in the First Databank or Medi-Span drug database feed. Used as the primary human-readable identity label across formulary displays, EOB communications, and member-facing materials.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugStatus rdf:type rdf:Property ;
    rdfs:label 'Drug Status' ;
    rdfs:comment 'Current lifecycle status of the drug record in the master file. Active drugs are eligible for formulary placement and PBM adjudication. Discontinued or recalled drugs trigger claim edits and member/provider notifications. Drives formulary maintenance workflows in RxClaim/Argus.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugType rdf:type rdf:Property ;
    rdfs:label 'Drug Type' ;
    rdfs:comment 'Classification of the drug as brand-name, generic, biosimilar, over-the-counter (OTC), compounded, or repackaged. Drives formulary tier assignment, cost-sharing rules, generic substitution logic, and rebate eligibility in PBM adjudication and formulary management.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Fda Approval Status' ;
    rdfs:comment 'The current FDA regulatory approval status of the drug product. Approved drugs are eligible for formulary coverage. Tentatively approved generics may be covered under specific plan designs. Withdrawn or not-approved drugs are excluded from formulary and trigger claim denials. Required for CMS Part D formulary compliance.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genericName rdf:type rdf:Property ;
    rdfs:label 'Generic Name' ;
    rdfs:comment 'The International Nonproprietary Name (INN) or United States Adopted Name (USAN) for the active ingredient(s) of the drug (e.g., atorvastatin, adalimumab). Used for generic substitution logic, DUR screening, therapeutic equivalence grouping, and HEDIS pharmacy measure reporting.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpiCode rdf:type rdf:Property ;
    rdfs:label 'Gpi Code' ;
    rdfs:comment 'The 14-digit Medi-Span Generic Product Identifier (GPI) code providing a hierarchical drug classification from drug group (2 digits) through drug class, subclass, name, name extension, dosage form, and strength. Used as the primary therapeutic classification key in RxClaim/Argus PBM systems for formulary management, DUR screening, and rebate contracting.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hccRelevant rdf:type rdf:Property ;
    rdfs:label 'Hcc Relevant' ;
    rdfs:comment 'Indicates whether this drug is clinically associated with one or more CMS Hierarchical Condition Categories (HCCs) for risk adjustment purposes. HCC-relevant drugs are used in RAF score modeling, RAPS/EDPS encounter data submissions, and population health stratification for Medicare Advantage plans.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBiosimilar rdf:type rdf:Property ;
    rdfs:label 'Is Biosimilar' ;
    rdfs:comment 'Indicates whether this drug is an FDA-approved biosimilar to a reference biological product. Biosimilars have distinct formulary placement rules, interchangeability designations, and rebate contracting considerations under CMS Part D and commercial plan designs.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGenericAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Generic Available' ;
    rdfs:comment 'Indicates whether an FDA-approved generic equivalent is available in the market for this brand-name drug. Used in formulary tier assignment, member cost-sharing communications, and generic substitution prompts during PBM adjudication and pharmacy dispensing.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMaintenanceDrug rdf:type rdf:Property ;
    rdfs:label 'Is Maintenance Drug' ;
    rdfs:comment 'Indicates whether this drug is classified as a maintenance medication intended for long-term chronic condition management (e.g., antihypertensives, statins, diabetes medications). Maintenance drugs are eligible for 90-day supply dispensing at mail-order pharmacies and are used in HEDIS medication adherence measures (PDC).' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreventiveDrug rdf:type rdf:Property ;
    rdfs:label 'Is Preventive Drug' ;
    rdfs:comment 'Indicates whether this drug qualifies as a preventive medication under ACA Section 2713 or HDHP/HSA preventive care rules, making it eligible for $0 cost-sharing before the deductible is met. Used in benefit configuration and claims adjudication cost-sharing logic.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSpecialtyDrug rdf:type rdf:Property ;
    rdfs:label 'Is Specialty Drug' ;
    rdfs:comment 'Indicates whether this drug is classified as a specialty pharmaceutical requiring special handling, storage, administration, or monitoring (e.g., biologics, oncology agents, hepatitis C treatments). Specialty drugs are subject to mandatory specialty pharmacy channel requirements, prior authorization, and enhanced DUR in PBM adjudication. Critical for CMS Part D specialty tier placement.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelerCode rdf:type rdf:Property ;
    rdfs:label 'Labeler Code' ;
    rdfs:comment 'The 5-digit FDA-assigned labeler code (first segment of the NDC) identifying the firm that manufactures, repackages, relabels, or distributes the drug. Used for manufacturer-level rebate aggregation and PBM contract management.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiSourceCode rdf:type rdf:Property ;
    rdfs:label 'Multi Source Code' ;
    rdfs:comment 'The FDA Orange Book multi-source code indicating the competitive market status of the drug: O=originator brand with no generic, M=multi-source (generic available), N=no current market (discontinued), Y=single-source generic. Used in generic substitution logic, formulary tier assignment, and MAC pricing eligibility determination.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndc rdf:type rdf:Property ;
    rdfs:label 'Ndc' ;
    rdfs:comment 'The 11-digit National Drug Code assigned by the FDA uniquely identifying the labeler, product, and package size of a drug. This is the primary external business identifier for the drug and is used in pharmacy claims (NCPDP/837P), formulary management, PBM adjudication (RxClaim/Argus), and CMS Part D reporting. Stored in 5-4-2 format without hyphens.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndc11 rdf:type rdf:Property ;
    rdfs:label 'Ndc 11' ;
    rdfs:comment 'The NDC formatted in the standard 5-4-2 hyphenated display format (e.g., 12345-6789-01) as required for human-readable labeling, SBC documentation, and regulatory submissions to CMS and state DOIs.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageSize rdf:type rdf:Property ;
    rdfs:label 'Package Size' ;
    rdfs:comment 'The quantity of drug units contained in the dispensed package as defined by the NDC (e.g., 30 tablets, 100 mL, 1 vial). Used in unit-of-use pricing calculations, days supply verification, quantity limit enforcement, and MAC pricing per-unit derivation.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Package Size Unit' ;
    rdfs:comment 'The unit of measure for the package size quantity (e.g., EA for each/tablet/capsule, ML for milliliter, GM for gram). Used in conjunction with package_size for accurate dispensing quantity calculations, days supply verification, and unit-cost pricing in PBM adjudication. [ENUM-REF-CANDIDATE: EA|ML|GM|MG|TAB|CAP|VIAL|PATCH|KIT — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacologicalCategory rdf:type rdf:Property ;
    rdfs:label 'Pharmacological Category' ;
    rdfs:comment 'The pharmacological mechanism-of-action category of the drug (e.g., ACE Inhibitor, Beta Blocker, SSRI, Statin, Monoclonal Antibody). Used for DUR drug-drug interaction screening, therapeutic duplication edits, clinical program targeting in care management, and HEDIS measure attribution.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDrugNdc rdf:type rdf:Property ;
    rdfs:label 'Reference Drug Ndc' ;
    rdfs:comment 'The NDC of the FDA Reference Listed Drug (RLD) or reference biological product to which this generic or biosimilar is therapeutically equivalent. Enables generic substitution relationship mapping, step therapy configuration, and biosimilar interchangeability tracking in the PBM system.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsProgram rdf:type rdf:Property ;
    rdfs:label 'Rems Program' ;
    rdfs:comment 'The name of the FDA-mandated Risk Evaluation and Mitigation Strategy (REMS) program associated with this drug, if applicable (e.g., iPLEDGE for isotretinoin, TIRF REMS for fentanyl products). REMS drugs require special dispensing controls, patient enrollment, and prescriber certification that must be validated during PBM adjudication and prior authorization.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeOfAdministration rdf:type rdf:Property ;
    rdfs:label 'Route Of Administration' ;
    rdfs:comment 'The path by which the drug is administered to the patient (e.g., oral, intravenous, subcutaneous, topical, inhalation). Drives formulary benefit category assignment (medical vs. pharmacy benefit), prior authorization requirements, and specialty pharmacy routing in PBM adjudication. [ENUM-REF-CANDIDATE: oral|intravenous|subcutaneous|intramuscular|topical|inhalation|transdermal|ophthalmic|otic|rectal — promote to reference product]' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source Record Code' ;
    rdfs:comment 'The native record identifier from the originating source system (First Databank, Medi-Span, RxClaim, or Argus) for this drug master record. Used for data lineage, cross-system reconciliation, and upstream change tracking in the lakehouse ingestion pipeline.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strength rdf:type rdf:Property ;
    rdfs:label 'Strength' ;
    rdfs:comment 'The concentration or potency of the active ingredient(s) expressed as a numeric value with unit of measure (e.g., 10 mg, 500 mg/5 mL, 0.25%). Used in DUR duplicate therapy screening, quantity limit enforcement, and clinical appropriateness review in UM/PA workflows.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticClassCode rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Class Code' ;
    rdfs:comment 'The standardized code identifying the broad therapeutic class of the drug (e.g., cardiovascular agents, anti-infectives, antineoplastics). Used for formulary tier grouping, rebate contract aggregation, utilization reporting, and disease management program enrollment triggers.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticClassName rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Class Name' ;
    rdfs:comment 'The human-readable name of the therapeutic class corresponding to the therapeutic_class_code. Used in formulary displays, member-facing SBC documents, provider communications, and regulatory reporting to CMS and state DOIs.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticEquivalenceCode rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Equivalence Code' ;
    rdfs:comment 'The FDA Orange Book therapeutic equivalence evaluation code (e.g., AB, AA, BC) indicating whether a generic drug is therapeutically equivalent to the reference listed drug. AB-rated generics are substitutable at the pharmacy. Used in generic substitution logic, formulary step therapy, and DAW (Dispense As Written) override processing in PBM adjudication.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticSubclassCode rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Subclass Code' ;
    rdfs:comment 'The standardized code identifying the therapeutic subclass within the broader therapeutic class (e.g., HMG-CoA Reductase Inhibitors within cardiovascular agents). Enables granular formulary tier differentiation, step therapy protocol design, and rebate contract segmentation.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticSubclassName rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Subclass Name' ;
    rdfs:comment 'The human-readable name of the therapeutic subclass corresponding to the therapeutic_subclass_code. Used in formulary management workflows, clinical program configuration, and detailed utilization analytics.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wacUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Wac Unit Price' ;
    rdfs:comment 'The Wholesale Acquisition Cost (WAC) per unit as reported by the manufacturer, representing the list price to wholesalers before discounts and rebates. Used as a pricing benchmark for specialty drug reimbursement, rebate baseline calculations, and CMS Part D coverage gap discount program calculations.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Formulary management assigns a responsible pharmacist/employee; needed for formulary change approval and governance reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priorVersionFormularyId rdf:type rdf:Property ;
    rdfs:label 'Prior Version Formulary Id' ;
    rdfs:comment 'Reference to the immediately preceding version of this formulary. Enables formulary change tracking, member notification workflows, and historical adjudication lookups for appeals and grievances.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Formulary .

ind:formularyCategory rdf:type rdf:Property ;
    rdfs:label 'Formulary Category' ;
    rdfs:comment 'Business classification of the formulary indicating its benefit richness level relative to other formularies offered by the plan. Used in benefit design analytics, member communications, and plan comparison tools.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Change Notification Date' ;
    rdfs:comment 'Date on which member notification was sent for formulary changes. CMS Part D requires 60-day advance notice for non-preferred formulary changes and immediate notification for safety-related removals.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cmsFormularyCode rdf:type rdf:Property ;
    rdfs:label 'Cms Formulary Code' ;
    rdfs:comment 'The CMS-assigned formulary identifier used in Part D formulary file submissions to CMS. Required for Medicare Part D plans to identify the formulary in RAPS and EDPS submissions.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyCode rdf:type rdf:Property ;
    rdfs:label 'Formulary Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the formulary across systems, used in EDI transactions, PBM interfaces, and CMS Part D submissions. Corresponds to the formulary ID field in RxClaim/Argus PBM system.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyDescription rdf:type rdf:Property ;
    rdfs:label 'Formulary Description' ;
    rdfs:comment 'Free-text business description of the formulary, including its intended population, key design features, and any notable coverage inclusions or exclusions. Used in internal documentation and plan benefit configuration.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugCount rdf:type rdf:Property ;
    rdfs:label 'Drug Count' ;
    rdfs:comment 'Total number of unique drug entries (NDC or drug-tier combinations) included in this formulary at the time of the last update. Used for formulary adequacy assessments and CMS Part D formulary file validation.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drugUtilizationReviewInd rdf:type rdf:Property ;
    rdfs:label 'Drug Utilization Review Ind' ;
    rdfs:comment 'Indicates whether Drug Utilization Review (DUR) edits are applied during adjudication under this formulary. DUR programs screen for drug interactions, duplicate therapy, and inappropriate dosing per OBRA \'90 requirements.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formularyStatus rdf:type rdf:Property ;
    rdfs:label 'Formulary Status' ;
    rdfs:comment 'Current lifecycle status of the formulary record. Active formularies are used in live adjudication; pending formularies are approved but not yet effective; retired formularies are historical records no longer in use.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyType rdf:type rdf:Property ;
    rdfs:label 'Formulary Type' ;
    rdfs:comment 'Classification of the formulary structure indicating coverage breadth and tier design. Open formularies cover most drugs; closed formularies restrict to listed drugs only; tiered formularies apply differential cost-sharing by tier.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genericSubstitutionPolicy rdf:type rdf:Property ;
    rdfs:label 'Generic Substitution Policy' ;
    rdfs:comment 'Policy governing generic drug substitution at point of dispensing. Mandatory substitution requires dispensing of generic equivalents; permissive allows brand if requested; DAW (Dispense As Written) honored respects prescriber instructions.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAcaCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Aca Compliant' ;
    rdfs:comment 'Indicates whether this formulary meets ACA Qualified Health Plan (QHP) essential health benefit (EHB) drug coverage requirements, including the required drug categories and classes under 45 CFR Part 156.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCmsPartD rdf:type rdf:Property ;
    rdfs:label 'Is Cms Part D' ;
    rdfs:comment 'Indicates whether this formulary is subject to CMS Medicare Part D regulatory requirements, including annual bid submission, formulary file submission to CMS, and coverage determination obligations.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowIncomeSubsidyInd rdf:type rdf:Property ;
    rdfs:label 'Low Income Subsidy Ind' ;
    rdfs:comment 'Indicates whether this formulary is designated for use by Low Income Subsidy (LIS) eligible members under Medicare Part D. LIS formularies must meet CMS benchmark plan requirements for cost-sharing and drug coverage.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mailOrderInd rdf:type rdf:Property ;
    rdfs:label 'Mail Order Ind' ;
    rdfs:comment 'Indicates whether this formulary supports mail-order pharmacy dispensing. Mail-order programs typically offer 90-day supplies at reduced cost-sharing and are a key component of pharmacy benefit design.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formularyName rdf:type rdf:Property ;
    rdfs:label 'Formulary Name' ;
    rdfs:comment 'Human-readable business name of the formulary (e.g., \'Standard Commercial Formulary 2025\', \'Medicare Part D Enhanced Formulary\'). Used in member-facing materials, SBC documents, and plan benefit configurations.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pbmFormularyCode rdf:type rdf:Property ;
    rdfs:label 'Pbm Formulary Code' ;
    rdfs:comment 'The formulary identifier as assigned by the PBM system (RxClaim or Argus). Used for cross-system reconciliation between the health plan\'s internal formulary record and the PBM\'s formulary configuration.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthInd rdf:type rdf:Property ;
    rdfs:label 'Prior Auth Ind' ;
    rdfs:comment 'Indicates whether this formulary requires prior authorization (PA) for any covered drugs. PA requirements are subject to CMS Part D coverage determination timelines and member appeal rights.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ptCommitteeApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Pt Committee Approval Date' ;
    rdfs:comment 'Date on which the Pharmacy and Therapeutics (P&T) Committee formally approved this formulary or the most recent formulary update. Required documentation for CMS Part D compliance and NCQA accreditation audits.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityLimitInd rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Ind' ;
    rdfs:comment 'Indicates whether this formulary applies quantity limits (QL) on covered drugs, restricting the amount dispensed per fill or per defined time period. Quantity limits are a utilization management tool subject to CMS Part D exception requirements.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Date' ;
    rdfs:comment 'The date on which the formulary was submitted to CMS or the applicable State Department of Insurance for regulatory review and approval.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Status' ;
    rdfs:comment 'Status of the formulary\'s regulatory filing with CMS or applicable State Department of Insurance (DOI). Tracks whether the formulary has been submitted, approved, or rejected for compliance with Part D or state market requirements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyPharmacyInd rdf:type rdf:Property ;
    rdfs:label 'Specialty Pharmacy Ind' ;
    rdfs:comment 'Indicates whether this formulary designates a specialty pharmacy network for dispensing high-cost specialty drugs. Specialty pharmacy programs may include limited distribution networks and enhanced clinical support services.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialtyTierInd rdf:type rdf:Property ;
    rdfs:label 'Specialty Tier Ind' ;
    rdfs:comment 'Indicates whether this formulary includes a specialty drug tier for high-cost specialty medications. Specialty tiers typically apply to drugs with monthly costs exceeding CMS specialty tier threshold (currently $670/month for Part D).' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepTherapyInd rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Ind' ;
    rdfs:comment 'Indicates whether this formulary employs step therapy (also known as fail-first) protocols requiring members to try lower-cost or preferred drugs before coverage of higher-cost alternatives is authorized.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierCount rdf:type rdf:Property ;
    rdfs:label 'Tier Count' ;
    rdfs:comment 'The total number of cost-sharing tiers defined in this formulary (e.g., 3-tier, 4-tier, 5-tier, 6-tier). Determines the tier structure used in drug tier assignments and member cost-sharing calculations.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:url rdf:type rdf:Property ;
    rdfs:label 'Url' ;
    rdfs:comment 'Public-facing URL where members can access the formulary drug list. CMS Part D and ACA QHP regulations require health plans to publish formularies online and provide the URL in plan materials and SBC documents.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyDrugTierId rdf:type rdf:Property ;
    rdfs:label 'Formulary Drug Tier Id' ;
    rdfs:comment 'Unique surrogate identifier for each formulary drug tier assignment record. Primary key for this association entity linking a drug (NDC) to a formulary with its tier, cost-sharing, and utilization management (UM) controls.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:copayMailOrder rdf:type rdf:Property ;
    rdfs:label 'Copay Mail Order' ;
    rdfs:comment 'Fixed member copay amount for a 90-day supply dispensed through a mail-order pharmacy under this formulary tier assignment. Mail-order copays are typically lower than retail to incentivize mail-order utilization.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayRetail30 rdf:type rdf:Property ;
    rdfs:label 'Copay Retail 30' ;
    rdfs:comment 'Fixed member copay amount for a 30-day supply dispensed at a retail pharmacy under this formulary tier assignment. Drives member cost-sharing at point of sale. Used in SBC and EOB generation.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayRetail90 rdf:type rdf:Property ;
    rdfs:label 'Copay Retail 90' ;
    rdfs:comment 'Fixed member copay amount for a 90-day supply dispensed at a retail pharmacy under this formulary tier assignment. Applicable for maintenance medications at extended-supply retail pharmacies.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductibleApplies rdf:type rdf:Property ;
    rdfs:label 'Deductible Applies' ;
    rdfs:comment 'Indicates whether the plan deductible must be met before cost-sharing for this drug tier applies. Relevant for High Deductible Health Plans (HDHP) and plans with drug-specific deductibles.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispensingChannel rdf:type rdf:Property ;
    rdfs:label 'Dispensing Channel' ;
    rdfs:comment 'Pharmacy dispensing channel(s) through which this drug may be dispensed under this formulary tier assignment. \'specialty\' indicates dispensing is restricted to a specialty pharmacy network. Drives pharmacy routing at point of sale.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugTierChangeReason rdf:type rdf:Property ;
    rdfs:label 'Drug Tier Change Reason' ;
    rdfs:comment 'Business reason for a change to the drug\'s tier assignment (e.g., \'generic available\', \'contract renegotiation\', \'clinical review\', \'CMS requirement\', \'formulary refresh\'). Supports audit trail and CMS formulary change notification requirements.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durAlertType rdf:type rdf:Property ;
    rdfs:label 'Dur Alert Type' ;
    rdfs:comment 'Type of Drug Utilization Review (DUR) alert associated with this formulary drug tier assignment (e.g., \'drug-drug interaction\', \'drug-disease contraindication\', \'duplicate therapy\', \'dose range check\'). Drives DUR edits at point of sale in the PBM adjudication system. [ENUM-REF-CANDIDATE: drug_drug_interaction|drug_disease|duplicate_therapy|dose_range|drug_allergy|drug_age — promote to reference product]' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyStatusCode rdf:type rdf:Property ;
    rdfs:label 'Formulary Status Code' ;
    rdfs:comment 'CMS-defined formulary status code used in the Part D formulary file submission. Values: 1=Covered, 2=Covered with Restrictions, 3=Not Covered, 4=Covered (Grandfathered), 5=Covered (Transition), 6=Covered (LIS). Required field in CMS formulary extract file.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macPricingApplicable rdf:type rdf:Property ;
    rdfs:label 'Mac Pricing Applicable' ;
    rdfs:comment 'Indicates whether Maximum Allowable Cost (MAC) pricing applies to this drug under this formulary tier assignment. MAC pricing caps reimbursement for generic drugs and is a key PBM contract term.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paCriteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Pa Criteria Description' ;
    rdfs:comment 'Narrative description of the clinical criteria that must be met for prior authorization approval of this drug. Supports PA adjudication, member appeals, and CMS/NCQA compliance documentation.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paType rdf:type rdf:Property ;
    rdfs:label 'Pa Type' ;
    rdfs:comment 'Type of prior authorization process required for this drug (e.g., \'standard\' = standard review timeline; \'expedited\' = urgent/expedited review; \'retrospective\' = post-service review). Null or \'not_applicable\' if prior_auth_required is false.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qlClinicalBasis rdf:type rdf:Property ;
    rdfs:label 'Ql Clinical Basis' ;
    rdfs:comment 'Clinical rationale or basis for the quantity limit rule (e.g., \'FDA-approved maximum dose\', \'clinical guidelines\', \'safety limit\'). Documents the evidence basis for the QL control as required for CMS and NCQA compliance.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qlDaysSupply rdf:type rdf:Property ;
    rdfs:label 'Ql Days Supply' ;
    rdfs:comment 'The number of days supply over which the maximum quantity limit applies (e.g., 30 days, 90 days). Defines the time window for the quantity limit rule. Null if quantity_limit_required is false.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qlDosageFormRestriction rdf:type rdf:Property ;
    rdfs:label 'Ql Dosage Form Restriction' ;
    rdfs:comment 'Specifies any dosage form restrictions associated with the quantity limit rule (e.g., \'tablet only\', \'extended-release excluded\', \'oral solution only\'). Captures clinical basis for dosage form-specific QL controls.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qlMaxQuantity rdf:type rdf:Property ;
    rdfs:label 'Ql Max Quantity' ;
    rdfs:comment 'Maximum quantity of the drug allowed per fill or per defined time period under the quantity limit rule. Expressed in the drug\'s dispensing unit (e.g., tablets, mL, units). Null if quantity_limit_required is false.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityLimitRequired rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Required' ;
    rdfs:comment 'Indicates whether a quantity limit (QL) applies to this drug under this formulary assignment. When true, the dispensed quantity per fill or per time period is restricted. Reported in the CMS QL extract file.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialtyDrugFlag rdf:type rdf:Property ;
    rdfs:label 'Specialty Drug Flag' ;
    rdfs:comment 'Indicates whether this drug is designated as a specialty drug under this formulary. Specialty drugs typically require dispensing through a specialty pharmacy, have higher cost-sharing, and may require PA. Used in specialty pharmacy channel routing and PBM contract management.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stClinicalRationale rdf:type rdf:Property ;
    rdfs:label 'St Clinical Rationale' ;
    rdfs:comment 'Clinical rationale or evidence basis for the step therapy protocol (e.g., \'preferred generic available\', \'clinical guidelines recommend first-line therapy\', \'cost-effectiveness\'). Required for CMS and NCQA UM documentation.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stOverrideCriteria rdf:type rdf:Property ;
    rdfs:label 'St Override Criteria' ;
    rdfs:comment 'Criteria under which the step therapy requirement may be overridden without completing the required step sequence (e.g., \'contraindication to step drug\', \'prior treatment failure documented\', \'clinical exception\'). Supports PA override adjudication.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stRequiredStepNdc rdf:type rdf:Property ;
    rdfs:label 'St Required Step Ndc' ;
    rdfs:comment 'National Drug Code (NDC) of the required step drug that must be tried and failed before coverage of this drug is approved under the step therapy protocol. Null if step_therapy_required is false.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stStepNumber rdf:type rdf:Property ;
    rdfs:label 'St Step Number' ;
    rdfs:comment 'The sequence number of this drug in the step therapy protocol (e.g., 1 = first-line, 2 = second-line). Defines the order in which step drugs must be tried and failed before coverage of the target drug is approved. Null if step_therapy_required is false.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Human-readable label for the drug tier (e.g., \'Generic\', \'Preferred Brand\', \'Non-Preferred Brand\', \'Specialty\', \'Specialty Preferred\'). Displayed on member-facing materials including the Summary of Benefits and Coverage (SBC) and Explanation of Benefits (EOB).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierNumber rdf:type rdf:Property ;
    rdfs:label 'Tier Number' ;
    rdfs:comment 'Numeric tier level assigned to the drug within the formulary (e.g., 1=Generic, 2=Preferred Brand, 3=Non-Preferred Brand, 4=Specialty, 5=Specialty Preferred, 6=Select Care). Drives member cost-sharing at point of sale. CMS requires tier number in formulary file submissions.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitionFillAllowed rdf:type rdf:Property ;
    rdfs:label 'Transition Fill Allowed' ;
    rdfs:comment 'Indicates whether a transition fill is permitted for this drug when a member is new to the plan or the drug\'s formulary status has changed. CMS Part D requires transition fills for certain drugs during the transition period.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drugPricingId rdf:type rdf:Property ;
    rdfs:label 'Drug Pricing Id' ;
    rdfs:comment 'Unique surrogate identifier for each NDC-level drug pricing record in the Silver Layer lakehouse. Primary key for the drug_pricing data product.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:macListId rdf:type rdf:Property ;
    rdfs:label 'Mac List Id' ;
    rdfs:comment 'FK to pharmacy.mac_list' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MacList .

ind:awpDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Awp Discount Pct' ;
    rdfs:comment 'Percentage discount applied to AWP to derive the reimbursement rate under AWP-based contracts (e.g., AWP minus 15%). Expressed as a positive decimal percentage (e.g., 15.0000 = 15%). Used for PBM contract compliance validation and reimbursement audits.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awpPrice rdf:type rdf:Property ;
    rdfs:label 'Awp Price' ;
    rdfs:comment 'Average Wholesale Price per unit as published by First Databank or Medi-Span. Commonly used as the benchmark for pharmacy reimbursement calculations and discount negotiations. Expressed in USD.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysSupply rdf:type rdf:Property ;
    rdfs:label 'Days Supply' ;
    rdfs:comment 'Number of days of drug supply for which this pricing record applies (e.g., 30-day retail, 90-day mail order). Used to differentiate pricing tiers by supply duration per PBM contract terms.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deaSchedule rdf:type rdf:Property ;
    rdfs:label 'Dea Schedule' ;
    rdfs:comment 'DEA controlled substance schedule classification (CI through CV) or NON-CONTROLLED. Used for DUR edits, quantity limit enforcement, prior authorization requirements, and regulatory compliance reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensingFee rdf:type rdf:Property ;
    rdfs:label 'Dispensing Fee' ;
    rdfs:comment 'Fixed dispensing fee in USD paid to the pharmacy per prescription fill, separate from the ingredient cost. Defined in PBM network contracts and applied during claim adjudication to calculate total pharmacy reimbursement.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:macListVersion rdf:type rdf:Property ;
    rdfs:label 'Mac List Version' ;
    rdfs:comment 'Version identifier of the MAC list, used to track updates and revisions to the MAC pricing schedule. Supports audit trails for MAC list changes and pharmacy reimbursement disputes. Null when price_type is not MAC.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macMethodology rdf:type rdf:Property ;
    rdfs:label 'Mac Methodology' ;
    rdfs:comment 'Describes the methodology used to derive the MAC price (e.g., MARKET_BASKET=based on market survey of acquisition costs, NADAC_BASED=derived from CMS NADAC data, AWP_DISCOUNT=percentage discount from AWP, WAC_DISCOUNT=percentage discount from WAC, CUSTOM=plan-specific methodology). Required for PBM contract compliance and regulatory transparency. Null when price_type is not MAC.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macPrice rdf:type rdf:Property ;
    rdfs:label 'Mac Price' ;
    rdfs:comment 'Maximum Allowable Cost per unit set by the PBM or health plan for generic and multi-source drugs. Represents the upper reimbursement limit for a drug under the applicable MAC list. Expressed in USD. Null when price_type is not MAC.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageSizeUom rdf:type rdf:Property ;
    rdfs:label 'Package Size Uom' ;
    rdfs:comment 'Unit of measure for the package size quantity (e.g., TAB for tablets, ML for milliliters). Distinct from unit_of_measure which applies to the pricing unit; this field describes the package-level quantity unit. [ENUM-REF-CANDIDATE: EA|ML|GM|MG|UN|TAB|CAP|VIAL|PATCH — promote to reference product]' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangePct rdf:type rdf:Property ;
    rdfs:label 'Price Change Pct' ;
    rdfs:comment 'Percentage change in unit price from the prior pricing record to the current record, calculated as ((unit_price - prior_unit_price) / prior_unit_price) * 100. Used for drug price inflation monitoring, CMS price increase reporting, and PBM contract compliance.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classifies the pricing methodology represented by this record: AWP (Average Wholesale Price), WAC (Wholesale Acquisition Cost), MAC (Maximum Allowable Cost), RBP (Reference Based Pricing), NADAC (National Average Drug Acquisition Cost), or Usual and Customary. Determines how the price is applied during claim adjudication and reimbursement calculation. [ENUM-REF-CANDIDATE: AWP|WAC|MAC|RBP|NADAC|USUAL_AND_CUSTOMARY — promote to reference product]' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingFileDate rdf:type rdf:Property ;
    rdfs:label 'Pricing File Date' ;
    rdfs:comment 'Publication or release date of the source pricing file from which this record was extracted. Used to track pricing file currency, identify stale pricing data, and support audit and reconciliation processes.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricingFileName rdf:type rdf:Property ;
    rdfs:label 'Pricing File Name' ;
    rdfs:comment 'Name of the source pricing file from which this record was loaded (e.g., \'FDB_PRICE_20240101.txt\', \'RXCLAIM_MAC_Q1_2024.csv\'). Used for data lineage, audit trails, and troubleshooting pricing discrepancies.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingSource rdf:type rdf:Property ;
    rdfs:label 'Pricing Source' ;
    rdfs:comment 'Identifies the originating source of the pricing data (e.g., First Databank, Medi-Span, RxClaim PBM feed, Argus PBM feed, CMS published rates, internal custom pricing). Critical for audit trails and PBM contract compliance. [ENUM-REF-CANDIDATE: FDB|MEDISPAN|RXCLAIM|ARGUS|CMS|INTERNAL|CUSTOM — promote to reference product]' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Status' ;
    rdfs:comment 'Current lifecycle status of the pricing record: active (currently in use for adjudication), inactive (no longer applicable), pending (approved but not yet effective), superseded (replaced by a newer pricing record for the same NDC and price type).' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Prior Unit Price' ;
    rdfs:comment 'Previous per-unit price for this NDC and price type before the most recent pricing update. Used for price change analysis, trend reporting, and PBM contract compliance audits.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rbpPrice rdf:type rdf:Property ;
    rdfs:label 'Rbp Price' ;
    rdfs:comment 'Reference Based Pricing per unit used as the benchmark reimbursement amount under RBP pharmacy contracts. Expressed in USD. Null when price_type is not RBP.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Dispensing unit of measure for which the price applies (e.g., EA=Each, ML=Milliliter, GM=Gram, MG=Milligram, UN=Unit, TAB=Tablet, CAP=Capsule, VIAL=Vial, PATCH=Patch). Required for accurate per-unit cost calculation during adjudication. [ENUM-REF-CANDIDATE: EA|ML|GM|MG|UN|TAB|CAP|VIAL|PATCH — promote to reference product]' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Per-unit drug price expressed in USD for the applicable price type (AWP, WAC, MAC, or RBP). Used as the basis for claim adjudication, cost-sharing calculation, and pharmacy reimbursement. Precision to 6 decimal places to accommodate high-precision specialty drug pricing.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wacPrice rdf:type rdf:Property ;
    rdfs:label 'Wac Price' ;
    rdfs:comment 'Wholesale Acquisition Cost per unit as reported by the manufacturer to the pricing compendia. Represents the list price from manufacturer to wholesaler before discounts. Expressed in USD. Used in WAC-based reimbursement contracts.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pharmacyClaimId rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Claim Id' ;
    rdfs:comment 'Unique surrogate identifier for each pharmacy claim record in the Silver layer lakehouse. Primary key for the pharmacy_claim data product. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PharmacyClaim .

ind:dispensingPharmacyId rdf:type rdf:Property ;
    rdfs:label 'Dispensing Pharmacy Id' ;
    rdfs:comment 'Surrogate reference to the pharmacy that dispensed the drug. Links to the provider/pharmacy master record. Distinguishes retail, mail-order, and specialty pharmacy channels. Used for network adequacy reporting and pharmacy audit trail requirements.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DispensingPharmacy .

ind:memberRiskScoreId rdf:type rdf:Property ;
    rdfs:label 'Member Risk Score Id' ;
    rdfs:comment 'Foreign key linking to risk.member_risk_score. Business justification: Risk-adjusted claim adjudication report requires each claim to reference the member\'s risk score to apply CMS risk adjustment factors.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberRiskScore .

ind:pharmacyPbmTransactionId rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Pbm Transaction Id' ;
    rdfs:comment 'Source system transaction identifier assigned by the PBM system (RxClaim or Argus) at the time of adjudication. Used for claim traceability, PBM reconciliation, EDI 835 remittance matching, and pharmacy audit trail. Enables lineage back to the operational system of record.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:prescriberCredentialRecordId rdf:type rdf:Property ;
    rdfs:label 'Prescriber Credential Record Id' ;
    rdfs:comment 'Foreign key linking to credential.credential_record. Business justification: Claim adjudication requires verifying prescriber credentials per CMS regulations; linking claim to credential_record enables automated credential status checks.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Record .

ind:priorAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Id' ;
    rdfs:comment 'Surrogate reference to the prior authorization record that approved dispensing of this drug, if applicable. Null when no PA was required. Links to the utilization management PA product. Required for specialty drug claims and step therapy override tracking.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriorAuthorization .

ind:processorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Processor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Required for Claim Processing Audit Report to track which employee adjudicated each pharmacy claim.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:basisOfCostDetermination rdf:type rdf:Property ;
    rdfs:label 'Basis Of Cost Determination' ;
    rdfs:comment 'Code indicating the pricing benchmark used to determine the ingredient cost for this claim. AWP = Average Wholesale Price; WAC = Wholesale Acquisition Cost; MAC = Maximum Allowable Cost; usual_and_customary = pharmacy\'s standard retail price; negotiated = contracted rate; 340B = 340B program pricing; other = alternative basis. [ENUM-REF-CANDIDATE: awp|wac|mac|usual_and_customary|negotiated|340b|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dawCode rdf:type rdf:Property ;
    rdfs:label 'Daw Code' ;
    rdfs:comment 'NCPDP Dispense As Written (DAW) code indicating whether a brand drug was dispensed when a generic was available, and the reason. 0 = no product selection indicated; 1 = substitution not allowed by prescriber; 2 = substitution allowed, patient requested brand; 3 = substitution allowed, pharmacist selected brand; 4 = substitution allowed, generic not in stock; 5 = substitution allowed, brand dispensed as generic. Used for generic substitution rate analytics and formulary compliance.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleApplied rdf:type rdf:Property ;
    rdfs:label 'Deductible Applied' ;
    rdfs:comment 'Dollar amount of this pharmacy claim applied toward the member\'s pharmacy or combined medical/pharmacy deductible. Relevant for HDHP/HSA plans and CMS Part D deductible phase tracking. Contributes to OOP/MOOP accumulation.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispensingPharmacyNpi rdf:type rdf:Property ;
    rdfs:label 'Dispensing Pharmacy Npi' ;
    rdfs:comment '10-digit National Provider Identifier (NPI) of the dispensing pharmacy as submitted on the pharmacy claim. Denormalized for claim-level auditability and NCPDP D.0 compliance. Used for pharmacy network validation, audit trail, and CMS Part D encounter data.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durOutcomeCode rdf:type rdf:Property ;
    rdfs:label 'Dur Outcome Code' ;
    rdfs:comment 'NCPDP standard code indicating the outcome of the prospective drug utilization review (DUR) edit performed during adjudication (e.g., drug-drug interaction, duplicate therapy, dose check). Null if no DUR alert was triggered. Critical for pharmacy safety and regulatory compliance. [ENUM-REF-CANDIDATE: promote to reference product — NCPDP DUR outcome codes exceed 6 values]' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fhirMedication rdf:type rdf:Property ;
    rdfs:label 'Fhir Medication' ;
    rdfs:comment 'FHIR MedicationDispense.medication mapping' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fhirQuantity rdf:type rdf:Property ;
    rdfs:label 'Fhir Quantity' ;
    rdfs:comment 'FHIR MedicationDispense.quantity mapping' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fhirSubject rdf:type rdf:Property ;
    rdfs:label 'Fhir Subject' ;
    rdfs:comment 'FHIR MedicationDispense.subject mapping' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillDate rdf:type rdf:Property ;
    rdfs:label 'Fill Date' ;
    rdfs:comment 'The date the prescription was dispensed by the pharmacy to the member. This is the principal real-world business event date (BUSINESS_EVENT_TIMESTAMP category). Used for days supply calculations, refill-too-soon edits, and CMS Part D encounter data date of service reporting.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ingredientCost rdf:type rdf:Property ;
    rdfs:label 'Ingredient Cost' ;
    rdfs:comment 'The cost of the drug ingredient(s) as billed by the dispensing pharmacy, before dispensing fee and other adjustments. Basis may be AWP, WAC, MAC, or negotiated rate. Core component of the MONETARY_TRIPLET for pharmacy claim financials. Used for PBM contract reconciliation and MLR calculation.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:is340bClaim rdf:type rdf:Property ;
    rdfs:label 'Is 340b Claim' ;
    rdfs:comment 'Indicates whether this pharmacy claim was dispensed under the 340B Drug Pricing Program (True = 340B claim). Used for 340B duplicate discount prevention, HRSA compliance reporting, and separation of 340B and non-340B claims in financial reconciliation.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCompoundClaim rdf:type rdf:Property ;
    rdfs:label 'Is Compound Claim' ;
    rdfs:comment 'Indicates whether this claim is for a compounded drug product containing multiple ingredients (True = compound claim). Compound claims require line-level detail in the pharmacy_claim_line product. Used for compound drug utilization review and cost management.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberCoinsurance rdf:type rdf:Property ;
    rdfs:label 'Member Coinsurance' ;
    rdfs:comment 'Percentage-based cost-sharing amount paid by the member for this pharmacy claim, calculated as a percentage of the allowed cost. Applies when the benefit design uses coinsurance rather than fixed copay. Contributes to OOP/MOOP accumulation.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memberCopay rdf:type rdf:Property ;
    rdfs:label 'Member Copay' ;
    rdfs:comment 'Fixed dollar amount paid by the member at point of sale as their cost-sharing obligation for this pharmacy claim. Determined by formulary tier and benefit design. Contributes to member out-of-pocket (OOP) and maximum out-of-pocket (MOOP) accumulation.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Original Claim Number' ;
    rdfs:comment 'Claim number of the original pharmacy claim that this record adjusts or reverses. Populated only for adjusted or reversed claims; null for original claims. Enables claim adjustment chain tracing for financial reconciliation, audit, and CMS Part D encounter data correction submissions.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otherPayerAmount rdf:type rdf:Property ;
    rdfs:label 'Other Payer Amount' ;
    rdfs:comment 'Amount paid by another payer (secondary insurer, Medicare, Medicaid, manufacturer coupon) under coordination of benefits (COB). Used for COB reconciliation, 340B duplicate discount prevention, and CMS Part D TrOOP (True Out-of-Pocket) calculations.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pharmacyChannel rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Channel' ;
    rdfs:comment 'Channel through which the drug was dispensed. Drives cost-sharing differentials, formulary tier rules, and network adequacy reporting. \'retail\' = community pharmacy; \'mail_order\' = 90-day mail service; \'specialty\' = specialty pharmacy for high-cost/complex drugs; \'long_term_care\' = SNF/LTC pharmacy; \'home_infusion\' = infusion therapy at home.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriberNpi rdf:type rdf:Property ;
    rdfs:label 'Prescriber Npi' ;
    rdfs:comment '10-digit National Provider Identifier (NPI) of the prescribing provider as submitted on the pharmacy claim. Denormalized for claim-level auditability, NCPDP D.0 compliance, and CMS Part D encounter data submission. Used for prescriber fraud/waste/abuse (FWA) analytics.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionWrittenDate rdf:type rdf:Property ;
    rdfs:label 'Prescription Written Date' ;
    rdfs:comment 'Date the prescription was written by the prescriber. Used to validate prescription age, enforce days-supply-from-written-date rules, and support medication adherence analytics. Distinct from fill_date (dispensing date).' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityDispensed rdf:type rdf:Property ;
    rdfs:label 'Quantity Dispensed' ;
    rdfs:comment 'Actual quantity of the drug dispensed (e.g., number of tablets, milliliters, grams) as reported by the dispensing pharmacy. Used for quantity limit (QL) edits, drug utilization review (DUR), and CMS Part D encounter data submission.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'NCPDP standard unit of measure code for the quantity dispensed. EA = each (tablets/capsules); ML = milliliters; GM = grams; UN = units; F2 = international units; ME = milliequivalents. Required for accurate quantity limit (QL) edit enforcement and CMS Part D encounter data.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refillNumber rdf:type rdf:Property ;
    rdfs:label 'Refill Number' ;
    rdfs:comment 'Refill sequence number for this dispensing event. Zero (0) indicates the original fill; subsequent values indicate refill number. Used for refill-too-soon edits, medication adherence tracking, and prescription lifecycle management.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectCode rdf:type rdf:Property ;
    rdfs:label 'Reject Code' ;
    rdfs:comment 'NCPDP standard reject code returned by the PBM system when a claim is rejected or denied. Null for paid claims. Used for pharmacy operations, member appeals, and drug utilization review (DUR) outcome tracking. [ENUM-REF-CANDIDATE: promote to reference product — NCPDP reject codes exceed 6 values]' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTax rdf:type rdf:Property ;
    rdfs:label 'Sales Tax' ;
    rdfs:comment 'Sales tax amount applied to the pharmacy claim where applicable by state law. Included in total claim cost and reported separately for financial reconciliation and statutory accounting (SAP) purposes.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepTherapyOverride rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Override' ;
    rdfs:comment 'Indicates whether a step therapy protocol was overridden for this claim (True = override applied). Step therapy requires trying lower-cost drugs before approving higher-cost alternatives. Override requires prior authorization. Used for utilization management (UM) reporting and CMS step therapy compliance.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:catastrophicCoverageIndicator rdf:type rdf:Property ;
    rdfs:label 'Catastrophic Coverage Indicator' ;
    rdfs:comment 'Indicates whether this claim line was adjudicated under the catastrophic coverage phase of the Part D benefit, where the plan pays a higher percentage of drug costs after the member\'s True Out-of-Pocket (TrOOP) threshold is met.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobSequence rdf:type rdf:Property ;
    rdfs:label 'Cob Sequence' ;
    rdfs:comment 'Indicates the payer sequence in a Coordination of Benefits (COB) scenario. 1=primary payer, 2=secondary payer, 3=tertiary payer. Used to correctly apply COB rules and calculate each payer\'s liability on this claim line.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compoundIndicator rdf:type rdf:Property ;
    rdfs:label 'Compound Indicator' ;
    rdfs:comment 'Indicates whether this claim line is part of a compounded drug prescription. When true, multiple ingredient lines will exist under the same claim header, each with its own NDC and ingredient cost.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageGapIndicator rdf:type rdf:Property ;
    rdfs:label 'Coverage Gap Indicator' ;
    rdfs:comment 'Indicates whether this claim line was adjudicated during the Part D coverage gap (donut hole) phase. Used for manufacturer discount program tracking and CMS Part D benefit phase reporting.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispenseAsWrittenCode rdf:type rdf:Property ;
    rdfs:label 'Dispense As Written Code' ;
    rdfs:comment 'NCPDP Dispense As Written (DAW) code indicating whether the prescriber or member requested brand-name dispensing when a generic was available. DAW 0=no product selection indicated, DAW 1=substitution not allowed by prescriber, DAW 2=substitution allowed-patient requested brand. Impacts cost-sharing and GDR calculations.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensedDate rdf:type rdf:Property ;
    rdfs:label 'Dispensed Date' ;
    rdfs:comment 'Date the drug was dispensed to the member at the pharmacy. Represents the real-world service event date used for benefit period calculations, days supply tracking, and CMS Part D reporting.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispensingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Dispensing Fee Amount' ;
    rdfs:comment 'The fee charged by the dispensing pharmacy for the professional service of dispensing the medication. Negotiated as part of PBM network contracts and reported separately from ingredient cost per CMS Part D requirements.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drugCoverageStatus rdf:type rdf:Property ;
    rdfs:label 'Drug Coverage Status' ;
    rdfs:comment 'Coverage determination status for this drug on the applicable formulary at time of adjudication. Indicates whether the drug is covered, non-covered, excluded, subject to step therapy, or requires prior authorization (PA).' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durConflictCode rdf:type rdf:Property ;
    rdfs:label 'Dur Conflict Code' ;
    rdfs:comment 'NCPDP DUR conflict code identifying the type of drug utilization issue detected during adjudication (e.g., drug-drug interaction, drug-disease contraindication, duplicate therapy, high dose). Supports clinical safety monitoring and regulatory DUR reporting. [ENUM-REF-CANDIDATE: promote to reference product for full NCPDP DUR conflict code set]' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillNumber rdf:type rdf:Property ;
    rdfs:label 'Fill Number' ;
    rdfs:comment 'Sequential fill number for this prescription across all fills, including original and all refills. Distinct from refill_number in that it counts total fills rather than refill sequence. Used for prescription lifecycle tracking.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:genericIndicator rdf:type rdf:Property ;
    rdfs:label 'Generic Indicator' ;
    rdfs:comment 'Indicates whether the dispensed drug is a generic equivalent. Used for generic dispensing rate (GDR) reporting, formulary compliance analytics, and PBM performance measurement.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossDrugCostAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Drug Cost Amount' ;
    rdfs:comment 'Total gross cost of the drug on this claim line, calculated as ingredient cost plus dispensing fee plus sales tax plus incentive amount. Used as the basis for CMS Part D gross drug cost reporting and risk corridor calculations.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount' ;
    rdfs:comment 'Incentive or bonus amount paid to the pharmacy for performance-based or preferred network participation on this claim line. Included in gross drug cost calculations for CMS Part D reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingredientCostAmount rdf:type rdf:Property ;
    rdfs:label 'Ingredient Cost Amount' ;
    rdfs:comment 'The drug ingredient cost component of the claim line, representing the cost of the drug itself exclusive of dispensing fee, sales tax, and other charges. Key input for MAC/AWP/WAC-based reimbursement calculations and compound drug cost analysis.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowIncomeSubsidyIndicator rdf:type rdf:Property ;
    rdfs:label 'Low Income Subsidy Indicator' ;
    rdfs:comment 'Indicates whether the member received a Low Income Subsidy (LIS) benefit on this claim line, resulting in reduced cost-sharing. Required for CMS Part D PDE reporting and LIS reconciliation.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturerDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Discount Amount' ;
    rdfs:comment 'Amount of manufacturer discount applied to this claim line under the CMS Part D Coverage Gap Discount Program. Counts toward the member\'s TrOOP and is reported on the PDE record.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patientPayAmount rdf:type rdf:Property ;
    rdfs:label 'Patient Pay Amount' ;
    rdfs:comment 'Total amount paid by the member/patient at point of sale, including copay, coinsurance, and deductible contributions. Used for Out-of-Pocket (OOP) accumulator tracking and Maximum Out-of-Pocket (MOOP) calculations.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdeSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Pde Submission Date' ;
    rdfs:comment 'Date this claim line was submitted to CMS as a Prescription Drug Event (PDE) record for Part D reconciliation and risk adjustment. Null for non-Part D claims. Critical for CMS compliance and audit.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityLimitIndicator rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Indicator' ;
    rdfs:comment 'Indicates whether a quantity limit restriction was applied to this drug claim line during adjudication. When true, the dispensed quantity was subject to plan-defined quantity limit rules.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Date and time when this pharmacy claim line was reversed, if applicable. Null for non-reversed lines. Used for financial reconciliation, audit trails, and identifying reversed claims in PMPM and MLR calculations.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:salesTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Sales Tax Amount' ;
    rdfs:comment 'State or local sales tax applied to this pharmacy claim line where applicable. Reported separately per CMS Part D PDE requirements. Zero or null in states with no drug sales tax.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemClaimLineKey rdf:type rdf:Property ;
    rdfs:label 'Source System Claim Line Key' ;
    rdfs:comment 'Natural key or transaction identifier for this claim line as assigned by the originating PBM system (RxClaim or Argus). Used for lineage tracing, reconciliation with source system, and EDI transaction matching.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyDrugIndicator rdf:type rdf:Property ;
    rdfs:label 'Specialty Drug Indicator' ;
    rdfs:comment 'Indicates whether the drug dispensed on this line is classified as a specialty drug, typically requiring special handling, storage, or administration and subject to specialty pharmacy channel requirements and PA rules.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepTherapyIndicator rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Indicator' ;
    rdfs:comment 'Indicates whether this drug claim line was subject to a step therapy protocol requiring the member to try a preferred or lower-cost drug before coverage of this drug was approved.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trueOopAmount rdf:type rdf:Property ;
    rdfs:label 'True Oop Amount' ;
    rdfs:comment 'Member\'s True Out-of-Pocket (TrOOP) cost contribution from this claim line, used to track progress toward the Part D catastrophic coverage threshold. Includes patient pay and applicable manufacturer discounts.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalPaPriorAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Original Pa Prior Authorization Id' ;
    rdfs:comment 'Reference to the original prior authorization record when this record represents a renewal, appeal, or modification. Enables tracking of the full PA lifecycle chain. Null for initial requests.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriorAuthorization .

ind:paDecisionId rdf:type rdf:Property ;
    rdfs:label 'Pa Decision Id' ;
    rdfs:comment 'Foreign key linking to utilization.pa_decision. Business justification: Needed for compliance reporting that ties each prior authorization to the final decision, supporting regulatory PA decision audit.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaDecision .

ind:paRequestId rdf:type rdf:Property ;
    rdfs:label 'Pa Request Id' ;
    rdfs:comment 'Foreign key linking to utilization.pa_request. Business justification: Required for PA audit report linking each prior authorization record to its originating request, enabling traceability of request-to-authorization lifecycle.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaRequest .

ind:appealIndicator rdf:type rdf:Property ;
    rdfs:label 'Appeal Indicator' ;
    rdfs:comment 'Indicates whether this prior authorization record is associated with a member or prescriber appeal of a prior denial. True = this PA is an appeal case.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedDaysSupply rdf:type rdf:Property ;
    rdfs:label 'Approved Days Supply' ;
    rdfs:comment 'Number of days of drug therapy authorized under this prior authorization. Used by the PBM to enforce dispensing limits and by CMS Part D for compliance reporting.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedQuantity rdf:type rdf:Property ;
    rdfs:label 'Approved Quantity' ;
    rdfs:comment 'Total quantity of the drug authorized for dispensing under this prior authorization (e.g., number of tablets, milliliters, units). Enforced at point-of-sale by the PBM adjudication system.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedRefills rdf:type rdf:Property ;
    rdfs:label 'Approved Refills' ;
    rdfs:comment 'Number of refills authorized under this prior authorization in addition to the initial fill. Enforced by the PBM adjudication system at point-of-sale.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clinicalCriteriaCode rdf:type rdf:Property ;
    rdfs:label 'Clinical Criteria Code' ;
    rdfs:comment 'Code identifying the specific clinical criteria set applied during the prior authorization review, sourced from the Utilization Management system (InterQual or MCG). Used for audit, appeals, and regulatory reporting.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalCriteriaVersion rdf:type rdf:Property ;
    rdfs:label 'Clinical Criteria Version' ;
    rdfs:comment 'Version of the clinical criteria set (InterQual or MCG) applied at the time of the prior authorization decision. Required for audit trails and appeals to ensure the correct criteria version is referenced.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsPartDReportable rdf:type rdf:Property ;
    rdfs:label 'Cms Part D Reportable' ;
    rdfs:comment 'Indicates whether this prior authorization record is subject to CMS Part D PA reporting requirements. True = must be included in CMS Part D PA reporting submissions.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criteriaMet rdf:type rdf:Property ;
    rdfs:label 'Criteria Met' ;
    rdfs:comment 'Indicates whether the submitted clinical information met the applicable clinical criteria (InterQual/MCG) for the requested drug. True = criteria met (supports approval); False = criteria not met (supports denial).' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Exact date and time the prior authorization decision (approval, denial, or pend) was rendered by the clinical reviewer or automated adjudication engine. Used to calculate turnaround time against CMS and URAC standards.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:denialReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Description' ;
    rdfs:comment 'Free-text description of the denial reason, providing clinical or administrative context beyond the denial reason code. Included in member and prescriber denial notices per CMS and state DOI requirements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugTier rdf:type rdf:Property ;
    rdfs:label 'Drug Tier' ;
    rdfs:comment 'Formulary tier of the requested drug at the time of the prior authorization request. Determines cost-sharing obligations and PA criteria applied.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icdDiagnosisCode rdf:type rdf:Property ;
    rdfs:label 'Icd Diagnosis Code' ;
    rdfs:comment 'Primary ICD-10-CM diagnosis code submitted by the prescriber to support the clinical necessity of the requested drug. Required for clinical criteria evaluation and CMS Part D PA reporting. Contains Protected Health Information (PHI).' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Pa Reference Number' ;
    rdfs:comment 'Externally-known, human-readable prior authorization reference number assigned by the Pharmacy Benefit Management (PBM) system (RxClaim or Argus) or Utilization Management (UM) system (InterQual/MCG). Used on Explanation of Benefits (EOB) and communicated to prescribers and pharmacies.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paStatus rdf:type rdf:Property ;
    rdfs:label 'Pa Status' ;
    rdfs:comment 'Current lifecycle status of the prior authorization request. Drives dispensing eligibility at the pharmacy and CMS Part D PA reporting. [ENUM-REF-CANDIDATE: approved|denied|pending|cancelled|expired|appealed — promote to reference product if additional statuses are needed]' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityLimitApplied rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Applied' ;
    rdfs:comment 'Indicates whether a quantity limit restriction was a factor in the prior authorization evaluation. True = quantity limit rules were applied during adjudication.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of the prior authorization request indicating whether it is a new request, renewal of an existing authorization, appeal of a denial, expedited urgent request, or retrospective review.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewLevel rdf:type rdf:Property ;
    rdfs:label 'Review Level' ;
    rdfs:comment 'Level of clinical review applied to the prior authorization request, indicating whether it was reviewed by a pharmacist, physician, peer-to-peer consultation, or medical director. Escalation level affects turnaround time standards.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryDiagnosisCodes rdf:type rdf:Property ;
    rdfs:label 'Secondary Diagnosis Codes' ;
    rdfs:comment 'Pipe-delimited list of secondary ICD-10-CM diagnosis codes submitted to support clinical necessity. Stored as a delimited string per Silver Layer conventions (no ARRAY type). Contains Protected Health Information (PHI).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPaCode rdf:type rdf:Property ;
    rdfs:label 'Source System Pa Code' ;
    rdfs:comment 'Native prior authorization identifier from the originating operational system (RxClaim, Argus, InterQual, or MCG). Preserved for reconciliation, audit, and cross-system traceability in the Silver Layer.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepTherapyCompleted rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Completed' ;
    rdfs:comment 'Indicates whether the member has documented evidence of completing the required step therapy (tried and failed prerequisite drugs) as required by the formulary PA criteria. Populated when step_therapy_required = True.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durAlertId rdf:type rdf:Property ;
    rdfs:label 'Dur Alert Id' ;
    rdfs:comment 'Unique surrogate identifier for each Drug Utilization Review (DUR) alert record generated during pharmacy claim adjudication in the Pharmacy Benefit Management (PBM) system (RxClaim or Argus).' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pbmTransactionId rdf:type rdf:Property ;
    rdfs:label 'Pbm Transaction Id' ;
    rdfs:comment 'Unique transaction identifier assigned by the PBM system (RxClaim or Argus) to the adjudication transaction that generated this DUR alert. Used for cross-system reconciliation and audit trail.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:reviewEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Review Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: DUR alerts are reviewed by a clinical reviewer employee; audit of DUR decisions needs this link.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjudicationOutcome rdf:type rdf:Property ;
    rdfs:label 'Adjudication Outcome' ;
    rdfs:comment 'Final adjudication outcome of the pharmacy claim after the DUR alert was processed. Indicates whether the claim was paid, rejected due to the alert, overridden by the pharmacist or plan, pending review, or reversed.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Generated Timestamp' ;
    rdfs:comment 'Date and time when the DUR alert was generated by the PBM adjudication engine (RxClaim or Argus) during real-time claim processing. Represents the principal business event timestamp for this record.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertStatus rdf:type rdf:Property ;
    rdfs:label 'Alert Status' ;
    rdfs:comment 'Current lifecycle status of the DUR alert record. \'active\'=alert is open and requires action, \'resolved\'=alert addressed and closed, \'overridden\'=pharmacist or plan overrode the alert, \'suppressed\'=alert suppressed per plan rules, \'escalated\'=referred for clinical review.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertTypeCode rdf:type rdf:Property ;
    rdfs:label 'Alert Type Code' ;
    rdfs:comment 'NCPDP standardized code identifying the category of Drug Utilization Review (DUR) alert. Common values: DD=Drug-Drug Interaction, DC=Drug-Disease Contraindication, TD=Therapeutic Duplication, PA=Drug-Allergy, LD=Low Dose, HD=High Dose, MN=Drug-Age, CS=Drug-Gender, AD=Additive Toxicity, RF=Early Refill. [ENUM-REF-CANDIDATE: DD|DC|TD|PA|LD|HD|MN|CS|AD|RF|LR|DS|PG|MC|ID — promote to reference product]' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Alert Type Description' ;
    rdfs:comment 'Human-readable description of the DUR alert type (e.g., \'Drug-Drug Interaction\', \'Therapeutic Duplication\', \'High Dose Alert\', \'Early Refill\'). Complements the alert_type_code for reporting and member communications.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalSignificanceCode rdf:type rdf:Property ;
    rdfs:label 'Clinical Significance Code' ;
    rdfs:comment 'Numeric code from the clinical drug database (First DataBank or Medi-Span) indicating the clinical significance of the drug interaction or contraindication. Ranges from 1 (most severe) to 5 (least severe). Supplements the NCPDP severity_level_code with database-specific grading.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysSinceLastFill rdf:type rdf:Property ;
    rdfs:label 'Days Since Last Fill' ;
    rdfs:comment 'Number of days elapsed since the member\'s last fill of the same or therapeutically equivalent drug. Key metric for early refill DUR alert generation and medication adherence analysis.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispensingDate rdf:type rdf:Property ;
    rdfs:label 'Dispensing Date' ;
    rdfs:comment 'Date on which the drug was dispensed at the pharmacy. Used to correlate the DUR alert with the dispensing event and for retrospective DUR analysis and CMS Part D reporting.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugDatabaseSource rdf:type rdf:Property ;
    rdfs:label 'Drug Database Source' ;
    rdfs:comment 'Identifies the clinical drug knowledge database used to generate the DUR alert (e.g., First DataBank (FDB), Medi-Span, Micromedex, Multum, or custom plan rules). Important for audit, reproducibility, and database version tracking.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugDatabaseVersion rdf:type rdf:Property ;
    rdfs:label 'Drug Database Version' ;
    rdfs:comment 'Version or effective date of the clinical drug knowledge database (e.g., FDB or Medi-Span) used at the time the DUR alert was generated. Required for audit trail and regulatory reproducibility of DUR alert decisions.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durProgramType rdf:type rdf:Property ;
    rdfs:label 'Dur Program Type' ;
    rdfs:comment 'Indicates whether the DUR alert was generated as part of a prospective (point-of-sale, real-time), retrospective (post-dispensing, claims analysis), or concurrent (during hospitalization or ongoing therapy) DUR program.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icdCodeVersion rdf:type rdf:Property ;
    rdfs:label 'Icd Code Version' ;
    rdfs:comment 'Version of the ICD coding system used for the icd_diagnosis_code on this DUR alert record (e.g., ICD-10-CM). Required for accurate clinical coding interpretation and regulatory reporting.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactingDrugName rdf:type rdf:Property ;
    rdfs:label 'Interacting Drug Name' ;
    rdfs:comment 'Brand or generic name of the interacting drug involved in a drug-drug interaction or therapeutic duplication alert. Provides human-readable context for pharmacist review and DUR reporting without requiring a drug master lookup.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactingDrugNdc rdf:type rdf:Property ;
    rdfs:label 'Interacting Drug Ndc' ;
    rdfs:comment '11-digit NDC of the second drug involved in a drug-drug interaction (DDI) or therapeutic duplication DUR alert. Populated when alert_type_code indicates a drug-drug conflict. Null for non-interaction alert types.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncpdpDurCode rdf:type rdf:Property ;
    rdfs:label 'Ncpdp Dur Code' ;
    rdfs:comment 'Two-character NCPDP standardized DUR conflict code transmitted in the pharmacy claim transaction (Field 439-E4). Identifies the specific clinical conflict detected (e.g., \'DD\' for drug-drug interaction). Required for CMS Part D DUR reporting.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncpdpRejectCode rdf:type rdf:Property ;
    rdfs:label 'Ncpdp Reject Code' ;
    rdfs:comment 'Two-digit NCPDP reject code returned when the DUR alert results in a claim rejection (e.g., \'88\'=DUR Reject Error). Populated when adjudication_outcome is \'rejected\'. Used for claim denial tracking and appeals.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideCode rdf:type rdf:Property ;
    rdfs:label 'Override Code' ;
    rdfs:comment 'Two-character NCPDP code submitted by the pharmacist to override a DUR alert and allow dispensing (e.g., \'OO\'=Other Override, \'OP\'=Prescriber Override, \'OR\'=Pharmacist Override). Populated when adjudication_outcome is \'overridden\'.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideComment rdf:type rdf:Property ;
    rdfs:label 'Override Comment' ;
    rdfs:comment 'Free-text clinical justification or pharmacist notes entered when overriding a DUR alert. Documents the clinical rationale for proceeding with dispensing despite the alert. Supports audit and retrospective DUR review.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pa Required Flag' ;
    rdfs:comment 'Indicates whether the DUR alert outcome requires a Prior Authorization (PA) to be obtained before the drug can be dispensed. True when the alert triggers a PA requirement per plan formulary or step therapy rules.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prescribedQuantity rdf:type rdf:Property ;
    rdfs:label 'Prescribed Quantity' ;
    rdfs:comment 'Quantity of the drug as written on the original prescription by the prescriber. Compared against quantity_dispensed and plan quantity limits in DUR alert evaluation.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:professionalServiceCode rdf:type rdf:Property ;
    rdfs:label 'Professional Service Code' ;
    rdfs:comment 'Two-character NCPDP code (Field 440-E5) indicating the professional service performed by the pharmacist in response to the DUR alert (e.g., \'AS\'=Patient Assessment, \'CC\'=Coordination of Care, \'DE\'=Dosing Evaluation, \'PM\'=Patient Medication Education). Required for CMS Part D DUR reporting.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityLimitFlag rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Flag' ;
    rdfs:comment 'Indicates whether the DUR alert was triggered by a quantity limit edit, where the dispensed or prescribed quantity exceeds the plan\'s maximum allowable quantity for the drug.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reasonForServiceCode rdf:type rdf:Property ;
    rdfs:label 'Reason For Service Code' ;
    rdfs:comment 'Two-character NCPDP code (Field 439-E4 context) providing the clinical reason for the DUR service intervention. Captures the specific clinical basis for the alert and pharmacist action. Used in prospective DUR programs.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultOfServiceCode rdf:type rdf:Property ;
    rdfs:label 'Result Of Service Code' ;
    rdfs:comment 'Two-character NCPDP code (Field 441-E6) indicating the outcome of the pharmacist\'s intervention in response to the DUR alert (e.g., \'FA\'=Filled As Is, \'FN\'=Filled with Prescriber Approval, \'FC\'=Filled, Calling Prescriber, \'FD\'=Filled, Directions Clarified). Required for CMS Part D DUR reporting.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevelCode rdf:type rdf:Property ;
    rdfs:label 'Severity Level Code' ;
    rdfs:comment 'Coded severity level of the DUR alert indicating clinical significance. Typically: 1=Contraindicated/Severe, 2=Major, 3=Moderate, 4=Minor, 5=Informational. Drives pharmacist override requirements and adjudication workflow.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevelDescription rdf:type rdf:Property ;
    rdfs:label 'Severity Level Description' ;
    rdfs:comment 'Plain-language description of the DUR alert severity level (e.g., \'Contraindicated\', \'Major\', \'Moderate\', \'Minor\', \'Informational\'). Used in pharmacist-facing displays and DUR reporting dashboards.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepTherapyFlag rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Flag' ;
    rdfs:comment 'Indicates whether the DUR alert is related to a step therapy protocol violation, where the member has not tried a required first-line drug before the prescribed drug. Supports step therapy enforcement and CMS Part D reporting.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baaId rdf:type rdf:Property ;
    rdfs:label 'Baa Id' ;
    rdfs:comment 'Foreign key linking to compliance.baa. Business justification: BAA management: each dispensing pharmacy must have a Business Associate Agreement for PHI handling; compliance tracks BAAs per pharmacy.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Baa .

ind:pharmacyCredentialRecordId rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Credential Record Id' ;
    rdfs:comment 'Foreign key linking to credential.credential_record. Business justification: Network participation reports need each pharmacy\'s verified credential record; FK provides authoritative license/DEA data for compliance audits.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Record .

ind:acceptsElectronicPrescriptions rdf:type rdf:Property ;
    rdfs:label 'Accepts Electronic Prescriptions' ;
    rdfs:comment 'Indicates whether the pharmacy is enabled to receive electronic prescriptions (e-prescribing) via NCPDP SCRIPT standard. Required for controlled substance e-prescribing (EPCS) compliance in many states.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:awpDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Awp Discount Percent' ;
    rdfs:comment 'The contracted discount percentage applied to the AWP for brand drug ingredient cost reimbursement. For example, AWP minus 15% means awp_discount_percent = 15.00. Applies when ingredient_cost_basis is \'awp_discount\'. Commercially sensitive contract term.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chainIndependentFlag rdf:type rdf:Property ;
    rdfs:label 'Chain Independent Flag' ;
    rdfs:comment 'Indicates whether the pharmacy is part of a chain organization (e.g., CVS, Walgreens, Rite Aid) or operates as an independent pharmacy. Affects contract terms, reimbursement rates, and network tier assignment.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chainOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Chain Organization Name' ;
    rdfs:comment 'Name of the parent chain organization if the pharmacy is a chain location (e.g., CVS Health, Walgreens Boots Alliance). Null for independent pharmacies. Used for chain-level contract management and performance reporting.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainCertified rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Certified' ;
    rdfs:comment 'Indicates whether the pharmacy holds cold chain certification for temperature-sensitive drug storage and shipping (e.g., biologics, insulin, vaccines). Required for specialty and mail-order pharmacies dispensing refrigerated or frozen medications.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Indicates whether the pharmacy reimbursement contract is negotiated directly with the health plan (direct) or administered through the PBM intermediary (PBM-administered). Affects financial settlement, audit rights, and MAC list applicability.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensingStateCode rdf:type rdf:Property ;
    rdfs:label 'Dispensing State Code' ;
    rdfs:comment 'Two-letter USPS state code of the state in which the pharmacy is licensed to dispense. May differ from the physical address state for mail-order pharmacies licensed in multiple states. Used for state-level regulatory compliance and claim adjudication.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientCostBasis rdf:type rdf:Property ;
    rdfs:label 'Ingredient Cost Basis' ;
    rdfs:comment 'The pricing benchmark used to calculate ingredient cost reimbursement for drug claims. AWP (Average Wholesale Price) discount is most common for brand drugs; MAC (Maximum Allowable Cost) applies to generics; WAC (Wholesale Acquisition Cost) and NADAC (National Average Drug Acquisition Cost) are alternative benchmarks. Sourced from PBM contract terms in RxClaim/Argus.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mailOrderCapable rdf:type rdf:Property ;
    rdfs:label 'Mail Order Capable' ;
    rdfs:comment 'Indicates whether the pharmacy is certified and operationally capable of fulfilling mail-order prescriptions (90-day supply, home delivery). Drives claim routing and member benefit design enforcement.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ncpdpChainCode rdf:type rdf:Property ;
    rdfs:label 'Ncpdp Chain Code' ;
    rdfs:comment 'NCPDP-assigned 4-digit chain code identifying the pharmacy chain organization. Used for chain-level contract application and bulk reimbursement rate assignment in the PBM system.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncpdpProviderNumber rdf:type rdf:Property ;
    rdfs:label 'Ncpdp Provider Number' ;
    rdfs:comment 'The 7-digit NCPDP pharmacy identifier (formerly NABP number) used as the primary pharmacy identifier in PBM claim transactions, formulary lookups, and pharmacy network directories. Sourced from RxClaim or Argus PBM system.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkParticipationStatus rdf:type rdf:Property ;
    rdfs:label 'Network Participation Status' ;
    rdfs:comment 'Current status of the pharmacy\'s participation in the PBM network. Drives real-time claim adjudication eligibility checks in RxClaim/Argus. Active pharmacies are eligible to dispense covered drugs; inactive/terminated pharmacies are rejected at point-of-sale.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceAuditProvision rdf:type rdf:Property ;
    rdfs:label 'Performance Audit Provision' ;
    rdfs:comment 'Indicates whether the pharmacy contract includes audit provisions allowing the PBM or health plan to conduct on-site or desk audits of dispensing records, pricing, and compliance. Required for CMS Part D sponsor oversight obligations.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pharmacyName rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Name' ;
    rdfs:comment 'Legal business name of the dispensing pharmacy as registered with the state board of pharmacy and NCPDP. Used in member-facing communications, EOB documents, and provider directory.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyType rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Type' ;
    rdfs:comment 'Classification of the pharmacy by dispensing channel and operational model. Drives claim routing, reimbursement logic, and formulary applicability within the PBM system (RxClaim/Argus). [ENUM-REF-CANDIDATE: retail|mail_order|specialty|long_term_care|compounding — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Required Flag' ;
    rdfs:comment 'Indicates whether the pharmacy requires patient or authorized representative signature upon delivery for mail-order or specialty drug shipments. Relevant for controlled substances and high-value specialty medications.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialtyAccreditationCode rdf:type rdf:Property ;
    rdfs:label 'Specialty Accreditation Code' ;
    rdfs:comment 'Accreditation body certification held by the pharmacy for specialty drug dispensing. URAC, ACHC, and NABP PCAB are the primary specialty pharmacy accreditation bodies recognized by health plans and PBMs. Required for specialty network participation. [ENUM-REF-CANDIDATE: urac|achc|jcaho|nabp_pcab|none — promote to reference product if multi-accreditation tracking is needed]' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:twentyFourHourFlag rdf:type rdf:Property ;
    rdfs:label 'Twenty Four Hour Flag' ;
    rdfs:comment 'Indicates whether the pharmacy operates 24 hours per day, 7 days per week. Used for network adequacy reporting and member access analysis, particularly for CMS Part D access requirements.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Contract management assigns a manager employee; needed for performance monitoring and audit of PBM contracts.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:pbmVendorId rdf:type rdf:Property ;
    rdfs:label 'Pbm Vendor Id' ;
    rdfs:comment 'Reference identifier for the PBM vendor organization in the health plan\'s vendor or trading partner master. Supports linking to vendor management records for credentialing and payment.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or addendum executed against this PBM contract. Null if no amendments have been made since original execution. Used to track contract evolution and ensure current terms are applied in adjudication.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'Contractually specified frequency at which the health plan may exercise audit rights over the PBM. Relevant only when audit_rights_flag is True. Drives compliance calendar and vendor oversight scheduling.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Flag' ;
    rdfs:comment 'Indicates whether the health plan has contractual audit rights to inspect PBM financial records, rebate calculations, MAC list pricing, and claims adjudication data. True = audit rights granted; False = not included. Critical for compliance and financial oversight.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the PBM contract automatically renews at the end of the contract term unless notice of termination is provided. True = auto-renews; False = requires affirmative renewal action.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:awpDiscountMailPct rdf:type rdf:Property ;
    rdfs:label 'Awp Discount Mail Pct' ;
    rdfs:comment 'Contracted discount percentage off AWP (Average Wholesale Price) applied to drug ingredient cost reimbursement at mail-order pharmacies. Typically deeper than retail AWP discounts due to mail-order volume.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awpDiscountRetailPct rdf:type rdf:Property ;
    rdfs:label 'Awp Discount Retail Pct' ;
    rdfs:comment 'Contracted discount percentage off AWP (Average Wholesale Price) applied to brand and generic drug ingredient cost reimbursement at retail pharmacies. A core financial term in PBM contracts (e.g., AWP minus 18% for generics).' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractName rdf:type rdf:Property ;
    rdfs:label 'Contract Name' ;
    rdfs:comment 'Descriptive name of the PBM contract (e.g., \'Express Scripts ASO Agreement FY2024\'). Used for display in reporting dashboards and contract management workflows.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known, human-readable contract reference number assigned by the health plan or PBM vendor at execution. Used for correspondence, audits, and regulatory filings. Maps to the contract identifier in RxClaim or Argus PBM system.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractOwnerName rdf:type rdf:Property ;
    rdfs:label 'Contract Owner Name' ;
    rdfs:comment 'Name of the health plan employee or department responsible for managing this PBM contract relationship. Used for escalation routing, audit coordination, and vendor governance.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractVersion rdf:type rdf:Property ;
    rdfs:label 'Contract Version' ;
    rdfs:comment 'Version identifier for the PBM contract document, incremented with each amendment or renewal (e.g., \'1.0\', \'2.1\', \'Amendment_3\'). Supports contract lifecycle management and audit trail for regulatory examinations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensingFeeMailOrder rdf:type rdf:Property ;
    rdfs:label 'Dispensing Fee Mail Order' ;
    rdfs:comment 'Contracted dispensing fee in USD paid per prescription claim fulfilled through mail-order pharmacy channels under this PBM contract. Typically lower than retail due to volume efficiencies.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispensingFeeRetail rdf:type rdf:Property ;
    rdfs:label 'Dispensing Fee Retail' ;
    rdfs:comment 'Contracted dispensing fee in USD paid to retail network pharmacies per prescription claim under this PBM contract. Part of the pharmacy reimbursement formula alongside ingredient cost (AWP/WAC/MAC).' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispensingFeeSpecialty rdf:type rdf:Property ;
    rdfs:label 'Dispensing Fee Specialty' ;
    rdfs:comment 'Contracted dispensing fee in USD paid per specialty drug prescription claim under this PBM contract. Specialty pharmacy dispensing fees are negotiated separately due to the high-cost, high-touch nature of specialty drugs.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Dur Program Flag' ;
    rdfs:comment 'Indicates whether Drug Utilization Review (DUR) — including prospective, concurrent, and retrospective DUR — is included as a service under this PBM contract. True = DUR services included; False = not included.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genericDispensingRateGuarantee rdf:type rdf:Property ;
    rdfs:label 'Generic Dispensing Rate Guarantee' ;
    rdfs:comment 'Contractually guaranteed minimum generic dispensing rate (GDR) as a percentage of total prescription claims. If the PBM fails to achieve this rate, financial penalties or credits apply. Key cost-management metric in PBM contracts.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingStateCode rdf:type rdf:Property ;
    rdfs:label 'Governing State Code' ;
    rdfs:comment 'Two-letter US state code of the state whose laws govern this PBM contract for dispute resolution and regulatory compliance purposes. Relevant for state DOI oversight, MAC transparency laws, and PBM regulation.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lobScope rdf:type rdf:Property ;
    rdfs:label 'Lob Scope' ;
    rdfs:comment 'Line of Business (LOB) covered under this PBM contract. Determines which member populations and benefit programs are governed by this agreement. A single contract may cover one or multiple LOBs. [ENUM-REF-CANDIDATE: commercial|medicare_part_d|medicaid|exchange|all — promote to reference product for multi-LOB support]' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macListReference rdf:type rdf:Property ;
    rdfs:label 'Mac List Reference' ;
    rdfs:comment 'Identifier or name of the MAC (Maximum Allowable Cost) list applied under this PBM contract for generic and multi-source drug reimbursement. MAC lists cap reimbursement for generics below AWP. References the specific MAC list version maintained by the PBM.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Mail Order Flag' ;
    rdfs:comment 'Indicates whether mail-order pharmacy dispensing services are included in the scope of this PBM contract. True = mail order included; False = retail-only or carved out.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mailOrderPenetrationGuarantee rdf:type rdf:Property ;
    rdfs:label 'Mail Order Penetration Guarantee' ;
    rdfs:comment 'Contractually guaranteed minimum mail-order pharmacy utilization rate as a percentage of eligible maintenance drug claims. Drives cost savings through mail-order channel incentives.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceGuaranteeFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee Flag' ;
    rdfs:comment 'Indicates whether the PBM contract includes financial performance guarantees (e.g., generic dispensing rate, mail-order penetration, member satisfaction scores). True = performance guarantees included; False = not included.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorAuthFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Auth Flag' ;
    rdfs:comment 'Indicates whether prior authorization (PA) requirements for specialty and non-formulary drugs are administered by the PBM under this contract. True = PBM manages PA; False = health plan manages PA internally.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rebateGuaranteePmpm rdf:type rdf:Property ;
    rdfs:label 'Rebate Guarantee Pmpm' ;
    rdfs:comment 'Contractually guaranteed minimum rebate amount expressed as Per Member Per Month (PMPM) in USD that the PBM must remit to the health plan. A key financial performance guarantee in PBM contracts. Used for actuarial reserving and financial reconciliation.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebatePassThroughPct rdf:type rdf:Property ;
    rdfs:label 'Rebate Pass Through Pct' ;
    rdfs:comment 'Percentage of manufacturer drug rebates that the PBM is contractually obligated to pass through to the health plan (e.g., 100% pass-through vs. spread-based retention). Critical for MLR (Medical Loss Ratio) calculations and CMS Part D compliance.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateReconciliationLagDays rdf:type rdf:Property ;
    rdfs:label 'Rebate Reconciliation Lag Days' ;
    rdfs:comment 'Number of calendar days after the close of a settlement period within which the PBM must provide rebate invoices and supporting data to the health plan. Used for financial close scheduling and IBNR reserve calculations.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateSettlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Rebate Settlement Frequency' ;
    rdfs:comment 'Contractually specified frequency at which the PBM remits drug manufacturer rebates to the health plan. Drives cash flow forecasting, accounts receivable management, and actuarial IBNR (Incurred But Not Reported) rebate estimates.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days prior to contract termination_date by which either party must provide written notice of intent not to renew. Operationally critical for contract management and vendor transitions.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialtyPharmacyFlag rdf:type rdf:Property ;
    rdfs:label 'Specialty Pharmacy Flag' ;
    rdfs:comment 'Indicates whether specialty pharmacy benefit management (high-cost biologics, specialty injectables) is within the scope of this PBM contract. True = specialty pharmacy included; False = carved out or not applicable.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drugRebateId rdf:type rdf:Property ;
    rdfs:label 'Drug Rebate Id' ;
    rdfs:comment 'Unique surrogate identifier for each drug manufacturer rebate record in the pharmacy benefit management system. Primary key for the drug_rebate data product.' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedRebateAmount rdf:type rdf:Property ;
    rdfs:label 'Calculated Rebate Amount' ;
    rdfs:comment 'Rebate amount computed by applying the contracted rebate rate to the utilization units and applicable price benchmark. Represents the expected receivable before invoicing.' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedRebateRate rdf:type rdf:Property ;
    rdfs:label 'Contracted Rebate Rate' ;
    rdfs:comment 'Negotiated rebate rate expressed as a decimal percentage of Average Wholesale Price (AWP) or Wholesale Acquisition Cost (WAC) per the PBM contract terms. Confidential as it reflects proprietary pricing agreements.' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text or coded reason for a rebate dispute when reconciliation_status is \'disputed\'. Captures manufacturer objections, utilization data discrepancies, or contract interpretation differences.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date on which a disputed rebate was formally resolved. Null if no dispute exists or dispute is still open.' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'Oracle Financials General Ledger account code to which the rebate receivable or cash receipt is posted. Supports financial close and statutory reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date on which the rebate invoice was issued to the manufacturer or PBM. Marks the start of the payment due window per contract terms.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'Rebate amount formally invoiced to the manufacturer or PBM for the period. May differ from calculated amount due to adjustments, disputes, or rounding.' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Legal name of the pharmaceutical manufacturer obligated to pay the rebate. Retained on the transaction for reporting and reconciliation without requiring a join.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSharePct rdf:type rdf:Property ;
    rdfs:label 'Market Share Pct' ;
    rdfs:comment 'Drug\'s market share within its therapeutic class during the rebate period, expressed as a decimal percentage. Used to determine market share rebate tier attainment per contract.' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mlrRebateCategory rdf:type rdf:Property ;
    rdfs:label 'Mlr Rebate Category' ;
    rdfs:comment 'Classification of the rebate for ACA Medical Loss Ratio (MLR) reporting purposes: medical_cost_reduction (reduces incurred claims), quality_improvement (allocated to QI activities), or excluded (not counted in MLR numerator).' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partDIndicator rdf:type rdf:Property ;
    rdfs:label 'Part D Indicator' ;
    rdfs:comment 'Indicates whether this rebate is subject to CMS Part D rebate pass-through requirements. True for Medicare Part D covered drugs; False for commercial or Medicaid lines of business.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passThroughAmount rdf:type rdf:Property ;
    rdfs:label 'Pass Through Amount' ;
    rdfs:comment 'Portion of the received rebate amount that must be passed through to CMS or plan members per Part D or ACA requirements. Critical for MLR and CMS DIR (Direct and Indirect Remuneration) reporting.' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date on which the rebate payment was actually received and posted. Null if payment has not yet been received.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceTargetMetIndicator rdf:type rdf:Property ;
    rdfs:label 'Performance Target Met Indicator' ;
    rdfs:comment 'Indicates whether the contractual performance target (e.g., market share threshold, utilization goal) was met during the rebate period, triggering performance rebate eligibility.' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorAuthRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Prior Auth Required Indicator' ;
    rdfs:comment 'Indicates whether prior authorization was required for the drug during the rebate period. PA requirements can affect utilization volumes and rebate performance thresholds.' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rebateInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Rebate Invoice Number' ;
    rdfs:comment 'Externally-known invoice number assigned by the PBM or manufacturer for this rebate billing cycle. Used for reconciliation with accounts receivable and PBM remittance.' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebatePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Rebate Period End Date' ;
    rdfs:comment 'Last day of the rebate performance or utilization measurement period for which this rebate invoice applies.' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebatePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Rebate Period Start Date' ;
    rdfs:comment 'First day of the rebate performance or utilization measurement period (typically a calendar quarter) for which this rebate invoice applies.' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateRateBasis rdf:type rdf:Property ;
    rdfs:label 'Rebate Rate Basis' ;
    rdfs:comment 'Price benchmark on which the contracted rebate rate is applied: Average Wholesale Price (AWP), Wholesale Acquisition Cost (WAC), Maximum Allowable Cost (MAC), or net price.' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateType rdf:type rdf:Property ;
    rdfs:label 'Rebate Type' ;
    rdfs:comment 'Classification of the rebate by its contractual basis: base (standard formulary placement), performance (quality/utilization targets), market_share (volume threshold), formulary_access (preferred tier), inflation (price increase above CPI), or supplemental (ad hoc negotiated). [ENUM-REF-CANDIDATE: base|performance|market_share|formulary_access|inflation|supplemental — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedAmount rdf:type rdf:Property ;
    rdfs:label 'Received Amount' ;
    rdfs:comment 'Actual cash amount received from the manufacturer or PBM for this rebate invoice. Used for cash reconciliation and MLR reporting.' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationClaimsCount rdf:type rdf:Property ;
    rdfs:label 'Utilization Claims Count' ;
    rdfs:comment 'Number of pharmacy claims adjudicated for the drug during the rebate period. Used to validate utilization units and support audit of rebate calculations.' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utilizationUnits rdf:type rdf:Property ;
    rdfs:label 'Utilization Units' ;
    rdfs:comment 'Total dispensed units (e.g., tablets, milliliters, grams) of the drug during the rebate period, as reported to the manufacturer for rebate calculation. Sourced from PBM claims data.' ;
    rdfs:domain ind:DrugRebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Difference between the invoiced amount and the received amount. A non-zero variance triggers reconciliation or dispute resolution workflows.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialtyDrugProgramId rdf:type rdf:Property ;
    rdfs:label 'Specialty Drug Program Id' ;
    rdfs:comment 'Unique surrogate identifier for the specialty drug program record. Primary key for this entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pbmProgramId rdf:type rdf:Property ;
    rdfs:label 'Pbm Program Id' ;
    rdfs:comment 'Source system identifier for this program as assigned by the PBM system (RxClaim or Argus). Used for reconciliation between the lakehouse and the operational PBM system.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:programManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Specialty drug programs are overseen by a program manager employee; required for program governance and reporting.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accumulatorAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Accumulator Adjustment Flag' ;
    rdfs:comment 'Indicates whether the Copay Accumulator Adjustment Program (CAAP) applies to this specialty drug program. When true, manufacturer copay assistance payments do NOT count toward the member\'s deductible or Maximum Out-of-Pocket (MOOP). Critical for CMS Part D compliance.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clinicalManagementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Clinical Management Required Flag' ;
    rdfs:comment 'Indicates whether drugs in this program require active clinical management, including disease management, case management, or care coordination through the Care Management Platform (Casenet TruCare or Altruista).' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmsPartDSpecialtyTierFlag rdf:type rdf:Property ;
    rdfs:label 'Cms Part D Specialty Tier Flag' ;
    rdfs:comment 'Indicates whether this program is reportable to CMS under the Part D specialty tier requirements. Drives inclusion in CMS Part D formulary submissions and Star Ratings (STAR) calculations.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coldChainRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required Flag' ;
    rdfs:comment 'Indicates whether drugs in this program require temperature-controlled cold chain handling and storage during dispensing and shipping. Drives specialty pharmacy network eligibility and logistics requirements.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copayAssistanceFlag rdf:type rdf:Property ;
    rdfs:label 'Copay Assistance Flag' ;
    rdfs:comment 'Indicates whether a manufacturer-sponsored copay assistance program (copay card) is available for drugs in this specialty program. Triggers copay accumulator adjustment program (CAAP) evaluation logic.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copayAssistanceMaxBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Assistance Max Benefit Amount' ;
    rdfs:comment 'Maximum dollar amount of manufacturer copay assistance benefit available to a member per program year under this specialty drug program. Used in accumulator adjustment calculations and OOP tracking.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayAssistanceProgramName rdf:type rdf:Property ;
    rdfs:label 'Copay Assistance Program Name' ;
    rdfs:comment 'Name of the manufacturer-sponsored copay assistance program (e.g., copay card program) associated with this specialty drug program. Used for affordability program tracking and OIG compliance reporting.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drugUtilizationReviewType rdf:type rdf:Property ;
    rdfs:label 'Drug Utilization Review Type' ;
    rdfs:comment 'Type of Drug Utilization Review (DUR) applied to claims under this specialty program. Prospective DUR occurs at point-of-sale; retrospective DUR occurs post-adjudication for quality and safety analysis.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foundationGrantFlag rdf:type rdf:Property ;
    rdfs:label 'Foundation Grant Flag' ;
    rdfs:comment 'Indicates whether independent charitable foundation grants are available to assist members with cost-sharing obligations for drugs in this specialty program. Foundation grants may or may not count toward OOP accumulators depending on CMS guidance.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hubServicesEnrollmentFlag rdf:type rdf:Property ;
    rdfs:label 'Hub Services Enrollment Flag' ;
    rdfs:comment 'Indicates whether members must enroll in a manufacturer-sponsored hub services program to access drugs under this specialty program. Hub services may include patient support, adherence programs, and financial assistance coordination.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icdConditionCodes rdf:type rdf:Property ;
    rdfs:label 'Icd Condition Codes' ;
    rdfs:comment 'Comma-delimited list of ICD-10-CM diagnosis codes representing the covered clinical conditions for which drugs in this program are indicated. Used for prior authorization (PA) criteria and medical necessity determination.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitedDistributionFlag rdf:type rdf:Property ;
    rdfs:label 'Limited Distribution Flag' ;
    rdfs:comment 'Indicates whether the drugs in this program are classified as Limited Distribution Drugs (LDD), available only through a restricted network of specialty pharmacies designated by the manufacturer.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mailOrderAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Mail Order Allowed Flag' ;
    rdfs:comment 'Indicates whether drugs in this program may be dispensed via mail-order pharmacy channels in addition to retail specialty pharmacies.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxDaysSupply rdf:type rdf:Property ;
    rdfs:label 'Max Days Supply' ;
    rdfs:comment 'Maximum number of days supply permitted per dispensing event for specialty drugs under this program. Typically 30 days for specialty drugs per CMS Part D guidance. Enforced at PBM adjudication.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oopAccumulatorAppliesFlag rdf:type rdf:Property ;
    rdfs:label 'Oop Accumulator Applies Flag' ;
    rdfs:comment 'Indicates whether third-party assistance payments (copay cards, foundation grants) applied to this program count toward the member\'s Out-of-Pocket (OOP) and Maximum Out-of-Pocket (MOOP) accumulators. Governs accumulator adjustment compliance.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientAssistanceProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Patient Assistance Program Flag' ;
    rdfs:comment 'Indicates whether a manufacturer-sponsored Patient Assistance Program (PAP) is available for uninsured or underinsured members enrolled in this specialty drug program.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorAuthRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Auth Required Flag' ;
    rdfs:comment 'Indicates whether Prior Authorization (PA) is required for all drugs covered under this specialty program before dispensing. Drives integration with the Utilization Management (UM) system (InterQual or MCG).' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the specialty drug program within the Pharmacy Benefit Management (PBM) system (RxClaim or Argus). Used in EDI transactions and CMS Part D reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Detailed narrative description of the specialty drug program, including clinical rationale, covered conditions, and program objectives. Used in plan documents, Summary of Benefits and Coverage (SBC), and member communications.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Human-readable name of the specialty drug program (e.g., \'Oncology Specialty Tier Program\', \'Rheumatology Hub Services Program\'). Used in member-facing communications and plan documents.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle state of the specialty drug program. Controls whether the program is available for member enrollment and claim adjudication.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the specialty drug program by its primary operational function. Drives downstream adjudication logic and reporting segmentation. [ENUM-REF-CANDIDATE: specialty_tier|hub_services|copay_assistance|patient_assistance|rems|cold_chain|limited_distribution — promote to reference product]' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rems Required Flag' ;
    rdfs:comment 'Indicates whether the specialty drugs in this program are subject to an FDA-mandated Risk Evaluation and Mitigation Strategy (REMS). When true, dispensing requires REMS-certified pharmacy and prescriber enrollment.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialtyDrugListName rdf:type rdf:Property ;
    rdfs:label 'Specialty Drug List Name' ;
    rdfs:comment 'Name of the specialty drug list (SDL) associated with this program, identifying the set of National Drug Codes (NDCs) covered under the program. Managed in the PBM formulary system.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyPharmacyNetworkName rdf:type rdf:Property ;
    rdfs:label 'Specialty Pharmacy Network Name' ;
    rdfs:comment 'Name of the specialty pharmacy network designated to dispense drugs under this program. Defines the restricted network of pharmacies eligible to fill specialty prescriptions.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyTierDesignation rdf:type rdf:Property ;
    rdfs:label 'Specialty Tier Designation' ;
    rdfs:comment 'Formulary tier designation assigned to specialty drugs in this program. Determines member cost-sharing obligations and CMS Part D specialty tier reporting requirements.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepTherapyRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Required Flag' ;
    rdfs:comment 'Indicates whether step therapy protocols are enforced for drugs in this program, requiring members to try and fail on preferred therapies before accessing specialty drugs. Governed by state step therapy laws and CMS guidance.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:therapeuticCategory rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Category' ;
    rdfs:comment 'Primary therapeutic or disease category associated with the specialty drugs in this program (e.g., Oncology, Rheumatology, Multiple Sclerosis, HIV/AIDS). Used for clinical reporting, HEDIS measures, and population health analytics.' ;
    rdfs:domain ind:SpecialtyDrugProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wacDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Wac Discount Pct' ;
    rdfs:comment 'Contracted discount percentage applied to the Wholesale Acquisition Cost (WAC) for specialty drugs in this program. Used as an alternative pricing basis to AWP in PBM contract negotiations.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mtmServiceId rdf:type rdf:Property ;
    rdfs:label 'Mtm Service Id' ;
    rdfs:comment 'Primary key for mtm_service' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mtmProgramId rdf:type rdf:Property ;
    rdfs:label 'Mtm Program Id' ;
    rdfs:comment 'Identifier for the specific MTM program offering under which this service was delivered. A plan sponsor may operate multiple MTM programs targeting different chronic condition cohorts.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:chronicConditionCount rdf:type rdf:Property ;
    rdfs:label 'Chronic Condition Count' ;
    rdfs:comment 'Number of qualifying chronic conditions the member has at the time of MTM eligibility determination. CMS Part D MTM eligibility requires a minimum number of chronic conditions (typically 2-3 depending on plan criteria). Used for eligibility validation and population stratification.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cmrCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Cmr Completion Date' ;
    rdfs:comment 'Date on which the annual Comprehensive Medication Review (CMR) was completed for the member. CMS requires at least one CMR per calendar year for all enrolled MTM beneficiaries. Directly drives the CMS STAR Ratings MTM CMR Completion Rate measure.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cmsReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Cms Reporting Period' ;
    rdfs:comment 'CMS Part D reporting period to which this MTM service record is attributed (e.g., 2024-Q1, 2024-ANNUAL). Used for CMS Part D MTM program reporting submissions and STAR ratings measurement year alignment.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Contact Attempt Count' ;
    rdfs:comment 'Total number of outreach attempts made to the member to schedule or deliver the MTM service. CMS requires documentation of good-faith efforts to reach enrolled members. Used for compliance audits and outreach effectiveness analytics.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disenrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Disenrollment Date' ;
    rdfs:comment 'Date on which the member was disenrolled or opted out of the MTM program. Null if the member remains enrolled. Used to track program retention and calculate MTM completion rates.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugTherapyProblemType rdf:type rdf:Property ;
    rdfs:label 'Drug Therapy Problem Type' ;
    rdfs:comment 'Primary category of drug therapy problem identified during the MTM service. Common types include: unnecessary drug therapy, needs additional drug therapy, ineffective drug, dosage too low, dosage too high, adverse drug reaction, non-adherence. [ENUM-REF-CANDIDATE: UNNECESSARY_DRUG|NEEDS_ADDITIONAL_DRUG|INEFFECTIVE_DRUG|DOSE_TOO_LOW|DOSE_TOO_HIGH|ADVERSE_REACTION|NON_ADHERENCE|NONE — promote to reference product]' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Determination Date' ;
    rdfs:comment 'Date on which the member was determined to be eligible for the MTM program based on CMS Part D criteria (multiple chronic conditions, multiple Part D drugs, likely to incur annual costs above the CMS threshold).' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date on which the eligible member was enrolled into the MTM program. CMS requires auto-enrollment of all eligible beneficiaries with opt-out capability.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedAnnualDrugCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Drug Cost' ;
    rdfs:comment 'Estimated annual cost of Part D covered drugs for the member at the time of MTM eligibility determination. CMS requires members likely to incur annual drug costs above the established threshold to be enrolled. Expressed in USD.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Scheduled or actual date of the follow-up contact or service following the MTM encounter. Null if no follow-up is required or scheduled. Used to track closure of open MAP items and clinical recommendations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpStatus rdf:type rdf:Property ;
    rdfs:label 'Follow Up Status' ;
    rdfs:comment 'Current status of the follow-up action required after the MTM service. PENDING = follow-up scheduled but not yet completed; COMPLETED = follow-up successfully conducted; DECLINED = member declined follow-up; UNREACHABLE = member could not be contacted for follow-up; NOT_REQUIRED = no follow-up needed.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interventionCount rdf:type rdf:Property ;
    rdfs:label 'Intervention Count' ;
    rdfs:comment 'Total number of clinical interventions or recommendations made during the MTM service encounter (e.g., drug therapy problem resolutions, adherence recommendations, prescriber referrals). Used for quality reporting and pharmacist productivity analytics.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastContactAttemptDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Attempt Date' ;
    rdfs:comment 'Date of the most recent outreach attempt made to the member for MTM scheduling or delivery. Used alongside contact_attempt_count to document good-faith outreach efforts for CMS compliance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mapItemCount rdf:type rdf:Property ;
    rdfs:label 'Map Item Count' ;
    rdfs:comment 'Number of action items documented in the Medication Action Plan (MAP) provided to the member. Each MAP item represents a specific recommendation or goal agreed upon between the pharmacist and the member.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mapProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Map Provided Flag' ;
    rdfs:comment 'Indicates whether a written Medication Action Plan (MAP) was provided to the member following the CMR. CMS requires a standardized MAP to be delivered to the member and their prescriber(s) after each CMR. True = MAP provided; False = MAP not yet provided.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Member Consent Flag' ;
    rdfs:comment 'Indicates whether the member provided consent to participate in the MTM service and for sharing of clinical findings with their prescriber(s). True = consent obtained; False = consent not obtained or pending. Required for HIPAA compliance when sharing PHI with prescribers.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Indicates whether the member has opted out of the MTM program. CMS requires auto-enrollment with opt-out capability. True = member has opted out; False = member remains enrolled. When True, disenrollment_date should be populated.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutReason rdf:type rdf:Property ;
    rdfs:label 'Opt Out Reason' ;
    rdfs:comment 'Reason code for the member\'s opt-out or disenrollment from the MTM program. Null if the member has not opted out. Used for program retention analysis and CMS reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partDDrugCount rdf:type rdf:Property ;
    rdfs:label 'Part D Drug Count' ;
    rdfs:comment 'Number of Part D covered drugs the member is taking at the time of MTM eligibility determination. CMS Part D MTM eligibility requires a minimum number of Part D drugs (typically 8 or more). Used for eligibility validation.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pbmMemberCode rdf:type rdf:Property ;
    rdfs:label 'Pbm Member Code' ;
    rdfs:comment 'Member identifier assigned by the Pharmacy Benefit Manager (PBM) system (RxClaim or Argus) used to cross-reference the MTM record with pharmacy claims and formulary data.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalMedicationListProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Personal Medication List Provided Flag' ;
    rdfs:comment 'Indicates whether a Personal Medication List (PML) was provided to the member as part of the CMR standardized format. CMS requires both a MAP and a PML to be delivered following each CMR. True = PML provided; False = PML not provided.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pharmacistNpi rdf:type rdf:Property ;
    rdfs:label 'Pharmacist Npi' ;
    rdfs:comment '10-digit National Provider Identifier (NPI) of the pharmacist or clinical pharmacist who delivered the MTM service, including Comprehensive Medication Review (CMR) or Targeted Medication Review (TMR). Required for CMS Part D MTM reporting.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacistRecommendationNotes rdf:type rdf:Property ;
    rdfs:label 'Pharmacist Recommendation Notes' ;
    rdfs:comment 'Free-text clinical notes documenting the pharmacist\'s recommendations, findings, and interventions during the MTM service encounter. Contains Protected Health Information (PHI) and must be handled in accordance with HIPAA Privacy Rule requirements.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriberNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Prescriber Notification Date' ;
    rdfs:comment 'Date on which the prescriber(s) were notified of the MTM service findings and MAP items. Null if notification has not yet been sent. Used for compliance tracking against CMS timelines.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prescriberNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Prescriber Notification Flag' ;
    rdfs:comment 'Indicates whether the member\'s prescriber(s) were notified of the MTM service findings, recommendations, or MAP items. CMS requires that the MAP and relevant clinical findings be shared with the prescriber. True = prescriber notified; False = notification pending or not completed.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceDeliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Channel' ;
    rdfs:comment 'Mode through which the MTM service was delivered to the member. CMS requires CMRs to be offered as interactive, person-to-person consultations (in-person or telehealth). Supports channel-level analytics and compliance verification.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Service Duration Minutes' ;
    rdfs:comment 'Duration of the MTM service encounter in minutes. Used for pharmacist productivity reporting, billing reconciliation with PBM, and quality analytics. CMR encounters typically range from 30 to 60 minutes.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current lifecycle status of the MTM service record. SCHEDULED = appointment set; IN_PROGRESS = service initiated; COMPLETED = service fully delivered and documented; DECLINED = member declined participation; UNREACHABLE = member could not be contacted; CANCELLED = service cancelled prior to delivery.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Classification of the MTM service delivered. CMR = Comprehensive Medication Review (annual face-to-face or telehealth); TMR = Targeted Medication Review (quarterly or as needed); FOLLOW_UP = follow-up contact on prior CMR/TMR; REFERRAL = referral to prescriber or specialist; OTHER = other MTM-related service.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:starMeasureEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Star Measure Eligible Flag' ;
    rdfs:comment 'Indicates whether this MTM service record is eligible to be counted toward the CMS STAR Ratings MTM Completion Rate for Comprehensive Medication Reviews (CMR) quality measure. True = eligible for STAR measure numerator/denominator; False = excluded from STAR measure calculation.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tmrDate rdf:type rdf:Property ;
    rdfs:label 'Tmr Date' ;
    rdfs:comment 'Date on which the most recent Targeted Medication Review (TMR) was conducted. TMRs are performed at least quarterly for enrolled members who have not yet received a CMR or as clinically indicated. Null if no TMR has been performed.' ;
    rdfs:domain ind:MtmService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formularyExceptionId rdf:type rdf:Property ;
    rdfs:label 'Formulary Exception Id' ;
    rdfs:comment 'Primary key for formulary_exception' ;
    rdfs:domain ind:FormularyException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealRightsNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Rights Notification Date' ;
    rdfs:comment 'Date on which the appeal rights notification was sent to the member and prescriber following a denial. Required for CMS Part D compliance tracking and audit purposes.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clinicalJustification rdf:type rdf:Property ;
    rdfs:label 'Clinical Justification' ;
    rdfs:comment 'Free-text clinical rationale provided by the prescriber or member supporting the formulary exception request. May include diagnosis, treatment history, contraindications to formulary alternatives, or medical necessity documentation. Treated as confidential clinical information.' ;
    rdfs:domain ind:FormularyException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsCoverageDeterminationType rdf:type rdf:Property ;
    rdfs:label 'Cms Coverage Determination Type' ;
    rdfs:comment 'CMS-defined classification of the coverage determination process type for Part D reporting. Standard: routine 72-hour review; Expedited: 24-hour urgent review; Reopen: plan-initiated reconsideration; Revised: updated determination on a prior decision.' ;
    rdfs:domain ind:FormularyException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentDrugTier rdf:type rdf:Property ;
    rdfs:label 'Current Drug Tier' ;
    rdfs:comment 'The formulary tier at which the requested drug is currently placed (or non_formulary if not on the formulary) at the time the exception request is submitted. Used to assess the tier differential and cost-sharing impact of the exception. [ENUM-REF-CANDIDATE: tier_1|tier_2|tier_3|tier_4|tier_5|specialty|non_formulary — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FormularyException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysSupplyRequested rdf:type rdf:Property ;
    rdfs:label 'Days Supply Requested' ;
    rdfs:comment 'Number of days of drug supply requested in the formulary exception, applicable for quantity limit or day supply override exceptions. Standard values are 30, 60, or 90 days.' ;
    rdfs:domain ind:FormularyException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Calendar date on which the final determination (approval or denial) was made on the formulary exception request. Used to calculate turnaround time and assess CMS timeliness compliance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Exception Request Number' ;
    rdfs:comment 'Externally-visible, human-readable unique reference number assigned to the formulary exception request at intake. Used by members, prescribers, and pharmacies to track the status of the request. Generated by the PBM system (RxClaim/Argus) or UM system.' ;
    rdfs:domain ind:FormularyException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Status' ;
    rdfs:comment 'Current lifecycle status of the formulary exception request. Pending: under review; Approved: exception granted; Denied: exception not granted; Withdrawn: requestor cancelled; Expired: approved exception past effective period; Appealed: denial under appeal review.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionType rdf:type rdf:Property ;
    rdfs:label 'Exception Type' ;
    rdfs:comment 'Classification of the formulary exception request indicating the specific restriction being challenged. Values: non_formulary (drug not on formulary), tier_exception (request lower cost-sharing tier), pa_exception (override Prior Authorization requirement), step_therapy_exception (bypass step therapy protocol), quantity_limit_exception (override quantity/day supply limit), coverage_determination (standard CMS Part D coverage determination). [ENUM-REF-CANDIDATE: non_formulary|tier_exception|pa_exception|step_therapy_exception|quantity_limit_exception|coverage_determination — promote to reference product]' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyAlternativeNdc rdf:type rdf:Property ;
    rdfs:label 'Formulary Alternative Ndc' ;
    rdfs:comment '11-digit NDC of the formulary-covered alternative drug suggested by the plan when denying a non-formulary or tier exception request. Required by CMS to be communicated to the member and prescriber in the denial notice.' ;
    rdfs:domain ind:FormularyException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExpedited rdf:type rdf:Property ;
    rdfs:label 'Is Expedited' ;
    rdfs:comment 'Indicates whether the formulary exception request was submitted and processed under the expedited (24-hour) review pathway, as opposed to the standard (72-hour) pathway. Expedited requests require prescriber attestation that the standard timeframe would seriously jeopardize the member\'s life, health, or ability to regain maximum function.' ;
    rdfs:domain ind:FormularyException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'The quantity of the drug (in dispensing units) for which the exception is requested, applicable for quantity limit exception requests. Expressed in the drug\'s standard dispensing unit (e.g., tablets, milliliters).' ;
    rdfs:domain ind:FormularyException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestChannel rdf:type rdf:Property ;
    rdfs:label 'Request Channel' ;
    rdfs:comment 'Channel through which the formulary exception request was submitted. Values: phone (member/prescriber call), fax (fax submission), portal (member or prescriber web portal), edi (electronic data interchange transaction), mail (paper/postal), prescriber_portal (dedicated prescriber e-prescribing or PBM portal).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Received Timestamp' ;
    rdfs:comment 'Precise date and time the formulary exception request was received and logged in the PBM or UM system. Used for exact timeliness measurement against CMS regulatory response deadlines.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedDrugTier rdf:type rdf:Property ;
    rdfs:label 'Requested Drug Tier' ;
    rdfs:comment 'The formulary cost-sharing tier to which the requestor is asking the drug to be assigned for this member (e.g., requesting Tier 2 generic pricing for a Tier 3 preferred brand). Applicable for tier exception requests.' ;
    rdfs:domain ind:FormularyException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorType rdf:type rdf:Property ;
    rdfs:label 'Requestor Type' ;
    rdfs:comment 'Identifies who initiated the formulary exception request. Member: the enrollee themselves; Prescriber: the treating physician or authorized prescriber; Authorized Representative: a legally designated representative acting on behalf of the member; Pharmacy: the dispensing pharmacy acting on behalf of the member.' ;
    rdfs:domain ind:FormularyException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepTherapyDrugsTried rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Drugs Tried' ;
    rdfs:comment 'Comma-separated list of NDCs or drug names of step therapy prerequisite drugs that the member has already tried and failed, as documented in the step therapy exception request. Supports clinical review and CMS step therapy override requirements.' ;
    rdfs:domain ind:FormularyException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocReceived rdf:type rdf:Property ;
    rdfs:label 'Supporting Doc Received' ;
    rdfs:comment 'Indicates whether the required clinical supporting documentation (e.g., prescriber letter of medical necessity, lab results, treatment history) has been received from the prescriber or member. True = documentation received; False = documentation pending or not received.' ;
    rdfs:domain ind:FormularyException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportingDocReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Supporting Doc Received Date' ;
    rdfs:comment 'Date on which the required clinical supporting documentation was received from the prescriber or member. Used to calculate the effective review start date and CMS timeliness compliance.' ;
    rdfs:domain ind:FormularyException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partDSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Part D Submission Id' ;
    rdfs:comment 'Unique surrogate identifier for each CMS Part D regulatory data submission record in the lakehouse silver layer. Serves as the primary key for this entity.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planBenefitPackageId rdf:type rdf:Property ;
    rdfs:label 'Plan Benefit Package Id' ;
    rdfs:comment 'The CMS-assigned Plan Benefit Package identifier associated with this submission. Distinguishes specific benefit packages within a Part D contract for formulary, cost-sharing, and coverage gap reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPackage .

ind:acceptedRecordCount rdf:type rdf:Property ;
    rdfs:label 'Accepted Record Count' ;
    rdfs:comment 'The number of records within the submission batch that CMS accepted and processed successfully. Derived from the CMS acknowledgment response file. Used to calculate acceptance rate and identify partial rejections.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cgdpInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Cgdp Invoice Amount' ;
    rdfs:comment 'The total dollar amount invoiced under the Coverage Gap Discount Program for this submission, applicable to CGDP submission types. Represents manufacturer discount obligations for brand-name drugs dispensed to Part D beneficiaries in the coverage gap.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearinghouseTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Tracking Number' ;
    rdfs:comment 'The tracking or reference identifier assigned by the EDI clearinghouse (Availity or Change Healthcare) upon receipt of the submission file. Used to trace submission status through the clearinghouse to CMS.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsRegionCode rdf:type rdf:Property ;
    rdfs:label 'Cms Region Code' ;
    rdfs:comment 'The CMS regional office code associated with the Part D contract under which this submission is filed. Used for regulatory routing and regional compliance reporting.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsResponseCode rdf:type rdf:Property ;
    rdfs:label 'Cms Response Code' ;
    rdfs:comment 'The acknowledgment or disposition code returned by CMS upon processing the submission batch. Maps to CMS-defined response code sets (e.g., RAPS response codes, EDPS acknowledgment codes). Used for automated error triage and compliance tracking.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsResponseDate rdf:type rdf:Property ;
    rdfs:label 'Cms Response Date' ;
    rdfs:comment 'The timestamp when the CMS acknowledgment or response file was received by the health plan. Used to calculate CMS processing turnaround time and to trigger downstream reconciliation workflows.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cmsResponseDescription rdf:type rdf:Property ;
    rdfs:label 'Cms Response Description' ;
    rdfs:comment 'Human-readable description of the CMS response code returned for this submission. Provides context for the acceptance, rejection, or error condition reported by CMS.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dirAmount rdf:type rdf:Property ;
    rdfs:label 'Dir Amount' ;
    rdfs:comment 'The total Direct and Indirect Remuneration dollar amount reported in this submission, applicable to DIR submission types. Represents post-point-of-sale price concessions, rebates, and other remuneration from manufacturers and pharmacies that reduce net drug costs. Required for CMS Part D DIR reconciliation.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediInterchangeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Edi Interchange Control Number' ;
    rdfs:comment 'The ISA13 interchange control number from the EDI transmission envelope, applicable to EDI-formatted submissions. Used to correlate submission files with EDI gateway acknowledgments (997/999) from the clearinghouse or CMS.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorDetail rdf:type rdf:Property ;
    rdfs:label 'Error Detail' ;
    rdfs:comment 'Structured or free-text description of errors returned by CMS for rejected or partially accepted records. May include CMS error codes, field-level rejection reasons, and record-level identifiers. Supports error remediation and resubmission workflows.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hccRecordCount rdf:type rdf:Property ;
    rdfs:label 'Hcc Record Count' ;
    rdfs:comment 'The number of Hierarchical Condition Category diagnosis records included in this submission batch, applicable to RAPS and EDPS submission types. Used to monitor HCC capture completeness and risk score optimization.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isResubmission rdf:type rdf:Property ;
    rdfs:label 'Is Resubmission' ;
    rdfs:comment 'Indicates whether this submission is a resubmission of a previously rejected or corrected batch (True) or an original submission (False). Used to track correction cycles and measure first-pass acceptance rates.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTimelySubmission rdf:type rdf:Property ;
    rdfs:label 'Is Timely Submission' ;
    rdfs:comment 'Indicates whether the submission was transmitted to CMS on or before the regulatory deadline date (True) or after the deadline (False). Supports CMS compliance reporting and internal SLA monitoring.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Original Batch Number' ;
    rdfs:comment 'For resubmissions, the batch_id of the original submission that this record corrects or replaces. Null for original submissions. Enables lineage tracing across submission correction cycles.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pbmSystemSource rdf:type rdf:Property ;
    rdfs:label 'Pbm System Source' ;
    rdfs:comment 'Identifies the source PBM system from which the submission data was extracted. Supports data lineage, reconciliation, and audit trail requirements. Values align to operational PBM platforms (RxClaim, Argus).' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdeRecordCount rdf:type rdf:Property ;
    rdfs:label 'Pde Record Count' ;
    rdfs:comment 'The number of Prescription Drug Event records included in this submission batch, applicable to PDE and EDPS submission types. PDE records are the foundational data element for CMS Part D payment and reconciliation.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pendingRecordCount rdf:type rdf:Property ;
    rdfs:label 'Pending Record Count' ;
    rdfs:comment 'The number of records within the submission batch that CMS has received but not yet finalized (e.g., held for additional review or in a processing queue). Supports real-time submission status monitoring.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rafImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Raf Impact Amount' ;
    rdfs:comment 'The estimated revenue impact in dollars attributable to the risk adjustment data submitted in this batch, applicable to RAPS and EDPS submission types. Supports risk adjustment revenue integrity analysis and HCC-based payment reconciliation.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'The date on which the submission was fully reconciled against the CMS response. Null if reconciliation is not yet complete. Used for SLA tracking and audit trail.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectedRecordCount rdf:type rdf:Property ;
    rdfs:label 'Rejected Record Count' ;
    rdfs:comment 'The number of records within the submission batch that CMS rejected. Derived from the CMS acknowledgment response file. Drives error remediation workflows and resubmission prioritization.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'The last calendar date of the reporting period covered by this Part D submission. Together with reporting_period_start_date, defines the data window for the submission batch.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'The first calendar date of the reporting period covered by this Part D submission. Used to align submission data with the applicable benefit year, payment year, or reconciliation cycle as defined by CMS.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resubmissionAttemptNumber rdf:type rdf:Property ;
    rdfs:label 'Resubmission Attempt Number' ;
    rdfs:comment 'Sequential count of resubmission attempts for a given original batch. Value is 0 for original submissions, 1 for first resubmission, 2 for second, etc. Supports escalation workflows and CMS deadline compliance monitoring.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline Date' ;
    rdfs:comment 'The regulatory deadline date by which this submission must be received by CMS. Used to assess timeliness compliance and trigger escalation alerts for at-risk submissions.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionFormat rdf:type rdf:Property ;
    rdfs:label 'Submission Format' ;
    rdfs:comment 'The electronic data interchange or file format used for the CMS submission. EDI_837 = ANSI X12 837 pharmacy claim transaction; FLAT_FILE = CMS-specified fixed-width flat file; XML = extensible markup language; CSV = comma-separated values.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submitterName rdf:type rdf:Property ;
    rdfs:label 'Submitter Name' ;
    rdfs:comment 'The name of the organization or entity submitting the Part D data to CMS. May be the health plan, TPA, or PBM acting on behalf of the plan. Supports audit trail and accountability tracking.' ;
    rdfs:domain ind:PartDSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRecordCount rdf:type rdf:Property ;
    rdfs:label 'Total Record Count' ;
    rdfs:comment 'The total number of records (encounters, claims, or line items) included in the submission batch as transmitted to CMS. Used as the control total for reconciliation against CMS acknowledgment.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitAccumulatorId rdf:type rdf:Property ;
    rdfs:label 'Benefit Accumulator Id' ;
    rdfs:comment 'Primary key for benefit_accumulator' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accumulatorSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Accumulator Source System' ;
    rdfs:comment 'Identifies the operational system of record that originated or last updated this accumulator record (e.g., RxClaim, Argus PBM, Facets, QNXT). Supports data lineage, reconciliation, and audit trail requirements.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accumulatorVersion rdf:type rdf:Property ;
    rdfs:label 'Accumulator Version' ;
    rdfs:comment 'Optimistic locking version counter incremented with each update to the accumulator record. Supports concurrent adjudication event handling and prevents race conditions in real-time point-of-sale updates.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Benefit Period End Date' ;
    rdfs:comment 'Last date of the benefit year or coverage period to which this accumulator record applies. Defines the boundary for annual accumulator reset.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefitPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Benefit Period Start Date' ;
    rdfs:comment 'First date of the benefit year or coverage period to which this accumulator record applies. Accumulators reset at the start of each new benefit period.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:catastrophicAppliedAmt rdf:type rdf:Property ;
    rdfs:label 'Catastrophic Applied Amt' ;
    rdfs:comment 'Cumulative drug cost amounts applied toward the Medicare Part D catastrophic coverage threshold. Tracks member spend after exiting the coverage gap and entering catastrophic coverage.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:catastrophicLimitAmt rdf:type rdf:Property ;
    rdfs:label 'Catastrophic Limit Amt' ;
    rdfs:comment 'The Medicare Part D catastrophic coverage threshold amount for the current benefit year. Once TrOOP reaches this level, the member qualifies for catastrophic cost-sharing rates. Published annually by CMS.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmsReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Cms Reconciliation Status' ;
    rdfs:comment 'Status of the CMS annual Part D reconciliation process for this accumulator record. Tracks whether the accumulator data has been submitted to and accepted by CMS via RAPS/EDPS for risk adjustment and subsidy reconciliation.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinationOfBenefitsType rdf:type rdf:Property ;
    rdfs:label 'Coordination Of Benefits Type' ;
    rdfs:comment 'Indicates the coordination of benefits (COB) role of this plan for the member\'s pharmacy benefit. Determines how accumulator amounts are applied when multiple payers are involved.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageGapDiscountAppliedAmt rdf:type rdf:Property ;
    rdfs:label 'Coverage Gap Discount Applied Amt' ;
    rdfs:comment 'Cumulative manufacturer discount amounts applied to brand-name drugs while the member is in the Medicare Part D coverage gap (donut hole). These discounts count toward TrOOP under the ACA Coverage Gap Discount Program.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductibleAppliedAmt rdf:type rdf:Property ;
    rdfs:label 'Deductible Applied Amt' ;
    rdfs:comment 'Cumulative dollar amount the member has applied toward their pharmacy deductible in the current benefit period. Updated with each pharmacy claim adjudication event. Used at point of sale to determine member cost-sharing responsibility.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductibleLimitAmt rdf:type rdf:Property ;
    rdfs:label 'Deductible Limit Amt' ;
    rdfs:comment 'Total pharmacy deductible amount the member must satisfy before plan cost-sharing begins, as defined in the benefit plan design for the current benefit period.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eobGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Eob Generated Flag' ;
    rdfs:comment 'Indicates whether an Explanation of Benefits (EOB) has been generated for the member reflecting the current accumulator balances. Supports member communication and regulatory EOB delivery requirements.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:familyDeductibleAppliedAmt rdf:type rdf:Property ;
    rdfs:label 'Family Deductible Applied Amt' ;
    rdfs:comment 'Cumulative dollar amount applied toward the family-level pharmacy deductible for plans with embedded or aggregate family deductible structures. Applicable for commercial group plans with family coverage tiers.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:familyOopAppliedAmt rdf:type rdf:Property ;
    rdfs:label 'Family Oop Applied Amt' ;
    rdfs:comment 'Cumulative out-of-pocket spend applied toward the family-level MOOP for plans with family OOP limits. Tracks combined member cost-sharing across all family members enrolled under the same plan.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formularyTierApplied rdf:type rdf:Property ;
    rdfs:label 'Formulary Tier Applied' ;
    rdfs:comment 'The formulary drug tier level most recently applied during adjudication for this member\'s accumulator. Indicates the cost-sharing tier structure in effect, which affects deductible and OOP accumulation rates.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsaEligibleAppliedAmt rdf:type rdf:Property ;
    rdfs:label 'Hsa Eligible Applied Amt' ;
    rdfs:comment 'Cumulative amount of pharmacy cost-sharing that qualifies as HSA-eligible expenses under IRS rules for members enrolled in a High Deductible Health Plan (HDHP). Supports member HSA contribution and tax reporting.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iclAppliedAmt rdf:type rdf:Property ;
    rdfs:label 'Icl Applied Amt' ;
    rdfs:comment 'Cumulative total drug costs (plan paid plus member cost-sharing) applied toward the Medicare Part D Initial Coverage Limit (ICL). When this amount reaches the ICL threshold, the member enters the coverage gap (donut hole).' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iclLimitAmt rdf:type rdf:Property ;
    rdfs:label 'Icl Limit Amt' ;
    rdfs:comment 'The Medicare Part D Initial Coverage Limit (ICL) threshold amount for the current benefit year, as published annually by CMS. Defines the boundary between the initial coverage phase and the coverage gap (donut hole).' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDeductibleMet rdf:type rdf:Property ;
    rdfs:label 'Is Deductible Met' ;
    rdfs:comment 'Indicates whether the member has fully satisfied their pharmacy deductible for the current benefit period. When true, plan cost-sharing (copay/coinsurance) applies rather than full deductible responsibility.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMoopMet rdf:type rdf:Property ;
    rdfs:label 'Is Moop Met' ;
    rdfs:comment 'Indicates whether the member has reached their maximum out-of-pocket (MOOP) limit for the current benefit period. When true, the plan covers 100% of covered pharmacy costs for the remainder of the benefit period.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAdjudicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Adjudication Timestamp' ;
    rdfs:comment 'Date and time of the most recent pharmacy claim adjudication event that updated this accumulator record. Critical for real-time point-of-sale cost-sharing calculation and concurrency control.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lisCopayTier rdf:type rdf:Property ;
    rdfs:label 'Lis Copay Tier' ;
    rdfs:comment 'The applicable LIS copay tier for the member, determining the fixed copay amounts for generic, preferred brand, non-preferred, and specialty drugs under the Low-Income Subsidy (LIS) program.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lisLevel rdf:type rdf:Property ;
    rdfs:label 'Lis Level' ;
    rdfs:comment 'Low-Income Subsidy (LIS) eligibility level for Medicare Part D members, determining reduced cost-sharing amounts. \'full\' indicates 100% subsidy; \'partial_1/2/3\' indicate graduated subsidy tiers; \'none\' indicates no LIS. Affects TrOOP accumulation rules.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailOrderAppliedAmt rdf:type rdf:Property ;
    rdfs:label 'Mail Order Applied Amt' ;
    rdfs:comment 'Cumulative cost-sharing amount applied for drugs dispensed through mail-order pharmacy channels in the current benefit period. Supports mail-order utilization reporting and member EOB generation.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moopLimitAmt rdf:type rdf:Property ;
    rdfs:label 'Moop Limit Amt' ;
    rdfs:comment 'The maximum out-of-pocket (MOOP) dollar threshold the member must reach before the plan covers 100% of covered pharmacy costs for the remainder of the benefit period. Set per plan design and ACA/CMS requirements.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oopAppliedAmt rdf:type rdf:Property ;
    rdfs:label 'Oop Applied Amt' ;
    rdfs:comment 'Cumulative out-of-pocket (OOP) spend by the member for pharmacy benefits in the current benefit period, including deductible, copays, and coinsurance. Used to track progress toward the maximum out-of-pocket (MOOP) limit.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partDBenefitPhase rdf:type rdf:Property ;
    rdfs:label 'Part D Benefit Phase' ;
    rdfs:comment 'Current Medicare Part D benefit phase for the member based on accumulated TrOOP and ICL amounts. Drives cost-sharing calculation at point of sale. \'not_applicable\' for non-Part D lines of business.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rxClaimCount rdf:type rdf:Property ;
    rdfs:label 'Rx Claim Count' ;
    rdfs:comment 'Total number of pharmacy claims adjudicated and applied to this accumulator record in the current benefit period. Used for utilization reporting and EOB generation.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialtyDrugAppliedAmt rdf:type rdf:Property ;
    rdfs:label 'Specialty Drug Applied Amt' ;
    rdfs:comment 'Cumulative cost-sharing amount applied specifically for specialty tier drugs in the current benefit period. Tracked separately to support specialty pharmacy reporting, prior authorization analytics, and plan design evaluation.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thirdPartyAppliedAmt rdf:type rdf:Property ;
    rdfs:label 'Third Party Applied Amt' ;
    rdfs:comment 'Cumulative dollar amount paid by third parties (e.g., manufacturer copay assistance programs, other insurance) toward the member\'s pharmacy cost-sharing. Tracked separately as these amounts may not count toward TrOOP under CMS rules.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:troopAppliedAmt rdf:type rdf:Property ;
    rdfs:label 'Troop Applied Amt' ;
    rdfs:comment 'Cumulative true out-of-pocket (TrOOP) expenditure for Medicare Part D members, counting only qualifying cost-sharing amounts toward the catastrophic coverage threshold. Excludes amounts paid by third parties not qualifying under CMS TrOOP rules. Required for CMS Part D benefit phase determination.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:troopLimitAmt rdf:type rdf:Property ;
    rdfs:label 'Troop Limit Amt' ;
    rdfs:comment 'The annual TrOOP threshold amount that, when reached, transitions a Medicare Part D member into catastrophic coverage. Published annually by CMS as part of the Part D benefit parameters.' ;
    rdfs:domain ind:BenefitAccumulator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pharmacyContractId rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Contract Id' ;
    rdfs:comment 'Unique surrogate identifier for the pharmacy contract record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:PharmacyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accreditationType rdf:type rdf:Property ;
    rdfs:label 'Accreditation Type' ;
    rdfs:comment 'Type of accreditation required or held by the pharmacy under this contract. URAC and ACHC are common for specialty pharmacies. PCAB (Pharmacy Compounding Accreditation Board) for compounding pharmacies. Relevant for specialty and mail-order contracts.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRightsIndicator rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Indicator' ;
    rdfs:comment 'Indicates whether the health plan or PBM retains the right to conduct on-site or desk audits of the pharmacy\'s dispensing records under this contract. Required for CMS Part D compliance.' ;
    rdfs:domain ind:PharmacyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalIndicator rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Indicator' ;
    rdfs:comment 'Indicates whether this contract automatically renews at the end of the contract term unless either party provides notice of termination within the required notice period.' ;
    rdfs:domain ind:PharmacyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:credentialingRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Credentialing Required Indicator' ;
    rdfs:comment 'Indicates whether the pharmacy must complete and maintain credentialing requirements (state licensure, DEA registration, accreditation) as a condition of this contract.' ;
    rdfs:domain ind:PharmacyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysSupplyMailMax rdf:type rdf:Property ;
    rdfs:label 'Days Supply Mail Max' ;
    rdfs:comment 'Maximum days supply per mail-order prescription fill authorized under this contract (typically 90 days). Drives adjudication edits in RxClaim/Argus.' ;
    rdfs:domain ind:PharmacyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysSupplyRetailMax rdf:type rdf:Property ;
    rdfs:label 'Days Supply Retail Max' ;
    rdfs:comment 'Maximum days supply per retail prescription fill authorized under this contract (typically 30 or 34 days). Claims exceeding this limit may be rejected during adjudication.' ;
    rdfs:domain ind:PharmacyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executedDate rdf:type rdf:Property ;
    rdfs:label 'Executed Date' ;
    rdfs:comment 'Date on which the pharmacy contract was fully executed (signed by all parties). May precede the effective_date if there is a future start date.' ;
    rdfs:domain ind:PharmacyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:genericAwpDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Generic Awp Discount Pct' ;
    rdfs:comment 'Contracted AWP discount percentage specifically for generic drugs, which typically carries a deeper discount than brand drugs. Expressed as a positive percentage. Applicable when ingredient_cost_basis is awp_discount and a separate generic rate is negotiated.' ;
    rdfs:domain ind:PharmacyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:genericDispensingRateTarget rdf:type rdf:Property ;
    rdfs:label 'Generic Dispensing Rate Target' ;
    rdfs:comment 'Contracted minimum generic dispensing rate (GDR) the pharmacy must achieve as a performance requirement. Expressed as a percentage (e.g., 85.00 = 85%). Supports CMS Part D Star Ratings and cost management objectives.' ;
    rdfs:domain ind:PharmacyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAmendedDate rdf:type rdf:Property ;
    rdfs:label 'Last Amended Date' ;
    rdfs:comment 'Date of the most recent amendment or addendum to this pharmacy contract. Used to track contract evolution and ensure the current fee schedule and terms are applied during adjudication.' ;
    rdfs:domain ind:PharmacyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mailOrderIndicator rdf:type rdf:Property ;
    rdfs:label 'Mail Order Indicator' ;
    rdfs:comment 'Indicates whether this pharmacy is authorized to dispense mail-order (90-day supply) prescriptions under this contract.' ;
    rdfs:domain ind:PharmacyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceGuaranteeIndicator rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee Indicator' ;
    rdfs:comment 'Indicates whether this contract includes performance guarantees (e.g., generic dispensing rate, medication adherence, fill accuracy). When true, performance_guarantee_details apply.' ;
    rdfs:domain ind:PharmacyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pharmacyNpi rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Npi' ;
    rdfs:comment '10-digit National Provider Identifier assigned to the dispensing pharmacy by CMS. Used for claims adjudication, EDI transactions (NCPDP 5.1/D.0), and network directory publication.' ;
    rdfs:domain ind:PharmacyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoupmentProvisionIndicator rdf:type rdf:Property ;
    rdfs:label 'Recoupment Provision Indicator' ;
    rdfs:comment 'Indicates whether the contract includes provisions allowing the health plan or PBM to recoup overpayments identified through audits or claims reviews.' ;
    rdfs:domain ind:PharmacyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemContractCode rdf:type rdf:Property ;
    rdfs:label 'Source System Contract Code' ;
    rdfs:comment 'Native contract identifier from the originating PBM system (RxClaim or Argus) or provider management system (Cactus/ProviderSource). Used for lineage tracing and reconciliation between the lakehouse and operational systems.' ;
    rdfs:domain ind:PharmacyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of calendar days advance written notice required by either party to terminate the contract without cause. Regulatory minimums vary by state DOI requirements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentMacListId rdf:type rdf:Property ;
    rdfs:label 'Parent Mac List Id' ;
    rdfs:comment 'Self-referencing FK on mac_list (parent_mac_list_id)' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MacList .

ind:dosageStrengthUnit rdf:type rdf:Property ;
    rdfs:label 'Dosage Strength Unit' ;
    rdfs:comment 'Unit of measurement for dosage strength.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosageStrengthValue rdf:type rdf:Property ;
    rdfs:label 'Dosage Strength Value' ;
    rdfs:comment 'Numeric strength of the dosage.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drugCategory rdf:type rdf:Property ;
    rdfs:label 'Drug Category' ;
    rdfs:comment 'Category of the drug (e.g., pain management, cardiovascular).' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugClass rdf:type rdf:Property ;
    rdfs:label 'Drug Class' ;
    rdfs:comment 'Class of the drug (e.g., analgesic, antibiotic).' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugCode rdf:type rdf:Property ;
    rdfs:label 'Drug Code' ;
    rdfs:comment 'Standard code identifying the drug (e.g., RxNorm code).' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugCodeDescription rdf:type rdf:Property ;
    rdfs:label 'Drug Code Description' ;
    rdfs:comment 'Description of the drug code.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugCodeType rdf:type rdf:Property ;
    rdfs:label 'Drug Code Type' ;
    rdfs:comment 'Type of drug code used (RxNorm, NDC, or other).' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugDescription rdf:type rdf:Property ;
    rdfs:label 'Drug Description' ;
    rdfs:comment 'Detailed description of the drug.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugFormCode rdf:type rdf:Property ;
    rdfs:label 'Drug Form Code' ;
    rdfs:comment 'Code representing the dosage form of the drug.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugFormDescription rdf:type rdf:Property ;
    rdfs:label 'Drug Form Description' ;
    rdfs:comment 'Description of the dosage form.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugStrengthCode rdf:type rdf:Property ;
    rdfs:label 'Drug Strength Code' ;
    rdfs:comment 'Code representing the dosage strength.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugStrengthDescription rdf:type rdf:Property ;
    rdfs:label 'Drug Strength Description' ;
    rdfs:comment 'Description of the dosage strength.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugTherapeuticClassCode rdf:type rdf:Property ;
    rdfs:label 'Drug Therapeutic Class Code' ;
    rdfs:comment 'Code representing the therapeutic class of the drug.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugTherapeuticClassDescription rdf:type rdf:Property ;
    rdfs:label 'Drug Therapeutic Class Description' ;
    rdfs:comment 'Description of the therapeutic class.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macCreatedAt rdf:type rdf:Property ;
    rdfs:label 'Mac Created At' ;
    rdfs:comment 'Timestamp when the MAC record was created in the system.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:macCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Mac Created By' ;
    rdfs:comment 'Identifier of the user who created the MAC record.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macCurrency rdf:type rdf:Property ;
    rdfs:label 'Mac Currency' ;
    rdfs:comment 'Currency in which the MAC value is expressed.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Mac Effective Date' ;
    rdfs:comment 'Date when the MAC value becomes effective.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:macExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Mac Expiration Date' ;
    rdfs:comment 'Date when the MAC value expires.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:macSource rdf:type rdf:Property ;
    rdfs:label 'Mac Source' ;
    rdfs:comment 'Source of the MAC value (PBM, manufacturer, CMS).' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macSourceDate rdf:type rdf:Property ;
    rdfs:label 'Mac Source Date' ;
    rdfs:comment 'Date when the MAC value was sourced.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:macStatus rdf:type rdf:Property ;
    rdfs:label 'Mac Status' ;
    rdfs:comment 'The mac status for this record.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Mac Termination Date' ;
    rdfs:comment 'The mac termination date for this record.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:macUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Mac Unit Price' ;
    rdfs:comment 'The mac unit price for this record.' ;
    rdfs:domain ind:MacList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:macUpdatedAt rdf:type rdf:Property ;
    rdfs:label 'Mac Updated At' ;
    rdfs:comment 'Timestamp when the MAC record was last updated.' ;
    rdfs:domain ind:MacList ;
