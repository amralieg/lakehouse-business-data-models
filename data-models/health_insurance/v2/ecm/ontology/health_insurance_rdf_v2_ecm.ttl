ind:CredentialDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Credential ;
    rdfs:label 'Credential Document' ;
    rdfs:comment 'Documents associated with provider credentialing including licenses, certifications, and verifications.' .

ind:CommitteeType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Credential ;
