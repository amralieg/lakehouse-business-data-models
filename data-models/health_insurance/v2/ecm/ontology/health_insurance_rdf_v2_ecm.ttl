ind:contractProviderContractId rdf:type rdf:Property ;
    rdfs:label 'Contract Provider Contract Id' ;
    rdfs:comment 'Foreign key linking to contract.provider_contract. Business justification: Required for compliance check that a PCP assignment respects an active provider contract; ensures network participation rules are enforced during PCP selection.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Current' ;
    rdfs:comment 'True if the assignment is the active PCP for the member at query time.' ;
