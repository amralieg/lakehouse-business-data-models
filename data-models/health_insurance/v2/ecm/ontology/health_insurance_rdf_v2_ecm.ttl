    rdfs:domain ind:CobRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otherCarrierVendorId rdf:type rdf:Property ;
    rdfs:label 'Other Carrier Vendor Id' ;
    rdfs:comment 'Foreign key linking to vendor.vendor. Business justification: COORDINATION_OF_BENEFITS: COB process requires linking the other carrier name to its vendor record for data exchange and compliance reporting.' ;
    rdfs:domain ind:CobRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

