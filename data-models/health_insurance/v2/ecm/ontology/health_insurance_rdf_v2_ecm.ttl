ind:agentType rdf:type rdf:Property ;
    rdfs:label 'Agent Type' ;
    rdfs:comment 'Classification of the general agent\'s role in the distribution hierarchy. Distinguishes between General Agent (GA), Managing General Agent (MGA), Field Marketing Organization (FMO), independent broker, or Third-Party Administrator (TPA). [ENUM-REF-CANDIDATE: general_agent|managing_general_agent|field_marketing_organization|broker|tpa — promote to reference product]' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Effective Date' ;
    rdfs:comment 'Date on which the general agent\'s appointment with the health plan became effective. Marks the start of the authorized distribution relationship.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointmentTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Appointment Termination Date' ;
    rdfs:comment 'Date on which the general agent\'s appointment with the health plan was terminated. Null if the appointment is currently active. Required for regulatory termination filings.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointmentTerminationReason rdf:type rdf:Property ;
    rdfs:label 'Appointment Termination Reason' ;
    rdfs:comment 'Reason code for the termination of the general agent\'s appointment. Required for state insurance department termination filings under NAIC guidelines.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'Date on which the most recent background check was completed for the general agent.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line1' ;
    rdfs:comment 'First line of the general agent\'s primary business mailing address. Used for commission check mailing, regulatory correspondence, and contract delivery.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line2' ;
    rdfs:comment 'Second line of the general agent\'s primary business mailing address (suite, floor, unit number).' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCity rdf:type rdf:Property ;
    rdfs:label 'Business City' ;
    rdfs:comment 'City of the general agent\'s primary business address.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCountry rdf:type rdf:Property ;
    rdfs:label 'Business Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the general agent\'s primary business address. Typically USA for domestic health insurance operations.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessState rdf:type rdf:Property ;
    rdfs:label 'Business State' ;
    rdfs:comment 'Two-letter USPS state code for the general agent\'s primary business address. Used for state-specific regulatory compliance and commission tax reporting.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessZipCode rdf:type rdf:Property ;
    rdfs:label 'Business Zip Code' ;
    rdfs:comment 'ZIP or ZIP+4 postal code for the general agent\'s primary business address.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Cms Certification Date' ;
    rdfs:comment 'Date on which the general agent completed CMS-required certification for Medicare Advantage and/or Part D product distribution.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commissionPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Commission Payment Method' ;
    rdfs:comment 'Method by which commission payments are disbursed to the general agent. Drives payment processing routing in the financial system.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Commission Schedule Code' ;
    rdfs:comment 'Code referencing the commission schedule applicable to this general agent. Determines commission rates, override structures, and bonus eligibility for group sales and renewals.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Date' ;
    rdfs:comment 'Date on which the general agent\'s contract is scheduled for renewal review. Used by the producer management team to initiate renewal negotiations.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eOCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'E O Coverage Amount' ;
    rdfs:comment 'Dollar amount of Errors and Omissions (E&O) professional liability coverage maintained by the general agent. Must meet minimum thresholds set by the health plan\'s appointment requirements.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eOExpirationDate rdf:type rdf:Property ;
    rdfs:label 'E O Expiration Date' ;
    rdfs:comment 'Date on which the general agent\'s E&O professional liability insurance policy expires. Used to trigger renewal reminders and flag compliance gaps.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eOInsuranceCarrier rdf:type rdf:Property ;
    rdfs:label 'E O Insurance Carrier' ;
    rdfs:comment 'Name of the insurance carrier providing Errors and Omissions (E&O) professional liability coverage for the general agent. Required as a condition of appointment.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eOPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'E O Policy Number' ;
    rdfs:comment 'Policy number for the general agent\'s Errors and Omissions (E&O) professional liability insurance policy.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaCode rdf:type rdf:Property ;
    rdfs:label 'Ga Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier assigned to the general agent by the health plan or carrier. Used in downstream systems, commission statements, and regulatory filings to uniquely reference the GA.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAcaCertified rdf:type rdf:Property ;
    rdfs:label 'Is Aca Certified' ;
    rdfs:comment 'Indicates whether the general agent has completed required ACA marketplace training and certification for individual and small group exchange product sales.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCmsApproved rdf:type rdf:Property ;
    rdfs:label 'Is Cms Approved' ;
    rdfs:comment 'Indicates whether the general agent has completed CMS-required training and certification for Medicare Advantage and/or Part D product sales. Required for MA/PDP distribution.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:generalAgentName rdf:type rdf:Property ;
    rdfs:label 'General Agent Name' ;
    rdfs:comment 'Full legal business name of the general agent organization as registered with the state insurance department. Used for contracts, commission payments, and regulatory correspondence.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npn rdf:type rdf:Property ;
    rdfs:label 'Npn' ;
    rdfs:comment 'National Producer Number (NPN) as assigned by the National Insurance Producer Registry (NIPR). Primary cross-state identifier for producer licensing verification and CMS reporting for Medicare/Medicaid lines of business.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ofacCheckDate rdf:type rdf:Property ;
    rdfs:label 'Ofac Check Date' ;
    rdfs:comment 'Date on which the most recent OFAC sanctions screening was performed for the general agent.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ofacCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Ofac Check Status' ;
    rdfs:comment 'Status of the OFAC (Office of Foreign Assets Control) sanctions screening for the general agent. Required to ensure the health plan does not conduct business with sanctioned entities.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Business email address of the primary contact at the general agent organization. Used for commission statements, contract communications, and compliance notifications.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact at the general agent organization for day-to-day operational communications with the health plan.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Business phone number of the primary contact at the general agent organization.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Job title of the primary contact at the general agent organization (e.g., President, Director of Sales, Account Manager).' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryStateLicenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Primary State License Expiration Date' ;
    rdfs:comment 'Date on which the general agent\'s primary state insurance producer license expires. Used to trigger renewal reminders and suspend commission eligibility for unlicensed agents.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryStateLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Primary State License Number' ;
    rdfs:comment 'Insurance producer license number issued by the general agent\'s primary state of domicile. Required for appointment processing and regulatory compliance verification.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryStateLicenseState rdf:type rdf:Property ;
    rdfs:label 'Primary State License State' ;
    rdfs:comment 'Two-letter USPS state code for the state in which the general agent holds their primary insurance producer license (state of domicile).' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaStates rdf:type rdf:Property ;
    rdfs:label 'Service Area States' ;
    rdfs:comment 'Comma-delimited list of two-letter state codes representing the states in which the general agent is authorized to market and sell health plan products. Used for geographic territory management.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalAgentStatus rdf:type rdf:Property ;
    rdfs:label 'General Agent Status' ;
    rdfs:comment 'Current lifecycle status of the general agent relationship with the health plan. Drives eligibility for commission payments, new group submissions, and renewal processing.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:w9OnFile rdf:type rdf:Property ;
    rdfs:label 'W9 On File' ;
    rdfs:comment 'Indicates whether a current IRS Form W-9 (Request for Taxpayer Identification Number and Certification) is on file for this general agent. Required before commission payments can be issued.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:w9ReceivedDate rdf:type rdf:Property ;
    rdfs:label 'W9 Received Date' ;
    rdfs:comment 'Date on which the most recent IRS Form W-9 was received from the general agent. Used to track compliance with IRS backup withholding requirements.' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisingGeneralAgentId rdf:type rdf:Property ;
    rdfs:label 'Supervising General Agent Id' ;
    rdfs:comment 'Self-referencing FK on general_agent (supervising_general_agent_id)' ;
    rdfs:domain ind:GeneralAgent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralAgent .
