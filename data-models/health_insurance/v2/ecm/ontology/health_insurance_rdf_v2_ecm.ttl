ind:practiceLocationId rdf:type rdf:Property ;
    rdfs:label 'Practice Location Id' ;
    rdfs:comment 'Foreign key linking to provider.provider_provider. Business justification: REQUIRED: PCP assignment records must reference the provider entity to support network participation audits and accurate provider-member linkage.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeLocation .

ind:providerNetworkId rdf:type rdf:Property ;
