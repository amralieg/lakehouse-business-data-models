ind:ibnrStatus rdf:type rdf:Property ;
    rdfs:label 'Ibnr Status' ;
    rdfs:comment 'Current lifecycle status of the IBNR reserve record.' ;
    rdfs:domain ind:Ibnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incurredMonth rdf:type rdf:Property ;
