ind:lastCredentialingDate rdf:type rdf:Property ;
    rdfs:label 'Last Credentialing Date' ;
    rdfs:comment 'Date of last credentialing verification for this participation' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDirectoryUpdateDate rdf:type rdf:Property ;
