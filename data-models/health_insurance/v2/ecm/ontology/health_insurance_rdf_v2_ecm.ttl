ind:pcpAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Pcp Assignment Id' ;
    rdfs:comment 'Primary key for pcp_assignment' ;
    rdfs:domain ind:PcpAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentRuleId rdf:type rdf:Property ;
    rdfs:label 'Assignment Rule Id' ;
    rdfs:comment 'Reference to the rule used for automatic PCP assignment (e.g., newborn rule).' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
