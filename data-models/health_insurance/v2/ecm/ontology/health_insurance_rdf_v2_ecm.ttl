ind:completionFactor rdf:type rdf:Property ;
    rdfs:label 'Completion Factor' ;
    rdfs:comment 'Factor representing the proportion of ultimate loss expected to be reported.' ;
    rdfs:domain ind:Ibnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ibnrDescription rdf:type rdf:Property ;
    rdfs:label 'Ibnr Description' ;
    rdfs:comment 'Free-form text describing the purpose or notes for the reserve.' ;
    rdfs:domain ind:Ibnr ;
    rdf:type owl:DatatypeProperty ;
