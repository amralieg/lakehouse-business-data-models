    rdfs:comment 'Indicates if provider qualifies as an essential community provider' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPcp rdf:type rdf:Property ;
    rdfs:label 'Is Pcp' ;
    rdfs:comment 'The is pcp for this record.' ;
