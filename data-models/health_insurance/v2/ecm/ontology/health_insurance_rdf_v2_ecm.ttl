    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Group .

ind:headerGroupId rdf:type rdf:Property ;
    rdfs:label 'Header Group Id' ;
    rdfs:comment 'Foreign key linking to employer.employer_group. Business justification: Required for employer-sponsored plan cost reporting and ACA employer reporting; each claim must be attributed to the employer group that provided the coverage.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Group .

ind:inpatientAdmissionId rdf:type rdf:Property ;
    rdfs:label 'Inpatient Admission Id' ;
    rdfs:comment 'Foreign key linking to utilization.inpatient_admission. Business justification: Required for Admission-to-Claim reconciliation report; claims are generated from inpatient admissions, so linking each claim to its admission record is standard practice.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InpatientAdmission .

ind:providerCredentialRecordId rdf:type rdf:Property ;
    rdfs:label 'Provider Credential Record Id' ;
    rdfs:comment 'Foreign key linking to credential.credential_record. Business justification: Needed for Claim Intake Eligibility Check: validates rendering provider\'s credential status before claim acceptance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Record .

ind:providerPartyId rdf:type rdf:Property ;
    rdfs:label 'Provider Party Id' ;
    rdfs:comment 'Foreign key linking to contract.party. Business justification: Needed to associate each claim with the contracting party (provider organization) for regulatory reporting and payment reconciliation.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:regulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_submission. Business justification: Regulatory submissions aggregate claims; associating claim with its submission supports submission tracking and audit of filing completeness.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatorySubmission .

ind:renderingProviderPracticeLocationId rdf:type rdf:Property ;
    rdfs:label 'Rendering Provider Practice Location Id' ;
    rdfs:comment 'FK to provider.provider.provider_id — Every claim must resolve to a rendering provider for network status determination, fee schedule lookup, and provider payment. This is the second most critical operational join in health insurance.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeLocation .

ind:umCaseId rdf:type rdf:Property ;
    rdfs:label 'Um Case Id' ;
    rdfs:comment 'Foreign key linking to utilization.um_case. Business justification: Needed for Case Management Dashboard; each claim must be tied to the utilization case that governs its clinical and financial review.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UmCase .

ind:adjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Flag' ;
    rdfs:comment 'Indicates if the claim includes any adjustments.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:admissionDate rdf:type rdf:Property ;
    rdfs:label 'Admission Date' ;
    rdfs:comment 'Date of patient admission for inpatient claims.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allowedAmount rdf:type rdf:Property ;
    rdfs:label 'Allowed Amount' ;
    rdfs:comment 'Maximum amount the insurer permits for the services.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billedAmount rdf:type rdf:Property ;
    rdfs:label 'Billed Amount' ;
    rdfs:comment 'Total amount billed to the insurer before adjustments.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingProviderNpi rdf:type rdf:Property ;
    rdfs:label 'Billing Provider Npi' ;
    rdfs:comment 'NPI of the provider responsible for billing.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingType rdf:type rdf:Property ;
    rdfs:label 'Billing Type' ;
    rdfs:comment 'Method of billing for the claim.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Claim Event Timestamp' ;
    rdfs:comment 'Date and time of the primary service rendered for the claim.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:claimLineCount rdf:type rdf:Property ;
    rdfs:label 'Claim Line Count' ;
    rdfs:comment 'Number of line detail records associated with this claim.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Unique claim identifier assigned by the insurer.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimSource rdf:type rdf:Property ;
    rdfs:label 'Claim Source' ;
    rdfs:comment 'Origin of the claim submission.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current processing status of the claim.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Category of claim based on service type.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimVersion rdf:type rdf:Property ;
    rdfs:label 'Claim Version' ;
    rdfs:comment 'Version number of the claim for tracking revisions.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:denialReasonCode rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Code' ;
    rdfs:comment 'Code representing the reason for claim denial, if applicable.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisCodes rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Codes' ;
    rdfs:comment 'Pipe-separated list of diagnosis codes associated with the claim.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeDate rdf:type rdf:Property ;
    rdfs:label 'Discharge Date' ;
    rdfs:comment 'Date of patient discharge for inpatient claims.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drgCode rdf:type rdf:Property ;
    rdfs:label 'Drg Code' ;
    rdfs:comment 'DRG assignment for inpatient claims.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fhirDiagnosis rdf:type rdf:Property ;
    rdfs:label 'Fhir Diagnosis' ;
    rdfs:comment 'FHIR Claim.diagnosis mapping' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fhirItem rdf:type rdf:Property ;
    rdfs:label 'Fhir Item' ;
    rdfs:comment 'FHIR Claim.item mapping' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fhirPatient rdf:type rdf:Property ;
    rdfs:label 'Fhir Patient' ;
    rdfs:comment 'FHIR Claim.patient mapping' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fhirProvider rdf:type rdf:Property ;
    rdfs:label 'Fhir Provider' ;
    rdfs:comment 'FHIR Claim.provider mapping' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHipaaCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Hipaa Compliant' ;
    rdfs:comment 'Flag indicating whether the claim data complies with HIPAA regulations.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMlrExcluded rdf:type rdf:Property ;
    rdfs:label 'Is Mlr Excluded' ;
    rdfs:comment 'Indicates if the claim is excluded from MLR calculations.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSuspended rdf:type rdf:Property ;
    rdfs:label 'Is Suspended' ;
    rdfs:comment 'Indicates if the claim is currently suspended pending additional information.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lengthOfStay rdf:type rdf:Property ;
    rdfs:label 'Length Of Stay' ;
    rdfs:comment 'Number of days between admission and discharge.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Net amount paid to the provider after adjustments.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placeOfServiceCode rdf:type rdf:Property ;
    rdfs:label 'Place Of Service Code' ;
    rdfs:comment 'Code indicating where the service was provided.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Number' ;
    rdfs:comment 'Reference number for prior authorization, if required.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureCodes rdf:type rdf:Property ;
    rdfs:label 'Procedure Codes' ;
    rdfs:comment 'Pipe-separated list of procedure codes billed on the claim.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralProviderNpi rdf:type rdf:Property ;
    rdfs:label 'Referral Provider Npi' ;
    rdfs:comment 'NPI of the referring provider, if applicable.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Due Date' ;
    rdfs:comment 'Date by which the claim must be processed to meet service level agreement.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaMet rdf:type rdf:Property ;
    rdfs:label 'Sla Met' ;
    rdfs:comment 'Flag indicating whether the claim met the SLA deadline.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Status Change Timestamp' ;
    rdfs:comment 'Timestamp of the most recent status transition.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Reason why the claim was suspended.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Primary key for line' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:authServiceLineId rdf:type rdf:Property ;
    rdfs:label 'Auth Service Line Id' ;
    rdfs:comment 'Foreign key linking to utilization.auth_service_line. Business justification: Audit of Prior Authorization compliance; claim line references the authorized service line to verify authorized quantity, price, and status.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuthServiceLine .

ind:claimHeaderId rdf:type rdf:Property ;
    rdfs:label 'Claim Header Id' ;
    rdfs:comment 'Identifier of the parent claim to which this line belongs.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:ledgerId rdf:type rdf:Property ;
    rdfs:label 'Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.ledger. Business justification: Each claim line maps to a specific ledger account for revenue recognition; required for daily financial reporting and cost allocation.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:tierId rdf:type rdf:Property ;
    rdfs:label 'Tier Id' ;
    rdfs:comment 'Foreign key linking to network.network_tier. Business justification: Needed for patient billing statements; tier determines deductible, copay, and coinsurance for each claim line in network-based cost-share calculations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:anesthesiaMinutes rdf:type rdf:Property ;
    rdfs:label 'Anesthesia Minutes' ;
    rdfs:comment 'Total minutes of anesthesia administered for the line (if applicable).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cobPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Cob Paid Amount' ;
    rdfs:comment 'Amount paid by secondary/tertiary payers under COB processing.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Free-text description of the service rendered.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyIndicator rdf:type rdf:Property ;
    rdfs:label 'Emergency Indicator' ;
    rdfs:comment 'True if the service was rendered as an emergency.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epsdtIndicator rdf:type rdf:Property ;
    rdfs:label 'Epsdt Indicator' ;
    rdfs:comment 'True if the service qualifies for EPSDT coverage (for Medicaid).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:familyPlanningIndicator rdf:type rdf:Property ;
    rdfs:label 'Family Planning Indicator' ;
    rdfs:comment 'True if the service is related to family planning.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential number of the line within the claim.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current processing status of the claim line.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Category of service rendered on the line.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifier1 rdf:type rdf:Property ;
    rdfs:label 'Modifier 1' ;
    rdfs:comment 'First two-character modifier associated with the procedure code.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifier2 rdf:type rdf:Property ;
    rdfs:label 'Modifier 2' ;
    rdfs:comment 'Second two-character modifier associated with the procedure code.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifier3 rdf:type rdf:Property ;
    rdfs:label 'Modifier 3' ;
    rdfs:comment 'Third two-character modifier associated with the procedure code.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifier4 rdf:type rdf:Property ;
    rdfs:label 'Modifier 4' ;
    rdfs:comment 'Fourth two-character modifier associated with the procedure code.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcCode rdf:type rdf:Property ;
    rdfs:label 'Ndc Code' ;
    rdfs:comment 'Identifier for drug products when the line represents a pharmacy claim.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientResponsibilityAmount rdf:type rdf:Property ;
    rdfs:label 'Patient Responsibility Amount' ;
    rdfs:comment 'Sum of copay, coinsurance, and deductible amounts owed by the member.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procedureCode rdf:type rdf:Property ;
    rdfs:label 'Procedure Code' ;
    rdfs:comment 'Standard procedure code representing the service rendered.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarkCode rdf:type rdf:Property ;
    rdfs:label 'Remark Code' ;
    rdfs:comment 'Additional informational code attached to the line.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Code' ;
    rdfs:comment 'Four-digit code used for institutional billing to indicate type of service.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceDate rdf:type rdf:Property ;
    rdfs:label 'Service Date' ;
    rdfs:comment 'Date on which the service was provided.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unitsOfService rdf:type rdf:Property ;
    rdfs:label 'Units Of Service' ;
    rdfs:comment 'Quantity of the service rendered (e.g., number of visits, dosage units).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisId rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Id' ;
    rdfs:comment 'Primary key for diagnosis' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskHccMappingId rdf:type rdf:Property ;
    rdfs:label 'Risk Hcc Mapping Id' ;
    rdfs:comment 'Foreign key linking to risk.hcc_mapping. Business justification: Clinical quality and risk-adjustment reports need each diagnosis linked to its HCC mapping for proper risk score calculations.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HccMapping .

ind:diagnosisDescription rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Description' ;
    rdfs:comment 'Full textual description of the diagnosis code.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisDate rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Date' ;
    rdfs:comment 'Calendar date the diagnosis was documented on the claim.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:diagnosisStatus rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Status' ;
    rdfs:comment 'Operational status indicating if the diagnosis line is active, pending review, or logically deleted.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisType rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Type' ;
    rdfs:comment 'Specifies the role of the diagnosis (e.g., principal, admitting, external cause, other).' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drgDescription rdf:type rdf:Property ;
    rdfs:label 'Drg Description' ;
    rdfs:comment 'Textual description of the DRG code.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hccCategory rdf:type rdf:Property ;
    rdfs:label 'Hcc Category' ;
    rdfs:comment 'HCC category code used for risk-adjustment and RAF calculations.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icdVersion rdf:type rdf:Property ;
    rdfs:label 'Icd Version' ;
    rdfs:comment 'Indicates whether the diagnosis code follows ICD-9-CM or ICD-10-CM standards.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineQuantity rdf:type rdf:Property ;
    rdfs:label 'Line Quantity' ;
    rdfs:comment 'Number of times the same diagnosis appears on the claim; typically 1.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:poaIndicator rdf:type rdf:Property ;
    rdfs:label 'Poa Indicator' ;
    rdfs:comment 'Indicates if the condition was present at the time of admission (Y=Yes, N=No, U=Unknown).' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifier rdf:type rdf:Property ;
    rdfs:label 'Qualifier' ;
    rdfs:comment 'Free-text qualifier providing extra context (e.g., laterality, severity).' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureId rdf:type rdf:Property ;
    rdfs:label 'Procedure Id' ;
    rdfs:comment 'Primary key for procedure' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkServiceAreaId rdf:type rdf:Property ;
    rdfs:label 'Network Service Area Id' ;
    rdfs:comment 'Foreign key linking to network.service_area. Business justification: Supports network adequacy compliance reporting by linking procedure location to the defined service area of the provider network.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkServiceArea .

ind:surgeonCredentialRecordId rdf:type rdf:Property ;
    rdfs:label 'Surgeon Credential Record Id' ;
    rdfs:comment 'Foreign key linking to credential.credential_record. Business justification: Required for Provider Credential Verification Report: ensures surgeon\'s credentials are valid for each procedure billed.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Record .

ind:surgeonProviderProviderProviderPracticeLocationId rdf:type rdf:Property ;
    rdfs:label 'Surgeon Provider Provider Provider Practice Location Id' ;
    rdfs:comment 'Foreign key linking to provider.provider_provider. Business justification: Links surgeon NPI to provider entity for surgeon performance, outcome, and credentialing dashboards mandated by quality-measure reporting.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeLocation .

ind:anesthesiaTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Anesthesia Time Minutes' ;
    rdfs:comment 'Total minutes of anesthesia administered for the procedure.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingCategory rdf:type rdf:Property ;
    rdfs:label 'Billing Category' ;
    rdfs:comment 'Category used for billing and reimbursement rules.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeAmount rdf:type rdf:Property ;
    rdfs:label 'Charge Amount' ;
    rdfs:comment 'Billed amount for the procedure before adjustments.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Claim Adjustment Amount' ;
    rdfs:comment 'Monetary amount of the adjustment applied to the procedure charge.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Claim Adjustment Reason' ;
    rdfs:comment 'Reason code for any post-adjudication adjustment applied to this procedure.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimLineNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Line Number' ;
    rdfs:comment 'Line number of this procedure within the claim file.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codeSystem rdf:type rdf:Property ;
    rdfs:label 'Code System' ;
