    rdfs:comment 'Tracks identified gaps in network adequacy including remediation plans and exception requests.' .

ind:ProviderDirectory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Provider Directory' ;
    rdfs:comment 'Provider directory entry with verified contact and practice information for member-facing directories.' .

ind:NetworkDirectoryVerification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Network Directory Verification' ;
    rdfs:comment 'Tracks verification activities for provider directory accuracy compliance.' .

ind:VbcArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Vbc Arrangement' ;
    rdfs:comment 'Defines value-based care arrangements including shared savings/loss parameters.' .

ind:AcoProvider rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Aco Provider' ;
    rdfs:comment 'Tracks provider participation in ACO/VBC arrangements.' .

ind:Exception rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Exception' ;
    rdfs:comment 'Records network adequacy exceptions granted by regulators.' .

ind:ChangeEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Change Event' ;
    rdfs:comment 'Tracks network change events including provider additions, terminations, and tier changes.' .

ind:AccessStandard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Access Standard' ;
    rdfs:comment 'Defines appointment access and wait time standards for network providers.' .

ind:AccessSurvey rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Access Survey' ;
    rdfs:comment 'Records access survey results measuring appointment availability and wait times.' .

ind:Filing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Filing' ;
    rdfs:comment 'Tracks regulatory filings for network adequacy and compliance.' .

ind:VbcProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Vbc Program' ;
    rdfs:comment 'Defines value-based care programs with performance parameters and quality thresholds.' .

ind:NetworkRecruitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Network Recruitment' ;
    rdfs:comment 'Tracks provider recruitment efforts to address network adequacy gaps.' .

ind:Termination rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Termination' ;
    rdfs:comment 'Tracks provider network terminations including member impact and continuity of care.' .

ind:ParAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Par Agreement' ;
    rdfs:comment 'Participation agreements between providers and the network defining terms of participation.' .

ind:Group rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Group' ;
    rdfs:comment 'Employer group master record' .

ind:GroupLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Group Location' ;
    rdfs:comment 'Employer group location' .

ind:GroupContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Group Contact' ;
    rdfs:comment 'Employer group contact' .

ind:GroupDivision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Group Division' ;
    rdfs:comment 'Employer group division' .

ind:GroupPlanOffering rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Group Plan Offering' ;
    rdfs:comment 'Employer group plan offering' .

ind:ContributionStrategy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Contribution Strategy' ;
    rdfs:comment 'Employer contribution strategy' .

ind:GroupRenewal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Group Renewal' ;
    rdfs:comment 'Employer group renewal' .

ind:ParticipationRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Participation Requirement' ;
    rdfs:comment 'Employer participation requirement' .

ind:BrokerAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Broker Assignment' ;
    rdfs:comment 'Broker assignment to employer group' .

ind:TpaArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Tpa Arrangement' ;
    rdfs:comment 'TPA arrangement with employer group' .

ind:OpenEnrollmentWindow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Open Enrollment Window' ;
    rdfs:comment 'Open enrollment window for employer group' .

ind:EmployerUnderwritingCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Employer Underwriting Case' ;
    rdfs:comment 'Employer underwriting case' .

ind:RateQuote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Rate Quote' ;
    rdfs:comment 'Rate quote for employer group' .

ind:GroupAmendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Group Amendment' ;
    rdfs:comment 'Employer group amendment' .

ind:CobraAdministration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Cobra Administration' ;
    rdfs:comment 'COBRA administration for employer group' .

ind:WellnessProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Wellness Program' ;
    rdfs:comment 'Wellness program for employer group' .

ind:GroupDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Group Document' ;
    rdfs:comment 'Employer group document' .

ind:AsoFeeSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Aso Fee Schedule' ;
    rdfs:comment 'ASO fee schedule for employer group' .

ind:StopLossPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Stop Loss Policy' ;
    rdfs:comment 'Stop loss policy for employer group' .

ind:GroupRatingFactor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Group Rating Factor' ;
    rdfs:comment 'Group rating factor' .

ind:ErisaPlanDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Erisa Plan Document' ;
    rdfs:comment 'ERISA plan document' .

ind:RegulatoryComplianceRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Regulatory Compliance Record' ;
    rdfs:comment 'Regulatory compliance record for employer group' .

ind:EmployerContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Employer Contract' ;
    rdfs:comment 'Employer contract' .

ind:Broker rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Broker' ;
    rdfs:comment 'Broker master record' .

ind:Tpa rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Tpa' ;
    rdfs:comment 'Third party administrator master record' .

ind:BrokerAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Broker Agreement' ;
    rdfs:comment 'Broker agreement' .

ind:Party rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Party' ;
    rdfs:comment 'Identifies all parties bound by a provider contract — the health plan entity, the contracting provider (individual NPI or organizational NPI), group practice, IPA, ACO, or hospital system. Tracks party role (payer, provider, delegated entity), NPI, TIN, legal entity name, signatory authority, and party effective dates. Supports multi-party and delegated contracting arrangements. [FHIR-aligned]' .

ind:Term rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Term' ;
    rdfs:comment 'Defines the specific terms, conditions, obligations, and reimbursement policies within a provider contract. Captures term type (payment methodology, exclusivity, termination clause, audit rights, hold-harmless, indemnification, confidentiality, HIPAA BAA, reimbursement rule), term text, effective date, expiration date, and whether the term is negotiable or standard boilerplate. For reimbursement rule terms: captures policy sub-type (multiple procedure reduction, bilateral procedure, assistant surgeon, global surgery, unbundling rules, place-of-service differential), applicable CPT/HCPCS ranges, reduction percentage, and LOB applicability. Enables granular tracking of contractual obligations, compliance checkpoints, and reimbursement adjudication rules. Bridges contract terms to claims adjudication logic in Facets/QNXT. [FHIR-aligned]' .

ind:Amendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Amendment' ;
    rdfs:comment '[SSOT:amendment] Single source of truth (canonical) for the \'amendment\' concept. Tracks all formal amendments, addenda, and modifications to an existing provider contract. Captures amendment number, amendment type (rate change, term modification, LOB addition, network tier change), effective date, reason for amendment, negotiation outcome, approval status, and the specific contract sections modified. Maintains full amendment history for audit and compliance purposes. SSOT NOTE: This product is the single source of truth (canonical) for the \'amendment\' concept across domains. [FHIR-aligned] Designated SSOT for the amendment concept.' .

ind:FeeSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Fee Schedule' ;
    rdfs:comment 'Master fee schedule defining reimbursement rates for covered services under a provider contract. Captures fee schedule name, version, effective and termination dates, payment basis (% of Medicare, % of billed charges, flat rate, RVU-based), geographic modifier applicability, LOB scope, and fee schedule type (professional, institutional, ancillary, DME, lab). SSOT for all fee-for-service reimbursement rates. Sourced from Facets/QNXT Benefits Configuration. [FHIR-aligned]' .

ind:FeeScheduleRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Fee Schedule Rate' ;
    rdfs:comment 'Line-level reimbursement rates within a fee schedule. Each record defines the allowed amount or rate for a specific procedure code (CPT/HCPCS), revenue code, DRG, or service category. Captures procedure code, modifier, place of service, allowed amount, MAC/AWP/WAC reference, RBP rate, effective date, and rate derivation method. Enables adjudication systems to price claims against contracted rates. [FHIR-aligned]' .

ind:CapitationArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Capitation Arrangement' ;
    rdfs:comment 'Defines capitation payment arrangements where providers receive a fixed PMPM (Per Member Per Month) payment to cover a defined scope of services. Captures capitation rate, covered service categories, risk pool participation, stop-loss thresholds, carve-out services, attributed member population criteria, LOB applicability, and payment frequency. Supports HMO and managed care capitation models. [FHIR-aligned]' .

ind:CapitationPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Capitation Payment' ;
    rdfs:comment 'Transactional record of each capitation payment disbursed to a provider under a capitation arrangement. Captures payment period (month/year), attributed member count, PMPM rate applied, gross payment amount, adjustments (retroactive enrollment changes, risk pool settlements, stop-loss recoveries), net payment amount, payment date, payment status, and remittance advice reference. Feeds accounts payable, provider remittance reporting (835 ERA), and contract financial summary reconciliation. [FHIR-aligned]' .

ind:VbcContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Vbc Contract' ;
    rdfs:comment 'Master record for Value-Based Care (VBC) contracts, ACO agreements, risk-sharing arrangements, and bundled payment programs. Captures VBC model type (shared savings, shared risk, full capitation, bundled payment, pay-for-performance), ACO/IPA entity details, and reconciliation status. Includes performance period definitions with performance year, benchmark expenditure target, actual expenditure, quality score, shared savings or loss amount, reconciliation status, settlement date, minimum savings rate (MSR), maximum shared savings/loss rate, and quality gate requirements (HEDIS/STAR measure targets). For bundled payment models, captures episode definitions including episode type (joint replacement, cardiac surgery, maternity), trigger event (procedure code, DRG), episode window (days pre/post trigger), target price, included/excluded services, reconciliation methodology, and quality metrics. Supports CMS MSSP, BPCI-A, and commercial ACO/VBC reporting. SSOT for all VBC, risk-sharing, episode-based payment contractual structures, performance period tracking, bundled episode definitions, and year-over-year performance trend analysis. [FHIR-aligned]' .

ind:VbcPerformancePeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Vbc Performance Period' ;
    rdfs:comment 'Defines the measurement and reconciliation periods within a VBC contract. Captures performance year, benchmark expenditure target, actual expenditure, quality score, shared savings or loss amount, reconciliation status, and settlement date. Tracks year-over-year performance trends and supports CMS MSSP and commercial ACO reporting requirements. [FHIR-aligned]' .

ind:BundledPaymentEpisode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Bundled Payment Episode' ;
    rdfs:comment 'Defines bundled payment episodes under episode-of-care payment models. Captures episode type (joint replacement, cardiac surgery, maternity), trigger event (procedure code, DRG), episode window (days pre/post trigger), target price, included services, excluded services, reconciliation methodology, and quality metrics. Supports CMS BPCI-A and commercial bundled payment programs. [FHIR-aligned]' .

ind:ReimbursementPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Reimbursement Policy' ;
    rdfs:comment 'Defines payer reimbursement policies that govern how claims are adjudicated against contracted rates. Captures policy type (multiple procedure reduction, bilateral procedure, assistant surgeon, global surgery, unbundling rules, place-of-service differential), applicable CPT/HCPCS ranges, reduction percentage, effective date, and LOB applicability. Bridges contract terms to claims adjudication logic in Facets/QNXT. [FHIR-aligned]' .

ind:ContractLifecycleEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Contract Lifecycle Event' ;
    rdfs:comment '[SSOT:lifecycle_event] Reference to canonical SSOT member.member_lifecycle_event for the \'lifecycle_event\' concept; do not duplicate authoritative data here. Audit and lifecycle tracking for all significant events in a contract\'s lifecycle — initiation, negotiation, execution, amendment, renewal, auto-renewal execution, suspension, termination, reinstatement, renegotiation, dispute filing, dispute resolution, and arbitration. Captures event type, event date, triggered-by user or system, prior status, new status, notes, approval chain. For renewal events: renewal type (auto, renegotiated, evergreen), rate change percentage, new effective date, and responsible contracting analyst. For dispute events: dispute type (rate dispute, scope-of-service dispute, payment dispute, termination dispute), disputed amount, dispute status (open, under review, resolved, escalated to arbitration), resolution outcome, resolution date, and provider relations case reference. SSOT for all contract state transitions, dispute management, renewal pipeline tracking, and provider relations workflows. Supports compliance audit trail, proactive contract management, and regulatory examination readiness. SSOT NOTE: This product is the single source of truth (canonical) for the \'lifecycle_event\' concept across domains. [FHIR-aligned] SSOT duplicate; single source of truth is member.member_lifecycle_event.' .

ind:ServiceScope rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Service Scope' ;
    rdfs:comment 'Defines the scope of covered services included or excluded under a specific provider contract. Captures service category (inpatient, outpatient, professional, ancillary, behavioral health, DME, SNF), CPT/HCPCS code ranges, revenue code ranges, DRG ranges, inclusion/exclusion flag, carve-out indicator, and applicable LOB. Determines which services are reimbursable under the contract. [FHIR-aligned]' .

ind:DelegationAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Delegation Agreement' ;
    rdfs:comment 'Manages delegation agreements where the health plan delegates specific functions (credentialing, UM, claims payment, member services) to an IPA, ACO, TPA, or medical group. Captures delegated function type, delegating entity, delegate entity, oversight requirements, audit frequency, performance standards, NCQA/URAC delegation standards compliance, and delegation effective dates. Required for NCQA accreditation and CMS oversight. [FHIR-aligned]' .

ind:IncentiveArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Incentive Arrangement' ;
    rdfs:comment 'Unified record for all performance-linked financial arrangements within provider contracts — including pay-for-performance (P4P) bonuses, quality withholds, risk withholds, shared savings distributions, performance guarantees, SLA commitments, and penalty/incentive structures. Captures arrangement type (bonus, withhold, shared savings, performance guarantee, penalty, SLA), quality measure set (HEDIS, STAR, CAHPS, custom), performance threshold tiers, withhold percentage and release criteria (quality, utilization, shared risk), withhold pool type, target metric and measurement methodology, maximum incentive or penalty amount, total withheld amount, amount released, amount forfeited, measurement period, payout schedule, earned/forfeited status, settlement date, and reporting frequency. Supports VBC quality gate enforcement, HMO/IPA withhold models, pay-for-performance programs, and provider engagement programs. SSOT for all performance-linked financial commitments in provider contracts. [FHIR-aligned]' .

ind:ContractDispute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Contract Dispute' ;
    rdfs:comment '[SSOT:dispute] Single source of truth (canonical) for the \'dispute\' concept. Tracks formal disputes and grievances raised by providers against contract terms, reimbursement rates, or payment decisions. Captures dispute type (rate dispute, scope-of-service dispute, payment dispute, termination dispute), dispute initiation date, disputed amount, dispute status (open, under review, resolved, escalated to arbitration), resolution outcome, and resolution date. Supports provider relations and legal team workflows. SSOT NOTE: Canonical source of truth for the \'dispute\' concept is billing.billing_dispute; this product is retained as a domain-specific view/duplicate and must defer to the canonical entity. [FHIR-aligned] SSOT duplicate; single source of truth is vendor.vendor_dispute.' .

ind:NetworkParticipation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Network Participation' ;
    rdfs:comment 'Association entity linking a provider contract to specific network configurations, defining which provider networks the contract covers. Captures network ID reference, participation tier (tier 1, tier 2, preferred, standard, narrow), in-network effective and termination dates, out-of-network flag, geographic service area, product line applicability (commercial, Medicare Advantage, Medicaid, exchange/QHP), and participation status (active, pending, terminated). Bridges the contract domain to the network domain for directory accuracy and claims adjudication network matching. [FHIR-aligned]' .

ind:ContractAudit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Contract Audit' ;
    rdfs:comment 'Records formal contract compliance audits, post-payment reviews, and delegation oversight audits conducted against provider contracts and delegation agreements. Captures audit type (payment accuracy, credentialing compliance, delegation oversight, coding audit, medical record review, rate validation), audit period, audit scope, findings summary, overpayment or underpayment amount identified, corrective action plan (CAP), CAP due date, audit status (scheduled, in-progress, completed, findings-issued, CAP-pending), and next scheduled audit date. Supports NCQA delegation oversight standards, CMS program audit readiness, state DOI examination requirements, and SIU referral triggers. [FHIR-aligned]' .

ind:FinancialSummary rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Financial Summary' ;
    rdfs:comment 'Contract-level financial summary and accrual tracking record aggregating total contracted spend, paid amounts, outstanding liabilities, capitation accruals, withhold balances, incentive payouts, and reconciliation status for each provider contract by performance period. Captures summary period (month/quarter/year), total allowed amount, total paid amount, capitation accrual balance, withhold pool balance, incentive earned amount, IBNR estimate contribution, and reconciliation status. Supports finance department contract-level P&L reporting, IBNR estimation inputs, total-cost-of-care tracking for VBC contracts, medical loss ratio (MLR) allocation, and regulatory financial reporting. SSOT for contract-level financial position. Links to provider_contract as the parent entity. [FHIR-aligned]' .

ind:Obligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Obligation' ;
    rdfs:comment 'This association product records the compliance relationship between a provider contract and a regulatory obligation. It captures the compliance status and the effective/termination dates specific to each contract-obligation pairing.. Existence Justification: Each provider contract must satisfy multiple regulatory obligations (e.g., HIPAA, ACA, state mandates) and each regulatory obligation applies to many provider contracts. The compliance status, effective and termination dates of the obligation for a specific contract are tracked, making the relationship a managed business entity. [FHIR-aligned]' .

ind:PartyRegulatoryObligationCompliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Party Regulatory Obligation Compliance' ;
    rdfs:comment 'Represents the compliance relationship between a contract party and a regulatory obligation. Each record captures the compliance status and the effective/termination dates for that specific party-obligation pairing.. Existence Justification: Each provider party must satisfy multiple regulatory obligations, and each regulatory obligation applies to many provider parties. The organization tracks compliance status, effective and termination dates for each party-obligation pair, which is managed as a distinct record. [FHIR-aligned]' .

ind:AppealGrievance rdf:type rdfs:Class ;
