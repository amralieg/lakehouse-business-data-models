ind:ibnrId rdf:type rdf:Property ;
    rdfs:label 'Ibnr Id' ;
    rdfs:comment 'Primary key for ibnr' ;
    rdfs:domain ind:Ibnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actuarialMethod rdf:type rdf:Property ;
