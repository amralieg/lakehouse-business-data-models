    rdfs:comment 'Whether provider accepts new patients.' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEssentialCommunityProvider rdf:type rdf:Property ;
