    rdfs:comment 'Standardized code describing the reason for the claim adjustment/denial.' ;
    rdfs:domain ind:Denial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalCriteria rdf:type rdf:Property ;
    rdfs:label 'Clinical Criteria' ;
    rdfs:comment 'Reference to the clinical guideline or utilization management criteria applied.' ;
    rdfs:domain ind:Denial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialDate rdf:type rdf:Property ;
    rdfs:label 'Denial Date' ;
    rdfs:comment 'Date the denial decision was rendered.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:denialNumber rdf:type rdf:Property ;
    rdfs:label 'Denial Number' ;
    rdfs:comment 'External business identifier assigned to the denial, used in communications and reporting.' ;
    rdfs:domain ind:Denial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialStatus rdf:type rdf:Property ;
    rdfs:label 'Denial Status' ;
    rdfs:comment 'Current lifecycle status of the denial.' ;
    rdfs:domain ind:Denial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialType rdf:type rdf:Property ;
    rdfs:label 'Denial Type' ;
    rdfs:comment 'High-level classification of the denial reason.' ;
    rdfs:domain ind:Denial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deniedAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Denied Adjustment Amount' ;
    rdfs:comment 'Adjustments (e.g., contractual allowances, discounts) applied to the denied amount.' ;
    rdfs:domain ind:Denial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deniedGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Denied Gross Amount' ;
    rdfs:comment 'Original amount of the claim that was denied before any adjustments.' ;
    rdfs:domain ind:Denial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deniedNetAmount rdf:type rdf:Property ;
    rdfs:label 'Denied Net Amount' ;
    rdfs:comment 'Final net amount after adjustments that the member is responsible for due to the denial.' ;
    rdfs:domain ind:Denial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:letterGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Letter Generated Flag' ;
    rdfs:comment 'True if a formal denial letter was generated and sent to the member/provider.' ;
    rdfs:domain ind:Denial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'True if the denial was manually overridden by a reviewer.' ;
    rdfs:domain ind:Denial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Explanation for why the denial was overridden.' ;
    rdfs:domain ind:Denial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:racCode rdf:type rdf:Property ;
    rdfs:label 'Rac Code' ;
    rdfs:comment 'Standardized remark code that provides additional context for the denial.' ;
    rdfs:domain ind:Denial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'More granular category within the denial type, if applicable.' ;
    rdfs:domain ind:Denial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobId rdf:type rdf:Property ;
    rdfs:label 'Cob Id' ;
    rdfs:comment 'Primary key for cob' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPayerId rdf:type rdf:Property ;
    rdfs:label 'Primary Payer Id' ;
    rdfs:comment 'Internal identifier of the primary insurance payer.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClaimPayer .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Reason for any monetary adjustment applied during COB processing.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossoverClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Crossover Claim Flag' ;
    rdfs:comment 'Indicates whether the claim crosses over between primary and secondary payer responsibilities.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManualOverride rdf:type rdf:Property ;
    rdfs:label 'Is Manual Override' ;
    rdfs:comment 'True if a user manually overrode automated COB decisions.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicaidCrossoverIndicator rdf:type rdf:Property ;
    rdfs:label 'Medicaid Crossover Indicator' ;
    rdfs:comment 'Flag showing if Medicaid is involved in a crossover scenario.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:method rdf:type rdf:Property ;
    rdfs:label 'Method' ;
    rdfs:comment 'Method used for coordination of benefits: standard, non-duplication, or maintenance of benefits.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mspIndicator rdf:type rdf:Property ;
    rdfs:label 'Msp Indicator' ;
    rdfs:comment 'Flag indicating whether Medicare is acting as the secondary payer for this claim.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mspType rdf:type rdf:Property ;
    rdfs:label 'Msp Type' ;
    rdfs:comment 'Specifies the type of Medicare secondary payer relationship (full or partial).' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Net Liability Amount' ;
    rdfs:comment 'Remaining liability amount after primary and secondary payments and adjustments.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherInsuranceType rdf:type rdf:Property ;
    rdfs:label 'Other Insurance Type' ;
    rdfs:comment 'Classification of the secondary insurance when it is not a standard payer (e.g., employer group, Medicare, Medicaid, auto, workers\' compensation).' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPayerAllowedAmount rdf:type rdf:Property ;
    rdfs:label 'Primary Payer Allowed Amount' ;
    rdfs:comment 'Maximum amount the primary payer allowed for the claim before COB.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryPayerDenialReason rdf:type rdf:Property ;
    rdfs:label 'Primary Payer Denial Reason' ;
    rdfs:comment 'Reason code or description why the primary payer denied all or part of the claim.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryPayerPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Primary Payer Paid Amount' ;
    rdfs:comment 'Amount actually paid by the primary payer after adjudication.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processOrder rdf:type rdf:Property ;
    rdfs:label 'Process Order' ;
    rdfs:comment 'Sequential order in which multiple payer COB steps are applied for the claim.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingUserName rdf:type rdf:Property ;
    rdfs:label 'Processing User Name' ;
    rdfs:comment 'Display name of the user who performed the COB processing.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryPayerAllowedAmount rdf:type rdf:Property ;
    rdfs:label 'Secondary Payer Allowed Amount' ;
    rdfs:comment 'Maximum amount the secondary payer is allowed to pay for the claim.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondaryPayerCode rdf:type rdf:Property ;
    rdfs:label 'Secondary Payer Code' ;
    rdfs:comment 'Internal identifier of the secondary insurance payer.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondaryPayerDenialReason rdf:type rdf:Property ;
    rdfs:label 'Secondary Payer Denial Reason' ;
    rdfs:comment 'Reason code or description for any denial by the secondary payer.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondaryPayerName rdf:type rdf:Property ;
    rdfs:label 'Secondary Payer Name' ;
    rdfs:comment 'Legal name of the secondary insurance payer.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondaryPayerPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Secondary Payer Paid Amount' ;
    rdfs:comment 'Amount paid by the secondary payer after COB processing.' ;
    rdfs:domain ind:Cob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAllowedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Allowed Amount' ;
    rdfs:comment 'Sum of allowed amounts for all claim lines as determined by the primary payer.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Total Paid Amount' ;
    rdfs:comment 'Total amount paid by the primary payer before secondary adjudication.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Primary key for payment' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Foreign key linking to finance.bank_account. Business justification: Claim payments are disbursed through designated bank accounts; linking supports cash-management reconciliation and audit trails.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:outcomeId rdf:type rdf:Property ;
    rdfs:label 'Outcome Id' ;
    rdfs:comment 'Foreign key linking to appeal.appeal_outcome. Business justification: Payments may be adjusted based on appeal outcomes; linking to the appeal outcome enables accurate reconciliation and compliance reporting of appeal-related payment changes.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Outcome .

ind:primaryPaymentClaimClaimHeaderId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Claim Claim Header Id' ;
    rdfs:comment 'FK to claim.header' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:primaryPaymentPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Party Id' ;
    rdfs:comment 'Unique identifier of the entity receiving the payment (provider NPI or member ID).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:batchSequence rdf:type rdf:Property ;
    rdfs:label 'Batch Sequence' ;
    rdfs:comment 'Sequence order of the payment within its batch.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carcCodes rdf:type rdf:Property ;
    rdfs:label 'Carc Codes' ;
    rdfs:comment 'Pipe-separated list of CARC codes applied to the claim payment.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Check number when payment method is a paper check.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearinghouseCode rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Code' ;
    rdfs:comment 'Identifier of the EDI clearinghouse that processed the 835 transaction.' ;
