    rdfs:range ind:Party .

ind:accidentCity rdf:type rdf:Property ;
    rdfs:label 'Accident City' ;
    rdfs:comment 'City of the accident location.' ;
    rdfs:domain ind:Subrogation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accidentCountry rdf:type rdf:Property ;
    rdfs:label 'Accident Country' ;
    rdfs:comment 'Three-letter ISO country code of the accident location.' ;
    rdfs:domain ind:Subrogation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accidentDate rdf:type rdf:Property ;
    rdfs:label 'Accident Date' ;
    rdfs:comment 'Date on which the loss event occurred.' ;
    rdfs:domain ind:Subrogation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accidentStateCode rdf:type rdf:Property ;
    rdfs:label 'Accident State Code' ;
