    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkTier rdf:type rdf:Property ;
    rdfs:label 'Network Tier' ;
    rdfs:comment 'Tier classification of the PCP within the plan\'s provider network.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelStatus rdf:type rdf:Property ;
    rdfs:label 'Panel Status' ;
    rdfs:comment 'Indicates whether the PCP is currently in the member\'s provider panel.' ;
    rdfs:domain ind:HealthInsurance ;
