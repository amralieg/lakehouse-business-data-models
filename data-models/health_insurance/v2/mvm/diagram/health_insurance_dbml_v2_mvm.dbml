  document_number varchar [note: 'The document number attribute capturing relevant data for the sbc document in the plan domain.']
  document_size_bytes varchar [note: 'Document size in bytes']
  document_title varchar [note: 'The document title attribute capturing relevant data for the sbc document in the plan domain.']
  document_type varchar [note: 'The category or classification type of the document.']
  document_url varchar [note: 'The document url attribute capturing relevant data for the sbc document in the plan domain.']
