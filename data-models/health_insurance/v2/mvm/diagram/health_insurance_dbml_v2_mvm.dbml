  Note: 'Stores information about Independent Review Organizations (IROs) that conduct external reviews.'
}

Table appeal.outcome {
  outcome_id varchar [pk, note: 'Primary key for the outcome.']
  adjustment_id varchar [note: 'add column adjustment_id (BIGINT) with FK to claim.adjustment.adjustment_id - overturn outcomes generate claim adjustments']
  adverse_determination_id varchar [note: 'Foreign key linking to appeal.adverse_determination. Business justification: An outcome records the final resolution of an appeal, which ultimately resolves the original adverse determination. Linking outcome directly to adverse_determination enables overturn rate analysis (wh']
  case_id varchar [note: 'FK to the appeal case.']
  claim_header_id varchar [note: 'FK to the claim header.']
  health_plan_id varchar [note: 'Foreign key linking to plan.health_plan. Business justification: Appeal outcomes drive plan-level financial adjustments, MLR recalculations, and CMS regulatory filings. Direct health_plan attribution on outcome enables plan-level overturn rate reporting and financi']
  member_identity_id varchar [note: 'FK to the member identity.']
  pa_decision_id varchar [note: 'Foreign key linking to utilization.pa_decision. Business justification: When an appeal outcome overturns a PA denial, the outcome must reference the original pa_decision for financial reconciliation, authorized-amount adjustment, and regulatory overturn-rate reporting. No']
  plan_election_id varchar [note: 'Foreign key linking to enrollment.plan_election. Business justification: Enrollment reinstatement tracking: appeal outcomes overturning adverse determinations trigger plan election reinstatement. Linking outcome directly to plan_election supports reinstatement reporting, p']
  premium_invoice_id varchar [note: 'Foreign key linking to billing.premium_invoice. Business justification: Appeal outcome billing resolution: when a billing appeal is resolved, the outcome must reference the original invoice to trigger refunds, adjustments, or write-offs. Billing operations require this li']
  prior_outcome_id varchar [note: 'Self-referencing FK to parent outcome.']
  provider_id varchar [note: 'FK to the provider.']
  transaction_id varchar [note: 'Foreign key linking to enrollment.transaction. Business justification: Appeal outcome downstream actions: when an appeal outcome results in enrollment reinstatement or coverage restoration, the outcome must reference the enrollment transaction it affects. Required for fi']
  compliance_flag boolean [note: 'Compliance flag.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  currency_code varchar [note: 'Currency code.']
  downstream_action varchar [note: 'Downstream action required.']
  financial_impact_amount decimal(15,2) [note: 'Financial impact amount.']
  jurisdiction_state varchar [note: 'State jurisdiction.']
  member_notification_timestamp timestamp [note: 'Timestamp of member notification.']
  notes varchar [note: 'Additional notes.']
  outcome_number varchar [note: 'Unique outcome number.']
  outcome_status varchar [note: 'Current outcome status.']
  outcome_timestamp timestamp [note: 'Timestamp of the outcome.']
  outcome_type varchar [note: 'Type of outcome.']
  provider_notification_timestamp timestamp [note: 'Timestamp of provider notification.']
  reason_code varchar [note: 'Reason code.']
  reason_description varchar [note: 'Reason description.']
  regulatory_body varchar [note: 'Regulatory body.']
  source_system_record_code varchar [note: 'Source system record code.']
  updated_timestamp timestamp [note: 'Record last updated timestamp.']

  Note: 'Records the final outcomes of appeal cases including decisions, financial impacts, and downstream actions.'
}

Table risk.member_risk_score {
  member_risk_score_id varchar [pk, note: 'System-generated unique identifier for the member risk score record.']
  eligibility_span_id varchar [note: 'Foreign key linking to member.member_eligibility_span. Business justification: CMS requires risk scores to correspond to validated enrollment/eligibility periods for payment accuracy. Compliance and actuarial teams must verify each risk score aligns with an active eligibility sp']
  health_plan_id varchar [note: 'Foreign key linking to plan.health_plan. Business justification: CMS risk adjustment payment calculation requires member risk scores to be associated with the specific health_plan for RAF computation, MLR reporting, and CMS submissions. Risk actuaries and complianc']
  member_identity_id varchar [note: 'Unique identifier of the member to whom the risk score applies.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: CMS risk adjustment payments are tied to specific policy/coverage periods. Actuaries and compliance teams must link each risk score to the exact policy it was calculated for — supporting premium recon']
  score_run_id varchar
  audit_user varchar [note: 'User ID of the person who performed the most recent audit action.']
  cms_published_score decimal(10,4) [note: 'RAF score value as published by CMS after reconciliation.']
  cms_submission_status varchar [note: 'Current status of the score\'s submission to CMS.']
  corrective_action varchar [note: 'Description of actions taken to resolve score variance (e.g., code addendum, data correction).']
  created_timestamp timestamp [note: 'Timestamp when the risk score record was first created in the data lake.']
  data_quality_score varchar [note: 'Computed data-quality score for ECM scoring.']
  demographic_factor_score decimal(10,4) [note: 'Score component derived from member demographics (age, gender, Medicaid status).']
  diagnosis_count varchar [note: 'Number of distinct diagnoses captured for the member in the scoring period.']
  effective_end_date date [note: 'Effective end of the record validity window.']
  effective_start_date date [note: 'Effective start of the record validity window.']
  effective_timestamp timestamp [note: 'Exact timestamp when the risk score became effective.']
  expiration_date date [note: 'Date after which the risk score is no longer valid for payment.']
  fhir_last_updated timestamp [note: 'FHIR meta.lastUpdated for resource versioning']
  fhir_profile_url varchar [note: 'Canonical FHIR/US Core profile URL this record conforms to']
  fhir_resource_reference varchar [note: 'Stable FHIR logical resource id for interop exchange']
  fhir_resource_type varchar [note: 'FHIR resource type this record maps to for interoperability (default: RiskAssessment)']
  fhir_version_code varchar [note: 'FHIR meta.versionId optimistic concurrency token']
  hcc_codes varchar [note: 'Pipe‑separated list of HCC codes contributing to the score.']
  hcc_count bigint
  is_active boolean [note: 'Logical active flag for soft-delete and current-state filtering.']
  is_manual_override boolean [note: 'Indicates whether the score was manually overridden.']
  manual_override_reason varchar [note: 'Reason provided for a manual override of the risk score.']
  master_entity_reference varchar [note: 'Cross-domain master/golden entity key for SSOT resolution.']
  model_name varchar [note: 'Name of the risk adjustment model (e.g., "CMS‑HCC", "RxHCC", "HHS‑HCC").']
  model_version varchar [note: 'Version identifier of the actuarial model used to generate the score (e.g., "CMS‑HCC v2023").']
  payment_year bigint [note: 'Calendar year for which the risk score is used in CMS payment calculations.']
  plan_calculated_score decimal(10,4) [note: 'RAF score calculated internally by the health plan prior to CMS submission.']
  raf_score decimal [note: 'add column raf_score, hcc_count, score_methodology_code (CMS-HCC v24, etc.), payment_year, score_run_id (BIGINT) FK to risk.score_run.score_run_id']
  record_created_at timestamp [note: 'Timestamp the record was created (audit lineage).']
  record_source_system varchar [note: 'System of record / source system that produced this record (SSOT provenance).']
  record_status varchar [note: 'Lifecycle status of the risk score record.']
  record_updated_at timestamp [note: 'Timestamp the record was last updated (audit lineage).']
  record_version varchar [note: 'Optimistic-concurrency / change version of the record.']
  resubmission_reference varchar [note: 'Reference identifier for any resubmitted score file to CMS.']
  risk_adjustment_factor_category varchar [note: 'Category of the risk adjustment factor (e.g., "RAF", "HCC", "RxHCC").']
  risk_score_code varchar [note: 'Business identifier code for the risk score record, often composed of member ID, year, and model version.']
  risk_score_confidence_score decimal(5,2) [note: 'Confidence level (0‑100) assigned by the model to the score.']
  risk_score_label varchar [note: 'Human‑readable label describing the risk score record (e.g., "2023 Medicare Advantage RAF").']
  risk_score_notes varchar [note: 'Free‑text field for any additional commentary or observations.']
  risk_score_source varchar [note: 'Data source used to generate the score.']
  risk_score_status varchar [note: 'Current processing status of the risk score.']
  risk_score_type varchar [note: 'Indicates whether the score is projected (prospective), derived from current data (concurrent), or the final CMS‑published value.']
  risk_score_value decimal(10,4) [note: 'Numeric RAF score calculated for the member (e.g., 1.2345).']
  score_components varchar [note: 'Delimited list or JSON string of component scores (e.g., HCC contributions, demographic adjustments).']
  score_effective_date date [note: 'Date on which the risk score becomes effective for payment calculations.']
  score_methodology_code varchar
  score_variance decimal(10,4) [note: 'Numeric difference between the plan‑calculated score and the CMS‑published score.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the risk score record.']
  variance_category varchar [note: 'Root‑cause classification for any variance between plan and CMS scores.']

  Note: 'Authoritative member-level risk score record and reconciliation tracker. Captures RAF (Risk Adjustment Factor) scores, HCC (Hierarchical Condition Category) mappings, CMS reconciliation outcomes, and plan-vs-CMS variance analysis. Stores prospective and concurrent RAF scores derived from actuarial models and encounter data, including score effective dates, payment year, model version (CMS-HCC, RxHCC, HHS-HCC, PACE), score components, CMS submission status, plan-calculated vs. CMS-published RAF variance, root cause category (missing diagnoses, HCC hierarchy differences, demographic factors), corrective actions, and resubmission references. Core SSOT for member-level risk in Medicare Advantage, ACA, and Medicaid risk adjustment programs. Subsumes RAF reconciliation tracking.'
}

Table risk.hcc_mapping {
  hcc_mapping_id varchar [pk, note: 'Primary key for hcc_mapping']
  member_risk_score_id varchar [note: 'add column member_risk_score_id (BIGINT) with FK to risk.member_risk_score.member_risk_score_id - HCC mappings feed RAF scores']
  age_adjustment_factor decimal(5,4) [note: 'Multiplier adjusting the HCC coefficient based on member age.']
  coefficient decimal(10,6) [note: 'Weighting coefficient used in RAF score calculations for the HCC.']
  created_timestamp timestamp [note: 'Timestamp when the mapping record was first loaded into the lakehouse.']
  data_quality_score varchar [note: 'Computed data-quality score for ECM scoring.']
  demographic_adjustment_factor decimal(5,4) [note: 'Factor adjusting the HCC weight for demographic characteristics (age, gender, etc.).']
  disease_interaction_group varchar [note: 'Identifier for a group of diagnoses that have interaction effects.']
  effective_date date [note: 'Date when this mapping becomes effective.']
  effective_end_date date [note: 'Effective end of the record validity window.']
  effective_start_date date [note: 'Effective start of the record validity window.']
  expiration_date date [note: 'Date when this mapping expires or is superseded; null if still active.']
  fhir_last_updated timestamp [note: 'FHIR meta.lastUpdated for resource versioning']
  fhir_profile_url varchar [note: 'Canonical FHIR/US Core profile URL this record conforms to']
  fhir_resource_reference varchar [note: 'Stable FHIR logical resource id for interop exchange']
  fhir_resource_type varchar [note: 'FHIR resource type this record maps to for interoperability (default: Basic)']
  fhir_version_code varchar [note: 'FHIR meta.versionId optimistic concurrency token']
  gender_adjustment_factor decimal(5,4) [note: 'Multiplier adjusting the HCC coefficient based on member gender.']
  hcc_code varchar [note: 'CMS-assigned HCC identifier linked to the diagnosis.']
  hcc_description varchar [note: 'Human‑readable description of the HCC.']
  hcc_mapping_status varchar [note: 'Current lifecycle status of the mapping record.']
  hierarchy_level varchar [note: 'Depth of the HCC within the hierarchical structure (0 = top level).']
  icd10_code varchar [note: 'Standard ICD-10 diagnosis code associated with the mapping.']
  icd10_description varchar [note: 'Full textual description of the ICD-10 diagnosis.']
  interaction_flag varchar [note: 'Indicates whether the diagnosis interacts with other HCCs (yes) or not (no).']
  is_active boolean [note: 'Logical active flag for soft-delete and current-state filtering.']
  is_excluded boolean [note: 'Indicates whether the diagnosis is excluded from the current model year.']
  is_mapped boolean [note: 'True if the ICD‑10 code has a valid HCC mapping in this version.']
  last_review_date date [note: 'Date when the mapping was last reviewed for accuracy.']
  last_updated_by varchar [note: 'Identifier of the user or process that performed the last update.']
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent update to the mapping record.']
  mapping_source varchar [note: 'Origin of the mapping data.']
  master_entity_reference varchar [note: 'Cross-domain master/golden entity key for SSOT resolution.']
  model_year varchar [note: 'Calendar year of the CMS HCC model version to which the mapping applies.']
  notes varchar [note: 'Free‑form comments or audit notes regarding the mapping.']
  parent_hcc_code varchar [note: 'Code of the immediate parent HCC in the hierarchy, if applicable.']
  plan_type_adjustment_factor decimal(5,4) [note: 'Adjustment factor for the HCC based on the member\'s health plan type (e.g., HMO, PPO).']
  record_created_at timestamp [note: 'Timestamp the record was created (audit lineage).']
  record_source_system varchar [note: 'System of record / source system that produced this record (SSOT provenance).']
  record_status varchar [note: 'Standard ECM audit/governance attribute record_status.']
  record_updated_at timestamp [note: 'Timestamp the record was last updated (audit lineage).']
  record_version varchar [note: 'Optimistic-concurrency / change version of the record.']
  region_adjustment_factor decimal(5,4) [note: 'Adjustment factor reflecting geographic cost variations.']
  review_status varchar [note: 'Current status of the most recent review process.']
  risk_score_weight decimal(5,4) [note: 'Weight applied to the HCC when aggregating RAF scores.']
  source_version varchar [note: 'Version identifier of the source CMS model (e.g., V24, V28).']
  updated_timestamp timestamp [note: 'Standard ECM audit/governance attribute updated_timestamp.']

  Note: 'Maps ICD-10 diagnosis codes to Hierarchical Condition Categories (HCCs) per CMS model version. Stores the ICD-to-HCC crosswalk, HCC hierarchy relationships (parent/child HCC hierarchies), coefficient values by model year, disease interaction flags, and demographic adjustment factors. Supports RAF score calculation, RAPS/EDPS submission validation, and RADV audit defense. Reference entity managed per CMS annual model updates (V24, V28 transition). Source: CMS annual HCC model release files.'
}

Table risk.raps_submission {
  raps_submission_id varchar [pk, note: 'System-generated unique identifier for each RAPS submission batch record.']
  health_plan_id varchar [note: 'Unique identifier of the health plan (contract) associated with the RAPS submission.']
  score_run_id varchar [note: 'Foreign key linking to risk.score_run. Business justification: RAPS submissions to CMS are generated from a specific score run — the risk scores and RAF values in the submission are produced by a particular score_run execution (model version, run date, population']
  accepted_record_count varchar [note: 'Number of records that CMS accepted without error in this submission.']
  batch_number varchar [note: 'External batch identifier assigned by the source system for the RAPS submission.']
  cms_acknowledgment_status varchar [note: 'Acknowledgment status returned by CMS for the submitted batch.']
  created_timestamp timestamp [note: 'Timestamp when the submission record was first created in the data warehouse.']
  data_quality_score varchar [note: 'Computed data-quality score for ECM scoring.']
  effective_end_date date [note: 'Effective end of the record validity window.']
  effective_start_date date [note: 'Effective start of the record validity window.']
  error_disposition varchar [note: 'Textual description of any errors or rejections returned by CMS for this batch.']
  fhir_last_updated timestamp [note: 'FHIR meta.lastUpdated for resource versioning']
  fhir_profile_url varchar [note: 'Canonical FHIR/US Core profile URL this record conforms to']
  fhir_resource_reference varchar [note: 'Stable FHIR logical resource id for interop exchange']
  fhir_resource_type varchar [note: 'FHIR resource type this record maps to for interoperability (default: Basic)']
  fhir_version_code varchar [note: 'FHIR meta.versionId optimistic concurrency token']
  is_active boolean [note: 'Logical active flag for soft-delete and current-state filtering.']
  master_entity_reference varchar [note: 'Cross-domain master/golden entity key for SSOT resolution.']
  payment_year varchar [note: 'Calendar year for which the risk adjustment payment is being calculated.']
  plan_contract_number varchar [note: 'Contract number of the plan submitted to CMS for risk adjustment.']
  plan_type varchar [note: 'Type of health plan associated with the submission (e.g., HMO, PPO).']
  raps_submission_status varchar [note: 'Current processing status of the RAPS submission within the CMS workflow.']
  record_created_at timestamp [note: 'Timestamp the record was created (audit lineage).']
  record_source_system varchar [note: 'System of record / source system that produced this record (SSOT provenance).']
  record_status varchar [note: 'Standard ECM audit/governance attribute record_status.']
  record_updated_at timestamp [note: 'Timestamp the record was last updated (audit lineage).']
  record_version varchar [note: 'Optimistic-concurrency / change version of the record.']
  rejected_record_count varchar [note: 'Number of records that CMS rejected or flagged with errors in this submission.']
  risk_adjustment_factor decimal(5,4) [note: 'Aggregated HCC-derived factor used to compute the plan\'s risk adjustment payment.']
  risk_adjustment_year varchar [note: 'Year for which the risk adjustment factors are being reported.']
  risk_score decimal(10,4) [note: 'Risk Adjustment Factor (RAF) score calculated for the plan in this submission.']
  submission_file_checksum varchar [note: 'SHA-256 checksum of the transmitted file to ensure data integrity.']
  submission_file_name varchar [note: 'Name of the flat file or payload transmitted to CMS for this batch.']
  submission_timestamp timestamp [note: 'Date and time when the RAPS batch was transmitted to the CMS gateway.']
  submission_user_name varchar [note: 'Display name of the user who submitted the batch.']
  total_record_count varchar [note: 'Total number of individual member risk adjustment records included in the batch.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the submission record.']

  Note: 'Tracks Risk Adjustment Processing System (RAPS) submissions to CMS for Medicare Advantage risk adjustment. Captures submission batch ID, submission date, plan contract number, payment year, record counts, accepted/rejected record counts, CMS acknowledgment status, and error disposition. Each record represents a RAPS batch transaction submitted via the CMS RAPS gateway. Source: Milliman MG-ALFA and EDI gateway.'
}

Table risk.score_run {
  score_run_id varchar [pk, note: 'Primary key for score_run']
  health_plan_id varchar [note: 'Foreign key linking to plan.health_plan. Business justification: Score runs are executed against a specific plan population for CMS model year alignment and actuarial sign-off. Risk analytics teams must filter score runs by health_plan to produce plan-level RAF sum']
  actuarial_signoff_date date [note: 'Date the actuarial sign‑off was recorded.']
  average_raf_score decimal(10,4) [note: 'Mean RAF score across the member population for the run.']
  cms_model_year varchar [note: 'Calendar year of the CMS model specification applied in the run.']
  created_timestamp timestamp [note: 'Timestamp when the run record was first created in the data lake.']
  data_quality_flag varchar [note: 'Indicator of the overall data quality for the run.']
  data_quality_score varchar [note: 'Computed data-quality score for ECM scoring.']
  data_snapshot_date date [note: 'Date of the data extract snapshot used for scoring.']
  effective_end_date date [note: 'Effective end of the record validity window.']
  effective_start_date date [note: 'Effective start of the record validity window.']
  fhir_last_updated timestamp [note: 'FHIR meta.lastUpdated for resource versioning']
  fhir_profile_url varchar [note: 'Canonical FHIR/US Core profile URL this record conforms to']
  fhir_resource_reference varchar [note: 'Stable FHIR logical resource id for interop exchange']
  fhir_resource_type varchar [note: 'FHIR resource type this record maps to for interoperability (default: Basic)']
  fhir_version_code varchar [note: 'FHIR meta.versionId optimistic concurrency token']
  input_data_period_end date [note: 'Last day of the data period used as input for the model.']
  input_data_period_start date [note: 'First day of the data period used as input for the model.']
  is_active boolean [note: 'Logical active flag for soft-delete and current-state filtering.']
  master_entity_reference varchar [note: 'Cross-domain master/golden entity key for SSOT resolution.']
  member_population_count varchar [note: 'Number of members included in the scoring run.']
  model_name varchar [note: 'Descriptive name of the actuarial risk model (e.g., CMS-HCC Model).']
  model_status varchar [note: 'Current lifecycle status of the risk model used in the run.']
  model_version varchar [note: 'Version string of the risk model used for the run.']
  normalization_factor decimal(10,4) [note: 'Factor applied to adjust raw scores to a common scale.']
  population_segment varchar [note: 'Member segment targeted by the run.']
  record_created_at timestamp [note: 'Timestamp the record was created (audit lineage).']
  record_source_system varchar [note: 'System of record / source system that produced this record (SSOT provenance).']
  record_status varchar [note: 'Standard ECM audit/governance attribute record_status.']
  record_updated_at timestamp [note: 'Timestamp the record was last updated (audit lineage).']
  record_version varchar [note: 'Optimistic-concurrency / change version of the record.']
  risk_model_type varchar [note: 'Category of the risk model applied.']
  run_code varchar [note: 'Business identifier code for the run, often used in reporting and audit logs.']
  run_date date [note: 'Date on which the run was initiated.']
  run_description varchar [note: 'Free‑form description or notes about the run.']
  run_status varchar [note: 'Current lifecycle status of the run.']
  run_type varchar [note: 'Indicates whether the run is a production, test, or reconciliation execution.']
  score_distribution_summary varchar [note: 'JSON-formatted summary of score buckets and frequencies.']
  total_raf_score decimal(18,4) [note: 'Sum of all Risk Adjustment Factor (RAF) scores calculated in the run.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the run record.']

  Note: 'Represents a risk score model configuration and its production/test execution runs against the member population. Captures model name, model version, CMS model year, risk model type (CMS-HCC, RxHCC, HHS-HCC, CDPS), population segment (Medicare, Medicaid, Commercial), normalization factor, model status, run type (production/test/reconciliation), run date, input data period, data snapshot date, member population count, total and average RAF scores, score distribution summary, run status, and actuarial sign-off. Manages the actuarial model catalog and provides the complete audit trail from model configuration through execution for each risk score production cycle. Source: Milliman MG-ALFA.'
}

Table risk.radv_audit {
  radv_audit_id varchar [pk, note: 'Unique surrogate key for each RADV audit record.']
  case_id varchar [note: 'Foreign key linking to appeal.case. Business justification: CMS RADV audits with adverse findings trigger formal appeal cases under the RADV Appeals Process. Risk adjustment teams must link each RADV audit to its associated appeal case to track dispute status,']
  claim_header_id varchar [note: 'Foreign key linking to claim.header. Business justification: RADV audits validate HCC coding accuracy by reviewing specific sampled claims. Auditors must pull the exact claim record to verify diagnosis documentation supports the HCC. This link is operationally ']
  health_plan_id varchar [note: 'Foreign key linking to plan.health_plan. Business justification: RADV audits are conducted by CMS at the plan/contract level. Linking radv_audit to health_plan enables plan-level audit tracking, financial settlement reconciliation, and regulatory compliance reporti']
  member_risk_score_id varchar [note: 'Foreign key linking to risk.member_risk_score. Business justification: RADV audits are performed to validate the accuracy of member-level risk scores submitted to CMS for Medicare Advantage. Each audit record directly validates a specific member_risk_score record — the a']
  member_subscriber_id varchar [note: 'Unique identifier of the member whose records were sampled for the audit.']
  rendering_facility_id varchar [note: 'Foreign key linking to provider.facility. Business justification: RADV audits require medical record retrieval from the facility where the audited encounter occurred. The medical_record_request_status field confirms record retrieval workflows exist. Linking to the r']
  rendering_provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: CMS RADV audits require medical record retrieval from the rendering provider who submitted the HCC-supporting diagnosis. RADV audit teams must identify and contact the specific provider for record req']
  appeal_status varchar [note: 'Current status of any appeal filed against CMS audit findings.']
  audit_end_timestamp timestamp [note: 'Timestamp when the audit reached final settlement.']
  audit_error_description varchar [note: 'Text description of the error condition when audit_error_flag is true.']
  audit_error_flag boolean [note: 'Indicates whether any processing error was detected for this audit record.']
  audit_notes varchar [note: 'Free‑form notes captured by auditors during the audit process.']
  audit_source varchar [note: 'Origin of the audit request – either CMS‑initiated or internally initiated.']
  audit_start_timestamp timestamp [note: 'Timestamp when the audit process was initiated.']
  audit_status varchar [note: 'Current lifecycle state of the RADV audit.']
  audit_type varchar [note: 'Indicates whether this is an initial RADV audit or a follow‑up audit.']
  audit_updated_by varchar [note: 'User identifier of the analyst who last updated the audit record.']
  audit_year varchar [note: 'Calendar year in which the RADV audit was performed.']
  cms_findings varchar [note: 'Summary of findings and observations reported by CMS for this audit.']
  created_timestamp timestamp [note: 'Standard ECM audit/governance attribute created_timestamp.']
  currency_code varchar [note: 'Three‑letter ISO currency code for monetary amounts.']
  data_quality_score varchar [note: 'Computed data-quality score for ECM scoring.']
  effective_end_date date [note: 'Effective end of the record validity window.']
  effective_start_date date [note: 'Effective start of the record validity window.']
  extrapolated_payment_error decimal(15,2) [note: 'Estimated monetary error in payments derived from audit findings, before final settlement.']
  fhir_last_updated timestamp [note: 'FHIR meta.lastUpdated for resource versioning']
  fhir_profile_url varchar [note: 'Canonical FHIR/US Core profile URL this record conforms to']
  fhir_resource_reference varchar [note: 'Stable FHIR logical resource id for interop exchange']
  fhir_resource_type varchar [note: 'FHIR resource type this record maps to for interoperability (default: Basic)']
  fhir_version_code varchar [note: 'FHIR meta.versionId optimistic concurrency token']
  final_settlement_amount decimal(15,2) [note: 'Monetary amount finally paid or recovered after audit resolution.']
  hcc_mapping_version varchar [note: 'Version of the HCC mapping algorithm used for validation.']
  is_active boolean [note: 'Logical active flag for soft-delete and current-state filtering.']
  master_entity_reference varchar [note: 'Cross-domain master/golden entity key for SSOT resolution.']
  medical_record_receipt_date date [note: 'Date on which the requested medical records were received.']
  medical_record_request_status varchar [note: 'Current status of the request for medical records from providers.']
  record_created timestamp [note: 'Timestamp when this audit record was first captured in the data warehouse.']
  record_created_at timestamp [note: 'Timestamp the record was created (audit lineage).']
  record_source_system varchar [note: 'System of record / source system that produced this record (SSOT provenance).']
  record_status varchar [note: 'Standard ECM audit/governance attribute record_status.']
  record_updated timestamp [note: 'Timestamp of the most recent modification to this audit record.']
  record_updated_at timestamp [note: 'Timestamp the record was last updated (audit lineage).']
  record_version varchar [note: 'Optimistic-concurrency / change version of the record.']
  risk_adjustment_factor decimal(5,4) [note: 'RAF score applied to the member cohort for this audit.']
  sampled_member_count varchar [note: 'Number of members selected for review in this audit.']
  updated_timestamp timestamp [note: 'Standard ECM audit/governance attribute updated_timestamp.']
  validated_hcc_count varchar [note: 'Number of Hierarchical Condition Categories confirmed as accurate after audit.']

  Note: 'Manages CMS Risk Adjustment Data Validation (RADV) audit records for Medicare Advantage contracts. Captures audit year, contract number, sampled member list, medical record request status, medical record receipt date, CMS audit findings, validated HCC count, extrapolated payment error, appeal status, and final settlement amount. Tracks the full RADV audit lifecycle from CMS notification through final payment reconciliation.'
}

