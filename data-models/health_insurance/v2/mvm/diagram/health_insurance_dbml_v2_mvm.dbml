  expiration_date date [note: 'The date value representing expiration date for this sbc document record.']
  format varchar [note: 'Document format']
  is_current boolean [note: 'Current version flag']
  language varchar [note: 'Document language']
  plan_year varchar [note: 'The calendar or fiscal year associated with the plan.']
  regulatory_submission_status varchar [note: 'The current status indicator for the regulatory submission within the workflow.']
  revision_number varchar [note: 'The revision number attribute capturing relevant data for the sbc document in the plan domain.']
  sbc_document_status varchar [note: 'Document status']
  sbc_version varchar [note: 'The sbc version attribute capturing relevant data for the sbc document in the plan domain.']
  submission_date date [note: 'The date value representing submission date for this sbc document record.']
  updated_timestamp timestamp [note: 'The updated timestamp attribute capturing relevant data for the sbc document in the plan domain.']
  version_number varchar [note: 'The version number attribute capturing relevant data for the sbc document in the plan domain.']
  vreq_validated boolean [note: 'VREQ validation marker']

  Note: 'Summary of Benefits and Coverage document'
}

Table plan.rate {
  rate_id varchar [pk, note: 'Primary key']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Premium rates in health insurance are often tied to specific benefit package designs — different benefit packages (e.g., bronze vs. gold metal tier packages) within the same health plan carry differen']
  health_plan_id varchar [note: 'FK to health plan']
  service_area_id varchar [note: 'Foreign key linking to plan.plan_service_area. Business justification: ACA-compliant premium rates are filed and applied by geographic rating area. rate currently has rating_area_code as a denormalized string. plan_service_area is the authoritative source for geographic ']
  age_rated_premium decimal(18,2) [note: 'The age rated premium attribute capturing relevant data for the rate in the plan domain.']
  base_rate decimal(12,4) [note: 'The numeric base rate value associated with this rate record.']
  change_reason varchar [note: 'The change reason for this record.']
  code decimal(18,2) [note: 'A standardized code representing the rate classification.']
  cost_sharing_rule_code decimal(18,2) [note: 'The cost sharing rule code for this record.']
  created_timestamp timestamp [note: 'The created timestamp attribute capturing relevant data for the rate in the plan domain.']
  currency_code varchar [note: 'A standardized code representing the currency classification.']
  effective_date date [note: 'The date value representing effective date for this rate record.']
  family_tier varchar [note: 'The family tier attribute capturing relevant data for the rate in the plan domain.']
  family_tier_premium decimal(18,2) [note: 'The family tier premium attribute capturing relevant data for the rate in the plan domain.']
  filing_reference varchar [note: 'The filing reference attribute capturing relevant data for the rate in the plan domain.']
  is_tobacco_surcharge_applicable boolean [note: 'The is tobacco surcharge applicable for this record.']
  market_segment varchar [note: 'The market segment attribute capturing relevant data for the rate in the plan domain.']
  max_age varchar [note: 'Maximum age']
  min_age varchar [note: 'Minimum age']
  name decimal(18,2) [note: 'The descriptive name assigned to the rate for identification purposes.']
  plan_designation varchar [note: 'The plan designation attribute capturing relevant data for the rate in the plan domain.']
  plan_year varchar [note: 'The calendar or fiscal year associated with the plan.']
  premium_type decimal(18,2) [note: 'The premium type for this record.']
  rate_status decimal(18,2) [note: 'The current status indicator for the rate within the workflow.']
  regulatory_filing_type varchar [note: 'The category or classification type of the regulatory filing.']
  surcharge_amount decimal(18,2) [note: 'The numeric surcharge amount value associated with this rate record.']
  termination_date date [note: 'The date value representing termination date for this rate record.']
  tobacco_use_indicator boolean [note: 'The tobacco use indicator attribute capturing relevant data for the rate in the plan domain.']
  underwriting_class_code varchar [note: 'A standardized code representing the underwriting class classification.']
  updated_timestamp timestamp [note: 'The updated timestamp attribute capturing relevant data for the rate in the plan domain.']
  version varchar [note: 'The version for this record.']
  vreq_validated boolean [note: 'VREQ validation marker']

  Note: 'Premium rate configuration'
}

Table plan.service_area {
