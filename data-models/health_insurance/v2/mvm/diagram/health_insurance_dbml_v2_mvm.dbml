  last_review_date date [note: 'The date value representing last review date for this health plan record.']
  line_of_business varchar [note: 'The line of business attribute capturing relevant data for the health plan in the plan domain.']
  market_segment varchar [note: 'The market segment attribute capturing relevant data for the health plan in the plan domain.']
  network_tier varchar [note: 'The network tier attribute capturing relevant data for the health plan in the plan domain.']
  out_of_pocket_max_family decimal(10,2) [note: 'Family OOP max']
  out_of_pocket_max_individual decimal(10,2) [note: 'Individual OOP max']
  plan_aca_compliant boolean [note: 'ACA compliant flag']
  plan_category varchar [note: 'The plan category attribute capturing relevant data for the health plan in the plan domain.']
  plan_code varchar [note: 'Plan code identifier']
  plan_description varchar [note: 'A detailed textual description of the plan.']
  plan_marketplace_eligible boolean [note: 'Marketplace eligible flag']
  plan_name varchar [note: 'The descriptive name assigned to the plan for identification purposes.']
  plan_region varchar [note: 'Region where plan is offered']
  plan_state varchar [note: 'State where plan is offered']
  plan_status varchar [note: 'The current status indicator for the plan within the workflow.']
  plan_type varchar [note: 'Plan type (HMO, PPO, etc)']
  plan_year varchar [note: 'The calendar or fiscal year associated with the plan.']
  premium_amount decimal(18,2) [note: 'The numeric premium amount value associated with this health plan record.']
  premium_currency decimal(18,2) [note: 'The premium currency for this record.']
  premium_frequency decimal(18,2) [note: 'The premium frequency for this record.']
  regulatory_classification varchar [note: 'The regulatory classification attribute capturing relevant data for the health plan in the plan domain.']
  risk_adjustment_factor decimal(5,4) [note: 'The risk adjustment factor attribute capturing relevant data for the health plan in the plan domain.']
  sbc_document_url varchar [note: 'The sbc document url attribute capturing relevant data for the health plan in the plan domain.']
  termination_date date [note: 'The date value representing termination date for this health plan record.']
  updated_timestamp timestamp [note: 'The updated timestamp attribute capturing relevant data for the health plan in the plan domain.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Core health plan entity containing plan design, cost sharing, and regulatory details'
}

Table plan.benefit_package {
  benefit_package_id varchar [pk, note: 'Primary key']
  health_plan_id varchar [note: 'FK to health plan']
  network_config_id varchar [note: 'Foreign key linking to plan.network_config. Business justification: A benefit package is associated with a specific network configuration — the network tier and designation define which provider network applies to the benefit package (e.g., HMO benefit package uses a ']
  actuarial_value_pct decimal(5,2) [note: 'Actuarial value percentage']
  benefit_package_status varchar [note: 'Package status']
  coinsurance_inpatient decimal(18,2) [note: 'Inpatient coinsurance']
  coinsurance_outpatient decimal(18,2) [note: 'Outpatient coinsurance']
  copay_primary_care decimal(18,2) [note: 'Primary care copay']
  copay_specialist decimal(18,2) [note: 'Specialist copay']
  created_timestamp timestamp [note: 'The created timestamp attribute capturing relevant data for the benefit package in the plan domain.']
  deductible_type decimal(18,2) [note: 'The deductible type for this record.']
  effective_end_date date [note: 'The date value representing effective end date for this benefit package record.']
  effective_start_date date [note: 'The date value representing effective start date for this benefit package record.']
  family_deductible_amount decimal(18,2) [note: 'Family deductible']
  generic_substitution_required boolean [note: 'Generic substitution required flag']
  individual_deductible_amount decimal(18,2) [note: 'Individual deductible']
  mail_order_copay_brand decimal(18,2) [note: 'Brand mail order copay']
  mail_order_copay_generic decimal(18,2) [note: 'Generic mail order copay']
  metal_tier varchar [note: 'Metal tier (Bronze, Silver, Gold, Platinum)']
  out_of_pocket_max_family decimal(10,2) [note: 'Family OOP max']
  out_of_pocket_max_individual decimal(10,2) [note: 'Individual OOP max']
  package_code varchar [note: 'A standardized code representing the package classification.']
  package_name varchar [note: 'The descriptive name assigned to the package for identification purposes.']
  plan_type varchar [note: 'The category or classification type of the plan.']
  prior_auth_required boolean [note: 'Prior auth required flag']
  retail_copay_brand decimal(18,2) [note: 'Brand retail copay']
  retail_copay_generic decimal(18,2) [note: 'Generic retail copay']
  specialty_copay decimal(18,2) [note: 'Specialty drug copay']
  specialty_drug_management_program varchar [note: 'The specialty drug management program for this record.']
  updated_timestamp timestamp [note: 'The updated timestamp attribute capturing relevant data for the benefit package in the plan domain.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Benefit package grouping benefits and cost sharing rules'
}

Table plan.benefit {
  benefit_id varchar [pk, note: 'Primary key']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: A benefit belongs to a benefit package — benefit_package is the grouping entity that organizes individual benefits and cost-sharing rules within a health plan. This 1:N relationship (benefit_package h']
  drug_master_id varchar [note: 'Foreign key linking to pharmacy.drug_master. Business justification: Drug-specific benefit rules (specialty drug benefits, formulary exclusions) must reference the drug master for NDC validation, therapeutic class assignment, and ACA EHB compliance reporting. Plan desi']
  health_plan_id varchar [note: 'FK to health plan']
  accumulation_rule varchar [note: 'The accumulation rule for this record.']
  authorization_required boolean [note: 'Authorization required flag']
  authorization_type varchar [note: 'The category or classification type of the authorization.']
  benefit_group varchar [note: 'The benefit group attribute capturing relevant data for the benefit in the plan domain.']
  benefit_status varchar [note: 'The current status indicator for the benefit within the workflow.']
  category varchar [note: 'The benefit category attribute capturing relevant data for the benefit in the plan domain.']
  code varchar [note: 'A standardized code representing the benefit classification.']
  cost_sharing_amount decimal(18,2) [note: 'The numeric cost sharing amount value associated with this benefit record.']
  cost_sharing_frequency decimal(18,2) [note: 'The cost sharing frequency for this record.']
  cost_sharing_percent decimal(18,2) [note: 'Cost sharing percentage']
  cost_sharing_type decimal(18,2) [note: 'The category or classification type of the cost sharing.']
  coverage_type varchar [note: 'The category or classification type of the coverage.']
  created_timestamp timestamp [note: 'The created timestamp attribute capturing relevant data for the benefit in the plan domain.']
  diagnosis_code varchar [note: 'The diagnosis code for this record.']
  effective_end_date date [note: 'The date value representing effective end date for this benefit record.']
  effective_start_date date [note: 'The date value representing effective start date for this benefit record.']
  ehb_classification varchar [note: 'Essential health benefit classification']
  exclusion_code varchar [note: 'The exclusion code for this record.']
  exclusion_reason varchar [note: 'The exclusion reason for this record.']
  exclusion_type varchar [note: 'The exclusion type for this record.']
  formulary_tier varchar [note: 'The formulary tier for this record.']
  is_exempt boolean [note: 'Exempt flag']
  is_mandatory boolean [note: 'Mandatory benefit flag']
  limit_period varchar [note: 'The limit period attribute capturing relevant data for the benefit in the plan domain.']
  limit_type varchar [note: 'The category or classification type of the limit.']
  limit_value decimal(12,2) [note: 'The limit value attribute capturing relevant data for the benefit in the plan domain.']
  moop_max_amount decimal(18,2) [note: 'The moop max amount for this record.']
  name varchar [note: 'The descriptive name assigned to the benefit for identification purposes.']
  oop_max_amount decimal(18,2) [note: 'The oop max amount for this record.']
  plan_year varchar [note: 'The calendar or fiscal year associated with the plan.']
  preventive_service_flag boolean [note: 'Boolean indicator for the preventive service condition or state.']
  prior_auth_review_level varchar [note: 'The prior auth review level for this record.']
  regulatory_classification varchar [note: 'The regulatory classification attribute capturing relevant data for the benefit in the plan domain.']
  service_code varchar [note: 'A standardized code representing the service classification.']
  tier varchar [note: 'The tier for this record.']
  updated_timestamp timestamp [note: 'The updated timestamp attribute capturing relevant data for the benefit in the plan domain.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']
  wellness_mandate_flag boolean [note: 'The wellness mandate flag for this record.']

  Note: 'Individual benefit definition within a plan'
}

Table plan.cost_share_rule {
  cost_share_rule_id varchar [pk, note: 'Primary key']
  benefit_id varchar [note: 'FK to benefit']
  benefit_package_id varchar [note: 'FK to benefit package']
  health_plan_id varchar [note: 'FK to health plan']
  network_config_id varchar [note: 'Foreign key linking to plan.network_config. Business justification: Cost sharing rules are network-tier-specific — in-network and out-of-network cost sharing rules differ based on the network configuration. cost_share_rule has network_type as a string attribute and se']
  accumulator_threshold decimal(12,2) [note: 'The accumulator threshold for this record.']
  accumulator_unit varchar [note: 'The accumulator unit for this record.']
  after_deductible boolean [note: 'The after deductible for this record.']
  applies_to_ancillary boolean [note: 'The applies to ancillary for this record.']
  applies_to_drug boolean [note: 'The applies to drug for this record.']
  applies_to_procedure boolean [note: 'The applies to procedure for this record.']
  applies_to_service_category varchar [note: 'The applies to service category for this record.']
  coinsurance_rate decimal(18,2) [note: 'The numeric coinsurance rate value associated with this cost share rule record.']
  coinsurance_rate_out_of_network decimal(18,2) [note: 'OON coinsurance rate']
  copay_amount decimal(18,2) [note: 'The numeric copay amount value associated with this cost share rule record.']
  copay_amount_out_of_network decimal(18,2) [note: 'OON copay amount']
  cost_share_category decimal(18,2) [note: 'The cost share category for this record.']
  cost_share_rule_status decimal(18,2) [note: 'Rule status']
  created_timestamp timestamp [note: 'The created timestamp attribute capturing relevant data for the cost share rule in the plan domain.']
  deductible_aggregate_flag boolean [note: 'Aggregate deductible flag']
  deductible_amount decimal(18,2) [note: 'The numeric deductible amount value associated with this cost share rule record.']
  deductible_embedded_flag boolean [note: 'Embedded deductible flag']
  description decimal(18,2) [note: 'The cost share rule description for this record.']
  effective_end_date date [note: 'The date value representing effective end date for this cost share rule record.']
  effective_start_date date [note: 'The date value representing effective start date for this cost share rule record.']
  hsa_compatible boolean [note: 'HSA compatible flag']
  is_default_rule boolean [note: 'Default rule flag']
  max_benefit_amount decimal(18,2) [note: 'The numeric max benefit amount value associated with this cost share rule record.']
  max_benefit_units varchar [note: 'The max benefit units attribute capturing relevant data for the cost share rule in the plan domain.']
  member_tier varchar [note: 'The member tier attribute capturing relevant data for the cost share rule in the plan domain.']
  network_type varchar [note: 'The category or classification type of the network.']
  notes varchar [note: 'The notes for this record.']
  out_of_pocket_max decimal(12,2) [note: 'The numeric out of pocket max value associated with this cost share rule record.']
  out_of_pocket_max_family decimal(12,2) [note: 'Family OOP max']
  prior_to_deductible boolean [note: 'The prior to deductible for this record.']
  regulatory_classification varchar [note: 'The regulatory classification for this record.']
  rule_code varchar [note: 'A standardized code representing the rule classification.']
  rule_name varchar [note: 'The descriptive name assigned to the rule for identification purposes.']
  rule_type varchar [note: 'The category or classification type of the rule.']
  rule_version varchar [note: 'The rule version attribute capturing relevant data for the cost share rule in the plan domain.']
  updated_timestamp timestamp [note: 'The updated timestamp attribute capturing relevant data for the cost share rule in the plan domain.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Cost sharing rules for benefits'
}

Table plan.sbc_document {
