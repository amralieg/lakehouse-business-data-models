  actual_extension_date date [note: 'Actual extension date.']
  appeal_category varchar [note: 'Category of the appeal.']
  appeal_filed_timestamp timestamp [note: 'Timestamp when appeal was filed.']
  appeal_origin varchar [note: 'Origin of the appeal.']
  appeal_status varchar [note: 'Current appeal status.']
  breach_flag boolean [note: 'Whether an SLA breach occurred.']
  breach_reason varchar [note: 'Reason for the breach.']
  clock_start_event varchar [note: 'Event that started the compliance clock.']
  clock_type varchar [note: 'Type of compliance clock.']
  compliance_status varchar [note: 'Current compliance status.']
  corrective_action varchar [note: 'Corrective action taken.']
  days_overdue varchar [note: 'Number of days overdue.']
  decision_due_date date [note: 'Due date for decision.']
  expedited_due_date date [note: 'Due date for expedited processing.']
  extension_notification_date date [note: 'Date extension notification was sent.']
  extension_reason varchar [note: 'Reason for the extension.']
  jurisdiction_state varchar [note: 'State jurisdiction.']
  last_action_timestamp timestamp [note: 'Timestamp of last action.']
  notes varchar [note: 'Additional notes.']
  priority varchar [note: 'Priority level.']
  record_audit_created timestamp [note: 'Audit creation timestamp.']
  record_audit_updated timestamp [note: 'Audit update timestamp.']
  record_version varchar [note: 'Version number of the record.']
  regulatory_body varchar [note: 'Regulatory body governing the timeline.']
  root_cause_category varchar [note: 'Root cause category for breaches.']
  self_report_flag boolean [note: 'Whether self-reported.']
  sla_actual_days varchar [note: 'Actual days taken.']
  sla_breach boolean [note: 'Whether SLA was breached.']
  sla_target_days varchar [note: 'Target SLA days.']
  source_system_record_code varchar [note: 'Source system record code.']

  Note: 'Tracks regulatory timelines and SLA compliance for appeal cases including deadlines and breach events.'
}

Table appeal.coverage_dispute {
  coverage_dispute_id varchar [pk, note: 'Primary key for the coverage dispute.']
  adverse_determination_id varchar [note: 'add column adverse_determination_id (BIGINT) with FK to appeal.adverse_determination.adverse_determination_id - coverage disputes follow adverse determinations']
  aptc_subsidy_id varchar [note: 'Foreign key linking to billing.aptc_subsidy. Business justification: APTC coverage disputes: a primary driver of coverage disputes is disagreement over APTC subsidy amounts or eligibility. Linking coverage_dispute to aptc_subsidy supports ACA marketplace regulatory rep']
  benefit_id varchar [note: 'Foreign key linking to plan.benefit. Business justification: coverage_dispute.disputed_benefit_code is a denormalized reference to plan.benefit. Normalizing via FK enables benefit-level dispute analytics, formulary exception tracking, and regulatory reporting o']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Coverage disputes arise from specific benefit package terms (COB rules, network designation, OOP maximums). Direct link to benefit_package supports package-level dispute resolution reporting, regulato']
  case_id varchar [note: 'FK to the appeal case.']
  claim_header_id varchar [note: 'FK to the claim header.']
  cob_id varchar [note: 'Foreign key linking to claim.cob. Business justification: Coverage disputes are directly triggered by COB records — a specific COB determination (primary payer order, MSP indicator) is what members and providers dispute. Linking coverage_dispute to the origi']
  cost_share_rule_id varchar [note: 'Foreign key linking to plan.cost_share_rule. Business justification: Coverage disputes frequently arise from specific cost-sharing rule application (deductible aggregation, coinsurance disputes, OOP max calculations). coverage_dispute.cob_rule_applied is a denormalizat']
  formulary_id varchar [note: 'Foreign key linking to pharmacy.formulary. Business justification: Coverage disputes involving formulary placement, non-formulary drug denials, or tier assignment require direct reference to the applicable formulary. CMS Part D coverage determination regulations and ']
  grace_period_id varchar [note: 'Foreign key linking to billing.grace_period. Business justification: Grace period coverage disputes: members dispute coverage terminations resulting from grace period expiration. Linking coverage_dispute to grace_period enables evaluation of reinstatement eligibility a']
  health_plan_id varchar [note: 'FK to the health plan.']
  invoice_line_id varchar [note: 'Foreign key linking to billing.invoice_line. Business justification: Itemized billing disputes: members dispute specific invoice line items (e.g., a specific coverage tier charge, CSR adjustment, or employer contribution line). Linking to invoice_line enables granular ']
  member_subscriber_id varchar [note: 'FK to the member subscriber.']
  open_enrollment_period_id varchar [note: 'Foreign key linking to enrollment.open_enrollment_period. Business justification: OEP eligibility disputes: members dispute whether they were permitted to enroll or change coverage during a specific open enrollment period. Dispute resolution requires referencing the OEP record to v']
  pa_decision_id varchar [note: 'Foreign key linking to utilization.pa_decision. Business justification: Coverage disputes triggered by PA denials require dispute analysts to access the original pa_decision\'s clinical rationale, authorization details, and denial reason. No existing path from coverage_dis']
  par_agreement_id varchar [note: 'Foreign key linking to network.par_agreement. Business justification: Coverage disputes about in-network billing rates directly reference the PAR agreement governing reimbursement terms. Resolving whether contracted rates apply requires the specific PAR agreement record']
  participation_status_id varchar [note: 'Foreign key linking to provider.participation_status. Business justification: Coverage disputes are fundamentally about provider network participation status. The existing network_status plain-text field is a denormalized representation of provider.participation_status. Normali']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Coverage disputes are fundamentally about specific policy terms (benefits, exclusions, COB rules). \'Coverage dispute resolution\' requires direct policy reference for adjudicators. coverage_dispute has']
  premium_invoice_id varchar [note: 'Foreign key linking to billing.premium_invoice. Business justification: Billing coverage disputes: coverage disputes frequently arise from premium invoice discrepancies (retroactive adjustments, incorrect billing periods). Linking coverage_dispute to the specific invoice ']
  premium_rate_id varchar [note: 'Foreign key linking to billing.premium_rate. Business justification: Rate-based coverage disputes: members dispute coverage decisions tied to incorrect premium rate assignments (wrong tier, age band, or rating area). Linking to premium_rate supports rate dispute resolu']
  prior_authorization_id varchar [note: 'FK to the pharmacy prior authorization.']
  provider_id varchar [note: 'FK to the provider.']
  provider_network_id varchar [note: 'Foreign key linking to network.provider_network. Business justification: Coverage disputes frequently arise from in-network vs. out-of-network billing disagreements. Direct FK to provider_network enables network-based dispute resolution reporting and regulatory compliance ']
  qualifying_life_event_id varchar [note: 'Foreign key linking to enrollment.qualifying_life_event. Business justification: QLE-based coverage disputes: members dispute coverage changes triggered by a QLE (e.g., disputed marriage/divorce event affecting coverage). Dispute resolution requires referencing the specific QLE re']
  transaction_id varchar [note: 'Foreign key linking to enrollment.transaction. Business justification: Coverage dispute resolution: disputes arise from specific enrollment transactions (retroactive terminations, premium adjustments). Operations teams must link the dispute to the originating enrollment ']
  appeal_deadline date [note: 'Deadline for filing an appeal.']
  appeal_filed_date date [note: 'Date appeal was filed.']
  appeal_status varchar [note: 'Current appeal status.']
  cob_order varchar [note: 'Coordination of benefits order.']
  cob_rule_applied varchar [note: 'COB rule applied.']
  coordination_amount decimal(12,2) [note: 'Coordination amount.']
  coverage_dispute_status varchar [note: 'Current status of the coverage dispute.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  currency_code varchar [note: 'Currency code.']
  dispute_description varchar [note: 'Description of the dispute.']
  dispute_number varchar [note: 'Unique dispute number.']
  dispute_type varchar [note: 'Type of dispute.']
  disputing_party_type varchar [note: 'Type of disputing party.']
  effective_from date [note: 'Effective start date.']
  effective_until date [note: 'Effective end date.']
  formulary_exception_flag boolean [note: 'Whether a formulary exception is involved.']
  is_critical boolean [note: 'Whether the dispute is critical.']
  notes varchar [note: 'Additional notes.']
  priority_level varchar [note: 'Priority level.']
  regulatory_reference varchar [note: 'Regulatory reference.']
  resolution_date date [note: 'Date of resolution.']
  resolution_outcome varchar [note: 'Outcome of resolution.']
  subrogation_amount decimal(12,2) [note: 'Subrogation amount.']
  subrogation_flag boolean [note: 'Whether subrogation applies.']
  supporting_document_count varchar [note: 'Number of supporting documents.']
  updated_timestamp timestamp [note: 'Record last updated timestamp.']

  Note: 'Records disputes related to coverage determinations including COB, network status, and benefit eligibility.'
}

