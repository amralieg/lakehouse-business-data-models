  benefit_design_version varchar [note: 'The benefit design version attribute capturing relevant data for the health plan in the plan domain.']
  cms_plan_code varchar [note: 'A standardized code representing the cms plan classification.']
  coinsurance_percentage decimal(18,2) [note: 'The coinsurance percentage attribute capturing relevant data for the health plan in the plan domain.']
