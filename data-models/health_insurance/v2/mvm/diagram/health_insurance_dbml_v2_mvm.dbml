// DBML Schema for Business: Health_Insurance
// Version: 2
// Generated on: 2026-06-23 01:34:35

Project {
  database_type: 'Databricks Unity Catalog'
  Note: 'Lakehouse data model for Health_Insurance - Version 2'
}

Table member.subscriber {
  subscriber_id varchar [pk, note: 'Primary key for subscriber']
  primary_care_coordinator_id varchar [note: 'Foreign key linking to care.care_coordinator. Business justification: Primary Care Coordinator Assignment: case‑management reports need each subscriber linked to their assigned care coordinator.']
  annual_income decimal(18,2) [note: 'Subscriber\'s reported annual income (for subsidy eligibility).']
  chip_number varchar [note: 'Children\'s Health Insurance Program identifier.']
  citizenship_status varchar [note: 'Legal citizenship or residency status.']
  cob_indicator boolean [note: 'Indicates subscriber\'s position in coordination of benefits.']
  consent_to_electronic_communication boolean [note: 'Subscriber\'s consent to receive electronic communications.']
  coverage_type varchar [note: 'Type of health plan coverage.']
  created_timestamp timestamp [note: 'Timestamp when the subscriber record was created.']
  date_of_birth date [note: 'Subscriber\'s birth date.']
  disability_status varchar [note: 'Indicates if subscriber has a disability.']
  effective_date date [note: 'Date when subscriber coverage becomes effective.']
  enrollment_source varchar [note: 'Channel through which subscriber enrolled.']
  fhir_address varchar [note: 'FHIR Patient.address mapping']
  fhir_birth_date date [note: 'FHIR Patient.birthDate mapping']
  fhir_gender varchar [note: 'FHIR Patient.gender mapping']
  fhir_identifier varchar [note: 'FHIR Patient.identifier mapping']
  fhir_name varchar [note: 'FHIR Patient.name mapping']
  fhir_telecom varchar [note: 'FHIR Patient.telecom mapping']
  first_name varchar [note: 'Subscriber\'s given name.']
  gender varchar [note: 'Subscriber\'s gender as reported.']
  hcc_score decimal(5,2) [note: 'Aggregated HCC score for the subscriber.']
  is_deceased boolean [note: 'Flag indicating if subscriber is deceased.']
  language_preference varchar [note: 'Preferred language for communications.']
  last_name varchar [note: 'Subscriber\'s family name.']
  line_of_business varchar [note: 'Business line the subscriber belongs to.']
  marital_status varchar [note: 'Subscriber\'s marital status.']
  medicaid_number varchar [note: 'State Medicaid identifier.']
  medicare_beneficiary_number varchar [note: 'Unique identifier for Medicare beneficiaries.']
  middle_name varchar [note: 'Subscriber\'s middle name (if any).']
  primary_contact_method varchar [note: 'Preferred method for contacting subscriber.']
  race_ethnicity varchar [note: 'Self-reported race/ethnicity for reporting.']
  risk_adjustment_factor decimal(5,4) [note: 'Factor used for risk adjustment calculations.']
  ssn varchar [note: 'Subscriber\'s Social Security Number.']
  subscriber_number varchar [note: 'External contract number assigned to the subscriber.']
  subscriber_status varchar [note: 'Current lifecycle status of the subscriber.']
  termination_date date [note: 'Date when subscriber coverage ends (if applicable).']
  tobacco_use_status varchar [note: 'Subscriber\'s tobacco use status.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the subscriber record.']
  veteran_status boolean [note: 'Indicates if subscriber is a veteran.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Core master entity representing the primary insured individual (subscriber/policyholder) who holds the health insurance contract. Captures full demographic identity including SSN, date of birth, gender, marital status, language preference, race/ethnicity (for HEDIS/CMS reporting), tobacco use status, disability status, and Medicare/Medicaid beneficiary identifiers. Serves as the SSOT for subscriber identity across commercial, Medicare Advantage, Medicaid, and CHIP lines of business. All dependent, eligibility, and benefit records reference this entity. Supports HIPAA PHI/PII obligations, CMS enrollment reporting, and X12 834 subscriber loop requirements. [FHIR-aligned]'
}

Table member.dependent {
  dependent_id varchar [pk, note: 'Primary key for dependent']
  address_id varchar [note: 'Foreign key linking to member.member_address. Business justification: The dependent table currently embeds raw address fields (address_line1, address_line2, city, state, postal_code, country) inline, duplicating the address management capability already provided by the ']
  contact_id varchar [note: 'Foreign key linking to member.member_contact. Business justification: The dependent table embeds contact fields (email_address, phone_number) inline, duplicating the contact management capability provided by the member_contact product. member_contact is the authoritativ']
  identity_id varchar [note: 'Foreign key linking to member.identity. Business justification: The identity table is the authoritative identity resolution record for ALL insured individuals — both subscribers AND dependents. The identity table contains fields like relationship_to_subscriber and']
  subscriber_id varchar [note: 'Identifier of the primary member (subscriber) to whom this dependent is attached.']
  age_out_eligibility_flag boolean [note: 'True if the dependent is eligible for age-out coverage under plan rules.']
  chip_eligibility_flag boolean [note: 'Indicates eligibility for the Children\'s Health Insurance Program.']
  coverage_end_date date [note: 'Date when dependent\'s coverage terminated or is scheduled to end.']
  coverage_start_date date [note: 'Date when dependent\'s coverage became effective.']
  coverage_status varchar [note: 'Current status of the dependent\'s coverage.']
  created_timestamp timestamp [note: 'Timestamp when the dependent record was first created in the system.']
  date_of_birth date [note: 'Birth date of the dependent.']
  disability_status boolean [note: 'Indicates if the dependent has a documented disability.']
  first_name varchar [note: 'Given name of the dependent.']
  gender varchar [note: 'Gender of the dependent as reported.']
  is_primary_contact boolean [note: 'Indicates if this dependent is the primary contact for the subscriber\'s household.']
  language_preference varchar [note: 'Preferred language for communications with the dependent.']
  last_name varchar [note: 'Family name of the dependent.']
  medicaid_eligibility_flag boolean [note: 'Indicates eligibility for Medicaid program.']
  middle_name varchar [note: 'Middle name or initial of the dependent.']
  record_status varchar [note: 'Lifecycle status of the record itself.']
  relationship_end_date date [note: 'Date when the dependent relationship ended, if applicable.']
  relationship_start_date date [note: 'Date when the dependent relationship became effective.']
  relationship_type varchar [note: 'Legal relationship of the dependent to the subscriber.']
  sequence_number varchar [note: 'Ordinal number to differentiate multiple dependents of same relationship type.']
  ssn varchar [note: 'Government-issued identifier for the dependent.']
  student_status boolean [note: 'Indicates if the dependent is currently a student (True) or not (False).']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the dependent record.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Master entity representing individuals covered under a subscriber\'s health plan — spouses, domestic partners, children, and other qualifying dependents. Tracks relationship type to subscriber, dependent sequence number, student status, disability status, age-out eligibility rules, and CHIP/Medicaid eligibility indicators. Maintains its own demographic profile including DOB, gender, SSN, and language preference. Supports dependent verification workflows, age-out processing, and CMS CHIP enrollment reporting. Each dependent record is linked to a subscriber and an enrollment span. [FHIR-aligned]'
}

Table member.identity {
  identity_id varchar [pk, note: 'Primary key for identity']
  account_id varchar [note: 'Foreign key linking to billing.billing_account. Business justification: Business process: Billing Account Management – each member identity must be linked to a billing account for premium collection, payment processing, and regulatory reporting.']
  subscriber_id varchar [note: 'Identifier assigned by the health plan to the member (e.g., commercial member ID, MBI for Medicare).']
  address_line1 varchar [note: 'First line of the member\'s mailing address.']
  address_line2 varchar [note: 'Second line of the member\'s mailing address (if applicable).']
  citizenship_status varchar [note: 'Citizenship or residency status relevant for eligibility and reporting.']
  city varchar [note: 'City component of the member\'s mailing address.']
  country varchar [note: 'Three‑letter ISO country code of the member\'s residence.']
  coverage_end_date date [note: 'Date when the member\'s coverage terminated or is scheduled to end.']
  coverage_start_date date [note: 'Date when the member\'s coverage became effective.']
  created_timestamp timestamp [note: 'Timestamp when the identity record was first created in the system.']
  date_of_birth date [note: 'Member\'s birth date, used for age‑based eligibility and risk calculations.']
  eligibility_status varchar [note: 'Current eligibility determination for benefits coverage.']
  email varchar [note: 'Primary email address used for member communications and portal login.']
  enrollment_effective_date date [note: 'Date the member\'s enrollment into the plan became effective.']
  ethnicity varchar [note: 'Member\'s ethnicity as reported for demographic reporting.']
  external_subscriber_number varchar [note: 'The external subscriber number for this record.']
  first_name varchar [note: 'Member\'s given (first) name.']
  full_name varchar [note: 'Complete legal name of the member as it appears on official documents.']
  gender varchar [note: 'Self‑identified gender of the member.']
  language_preference varchar [note: 'Primary language the member prefers for communications.']
  last_name varchar [note: 'Member\'s family (last) name.']
  lob varchar [note: 'Business line (e.g., commercial, Medicare) to which the member belongs.']
  marital_status varchar [note: 'Member\'s marital status for demographic and eligibility purposes.']
  member_status varchar [note: 'Overall lifecycle status of the member within the health plan.']
  member_type varchar [note: 'Indicates whether the record represents a primary subscriber or a dependent.']
  middle_name varchar [note: 'Member\'s middle name(s), if any.']
  phone_number varchar [note: 'Primary telephone number for member contact.']
  postal_code varchar [note: 'ZIP or postal code of the member\'s mailing address.']
  primary_contact_method varchar [note: 'Preferred channel for member communications.']
  race varchar [note: 'Member\'s race classification for HEDIS and regulatory reporting.']
  relationship_to_subscriber varchar [note: 'Describes the member\'s relationship to the primary subscriber.']
  risk_score decimal(5,2) [note: 'Calculated risk score used for underwriting and care management.']
  source_system_record_code varchar [note: 'Unique identifier of the source record in the originating system.']
  ssn_hash varchar [note: 'Hashed Social Security Number used for identity matching while protecting PII.']
  state varchar [note: 'State or province component of the member\'s mailing address (2‑letter code).']
  termination_date date [note: 'Date the member\'s relationship with the plan was terminated.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the identity record.']
  verification_date date [note: 'Date on which the member\'s identity was successfully verified.']
  verification_status varchar [note: 'Current status of the member\'s identity verification process.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Authoritative identity resolution record for each unique insured individual (subscriber or dependent) assigned a unique member ID by the health plan. Stores the plan-assigned member ID (MBI for Medicare, Medicaid ID, commercial member ID), cross-reference IDs from source systems (Facets member ID, QNXT ID), alternate IDs (SSN hash, external subscriber ID from employer), and identity verification status. Manages member ID history and superseded IDs. This is the enterprise golden record for member identity used by all downstream domains (claims, pharmacy, care management) to resolve member identity. [FHIR-aligned]'
}

Table member.address {
  address_id varchar [pk, note: 'Surrogate primary key for the address record.']
  subscriber_id varchar [note: 'Identifier of the member to whom this address belongs.']
  address_type varchar [note: 'Classification of address purpose.']
  census_tract varchar [note: 'Census tract identifier for demographic analysis.']
  change_reason varchar [note: 'Reason for address change (e.g., member request, system update).']
  city varchar [note: 'City name of the address.']
  country_code varchar [note: 'Three-letter ISO country code.']
  county_fips varchar [note: 'Federal Information Processing Standard code for the county.']
  created_timestamp timestamp [note: 'Timestamp when the address record was first created in the data lake.']
  effective_date date [note: 'Date when the address became effective for the member.']
  external_code varchar [note: 'External identifier for the address from source system.']
  geocode_accuracy_meters varchar [note: 'Accuracy of the geocoding result in meters.']
  is_primary boolean [note: 'Indicates if this address is the primary address for the member.']
  latitude decimal(9,6) [note: 'Geographic latitude in decimal degrees.']
  line1 varchar [note: 'Primary street address line.']
  line2 varchar [note: 'Secondary address line (apartment, suite, etc.).']
  line3 varchar [note: 'Additional address line if needed.']
  line4 varchar [note: 'Additional address line if needed.']
  longitude decimal(9,6) [note: 'Geographic longitude in decimal degrees.']
  member_address_status varchar [note: 'Current lifecycle status of the address.']
  postal_code varchar [note: 'Five-digit ZIP code, optionally with ZIP+4.']
  priority_rank varchar [note: 'Rank indicating priority among multiple concurrent addresses for the member (1 = highest).']
  state_code varchar [note: 'Two-letter US state abbreviation.']
  termination_date date [note: 'Date when the address was terminated or superseded.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the address record.']
  verification_date date [note: 'Date when address verification was performed.']
  verification_status varchar [note: 'USPS CASS certification status of the address.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Manages all physical and mailing addresses associated with a member, including home address, mailing address, temporary address, and employer address. Tracks address type, effective and termination dates, address verification status (USPS CASS-certified), county FIPS code, census tract, and geographic coordinates for network adequacy analysis. Supports multiple concurrent addresses with priority ranking. Used for premium billing, EOB mailing, provider directory access, and CMS geographic reporting. Maintains address history for audit and compliance purposes. [FHIR-aligned]'
}

Table member.contact {
  contact_id varchar [pk, note: 'System-generated unique identifier for each contact record associated with a member.']
  member_subscriber_id varchar [note: 'member contacts must link to the subscriber']
  address_cass_certified boolean [note: 'True if the address has passed USPS CASS certification.']
  address_effective_date date [note: 'Date when the address became effective for the member.']
  address_geocode_accuracy varchar [note: 'Indicates the confidence level of the geocoding result.']
  address_geocode_source varchar [note: 'System used to generate latitude/longitude for the address.']
  address_line1 varchar [note: 'Primary street address line.']
  address_line2 varchar [note: 'Secondary street address line (apartment, suite, etc.).']
  address_priority_rank varchar [note: 'Numeric rank indicating the order of address preference for the member.']
  address_source_system varchar [note: 'Source system that originally supplied the address record.']
  address_termination_date date [note: 'Date when the address was terminated or superseded.']
  address_type varchar [note: 'Purpose of the address (e.g., home, mailing, temporary).']
  address_verification_status varchar [note: 'USPS CASS certification status of the address.']
  census_tract varchar [note: 'Eleven‑digit census tract identifier for geographic analysis.']
  city varchar [note: 'City of the address.']
  contact_type varchar [note: 'Classification of the contact relationship to the member.']
  country_code varchar [note: 'Three‑letter ISO country code of the address.']
  county_fips varchar [note: 'Five‑digit Federal Information Processing Standard code for the county.']
  created_timestamp timestamp [note: 'Date and time when the contact record was first created.']
  email_address varchar [note: 'Primary electronic mail address for the contact.']
  fax_number varchar [note: 'Fax number for the contact.']
  id_type varchar [note: 'Type of identifier used for the contact (e.g., NPI, SSN).']
  id_value decimal(18,2) [note: 'The actual identifier value corresponding to contact_id_type.']
  is_primary_contact boolean [note: 'Indicates whether this record is the member\'s primary contact.']
  language_preference varchar [note: 'Member\'s preferred language for communications.']
  last_verified_timestamp timestamp [note: 'Timestamp of the most recent address verification event.']
  latitude decimal(9,6) [note: 'Geographic latitude of the address in decimal degrees.']
  longitude decimal(9,6) [note: 'Geographic longitude of the address in decimal degrees.']
  member_contact_status varchar [note: 'Current lifecycle status of the contact record.']
  name varchar [note: 'Legal full name of the contact person (member, dependent, or other party).']
  notes varchar [note: 'Free‑form notes related to the contact (e.g., preferred call times).']
  opt_in_email boolean [note: 'Indicates whether the member has consented to receive email communications.']
  opt_in_robocall boolean [note: 'Indicates whether the member permits automated voice calls.']
  opt_in_sms boolean [note: 'Indicates whether the member has consented to receive SMS messages.']
  phone_home varchar [note: 'Primary residential telephone number.']
  phone_mobile varchar [note: 'Cellular telephone number for mobile contact.']
  phone_work varchar [note: 'Telephone number associated with the contact\'s place of work.']
  postal_code varchar [note: 'Postal or ZIP code for the address.']
  preferred_contact_method varchar [note: 'Contact channel the member prefers for communications.']
  relationship varchar [note: 'Relationship of the contact to the member.']
  state_province varchar [note: 'State or province component of the address.']
  tcp_a_consent_flag boolean [note: 'True if the contact has provided consent under the Telephone Consumer Protection Act.']
  updated_timestamp timestamp [note: 'Date and time of the most recent update to the contact record.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Single source of truth for all member contact information and addresses. Manages physical and mailing addresses (home, mailing, temporary, employer), phone numbers (home, mobile, work), email addresses, and fax numbers. Tracks contact type, address type, effective and termination dates, address verification status (USPS CASS-certified), county FIPS code, census tract, geographic coordinates for network adequacy analysis, opt-in/opt-out status per channel (SMS, email, robocall), TCPA consent flags, and preferred contact method and language. Supports multiple concurrent addresses with priority ranking. Used for premium billing, EOB mailing, provider directory access, CMS geographic reporting, member services outreach, care management communications, and CAHPS survey administration. Maintains full address and contact history for audit and compliance purposes. [FHIR-aligned]'
}

Table member.pcp_assignment {
  pcp_assignment_id varchar [pk, note: 'Primary key for pcp_assignment']
  capitation_arrangement_id varchar [note: 'Foreign key linking to contract.capitation_arrangement. Business justification: PCP assignment drives capitation attribution: the assigned PCP\'s practice location operates under a capitation arrangement, and the member\'s assignment determines which arrangement receives the PMPM p']
  member_subscriber_id varchar [note: 'Unique identifier of the member to whom the PCP is assigned.']
  assignment_reason varchar [note: 'Free‑text explanation for why the PCP was assigned (e.g., member request, network requirement).']
  assignment_status varchar [note: 'Current lifecycle status of the PCP assignment.']
  assignment_type varchar [note: 'Method by which the PCP was assigned: member‑selected, auto‑assigned by system, or plan‑assigned.']
  change_reason varchar [note: 'Reason for a change to the PCP assignment (e.g., member relocation, provider departure).']
  change_timestamp timestamp [note: 'Exact time when the most recent change to the assignment was recorded.']
  created_timestamp timestamp [note: 'Timestamp when the PCP assignment record was first created in the system.']
  effective_date date [note: 'Date when the PCP assignment becomes effective for the member.']
  is_current boolean [note: 'True if the assignment is the active PCP for the member at query time.']
  is_primary boolean [note: 'Indicates if this PCP is the member\'s primary provider when multiple assignments exist.']
  network_tier varchar [note: 'Tier classification of the PCP within the plan\'s provider network.']
  notes varchar [note: 'Additional free‑form comments or audit notes about the assignment.']
  panel_status varchar [note: 'Indicates whether the PCP is currently in the member\'s provider panel.']
  termination_date date [note: 'Date when the PCP assignment ends or is scheduled to end; null if still active.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the PCP assignment record.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Tracks Primary Care Provider (PCP) assignments for members enrolled in HMO, POS, and other gatekeeper plan types. Records assigned PCP NPI, PCP effective and termination dates, assignment type (member-selected, auto-assigned, plan-assigned), PCP change reason, PCP panel status at time of assignment, and PCP network tier. Manages PCP change request history and auto-assignment rules for newborns and new enrollees. Used for care coordination, referral authorization, capitation payment calculation, and HEDIS PCP attribution. Integrates with provider and network domains. [FHIR-aligned]'
}

Table member.cob_record {
  cob_record_id varchar [pk, note: 'Primary key for cob_record']
  member_subscriber_id varchar [note: 'Unique identifier of the member to whom this COB record belongs.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Coordination of Benefits (COB) records track a member\'s other insurance coverage to prevent duplicate payment. COB coordination is performed against a specific primary policy — the COB record must kno']
  transaction_id varchar [note: 'Foreign key linking to enrollment.transaction. Business justification: COB records are created or updated when enrollment transactions reflect changes in other coverage (e.g., gaining employer coverage). Linking cob_record to the enrollment transaction that triggered the']
  birthday_rule_applicable boolean [note: 'Indicates whether the birthday rule is used to determine primary payer.']
  cob_order varchar [note: 'Sequencing of the carrier in the coordination of benefits hierarchy.']
  cob_record_number varchar [note: 'Business identifier assigned to the COB record for external reference.']
  cob_status varchar [note: 'Current lifecycle status of the COB record.']
  cob_verification_date date [note: 'Date when the COB information was verified.']
  coordination_of_benefits_rule varchar [note: 'Rule applied to determine payer order (e.g., birthday rule).']
  created_timestamp timestamp [note: 'Timestamp when the COB record was first created in the data lake.']
  effective_date date [note: 'Date the COB coverage becomes effective.']
  is_msp_compliant boolean [note: 'Indicates compliance with Medicare Secondary Payer rules.']
  is_subrogation_flag boolean [note: 'True if the claim may be subject to subrogation based on this COB arrangement.']
  notes varchar [note: 'Free‑form notes or comments about the COB arrangement.']
  policy_type varchar [note: 'Classification of the other carrier policy.']
  termination_date date [note: 'Date the COB coverage ends or is terminated.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the COB record.']
  verification_method varchar [note: 'Method used to verify the COB information.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Coordination of Benefits (COB) record tracking a member\'s other insurance coverage to prevent duplicate payment and ensure correct primary/secondary/tertiary payer sequencing. Captures other carrier name, other carrier member ID, other carrier group number, policy type (commercial, Medicare, Medicaid, auto, workers comp), COB order (primary/secondary/tertiary), effective and termination dates, birthday rule applicability, and COB verification date. Supports COB inquiry workflows, subrogation identification, and Medicare Secondary Payer (MSP) compliance. Used by claims adjudication for COB calculation. [FHIR-aligned]'
}

Table member.id_card {
  id_card_id varchar [pk, note: 'Surrogate primary key for the ID card record.']
  health_plan_id varchar [note: 'Foreign key linking to plan.health_plan. Business justification: ID cards are issued per health plan; linking enables tracking issuance per plan for regulatory reporting.']
  member_identity_id varchar [note: 'Unique identifier of the member to whom the card is issued.']
  pcp_practice_location_id varchar [note: 'Foreign key linking to provider.practice_location. Business justification: ID cards display the PCP\'s office address and phone number. A FK to practice_location enables accurate, normalized retrieval of the PCP\'s specific practice site for card printing, member portal displa']
  pcp_provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: ID card issuance requires printing the member\'s PCP name, sourced from the provider record. The denormalized pcp_name on id_card violates 3NF; a FK to provider.provider normalizes this and supports ac']
  plan_election_id varchar [note: 'Foreign key linking to enrollment.plan_election. Business justification: ID cards are issued or reissued when a plan election is made or changed. Linking id_card to plan_election enables ID card reissuance workflows, election change tracking, and member services operations']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Health insurance ID cards represent coverage under a specific policy — the card displays policy-specific information such as group number, copay amounts, deductible, and coverage type. Currently id_ca']
  barcode varchar [note: 'Machine-readable barcode value encoded on the card.']
  card_format varchar [note: 'Delivery format of the card: physical plastic, digital image, or mobile app representation.']
  card_number varchar [note: 'The alphanumeric identifier printed on the ID card, used for member identification.']
  card_type varchar [note: 'Category of coverage the card provides (e.g., medical, dental).']
  card_version varchar [note: 'Version identifier for the card design/layout.']
  copay_amount decimal(18,2) [note: 'Standard copayment amount shown on the card for office visits.']
  created_timestamp timestamp [note: 'Timestamp when the card record was created in the system.']
  customer_service_phone varchar [note: 'Phone number printed on the card for member support.']
  delivery_confirmation_date date [note: 'Date when delivery of the card was confirmed.']
  delivery_method varchar [note: 'Method used to deliver the card to the member.']
  expiration_date date [note: 'Date after which the card is no longer valid.']
  external_system_code varchar [note: 'Identifier of the card record in the source operational system (e.g., Facets).']
  group_number varchar [note: 'Employer or group identifier shown on the card.']
  id_card_status varchar [note: 'Current lifecycle status of the card.']
  is_primary boolean [note: 'Indicates if this card is the member\'s primary ID card.']
  issue_date date [note: 'Date the card was originally issued to the member.']
  language_preference varchar [note: 'Member\'s preferred language for card language.']
  last_status_change_timestamp timestamp [note: 'Timestamp when the card status last changed.']
  magnetic_stripe_data varchar [note: 'Data encoded on the magnetic stripe of the physical card.']
  pharmacy_bin varchar [note: 'Bank Identification Number for pharmacy benefits.']
  pharmacy_group_number varchar [note: 'Group number used for pharmacy benefit routing.']
  pharmacy_pcn varchar [note: 'Processor Control Number for pharmacy claims.']
  replacement_date date [note: 'Date a replacement card was issued, if applicable.']
  replacement_reason varchar [note: 'Reason why the card was replaced.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the card record.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Manages the issuance and tracking of member health insurance ID cards (physical and digital). Records card issue date, card type (medical, dental, vision, pharmacy, combined), card format (physical, digital/mobile), card status (active, replaced, lost/stolen, expired), plan name on card, group number, member ID displayed, PCP name (for HMO cards), copay amounts displayed, pharmacy BIN/PCN/Group numbers, and customer service phone numbers. Tracks card replacement requests, reason for replacement, and delivery confirmation. Supports member services ID card fulfillment workflows and digital ID card provisioning via member portal. [FHIR-aligned]'
}

Table member.policy {
  policy_id varchar [pk, note: 'Primary key for policy']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: A policy is written against a specific benefit package that defines its deductibles, copays, and OOP maximums. This link is essential for claims adjudication, cost-sharing calculation, renewal process']
  group_party_id varchar [note: 'Foreign key linking to contract.party. Business justification: Group insurance policies are issued under employer group contracts where the employer is a contract.party. Group billing, COBRA administration, and employer reporting all require linking a policy to i']
  identity_id varchar [note: 'Reference to the insured member associated with the policy.']
  parent_policy_id varchar [note: 'Self-referencing FK on policy (parent_policy_id)']
  plan_election_id varchar [note: 'Foreign key linking to enrollment.plan_election. Business justification: A member policy is the direct outcome of a plan election. Linking policy to plan_election supports premium billing reconciliation, COBRA administration, and renewal processing — all of which require k']
  subscriber_id varchar [note: 'Foreign key linking to member.subscriber. Business justification: Policy is a child of subscriber; adding subscriber_id FK establishes the 1:N relationship and removes the silo.']
  vbc_contract_id varchar [note: 'Foreign key linking to contract.vbc_contract. Business justification: VBC/ACO programs attribute members to a vbc_contract based on their active policy. Performance period reporting, shared savings calculations, and CMS reconciliation all require knowing which policies ']
  coverage_end_date date [note: 'Date when coverage under the policy ends.']
  coverage_limit_amount decimal(18,2) [note: 'Maximum monetary limit for covered services under the policy.']
  coverage_limit_currency varchar [note: 'Currency code for the coverage limit amount.']
  coverage_limit_type varchar [note: 'Scope of the coverage limit (e.g., lifetime, annual).']
  coverage_start_date date [note: 'Date when coverage under the policy begins.']
  coverage_status varchar [note: 'Current status of the coverage portion of the policy.']
  coverage_type varchar [note: 'Type of coverage plan (e.g., HMO, PPO).']
  deductible_amount decimal(18,2) [note: 'Amount the insured must pay before coverage applies.']
  deductible_currency decimal(18,2) [note: 'Currency code for the deductible amount.']
  effective_date date [note: 'Date when the policy becomes effective.']
  expiration_date date [note: 'Date when the policy expires if not renewed.']
  out_of_pocket_max_amount decimal(18,2) [note: 'Maximum amount the insured pays in a benefit year.']
  out_of_pocket_max_currency varchar [note: 'Currency code for the out-of-pocket maximum amount.']
  policy_number varchar [note: 'Human-readable policy number assigned by the insurer.']
  policy_status varchar [note: 'Current lifecycle status of the policy.']
  policy_type varchar [note: 'Classification of the policy based on the insured entity type.']
  premium_amount decimal(18,2) [note: 'Amount to be paid for the policy coverage.']
  premium_currency decimal(18,2) [note: 'Currency code for the premium amount.']
  premium_frequency decimal(18,2) [note: 'Frequency at which the premium is billed.']
  renewal_amount decimal(18,2) [note: 'Total amount paid for the policy renewal.']
  renewal_currency varchar [note: 'Currency code for the renewal amount.']
  renewal_date date [note: 'Date when the policy renewal was processed.']
  renewal_deductible_amount decimal(18,2) [note: 'Deductible portion of the renewal payment.']
  renewal_deductible_currency decimal(18,2) [note: 'Currency code for the renewal deductible amount.']
  renewal_out_of_pocket_max_amount decimal(18,2) [note: 'Out-of-pocket maximum for the renewal period.']
  renewal_out_of_pocket_max_currency varchar [note: 'Currency code for the renewal out-of-pocket maximum amount.']
  renewal_premium_amount decimal(18,2) [note: 'Premium portion of the renewal payment.']
  renewal_premium_currency decimal(18,2) [note: 'Currency code for the renewal premium amount.']
  renewal_status varchar [note: 'Current status of the policy renewal process.']
  termination_date date [note: 'Date when the policy was terminated.']
  termination_reason varchar [note: 'Reason for policy termination.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Master reference table for policy. Referenced by policy_id. [FHIR-aligned]'
}

Table member.eligibility_span2 {
  eligibility_span2_id varchar [pk, note: 'System-generated unique identifier for the eligibility span record.']
  benefit_package_id varchar [note: 'Identifier of the specific benefit package within the plan.']
  capitation_arrangement_id varchar [note: 'Foreign key linking to contract.capitation_arrangement. Business justification: Capitation payment runs require counting attributed member-months per arrangement. Each eligibility span represents a covered period generating a PMPM obligation. Finance and actuarial teams link elig']
  enrollment2_id varchar [note: 'Foreign key linking to member.member_enrollment2. Business justification: An enrollment event (member_enrollment2) is the business transaction that initiates or modifies a member\'s coverage, and it results in one or more eligibility spans (member_eligibility_span2) represen']
  formulary_id varchar [note: 'Foreign key linking to pharmacy.formulary. Business justification: Formulary assignment is a core eligibility function — the applicable formulary during a coverage span governs drug coverage, tier placement, and PA requirements. Member portal drug lookup, pharmacy ad']
  member_identity_id varchar [note: 'Unique identifier of the member to whom this eligibility span applies.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Eligibility spans represent continuous periods of health plan eligibility derived from an underlying policy contract. Currently member_eligibility_span2 links to identity and health_plan but has no di']
  cobro_end_date date [note: 'End date of COBRA continuation coverage, if applicable.']
  cobro_start_date date [note: 'Start date of COBRA continuation coverage, if applicable.']
  coverage_type varchar [note: 'Type of coverage provided during the eligibility span.']
  created_timestamp timestamp [note: 'Timestamp when the eligibility span record was created in the system.']
  effective_date date [note: 'Date when the eligibility period becomes effective.']
  eligibility_source varchar [note: 'Origin of the eligibility information (e.g., EDI 834 file, manual entry).']
  eligibility_status varchar [note: 'Current status of the eligibility span.']
  enrollment_type varchar [note: 'Nature of the enrollment event that created this eligibility span.']
  gap_in_coverage_flag boolean [note: 'True if there is a gap in coverage between this span and the previous span.']
  is_primary_coverage boolean [note: 'Indicates whether this span represents the primary coverage for the member (vs. supplemental).']
  line_of_business varchar [note: 'Business line under which the coverage is offered.']
  premium_amount decimal(18,2) [note: 'Monthly premium amount associated with this eligibility span.']
  premium_currency decimal(18,2) [note: 'Three-letter ISO currency code for the premium amount.']
  retroactive_eligibility_flag boolean [note: 'Indicates if the eligibility was applied retroactively.']
  subscriber_relationship_code varchar [note: 'Code indicating the relationship of the member to the primary subscriber.']
  termination_date date [note: 'Date when the eligibility period ends or is scheduled to end.']
  termination_reason_code varchar [note: 'Code describing why the eligibility span terminated.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the eligibility span record.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Core transactional entity representing a continuous period of health plan eligibility for a member. Captures effective date, termination date, termination reason code, plan ID, benefit package, group/employer ID, subscriber relationship code, premium amount, and eligibility source (834 EDI, manual entry, CMS enrollment file). Tracks eligibility status (active, terminated, suspended, COBRA), retroactive eligibility adjustments, and gap-in-coverage periods. The SSOT for answering \'Is this member eligible on date X?\' — used by claims adjudication, pharmacy, and provider eligibility verification (270/271 transactions). [FHIR-aligned]'
}

Table member.enrollment2 {
  enrollment2_id varchar [pk, note: 'Primary key for the enrollment association']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Enrollment events are tied to a specific benefit package selected during open enrollment or SEP. This link supports enrollment administration, cost-sharing determination, and ACA compliance reporting.']
  offering_id varchar [note: 'Foreign key linking to plan.offering. Business justification: In employer-sponsored and exchange plans, enrollment events occur under a specific offering (defining contribution tiers, open enrollment windows, employer contribution amounts). This link supports em']
  plan_election_id varchar [note: 'Foreign key linking to enrollment.plan_election. Business justification: Standard enrollment workflow: a plan election drives creation of the member enrollment record. Linking member_enrollment2 to plan_election enables enrollment audit trails, retroactive adjustment proce']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: The member_enrollment2 product represents the enrollment contract between a subscriber and a care program. Enrollment is always performed under a specific policy — the policy defines the benefit packa']
  qualifying_life_event_id varchar [note: 'Foreign key linking to enrollment.qualifying_life_event. Business justification: Enrollment changes triggered by qualifying life events (birth, marriage, job loss) must be traceable from the member enrollment record to the QLE. SEP compliance reporting and CMS audit requirements m']
  transaction_id varchar [note: 'Foreign key linking to enrollment.transaction. Business justification: Every member enrollment record is created or modified by an enrollment transaction. Linking member_enrollment2 to the enrollment transaction supports EDI reconciliation, financial impact tracking, and']
  effective_end_date date [note: 'Date when the enrollment ends or is terminated']
  effective_start_date date [note: 'Date when the enrollment becomes effective']
  enrollment_number varchar [note: 'Unique identifier for the enrollment record']
  enrollment_status varchar [note: 'Current status of the enrollment (e.g., active, terminated)']
  enrollment_type varchar [note: 'Classification of enrollment (e.g., mandatory, optional)']
  reason varchar [note: 'Reason for enrollment, often derived from eligibility criteria']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'This association product represents the enrollment contract between a subscriber and a care program. It captures enrollment-specific data such as enrollment number, status, effective dates, type, and reason. Each record links one subscriber to one care program.. Existence Justification: Subscribers can enroll in multiple care programs and each care program can have many subscribers. The enrollment is an operational record that is created, updated, and deleted by staff and includes attributes such as enrollment dates, status, type, and reason. The business treats enrollment as a distinct entity (Enrollment) that is queried and reported on. [FHIR-aligned]'
}

Table enrollment.eligibility_span {
  eligibility_span_id varchar [pk, note: 'System-generated unique identifier for the enrollment eligibility span record.']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Needed for eligibility reporting to show which benefit package a member\'s coverage span belongs to, essential for benefit design analysis.']
  plan_election_id varchar [note: 'Foreign key linking to enrollment.plan_election. Business justification: An enrollment eligibility span is the coverage record that results from a subscriber\'s plan election. Linking the span back to the plan_election master record enables direct retrieval of coverage tier']
  program_id varchar [note: 'Foreign key linking to care.care_program. Business justification: Eligibility Span determines member eligibility for specific Care Programs; required for Care Program Eligibility Reporting and program enrollment tracking.']
  qualifying_life_event_id varchar [note: 'Foreign key linking to enrollment.qualifying_life_event. Business justification: An eligibility span initiated by a SEP must reference the qualifying life event that triggered it. The existing qualifying_life_event_code STRING column is a denormalized code that is replaced by this']
  raps_submission_id varchar [note: 'Foreign key linking to risk.raps_submission. Business justification: RAPS reconciliation requires knowing which eligibility spans were included in which CMS submission batch. Plans must confirm that each active MA eligibility span was captured in a RAPS submission for ']
  benefit_designation varchar [note: 'Design of the benefit plan (e.g., HMO, PPO).']
  benefit_period_end date [note: 'End date of the benefit period (often same as termination_date).']
  benefit_period_start date [note: 'Start date of the benefit period (often same as effective_date).']
  benefit_year varchar [note: 'Calendar year for which the benefit amounts apply.']
  coverage_category varchar [note: 'Classification of the covered individual (e.g., employee, spouse).']
  coverage_limit_amount decimal(12,2) [note: 'Maximum allowable amount for a specific benefit within the span.']
  coverage_limit_units varchar [note: 'Unit of measure for the coverage limit (e.g., visits, days).']
  coverage_type varchar [note: 'Type of coverage provided in this span (e.g., medical, dental).']
  created_timestamp timestamp [note: 'Timestamp when the eligibility span record was first created.']
  deductible_amount decimal(12,2) [note: 'Annual deductible amount applicable for this span.']
  deductible_reset_date decimal(18,2) [note: 'Date when the deductible accumulator resets (usually start of benefit year).']
  effective_date date [note: 'Date when the eligibility span becomes active.']
  eligibility_status varchar [note: 'Eligibility determination for the member during this span.']
  enrollment_eligibility_span_status varchar [note: 'Current lifecycle status of the eligibility span.']
  enrollment_event_type varchar [note: 'Category of enrollment event that created or modified this span.']
  enrollment_source varchar [note: 'System or channel through which the enrollment was received.']
  is_primary_coverage boolean [note: 'True if this span represents the member\'s primary coverage.']
  is_waiver_applied boolean [note: 'Indicates if a cost‑sharing waiver (e.g., HSA) is applied to this span.']
  last_status_change_timestamp timestamp [note: 'Timestamp when the status field last changed.']
  line_of_business varchar [note: 'Business line under which the enrollment is processed.']
  moop_reset_date date [note: 'Date when the MOOP threshold resets.']
  moop_threshold decimal(12,2) [note: 'Combined deductible and OOP limit for this span.']
  oop_maximum decimal(12,2) [note: 'Maximum out‑of‑pocket expense the member can incur.']
  oop_reset_date date [note: 'Date when the OOP accumulator resets.']
  plan_code varchar [note: 'External plan identifier used in contracts and communications.']
  prior_coverage_end_date date [note: 'Termination date of the preceding coverage period, if any.']
  prior_coverage_indicator boolean [note: 'True if the member had coverage immediately before this span.']
  retroactive_adjustment_flag boolean [note: 'Indicates whether the span was created or modified retroactively.']
  retroactive_adjustment_reason varchar [note: 'Explanation for a retroactive change to the eligibility span.']
  subscriber_relationship varchar [note: 'Relationship of the covered individual to the subscriber.']
  termination_date date [note: 'Date when the eligibility span ends; null if still active.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the record.']
  utilization_reset_date date [note: 'Date when utilization counters (e.g., visit counts) reset.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']
  waiver_type varchar [note: 'Type of waiver applied, if any.']

  Note: 'Core master record representing a member\'s continuous coverage period under a specific health plan, including benefit year boundaries, deductible/OOP accumulator reset dates, and MOOP thresholds. Captures effective date, termination date, coverage type, line of business (commercial, Medicare, Medicaid), plan code, subscriber relationship, eligibility status, and benefit period attributes. This is the authoritative SSOT for \'is this member covered?\' and \'what benefit period applies?\' at any point in time. One enrollment_transaction may produce one or more eligibility_spans. Sourced from Facets/QNXT enrollment module and CMS EDPS for government programs. [FHIR-aligned]'
}

Table enrollment.transaction {
  transaction_id varchar [pk, note: 'Primary key for transaction']
  capitation_arrangement_id varchar [note: 'Foreign key linking to contract.capitation_arrangement. Business justification: Enrollment transactions (adds, terms, retroactive changes) directly trigger capitation payment adjustments. Linking transactions to the capitation arrangement enables automated enrollment adjustment p']
  eligibility_span_id varchar [note: 'Identifier of the eligibility span generated from this transaction.']
  enrollment_open_enrollment_period_id varchar [note: 'Foreign key linking to enrollment.open_enrollment_period. Business justification: Each enrollment transaction occurs within a defined open enrollment period; linking transaction to period enables period‑based reporting and ensures the period is not a silo.']
  qualifying_life_event_id varchar [note: 'Foreign key linking to enrollment.qualifying_life_event. Business justification: An enrollment transaction triggered by a Special Enrollment Period (SEP) must reference the qualifying life event (QLE) that opened that SEP window. This FK captures the causal link between the QLE an']
  rate_id varchar [note: 'Foreign key linking to plan.plan_rate. Business justification: Required for premium audit reports that must trace each enrollment transaction to the exact rate applied for regulatory compliance.']
  adjustment_amount decimal(12,2) [note: 'Monetary adjustment (e.g., discount, surcharge) applied to the gross premium.']
  adjustment_reason_code varchar [note: 'Standard code describing why a financial or coverage adjustment was made.']
  approving_authority varchar [note: 'Name or role of the individual or system that approved the enrollment change.']
  audit_user_role varchar [note: 'Role of the audit user (e.g., admin, operator, system).']
  claims_reprocess_flag boolean [note: 'True if the enrollment change requires downstream claims to be re‑processed.']
  compliance_status varchar [note: 'Current compliance status of the transaction with applicable regulations.']
  coverage_period_type varchar [note: 'Indicates whether the coverage is continuous, intermittent, or contains a gap.']
  created_timestamp timestamp [note: 'Timestamp when the enrollment transaction record was first created in the lakehouse.']
  currency_code varchar [note: 'Three‑letter ISO currency code for the monetary values in this transaction.']
  effective_date date [note: 'Date on which the member\'s coverage under the new enrollment becomes effective.']
  effective_end_date date [note: 'Scheduled end date of the coverage period associated with this enrollment (may differ from termination_date).']
  enrollment_comment varchar [note: 'Free‑form text field for notes or comments entered by the processor.']
  enrollment_origin varchar [note: 'Channel through which the enrollment was initiated.']
  enrollment_transaction_number varchar [note: 'External business identifier assigned to the enrollment transaction, used for tracking and reference.']
  enrollment_type varchar [note: 'Category of enrollment event: open enrollment, special enrollment period, automatic enrollment, special manual enrollment, or other.']
  event_timestamp timestamp [note: 'Exact date‑time when the enrollment event occurred in the source system.']
  financial_impact_flag boolean [note: 'True when the enrollment change has a direct impact on premium billing or financial reporting.']
  grace_period_end_date date [note: 'Date when the applicable grace period expires.']
  gross_amount decimal(12,2) [note: 'Total premium amount before any adjustments for the enrollment period.']
  health_plan_type varchar [note: 'Classification of the health plan (e.g., HMO, PPO, EPO, POS, HDHP).']
  is_grace_period boolean [note: 'True if the enrollment is being processed within a grace period after termination.']
  net_amount decimal(12,2) [note: 'Final premium amount after adjustments, representing the amount to be billed.']
  original_termination_reference varchar [note: 'Reference to the prior termination transaction that is being reinstated.']
  prior_authorization_required boolean [note: 'Indicates whether the enrollment change triggers a prior authorization requirement.']
  processing_status varchar [note: 'Current processing stage of the transaction within the enrollment workflow.']
  reactivation_date date [note: 'Effective date of coverage reactivation for reinstatement events.']
  regulatory_reporting_flag boolean [note: 'Indicates whether this transaction must be reported to a regulatory body (e.g., CMS, NAIC).']
  retroactive_adjustment_flag boolean [note: 'Flag indicating whether the transaction represents a retroactive adjustment to prior coverage dates.']
  source varchar [note: 'Source of the enrollment transaction record, e.g., EDI 834 feed, web portal, batch load, or API.']
  termination_date date [note: 'Date on which coverage ends for a disenrollment or termination event (nullable if not applicable).']
  termination_reason varchar [note: 'Standardized reason why the enrollment was terminated.']
  transaction_status varchar [note: 'Current lifecycle status of the enrollment transaction.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the enrollment transaction record.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Transactional record capturing every enrollment action for a member — initial enrollment, re-enrollment, plan change, disenrollment (voluntary/involuntary termination), reinstatement, and retroactive adjustment. Tracks enrollment source, enrollment period type (open enrollment, SEP, auto-enrollment), effective date, submitted date, processing status, and transaction-type-specific attributes: termination reason/last day of coverage/grace period status for disenrollments; original termination reference/reinstatement effective date/approving authority for reinstatements; adjusted dates/financial impact flag/claims reprocessing trigger for retro adjustments. One enrollment_transaction may produce one or more eligibility_spans. Sourced from Facets/QNXT and 834 EDI transactions via Availity/Change Healthcare. [FHIR-aligned]'
}

Table enrollment.qualifying_life_event {
  qualifying_life_event_id varchar [pk, note: 'System-generated unique identifier for the qualifying life event record.']
  member_subscriber_id varchar [note: 'Unique identifier of the member who reported the qualifying life event.']
  appeal_reference varchar [note: 'Reference number of any appeal filed against a denial.']
  cms_sep_outcome varchar [note: 'Result of the CMS SEP eligibility determination.']
  created_timestamp timestamp [note: 'Timestamp when the qualifying life event record was first created in the system.']
  denial_reason varchar [note: 'Explanation why the SEP request was denied, if applicable.']
  documentation_type varchar [note: 'Type of supporting document submitted for the event.']
  event_date date [note: 'Calendar date on which the qualifying life event occurred.']
  event_type varchar [note: 'Category of the life event that triggers a special enrollment period.']
  qualifying_life_event_status varchar [note: 'Overall lifecycle status of the qualifying life event record.']
  sep_category_code varchar [note: 'CMS‑defined code that classifies the SEP category for the qualifying life event.']
  sep_window_end date [note: 'Last date the special enrollment period (SEP) is open for this event.']
  sep_window_start date [note: 'First date the special enrollment period (SEP) is open for this event.']
  sep_window_status varchar [note: 'Current state of the SEP window based on dates and actions.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the qualifying life event record.']
  verification_date date [note: 'Date the verification decision was recorded.']
  verification_status varchar [note: 'Current status of the CMS SEP verification process.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Master record of a qualifying life event (QLE) that triggers a special enrollment period (SEP), including the full SEP verification lifecycle. Captures event type (marriage, birth, loss of coverage, relocation, divorce, adoption), event date, SEP window open/close dates, CMS SEP category codes, submitted documentation type and artifacts (birth certificate, marriage license, loss of coverage letter), verification status, verifier ID, verification date, CMS SEP verification outcome, pend/denial reason, and appeal reference. This is the authoritative SSOT for both QLE registration and SEP verification — no separate verification record exists. Required for ACA compliance, CMS SEP eligibility determinations, and SEP integrity program compliance. Sourced from Facets/QNXT pend workflow and member portal document uploads. [FHIR-aligned]'
}

Table enrollment.open_enrollment_period {
  open_enrollment_period_id varchar [pk, note: 'Primary key for open_enrollment_period']
  service_area_id varchar [note: 'Foreign key linking to plan.plan_service_area. Business justification: ACA and CMS regulations require open enrollment periods to be scoped to specific geographic service areas and exchange markets. This FK supports state exchange OEP compliance reporting, enrollment cap']
  compliance_status varchar [note: 'Current compliance verification outcome for the enrollment period.']
  created_timestamp timestamp [note: 'Date‑time when the enrollment period record was first created in the system.']
  eligibility_segment varchar [note: 'Population segment eligible for this enrollment period (e.g., group, individual, Medicare).']
  end_date date [note: 'Last calendar day for submitting enrollment applications; after this date the window closes.']
  enrollment_cutoff_time timestamp [note: 'Daily cut‑off time (in local time) after which submissions on the deadline date are rejected.']
  enrollment_deadline_date date [note: 'Final calendar date by which all enrollment submissions must be received.']
  enrollment_type varchar [note: 'Classification of the enrollment window based on its recurrence and purpose.']
  exchange_type varchar [note: 'Marketplace or exchange through which the enrollment is offered.']
  is_annual boolean [note: 'True if the enrollment period recurs each year on the same schedule.']
  is_retrospective_allowed boolean [note: 'True if members may submit enrollment changes that become effective prior to the submission date.']
  lob varchar [note: 'Business line to which the enrollment period applies.']
  notes varchar [note: 'Free‑form text for additional remarks, exceptions, or operational comments.']
  open_enrollment_period_status varchar [note: 'Current lifecycle status of the enrollment window.']
  period_code varchar [note: 'Short alphanumeric code that uniquely identifies the enrollment window across systems.']
  period_name varchar [note: 'Descriptive name of the enrollment window, e.g., "2025 Individual Marketplace OE".']
  regulatory_filing_required boolean [note: 'Indicates whether this enrollment period triggers mandatory regulatory reporting (e.g., CMS filings).']
  start_date date [note: 'First calendar day on which members may submit enrollment applications.']
  updated_timestamp timestamp [note: 'Date‑time of the most recent modification to the enrollment period record.']
  volume_actual varchar [note: 'Actual count of enrollments captured within the window.']
  volume_target varchar [note: 'Planned number of enrollments the organization aims to achieve during the window.']
  volume_target_met boolean [note: 'Indicates whether the actual enrollment volume met or exceeded the target.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Master record defining each open enrollment window — annual employer group OE, ACA marketplace OE, Medicare Annual Enrollment Period (AEP), and Medicaid continuous enrollment periods. Captures period start/end dates, eligible population segment, LOB, exchange type (SHOP, individual marketplace, off-exchange), and enrollment volume targets. Used to govern when enrollment_records are accepted without a QLE. Sourced from CMS plan year calendars and employer group contracts. [FHIR-aligned]'
}

Table enrollment.edi_transaction {
  edi_transaction_id varchar [pk, note: 'Primary key for edi_transaction']
  party_id varchar [note: 'Foreign key linking to contract.party. Business justification: 834 EDI enrollment files are submitted by contracted trading partners (employers, TPAs, exchanges). Linking edi_transaction to the contract party identifies the submitting entity for file reconciliati']
  transaction_id varchar [note: 'External identifier supplied by the sender to uniquely identify the transaction (e.g., control number from the sender\'s system).']
  average_record_size_bytes decimal(12,2) [note: 'Average size of each member record within the file, calculated as file_size_bytes divided by member_count.']
  effective_date date [note: 'Date on which the enrollment coverage becomes effective for the member(s).']
  enrollment_action_code varchar [note: 'Standard X12 834 code indicating Add (A), Delete (D), Modify (M), or Correct (C) action.']
  error_code varchar [note: 'Standardized error code returned when processing fails (e.g., X12 validation error).']
  error_description varchar [note: 'Human‑readable description of the processing error.']
  file_name varchar [note: 'Original filename of the inbound 834 transaction as received from the EDI gateway.']
  file_received_timestamp timestamp [note: 'Date‑time when the 834 file was first ingested into the lakehouse.']
  file_size_bytes varchar [note: 'Total size of the inbound 834 file in bytes.']
  group_control_number varchar [note: 'Control number identifying the GS functional group for the transaction.']
  interchange_control_number varchar [note: 'Control number identifying the ISA interchange envelope for the transaction.']
  last_attempt_timestamp timestamp [note: 'Timestamp of the most recent processing attempt.']
  lifecycle_status varchar [note: 'Overall lifecycle state of the transaction from ingestion to final disposition.']
  member_count varchar [note: 'Number of individual member enrollment records contained in the 834 file.']
  processing_attempts varchar [note: 'Number of times the transaction has been attempted for processing.']
  processing_status varchar [note: 'Current workflow status of the transaction within the ingestion pipeline.']
  receiver_code varchar [note: 'Identifier of the trading partner that receives the 834 file (typically the health insurer).']
  reconciliation_status varchar [note: 'Result of matching the transaction to internal enrollment records.']
  record_audit_created timestamp [note: 'Timestamp when the transaction record was first created in the lakehouse.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the transaction record.']
  termination_date date [note: 'Date on which the enrollment coverage ends, if applicable.']
  transaction_set_control_number varchar [note: 'Control number that uniquely identifies the 834 transaction set within the interchange.']
  transaction_timestamp timestamp [note: 'Timestamp representing the business event time encoded in the 834 transaction (e.g., effective date of the enrollment action).']
  transaction_type varchar [note: 'Indicates whether the 834 file adds new enrollments, changes existing ones, terminates coverage, or corrects prior data.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Raw and processed 834 EDI transaction records received from employer groups, exchanges, and CMS — the primary electronic mechanism for enrollment adds, changes, and terminations. Captures ISA/GS envelope metadata, transaction set control number, sender/receiver IDs, transaction type (full file vs. change only), processing status, error codes, and reconciliation status. Sourced from Availity/Change Healthcare EDI gateway. Distinct from enrollment_record (the business outcome) — this is the inbound EDI artifact. [FHIR-aligned]'
}

Table enrollment.eligibility_verification {
  eligibility_verification_id varchar [pk, note: 'Primary key for eligibility_verification']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Real-time eligibility verification (270/271 transactions) must return benefit package-specific cost-sharing details (copays, deductibles, OOP limits) to providers. This FK enables direct benefit packa']
  contract_network_participation_id varchar [note: 'Foreign key linking to contract.network_participation. Business justification: 270/271 eligibility verification transactions explicitly return in-network status for a provider. Linking eligibility_verification to network_participation records which participation record was evalu']
  eligibility_span_id varchar [note: 'Foreign key linking to enrollment.enrollment_eligibility_span. Business justification: A 270/271 real-time eligibility verification request is performed against a specific member eligibility span. This direct FK enables immediate span-level eligibility lookup without traversing through ']
  health_plan_id varchar [note: 'Identifier of the health plan under which the member is enrolled.']
  member_identity_id varchar [note: 'Unique member identifier used in the eligibility request (e.g., member number, SSN, MRN).']
  practice_location_id varchar [note: 'Foreign key linking to provider.provider_provider. Business justification: Required for automated provider credential checks during eligibility verification; the process matches providers to member eligibility inquiries.']
  transaction_id varchar [note: 'Identifier assigned by the source system for the eligibility transaction.']
  authorization_number varchar [note: 'Authorization number returned when prior authorization is required.']
  authorization_required boolean [note: 'Indicates whether prior authorization is required for the service.']
  benefit_category varchar [note: 'High‑level category of benefits being queried (e.g., medical, dental).']
  benefit_limit decimal(10,2) [note: 'Maximum dollar amount allowed for the queried benefit.']
  benefit_remaining decimal(10,2) [note: 'Remaining dollar amount of the benefit available.']
  benefit_used decimal(10,2) [note: 'Dollar amount of the benefit already utilized in the current period.']
  coverage_type varchar [note: 'Level of coverage returned (full, partial, or none).']
  created_timestamp timestamp [note: 'Timestamp when the eligibility record was first persisted in the data lake.']
  deductible_remaining decimal(10,2) [note: 'Member\'s remaining deductible balance for the benefit period.']
  diagnosis_code varchar [note: 'ICD diagnosis code associated with the request, if applicable.']
  eligibility_status varchar [note: 'Overall result of the eligibility check (eligible, ineligible, error, or pending).']
  error_code varchar [note: 'Technical or business error code returned in a failed eligibility response.']
  error_description varchar [note: 'Human‑readable description of the error condition.']
  inquiry_reference_number varchar [note: 'External reference number assigned by the source system (e.g., Availity) for the eligibility request.']
  inquiry_timestamp timestamp [note: 'Date‑time when the eligibility request was sent to the payer.']
  member_identifier_type varchar [note: 'Type of identifier supplied for the member (SSN, MRN, or internal member ID).']
  oop_remaining decimal(10,2) [note: 'Remaining out‑of‑pocket amount before maximum OOP is reached.']
  response_message varchar [note: 'Free‑form message returned by the payer providing additional context.']
  response_time_seconds decimal(10,2) [note: 'Elapsed time between request and response, measured in seconds.']
  response_timestamp timestamp [note: 'Date‑time when the eligibility response was received.']
  service_code varchar [note: 'CPT code of the service/procedure for which eligibility is being checked.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the eligibility record.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Transactional record of real-time 270/271 eligibility verification requests and responses. Captures requesting provider NPI, member identifier used, inquiry date/time, response status, coverage details returned, deductible/OOP balances returned, and response time SLA. Supports provider-facing eligibility verification at point of care. Sourced from Availity/Change Healthcare 270/271 gateway and Facets real-time eligibility API. [FHIR-aligned]'
}

Table enrollment.plan_election {
  plan_election_id varchar [pk, note: 'Unique surrogate identifier for the plan election record.']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: When a member elects a plan, they select a specific benefit package (e.g., HMO Gold, PPO Silver). This FK supports premium billing, benefit adjudication, and ACA metal-tier reporting. A health insuran']
  offering_id varchar [note: 'Foreign key linking to plan.offering. Business justification: Employer group plan elections are made against a specific offering that defines contribution tiers and eligible plans. This FK supports employer contribution reconciliation, benefits administration re']
  open_enrollment_period_id varchar [note: 'Foreign key linking to enrollment.open_enrollment_period. Business justification: A plan election made during an open enrollment window must reference the open_enrollment_period that governed it. This FK enables OEP-level analytics (volume_actual vs volume_target tracking, complian']
  prior_plan_election_id varchar [note: 'Reference to the previous election record when this election is a change or reinstatement.']
  qualifying_life_event_id varchar [note: 'Foreign key linking to enrollment.qualifying_life_event. Business justification: A plan election made outside of open enrollment (SEP election) must reference the qualifying life event that opened the special enrollment window. This FK captures the regulatory basis for the off-cyc']
  cobra_eligibility_end_date date [note: 'Date when COBRA eligibility expires.']
  coverage_tier varchar [note: 'Level of coverage elected (e.g., employee only, employee + spouse, employee + children, family).']
  dental_rider_flag boolean [note: 'Indicates if a dental coverage rider was elected.']
  effective_date date [note: 'Date the elected coverage becomes effective.']
  election_number varchar [note: 'External reference number assigned to the election by the enrollment system.']
  election_type varchar [note: 'Nature of the election event (new enrollment, change, termination, reinstatement).']
  enrollment_event_type varchar [note: 'Type of enrollment event that triggered the election.']
  enrollment_source varchar [note: 'Channel through which the election was submitted.']
  fsa_election_flag boolean [note: 'Indicates if a Flexible Spending Account was elected.']
  hra_election_flag boolean [note: 'Indicates if a Health Reimbursement Arrangement was elected.']
  hsa_election_flag boolean [note: 'Indicates if a Health Savings Account was elected.']
  is_cobra_eligible boolean [note: 'Indicates if the election is eligible for COBRA continuation coverage.']
  notes varchar [note: 'Free‑text field for additional comments or special instructions related to the election.']
  plan_election_status varchar [note: 'Current processing status of the election record.']
  premium_frequency decimal(18,2) [note: 'Billing frequency for the premium (e.g., monthly).']
  record_audit_created timestamp [note: 'Timestamp when the election record was first created in the system.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the election record.']
  termination_date date [note: 'Date the elected coverage ends, if applicable.']
  vision_rider_flag boolean [note: 'Indicates if a vision coverage rider was elected.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Master record of a subscriber\'s specific plan selection, coverage tier, and covered member roster during an enrollment or plan change event. Captures elected plan ID, coverage tier (employee-only, employee+spouse, employee+children, family), effective date, prior plan reference, premium contribution split (employer vs. employee), HSA/HRA/FSA election flag, dental/vision rider elections, and the roster of covered individuals with their relationship codes, age-out dates, and COBRA continuation eligibility. References member domain for person identity — this product owns the enrollment-specific election and roster, not the person demographics. Represents the member\'s choice artifact — distinct from eligibility_span (the resulting coverage). Sourced from Facets/QNXT benefits election module. [FHIR-aligned]'
}

Table enrollment.medicaid_eligibility {
  medicaid_eligibility_id varchar [pk, note: 'System-generated unique identifier for the Medicaid eligibility record.']
  eligibility_span_id varchar [note: 'Foreign key linking to enrollment.enrollment_eligibility_span. Business justification: A Medicaid eligibility determination results in an enrollment eligibility span for the managed care member. Linking medicaid_eligibility to the corresponding enrollment_eligibility_span enables direct']
  medicaid_care_program_id varchar [note: 'Foreign key linking to care.program. Business justification: Medicaid eligibility category (LTSS, HCBS waiver, managed long-term care) directly drives assignment to a specific care management program per state Medicaid contract requirements. This is a regulator']
  prior_eligibility_medicaid_eligibility_id varchar [note: 'Reference to the previous eligibility record for continuity tracking.']
  assets_amount decimal(12,2) [note: 'Total countable assets reported for eligibility assessment.']
  coverage_end_date date [note: 'Date when Medicaid coverage under this eligibility ends, if known.']
  coverage_start_date date [note: 'Date when Medicaid coverage under this eligibility begins.']
  created_timestamp timestamp [note: 'Timestamp when the eligibility record was first created in the system.']
  dual_eligible_flag boolean [note: 'Indicates whether the member is also eligible for Medicare.']
  effective_date date [note: 'Date on which the Medicaid coverage becomes effective.']
  eligibility_category varchar [note: 'Classification of Medicaid eligibility based on income and other criteria.']
  eligibility_determination_timestamp timestamp [note: 'Exact date and time when the eligibility determination was made.']
  eligibility_notes varchar [note: 'Free-text notes captured by eligibility staff during determination.']
  eligibility_number varchar [note: 'Business reference number for the eligibility determination, used in reporting and external communications.']
  eligibility_reason_code varchar [note: 'Standard code indicating the reason for eligibility determination (e.g., income, disability).']
  eligibility_status varchar [note: 'Current lifecycle status of the eligibility record.']
  eligibility_verification_date date [note: 'Date on which eligibility information was verified.']
  eligibility_verification_method varchar [note: 'Method used to verify eligibility information.']
  enrollment_source varchar [note: 'Origin of the eligibility record (e.g., EDI 834 file, Facets system, manual entry).']
  federal_program_indicator boolean [note: 'True if the eligibility is linked to a federal program such as Medicare.']
  fpl_percentage decimal(5,2) [note: 'Member\'s income expressed as a percentage of the Federal Poverty Level.']
  household_size varchar [note: 'Number of individuals in the member\'s household used for eligibility calculations.']
  income_amount decimal(12,2) [note: 'Reported annual income used for eligibility calculation.']
  income_verification_status decimal(18,2) [note: 'Result of the income verification process for eligibility.']
  last_update_timestamp timestamp [note: 'Timestamp of the most recent modification to the eligibility record.']
  medicaid_program_type varchar [note: 'Type of Medicaid program the member is enrolled in.']
  medical_need_flag boolean [note: 'Indicates whether the member qualifies based on medical need criteria.']
  redetermination_due_date date [note: 'Date by which the member must be re-evaluated for continued eligibility.']
  special_program_indicator varchar [note: 'Identifies enrollment in special Medicaid programs (e.g., pregnant, disability).']
  state_agency varchar [note: 'Two-letter code of the state Medicaid agency governing the eligibility.']
  state_medicaid_number varchar [note: 'State-assigned Medicaid identification number for the member.']
  termination_date date [note: 'Date on which the Medicaid coverage ends or is scheduled to end.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Master record tracking Medicaid and CHIP eligibility determinations for members enrolled in managed Medicaid plans. Captures Medicaid eligibility category (MAGI, SSI, CHIP, dual-eligible), state Medicaid ID, eligibility determination date, redetermination due date, income verification status, household size, FPL percentage, and dual-eligible Medicare coordination flag. Interfaces with state Medicaid agency eligibility systems and CMS EDPS. Sourced from state 834 files and Facets Medicaid module. [FHIR-aligned]'
}

Table enrollment.medicare_entitlement {
  medicare_entitlement_id varchar [pk, note: 'Unique surrogate key for the Medicare entitlement record.']
  capitation_arrangement_id varchar [note: 'Foreign key linking to contract.capitation_arrangement. Business justification: Medicare Advantage capitation (PMPM) applies RAF risk scores from member entitlement records. Linking medicare_entitlement to capitation_arrangement enables RAF-adjusted PMPM calculation, Part D premi']
  eligibility_span_id varchar [note: 'Foreign key linking to enrollment.enrollment_eligibility_span. Business justification: A Medicare entitlement record for a Medicare Advantage member corresponds to an enrollment eligibility span representing their MA coverage period. This FK links the CMS entitlement data (Part A/B date']
  medicare_care_program_id varchar [note: 'Foreign key linking to care.program. Business justification: CMS requires Medicare Advantage SNP members (identified by entitlement type: ESRD, chronic condition, dual eligible) to be enrolled in specific care management programs per contract. The entitlement t']
  transaction_id varchar [note: 'Foreign key linking to enrollment.transaction. Business justification: A Medicare entitlement record is created or updated as a result of an enrollment transaction (e.g., MA enrollment, Part D enrollment, CMS EDPS/RAPS submission). Linking medicare_entitlement to the ori']
  created_timestamp timestamp [note: 'Date‑time when the entitlement record was first created in the lakehouse.']
  eligibility_span_end date [note: 'End date of the member\'s overall Medicare eligibility period (null if ongoing).']
  eligibility_span_start date [note: 'Start date of the member\'s overall Medicare eligibility period.']
  entitlement_number varchar [note: 'External reference number used by business partners to identify this entitlement.']
  entitlement_status varchar [note: 'Overall lifecycle status of the Medicare entitlement record.']
  entitlement_type varchar [note: 'Category of Medicare coverage (e.g., Medicare Advantage, Part D, Dual Eligible).']
  extra_help_effective_date date [note: 'Date the Extra Help status became effective.']
  extra_help_status varchar [note: 'Eligibility status for the Extra Help program (assists with Part D costs).']
  irmaa_effective_date date [note: 'Date the IRMAA status became effective.']
  irmaa_income_bracket decimal(18,2) [note: 'Income bracket used to calculate the member\'s IRMAA surcharge.']
  irmaa_status varchar [note: 'Current IRMAA status indicating whether the member pays an income‑based surcharge.']
  is_dual_eligible boolean [note: 'Indicates whether the member is eligible for both Medicare and Medicaid.']
  is_retired boolean [note: 'True if the entitlement has been retired (e.g., member deceased or moved to non‑Medicare coverage).']
  last_verified_timestamp timestamp [note: 'Date‑time when the entitlement information was last verified against CMS.']
  lis_effective_date date [note: 'Date on which the LIS status became effective.']
  lis_status varchar [note: 'Current status of the member\'s Low Income Subsidy eligibility.']
  ma_enrollment_effective_date date [note: 'Date the member\'s Medicare Advantage (MA) plan enrollment became effective.']
  mbi varchar [note: 'Unique 11‑character identifier assigned to each Medicare beneficiary.']
  notes varchar [note: 'Free‑form text for any additional remarks or audit comments.']
  part_a_entitlement_date date [note: 'Effective date on which the member became entitled to Medicare Part A benefits.']
  part_a_termination_date date [note: 'Date on which Part A entitlement ended, if applicable.']
  part_b_entitlement_date date [note: 'Effective date on which the member became entitled to Medicare Part B benefits.']
  part_b_termination_date date [note: 'Date on which Part B entitlement ended, if applicable.']
  part_d_enrollment_effective_date date [note: 'Date the member\'s Medicare Part D prescription drug coverage became effective.']
  pbp_assignment varchar [note: 'Code representing the primary business partner (e.g., health plan) assigned to the member.']
  source_record_reference varchar [note: 'Unique identifier of the source record in the originating system.']
  updated_timestamp timestamp [note: 'Date‑time of the most recent update to the entitlement record.']
  verification_status varchar [note: 'Current verification state of the entitlement data.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Master record capturing Medicare entitlement and enrollment details for members in Medicare Advantage (MA) and Part D plans. Captures Medicare Beneficiary Identifier (MBI), Part A/B entitlement dates, MA enrollment effective date, Part D enrollment effective date, Low Income Subsidy (LIS) status, Extra Help level, IRMAA status, and CMS contract/PBP assignment. Sourced from CMS MARx system data and EDPS enrollment confirmations. [FHIR-aligned]'
}

Table plan.health_plan {
  health_plan_id varchar [pk, note: 'Primary key']
