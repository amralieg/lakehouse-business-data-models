  copay_specialist decimal(18,2) [note: 'Specialist copay']
  created_timestamp timestamp [note: 'The created timestamp attribute capturing relevant data for the health plan in the plan domain.']
  deductible_family decimal(18,2) [note: 'Family deductible amount']
  deductible_individual decimal(18,2) [note: 'Individual deductible amount']
  effective_date date [note: 'The date value representing effective date for this health plan record.']
  enrollment_end_date date [note: 'The date value representing enrollment end date for this health plan record.']
  enrollment_start_date date [note: 'The date value representing enrollment start date for this health plan record.']
  hcc_score decimal(5,2) [note: 'HCC risk score']
