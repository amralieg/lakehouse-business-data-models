  name varchar [note: 'The descriptive name assigned to the service area for identification purposes.']
  network_type varchar [note: 'The category or classification type of the network.']
  notes varchar [note: 'The notes for this record.']
  plan_category varchar [note: 'The plan category attribute capturing relevant data for the plan service area in the plan domain.']
  plan_year varchar [note: 'The calendar or fiscal year associated with the plan.']
  regulatory_approval_status varchar [note: 'The current status indicator for the regulatory approval within the workflow.']
  regulatory_filing_number varchar [note: 'The regulatory filing number attribute capturing relevant data for the plan service area in the plan domain.']
  service_area_type varchar [note: 'The category or classification type of the service area.']
  state varchar [note: 'The state attribute capturing relevant data for the plan service area in the plan domain.']
  updated_timestamp timestamp [note: 'The updated timestamp attribute capturing relevant data for the plan service area in the plan domain.']
  version_number varchar [note: 'The version number attribute capturing relevant data for the plan service area in the plan domain.']
  vreq_validated boolean [note: 'VREQ validation marker']
  zip_codes_excluded varchar [note: 'Excluded ZIP codes']
  zip_codes_included varchar [note: 'Included ZIP codes']

  Note: 'Geographic service area for a plan'
}

Table plan.rx_benefit_config {
  rx_benefit_config_id varchar [pk, note: 'Primary key']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Pharmacy benefit configurations are scoped to specific benefit packages — different benefit packages within a health plan can have different formulary tiers, copay structures, and pharmacy network typ']
  fee_schedule_id decimal(18,2) [note: 'Foreign key linking to contract.fee_schedule. Business justification: Pharmacy benefit configurations govern drug coverage; pharmacy fee schedules (AWP-based, MAC pricing) define allowed amounts for drug claims. Pharmacy claims adjudication requires linking rx_benefit_c']
  formulary_id varchar [note: 'FK to formulary']
  health_plan_id varchar [note: 'FK to health plan']
  pbm_contract_id varchar [note: 'Foreign key linking to pharmacy.pbm_contract. Business justification: rx_benefit_config defines pharmacy benefit parameters administered under a PBM contract. pbm_vendor is a denormalized text field violating 3NF. Replacing it with pbm_contract_id enables contract-level']
  coinsurance_rate decimal(18,2) [note: 'The numeric coinsurance rate value associated with this rx benefit config record.']
  cost_sharing_method decimal(18,2) [note: 'The cost sharing method for this record.']
  coverage_limit_per_prescription decimal(10,2) [note: 'Per prescription limit']
  coverage_limit_per_year decimal(10,2) [note: 'Per year limit']
  created_timestamp timestamp [note: 'The created timestamp attribute capturing relevant data for the rx benefit config in the plan domain.']
  deductible_amount decimal(18,2) [note: 'The numeric deductible amount value associated with this rx benefit config record.']
  deductible_applicable boolean [note: 'Deductible applicable flag']
  drug_category_exclusions varchar [note: 'The drug category exclusions attribute capturing relevant data for the rx benefit config in the plan domain.']
  effective_end_date date [note: 'The date value representing effective end date for this rx benefit config record.']
  effective_start_date date [note: 'The date value representing effective start date for this rx benefit config record.']
  formulary_version varchar [note: 'The formulary version attribute capturing relevant data for the rx benefit config in the plan domain.']
  is_biologic_preferred boolean [note: 'Biologic preferred']
  is_biosimilar_preferred boolean [note: 'Biosimilar preferred']
  is_exempt_from_mlr boolean [note: 'MLR exempt flag']
  is_specialty_drug_excluded boolean [note: 'Specialty drug excluded']
  last_review_date date [note: 'The date value representing last review date for this rx benefit config record.']
  mail_order_network_type varchar [note: 'The category or classification type of the mail order network.']
  max_coverage_amount decimal(18,2) [note: 'The numeric max coverage amount value associated with this rx benefit config record.']
  ninety_day_supply_allowed boolean [note: '90-day supply allowed']
  notes varchar [note: 'The notes for this record.']
  out_of_pocket_max decimal(10,2) [note: 'The numeric out of pocket max value associated with this rx benefit config record.']
  prior_auth_exemption_drugs varchar [note: 'The prior auth exemption drugs attribute capturing relevant data for the rx benefit config in the plan domain.']
  regulatory_classification varchar [note: 'The regulatory classification attribute capturing relevant data for the rx benefit config in the plan domain.']
  retail_network_type varchar [note: 'The category or classification type of the retail network.']
  rx_benefit_config_status varchar [note: 'Config status']
  specialty_pharmacy_network varchar [note: 'The specialty pharmacy network attribute capturing relevant data for the rx benefit config in the plan domain.']
  step_therapy_required boolean [note: 'The step therapy required attribute capturing relevant data for the rx benefit config in the plan domain.']
  therapeutic_class_limit varchar [note: 'The therapeutic class limit attribute capturing relevant data for the rx benefit config in the plan domain.']
  updated_timestamp timestamp [note: 'The updated timestamp attribute capturing relevant data for the rx benefit config in the plan domain.']
  version_number varchar [note: 'The version number attribute capturing relevant data for the rx benefit config in the plan domain.']
  vreq_validated boolean [note: 'VREQ validation marker']

  Note: 'Pharmacy benefit configuration'
}

Table plan.network_config {
  network_config_id varchar [pk, note: 'Primary key']
  health_plan_id varchar [note: 'FK to health plan']
  service_area_id varchar [note: 'Foreign key linking to plan.plan_service_area. Business justification: Network configurations are geographically scoped — a network configuration applies within a specific service area (e.g., a county-level HMO network, a state-level PPO network). network_config currentl']
  access_type varchar [note: 'The category or classification type of the access.']
  created_timestamp timestamp [note: 'The created timestamp attribute capturing relevant data for the network config in the plan domain.']
  effective_end_date date [note: 'The date value representing effective end date for this network config record.']
  effective_start_date date [note: 'The date value representing effective start date for this network config record.']
  network_adequacy_measure varchar [note: 'Adequacy measure']
  network_adequacy_standard_code varchar [note: 'Adequacy standard code']
  network_config_status varchar [note: 'Config status']
  network_contract_number varchar [note: 'Contract number']
  network_coverage_type varchar [note: 'Coverage type']
  network_designation varchar [note: 'The network designation attribute capturing relevant data for the network config in the plan domain.']
  network_exclusion_description varchar [note: 'The network exclusion description for this record.']
  network_exclusion_flag boolean [note: 'Boolean indicator for the network exclusion condition or state.']
  network_provider_count varchar [note: 'Provider count']
  network_tier varchar [note: 'The network tier attribute capturing relevant data for the network config in the plan domain.']
  out_of_network_benefit_type varchar [note: 'OON benefit type']
  out_of_network_coinsurance_pct decimal(18,2) [note: 'OON coinsurance percentage']
  out_of_network_copay_amount decimal(18,2) [note: 'OON copay amount']
  out_of_network_coverage_flag boolean [note: 'OON coverage flag']
  tier_priority varchar [note: 'The tier priority attribute capturing relevant data for the network config in the plan domain.']
  updated_timestamp timestamp [note: 'The updated timestamp attribute capturing relevant data for the network config in the plan domain.']
  vreq_validated boolean [note: 'VREQ validation marker']

  Note: 'Network configuration for a plan'
}

Table plan.offering {
  offering_id varchar [pk, note: 'Primary key']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: An offering presents a specific health plan product to employer groups. In practice, an offering is tied to a specific benefit package within a plan — the employer group is offered a particular benefi']
  health_plan_id varchar [note: 'FK to health plan']
  code varchar [note: 'A standardized code representing the offering classification.']
  contribution_amount decimal(18,2) [note: 'The numeric contribution amount value associated with this offering record.']
  contribution_percent decimal(5,4) [note: 'Contribution percentage']
  contribution_tier varchar [note: 'The contribution tier attribute capturing relevant data for the offering in the plan domain.']
  contribution_type varchar [note: 'The category or classification type of the contribution.']
  effective_from date [note: 'Effective from date']
  effective_until date [note: 'Effective until date']
  employee_contribution_amount decimal(18,2) [note: 'The numeric employee contribution amount value associated with this offering record.']
  family_contribution_amount decimal(18,2) [note: 'The numeric family contribution amount value associated with this offering record.']
  name varchar [note: 'The descriptive name assigned to the offering for identification purposes.']
  offering_status varchar [note: 'The current status indicator for the offering within the workflow.']
  offering_type varchar [note: 'The category or classification type of the offering.']
  open_enrollment_end_date date [note: 'OE end date']
  open_enrollment_start_date date [note: 'OE start date']
  vreq_validated boolean [note: 'VREQ validation marker']

  Note: 'Plan offering to employer groups'
}

Table plan.provider_contract {
  provider_contract_id varchar [pk, note: 'Primary key']
  health_plan_id varchar [note: 'FK to health plan']
  network_config_id varchar [note: 'Foreign key linking to plan.network_config. Business justification: A provider contract linkage to a health plan is associated with a specific network configuration — the contract defines the provider\'s participation in a particular network tier (e.g., Tier 1 preferre']
  party_id varchar [note: 'Foreign key linking to contract.party. Business justification: A plan-provider contract is executed with a legal entity (party). Provider contracting and credentialing operations require knowing which contracting party (provider organization, NPI, TIN) is party t']
  contract_reference varchar [note: 'Contract reference number']
  contract_status varchar [note: 'The current status indicator for the contract within the workflow.']
  created_timestamp timestamp [note: 'Record creation timestamp']
  effective_date date [note: 'Contract effective date']
  is_in_network boolean [note: 'Whether provider is in network']
  reimbursement_method varchar [note: 'The reimbursement method attribute capturing relevant data for the plan provider contract in the plan domain.']
  reimbursement_terms varchar [note: 'The reimbursement terms attribute capturing relevant data for the plan provider contract in the plan domain.']
  relationship_type varchar [note: 'Type of relationship']
  termination_date date [note: 'Contract termination date']
  updated_timestamp timestamp [note: 'Record update timestamp']

  Note: 'Provider contract linkage to health plans'
}

Table provider.specialty {
  specialty_id varchar [pk, note: 'Primary key for specialty']
  practice_location_id varchar [note: 'Reference to the healthcare provider who holds this specialty designation. Links to the provider master entity.']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: A specialty record belongs to a specific provider (physician, nurse, etc.). This is the fundamental parent-child relationship — specialty cannot exist without a provider. Currently specialty only link']
  accepting_new_patients_flag boolean [note: 'Indicates whether the provider is currently accepting new patients for this specialty. True if accepting; False if panel is closed. Used for provider directory accuracy.']
  board_certified_flag boolean [note: 'Indicates whether the provider is board certified in this specialty. True if certified by a recognized medical board; False otherwise.']
  category varchar [note: 'High-level grouping of the specialty into major healthcare service categories for network adequacy and reporting purposes. [ENUM-REF-CANDIDATE: allopathic_osteopathic|dental|behavioral_health|chiropractic|podiatric|nursing|pharmacy|ancillary — 8 candidates stripped; promote to reference product]']
  certification_date date [note: 'The date on which the provider was initially certified by the board in this specialty. Format: yyyy-MM-dd.']
  certification_expiration_date date [note: 'The date on which the board certification expires and requires renewal. Null if certification does not expire or is lifetime. Format: yyyy-MM-dd.']
  certification_number varchar [note: 'The unique certification number or identifier issued by the certifying board for this specialty. Used for verification purposes.']
  certifying_board_name varchar [note: 'The name of the medical board or certifying organization that granted board certification for this specialty (e.g., American Board of Internal Medicine, American Board of Surgery). Null if not board certified.']
  code varchar [note: 'The National Uniform Claim Committee (NUCC) Health Care Provider Taxonomy Code representing the provider\'s specialty classification. Ten-digit alphanumeric code with an X in the 11th position.']
  credentialing_effective_date date [note: 'The date on which the provider\'s credentialing for this specialty became effective within the health plan\'s network. Format: yyyy-MM-dd.']
  credentialing_end_date date [note: 'The date on which the provider\'s credentialing for this specialty ended or will end. Null if currently active with no planned end date. Format: yyyy-MM-dd.']
  credentialing_review_date date [note: 'The date of the most recent credentialing review or recredentialing for this specialty. NCQA requires recredentialing at least every three years. Format: yyyy-MM-dd.']
  credentialing_status varchar [note: 'The current credentialing status of the provider for this specific specialty within the health plan\'s network. Active indicates the provider is credentialed and authorized to provide services in this specialty.']
  current_record_flag boolean [note: 'Indicates whether this is the current active version of the specialty record. True for the current record; False for historical versions. Supports slowly changing dimension (SCD) Type 2 historization.']
  end_date date [note: 'The date on which the provider stopped practicing in this specialty, if applicable. Null if the provider is still actively practicing in this specialty. Format: yyyy-MM-dd.']
  fellowship_completed_flag boolean [note: 'Indicates whether the provider completed a fellowship program in this specialty or subspecialty. True if fellowship training was completed; False otherwise.']
  fellowship_completion_date date [note: 'The date on which the provider completed the fellowship program. Format: yyyy-MM-dd. Null if no fellowship was completed.']
  fellowship_program_name varchar [note: 'The name of the fellowship program and institution where the provider completed subspecialty training. Null if no fellowship was completed.']
  hedis_specialty_flag boolean [note: 'Indicates whether this specialty is relevant for HEDIS measure attribution and quality reporting. True if the specialty is used in HEDIS measure calculations; False otherwise.']
  name varchar [note: 'The human-readable name of the specialty (e.g., Cardiology, Orthopedic Surgery, Family Medicine). Corresponds to the specialty taxonomy code.']
  network_adequacy_category varchar [note: 'The network adequacy category or specialty grouping used for regulatory reporting and network adequacy analysis. Maps specialty to state-specific or CMS network adequacy standards.']
  next_credentialing_review_date date [note: 'The scheduled date for the next credentialing review or recredentialing for this specialty. Used for compliance tracking and proactive credentialing management. Format: yyyy-MM-dd.']
  pcp_eligible_flag boolean [note: 'Indicates whether this specialty qualifies the provider to serve as a Primary Care Provider (PCP) for member assignment. True for specialties such as Family Medicine, Internal Medicine, Pediatrics, and General Practice.']
  recertification_cycle_years varchar [note: 'The number of years in the recertification cycle (e.g., 10 years for most ABMS boards). Null if recertification is not required.']
  recertification_required_flag boolean [note: 'Indicates whether the board certification requires periodic recertification or maintenance of certification (MOC). True if recertification is required; False if lifetime certification.']
  record_created_timestamp timestamp [note: 'The timestamp when this specialty record was first created in the data platform. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Used for audit trail and data lineage.']
  record_effective_date date [note: 'The date from which this version of the specialty record is effective for business purposes. Supports slowly changing dimension (SCD) Type 2 historization. Format: yyyy-MM-dd.']
  record_end_date date [note: 'The date on which this version of the specialty record ceased to be effective. Null for the current active record. Supports slowly changing dimension (SCD) Type 2 historization. Format: yyyy-MM-dd.']
  record_updated_timestamp timestamp [note: 'The timestamp when this specialty record was last updated in the data platform. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Used for audit trail and change tracking.']
  source_system_code varchar [note: 'The unique identifier for this specialty record in the source system. Used for data lineage, reconciliation, and troubleshooting.']
  specialist_referral_required_flag boolean [note: 'Indicates whether members require a referral from their PCP to see this provider in this specialty, based on plan type (e.g., HMO requires referrals; PPO typically does not). True if referral is required; False otherwise.']
  specialty_type varchar [note: 'Indicates whether this is the provider\'s primary specialty, secondary specialty, or tertiary specialty. Primary specialty is the main area of practice; secondary and tertiary are additional areas of expertise.']
  start_date date [note: 'The date on which the provider began practicing in this specialty. Used to calculate years of experience and for credentialing verification. Format: yyyy-MM-dd.']
  subspecialty_code varchar [note: 'Additional NUCC taxonomy code representing a subspecialty within the primary specialty (e.g., Interventional Cardiology within Cardiology). Null if no subspecialty designation.']
  subspecialty_name varchar [note: 'The human-readable name of the subspecialty, if applicable. Provides additional granularity beyond the primary specialty for network adequacy and member search.']
  telehealth_enabled_flag boolean [note: 'Indicates whether the provider offers telehealth or telemedicine services for this specialty. True if telehealth services are available; False otherwise. Important for provider directory accuracy.']
  vreq_validated boolean [note: 'VREQ validation marker']
  years_in_specialty varchar [note: 'The number of years the provider has been practicing in this specialty. Calculated from the date the provider first began practicing in this specialty area.']

  Note: 'Tracks all specialty and sub-specialty designations for a provider, including primary and secondary specialties, NUCC taxonomy codes, board certification details, certification body, certification date, expiration date, and specialty-level credentialing status. A provider may hold multiple specialties across different taxonomies. Supports network adequacy analysis by specialty and HEDIS measure attribution. [FHIR-aligned]'
}

Table provider.practice_location {
  practice_location_id varchar [pk, note: 'Unique identifier for the practice location. Primary key.']
  facility_id varchar [note: 'Foreign key linking to provider.facility. Business justification: A practice location can be physically situated within a healthcare facility (e.g., a hospital-based clinic, an ASC-based practice). Linking practice_location to facility enables facility-level aggrega']
  provider_id varchar [note: 'Reference to the primary provider associated with this practice location. A provider may have multiple practice locations.']
  accepting_new_patients_flag boolean [note: 'Indicates whether this practice location is currently accepting new patients. Critical for member provider search and network adequacy.']
  ada_compliant_flag boolean [note: 'Indicates whether the practice location meets ADA accessibility requirements.']
  address_line_1 varchar [note: 'Primary street address of the practice location (street number and name).']
  address_line_2 varchar [note: 'Secondary address information such as suite, floor, building, or unit number.']
  city varchar [note: 'City name of the practice location.']
  county_name varchar [note: 'County name where the practice location is situated. Used for network adequacy geographic access analysis.']
  created_timestamp timestamp [note: 'Timestamp when this practice location record was first created in the system.']
  directory_display_flag boolean [note: 'Indicates whether this practice location should be displayed in the member-facing provider directory. May be false even if active (e.g., administrative locations).']
  effective_date date [note: 'Date when this practice location became active in the provider network.']
  email_address varchar [note: 'Primary email contact for the practice location for administrative and member communication.']
  fax_number varchar [note: 'Fax number for the practice location used for prior authorization and medical records transmission.']
  fips_code varchar [note: '5-digit FIPS county code for geographic identification and network adequacy reporting.']
  languages_spoken varchar [note: 'Comma-separated list of languages spoken by staff at this practice location (e.g., \'English, Spanish, Mandarin\'). Supports member language access requirements.']
  last_verified_date date [note: 'Date when the practice location information was last verified for accuracy. CMS requires quarterly verification for provider directory data.']
  latitude decimal(10,7) [note: 'Geographic latitude coordinate of the practice location in decimal degrees. Used for time/distance network adequacy calculations.']
  location_name varchar [note: 'Business name or designation of the practice location (e.g., \'Main Street Family Medicine\', \'Downtown Urgent Care Center\').']
  location_type varchar [note: 'Classification of the practice location type indicating the care delivery setting.']
  longitude decimal(10,7) [note: 'Geographic longitude coordinate of the practice location in decimal degrees. Used for time/distance network adequacy calculations.']
  medicaid_provider_number varchar [note: 'State-specific Medicaid provider identifier for this practice location. Required for Medicaid claims submission.']
  medical_group_name varchar [note: 'Name of the medical group or practice organization that operates this location. Used for provider directory grouping and network reporting.']
  medicare_provider_number varchar [note: 'Medicare provider identifier (PTAN or legacy OSCAR number) for this practice location. Required for Medicare Advantage claims.']
  npi varchar [note: '10-digit National Provider Identifier for this practice location if it has a Type 2 (organizational) NPI. May be null if location uses only the provider\'s individual NPI.']
  office_hours varchar [note: 'Operating hours of the practice location (e.g., \'Mon-Fri 8:00 AM - 5:00 PM, Sat 9:00 AM - 1:00 PM\'). Free-text field for member-facing display.']
  parking_available_flag boolean [note: 'Indicates whether on-site or nearby parking is available for patients.']
  participation_status varchar [note: 'Current participation status of this practice location in the provider network. Determines whether location appears in member-facing provider directory.']
  patient_age_maximum varchar [note: 'Maximum patient age accepted at this practice location (e.g., 18 for pediatrics only). Null if no maximum restriction.']
  patient_age_minimum varchar [note: 'Minimum patient age accepted at this practice location (e.g., 0 for all ages, 18 for adults only). Null if no minimum restriction.']
  patient_gender_restriction varchar [note: 'Gender restriction for patients served at this location (e.g., \'female_only\' for women\'s health clinics).']
  phone_number varchar [note: 'Primary contact phone number for the practice location (10-digit format without formatting).']
  public_transportation_access_flag boolean [note: 'Indicates whether the practice location is accessible via public transportation.']
  record_status varchar [note: 'Current status of this practice location record in the data warehouse. Supports soft-delete and historical tracking.']
  state_code varchar [note: 'Two-letter state abbreviation (e.g., \'CA\', \'NY\', \'TX\').']
  tax_identifier varchar [note: 'Federal Tax Identification Number (EIN) for the practice location or medical group. Used for claims payment and 1099 reporting.']
  telehealth_available_flag boolean [note: 'Indicates whether telehealth services are available at this practice location.']
  termination_date date [note: 'Date when this practice location was terminated from the provider network. Null if currently active.']
  updated_timestamp timestamp [note: 'Timestamp when this practice location record was last modified.']
  verification_method varchar [note: 'Method used for the most recent verification of practice location information.']
  vreq_validated boolean [note: 'VREQ validation marker']
  wheelchair_accessible_flag boolean [note: 'Indicates whether the practice location has wheelchair accessibility features (ramps, elevators, accessible restrooms).']
  zip_code varchar [note: '5-digit or ZIP+4 postal code for the practice location.']

  Note: 'Represents a physical or virtual practice location where a provider delivers care. Captures address (street, city, state, ZIP+4), county, FIPS code, geolocation (lat/long), phone, fax, office hours, accessibility features (ADA compliance, wheelchair access), telehealth availability, accepting new patients flag by location, patient age/population restrictions, and location type (office, hospital, urgent care, telehealth-only). Supports CMS provider directory accuracy requirements, network adequacy geographic access standards (time/distance), and member-facing provider search. A provider may have multiple practice locations; each location may serve multiple providers. [FHIR-aligned]'
}

Table provider.license {
  license_id varchar [pk, note: 'Primary key for license']
  practice_location_id varchar [note: 'Reference to the healthcare provider who holds this license. Links to the provider master entity.']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: A professional license is held by a specific provider. License is the SSOT for all professional licenses and regulatory registrations — it must directly reference the provider who holds it. Currently ']
  attestation_date date [note: 'The date the provider attested to the accuracy and currency of this license information. Used for credentialing and recredentialing cycles.']
  authorized_schedules varchar [note: 'For DEA and CDS registrations, the controlled substance schedules the provider is authorized to prescribe (Schedule II, III, IV, V). Stored as comma-separated list. Critical for pharmacy benefit management and prior authorization workflows.']
  compact_participation_flag boolean [note: 'Indicates whether this license is part of an interstate licensure compact (e.g., Interstate Medical Licensure Compact, Nurse Licensure Compact). True if the license grants multi-state practice privileges; false otherwise.']
  compact_privilege_states varchar [note: 'Comma-separated list of state abbreviations where the provider has practice privileges under the interstate compact. Used for multi-state network adequacy and provider directory management.']
  compact_type varchar [note: 'The specific interstate licensure compact this license participates in. IMLC is Interstate Medical Licensure Compact for physicians. Populated only when compact_participation_flag is true. [ENUM-REF-CANDIDATE: imlc|nurse_licensure_compact|psychology_compact|physical_therapy_compact|ems_compact|counseling_compact|none — 7 candidates stripped; promote to reference product]']
  continuing_education_hours_required decimal(6,2) [note: 'The number of continuing education or CME hours required per renewal cycle to maintain this license. Varies by state and license type.']
  continuing_education_required_flag boolean [note: 'Indicates whether continuing education (CE) or continuing medical education (CME) is required to maintain this license. True if CE/CME is mandatory for renewal; false otherwise.']
  disciplinary_action_date date [note: 'The date disciplinary action was taken against the license. Used for credentialing review timelines and risk assessment.']
  disciplinary_action_details varchar [note: 'Detailed description of any disciplinary actions, sanctions, or restrictions imposed by the licensing authority. Includes nature of violation, dates, and resolution. Populated only when disciplinary_action_flag is true.']
  disciplinary_action_flag boolean [note: 'Indicates whether any disciplinary action has been taken against this license by the issuing authority. True if disciplinary action exists; false otherwise. Critical for credentialing risk assessment.']
  effective_date date [note: 'The date the license becomes valid and the provider is authorized to practice under this credential. May differ from issue date for renewals or reinstatements.']
  expiration_date date [note: 'The date the license expires and is no longer valid unless renewed. Critical for credentialing compliance and provider directory accuracy. Null for licenses with no expiration.']
  issue_date date [note: 'The date the license or registration was originally issued by the licensing authority. Used to calculate license tenure and verify historical credentialing timelines.']
  issuing_authority varchar [note: 'The regulatory body or government agency that issued the license or registration. Examples include State Medical Board, State Board of Nursing, Drug Enforcement Administration (DEA), State Pharmacy Board, or Centers for Medicare and Medicaid Services (CMS).']
  issuing_state varchar [note: 'The U.S. state or territory that issued the license. Uses two-letter state abbreviation. Critical for multi-state licensure tracking and Interstate Medical Licensure Compact compliance. [ENUM-REF-CANDIDATE: AL|AK|AZ|AR|CA|CO|CT|DE|FL|GA|HI|ID|IL|IN|IA|KS|KY|LA|ME|MD|MA|MI|MN|MS|MO|MT|NE|NV|NH|NJ|NM|NY|NC|ND|OH|OK|OR|PA|RI|SC|SD|TN|TX|UT|VT|VA|WA|WV|WI|WY|DC — 51 candidates stripped; promote to reference product]']
  license_number varchar [note: 'The unique license or registration number issued by the licensing authority. For DEA registrations, this is the DEA number; for state medical licenses, this is the state-issued license number.']
  license_status varchar [note: 'Current status of the license or registration in its lifecycle. Active indicates the license is valid and in good standing; suspended, revoked, or expired indicate the provider cannot practice under this credential. [ENUM-REF-CANDIDATE: active|inactive|suspended|revoked|expired|surrendered|pending_renewal|probation|restricted — 9 candidates stripped; promote to reference product]']
  license_type varchar [note: 'The category of professional license or registration. Includes state medical licenses (MD, DO), nursing licenses (RN, LPN, NP), DEA controlled substance registrations, state CDS permits, pharmacy licenses, and other professional certifications. [ENUM-REF-CANDIDATE: medical_license|nursing_license|dea_registration|cds_permit|pharmacy_license|dental_license|optometry_license|podiatry_license|chiropractic_license|physical_therapy_license|occupational_therapy_license|behavioral_health_license|advanced_practice_license|physician_assistant_license|other — 15 candidates stripped; promote to reference product]']
  practice_restrictions varchar [note: 'Any limitations or restrictions placed on the license by the issuing authority. May include supervision requirements, practice setting restrictions, or specific clinical limitations.']
  primary_source_verification_date date [note: 'The date the license was last verified directly with the issuing authority (primary source). NCQA requires PSV within 180 days of credentialing decision and every 36 months thereafter.']
  primary_source_verification_method varchar [note: 'The method used to verify the license with the primary source. Includes online state board portals, written correspondence, phone verification, third-party credentialing services, or automated API integration.']
  record_created_timestamp timestamp [note: 'The date and time this license record was first created in the data platform. Used for audit trail and data lineage tracking.']
  record_current_flag boolean [note: 'Indicates whether this is the current active version of the license record. True for the current record; false for historical versions. Supports Type 2 slowly changing dimension queries.']
  record_effective_timestamp timestamp [note: 'The date and time from which this version of the license record is effective for business reporting. Supports Type 2 slowly changing dimension tracking.']
  record_end_timestamp timestamp [note: 'The date and time when this version of the license record was superseded by a new version. Null for the current active record. Supports Type 2 slowly changing dimension tracking.']
  record_updated_timestamp timestamp [note: 'The date and time this license record was last modified in the data platform. Used for change tracking and audit purposes.']
  renewal_cycle_months varchar [note: 'The number of months between required renewals for this license type. Common values are 12, 24, or 36 months depending on state and license type.']
  renewal_date date [note: 'The date the license was last renewed. Used to track renewal cycles and ensure continuous licensure for credentialing purposes.']
  scope_of_practice varchar [note: 'Description of the clinical activities and services the provider is authorized to perform under this license. Varies by license type and state regulations. Used for state-specific scope-of-practice validation.']
  source_system_code varchar [note: 'The unique identifier for this license record in the source operational system. Used for data lineage and reconciliation.']
  telemedicine_authorized_flag boolean [note: 'Indicates whether the provider is authorized to deliver telemedicine services under this license. True if telemedicine practice is permitted; false otherwise. Critical for virtual care network management.']
  verification_source varchar [note: 'The specific entity or system used to perform primary source verification. Examples include state medical board website, NPDB, third-party credentialing verification organization (CVO), or automated verification service.']
  verification_url varchar [note: 'The web address of the state licensing board or regulatory authority where the license can be verified online. Used for automated primary source verification workflows.']
  vreq_validated boolean [note: 'VREQ validation marker']

  Note: 'Single source of truth for all professional licenses, certifications, and regulatory registrations held by a provider. Covers state medical licenses (MD, DO, NP, PA, RN, LCSW, LPC, etc.), DEA controlled substance registrations (including authorized schedules II-V and registration state), CDS (state-level controlled dangerous substance) permits, state pharmacy licenses, and other regulatory registrations. Stores license/registration type, issuing authority (state medical board, state nursing board, DEA, CMS, state pharmacy board), license or registration number, authorized schedules (for DEA/CDS), issue date, expiration date, renewal date, status (active, suspended, revoked, expired, surrendered, pending renewal), disciplinary action flags, disciplinary action details, and primary source verification (PSV) date and source. Supports NCQA credentialing standards for PSV, multi-state licensure tracking via Interstate Medical Licensure Compact, controlled substance prescribing authorization, pharmacy benefit management workflows, and state-specific scope-of-practice validation. [FHIR-aligned]'
}

Table provider.group_practice {
  group_practice_id varchar [pk, note: 'Primary key for group_practice']
  facility_id varchar [note: 'Foreign key linking to provider.facility. Business justification: A group practice is often affiliated with or operates within a healthcare facility (hospital-based medical group, ASC-affiliated practice). group_practice currently has hospital_affiliation as a STRIN']
  party_id varchar [note: 'Foreign key linking to contract.party. Business justification: Group practices sign participation agreements as legal entities. Linking group_practice to contract.party enables group-level contract execution, group NPI/TIN reconciliation, and regulatory reporting']
  accepting_new_patients boolean [note: 'Indicates whether the group practice is currently accepting new patients. Used for provider directory accuracy and member access.']
  accessibility_accommodations varchar [note: 'Description of accessibility accommodations available at the group practice (e.g., wheelchair access, hearing loop, accessible exam tables) to comply with ADA requirements.']
  aco_participant boolean [note: 'Indicates whether the group practice participates in an Accountable Care Organization (ACO) for value-based care arrangements.']
  address_line_1 varchar [note: 'The primary street address line 1 of the group practice\'s main location or headquarters.']
  address_line_2 varchar [note: 'The primary street address line 2 (suite, floor, building) of the group practice\'s main location.']
  city varchar [note: 'The city where the group practice\'s primary location is situated.']
  cms_certification_number varchar [note: 'The CMS Certification Number (CCN) assigned to FQHC, RHC, or other certified facilities. Required for Medicare/Medicaid billing.']
  county varchar [note: 'The county in which the group practice\'s primary location is located. Used for network adequacy and geographic access reporting.']
  created_timestamp timestamp [note: 'The timestamp when this group practice record was first created in the provider management system.']
  credentialing_date date [note: 'The date on which the group practice was initially credentialed and approved for network participation.']
  credentialing_status varchar [note: 'The current credentialing status of the group practice within the health plan\'s credentialing process.']
  data_source_system varchar [note: 'The name of the source system from which this group practice record originated (e.g., Cactus, ProviderSource, NPPES).']
  doing_business_as_name varchar [note: 'The trade name or DBA name under which the group practice operates, if different from the legal name.']
  effective_date date [note: 'The date on which the group practice\'s participation in the health plan network became effective.']
  email_address varchar [note: 'The primary email address for administrative and contracting communications with the group practice.']
  fax_number varchar [note: 'The fax number for the group practice, used for prior authorization and medical records transmission.']
  group_name varchar [note: 'The legal business name of the medical group, physician organization, or practice entity as registered with state authorities and CMS.']
  group_npi varchar [note: 'The 10-digit Type 2 NPI assigned to the group practice organization by CMS. This is the organizational NPI distinct from individual provider NPIs.']
  group_size varchar [note: 'The total number of individual providers (physicians, nurse practitioners, physician assistants) affiliated with and practicing under this group.']
  group_type varchar [note: 'Classification of the group practice organizational structure: solo practice (single physician), single specialty group, multi-specialty group, Independent Practice Association (IPA), Federally Qualified Health Center (FQHC), or Rural Health Clinic (RHC).']
  language_services_offered varchar [note: 'Comma-separated list of languages in which the group practice offers clinical services, used for provider directory cultural competency and member access.']
  participation_status varchar [note: 'The current participation status of the group practice in the health plan\'s provider network. Active indicates the group is contracted and accepting members.']
  pcmh_recognition_level varchar [note: 'The NCQA PCMH recognition level achieved by the group practice (Level 1, 2, or 3), with Level 3 being the highest.']
  pcmh_recognized boolean [note: 'Indicates whether the group practice has achieved NCQA Patient-Centered Medical Home (PCMH) recognition, qualifying for enhanced reimbursement and quality incentives.']
  phone_number varchar [note: 'The primary contact phone number for the group practice.']
  primary_specialty varchar [note: 'The primary medical specialty or service focus of the group practice (e.g., Family Medicine, Cardiology, Orthopedic Surgery, Multi-Specialty).']
  recredentialing_due_date date [note: 'The date by which the group practice must complete recredentialing to maintain network participation. NCQA requires recredentialing at least every 36 months.']
  state varchar [note: 'The two-letter state abbreviation for the group practice\'s primary location.']
  tax_identifier varchar [note: 'The federal tax identification number (TIN/EIN) assigned to the group practice by the IRS. Used for claims payment and 1099 reporting.']
  taxonomy_code varchar [note: 'The 10-character alphanumeric taxonomy code identifying the group\'s primary classification, specialty, and area of practice per the NUCC taxonomy.']
  telehealth_enabled boolean [note: 'Indicates whether the group practice offers telehealth or telemedicine services to members.']
  termination_date date [note: 'The date on which the group practice\'s participation in the health plan network was terminated or is scheduled to terminate. Null for active participants.']
  termination_reason varchar [note: 'The reason for termination of the group practice\'s network participation (e.g., voluntary withdrawal, quality issues, credentialing failure, contract non-renewal).']
  updated_timestamp timestamp [note: 'The timestamp when this group practice record was last modified in the provider management system.']
  vreq_validated boolean [note: 'VREQ validation marker']
  website_url varchar [note: 'The public website URL for the group practice, used in provider directory listings.']
  zip_code varchar [note: 'The 5-digit or 9-digit ZIP code for the group practice\'s primary location.']

  Note: 'Represents a medical group, physician organization, IPA, or multi-specialty group practice as a distinct business entity with its own Type 2 NPI and TIN. Stores group name, group NPI, TIN/EIN, group type (solo practice, group practice, IPA, FQHC, RHC), primary specialty, address, phone, CMS certification number, and group size. Serves as the organizational parent for individual provider affiliations and supports group-level contracting and network participation. [FHIR-aligned]'
}

Table provider.facility {
  facility_id varchar [pk, note: 'Unique identifier for the healthcare facility record. Primary key.']
  party_id varchar [note: 'Foreign key linking to contract.party. Business justification: Facilities (hospitals, ASCs) are independent contracting parties with their own NPIs and TINs. This link enables facility contract execution, credentialing-to-contract traceability, and OIG exclusion ']
  accepting_new_patients_flag boolean [note: 'Indicates whether the facility is currently accepting new patients. Used in provider directory and network adequacy reporting.']
  accreditation_body varchar [note: 'Organization that has accredited the facility. Values: joint_commission (The Joint Commission), dnv (DNV Healthcare), cihq (Center for Improvement in Healthcare Quality), aoa (American Osteopathic Association), aaahc (Accreditation Association for Ambulatory Health Care), achc (Accreditation Commission for Health Care), none (not accredited). [ENUM-REF-CANDIDATE: joint_commission|dnv|cihq|aoa|aaahc|achc|none — 7 candidates stripped; promote to reference product]']
  accreditation_expiration_date date [note: 'Date when the current accreditation expires. Null if facility is not accredited.']
  address_line_1 varchar [note: 'Primary street address of the facility physical location.']
  address_line_2 varchar [note: 'Secondary address information such as suite, floor, or building number.']
  bed_count varchar [note: 'Total number of licensed beds at the facility. Used for network adequacy calculations and capacity planning.']
  ccn varchar [note: 'Six-character alphanumeric identifier assigned by CMS to Medicare/Medicaid certified facilities. Also known as Provider Number.']
  city varchar [note: 'City where the facility is located.']
  clia_number varchar [note: 'Ten-character identifier issued by CMS for facilities performing laboratory testing. Format: 2-digit state code + 1 letter + 7 digits.']
  county_name varchar [note: 'County where the facility is located. Used for network adequacy geographic analysis.']
  credentialing_status varchar [note: 'Current status of the facility credentialing process. Indicates whether the facility has passed credentialing review and is approved for network participation.']
  critical_access_hospital_flag boolean [note: 'Indicates whether the facility is designated as a Critical Access Hospital under the Medicare Rural Hospital Flexibility Program.']
  effective_date date [note: 'Date when the facility record or current participation status became effective.']
  email_address varchar [note: 'Primary email address for facility communications and electronic correspondence.']
  emergency_services_flag boolean [note: 'Indicates whether the facility provides 24/7 emergency department services.']
  facility_type varchar [note: 'Classification of the healthcare facility. Values: hospital (acute care hospital), snf (Skilled Nursing Facility), asc (Ambulatory Surgical Center), fqhc (Federally Qualified Health Center), rhc (Rural Health Clinic), behavioral_health (behavioral health facility). [ENUM-REF-CANDIDATE: hospital|snf|asc|fqhc|rhc|behavioral_health|home_health|hospice|dialysis_center|dme_supplier|ltac|irf|imaging_center — promote to reference product]']
  fax_number varchar [note: 'Fax number for the facility, used for prior authorization and medical records transmission.']
  fhir_address varchar [note: 'FHIR Organization.address mapping']
  fhir_identifier varchar [note: 'FHIR Organization.identifier mapping']
  fhir_name varchar [note: 'FHIR Organization.name mapping']
  fhir_type varchar [note: 'FHIR Organization.type mapping']
  medicaid_certified_flag boolean [note: 'Indicates whether the facility is certified to participate in the Medicaid program.']
  medicare_certified_flag boolean [note: 'Indicates whether the facility is certified to participate in the Medicare program.']
  name varchar [note: 'Legal name of the healthcare facility as registered with state and federal authorities.']
  network_tier varchar [note: 'Tiering classification of the facility within the provider network. Tier 1 is preferred/lowest cost-sharing. Out_of_network indicates non-participating facility.']
  npi varchar [note: 'Type 2 NPI assigned to the facility by CMS. Ten-digit unique organizational identifier required for HIPAA transactions.']
  ownership_type varchar [note: 'Legal ownership structure of the facility. Values: for_profit (investor-owned), non_profit (tax-exempt), government (federal/state/local), tribal (Indian Health Service or tribal).']
  parent_organization_name varchar [note: 'Name of the parent health system or organization that owns or operates the facility. Null if facility is independent.']
  participation_status varchar [note: 'Current status of the facility in the provider network. Indicates whether the facility is actively participating, suspended, or terminated.']
  phone_number varchar [note: 'Primary contact phone number for the facility.']
  postal_code varchar [note: 'Five or nine-digit ZIP code of the facility location.']
  quality_rating decimal(3,2) [note: 'Overall quality rating score for the facility on a scale of 1.00 to 5.00. Derived from CMS Star Ratings, HEDIS measures, or internal quality assessments.']
  record_created_timestamp timestamp [note: 'Timestamp when this facility record was first created in the data platform.']
  record_updated_timestamp timestamp [note: 'Timestamp when this facility record was last updated in the data platform.']
  source_system_code varchar [note: 'Unique identifier for this facility in the source system. Used for data lineage and reconciliation.']
  state_code varchar [note: 'Two-letter state abbreviation where the facility is located.']
  tax_identifier varchar [note: 'Federal Employer Identification Number (EIN) assigned by IRS. Used for claims payment and 1099 reporting.']
  teaching_hospital_flag boolean [note: 'Indicates whether the facility is a teaching hospital affiliated with a medical school and residency programs.']
  telehealth_enabled_flag boolean [note: 'Indicates whether the facility offers telehealth or virtual care services.']
  termination_date date [note: 'Date when the facility participation was terminated or is scheduled to terminate. Null if currently active.']
  trauma_level varchar [note: 'Trauma center designation level assigned by state or American College of Surgeons. Level 1 is highest capability. Not_designated indicates facility is not a trauma center.']
  vreq_validated boolean [note: 'VREQ validation marker']
  website_url varchar [note: 'Public website URL for the facility. Used in provider directory.']

  Note: 'Master record for healthcare facilities — hospitals, SNFs, ASCs, FQHCs, RHCs, behavioral health facilities, home health agencies, hospices, dialysis centers, and DME suppliers. Stores facility name, facility type, CMS certification number (CCN), Medicare/Medicaid certification status, accreditation body (Joint Commission, DNV, CIHQ), accreditation expiration, bed count, trauma level, teaching hospital status, critical access hospital designation, CLIA number, and facility NPI. Distinct from individual provider records; supports institutional claims (837I) routing, network adequacy facility-type analysis, and CMS Star Rating facility attribution. Serves as the organizational anchor for hospital privilege tracking. [FHIR-aligned]'
}

Table provider.directory_entry {
  directory_entry_id varchar [pk, note: 'Primary key for directory_entry']
  health_plan_id varchar [note: 'Reference to the specific health plan for which this directory entry is published. A provider may have multiple directory entries across different plans.']
  network_config_id varchar [note: 'Foreign key linking to plan.network_config. Business justification: CMS and state provider directory accuracy requirements mandate that directory entries reflect the correct network tier and adequacy classification. directory_entry.network_tier is a denormalized plain']
  participation_status_id varchar [note: 'Foreign key linking to provider.participation_status. Business justification: A directory entry reflects a provider\'s current participation status — the directory is the consumer-facing view of participation. Linking directory_entry to participation_status creates the authorita']
  practice_location_id varchar [note: 'Reference to the internal provider master record. Links this published directory entry to the authoritative provider identity in the provider domain.']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: A directory entry is the consumer-facing published record representing a specific provider\'s participation. Without a direct provider_id FK, the directory entry is only linked to a practice location a']
  specialty_id varchar [note: 'Foreign key linking to provider.specialty. Business justification: A directory entry displays a provider\'s specialty for consumer-facing directory purposes. Currently specialty_display is a denormalized string. Adding specialty_id FK to the specialty table normalizes']
  accepting_new_patients_flag boolean [note: 'Indicates whether the provider is currently accepting new patients for this plan and network. Critical for directory accuracy and member access.']
  accessibility_features varchar [note: 'Description of accessibility features available at the practice location (wheelchair access, hearing loop, accessible parking). Supports ADA compliance and member access.']
  attestation_method varchar [note: 'Method used to verify the directory information with the provider. Documents the verification approach for audit and compliance purposes.']
  attestation_status varchar [note: 'Status of the provider attestation or verification process for this directory entry. Tracks compliance with CMS directory accuracy requirements.']
  board_certifications varchar [note: 'Comma-separated list of board certifications held by the provider. Demonstrates advanced training and specialty expertise.']
  directory_display_name varchar [note: 'Consumer-facing display name of the provider as it appears in the published directory. May differ from legal name for readability and member experience.']
  directory_publication_date date [note: 'Date when this directory entry was published or last updated in the member-facing provider directory. Required for CMS directory accuracy attestation.']
  gender varchar [note: 'Gender of the provider. Some members have preferences for provider gender, particularly for primary care and OB/GYN services.']
  graduation_year varchar [note: 'Year the provider graduated from medical school or professional training program. Helps members assess provider experience.']
  hospital_affiliation varchar [note: 'Name of hospital(s) where the provider has admitting privileges or primary affiliation. Important for continuity of care and member decision-making.']
  languages_spoken varchar [note: 'Comma-separated list of languages spoken by the provider or available at the practice location. Critical for member access and cultural competency.']
  last_verified_date date [note: 'Date when the directory information was last verified with the provider or practice. CMS and state DOI mandate regular verification cycles (typically 90 days).']
  medical_school varchar [note: 'Name of the medical school or professional training institution where the provider received their degree. Provides credential transparency for members.']
  next_verification_due_date date [note: 'Date by which the next directory verification must be completed to maintain compliance with CMS and state DOI accuracy mandates.']
  npi varchar [note: 'Ten-digit National Provider Identifier assigned by CMS. The authoritative unique identifier for healthcare providers in the United States.']
  office_hours varchar [note: 'Text description of office hours for the practice location. Helps members understand availability for appointment scheduling.']
  pcp_flag boolean [note: 'Indicates whether this provider is eligible to serve as a Primary Care Provider (PCP) for plan members. Relevant for HMO and POS plans requiring PCP selection.']
  practice_address_line1 varchar [note: 'First line of the practice location street address where the provider sees patients. Published in member-facing directory for appointment scheduling.']
  practice_address_line2 varchar [note: 'Second line of the practice location street address (suite, floor, building). Optional field for additional address detail.']
  practice_city varchar [note: 'City name of the practice location. Used for member search and network adequacy geographic analysis.']
  practice_county varchar [note: 'County name of the practice location. Required for state DOI network adequacy reporting and CMS service area compliance.']
  practice_email varchar [note: 'Email address for the practice location. May be published for member communication or used for administrative coordination.']
  practice_fax varchar [note: 'Fax number for the practice location. Used for prior authorization submissions and medical records exchange.']
  practice_phone varchar [note: 'Primary phone number for the practice location. Published in directory for member appointment scheduling and inquiries.']
  practice_state varchar [note: 'Two-letter state abbreviation of the practice location. Critical for state-specific network adequacy and regulatory compliance.']
  practice_website_url varchar [note: 'Website URL for the practice or provider. Published in directory to enable members to learn more about the provider and services offered.']
  practice_zip_code varchar [note: 'Five-digit or nine-digit ZIP code of the practice location. Used for member proximity search and network adequacy geo-access analysis.']
  provider_type varchar [note: 'High-level classification of the provider entity type. Determines directory presentation and search filtering options for members.']
  record_created_timestamp timestamp [note: 'Timestamp when this directory entry record was first created in the data warehouse. Supports audit trail and data lineage tracking.']
  record_updated_timestamp timestamp [note: 'Timestamp when this directory entry record was last updated in the data warehouse. Tracks data freshness and change frequency.']
  source_system_code varchar [note: 'Unique identifier for this directory entry in the source system. Enables traceability and reconciliation with upstream provider management systems.']
  telehealth_available_flag boolean [note: 'Indicates whether the provider offers telehealth or virtual visit services for this plan. Increasingly important for member access and convenience.']
  tin varchar [note: 'Nine-digit Tax Identification Number (EIN or SSN) associated with the provider or practice for billing and contracting purposes.']
  vreq_validated boolean [note: 'VREQ validation marker']

  Note: 'Published provider directory record representing the consumer-facing view of a provider\'s participation in a specific health plan and network. Captures provider display name, accepting new patients status, languages spoken, telehealth availability, network tier, plan participation, directory publication date, last verified date, and directory accuracy attestation status. Supports CMS and state DOI provider directory accuracy mandates (no-surprise billing, network adequacy). Distinct from the internal provider master — this is the published, plan-specific directory entry. [FHIR-aligned]'
}

Table provider.participation_status {
  participation_status_id varchar [pk, note: 'Unique identifier for the provider participation status record.']
  group_practice_id varchar [note: 'Foreign key linking to provider.group_practice. Business justification: A provider\'s participation status is often tracked at the group practice level — group practices negotiate network participation collectively, and participation status may be granted to a provider as ']
  network_config_id varchar [note: 'Foreign key linking to plan.network_config. Business justification: CMS network adequacy compliance and state regulatory reporting require linking a provider\'s participation status (network tier, panel status, credentialing) to the specific network_config that defines']
  party_id varchar [note: 'Foreign key linking to contract.party. Business justification: Participation status is governed by a contract party\'s active agreement. Linking to contract.party enables contract compliance validation (is the party\'s contract active?), sanction monitoring, and CM']
  practice_location_id varchar [note: 'Identifier of the healthcare provider whose participation status is being tracked. Links to the provider master entity.']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Participation status tracks a provider\'s participation history within a health plan and network. Without provider_id, the participation status record cannot be directly attributed to a provider — it o']
  specialty_id varchar [note: 'Foreign key linking to provider.specialty. Business justification: A provider\'s participation status in a network is often specialty-specific — a provider may be in-network for their primary specialty but not for a subspecialty. Linking participation_status to specia']
  accepting_new_patients_flag boolean [note: 'Indicates whether the provider is currently accepting new patients within this network and plan. Critical for provider directory accuracy and member access to care.']
  claims_adjudication_flag boolean [note: 'Indicates whether claims from this provider should be adjudicated as in-network for this plan and network. This is the authoritative flag for claims processing network determination.']
  code varchar [note: 'Current participation status of the provider within the network and plan. Active status indicates the provider is eligible for in-network claims adjudication. This is the authoritative field for network participation determination.']
  continuity_of_care_end_date date [note: 'The date through which continuity of care provisions apply for members in active treatment with this provider. Allows in-network benefits to continue for a transition period after provider termination.']
  credentialing_approval_date date [note: 'The date on which the provider was approved through the credentialing process for this participation arrangement.']
  credentialing_status varchar [note: 'The current credentialing status of the provider for this participation arrangement. Credentialing approval is a prerequisite for active participation status.']
  current_record_flag boolean [note: 'Indicates whether this is the current active version of the participation status record. True for the most recent version, false for historical versions.']
  directory_display_flag boolean [note: 'Indicates whether the provider should be displayed in the member-facing provider directory for this network and plan. May be false during pending credentialing or for providers with restricted panel status.']
  effective_date date [note: 'The date on which this participation status becomes effective. Claims with service dates on or after this date are subject to this participation status for network determination.']
  lob_code varchar [note: 'The line of business for which this participation status applies. Determines the regulatory framework and benefit structure applicable to this participation relationship.']
  member_notification_date date [note: 'The date on which affected members were notified of the provider participation status change. Required for regulatory compliance with provider termination notification requirements.']
  member_notification_method varchar [note: 'The communication channel used to notify members of the provider participation status change.']
  name varchar [note: 'Human-readable description of the participation status code.']
  network_tier_code varchar [note: 'The network tier assignment for this provider participation. Determines member cost-sharing levels in tiered network products.']
  next_recredentialing_date date [note: 'The date by which the provider must complete recredentialing to maintain active participation status. Typically occurs every 24-36 months per NCQA standards.']
  panel_status varchar [note: 'Indicates whether the provider panel is open to new member assignments. Closed or restricted panels may still serve existing members but do not accept new PCP assignments.']
  participation_category varchar [note: 'The category of participation indicating the scope of services the provider is authorized to deliver under this arrangement.']
  pcp_flag boolean [note: 'Indicates whether the provider is participating as a primary care provider in this network and plan. Determines PCP assignment eligibility for HMO and POS products.']
  record_created_timestamp timestamp [note: 'The timestamp when this participation status record was first created in the data platform.']
  record_effective_date date [note: 'The business effective date of this participation status record version. Used for slowly changing dimension type 2 historization.']
  record_end_date date [note: 'The business end date of this participation status record version. Null for the current active version. Used for slowly changing dimension type 2 historization.']
  record_updated_timestamp timestamp [note: 'The timestamp when this participation status record was last updated in the data platform.']
  regulatory_sanction_flag boolean [note: 'Indicates whether the provider is currently under regulatory sanction that affects their participation status. Sanctions may be imposed by state medical boards, CMS, or other regulatory bodies.']
  risk_arrangement_code varchar [note: 'The financial risk arrangement under which the provider participates. Indicates whether the provider is paid fee-for-service, capitation, or under a value-based care model.']
  sanction_effective_date date [note: 'The date on which a regulatory sanction affecting participation status became effective.']
  sanction_end_date date [note: 'The date on which a regulatory sanction affecting participation status is scheduled to end or was lifted.']
  source_system_code varchar [note: 'The unique identifier for this participation status record in the source system. Used for data lineage and reconciliation.']
  specialist_flag boolean [note: 'Indicates whether the provider is participating as a specialist in this network and plan. Used for network adequacy reporting and referral management.']
  status_change_trigger varchar [note: 'The business event or process that triggered this participation status change. Used for audit trail and root cause analysis of network changes. [ENUM-REF-CANDIDATE: CREDENTIALING_DECISION|CONTRACT_EXECUTION|CONTRACT_TERMINATION|SANCTION_IMPOSED|VOLUNTARY_REQUEST|NETWORK_CHANGE|RECREDENTIALING_OUTCOME — 7 candidates stripped; promote to reference product]']
  telehealth_enabled_flag boolean [note: 'Indicates whether the provider offers telehealth services under this participation arrangement. Required for provider directory display and member access to virtual care.']
  termination_date date [note: 'The date on which this participation status ends. Null for active, ongoing participation. Claims with service dates after this date are subject to out-of-network adjudication unless continuity of care provisions apply.']
  termination_reason_code varchar [note: 'Standardized code indicating the reason for participation termination. Required for regulatory reporting and member notification requirements.']
  termination_reason_description varchar [note: 'Detailed explanation of the termination reason. Provides additional context beyond the standardized termination reason code.']
  vreq_validated boolean [note: 'VREQ validation marker']

  Note: 'Tracks the participation status history of a provider within a specific health plan, network, and line of business (LOB). Records participation status (active, inactive, terminated, suspended, pending credentialing), effective date, termination date, termination reason code, LOB (commercial, Medicare Advantage, Medicaid, CHIP, marketplace/QHP), network ID, and status change trigger (credentialing decision, contract termination, sanction, voluntary withdrawal). This is the authoritative record for claims adjudication in-network/out-of-network determination. Supports member notification requirements for provider terminations, continuity of care provisions, and regulatory reporting of network changes. [FHIR-aligned]'
}

Table provider.provider_network_participation {
  provider_network_participation_id varchar [pk, note: 'Primary key for the NetworkParticipation association']
  capitation_arrangement_id varchar [note: 'Foreign key linking to contract.capitation_arrangement. Business justification: Providers under capitation contracts need their network participation record linked to the specific capitation arrangement for PMPM payment calculation, stop-loss application, and risk-pool reporting.']
  facility_id varchar [note: 'Foreign key linking to the facility']
  group_practice_id varchar [note: 'Foreign key linking to provider.group_practice. Business justification: Network participation is frequently negotiated and managed at the group practice level (IPA, medical group, physician organization). Linking provider_network_participation to group_practice enables gr']
  network_config_id varchar [note: 'Foreign key linking to plan.network_config. Business justification: Network adequacy reporting and provider directory management require linking a provider\'s network participation record to the specific network_config governing that participation (tier, adequacy stand']
  party_id varchar [note: 'Foreign key linking to contract.party. Business justification: Network participation agreements are executed by a contracting party. This link replaces the denormalized contract_reference text field, enabling sanction checks, OIG exclusion verification, and contr']
  practice_location_id varchar [note: 'Participating provider.']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: provider_network_participation tracks contractual network participation. While it links to facility and practice_location, it lacks a direct link to the individual provider. The product contains provi']
  reimbursement_policy_id varchar [note: 'Foreign key linking to contract.reimbursement_policy. Business justification: Reimbursement policies (NCCI edits, global surgery rules, modifier policies) govern claims adjudication for providers in a network. Linking network participation to the applicable reimbursement policy']
  service_area_id varchar [note: 'Foreign key linking to plan.plan_service_area. Business justification: Network adequacy geo-access compliance (CMS time-distance standards, state access rules) requires mapping each provider\'s network participation to the plan service area it covers. This link enables ge']
  specialty_id varchar [note: 'Foreign key linking to provider.specialty. Business justification: provider_network_participation contains specialty_code as a STRING, which is a denormalized reference to the specialty. Replacing this with specialty_id FK to the specialty table normalizes the relati']
  accepting_new_patients boolean [note: 'The accepting new patients for this record.']
  accepting_new_patients_flag boolean [note: 'The accepting new patients flag for this record.']
  accessibility_features varchar [note: 'ADA accessibility features available at the practice location']
  after_hours_flag boolean [note: 'Indicates if provider offers after-hours care']
  attestation_date date [note: 'Date of provider attestation']
  attestation_flag boolean [note: 'Indicates if provider has attested']
  board_certified boolean [note: 'Whether provider is board certified']
  capitation_rate decimal(18,2) [note: 'Monthly capitation rate if applicable']
  contract_effective_date date [note: 'Effective date of the provider contract']
  contract_termination_date date [note: 'Termination date of the provider contract']
  contracted_reimbursement_model varchar [note: 'The contracted reimbursement model for this record.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  credentialing_date date [note: 'Date provider was credentialed']
  credentialing_expiration_date date [note: 'Date when credentialing expires']
  credentialing_status varchar [note: 'The credentialing status for this record.']
  cultural_competency varchar [note: 'Cultural competency certifications']
  current_panel_size varchar [note: 'The current panel size for this record.']
  directory_display_flag boolean [note: 'The directory display flag for this record.']
  directory_effective_date date [note: 'Date provider appeared in directory']
  directory_termination_date date [note: 'Date provider removed from directory']
  effective_date date [note: 'Date the facility\'s participation became effective']
  geo_access_flag boolean [note: 'Indicates if provider meets geo access standards']
  handicap_accessible boolean [note: 'Whether location is handicap accessible']
  hospital_privileges varchar [note: 'Hospital privileges held by provider']
  is_accepting_new_patients boolean [note: 'Whether provider accepts new patients.']
  is_essential_community_provider boolean [note: 'Indicates if provider qualifies as an essential community provider']
  is_pcp boolean [note: 'The is pcp for this record.']
  languages_spoken varchar [note: 'Languages spoken by provider']
  last_credentialing_date date [note: 'Date of last credentialing verification for this participation']
  last_directory_update_date date [note: 'Date of last provider directory information update']
  network_adequacy_role varchar [note: 'Role this provider fills for network adequacy (e.g., essential community provider)']
  network_effective_date date [note: 'Date provider became effective in network']
  network_termination_date date [note: 'Date provider terminated from network']
  network_tier varchar [note: 'Tier classification of the facility within the network (e.g., Tier 1, Tier 2)']
  notes varchar [note: 'Notes related to network participation']
  panel_capacity varchar [note: 'The panel capacity for this record.']
  panel_close_date date [note: 'Date provider panel was closed']
  panel_open_date date [note: 'Date provider panel was opened']
  panel_size_limit varchar [note: 'The panel size limit for this record.']
  par_non_par_indicator varchar [note: 'The par non par indicator for this record.']
  par_nonpar_indicator varchar [note: 'The par nonpar indicator for this record.']
  par_status varchar [note: 'Added business attribute par_status']
  par_status_flag boolean [note: 'Depth attribute added by thin-product expansion (3b) for par_status_flag.']
  par_status_reason varchar [note: 'The par status reason for this record.']
  participation_agreement_date date [note: 'Date participation agreement was signed']
  participation_effective_date date [note: 'Date when provider participation in network becomes effective']
  participation_reason varchar [note: 'Reason for participation status change']
  participation_reason_code varchar [note: 'Reason code for participation change.']
  participation_status varchar [note: 'Current in‑network or out‑of‑network status for the facility in this network']
  participation_termination_date date [note: 'Date when provider participation in network terminates']
  participation_tier varchar [note: 'Tier classification of the provider within the network']
  participation_type varchar [note: 'Type of participation (par/non-par).']
  quality_score decimal(5,2) [note: 'Provider quality score']
  recredentialing_due_date date [note: 'Date recredentialing is due']
  reimbursement_method varchar [note: 'The reimbursement method for this record.']
  reimbursement_rate decimal(18,2) [note: 'Negotiated reimbursement rate.']
  reimbursement_terms varchar [note: 'Added business attribute reimbursement_terms']
  telehealth_available boolean [note: 'Whether telehealth services are available']
  termination_date date [note: 'Date the facility\'s participation ends or is scheduled to end']
  termination_reason varchar [note: 'The termination reason for this record.']
  termination_reason_code varchar [note: 'The termination reason code for this record.']
  tier varchar [note: 'Depth attribute added by thin-product expansion (3b) for tier.']
  tier_assignment varchar [note: 'Added business attribute tier_assignment']
  tier_level varchar [note: 'The tier level for this record.']
  time_distance_compliant boolean [note: 'Indicates compliance with time/distance standards']
  updated_timestamp timestamp [note: 'Record last update timestamp.']
  vbc_participation_flag boolean [note: 'Whether provider participates in value-based care']
  verification_date date [note: 'Date participation was last verified']
  verification_method varchar [note: 'Method used to verify participation']
  vreq_validated boolean [note: 'VREQ validation marker']
  wait_time_days varchar [note: 'Average wait time for appointments in days']
  weekend_hours_flag boolean [note: 'Indicates if provider offers weekend hours']

  Note: 'Represents the contractual participation of a healthcare facility in a provider network. Each record links one facility to one network and stores attributes that describe the nature of that participation.. Existence Justification: A healthcare facility can belong to multiple provider networks simultaneously, and each provider network includes many facilities. The relationship is actively managed (contracts/agreements) and carries attributes such as participation status and effective/termination dates. [FHIR-aligned]'
}

Table provider.provider {
  provider_id varchar [pk]
  group_practice_id varchar [note: 'Foreign key linking to provider.group_practice. Business justification: A provider has a primary group practice affiliation — the medical group, IPA, or physician organization they primarily practice under. The provider table (hub entity) needs a direct link to group_prac']
  party_id varchar [note: 'Foreign key linking to contract.party. Business justification: Providers are legal contracting parties. This link enables contract execution, credentialing-to-contract resolution, OIG sanction checks, and claims adjudication party validation. A health insurance E']
}

Table provider.privilege {
  privilege_id varchar [pk, note: 'Primary key for the provider_privilege association']
  facility_id varchar [note: 'Foreign key linking to the facility that granted the privilege.']
  provider_id varchar [note: 'Foreign key linking to the provider who holds the privilege.']
  category varchar [note: 'Broad category grouping for the privilege, used for credentialing workflow routing and reporting. Distinguishes standard core privileges from special or temporary grants.']
  credentialing_effective_date date [note: 'Date when the current credentialing approval became effective. [Moved from facility: Credentialing effective date is specific to a provider\'s credentialing at a particular facility, not a property of the facility itself. Moving it to the provider_privilege association correctly scopes it to the provider-facility relationship.]']
  credentialing_expiration_date date [note: 'Date when the current credentialing approval expires and recredentialing is required. [Moved from facility: Credentialing expiration is a provider-at-facility attribute, not a facility-level attribute. A facility has many credentialed providers each with their own expiration dates; this belongs on the association record.]']
  credentialing_status varchar [note: 'Status of the credentialing or recredentialing process for this specific provider-facility privilege. Distinct from the privilege_status — a privilege may be active while recredentialing is pending.']
  effective_date date [note: 'Date on which the privilege grant became active at this facility. Used for claims date-of-service validation and credentialing audit trails.']
  privilege_status varchar [note: 'Current operational status of the privilege grant. Drives claims adjudication eligibility checks and network directory accuracy.']
  privilege_type varchar [note: 'Classification of the clinical privilege granted to the provider at this facility. Determines the scope of clinical activities the provider is authorized to perform.']
  termination_date date [note: 'Date on which the privilege was or will be terminated at this facility. Null if the privilege is currently active with no scheduled end date.']

  Note: 'This association product represents the clinical privilege grant between a provider and a healthcare facility. It captures the formal credentialing decision by which a facility authorizes a provider to perform specific clinical activities within that institution. Each record links one provider to one facility and carries privilege-specific attributes — type, category, status, and effective/termination dates — that exist only in the context of this provider-facility relationship. Supports institutional claims (837I) routing validation, network adequacy analysis, regulatory credentialing compliance, and CMS reporting.. Existence Justification: Hospital privileges represent a well-established, actively managed business concept in healthcare credentialing: a single provider (physician, surgeon, etc.) holds clinical privileges at multiple facilities simultaneously, and each facility grants privileges to many providers. This relationship is not derivable from transactional data — it is an operational record that credentialing departments create, update, and expire as part of regulatory compliance workflows. The relationship carries rich, relationship-specific data (privilege type, status, effective/termination dates, credentialing status, privilege category) that belongs to neither the provider nor the facility alone.'
}

Table claim.header {
  header_id varchar [pk, note: 'Primary key for header']
  capitation_arrangement_id varchar [note: 'Foreign key linking to contract.capitation_arrangement. Business justification: For capitated providers, claims must be linked to the capitation arrangement to prevent double-payment (capitation already covers the service). Payment integrity, capitation reconciliation, and carve-']
  care_enrollment_id varchar [note: 'Foreign key linking to care.care_enrollment. Business justification: Supports enrollment‑specific claim tracking required by regulatory reporting (e.g., CMS program‑level cost reporting) linking claim to the exact enrollment record.']
  contract_network_participation_id varchar [note: 'Foreign key linking to contract.network_participation. Business justification: Claim adjudication requires determining the provider\'s network participation status at time of service to apply correct cost-sharing and allowed amounts. In-network vs. out-of-network determination is']
  episode_of_care_id varchar [note: 'Foreign key linking to utilization.episode_of_care. Business justification: Claims are assigned to episodes of care for bundled payment programs, value-based care contracts, and population health cost rollups. Direct FK from claim header to episode_of_care enables episode-lev']
  member_identity_id varchar [note: 'Unique identifier of the member (patient) associated with the claim.']
  pa_decision_id varchar [note: 'Foreign key linking to utilization.pa_decision. Business justification: Outpatient claims adjudicate against the PA decision record (authorized dates, quantity, service codes) without necessarily having a UM case. Direct FK from claim header to pa_decision enables authori']
  pa_request_id varchar [note: 'Foreign key linking to utilization.pa_request. Business justification: Claims must be validated against the originating PA request during adjudication — a core regulatory and operational requirement. utilization.header.prior_authorization_number is a denormalized text field; r']
  participation_status_id varchar [note: 'Foreign key linking to provider.participation_status. Business justification: Claims adjudication requires validating the provider\'s network participation status (par/non-par) at time of service for allowed amount determination, member cost-sharing calculation, and regulatory n']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Claims adjudication requires the active policy to apply correct benefits, deductibles, COB rules, and coverage limits. Every claim is filed under a specific policy. Health insurance adjudicators and a']
  provider_party_id varchar [note: 'Foreign key linking to contract.party. Business justification: Needed to associate each claim with the contracting party (provider organization) for regulatory reporting and payment reconciliation.']
  radv_audit_id varchar [note: 'Foreign key linking to risk.radv_audit. Business justification: CMS RADV audits sample specific claims to validate HCC-supporting medical records. Auditors and compliance teams must identify exactly which claim headers were sampled in a given RADV audit for medica']
  rendering_provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Provider-level claim analytics (HEDIS, network adequacy reporting, credentialing status at time of service) require linking claim headers to the rendering provider entity. billing_provider_npi is a se']
  rendering_provider_practice_location_id varchar [note: 'FK to provider.provider.provider_id — Every claim must resolve to a rendering provider for network status determination, fee schedule lookup, and provider payment. This is the second most critical operational join in health insurance.']
  rendering_specialty_id varchar [note: 'Foreign key linking to provider.specialty. Business justification: HEDIS specialty reporting, network adequacy analysis by specialty, and specialty-specific medical policy application require linking claim headers to the rendering provider\'s specialty. Role-prefixed ']
  service_area_id varchar [note: 'Foreign key linking to plan.plan_service_area. Business justification: Network adequacy and service‑area compliance reports need to map each claim to the plan’s service area where the service was rendered.']
  adjustment_flag boolean [note: 'Indicates if the claim includes any adjustments.']
  admission_date date [note: 'Date of patient admission for inpatient claims.']
  allowed_amount decimal(12,2) [note: 'Maximum amount the insurer permits for the services.']
  billed_amount decimal(12,2) [note: 'Total amount billed to the insurer before adjustments.']
  billing_provider_npi varchar [note: 'NPI of the provider responsible for billing.']
  billing_type varchar [note: 'Method of billing for the claim.']
  claim_event_timestamp timestamp [note: 'Date and time of the primary service rendered for the claim.']
  claim_line_count varchar [note: 'Number of line detail records associated with this claim.']
  claim_number varchar [note: 'Unique claim identifier assigned by the insurer.']
  claim_source varchar [note: 'Origin of the claim submission.']
  claim_status varchar [note: 'Current processing status of the claim.']
  claim_type varchar [note: 'Category of claim based on service type.']
  claim_version varchar [note: 'Version number of the claim for tracking revisions.']
  cob_indicator boolean [note: 'Flag indicating whether coordination of benefits processing is required.']
  created_timestamp timestamp [note: 'Timestamp when the claim header record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO currency code for monetary amounts.']
  denial_reason_code varchar [note: 'Code representing the reason for claim denial, if applicable.']
  diagnosis_codes varchar [note: 'Pipe-separated list of diagnosis codes associated with the claim.']
  discharge_date decimal(18,2) [note: 'Date of patient discharge for inpatient claims.']
  drg_code varchar [note: 'DRG assignment for inpatient claims.']
  fhir_diagnosis varchar [note: 'FHIR Claim.diagnosis mapping']
  fhir_item varchar [note: 'FHIR Claim.item mapping']
  fhir_patient varchar [note: 'FHIR Claim.patient mapping']
  fhir_provider varchar [note: 'FHIR Claim.provider mapping']
  fhir_status varchar [note: 'FHIR Claim.status mapping']
  fhir_type varchar [note: 'FHIR Claim.type mapping']
  is_hipaa_compliant boolean [note: 'Flag indicating whether the claim data complies with HIPAA regulations.']
  is_mlr_excluded boolean [note: 'Indicates if the claim is excluded from MLR calculations.']
  is_suspended boolean [note: 'Indicates if the claim is currently suspended pending additional information.']
  length_of_stay varchar [note: 'Number of days between admission and discharge.']
  lob varchar [note: 'Business line to which the claim belongs.']
  paid_amount decimal(12,2) [note: 'Net amount paid to the provider after adjustments.']
  place_of_service_code varchar [note: 'Code indicating where the service was provided.']
  prior_status varchar [note: 'Previous status before the most recent transition.']
  procedure_codes varchar [note: 'Pipe-separated list of procedure codes billed on the claim.']
  referral_provider_npi varchar [note: 'NPI of the referring provider, if applicable.']
  sla_due_date date [note: 'Date by which the claim must be processed to meet service level agreement.']
  sla_met boolean [note: 'Flag indicating whether the claim met the SLA deadline.']
  status_change_timestamp timestamp [note: 'Timestamp of the most recent status transition.']
  suspension_reason varchar [note: 'Reason why the claim was suspended.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the claim header record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Core master record and lifecycle hub for every submitted health insurance claim — professional (CMS-1500/837P), institutional (UB-04/837I), dental (ADA/837D), and behavioral health. Captures claim-level identifiers (ICN), claim type, bill type, place of service, financial totals (billed/allowed/paid), adjudication status with full status transition history (prior status, new status, timestamp, reason, changed-by), service dates, COB indicator, LOB, plan and member identifiers, provider NPIs (rendering, billing, facility, attending, referring), DRG assignment, admission details, claim source (EDI/paper/portal), adjustment linkage, pend/suspend reason tracking, SLA monitoring dates, and HIPAA compliance flags. Serves as the central hub linking all claim-related detail records. [FHIR-aligned]'
}

Table claim.line {
  line_id varchar [pk, note: 'Primary key for line']
  auth_service_line_id varchar [note: 'Foreign key linking to utilization.auth_service_line. Business justification: Audit of Prior Authorization compliance; claim line references the authorized service line to verify authorized quantity, price, and status.']
  benefit_id varchar [note: 'Foreign key linking to plan.benefit. Business justification: Adjudication uses benefit definitions to determine coverage and cost sharing for each claim line; linking claim line to plan.benefit is required for accurate payment calculation.']
  claim_header_id varchar [note: 'Identifier of the parent claim to which this line belongs.']
  cost_share_rule_id varchar [note: 'Foreign key linking to plan.cost_share_rule. Business justification: Each claim line\'s cost-sharing calculation (copay, coinsurance, deductible application) references a specific cost_share_rule. Used in line-level adjudication, member EOB generation, and cost-sharing ']
  drug_master_id varchar [note: 'Foreign key linking to pharmacy.drug_master. Business justification: Medical drug claims (infusion therapy, chemotherapy J-codes) require resolving the NDC on a claim line to the drug master for formulary tier validation, drug interaction review, and MLR drug-spend rep']
  pa_request_id varchar [note: 'Foreign key linking to utilization.pa_request. Business justification: Individual claim service lines reference their own PA request for line-level authorization validation. Multi-service authorizations require per-line PA tracking. utilization.line.prior_authorization_number ']
  rendering_provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Service lines may have different rendering providers than the claim header (assistant surgeon, anesthesiologist, co-surgeon). 837 transaction processing and line-level provider utilization reporting r']
  specialty_id varchar [note: 'Foreign key linking to provider.specialty. Business justification: Line-level specialty attribution supports specialty-specific benefit application (e.g., mental health parity), tiered cost-sharing rules, and HEDIS measure calculation at the individual service line l']
  adjustment_amount decimal(12,2) [note: 'Monetary amount of any adjustment applied to the line after initial adjudication.']
  adjustment_reason_code varchar [note: 'Code describing the reason for the line adjustment.']
  admission_date date [note: 'Date the patient was admitted (applicable to institutional claims).']
  allowed_amount decimal(12,2) [note: 'Maximum amount the payer agrees to pay for the line.']
  anesthesia_minutes varchar [note: 'Total minutes of anesthesia administered for the line (if applicable).']
  billed_amount decimal(12,2) [note: 'Charged amount submitted to the payer for the line.']
  cob_paid_amount decimal(12,2) [note: 'Amount paid by secondary/tertiary payers under COB processing.']
  created_timestamp timestamp [note: 'Timestamp when the line record was first created in the system.']
  denial_reason_code varchar [note: 'Standard code indicating why the line was denied.']
  description varchar [note: 'Free‑text description of the service rendered.']
  discharge_date decimal(18,2) [note: 'Date the patient was discharged (applicable to institutional claims).']
  emergency_indicator boolean [note: 'True if the service was rendered as an emergency.']
  epsdt_indicator boolean [note: 'True if the service qualifies for EPSDT coverage (for Medicaid).']
  family_planning_indicator boolean [note: 'True if the service is related to family planning.']
  line_number varchar [note: 'Sequential number of the line within the claim.']
  line_status varchar [note: 'Current processing status of the claim line.']
  line_type varchar [note: 'Category of service rendered on the line.']
  modifier_1 varchar [note: 'First two‑character modifier associated with the procedure code.']
  modifier_2 varchar [note: 'Second two‑character modifier associated with the procedure code.']
  modifier_3 varchar [note: 'Third two‑character modifier associated with the procedure code.']
  modifier_4 varchar [note: 'Fourth two‑character modifier associated with the procedure code.']
  paid_amount decimal(12,2) [note: 'Amount actually paid by the payer for the line.']
  patient_responsibility_amount decimal(12,2) [note: 'Sum of copay, coinsurance, and deductible amounts owed by the member.']
  place_of_service_code varchar [note: 'Two‑digit code indicating where the service was provided.']
  procedure_code varchar [note: 'Standard procedure code representing the service rendered.']
  remark_code varchar [note: 'Additional informational code attached to the line.']
  revenue_code decimal(18,2) [note: 'Four‑digit code used for institutional billing to indicate type of service.']
  service_date date [note: 'Date on which the service was provided.']
  units_of_service decimal(10,2) [note: 'Quantity of the service rendered (e.g., number of visits, dosage units).']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the line record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Line-level detail for each service rendered within a claim. Captures line number, CPT/HCPCS procedure code, procedure modifier codes (up to 4), revenue code (institutional), service date, units of service, billed amount per line, allowed amount, paid amount, copay amount, coinsurance amount, deductible amount, COB paid amount, line status, denial reason code, remark codes, place of service code, rendering provider NPI at line level, NDC code (for drug lines), quantity qualifier, anesthesia minutes, emergency indicator, EPSDT indicator, family planning indicator, and prior authorization number. [FHIR-aligned]'
}

Table claim.diagnosis {
  diagnosis_id varchar [pk, note: 'Primary key for diagnosis']
  claim_header_id varchar [note: 'Identifier of the claim to which this diagnosis belongs.']
  risk_hcc_mapping_id varchar [note: 'Foreign key linking to risk.hcc_mapping. Business justification: Clinical quality and risk‑adjustment reports need each diagnosis linked to its HCC mapping for proper risk score calculations.']
  chronic_condition_flag boolean [note: 'True if the diagnosis represents a chronic condition relevant for care management.']
  code varchar [note: 'Official diagnosis code assigned to the claim line.']
  created_timestamp timestamp [note: 'Date‑time when the diagnosis line was initially loaded into the data lake.']
  description varchar [note: 'Full textual description of the diagnosis code.']
  diagnosis_date timestamp [note: 'Calendar date the diagnosis was documented on the claim.']
  diagnosis_status varchar [note: 'Operational status indicating if the diagnosis line is active, pending review, or logically deleted.']
  diagnosis_type varchar [note: 'Specifies the role of the diagnosis (e.g., principal, admitting, external cause, other).']
  drg_code varchar [note: 'DRG (Diagnosis Related Group) code assigned for inpatient claims.']
  drg_description varchar [note: 'Textual description of the DRG code.']
  hcc_category varchar [note: 'HCC category code used for risk‑adjustment and RAF calculations.']
  icd_version varchar [note: 'Indicates whether the diagnosis code follows ICD‑9‑CM or ICD‑10‑CM standards.']
  line_quantity varchar [note: 'Number of times the same diagnosis appears on the claim; typically 1.']
  poa_indicator varchar [note: 'Indicates if the condition was present at the time of admission (Y=Yes, N=No, U=Unknown).']
  qualifier varchar [note: 'Free‑text qualifier providing extra context (e.g., laterality, severity).']
  risk_adjustment_factor decimal(5,4) [note: 'Numeric factor used in risk‑adjustment calculations for the diagnosis.']
  sequence varchar [note: 'Ordinal position of the diagnosis on the claim (1‑n).']
  updated_timestamp timestamp [note: 'Date‑time of the latest modification to the diagnosis line.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Diagnosis code assignments at the claim level supporting ICD-10-CM coding. Captures claim ICN, diagnosis sequence number, ICD version (ICD-10/ICD-9), diagnosis code, diagnosis description, diagnosis type (principal, admitting, external cause, other), POA (Present on Admission) indicator, HCC category mapping, chronic condition flag, and diagnosis qualifier. Supports DRG grouping, risk adjustment (HCC/RAF), HEDIS measure attribution, and clinical analytics. [FHIR-aligned]'
}

Table claim.procedure {
  procedure_id varchar [pk, note: 'Primary key for procedure']
  benefit_id varchar [note: 'Foreign key linking to plan.benefit. Business justification: Claim procedures must be mapped to covered benefits for coverage determination and cost-sharing calculation. Used in prior authorization validation, coverage determination, and adjudication. A claims ']
  claim_header_id varchar [note: 'Identifier of the parent claim to which this procedure belongs.']
  facility_id varchar [note: 'Foreign key linking to provider.facility. Business justification: Facility-based procedures (OR, cath lab, ASC) require facility linkage for facility fee calculation, accreditation validation, and CMS quality reporting. Existing practice_location FK covers office-ba']
  fee_schedule_rate_id decimal(18,2) [note: 'Foreign key linking to contract.fee_schedule_rate. Business justification: Each claim procedure maps to a specific contracted fee schedule rate for pricing (procedure code + modifier + POS → rate). Procedure-level rate traceability is required for provider payment reconcilia']
  pa_request_id varchar [note: 'Foreign key linking to utilization.pa_request. Business justification: Surgical and procedural claims require PA validation at the procedure level. utilization.procedure carries prior_authorization_number and prior_authorization_status as denormalized fields; FK to pa_request ']
  procedure_practice_location_id varchar [note: 'Identifier of the facility where the procedure was performed (e.g., hospital NPI or internal location code).']
  procedure_surgeon_provider_provider_provider_practice_location_id varchar [note: 'Foreign key linking to provider.provider_provider. Business justification: Links surgeon NPI to provider entity for surgeon performance, outcome, and credentialing dashboards mandated by quality‑measure reporting.']
  rendering_provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Procedure table has surgeon_name as a denormalized field. A proper FK to provider.provider enables surgical outcome tracking, credentialing validation at time of procedure, and provider profiling. sur']
  specialty_id varchar [note: 'Foreign key linking to provider.specialty. Business justification: Procedure-level specialty linkage enables specialty-specific medical policy application, prior authorization requirement validation by specialty, and quality measure attribution for value-based care p']
  anesthesia_time_minutes varchar [note: 'Total minutes of anesthesia administered for the procedure.']
  billing_category varchar [note: 'Category used for billing and reimbursement rules.']
  charge_amount decimal(12,2) [note: 'Billed amount for the procedure before adjustments.']
  claim_adjustment_amount decimal(12,2) [note: 'Monetary amount of the adjustment applied to the procedure charge.']
  claim_adjustment_reason varchar [note: 'Reason code for any post‑adjudication adjustment applied to this procedure.']
  claim_line_number varchar [note: 'Line number of this procedure within the claim file.']
  claim_status varchar [note: 'Current processing status of the claim line containing this procedure.']
  code varchar [note: 'Standardized code representing the medical procedure performed.']
  code_system varchar [note: 'The coding system used for the procedure_code field.']
  currency_code varchar [note: 'Three‑letter ISO 4217 currency code for monetary amounts.']
  diagnosis_codes varchar [note: 'Pipe‑delimited list of primary diagnosis codes (ICD‑10‑CM) associated with the procedure. [ENUM-REF-CANDIDATE: multiple codes — promote to reference product]']
  documentation_indicator varchar [note: 'Indicates completeness of clinical documentation for the procedure.']
  drg_code varchar [note: 'DRG assignment for the inpatient case derived from the procedure and diagnoses.']
  drg_weight decimal(5,4) [note: 'Relative weight of the DRG used for reimbursement calculations.']
  is_emergency boolean [note: 'True if the procedure was performed under emergency conditions.']
  is_outpatient boolean [note: 'True if the procedure was performed in an outpatient setting.']
  is_primary_procedure boolean [note: 'True if this is the principal procedure for the claim.']
  laterality varchar [note: 'Anatomical side on which the procedure was performed.']
  modifier varchar [note: 'Additional qualifier or modifier associated with the procedure code (e.g., bilateral, emergency).']
  net_amount decimal(12,2) [note: 'Final reimbursable amount after adjustments, discounts, and contractual allowances.']
  notes varchar [note: 'Clinician‑entered free‑text comments about the procedure.']
  procedure_date date [note: 'Calendar date on which the procedure was performed.']
  procedure_status varchar [note: 'Current processing status of the procedure record.']
  procedure_timestamp timestamp [note: 'Exact date‑time when the procedure was performed, captured to the second.']
  quality_measure_flag boolean [note: 'True if the procedure contributes to a quality measure (e.g., HEDIS).']
  record_created_timestamp timestamp [note: 'Timestamp when the procedure record was first inserted into the data lake.']
  record_updated_timestamp timestamp [note: 'Timestamp of the most recent update to the procedure record.']
  revenue_code decimal(18,2) [note: 'Hospital revenue code associated with the procedure for institutional claims.']
  risk_adjustment_factor decimal(5,4) [note: 'Factor used for risk‑adjusted payment calculations.']
  sequence varchar [note: 'Ordinal position of the procedure within the claim (1‑based).']
  service_location_type varchar [note: 'Classification of the place where the procedure occurred.']
  units_of_service varchar [note: 'Number of units billed for the procedure (e.g., time‑based units).']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Procedure code assignments at the claim header level (distinct from line-level CPT). Captures principal procedure code (ICD-10-PCS for inpatient), procedure date, procedure sequence, surgeon NPI, procedure qualifier, and secondary procedure codes. Supports DRG assignment, surgical case management, and inpatient utilization analytics. Primarily applicable to 837I institutional claims. [FHIR-aligned]'
}

Table claim.adjudication {
  adjudication_id varchar [pk, note: 'System-generated unique identifier for the adjudication record.']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Adjudication applies cost-sharing rules (deductible, OOP, coinsurance) defined at the benefit_package level. Adjudicators must reference the applicable benefit_package to calculate member liability co']
  claim_header_id varchar [note: 'Unique identifier of the claim that this adjudication decision applies to.']
  claim_line_id varchar [note: 'Foreign key linking to claim.line. Business justification: Adjudication decisions are made at both the claim header level and the individual claim line level. Adding claim_line_id FK to adjudication allows each adjudication record to reference the specific li']
  medical_policy_id varchar [note: 'Foreign key linking to utilization.medical_policy. Business justification: Adjudication applies medical policies to determine coverage (experimental treatment, medical necessity, prior auth requirements). FK from adjudication to medical_policy records which policy version go']
  member_identity_id varchar [note: 'Unique identifier of the insured member associated with the claim.']
  network_config_id varchar [note: 'Foreign key linking to plan.network_config. Business justification: Adjudication applies network-specific cost-sharing (in/out-of-network rates). The adjudication.network_status plain attribute is a denormalization of network_config data. Network adequacy audits and i']
  pa_decision_id varchar [note: 'Foreign key linking to utilization.pa_decision. Business justification: Adjudication validates authorized quantity, dates, and service codes from the PA decision. Direct FK from adjudication to pa_decision is required for auto-adjudication PA match logic, a core named pro']
  pa_request_id varchar [note: 'Foreign key linking to utilization.pa_request. Business justification: Adjudication logic must validate PA status (required, approved, denied) against the PA request record. utilization.adjudication.prior_authorization_required and prior_authorization_status are plain fields; ']
  participation_status_id varchar [note: 'Foreign key linking to provider.participation_status. Business justification: Adjudication explicitly determines network_status. The adjudication engine must reference provider.participation_status to compute allowed amounts, apply tiered cost-sharing, and support COB processin']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Adjudication applies policy-specific deductible, OOP max, and benefit limits. The adjudication engine must reference the exact policy to correctly calculate member cost-sharing, apply accumulators, an']
  provider_network_participation_id varchar [note: 'Foreign key linking to provider.provider_network_participation. Business justification: Adjudication allowed amount calculation depends on the contracted reimbursement model and fee schedule in provider_network_participation. This FK enables auditable traceability from adjudication outco']
  reimbursement_policy_id varchar [note: 'Foreign key linking to contract.reimbursement_policy. Business justification: Adjudication applies reimbursement policies (NCCI edits, global surgery rules, modifier reductions) to determine payment. Regulatory audits and appeals processes require traceability from each adjudic']
  accumulator_deductible_impact decimal(12,2) [note: 'Impact on the member\'s deductible accumulator from this adjudication.']
  accumulator_oop_impact decimal(12,2) [note: 'Impact on the member\'s out‑of‑pocket accumulator.']
  adjudication_number varchar [note: 'External reference number assigned to the adjudication for audit and communication purposes.']
  adjudication_status varchar [note: 'Current status of the adjudication decision.']
  adjudication_timestamp timestamp [note: 'Date and time when the adjudication decision was generated.']
  admission_date date [note: 'Date the patient was admitted (for institutional claims).']
  allowed_amount decimal(12,2) [note: 'Maximum amount the plan permits for the service after contracts and fee schedules.']
  allowed_amount_method decimal(18,2) [note: 'Methodology used to calculate the allowed amount.']
  auto_adjudication_flag boolean [note: 'Indicates whether the claim was processed automatically without manual review.']
  claim_type varchar [note: 'Category of the claim based on service setting.']
  cob_adjusted_amount decimal(12,2) [note: 'Amount adjusted after coordination of benefits.']
  cob_processing_result varchar [note: 'Result of COB processing for the claim.']
  currency_code varchar [note: 'Three‑letter ISO currency code for monetary amounts.']
  deductible_amount decimal(12,2) [note: 'Portion of the member\'s deductible applied by this adjudication.']
  diagnosis_code varchar [note: 'Primary diagnosis code associated with the claim.']
  discharge_date decimal(18,2) [note: 'Date the patient was discharged (for institutional claims).']
  duplicate_claim_flag boolean [note: 'True if the claim is identified as a potential duplicate.']
  edit_bypass_reason varchar [note: 'Reason provided when an edit was bypassed.']
  edit_code varchar [note: 'Code of the clinical or administrative edit applied (e.g., NCCI, OCE).']
  edit_description varchar [note: 'Human‑readable description of the edit.']
  edit_outcome varchar [note: 'Result of the edit evaluation.']
  edit_override_authority varchar [note: 'Identifier of the person or system that overrode the edit.']
  edit_override_flag boolean [note: 'Indicates whether the edit result was manually overridden.']
  edit_timestamp timestamp [note: 'Date and time when the edit was evaluated.']
  medical_necessity_flag boolean [note: 'Indicates whether the service met medical necessity criteria.']
  oop_amount decimal(12,2) [note: 'Member out‑of‑pocket responsibility after this adjudication.']
  prior_authorization_required boolean [note: 'True if the service required prior authorization.']
  prior_authorization_status varchar [note: 'Outcome of the prior authorization request.']
  record_audit_created timestamp [note: 'Timestamp when the adjudication record was first created in the system.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the adjudication record.']
  service_date date [note: 'Date on which the service was rendered.']
  timeliness_flag boolean [note: 'Indicates whether the claim was filed within the required time window.']
  total_adjustment_amount decimal(12,2) [note: 'Sum of all adjustments (deductibles, coinsurance, contractual) applied.']
  total_charge_amount decimal(12,2) [note: 'Aggregate charge amount submitted on the claim before any adjustments.']
  total_net_amount decimal(12,2) [note: 'Final amount payable to the provider after all adjustments.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Authoritative record of the adjudication decision for each claim and claim line, capturing the full pre-payment processing lifecycle including all clinical and administrative edit results. Includes adjudication status (paid/denied/pended/suspended/voided), auto-adjudication flag, adjudicator ID, benefit plan applied, accumulator impacts (deductible/OOP), COB processing results, allowed amount calculation method (fee schedule/MAC/RBP/capitation), network status, medical necessity determination, and final disposition. Captures granular edit-level results (NCCI/OCE/LCD/NCD/plan-specific/timely filing/duplicate) with edit code, edit description, pass/fail/bypass/override outcomes per line, bypass reason, and override authority. Supports coding compliance, payment accuracy, and CMS edit mandate adherence. [FHIR-aligned]'
}

Table claim.eob {
  eob_id varchar [pk, note: 'Unique surrogate key for the EOB record.']
  adjudication_id varchar [note: 'Foreign key linking to claim.adjudication. Business justification: An EOB document is generated as a direct result of an adjudication decision. Linking eob.adjudication_id -> adjudication.adjudication_id establishes the authoritative traceability from the member-faci']
  claim_header_id varchar [note: 'Foreign key linking to claim.header. Business justification: EOB is generated for a specific claim; linking to claim header provides the parent relationship']
  member_identity_id varchar [note: 'Unique identifier of the covered member associated with the claim.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: EOB documents must display policy-specific benefit information, member cost-sharing, and plan details. Regulatory requirements mandate EOBs reference the governing policy. Member services and complian']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: EOB documents reference the rendering provider for member-facing explanation. provider_name and provider_npi are denormalized. A proper FK enables accurate provider directory data on EOBs and supports']
  sbc_document_id varchar [note: 'Foreign key linking to plan.sbc_document. Business justification: ACA (45 CFR 147.200) requires EOBs to reference the Summary of Benefits and Coverage document. The eob.sbc_reference plain attribute is a denormalization of sbc_document data. Regulatory compliance an']
  subscriber_id varchar [note: 'Identifier of the primary subscriber (often the employee or policyholder).']
  allowed_amount decimal(12,2) [note: 'Maximum amount the plan permits for the service.']
  appeal_rights_text varchar [note: 'Narrative describing the member\'s right to appeal the decision.']
  appeal_rights_version varchar [note: 'Version identifier for the appeal rights language used.']
  billed_amount decimal(12,2) [note: 'Total amount billed by the provider before any adjustments.']
  claim_icn varchar [note: 'Unique claim identifier used throughout the adjudication process.']
  cob_adjustment_amount decimal(12,2) [note: 'Amount adjusted due to coordination of benefits with other payers.']
  created_timestamp timestamp [note: 'Timestamp when the EOB record was first created in the data warehouse.']
  delivery_date date [note: 'Date the EOB was actually delivered to the recipient.']
  delivery_method varchar [note: 'Method used to deliver the EOB to the member or provider.']
  denial_reason_summary varchar [note: 'Brief text explaining why a claim or line was denied.']
  document_number varchar [note: 'External document identifier assigned to the EOB for tracking and reference.']
  eob_status varchar [note: 'Current lifecycle status of the EOB record.']
  eob_type varchar [note: 'Indicates whether the EOB is intended for the member or the provider.']
  fhir_claim varchar [note: 'FHIR ExplanationOfBenefit.claim mapping']
  fhir_item varchar [note: 'FHIR ExplanationOfBenefit.item mapping']
  fhir_outcome varchar [note: 'FHIR ExplanationOfBenefit.outcome mapping']
  fhir_patient varchar [note: 'FHIR ExplanationOfBenefit.patient mapping']
  fhir_status varchar [note: 'FHIR ExplanationOfBenefit.status mapping']
  generation_timestamp timestamp [note: 'Date and time when the EOB was generated by the claims engine.']
  language_code varchar [note: 'ISO 639‑2 language code indicating the language of the EOB content.']
  member_responsibility_amount decimal(12,2) [note: 'Portion of the claim the member must pay (deductible, copay, coinsurance, or non‑covered).']
  member_responsibility_type varchar [note: 'Category of the member\'s financial responsibility for the claim.']
  plan_paid_amount decimal(12,2) [note: 'Amount paid by the health plan to the provider.']
  remark_codes varchar [note: 'Standardized codes providing additional claim processing information.']
  service_end_date date [note: 'Last date of service covered by the claim.']
  service_start_date date [note: 'First date of service covered by the claim.']
  suppression_flag boolean [note: 'Indicates whether the EOB should be suppressed from member delivery (e.g., for zero‑payment claims).']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the EOB record.']
  version_number varchar [note: 'Sequential version number for revisions of the EOB.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Explanation of Benefits document record generated for members and providers following claim adjudication. Captures EOB document ID, EOB type (member/provider), generation date, delivery method (mail/portal/EDI 835), member ID, subscriber ID, claim ICN, service dates, provider name, billed amount, allowed amount, plan paid amount, member responsibility (deductible, copay, coinsurance, non-covered), COB adjustment, denial reason summary, remark codes, appeal rights language version, SBC reference, and EOB suppression flag. Supports member transparency and ACA SBC compliance. [FHIR-aligned]'
}

Table claim.adjustment {
  adjustment_id varchar [pk, note: 'Primary key for adjustment']
  adjudication_id varchar [note: 'Foreign key linking to claim.adjudication. Business justification: Post-adjudication adjustments (recoveries, corrections, audit findings) reference the original adjudication being corrected. Linking adjustment.adjudication_id -> adjudication.adjudication_id provides']
  billing_account_id varchar [note: 'Foreign key linking to billing.account. Business justification: ACA 60-day overpayment rule compliance and audit recovery: claim adjustments (overpayment recoveries, audit findings) must be tracked against the billing account for AR management and regulatory repor']
  case_id varchar [note: 'Foreign key linking to appeal.appeal_case. Business justification: Adjustment records are created after an appeal decision; linking to the appeal case provides audit trail and regulatory reporting of appeal‑driven adjustments.']
  claim_header_id varchar [note: 'Identifier of the original claim to which this adjustment applies.']
  denial_id varchar [note: 'Foreign key linking to claim.denial. Business justification: Adjustments are frequently triggered by denial overturns (e.g., appeal upheld, clinical criteria met on resubmission). Linking adjustment.denial_id -> denial.denial_id establishes the causal chain fro']
  line_id varchar [note: 'Foreign key linking to claim.line. Business justification: Adjustment may apply to a specific claim line; replace claim_line_number with a proper FK to claim.line']
  member_identity_id varchar [note: 'Unique identifier of the member associated with the claim adjustment.']
  pa_request_id varchar [note: 'Foreign key linking to utilization.pa_request. Business justification: Claim adjustments triggered by retroactive PA denial or PA status changes must reference the PA request. utilization.adjustment.prior_authorization_number is denormalized text; FK enables PA-driven adjustme']
  practice_location_id varchar [note: 'Unique identifier of the provider linked to the adjusted claim.']
  prior_authorization_id varchar [note: 'Foreign key linking to pharmacy.prior_authorization. Business justification: Pharmacy PA revisions and reversals trigger claim adjustments. The adjustment record\'s prior_authorization_number (plain text) should be a proper FK to the pharmacy PA for compliance 60-day rule track']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Overpayment recovery, RAC audit findings, and CMS compliance reporting require tracking adjustments to the specific provider entity. Provider-level financial reconciliation and demand letter generatio']
  radv_audit_id varchar [note: 'Foreign key linking to risk.radv_audit. Business justification: RADV audit findings by CMS directly trigger claim payment adjustments and overpayment recoveries. Compliance and finance teams require direct linkage between RADV audit records and resulting claim adj']
  adjusted_amount decimal(15,2) [note: 'Total amount after the adjustment is applied.']
  adjustment_date timestamp [note: 'Timestamp when the adjustment was recorded or became effective.']
  adjustment_status varchar [note: 'Current processing status of the adjustment.']
  adjustment_type varchar [note: 'Category of the adjustment indicating its nature.']
  audit_finding_reference varchar [note: 'Identifier of the audit finding or case that triggered the adjustment.']
  audit_source varchar [note: 'Origin of the audit finding (e.g., internal, RAC, OIG, provider self‑disclosure).']
  audit_type varchar [note: 'Type of audit that triggered the adjustment.']
  code varchar [note: 'Internal code categorizing the adjustment for reporting.']
  compliance_60_day_rule boolean [note: 'Indicates whether the adjustment complies with the CMS 60‑day overpayment recoupment rule.']
  created_timestamp timestamp [note: 'Timestamp when the adjustment record was first created in the system.']
  currency_code varchar [note: 'Three‑letter ISO currency code for monetary values.']
  demand_lifecycle_stage varchar [note: 'Stage of the demand/collection lifecycle for the adjustment.']
  description varchar [note: 'Narrative description of why and how the adjustment was made.']
  diagnosis_code varchar [note: 'ICD diagnosis code(s) associated with the claim adjustment, if relevant.']
  effective_date date [note: 'Date when the adjustment takes effect.']
  expiration_date date [note: 'Date when the adjustment ceases to be effective, if applicable.']
  identifier varchar [note: 'External or business-facing identifier for the adjustment (e.g., RAC audit number).']
  initiator_role varchar [note: 'Business role of the initiator.']
  is_duplicate boolean [note: 'Flag identifying the adjustment as a duplicate payment correction.']
  is_fraud boolean [note: 'Indicates whether the adjustment is related to suspected fraud.']
  is_reversal boolean [note: 'Indicates whether the adjustment reverses a prior adjustment.']
  is_void boolean [note: 'Indicates whether the adjustment voids the original claim payment.']
  net_adjustment_amount decimal(15,2) [note: 'Difference between original and adjusted amounts (positive for overpayment recovery, negative for additional payment).']
  notes varchar [note: 'Additional free‑form notes captured by the adjuster.']
  original_amount decimal(15,2) [note: 'Total amount originally paid on the claim before any adjustment.']
  overpayment_indicator decimal(18,2) [note: 'Flag indicating whether the adjustment relates to an overpayment.']
  overpayment_type decimal(18,2) [note: 'Specific category of overpayment being corrected.']
  procedure_code varchar [note: 'Procedure code(s) related to the adjusted claim line.']
  reason_code varchar [note: 'Standardized code describing the business reason for the adjustment.']
  recovery_method varchar [note: 'Method used to recover the overpayment.']
  recovery_status varchar [note: 'Current status of the recovery process.']
  regulatory_reporting_flag boolean [note: 'True when the adjustment must be reported to regulatory bodies (e.g., CMS RAC).']
  resolution_status varchar [note: 'Overall resolution state of the adjustment case.']
  sequence varchar [note: 'Sequential order of adjustments applied to the same claim.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the adjustment record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Single source of truth for all post-adjudication corrections, recoveries, and audit findings — including claim adjustments, voids, reprocessing events, overpayment identification and recovery, and post-payment audit results for payment integrity and FWA detection. Captures adjustment type (void/replacement/corrected/retroactive), overpayment type (duplicate payment/incorrect rate/ineligible member/billing error/fraud), audit type (post-payment/prepayment/clinical/coding/billing), audit source (internal/RAC/OIG/provider self-disclosure), financial impact (original vs adjusted amounts, net adjustment, overpayment amount, recovery amounts, demand lifecycle), initiator, CMS 60-day overpayment rule compliance, recovery method (offset/check/installment), recovery status, and resolution status. Supports payment integrity programs, CMS RAC audit compliance, and regulatory overpayment reporting. [FHIR-aligned]'
}

Table claim.denial {
  denial_id varchar [pk, note: 'System-generated unique identifier for the denial record.']
  adjudication_id varchar [note: 'Foreign key linking to claim.adjudication. Business justification: Denials are the outcome of adjudication decisions where a claim or line is not payable. Linking denial.adjudication_id -> adjudication.adjudication_id establishes the causal chain from adjudication to']
  benefit_id varchar [note: 'Foreign key linking to plan.benefit. Business justification: Denials are issued when a service is not covered under a specific benefit or benefit limits are exceeded. Denial management, appeals processing, and regulatory reporting (ERISA, ACA) require tracing w']
  claim_header_id varchar [note: 'Unique identifier of the claim associated with this denial.']
  line_id varchar [note: 'Foreign key linking to claim.line. Business justification: Denial may apply to a specific claim line; replace claim_line_number with a proper FK to claim.line']
  medical_policy_id varchar [note: 'Foreign key linking to utilization.medical_policy. Business justification: Denials citing medical necessity or experimental treatment must reference the specific medical policy version applied. Required for ACA-compliant adverse benefit determination notices, NCQA denial rep']
  pa_decision_id varchar [note: 'Foreign key linking to utilization.pa_decision. Business justification: Denials based on PA decision outcomes (denied, modified, expired authorization) must reference the specific pa_decision for member appeal rights letters and regulatory denial reporting. This link is r']
  pa_request_id varchar [note: 'Foreign key linking to utilization.pa_request. Business justification: Denials issued due to missing or failed PA (denial_type = PA-related) must reference the originating PA request for appeal processing and CMS/NCQA regulatory reporting. Direct FK enables PA-denial lin']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Denial notices must cite specific policy terms and exclusions per ACA and state regulatory requirements. Appeal rights letters reference policy coverage provisions. Compliance teams and member advocat']
  prior_authorization_id varchar [note: 'Foreign key linking to pharmacy.prior_authorization. Business justification: Pharmacy PA denials directly generate claim denial records. Linking denial to the pharmacy PA supports appeal workflow tracking, ACA grievance reporting, and CMS audit requirements. A health insurance']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Provider-level denial rate reporting, appeals tracking, and regulatory denial notification requirements (ACA timely notification, state mandates) require linking denials directly to the provider entit']
  reimbursement_policy_id varchar [note: 'Foreign key linking to contract.reimbursement_policy. Business justification: Denials are frequently triggered by reimbursement policy violations (NCCI bundling, global surgery periods, modifier rules). Linking denial to the governing reimbursement policy enables policy-level d']
  appeal_deadline_date date [note: 'Last date by which an appeal must be filed.']
  appeal_eligibility_flag boolean [note: 'Indicates whether the denial is eligible for an appeal.']
  carc_code varchar [note: 'Standardized code describing the reason for the claim adjustment/denial.']
  clinical_criteria varchar [note: 'Reference to the clinical guideline or utilization management criteria applied.']
  created_timestamp timestamp [note: 'Timestamp when the denial record was first created in the system.']
  currency_code varchar [note: 'Three‑letter ISO currency code for monetary values.']
  denial_date date [note: 'Date the denial decision was rendered.']
  denial_number varchar [note: 'External business identifier assigned to the denial, used in communications and reporting.']
  denial_status varchar [note: 'Current lifecycle status of the denial.']
  denial_type varchar [note: 'High‑level classification of the denial reason.']
  denied_adjustment_amount decimal(12,2) [note: 'Adjustments (e.g., contractual allowances, discounts) applied to the denied amount.']
  denied_gross_amount decimal(12,2) [note: 'Original amount of the claim that was denied before any adjustments.']
  denied_net_amount decimal(12,2) [note: 'Final net amount after adjustments that the member is responsible for due to the denial.']
  letter_generated_flag boolean [note: 'True if a formal denial letter was generated and sent to the member/provider.']
  medical_necessity_flag boolean [note: 'Indicates whether the claim failed medical necessity criteria (true = not medically necessary).']
  notes varchar [note: 'Free‑form notes captured by reviewers or staff during denial handling.']
  override_flag boolean [note: 'True if the denial was manually overridden by a reviewer.']
  override_reason varchar [note: 'Explanation for why the denial was overridden.']
  rac_code varchar [note: 'Standardized remark code that provides additional context for the denial.']
  reason_description varchar [note: 'Narrative explanation of why the claim or line was denied.']
  resolution_date date [note: 'Date the denial was resolved or closed.']
  resolution_status varchar [note: 'Current status of the denial resolution process.']
  subtype varchar [note: 'More granular category within the denial type, if applicable.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the denial record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Authoritative record of claim and claim line denials, capturing denial reason codes, clinical rationale, and resolution tracking. Includes denial ID, claim ICN, line number (if line-level denial), denial date, denial type (clinical, administrative, technical, COB, timely filing), CARC code, RARC code, denial reason description, clinical criteria applied (InterQual/MCG), medical necessity determination, denial letter generated flag, appeal eligibility flag, appeal deadline date, denial override flag, override reason, and resolution status. Supports appeals workflow, regulatory reporting, and denial management analytics. [FHIR-aligned]'
}

Table claim.cob {
  cob_id varchar [pk, note: 'Primary key for cob']
  adjudication_id varchar [note: 'Foreign key linking to claim.adjudication. Business justification: COB processing is an integral part of claim adjudication for multi-payer claims. The COB record captures the coordination outcome (primary payer paid amount, net liability) that feeds into the adjudic']
  claim_header_id varchar [note: 'Foreign key linking to claim.header. Business justification: COB processing is performed per claim; linking to claim header enables traceability']
  cob_record_id varchar [note: 'Foreign key linking to member.cob_record. Business justification: COB claim processing directly applies the rules established in the member\'s COB record (payer order, MSP compliance, coordination method). Claim COB adjudication must reference the member\'s active COB']
  medicaid_eligibility_id varchar [note: 'Foreign key linking to enrollment.medicaid_eligibility. Business justification: COB processing for Medicaid crossover claims (cob.medicaid_crossover_indicator, cob.msp_indicator) requires direct reference to the member\'s Medicaid eligibility record to validate coverage dates, dua']
  medicare_entitlement_id varchar [note: 'Foreign key linking to enrollment.medicare_entitlement. Business justification: COB processing for Medicare as Secondary Payer (cob.msp_type, cob.msp_indicator) requires direct reference to Medicare entitlement to validate Part A/B entitlement dates, IRMAA status, and dual eligib']
  adjustment_amount decimal(12,2) [note: 'Monetary amount of the adjustment applied to the net liability.']
  adjustment_reason varchar [note: 'Reason for any monetary adjustment applied during COB processing.']
  batch_number varchar [note: 'Identifier of the ETL batch that loaded this COB record.']
  claim_icn varchar [note: 'Unique identifier assigned to the underlying claim that this COB record relates to.']
  claim_line_count varchar [note: 'Number of line items on the underlying claim.']
  cob_status varchar [note: 'Current processing status of the COB record.']
  comments varchar [note: 'Free‑form notes entered by the processor.']
  created_timestamp timestamp [note: 'Timestamp when the COB record was first created in the system.']
  crossover_claim_flag boolean [note: 'Indicates whether the claim crosses over between primary and secondary payer responsibilities.']
  currency_code varchar [note: 'Three‑letter ISO 4217 code for monetary values (e.g., USD).']
  effective_date date [note: 'Date when the COB processing became effective.']
  expiration_date date [note: 'Date when the COB record expires or is no longer valid (nullable).']
  is_duplicate boolean [note: 'Flag indicating whether this COB record was generated for a duplicate claim.']
  is_manual_override boolean [note: 'True if a user manually overrode automated COB decisions.']
  medicaid_crossover_indicator boolean [note: 'Flag showing if Medicaid is involved in a crossover scenario.']
  method varchar [note: 'Method used for coordination of benefits: standard, non‑duplication, or maintenance of benefits.']
  msp_indicator boolean [note: 'Flag indicating whether Medicare is acting as the secondary payer for this claim.']
  msp_type varchar [note: 'Specifies the type of Medicare secondary payer relationship (full or partial).']
  net_liability_amount decimal(12,2) [note: 'Remaining liability amount after primary and secondary payments and adjustments.']
  primary_payer_allowed_amount decimal(12,2) [note: 'Maximum amount the primary payer allowed for the claim before COB.']
  primary_payer_denial_reason decimal(18,2) [note: 'Reason code or description why the primary payer denied all or part of the claim.']
  primary_payer_paid_amount decimal(12,2) [note: 'Amount actually paid by the primary payer after adjudication.']
  process_order varchar [note: 'Sequential order in which multiple payer COB steps are applied for the claim.']
  processed_timestamp timestamp [note: 'Date‑time when the COB processing was completed.']
  processing_user_name varchar [note: 'Display name of the user who performed the COB processing.']
  total_allowed_amount decimal(12,2) [note: 'Sum of allowed amounts for all claim lines as determined by the primary payer.']
  total_charge_amount decimal(12,2) [note: 'Aggregate charge amount from all claim lines before any adjustments.']
  total_paid_amount decimal(12,2) [note: 'Total amount paid by the primary payer before secondary adjudication.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the COB record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Coordination of Benefits processing record for claims involving multiple payers. Captures COB record ID, claim ICN, primary payer ID, primary payer name, primary payer paid amount, primary payer allowed amount, primary payer denial reason, secondary payer ID, COB processing order, COB method (standard/non-duplication/maintenance of benefits), other insurance type (employer group/Medicare/Medicaid/auto/workers comp), Medicare as secondary payer (MSP) indicator, MSP type, crossover claim flag, Medicaid crossover indicator, and net liability after COB. Supports accurate secondary adjudication and CMS MSP compliance. [FHIR-aligned]'
}

Table claim.payment {
  payment_id decimal(18,2) [pk, note: 'Primary key for payment']
  adjudication_id varchar [note: 'Foreign key linking to claim.adjudication. Business justification: Payment disbursements (835 ERA) are authorized by adjudication decisions. Linking payment.adjudication_id -> adjudication.adjudication_id enables direct traceability from the payment record to the adj']
  billing_account_id varchar [note: 'Foreign key linking to billing.account. Business justification: GL reconciliation and capitation/group billing: claim payments must be posted to a billing account for financial reporting and AR/AP tracking. In group and capitation arrangements, health plans track ']
  outcome_id varchar [note: 'Foreign key linking to appeal.appeal_outcome. Business justification: Payments may be adjusted based on appeal outcomes; linking to the appeal outcome enables accurate reconciliation and compliance reporting of appeal‑related payment changes.']
  payee_provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Provider payment reconciliation, 835 remittance generation, and 1099 tax reporting require linking payments to the provider entity. payee_type exists but no FK to provider. Role-prefixed payee_ to dis']
  primary_payment_claim_claim_header_id varchar [note: 'FK to claim.header']
  primary_payment_party_id varchar [note: 'Unique identifier of the entity receiving the payment (provider NPI or member ID).']
  adjustment_amount decimal(18,2) [note: 'Sum of all adjustments (CARC/RARC) applied to the gross amount.']
  batch_number varchar [note: 'Identifier of the batch in which this payment was processed.']
  batch_sequence varchar [note: 'Sequence order of the payment within its batch.']
  carc_codes varchar [note: 'Pipe‑separated list of CARC codes applied to the claim payment.']
  channel varchar [note: 'Delivery channel for the payment transaction.']
  check_number varchar [note: 'Check number when payment method is a paper check.']
  clearinghouse_code varchar [note: 'Identifier of the EDI clearinghouse that processed the 835 transaction.']
  clearinghouse_name varchar [note: 'Human‑readable name of the clearinghouse (e.g., Availity, Change Healthcare).']
  created_timestamp timestamp [note: 'Timestamp when the payment record was first created in the system.']
  currency_code varchar [note: 'Three‑letter ISO 4217 currency code for the payment.']
  cycle varchar [note: 'Frequency with which the payment is issued.']
  description decimal(18,2) [note: 'Free‑text description of the payment purpose.']
  gl_account_number varchar [note: 'General ledger account to which the payment is posted.']
  gl_posting_date date [note: 'Date the payment entry was posted to the general ledger.']
  gl_reference_number varchar [note: 'Reference identifier linking the payment to the GL transaction.']
  gross_amount decimal(18,2) [note: 'Total amount before any adjustments or taxes.']
  is_reconciled boolean [note: 'Indicates whether the payment has been fully reconciled.']
  is_returned boolean [note: 'True if the payment was returned by the bank or clearinghouse.']
  is_voided boolean [note: 'True if the payment was voided after issuance.']
  method decimal(18,2) [note: 'Instrument used to disburse the payment.']
  net_amount decimal(18,2) [note: 'Final amount paid to the payee after adjustments.']
  note varchar [note: 'Additional free‑form notes related to the payment.']
  payee_type varchar [note: 'Classification of the payee: provider, member, or other.']
  payment_date decimal(18,2) [note: 'Timestamp when the payment was issued to the payee.']
  payment_number decimal(18,2) [note: 'External payment reference number used in remittance advice and provider communications.']
  payment_status decimal(18,2) [note: 'Current lifecycle state of the payment.']
  payment_type decimal(18,2) [note: 'Category of the payment (e.g., claim settlement, capitation offset).']
  racr_codes varchar [note: 'Pipe‑separated list of RARC codes providing additional adjustment details.']
  reason_code varchar [note: 'Standard code indicating why the payment was made (e.g., claim settlement, rebate).']
  reconciliation_status varchar [note: 'Current status of the payment\'s financial reconciliation.']
  returned_reason varchar [note: 'Explanation for why the payment was returned.']
  source decimal(18,2) [note: 'Indicates whether the payment originated from internal systems or an external entity.']
  tax_amount decimal(18,2) [note: 'Tax withheld or applied to the payment, if applicable.']
  trace_number varchar [note: 'Bank‑provided trace number for tracking the payment.']
  transaction_control_number varchar [note: 'Unique control number for the 835 remittance advice transaction.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the payment record.']
  void_reason varchar [note: 'Explanation for why the payment was voided.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Single source of truth for all claim payment disbursements and electronic remittance advice (835 ERA) transmitted to providers and members. Captures payee information (NPI/TIN/member ID), payment amount, payment date, payment method (EFT/check/virtual card/capitation offset), check/EFT trace number, payment status lifecycle (issued/cleared/voided/returned/stopped), 835 transaction control number, clearinghouse ID (Availity, Change Healthcare), CARC/RARC adjustment codes at claim level, claim-level payment detail, reconciliation status, and GL posting reference. Consolidates provider remittance advice and claim payment into a single authoritative record for payment reconciliation, cash posting, and provider inquiry resolution. [FHIR-aligned]'
}

Table claim.drg {
  drg_id varchar [pk, note: 'Primary key for drg']
  adjudication_id varchar [note: 'Foreign key linking to claim.adjudication. Business justification: DRG assignment is used in the adjudication of inpatient institutional claims to determine payment amounts (base_rate_applied, payment_amount, outlier_payment_amount). Linking drg.adjudication_id -> ad']
  claim_header_id varchar [note: 'Identifier of the claim to which this DRG assignment belongs.']
  facility_id varchar [note: 'Foreign key linking to provider.facility. Business justification: DRG assignment and payment calculation are facility-specific (base rate, CCN, outlier threshold). Linking drg to provider.facility enables facility-specific DRG payment calculation and CMS cost report']
  fee_schedule_rate_id decimal(18,2) [note: 'Foreign key linking to contract.fee_schedule_rate. Business justification: DRG-based inpatient payments are calculated using contracted DRG base rates stored in fee_schedule_rate (which has drg_code and per_diem_rate columns). Linking DRG assignment to the applicable rate en']
  inpatient_admission_id varchar [note: 'Foreign key linking to utilization.inpatient_admission. Business justification: DRG assignment is fundamentally an inpatient concept — direct FK from utilization.drg to inpatient_admission enables DRG-based prospective payment validation against the admission record, LOS benchmark comp']
  principal_diagnosis_id varchar [note: 'Foreign key linking to claim.diagnosis. Business justification: DRG assignment is primarily driven by the principal diagnosis. The drg table currently stores principal_diagnosis_code as a denormalized string. Linking drg.principal_diagnosis_id -> diagnosis.diagnos']
  principal_procedure_id varchar [note: 'Foreign key linking to claim.procedure. Business justification: DRG assignment for surgical DRGs is driven by the principal procedure. The drg table currently stores principal_procedure_code as a denormalized string. Linking drg.principal_procedure_id -> procedure']
  arithmetic_mean_los decimal(5,2) [note: 'Arithmetic mean length of stay for the DRG across the reference population.']
  assignment_status varchar [note: 'Current processing status of the DRG assignment.']
  base_rate_applied decimal(12,2) [note: 'Base payment rate applied to the DRG before adjustments.']
  case_mix_index_contribution decimal(10,5) [note: 'Contribution of this DRG to the provider\'s overall case mix index.']
  cc_mcc_flag boolean [note: 'Indicates whether the claim has no CC/MCC, a CC, or an MCC.']
  code varchar [note: 'Three- or four‑digit Diagnosis Related Group code assigned to the claim.']
  created_timestamp timestamp [note: 'Timestamp when the DRG assignment record was first created.']
  description varchar [note: 'Human‑readable description of the DRG code.']
  drg_type varchar [note: 'Category of the DRG based on care setting.']
  effective_date date [note: 'Date on which the DRG assignment becomes effective.']
  expiration_date date [note: 'Date on which the DRG assignment expires, if applicable.']
  geometric_mean_los decimal(5,2) [note: 'Geometric mean of length of stay for the DRG across the reference population.']
  grouper_method varchar [note: 'Methodology used to generate the DRG (e.g., MS‑DRG, APR‑DRG).']
  grouper_run_timestamp timestamp [note: 'Date‑time when the DRG grouper was executed for this claim.']
  grouper_software_version varchar [note: 'Version identifier of the software that performed the DRG grouping.']
  grouper_status varchar [note: 'Processing status of the grouper run for this assignment.']
  line_quantity varchar [note: 'Number of DRG units represented by this line (typically 1).']
  line_sequence_number varchar [note: 'Sequence order of the DRG assignment within the claim (normally 1).']
  major_diagnostic_category varchar [note: 'Broad diagnostic category (MDC) associated with the DRG.']
  outlier_payment_amount decimal(12,2) [note: 'Additional payment made when the claim exceeds the outlier threshold.']
  outlier_threshold decimal(12,2) [note: 'Cost threshold above which an outlier payment is triggered.']
  payment_amount decimal(12,2) [note: 'Reimbursable amount calculated for the DRG before any claim‑level adjustments.']
  payment_currency decimal(18,2) [note: 'Three‑letter ISO currency code for the DRG payment amount.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the DRG assignment record.']
  version varchar [note: 'Version of the DRG grouper used (e.g., MS-DRG v38, APR-DRG v30).']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']
  weight decimal(10,5) [note: 'Relative weight used to calculate reimbursement for the DRG.']

  Note: 'Diagnosis Related Group (DRG) assignment record for inpatient institutional claims, capturing the DRG grouper output. Includes DRG assignment ID, claim ICN, DRG version (MS-DRG/APR-DRG/IR-DRG), DRG code, DRG description, MDC (Major Diagnostic Category), DRG weight, geometric mean LOS, arithmetic mean LOS, base rate applied, outlier threshold, outlier payment amount, case mix index contribution, grouper software version, grouper run date, principal diagnosis used, principal procedure used, and complication/comorbidity (CC/MCC) flag. Supports inpatient reimbursement, case mix management, and utilization benchmarking. [FHIR-aligned]'
}

Table claim.accumulator {
  accumulator_id varchar [pk, note: 'Primary key for accumulator']
  adjudication_id varchar [note: 'Foreign key linking to claim.adjudication. Business justification: Member benefit accumulators (deductible, MOOP) are updated as a direct result of adjudication processing. The adjudication table explicitly carries accumulator_deductible_impact and accumulator_oop_im']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Accumulators (deductible, OOP max) are validated against limits defined in benefit_package. Different packages have different thresholds. Accumulator management and member cost-sharing tracking requir']
  eligibility_span_id varchar [note: 'Foreign key linking to enrollment.enrollment_eligibility_span. Business justification: Accumulators (deductible, OOP, MOOP) are governed by benefit period limits and reset dates defined on the eligibility span. Accumulator validation and benefit period reset processing requires direct r']
  health_plan_id varchar [note: 'Identifier of the health insurance plan governing the benefit limits.']
  member_identity_id varchar [note: 'Unique identifier of the member to whom the accumulator applies.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Accumulators (deductible, OOP max) are tracked per policy and reset per policy period. ACA and state regulations require per-policy accumulator tracking. Linking accumulator to policy enables correct ']
  accumulated_amount decimal(15,2) [note: 'Total amount that has been applied to the accumulator to date.']
  accumulator_status varchar [note: 'Current lifecycle status of the accumulator record.']
  accumulator_type varchar [note: 'Type of benefit being tracked (e.g., deductible, out‑of‑pocket maximum).']
  adjustment_reason varchar [note: 'Free‑text or coded reason describing why an adjustment was applied.']
  benefit_category varchar [note: 'High‑level category of the benefit tracked by the accumulator.']
  benefit_period_end date [note: 'Last day of the benefit period for which the accumulator is calculated.']
  benefit_period_start date [note: 'First day of the benefit period for which the accumulator is calculated.']
  code varchar [note: 'Business identifier code for the accumulator, used in reporting and member communications.']
  created_timestamp timestamp [note: 'Timestamp when the accumulator record was first created.']
  currency_code varchar [note: 'Three‑letter ISO currency code for monetary values.']
  description varchar [note: 'Optional free‑form description or notes about the accumulator record.']
  event_timestamp timestamp [note: 'Timestamp of the most recent claim event that modified the accumulator.']
  is_adjustment boolean [note: 'Indicates whether the latest change to the accumulator was an adjustment (e.g., post‑payment correction).']
  is_reversal boolean [note: 'True if the most recent transaction reversed a prior accumulator entry.']
  last_reset_timestamp timestamp [note: 'Timestamp of the most recent reset of the accumulator (e.g., annual renewal).']
  limit_amount decimal(15,2) [note: 'Maximum monetary amount allowed for the accumulator in the benefit period.']
  line_of_business varchar [note: 'Business segment classification for the member\'s coverage.']
  network_tier varchar [note: 'Network tier defining provider cost-sharing rules for the accumulator.']
  remaining_balance decimal(15,2) [note: 'Amount remaining before the member reaches the benefit limit.']
  reversal_reason varchar [note: 'Reason code or description for a reversal operation.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the accumulator record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Member-level benefit accumulator ledger tracking deductibles, out-of-pocket maximums (MOOP), visit limits, and other benefit thresholds applied during claims adjudication. Captures current balances (accumulated amount, remaining balance, benefit limit) by member, benefit period, accumulator type, LOB, plan, and network tier, plus the full transaction-level audit trail of credits, debits, reversals, and resets applied by each claim event. Supports real-time adjudication decisions, ACA MOOP compliance, and member cost-sharing transparency. [FHIR-aligned]'
}

Table pharmacy.drug_master {
  drug_master_id varchar [pk, note: 'Unique surrogate identifier for each drug master record in the lakehouse Silver layer. Serves as the primary key for all downstream joins across formulary, claims, DUR, rebate contracting, and PBM adjudication.']
  hcc_mapping_id varchar [note: 'Foreign key linking to risk.hcc_mapping. Business justification: drug_master.hcc_relevant flag signals HCC-associated drugs used in CMS risk adjustment reporting. Formalizing this as a FK to hcc_mapping enables risk-adjustment drug utilization analytics and support']
  atc_code varchar [note: 'The WHO Anatomical Therapeutic Chemical (ATC) classification code at the 5th level, identifying the drug\'s anatomical main group, therapeutic subgroup, pharmacological subgroup, chemical subgroup, and chemical substance. Used for therapeutic class reporting, HEDIS pharmacy measures, population health analytics, and international drug classification alignment.']
  awp_effective_date date [note: 'The date on which the current AWP unit price became effective. Used to apply the correct AWP for historical claims repricing, audit reconciliation, and retroactive rebate calculations.']
  awp_unit_price decimal(18,6) [note: 'The Average Wholesale Price (AWP) per unit of the drug as published by First Databank or Medi-Span. AWP is the benchmark pricing reference used in pharmacy reimbursement calculations, MAC pricing comparisons, and rebate contract negotiations. Expressed in USD per unit (tablet, mL, gram, etc.).']
  brand_name varchar [note: 'The proprietary trade name under which the drug is marketed by the manufacturer (e.g., Lipitor, Humira). Used in formulary tier assignment, rebate contracting, member communications, and brand vs. generic substitution logic in PBM adjudication.']
  controlled_substance_schedule varchar [note: 'The DEA controlled substance schedule classification (I through V) indicating the drug\'s potential for abuse and accepted medical use. Schedule II-V drugs require enhanced DUR edits, quantity limits, early refill restrictions, and special handling in PBM adjudication. Not_scheduled indicates no DEA restriction.']
  created_timestamp timestamp [note: 'The timestamp when this drug master record was first created in the lakehouse Silver layer. Used for data lineage, audit compliance, and change data capture tracking per HIPAA Security Rule requirements.']
  dea_number_required boolean [note: 'Indicates whether a valid DEA registration number is required on the prescription for this drug due to its controlled substance classification. Drives prescription validation edits in PBM adjudication and pharmacy dispensing workflows.']
  dosage_form varchar [note: 'The physical form in which the drug is dispensed (e.g., tablet, capsule, solution, injection, patch, inhaler). Critical for formulary configuration, quantity limit rules, step therapy protocols, and DUR screening in RxClaim/Argus. [ENUM-REF-CANDIDATE: tablet|capsule|solution|injection|patch|inhaler|cream|ointment|suspension|powder — promote to reference product]']
  drug_class_code varchar [note: 'The classification code for the drug class within the GPI or ETC hierarchy, representing a more granular grouping below therapeutic subclass (e.g., specific statin subtype). Used in formulary step therapy rules, DUR clinical edits, and rebate tier segmentation in PBM systems.']
  drug_class_name varchar [note: 'The human-readable name of the drug class corresponding to the drug_class_code. Provides the most granular named classification level in the therapeutic hierarchy for formulary configuration and clinical reporting.']
  drug_name varchar [note: 'The full proprietary or established name of the drug as it appears on the FDA-approved label and in the First Databank or Medi-Span drug database feed. Used as the primary human-readable identity label across formulary displays, EOB communications, and member-facing materials.']
  drug_status varchar [note: 'Current lifecycle status of the drug record in the master file. Active drugs are eligible for formulary placement and PBM adjudication. Discontinued or recalled drugs trigger claim edits and member/provider notifications. Drives formulary maintenance workflows in RxClaim/Argus.']
  drug_type varchar [note: 'Classification of the drug as brand-name, generic, biosimilar, over-the-counter (OTC), compounded, or repackaged. Drives formulary tier assignment, cost-sharing rules, generic substitution logic, and rebate eligibility in PBM adjudication and formulary management.']
  effective_date date [note: 'The date on which this drug master record became effective and eligible for use in formulary configuration, PBM adjudication, and claims processing. Used for temporal validity enforcement in adjudication date-of-service lookups and formulary effective date management.']
  fda_approval_status varchar [note: 'The current FDA regulatory approval status of the drug product. Approved drugs are eligible for formulary coverage. Tentatively approved generics may be covered under specific plan designs. Withdrawn or not-approved drugs are excluded from formulary and trigger claim denials. Required for CMS Part D formulary compliance.']
  generic_name varchar [note: 'The International Nonproprietary Name (INN) or United States Adopted Name (USAN) for the active ingredient(s) of the drug (e.g., atorvastatin, adalimumab). Used for generic substitution logic, DUR screening, therapeutic equivalence grouping, and HEDIS pharmacy measure reporting.']
  gpi_code varchar [note: 'The 14-digit Medi-Span Generic Product Identifier (GPI) code providing a hierarchical drug classification from drug group (2 digits) through drug class, subclass, name, name extension, dosage form, and strength. Used as the primary therapeutic classification key in RxClaim/Argus PBM systems for formulary management, DUR screening, and rebate contracting.']
  hcc_relevant boolean [note: 'Indicates whether this drug is clinically associated with one or more CMS Hierarchical Condition Categories (HCCs) for risk adjustment purposes. HCC-relevant drugs are used in RAF score modeling, RAPS/EDPS encounter data submissions, and population health stratification for Medicare Advantage plans.']
  is_biosimilar boolean [note: 'Indicates whether this drug is an FDA-approved biosimilar to a reference biological product. Biosimilars have distinct formulary placement rules, interchangeability designations, and rebate contracting considerations under CMS Part D and commercial plan designs.']
  is_generic_available boolean [note: 'Indicates whether an FDA-approved generic equivalent is available in the market for this brand-name drug. Used in formulary tier assignment, member cost-sharing communications, and generic substitution prompts during PBM adjudication and pharmacy dispensing.']
  is_maintenance_drug boolean [note: 'Indicates whether this drug is classified as a maintenance medication intended for long-term chronic condition management (e.g., antihypertensives, statins, diabetes medications). Maintenance drugs are eligible for 90-day supply dispensing at mail-order pharmacies and are used in HEDIS medication adherence measures (PDC).']
  is_preventive_drug boolean [note: 'Indicates whether this drug qualifies as a preventive medication under ACA Section 2713 or HDHP/HSA preventive care rules, making it eligible for $0 cost-sharing before the deductible is met. Used in benefit configuration and claims adjudication cost-sharing logic.']
  is_specialty_drug boolean [note: 'Indicates whether this drug is classified as a specialty pharmaceutical requiring special handling, storage, administration, or monitoring (e.g., biologics, oncology agents, hepatitis C treatments). Specialty drugs are subject to mandatory specialty pharmacy channel requirements, prior authorization, and enhanced DUR in PBM adjudication. Critical for CMS Part D specialty tier placement.']
  labeler_code varchar [note: 'The 5-digit FDA-assigned labeler code (first segment of the NDC) identifying the firm that manufactures, repackages, relabels, or distributes the drug. Used for manufacturer-level rebate aggregation and PBM contract management.']
  multi_source_code varchar [note: 'The FDA Orange Book multi-source code indicating the competitive market status of the drug: O=originator brand with no generic, M=multi-source (generic available), N=no current market (discontinued), Y=single-source generic. Used in generic substitution logic, formulary tier assignment, and MAC pricing eligibility determination.']
  ndc varchar [note: 'The 11-digit National Drug Code assigned by the FDA uniquely identifying the labeler, product, and package size of a drug. This is the primary external business identifier for the drug and is used in pharmacy claims (NCPDP/837P), formulary management, PBM adjudication (RxClaim/Argus), and CMS Part D reporting. Stored in 5-4-2 format without hyphens.']
  ndc_11 varchar [note: 'The NDC formatted in the standard 5-4-2 hyphenated display format (e.g., 12345-6789-01) as required for human-readable labeling, SBC documentation, and regulatory submissions to CMS and state DOIs.']
  package_size decimal(18,4) [note: 'The quantity of drug units contained in the dispensed package as defined by the NDC (e.g., 30 tablets, 100 mL, 1 vial). Used in unit-of-use pricing calculations, days supply verification, quantity limit enforcement, and MAC pricing per-unit derivation.']
  package_size_unit varchar [note: 'The unit of measure for the package size quantity (e.g., EA for each/tablet/capsule, ML for milliliter, GM for gram). Used in conjunction with package_size for accurate dispensing quantity calculations, days supply verification, and unit-cost pricing in PBM adjudication. [ENUM-REF-CANDIDATE: EA|ML|GM|MG|TAB|CAP|VIAL|PATCH|KIT — 9 candidates stripped; promote to reference product]']
  pharmacological_category varchar [note: 'The pharmacological mechanism-of-action category of the drug (e.g., ACE Inhibitor, Beta Blocker, SSRI, Statin, Monoclonal Antibody). Used for DUR drug-drug interaction screening, therapeutic duplication edits, clinical program targeting in care management, and HEDIS measure attribution.']
  reference_drug_ndc varchar [note: 'The NDC of the FDA Reference Listed Drug (RLD) or reference biological product to which this generic or biosimilar is therapeutically equivalent. Enables generic substitution relationship mapping, step therapy configuration, and biosimilar interchangeability tracking in the PBM system.']
  rems_program varchar [note: 'The name of the FDA-mandated Risk Evaluation and Mitigation Strategy (REMS) program associated with this drug, if applicable (e.g., iPLEDGE for isotretinoin, TIRF REMS for fentanyl products). REMS drugs require special dispensing controls, patient enrollment, and prescriber certification that must be validated during PBM adjudication and prior authorization.']
  route_of_administration double [note: 'The path by which the drug is administered to the patient (e.g., oral, intravenous, subcutaneous, topical, inhalation). Drives formulary benefit category assignment (medical vs. pharmacy benefit), prior authorization requirements, and specialty pharmacy routing in PBM adjudication. [ENUM-REF-CANDIDATE: oral|intravenous|subcutaneous|intramuscular|topical|inhalation|transdermal|ophthalmic|otic|rectal — promote to reference product]']
  source_record_code varchar [note: 'The native record identifier from the originating source system (First Databank, Medi-Span, RxClaim, or Argus) for this drug master record. Used for data lineage, cross-system reconciliation, and upstream change tracking in the lakehouse ingestion pipeline.']
  source_system_code varchar [note: 'Identifies the operational source system from which this drug master record was ingested (e.g., FDB=First Databank, MEDISPAN=Medi-Span, RXCLAIM=RxClaim PBM, ARGUS=Argus PBM, INTERNAL=internally maintained). Used for data lineage tracking, conflict resolution during ETL, and audit compliance in the Databricks Silver layer.']
  strength varchar [note: 'The concentration or potency of the active ingredient(s) expressed as a numeric value with unit of measure (e.g., 10 mg, 500 mg/5 mL, 0.25%). Used in DUR duplicate therapy screening, quantity limit enforcement, and clinical appropriateness review in UM/PA workflows.']
  termination_date date [note: 'The date on which this drug master record was terminated or superseded, indicating the drug is no longer active for formulary placement or new claim adjudication. Null indicates the record is currently active. Used for historical claims repricing and formulary audit trails.']
  therapeutic_class_code varchar [note: 'The standardized code identifying the broad therapeutic class of the drug (e.g., cardiovascular agents, anti-infectives, antineoplastics). Used for formulary tier grouping, rebate contract aggregation, utilization reporting, and disease management program enrollment triggers.']
  therapeutic_class_name varchar [note: 'The human-readable name of the therapeutic class corresponding to the therapeutic_class_code. Used in formulary displays, member-facing SBC documents, provider communications, and regulatory reporting to CMS and state DOIs.']
  therapeutic_equivalence_code varchar [note: 'The FDA Orange Book therapeutic equivalence evaluation code (e.g., AB, AA, BC) indicating whether a generic drug is therapeutically equivalent to the reference listed drug. AB-rated generics are substitutable at the pharmacy. Used in generic substitution logic, formulary step therapy, and DAW (Dispense As Written) override processing in PBM adjudication.']
  therapeutic_subclass_code varchar [note: 'The standardized code identifying the therapeutic subclass within the broader therapeutic class (e.g., HMG-CoA Reductase Inhibitors within cardiovascular agents). Enables granular formulary tier differentiation, step therapy protocol design, and rebate contract segmentation.']
  therapeutic_subclass_name varchar [note: 'The human-readable name of the therapeutic subclass corresponding to the therapeutic_subclass_code. Used in formulary management workflows, clinical program configuration, and detailed utilization analytics.']
  updated_timestamp timestamp [note: 'The timestamp when this drug master record was last modified in the lakehouse Silver layer. Used for incremental data refresh, change detection, and audit trail maintenance in the Databricks lakehouse pipeline.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']
  wac_unit_price decimal(18,6) [note: 'The Wholesale Acquisition Cost (WAC) per unit as reported by the manufacturer, representing the list price to wholesalers before discounts and rebates. Used as a pricing benchmark for specialty drug reimbursement, rebate baseline calculations, and CMS Part D coverage gap discount program calculations.']

  Note: 'Authoritative NDC-level drug master record for all covered pharmaceutical products. Captures National Drug Code (NDC), drug name, generic name, brand name, manufacturer, dosage form, strength, route of administration, drug class, controlled substance schedule, FDA approval status, and therapeutic equivalence codes (AB-rated/biosimilar). Includes generic substitution relationships and the full therapeutic classification hierarchy: ATC (Anatomical Therapeutic Chemical) code, GPI (Generic Product Identifier) prefix, pharmacological category, therapeutic class, therapeutic subclass, class name, and subclass name. This is the SSOT for all drug identity, classification, equivalence, and therapeutic hierarchy data used across formulary, claims, DUR, rebate contracting, HEDIS pharmacy measures, and PBM adjudication. Sourced from First Databank/Medi-Span drug database feeds. [FHIR-aligned]'
}

Table pharmacy.formulary {
  formulary_id varchar [pk, note: 'Unique surrogate identifier for the formulary record. Primary key for the formulary data product in the pharmacy domain.']
  prior_version_formulary_id varchar [note: 'Reference to the immediately preceding version of this formulary. Enables formulary change tracking, member notification workflows, and historical adjudication lookups for appeals and grievances.']
  category varchar [note: 'Business classification of the formulary indicating its benefit richness level relative to other formularies offered by the plan. Used in benefit design analytics, member communications, and plan comparison tools.']
  change_notification_date date [note: 'Date on which member notification was sent for formulary changes. CMS Part D requires 60-day advance notice for non-preferred formulary changes and immediate notification for safety-related removals.']
  cms_formulary_code varchar [note: 'The CMS-assigned formulary identifier used in Part D formulary file submissions to CMS. Required for Medicare Part D plans to identify the formulary in RAPS and EDPS submissions.']
  code varchar [note: 'Externally-known alphanumeric code uniquely identifying the formulary across systems, used in EDI transactions, PBM interfaces, and CMS Part D submissions. Corresponds to the formulary ID field in RxClaim/Argus PBM system.']
  created_timestamp timestamp [note: 'Timestamp when this formulary record was first created in the system. Used for audit trail, data lineage, and compliance documentation purposes.']
  description varchar [note: 'Free-text business description of the formulary, including its intended population, key design features, and any notable coverage inclusions or exclusions. Used in internal documentation and plan benefit configuration.']
  drug_count varchar [note: 'Total number of unique drug entries (NDC or drug-tier combinations) included in this formulary at the time of the last update. Used for formulary adequacy assessments and CMS Part D formulary file validation.']
  drug_utilization_review_ind boolean [note: 'Indicates whether Drug Utilization Review (DUR) edits are applied during adjudication under this formulary. DUR programs screen for drug interactions, duplicate therapy, and inappropriate dosing per OBRA \'90 requirements.']
  effective_date date [note: 'The date on which this formulary becomes active and applicable to member benefit adjudication. Used by PBM systems (RxClaim/Argus) to determine which formulary version applies at point of dispensing.']
  formulary_status varchar [note: 'Current lifecycle status of the formulary record. Active formularies are used in live adjudication; pending formularies are approved but not yet effective; retired formularies are historical records no longer in use.']
  formulary_type varchar [note: 'Classification of the formulary structure indicating coverage breadth and tier design. Open formularies cover most drugs; closed formularies restrict to listed drugs only; tiered formularies apply differential cost-sharing by tier.']
  generic_substitution_policy varchar [note: 'Policy governing generic drug substitution at point of dispensing. Mandatory substitution requires dispensing of generic equivalents; permissive allows brand if requested; DAW (Dispense As Written) honored respects prescriber instructions.']
  is_aca_compliant boolean [note: 'Indicates whether this formulary meets ACA Qualified Health Plan (QHP) essential health benefit (EHB) drug coverage requirements, including the required drug categories and classes under 45 CFR Part 156.']
  is_cms_part_d boolean [note: 'Indicates whether this formulary is subject to CMS Medicare Part D regulatory requirements, including annual bid submission, formulary file submission to CMS, and coverage determination obligations.']
  last_review_date date [note: 'Date on which the Pharmacy and Therapeutics (P&T) Committee last reviewed and approved this formulary. P&T Committee review is required for CMS Part D compliance and NCQA accreditation.']
  lob_code varchar [note: 'Line of Business (LOB) associated with this formulary, indicating the regulatory and market segment under which the formulary operates. Drives CMS Part D, Medicaid, or commercial compliance requirements.']
  low_income_subsidy_ind decimal(18,2) [note: 'Indicates whether this formulary is designated for use by Low Income Subsidy (LIS) eligible members under Medicare Part D. LIS formularies must meet CMS benchmark plan requirements for cost-sharing and drug coverage.']
  mail_order_ind boolean [note: 'Indicates whether this formulary supports mail-order pharmacy dispensing. Mail-order programs typically offer 90-day supplies at reduced cost-sharing and are a key component of pharmacy benefit design.']
  name varchar [note: 'Human-readable business name of the formulary (e.g., \'Standard Commercial Formulary 2025\', \'Medicare Part D Enhanced Formulary\'). Used in member-facing materials, SBC documents, and plan benefit configurations.']
  next_review_date date [note: 'Scheduled date for the next Pharmacy and Therapeutics (P&T) Committee review of this formulary. Supports compliance tracking for CMS Part D requirements mandating regular formulary review cycles.']
  pbm_formulary_code varchar [note: 'The formulary identifier as assigned by the PBM system (RxClaim or Argus). Used for cross-system reconciliation between the health plan\'s internal formulary record and the PBM\'s formulary configuration.']
  plan_year varchar [note: 'The benefit plan year (e.g., 2025) for which this formulary is effective. Used for annual formulary change management, CMS Part D annual bid submissions, and benefit year reporting.']
  prior_auth_ind boolean [note: 'Indicates whether this formulary requires prior authorization (PA) for any covered drugs. PA requirements are subject to CMS Part D coverage determination timelines and member appeal rights.']
  pt_committee_approval_date date [note: 'Date on which the Pharmacy and Therapeutics (P&T) Committee formally approved this formulary or the most recent formulary update. Required documentation for CMS Part D compliance and NCQA accreditation audits.']
  quantity_limit_ind boolean [note: 'Indicates whether this formulary applies quantity limits (QL) on covered drugs, restricting the amount dispensed per fill or per defined time period. Quantity limits are a utilization management tool subject to CMS Part D exception requirements.']
  regulatory_approval_date date [note: 'The date on which CMS or the applicable State Department of Insurance approved this formulary for use. Required for Part D compliance documentation and audit trails.']
  regulatory_filing_date date [note: 'The date on which the formulary was submitted to CMS or the applicable State Department of Insurance for regulatory review and approval.']
  regulatory_filing_status varchar [note: 'Status of the formulary\'s regulatory filing with CMS or applicable State Department of Insurance (DOI). Tracks whether the formulary has been submitted, approved, or rejected for compliance with Part D or state market requirements.']
  source_system_code varchar [note: 'Identifies the operational source system from which this formulary record originated (e.g., RxClaim, Argus PBM system, Facets). Used for data lineage tracking and cross-system reconciliation in the Databricks Silver layer.']
  specialty_pharmacy_ind boolean [note: 'Indicates whether this formulary designates a specialty pharmacy network for dispensing high-cost specialty drugs. Specialty pharmacy programs may include limited distribution networks and enhanced clinical support services.']
  specialty_tier_ind boolean [note: 'Indicates whether this formulary includes a specialty drug tier for high-cost specialty medications. Specialty tiers typically apply to drugs with monthly costs exceeding CMS specialty tier threshold (currently $670/month for Part D).']
  step_therapy_ind boolean [note: 'Indicates whether this formulary employs step therapy (also known as fail-first) protocols requiring members to try lower-cost or preferred drugs before coverage of higher-cost alternatives is authorized.']
  termination_date date [note: 'The date on which this formulary is no longer active. Null indicates an open-ended formulary with no defined end date. Used for formulary version management and historical adjudication lookups.']
  tier_count varchar [note: 'The total number of cost-sharing tiers defined in this formulary (e.g., 3-tier, 4-tier, 5-tier, 6-tier). Determines the tier structure used in drug tier assignments and member cost-sharing calculations.']
  updated_timestamp timestamp [note: 'Timestamp when this formulary record was last modified. Used for change tracking, incremental data loads in the Databricks Silver layer, and audit trail requirements.']
  url varchar [note: 'Public-facing URL where members can access the formulary drug list. CMS Part D and ACA QHP regulations require health plans to publish formularies online and provide the URL in plan materials and SBC documents.']
  version varchar [note: 'Version number of the formulary, incremented with each approved update or mid-year formulary change. Used to track formulary change history and ensure members receive required 60-day advance notice of non-preferred changes.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Master record for each formulary (drug benefit list) offered by the health plan. Defines the formulary name, effective date range, line of business (LOB), plan year, formulary type (open/closed/tiered), PBM contract reference, and regulatory filing status. A formulary is the SSOT for which drugs are covered under a given benefit design and is required for CMS Part D compliance. [FHIR-aligned]'
}

Table pharmacy.formulary_drug_tier {
  formulary_drug_tier_id varchar [pk, note: 'Unique surrogate identifier for each formulary drug tier assignment record. Primary key for this association entity linking a drug (NDC) to a formulary with its tier, cost-sharing, and utilization management (UM) controls.']
  clinical_criteria_id varchar [note: 'Foreign key linking to utilization.clinical_criteria. Business justification: Formulary management process: each drug tier\'s PA, step therapy, and quantity limit requirements are governed by specific clinical criteria versions. Formulary teams must link tier-level coverage rule']
  drug_master_id varchar [note: 'Reference to the internal drug master record corresponding to this NDC, enabling joins to the drug master for drug name, therapeutic class, and other drug attributes.']
  formulary_id varchar [note: 'Reference to the formulary to which this drug tier assignment belongs. A formulary is the approved list of covered drugs for a given plan and benefit year.']
  health_plan_id varchar [note: 'Reference to the health plan or benefit plan under which this formulary drug tier assignment applies. Links the tier assignment to the specific plan for cost-sharing and benefit configuration.']
  benefit_year varchar [note: 'The plan benefit year (e.g., 2024, 2025) to which this formulary drug tier assignment applies. CMS Part D formulary files are submitted annually by benefit year.']
  coinsurance_rate decimal(5,4) [note: 'Member coinsurance percentage applied to the drug cost under this formulary tier assignment, expressed as a decimal (e.g., 0.20 = 20%). Used when cost-sharing is percentage-based rather than fixed copay. Applies to specialty and high-cost tiers.']
  copay_mail_order decimal(10,2) [note: 'Fixed member copay amount for a 90-day supply dispensed through a mail-order pharmacy under this formulary tier assignment. Mail-order copays are typically lower than retail to incentivize mail-order utilization.']
  copay_retail_30 decimal(10,2) [note: 'Fixed member copay amount for a 30-day supply dispensed at a retail pharmacy under this formulary tier assignment. Drives member cost-sharing at point of sale. Used in SBC and EOB generation.']
  copay_retail_90 decimal(10,2) [note: 'Fixed member copay amount for a 90-day supply dispensed at a retail pharmacy under this formulary tier assignment. Applicable for maintenance medications at extended-supply retail pharmacies.']
  coverage_status varchar [note: 'Indicates whether the drug is covered under this formulary assignment. \'covered\' = fully covered per tier rules; \'covered_with_restrictions\' = covered subject to UM controls (PA, ST, QL); \'not_covered\' = not on formulary; \'excluded\' = explicitly excluded per CMS or plan rules.']
  created_timestamp timestamp [note: 'Timestamp when this formulary drug tier assignment record was first created in the system. Supports audit trail, data lineage, and regulatory compliance documentation.']
  deductible_applies decimal(18,2) [note: 'Indicates whether the plan deductible must be met before cost-sharing for this drug tier applies. Relevant for High Deductible Health Plans (HDHP) and plans with drug-specific deductibles.']
  dispensing_channel varchar [note: 'Pharmacy dispensing channel(s) through which this drug may be dispensed under this formulary tier assignment. \'specialty\' indicates dispensing is restricted to a specialty pharmacy network. Drives pharmacy routing at point of sale.']
  drug_tier_change_reason varchar [note: 'Business reason for a change to the drug\'s tier assignment (e.g., \'generic available\', \'contract renegotiation\', \'clinical review\', \'CMS requirement\', \'formulary refresh\'). Supports audit trail and CMS formulary change notification requirements.']
  dur_alert_type varchar [note: 'Type of Drug Utilization Review (DUR) alert associated with this formulary drug tier assignment (e.g., \'drug-drug interaction\', \'drug-disease contraindication\', \'duplicate therapy\', \'dose range check\'). Drives DUR edits at point of sale in the PBM adjudication system. [ENUM-REF-CANDIDATE: drug_drug_interaction|drug_disease|duplicate_therapy|dose_range|drug_allergy|drug_age — promote to reference product]']
  effective_date date [note: 'Date on which this formulary drug tier assignment becomes effective. Used to determine the applicable tier and cost-sharing rules at the time of dispensing. Required for CMS formulary file submissions.']
  formulary_status_code varchar [note: 'CMS-defined formulary status code used in the Part D formulary file submission. Values: 1=Covered, 2=Covered with Restrictions, 3=Not Covered, 4=Covered (Grandfathered), 5=Covered (Transition), 6=Covered (LIS). Required field in CMS formulary extract file.']
  lob_code varchar [note: 'Line of business to which this formulary drug tier assignment applies (e.g., \'commercial\', \'medicare_part_d\', \'medicaid\', \'exchange\', \'fehb\'). Determines applicable regulatory requirements and cost-sharing rules.']
  mac_pricing_applicable boolean [note: 'Indicates whether Maximum Allowable Cost (MAC) pricing applies to this drug under this formulary tier assignment. MAC pricing caps reimbursement for generic drugs and is a key PBM contract term.']
  ndc_code varchar [note: '11-digit National Drug Code uniquely identifying the specific drug product, dosage form, and package size assigned to this formulary tier. NDC is the primary drug identifier used in pharmacy claim adjudication and CMS formulary file submissions.']
  pa_type varchar [note: 'Type of prior authorization process required for this drug (e.g., \'standard\' = standard review timeline; \'expedited\' = urgent/expedited review; \'retrospective\' = post-service review). Null or \'not_applicable\' if prior_auth_required is false.']
  pbm_formulary_code varchar [note: 'PBM system-specific formulary identifier used in RxClaim or Argus to reference this formulary configuration. Enables reconciliation between the health plan\'s internal formulary records and the PBM\'s adjudication system.']
  prior_auth_required boolean [note: 'Indicates whether prior authorization (PA) is required before this drug will be covered under this formulary tier assignment. When true, a PA request must be approved before the claim will adjudicate. Reported in the CMS PA extract file.']
  ql_clinical_basis varchar [note: 'Clinical rationale or basis for the quantity limit rule (e.g., \'FDA-approved maximum dose\', \'clinical guidelines\', \'safety limit\'). Documents the evidence basis for the QL control as required for CMS and NCQA compliance.']
  ql_days_supply varchar [note: 'The number of days supply over which the maximum quantity limit applies (e.g., 30 days, 90 days). Defines the time window for the quantity limit rule. Null if quantity_limit_required is false.']
  ql_dosage_form_restriction varchar [note: 'Specifies any dosage form restrictions associated with the quantity limit rule (e.g., \'tablet only\', \'extended-release excluded\', \'oral solution only\'). Captures clinical basis for dosage form-specific QL controls.']
  ql_max_quantity decimal(10,3) [note: 'Maximum quantity of the drug allowed per fill or per defined time period under the quantity limit rule. Expressed in the drug\'s dispensing unit (e.g., tablets, mL, units). Null if quantity_limit_required is false.']
  quantity_limit_required boolean [note: 'Indicates whether a quantity limit (QL) applies to this drug under this formulary assignment. When true, the dispensed quantity per fill or per time period is restricted. Reported in the CMS QL extract file.']
  record_status varchar [note: 'Lifecycle status of this formulary drug tier assignment record. \'active\' = currently in effect; \'inactive\' = terminated or expired; \'pending\' = approved but not yet effective; \'superseded\' = replaced by a newer version of the same assignment.']
  specialty_drug_flag boolean [note: 'Indicates whether this drug is designated as a specialty drug under this formulary. Specialty drugs typically require dispensing through a specialty pharmacy, have higher cost-sharing, and may require PA. Used in specialty pharmacy channel routing and PBM contract management.']
  st_override_criteria varchar [note: 'Criteria under which the step therapy requirement may be overridden without completing the required step sequence (e.g., \'contraindication to step drug\', \'prior treatment failure documented\', \'clinical exception\'). Supports PA override adjudication.']
  st_required_step_ndc varchar [note: 'National Drug Code (NDC) of the required step drug that must be tried and failed before coverage of this drug is approved under the step therapy protocol. Null if step_therapy_required is false.']
  st_step_number varchar [note: 'The sequence number of this drug in the step therapy protocol (e.g., 1 = first-line, 2 = second-line). Defines the order in which step drugs must be tried and failed before coverage of the target drug is approved. Null if step_therapy_required is false.']
  step_therapy_required boolean [note: 'Indicates whether step therapy (ST) applies to this drug under this formulary assignment. When true, the member must first try and fail one or more preferred (step) drugs before coverage of this drug is approved. Reported in the CMS ST extract file.']
  termination_date date [note: 'Date on which this formulary drug tier assignment expires or is terminated. Null indicates the assignment is currently active with no defined end date. Supports historical tracking and CMS formulary file change submissions.']
  tier_name varchar [note: 'Human-readable label for the drug tier (e.g., \'Generic\', \'Preferred Brand\', \'Non-Preferred Brand\', \'Specialty\', \'Specialty Preferred\'). Displayed on member-facing materials including the Summary of Benefits and Coverage (SBC) and Explanation of Benefits (EOB).']
  tier_number varchar [note: 'Numeric tier level assigned to the drug within the formulary (e.g., 1=Generic, 2=Preferred Brand, 3=Non-Preferred Brand, 4=Specialty, 5=Specialty Preferred, 6=Select Care). Drives member cost-sharing at point of sale. CMS requires tier number in formulary file submissions.']
  transition_fill_allowed boolean [note: 'Indicates whether a transition fill is permitted for this drug when a member is new to the plan or the drug\'s formulary status has changed. CMS Part D requires transition fills for certain drugs during the transition period.']
  updated_timestamp timestamp [note: 'Timestamp when this formulary drug tier assignment record was last modified. Supports change tracking, audit trail, and CMS formulary change notification compliance.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Association entity linking a specific drug (NDC) to a formulary with its assigned tier, cost-sharing rules, coverage status, and all utilization management (UM) controls. UM controls owned by this product include: quantity limits (max quantity per fill/time period, dosage form restrictions, clinical basis), step therapy protocols (fail-first drug sequences, required step drugs, step sequence, clinical rationale, override criteria), prior authorization flags, and specialty drug designation. Captures effective date range for each tier assignment and each UM control configuration. This is the single operational record that drives member cost-sharing and UM edits at point of sale, and is the SSOT for CMS formulary file submissions including formulary, QL, ST, and PA extract files. [FHIR-aligned]'
}

Table pharmacy.drug_pricing {
  drug_pricing_id varchar [pk, note: 'Unique surrogate identifier for each NDC-level drug pricing record in the Silver Layer lakehouse. Primary key for the drug_pricing data product.']
  drug_master_id varchar [note: 'Foreign key linking to pharmacy.drug_master. Business justification: drug_pricing records are defined per NDC; linking to drug_master provides the authoritative drug attributes and eliminates duplicated columns.']
  formulary_id varchar [note: 'Foreign key linking to pharmacy.formulary. Business justification: drug_pricing carries a denormalized formulary_tier STRING column. Adding formulary_id FK to formulary normalizes the formulary reference, enabling direct joins to retrieve tier and formulary metadata.']
  pbm_contract_id varchar [note: 'Foreign key linking to pharmacy.pbm_contract. Business justification: drug_pricing carries mac_list_version and mac_list_reference as denormalized attributes. PBM contracts define the MAC list reference, AWP discount percentages, and pricing methodology that govern drug']
  awp_discount_pct decimal(7,4) [note: 'Percentage discount applied to AWP to derive the reimbursement rate under AWP-based contracts (e.g., AWP minus 15%). Expressed as a positive decimal percentage (e.g., 15.0000 = 15%). Used for PBM contract compliance validation and reimbursement audits.']
  awp_price decimal(18,6) [note: 'Average Wholesale Price per unit as published by First Databank or Medi-Span. Commonly used as the benchmark for pharmacy reimbursement calculations and discount negotiations. Expressed in USD.']
  created_timestamp timestamp [note: 'Timestamp when this drug pricing record was first created in the Silver Layer lakehouse. Used for data lineage, audit trails, and SLA monitoring of pricing file processing.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for all monetary price fields in this record (e.g., USD). Supports multi-currency operations for Puerto Rico and other US territories. Defaults to USD for domestic plans.']
  days_supply varchar [note: 'Number of days of drug supply for which this pricing record applies (e.g., 30-day retail, 90-day mail order). Used to differentiate pricing tiers by supply duration per PBM contract terms.']
  dea_schedule varchar [note: 'DEA controlled substance schedule classification (CI through CV) or NON-CONTROLLED. Used for DUR edits, quantity limit enforcement, prior authorization requirements, and regulatory compliance reporting.']
  dispensing_channel varchar [note: 'Pharmacy dispensing channel for which this pricing record applies: retail (community pharmacy), mail_order (90-day supply mail service), specialty (specialty pharmacy), or long_term_care (LTC facility pharmacy). Pricing may differ by channel per PBM contract terms.']
  dispensing_fee decimal(10,4) [note: 'Fixed dispensing fee in USD paid to the pharmacy per prescription fill, separate from the ingredient cost. Defined in PBM network contracts and applied during claim adjudication to calculate total pharmacy reimbursement.']
  effective_date date [note: 'Date on which this pricing record becomes effective and applicable for claim adjudication. Used to select the correct price for a claim based on the date of service. Aligns with PBM pricing file effective dates.']
  expiration_date date [note: 'Date on which this pricing record expires and is no longer applicable for new claim adjudication. Null indicates an open-ended pricing record with no defined end date. Used with effective_date to determine the active pricing window.']
  mac_methodology varchar [note: 'Describes the methodology used to derive the MAC price (e.g., MARKET_BASKET=based on market survey of acquisition costs, NADAC_BASED=derived from CMS NADAC data, AWP_DISCOUNT=percentage discount from AWP, WAC_DISCOUNT=percentage discount from WAC, CUSTOM=plan-specific methodology). Required for PBM contract compliance and regulatory transparency. Null when price_type is not MAC.']
  mac_price decimal(18,6) [note: 'Maximum Allowable Cost per unit set by the PBM or health plan for generic and multi-source drugs. Represents the upper reimbursement limit for a drug under the applicable MAC list. Expressed in USD. Null when price_type is not MAC.']
  multi_source_code varchar [note: 'FDA Orange Book multi-source code indicating the competitive market status of the drug: O=Originator brand (no generic), M=Multi-source (generic available), N=Non-multi-source, Y=Generic product. Used to determine MAC eligibility and generic substitution applicability.']
  package_size decimal(10,4) [note: 'Quantity of units contained in the standard package as defined by the NDC. Used to convert between package-level and per-unit pricing and to validate dispensed quantity against package size during adjudication.']
  package_size_uom varchar [note: 'Unit of measure for the package size quantity (e.g., TAB for tablets, ML for milliliters). Distinct from unit_of_measure which applies to the pricing unit; this field describes the package-level quantity unit. [ENUM-REF-CANDIDATE: EA|ML|GM|MG|UN|TAB|CAP|VIAL|PATCH — promote to reference product]']
  price_change_pct decimal(10,4) [note: 'Percentage change in unit price from the prior pricing record to the current record, calculated as ((unit_price - prior_unit_price) / prior_unit_price) * 100. Used for drug price inflation monitoring, CMS price increase reporting, and PBM contract compliance.']
  price_type decimal(18,2) [note: 'Classifies the pricing methodology represented by this record: AWP (Average Wholesale Price), WAC (Wholesale Acquisition Cost), MAC (Maximum Allowable Cost), RBP (Reference Based Pricing), NADAC (National Average Drug Acquisition Cost), or Usual and Customary. Determines how the price is applied during claim adjudication and reimbursement calculation. [ENUM-REF-CANDIDATE: AWP|WAC|MAC|RBP|NADAC|USUAL_AND_CUSTOMARY — promote to reference product]']
  pricing_file_date date [note: 'Publication or release date of the source pricing file from which this record was extracted. Used to track pricing file currency, identify stale pricing data, and support audit and reconciliation processes.']
  pricing_file_name varchar [note: 'Name of the source pricing file from which this record was loaded (e.g., \'FDB_PRICE_20240101.txt\', \'RXCLAIM_MAC_Q1_2024.csv\'). Used for data lineage, audit trails, and troubleshooting pricing discrepancies.']
  pricing_source varchar [note: 'Identifies the originating source of the pricing data (e.g., First Databank, Medi-Span, RxClaim PBM feed, Argus PBM feed, CMS published rates, internal custom pricing). Critical for audit trails and PBM contract compliance. [ENUM-REF-CANDIDATE: FDB|MEDISPAN|RXCLAIM|ARGUS|CMS|INTERNAL|CUSTOM — promote to reference product]']
  pricing_status varchar [note: 'Current lifecycle status of the pricing record: active (currently in use for adjudication), inactive (no longer applicable), pending (approved but not yet effective), superseded (replaced by a newer pricing record for the same NDC and price type).']
  prior_unit_price decimal(18,6) [note: 'Previous per-unit price for this NDC and price type before the most recent pricing update. Used for price change analysis, trend reporting, and PBM contract compliance audits.']
  rbp_price decimal(18,6) [note: 'Reference Based Pricing per unit used as the benchmark reimbursement amount under RBP pharmacy contracts. Expressed in USD. Null when price_type is not RBP.']
  unit_of_measure varchar [note: 'Dispensing unit of measure for which the price applies (e.g., EA=Each, ML=Milliliter, GM=Gram, MG=Milligram, UN=Unit, TAB=Tablet, CAP=Capsule, VIAL=Vial, PATCH=Patch). Required for accurate per-unit cost calculation during adjudication. [ENUM-REF-CANDIDATE: EA|ML|GM|MG|UN|TAB|CAP|VIAL|PATCH — promote to reference product]']
  unit_price decimal(18,6) [note: 'Per-unit drug price expressed in USD for the applicable price type (AWP, WAC, MAC, or RBP). Used as the basis for claim adjudication, cost-sharing calculation, and pharmacy reimbursement. Precision to 6 decimal places to accommodate high-precision specialty drug pricing.']
  updated_timestamp timestamp [note: 'Timestamp when this drug pricing record was last modified in the Silver Layer lakehouse. Used for change data capture (CDC), incremental processing, and audit trail maintenance.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']
  wac_price decimal(18,6) [note: 'Wholesale Acquisition Cost per unit as reported by the manufacturer to the pricing compendia. Represents the list price from manufacturer to wholesaler before discounts. Expressed in USD. Used in WAC-based reimbursement contracts.']

  Note: 'NDC-level drug pricing record capturing AWP (Average Wholesale Price), WAC (Wholesale Acquisition Cost), MAC (Maximum Allowable Cost), and RBP (Reference Based Pricing) values sourced from PBM pricing files. Includes effective date, pricing source, unit of measure, package size, price type, MAC list name, and MAC list methodology reference. Used for claim adjudication, cost-sharing calculation, and pharmacy reimbursement. MAC list grouping attributes are included directly on pricing records for governance and PBM contract compliance. Sourced from RxClaim or Argus PBM pricing feeds and First Databank/Medi-Span pricing updates. [FHIR-aligned]'
}

Table pharmacy.pharmacy_claim {
  pharmacy_claim_id varchar [pk, note: 'Unique surrogate identifier for each pharmacy claim record in the Silver layer lakehouse. Primary key for the pharmacy_claim data product. Role: TRANSACTION_HEADER.']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Pharmacy claim adjudication applies cost-sharing rules defined at the benefit_package level (retail copay tiers, deductible applicability, specialty drug management). Linking claims to benefit_package']
  cost_share_rule_id varchar [note: 'Foreign key linking to plan.cost_share_rule. Business justification: During pharmacy claim adjudication, a specific cost_share_rule determines member copay/coinsurance. Regulatory audits and member grievance processes require an audit trail of which rule was applied to']
  dispensing_pharmacy_id varchar [note: 'Surrogate reference to the pharmacy that dispensed the drug. Links to the provider/pharmacy master record. Distinguishes retail, mail-order, and specialty pharmacy channels. Used for network adequacy reporting and pharmacy audit trail requirements.']
  drug_master_id varchar [note: 'Surrogate reference to the NDC-level drug master record in the pharmacy domain. Links to the formulary drug master product which carries NDC, drug name, tier, and pricing (AWP/WAC/MAC). Central to formulary compliance and drug utilization review (DUR).']
  formulary_id varchar [note: 'Foreign key linking to pharmacy.formulary. Business justification: pharmacy_claim carries formulary_tier as a denormalized STRING. Each pharmacy claim is adjudicated against a specific formulary (the member\'s plan formulary). Adding formulary_id FK to formulary norma']
  header_id varchar [note: 'Foreign key linking to claim.header. Business justification: Required for integrated care reporting: links pharmacy claims to the corresponding medical claim header for episode‑of‑care analysis and coordinated benefits calculations.']
  member_identity_id varchar [note: 'Surrogate reference to the health plan member who is the beneficiary of this pharmacy claim. Links to the member master record in the Core Administration Platform (Facets/QNXT). Required for eligibility verification, coordination of benefits (COB), and CMS Part D risk adjustment (RAF/HCC).']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Pharmacy claims are adjudicated against a specific member policy to determine deductible application, OOP accumulation, and plan-paid amounts. EOB generation, COB adjudication, and CMS Part D reportin']
  prescriber_provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Every pharmacy claim must identify the prescribing provider for CMS Part D reporting, HEDIS prescribing measures, fraud/waste/abuse detection, and provider profiling. prescriber_npi is a denormalized ']
  prior_authorization_id varchar [note: 'Surrogate reference to the prior authorization record that approved dispensing of this drug, if applicable. Null when no PA was required. Links to the utilization management PA product. Required for specialty drug claims and step therapy override tracking.']
  adjudication_timestamp timestamp [note: 'Date and time the pharmacy claim was adjudicated (approved or rejected) by the PBM system. Distinct from fill_date (dispensing event). Used for claims processing SLA measurement, 835 remittance matching, and audit trail compliance.']
  basis_of_cost_determination decimal(18,2) [note: 'Code indicating the pricing benchmark used to determine the ingredient cost for this claim. AWP = Average Wholesale Price; WAC = Wholesale Acquisition Cost; MAC = Maximum Allowable Cost; usual_and_customary = pharmacy\'s standard retail price; negotiated = contracted rate; 340B = 340B program pricing; other = alternative basis. [ENUM-REF-CANDIDATE: awp|wac|mac|usual_and_customary|negotiated|340b|other — 7 candidates stripped; promote to reference product]']
  claim_number varchar [note: 'Externally-known, human-readable claim reference number assigned by the Pharmacy Benefit Management (PBM) system (RxClaim or Argus) at adjudication. Used for member communications, Explanation of Benefits (EOB), and 835 remittance reconciliation. Maps to NCPDP D.0 transaction reference number.']
  claim_status varchar [note: 'Current adjudication lifecycle status of the pharmacy claim as determined by the PBM system. \'paid\' = claim adjudicated and payment issued; \'rejected\' = claim denied with reject code; \'reversed\' = previously paid claim reversed; \'adjusted\' = claim reprocessed with changed amounts; \'pending\' = awaiting adjudication; \'void\' = cancelled before processing.']
  cob_indicator boolean [note: 'Indicates whether coordination of benefits (COB) was applied on this claim (True = COB applied, another payer was involved). Triggers COB segment processing and other_payer_amount population. Used for COB reconciliation and CMS Part D TrOOP calculations.']
  created_timestamp timestamp [note: 'Timestamp when this pharmacy claim record was first created in the Silver layer data product. Supports audit trail, data lineage, and HIPAA record retention requirements. RECORD_AUDIT_CREATED category.']
  daw_code varchar [note: 'NCPDP Dispense As Written (DAW) code indicating whether a brand drug was dispensed when a generic was available, and the reason. 0 = no product selection indicated; 1 = substitution not allowed by prescriber; 2 = substitution allowed, patient requested brand; 3 = substitution allowed, pharmacist selected brand; 4 = substitution allowed, generic not in stock; 5 = substitution allowed, brand dispensed as generic. Used for generic substitution rate analytics and formulary compliance.']
  days_supply varchar [note: 'Number of days of medication supply dispensed on this claim as reported by the dispensing pharmacy. Used for refill-too-soon edits, medication adherence (MPR/PDC) calculations, HEDIS pharmacy measures, and CMS Part D days supply validation.']
  deductible_applied decimal(10,2) [note: 'Dollar amount of this pharmacy claim applied toward the member\'s pharmacy or combined medical/pharmacy deductible. Relevant for HDHP/HSA plans and CMS Part D deductible phase tracking. Contributes to OOP/MOOP accumulation.']
  dispensing_fee decimal(10,2) [note: 'Fee charged by the dispensing pharmacy for the act of dispensing the prescription, separate from ingredient cost. Negotiated as part of the PBM network contract. Used for PBM contract reconciliation and total claim cost analysis.']
  dispensing_pharmacy_npi varchar [note: '10-digit National Provider Identifier (NPI) of the dispensing pharmacy as submitted on the pharmacy claim. Denormalized for claim-level auditability and NCPDP D.0 compliance. Used for pharmacy network validation, audit trail, and CMS Part D encounter data.']
  dur_outcome_code varchar [note: 'NCPDP standard code indicating the outcome of the prospective drug utilization review (DUR) edit performed during adjudication (e.g., drug-drug interaction, duplicate therapy, dose check). Null if no DUR alert was triggered. Critical for pharmacy safety and regulatory compliance. [ENUM-REF-CANDIDATE: promote to reference product — NCPDP DUR outcome codes exceed 6 values]']
  fhir_medication varchar [note: 'FHIR MedicationDispense.medication mapping']
  fhir_quantity varchar [note: 'FHIR MedicationDispense.quantity mapping']
  fhir_status varchar [note: 'FHIR MedicationDispense.status mapping']
  fhir_subject varchar [note: 'FHIR MedicationDispense.subject mapping']
  fill_date date [note: 'The date the prescription was dispensed by the pharmacy to the member. This is the principal real-world business event date (BUSINESS_EVENT_TIMESTAMP category). Used for days supply calculations, refill-too-soon edits, and CMS Part D encounter data date of service reporting.']
  ingredient_cost decimal(12,2) [note: 'The cost of the drug ingredient(s) as billed by the dispensing pharmacy, before dispensing fee and other adjustments. Basis may be AWP, WAC, MAC, or negotiated rate. Core component of the MONETARY_TRIPLET for pharmacy claim financials. Used for PBM contract reconciliation and MLR calculation.']
  is_340b_claim boolean [note: 'Indicates whether this pharmacy claim was dispensed under the 340B Drug Pricing Program (True = 340B claim). Used for 340B duplicate discount prevention, HRSA compliance reporting, and separation of 340B and non-340B claims in financial reconciliation.']
  is_compound_claim boolean [note: 'Indicates whether this claim is for a compounded drug product containing multiple ingredients (True = compound claim). Compound claims require line-level detail in the pharmacy_claim_line product. Used for compound drug utilization review and cost management.']
  line_of_business varchar [note: 'Line of business under which this pharmacy claim was adjudicated. Drives regulatory reporting requirements, formulary rules, and cost-sharing structures. \'commercial\' = employer-sponsored or individual; \'medicare_part_d\' = CMS Medicare Part D; \'medicaid\' = state Medicaid; \'exchange\' = ACA marketplace QHP; \'cobra\' = COBRA continuation coverage.']
  member_coinsurance decimal(10,2) [note: 'Percentage-based cost-sharing amount paid by the member for this pharmacy claim, calculated as a percentage of the allowed cost. Applies when the benefit design uses coinsurance rather than fixed copay. Contributes to OOP/MOOP accumulation.']
  member_copay decimal(10,2) [note: 'Fixed dollar amount paid by the member at point of sale as their cost-sharing obligation for this pharmacy claim. Determined by formulary tier and benefit design. Contributes to member out-of-pocket (OOP) and maximum out-of-pocket (MOOP) accumulation.']
  ndc varchar [note: '11-digit National Drug Code identifying the specific drug product dispensed, including labeler, product, and package segment. Denormalized from the drug master for claim-level auditability and CMS Part D encounter data submission (EDPS). Required for 340B duplicate discount prevention and drug utilization review (DUR).']
  original_claim_number varchar [note: 'Claim number of the original pharmacy claim that this record adjusts or reverses. Populated only for adjusted or reversed claims; null for original claims. Enables claim adjustment chain tracing for financial reconciliation, audit, and CMS Part D encounter data correction submissions.']
  pharmacy_channel varchar [note: 'Channel through which the drug was dispensed. Drives cost-sharing differentials, formulary tier rules, and network adequacy reporting. \'retail\' = community pharmacy; \'mail_order\' = 90-day mail service; \'specialty\' = specialty pharmacy for high-cost/complex drugs; \'long_term_care\' = SNF/LTC pharmacy; \'home_infusion\' = infusion therapy at home.']
  plan_paid_amount decimal(12,2) [note: 'Total amount paid by the health plan for this pharmacy claim after applying member cost-sharing (copay, coinsurance, deductible) and COB adjustments. Net total component of the MONETARY_TRIPLET. Used for 835 remittance, MLR reporting, and CMS Part D encounter data.']
  prescription_written_date date [note: 'Date the prescription was written by the prescriber. Used to validate prescription age, enforce days-supply-from-written-date rules, and support medication adherence analytics. Distinct from fill_date (dispensing date).']
  quantity_dispensed decimal(12,3) [note: 'Actual quantity of the drug dispensed (e.g., number of tablets, milliliters, grams) as reported by the dispensing pharmacy. Used for quantity limit (QL) edits, drug utilization review (DUR), and CMS Part D encounter data submission.']
  quantity_unit_of_measure varchar [note: 'NCPDP standard unit of measure code for the quantity dispensed. EA = each (tablets/capsules); ML = milliliters; GM = grams; UN = units; F2 = international units; ME = milliequivalents. Required for accurate quantity limit (QL) edit enforcement and CMS Part D encounter data.']
  refill_number varchar [note: 'Refill sequence number for this dispensing event. Zero (0) indicates the original fill; subsequent values indicate refill number. Used for refill-too-soon edits, medication adherence tracking, and prescription lifecycle management.']
  reject_code varchar [note: 'NCPDP standard reject code returned by the PBM system when a claim is rejected or denied. Null for paid claims. Used for pharmacy operations, member appeals, and drug utilization review (DUR) outcome tracking. [ENUM-REF-CANDIDATE: promote to reference product — NCPDP reject codes exceed 6 values]']
  sales_tax decimal(10,2) [note: 'Sales tax amount applied to the pharmacy claim where applicable by state law. Included in total claim cost and reported separately for financial reconciliation and statutory accounting (SAP) purposes.']
  step_therapy_override boolean [note: 'Indicates whether a step therapy protocol was overridden for this claim (True = override applied). Step therapy requires trying lower-cost drugs before approving higher-cost alternatives. Override requires prior authorization. Used for utilization management (UM) reporting and CMS step therapy compliance.']
  updated_timestamp timestamp [note: 'Timestamp when this pharmacy claim record was last modified in the Silver layer, such as after a claim adjustment, reversal, or COB update. Supports change data capture (CDC) and audit trail requirements. RECORD_AUDIT_UPDATED category.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Core transactional record for each pharmacy claim submitted and adjudicated through the PBM system (RxClaim or Argus). Header captures: claim number, member ID, prescriber NPI, dispensing pharmacy NPI, NDC, days supply, quantity dispensed, fill date, adjudication date, claim status, reject codes, ingredient cost, dispensing fee, copay, coinsurance, deductible applied, plan paid amount, and coordination of benefits (COB) details. Line-level detail supports multi-ingredient compound claims and COB line splits: line sequence, per-ingredient NDC, ingredient cost, dispensing fee, sales tax, incentive amount, other payer amount, patient pay amount, and basis of cost determination. Supports NCPDP D.0 transaction standards, 835 remittance, CMS Part D encounter data submissions (EDPS/RAPS), 340B claim identification for duplicate discount prevention, and pharmacy audit trail requirements. This is the SSOT for all pharmacy claim header and line-level transactional data within the pharmacy domain. [FHIR-aligned]'
}

Table pharmacy.claim_line {
  claim_line_id varchar [pk, note: 'Primary key for claim_line']
  cost_share_rule_id varchar [note: 'Foreign key linking to plan.cost_share_rule. Business justification: Claim line adjudication applies drug-specific cost_share_rules (e.g., specialty drug coinsurance, HSA-compatible deductible rules). Linking claim_line to cost_share_rule enables line-level audit trail']
  drug_master_id varchar [note: 'Reference to the drug master record for the dispensed drug on this claim line, enabling linkage to formulary, tier, and pricing data.']
  formulary_drug_tier_id varchar [note: 'Foreign key linking to pharmacy.formulary_drug_tier. Business justification: claim_line carries formulary_tier as a denormalized STRING. formulary_drug_tier is the authoritative association entity linking a specific NDC to a formulary with its assigned tier, cost-sharing rules']
  formulary_id varchar [note: 'Reference to the formulary under which this drug was adjudicated, determining tier assignment, coverage rules, and cost-sharing obligations.']
  pharmacy_claim_id varchar [note: 'Reference to the parent pharmacy claim header to which this line belongs. Establishes the header/detail relationship for multi-line and compound drug claims.']
  prior_authorization_id varchar [note: 'Reference to the prior authorization record approved for this drug line, required for specialty and non-formulary drugs. Null if no PA was required.']
  adjudication_timestamp timestamp [note: 'Date and time when this pharmacy claim line was adjudicated by the PBM system (RxClaim or Argus). Represents the business event timestamp for the adjudication transaction. Used for audit trails and processing SLA measurement.']
  basis_of_cost_determination decimal(18,2) [note: 'Code indicating the pricing benchmark used to determine the ingredient cost for this claim line. Values include Average Wholesale Price (AWP), Wholesale Acquisition Cost (WAC), Maximum Allowable Cost (MAC), Federal Upper Limit (FUL), NADAC, negotiated rate, usual and customary, or other. Critical for PBM audit and CMS Part D compliance. [ENUM-REF-CANDIDATE: AWP|WAC|MAC|FUL|NADAC|negotiated|usual_and_customary|other — promote to reference product]']
  catastrophic_coverage_indicator boolean [note: 'Indicates whether this claim line was adjudicated under the catastrophic coverage phase of the Part D benefit, where the plan pays a higher percentage of drug costs after the member\'s True Out-of-Pocket (TrOOP) threshold is met.']
  cob_sequence varchar [note: 'Indicates the payer sequence in a Coordination of Benefits (COB) scenario. 1=primary payer, 2=secondary payer, 3=tertiary payer. Used to correctly apply COB rules and calculate each payer\'s liability on this claim line.']
  compound_indicator boolean [note: 'Indicates whether this claim line is part of a compounded drug prescription. When true, multiple ingredient lines will exist under the same claim header, each with its own NDC and ingredient cost.']
  coverage_gap_indicator boolean [note: 'Indicates whether this claim line was adjudicated during the Part D coverage gap (donut hole) phase. Used for manufacturer discount program tracking and CMS Part D benefit phase reporting.']
  days_supply varchar [note: 'Number of days of medication supply dispensed on this claim line as reported by the dispensing pharmacy. Used for refill-too-soon edits, adherence calculations, and HEDIS medication adherence measures.']
  dispense_as_written_code varchar [note: 'NCPDP Dispense As Written (DAW) code indicating whether the prescriber or member requested brand-name dispensing when a generic was available. DAW 0=no product selection indicated, DAW 1=substitution not allowed by prescriber, DAW 2=substitution allowed-patient requested brand. Impacts cost-sharing and GDR calculations.']
  dispensed_date date [note: 'Date the drug was dispensed to the member at the pharmacy. Represents the real-world service event date used for benefit period calculations, days supply tracking, and CMS Part D reporting.']
  dispensing_fee_amount decimal(10,2) [note: 'The fee charged by the dispensing pharmacy for the professional service of dispensing the medication. Negotiated as part of PBM network contracts and reported separately from ingredient cost per CMS Part D requirements.']
  drug_coverage_status varchar [note: 'Coverage determination status for this drug on the applicable formulary at time of adjudication. Indicates whether the drug is covered, non-covered, excluded, subject to step therapy, or requires prior authorization (PA).']
  dur_conflict_code varchar [note: 'NCPDP DUR conflict code identifying the type of drug utilization issue detected during adjudication (e.g., drug-drug interaction, drug-disease contraindication, duplicate therapy, high dose). Supports clinical safety monitoring and regulatory DUR reporting. [ENUM-REF-CANDIDATE: promote to reference product for full NCPDP DUR conflict code set]']
  dur_outcome_code varchar [note: 'NCPDP Drug Utilization Review (DUR) outcome code recorded during adjudication, indicating the pharmacist\'s action taken in response to a DUR alert (e.g., filled as is, filled with prescriber approval, not filled). Supports clinical safety audit trails. [ENUM-REF-CANDIDATE: promote to reference product for full NCPDP DUR outcome code set]']
  fill_number varchar [note: 'Sequential fill number for this prescription across all fills, including original and all refills. Distinct from refill_number in that it counts total fills rather than refill sequence. Used for prescription lifecycle tracking.']
  generic_indicator boolean [note: 'Indicates whether the dispensed drug is a generic equivalent. Used for generic dispensing rate (GDR) reporting, formulary compliance analytics, and PBM performance measurement.']
  gross_drug_cost_amount decimal(12,2) [note: 'Total gross cost of the drug on this claim line, calculated as ingredient cost plus dispensing fee plus sales tax plus incentive amount. Used as the basis for CMS Part D gross drug cost reporting and risk corridor calculations.']
  incentive_amount decimal(10,2) [note: 'Incentive or bonus amount paid to the pharmacy for performance-based or preferred network participation on this claim line. Included in gross drug cost calculations for CMS Part D reporting.']
  ingredient_cost_amount decimal(12,2) [note: 'The drug ingredient cost component of the claim line, representing the cost of the drug itself exclusive of dispensing fee, sales tax, and other charges. Key input for MAC/AWP/WAC-based reimbursement calculations and compound drug cost analysis.']
  line_sequence_number varchar [note: 'Sequential number identifying the position of this line within the parent pharmacy claim. Used to order compound ingredient lines and COB line splits. Starts at 1.']
  line_status varchar [note: 'Current adjudication status of this pharmacy claim line. Drives payment processing, COB resolution, and audit reporting. [ENUM-REF-CANDIDATE: paid|denied|reversed|adjusted|pending|void — promote to reference product if additional statuses are needed]']
  line_type varchar [note: 'Classifies the nature of this claim line: standard single-drug fill, compound ingredient line, COB line split, reversal, or adjustment. Drives compound cost analysis and COB workflows.']
  low_income_subsidy_indicator decimal(18,2) [note: 'Indicates whether the member received a Low Income Subsidy (LIS) benefit on this claim line, resulting in reduced cost-sharing. Required for CMS Part D PDE reporting and LIS reconciliation.']
  manufacturer_discount_amount decimal(10,2) [note: 'Amount of manufacturer discount applied to this claim line under the CMS Part D Coverage Gap Discount Program. Counts toward the member\'s TrOOP and is reported on the PDE record.']
  ndc_code varchar [note: '11-digit National Drug Code identifying the specific drug product, strength, and package size dispensed on this claim line. Sourced from FDA NDC Directory. PHI when linked to a member.']
  patient_pay_amount decimal(10,2) [note: 'Total amount paid by the member/patient at point of sale, including copay, coinsurance, and deductible contributions. Used for Out-of-Pocket (OOP) accumulator tracking and Maximum Out-of-Pocket (MOOP) calculations.']
  pde_submission_date date [note: 'Date this claim line was submitted to CMS as a Prescription Drug Event (PDE) record for Part D reconciliation and risk adjustment. Null for non-Part D claims. Critical for CMS compliance and audit.']
  pharmacy_channel varchar [note: 'Distribution channel through which the drug was dispensed: retail pharmacy, mail-order pharmacy, specialty pharmacy, long-term care (LTC) pharmacy, or home infusion. Drives network contract application, reimbursement rates, and utilization analytics.']
  plan_paid_amount decimal(10,2) [note: 'Net amount paid by the health plan on this claim line after applying member cost-sharing, COB adjustments, and other payer amounts. Core financial metric for MLR and PMPM reporting.']
  quantity_dispensed decimal(12,3) [note: 'Actual quantity of the drug dispensed (e.g., number of tablets, milliliters, grams) as reported by the pharmacy. Used for quantity limit edits, compound ingredient cost allocation, and drug utilization review (DUR).']
  quantity_limit_indicator boolean [note: 'Indicates whether a quantity limit restriction was applied to this drug claim line during adjudication. When true, the dispensed quantity was subject to plan-defined quantity limit rules.']
  refill_number varchar [note: 'Refill sequence number for this prescription fill. Zero indicates the original fill; subsequent values indicate refill number. Used for refill-too-soon edits, adherence monitoring, and quantity limit enforcement.']
  reversal_timestamp timestamp [note: 'Date and time when this pharmacy claim line was reversed, if applicable. Null for non-reversed lines. Used for financial reconciliation, audit trails, and identifying reversed claims in PMPM and MLR calculations.']
  sales_tax_amount decimal(10,2) [note: 'State or local sales tax applied to this pharmacy claim line where applicable. Reported separately per CMS Part D PDE requirements. Zero or null in states with no drug sales tax.']
  source_system_claim_line_key varchar [note: 'Natural key or transaction identifier for this claim line as assigned by the originating PBM system (RxClaim or Argus). Used for lineage tracing, reconciliation with source system, and EDI transaction matching.']
  specialty_drug_indicator boolean [note: 'Indicates whether the drug dispensed on this line is classified as a specialty drug, typically requiring special handling, storage, or administration and subject to specialty pharmacy channel requirements and PA rules.']
  step_therapy_indicator boolean [note: 'Indicates whether this drug claim line was subject to a step therapy protocol requiring the member to try a preferred or lower-cost drug before coverage of this drug was approved.']
  true_oop_amount decimal(10,2) [note: 'Member\'s True Out-of-Pocket (TrOOP) cost contribution from this claim line, used to track progress toward the Part D catastrophic coverage threshold. Includes patient pay and applicable manufacturer discounts.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Line-level detail for pharmacy claims supporting multi-ingredient compound claims and coordination of benefits (COB) line splits. Captures line sequence, NDC, ingredient cost, dispensing fee, sales tax, incentive amount, other payer amount, patient pay amount, and basis of cost determination. Enables granular adjudication audit trails and compound drug cost analysis. [FHIR-aligned]'
}

Table pharmacy.prior_authorization {
  prior_authorization_id varchar [pk, note: 'Primary key for prior_authorization']
  benefit_id varchar [note: 'Foreign key linking to plan.benefit. Business justification: A prior authorization is triggered by a specific benefit rule (authorization_required, prior_auth_review_level on benefit). Linking PA to benefit enables clinical criteria validation against the benef']
  clinical_criteria_id varchar [note: 'Foreign key linking to utilization.clinical_criteria. Business justification: Pharmacy PA review process: each pharmacy prior authorization is evaluated against a specific clinical criteria set and version. PA reviewers and auditors must trace which clinical_criteria governed a']
  drug_master_id varchar [note: 'Foreign key linking to pharmacy.drug_master. Business justification: prior_authorization carries drug_ndc as a denormalized NDC code STRING. drug_master is the authoritative NDC-level drug master record. Adding drug_master_id FK normalizes the drug reference on the PA ']
  formulary_id varchar [note: 'Identifier of the formulary associated with the member\'s plan at the time of the prior authorization request. Determines drug tier, coverage rules, and applicable PA criteria.']
  hcc_mapping_id varchar [note: 'Foreign key linking to risk.hcc_mapping. Business justification: PA clinical criteria for specialty and HCC-relevant drugs are validated against HCC-mapped diagnoses (prior_authorization.icd_diagnosis_code maps to hcc_mapping.icd10_code). Risk-adjustment-aware PA r']
  original_pa_prior_authorization_id varchar [note: 'Reference to the original prior authorization record when this record represents a renewal, appeal, or modification. Enables tracking of the full PA lifecycle chain. Null for initial requests.']
  pa_request_id varchar [note: 'Foreign key linking to utilization.pa_request. Business justification: Required for PA audit report linking each prior authorization record to its originating request, enabling traceability of request‑to‑authorization lifecycle.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: PA decisions are made against a specific policy\'s benefit design and coverage year. CMS PA reporting, denial letters, and appeal processing all require policy context. prior_authorization links to sub']
  prescriber_provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Every pharmacy PA is submitted by a prescribing provider. Health insurance PA workflows, CMS Part D audit trails, and fraud/abuse detection require linking the PA to the credentialed prescriber in the']
  appeal_indicator boolean [note: 'Indicates whether this prior authorization record is associated with a member or prescriber appeal of a prior denial. True = this PA is an appeal case.']
  approved_days_supply varchar [note: 'Number of days of drug therapy authorized under this prior authorization. Used by the PBM to enforce dispensing limits and by CMS Part D for compliance reporting.']
  approved_quantity decimal(10,3) [note: 'Total quantity of the drug authorized for dispensing under this prior authorization (e.g., number of tablets, milliliters, units). Enforced at point-of-sale by the PBM adjudication system.']
  approved_refills varchar [note: 'Number of refills authorized under this prior authorization in addition to the initial fill. Enforced by the PBM adjudication system at point-of-sale.']
  clinical_criteria_version varchar [note: 'Version of the clinical criteria set (InterQual or MCG) applied at the time of the prior authorization decision. Required for audit trails and appeals to ensure the correct criteria version is referenced.']
  cms_part_d_reportable boolean [note: 'Indicates whether this prior authorization record is subject to CMS Part D PA reporting requirements. True = must be included in CMS Part D PA reporting submissions.']
  created_timestamp timestamp [note: 'Timestamp when this prior authorization record was first created in the Silver Layer data platform. Used for data lineage, audit trail, and Silver Layer processing compliance.']
  criteria_met boolean [note: 'Indicates whether the submitted clinical information met the applicable clinical criteria (InterQual/MCG) for the requested drug. True = criteria met (supports approval); False = criteria not met (supports denial).']
  decision_timestamp timestamp [note: 'Exact date and time the prior authorization decision (approval, denial, or pend) was rendered by the clinical reviewer or automated adjudication engine. Used to calculate turnaround time against CMS and URAC standards.']
  denial_reason_code varchar [note: 'Standardized code indicating the reason for denial of the prior authorization request (e.g., not medically necessary, step therapy not completed, quantity limit exceeded, non-covered drug). Populated only when pa_status = denied. Used for member appeals and CMS Part D reporting.']
  denial_reason_description varchar [note: 'Free-text description of the denial reason, providing clinical or administrative context beyond the denial reason code. Included in member and prescriber denial notices per CMS and state DOI requirements.']
  dispensing_channel varchar [note: 'Pharmacy dispensing channel authorized for this prior authorization (retail, mail-order, specialty pharmacy, long-term care, or home infusion). Determines which pharmacy network is eligible to dispense.']
  drug_tier varchar [note: 'Formulary tier of the requested drug at the time of the prior authorization request. Determines cost-sharing obligations and PA criteria applied.']
  dur_outcome_code varchar [note: 'NCPDP-standardized Drug Utilization Review (DUR) outcome code resulting from prospective DUR screening performed during PA adjudication (e.g., drug-drug interaction, drug-disease contraindication, duplicate therapy). Sourced from PBM system (RxClaim/Argus).']
  effective_end_date date [note: 'Date on which the prior authorization expires and is no longer valid for dispensing. After this date, a new PA request is required. Nullable for open-ended authorizations.']
  effective_start_date date [note: 'Date from which the approved prior authorization is valid for dispensing. Pharmacies and PBM adjudication systems use this date to confirm dispensing eligibility.']
  icd_diagnosis_code varchar [note: 'Primary ICD-10-CM diagnosis code submitted by the prescriber to support the clinical necessity of the requested drug. Required for clinical criteria evaluation and CMS Part D PA reporting. Contains Protected Health Information (PHI).']
  lob varchar [note: 'Line of Business (LOB) under which the member\'s coverage falls, determining applicable regulatory requirements, formulary rules, and PA criteria (e.g., Commercial, Medicare Part D, Medicaid, ACA Marketplace).']
  notes varchar [note: 'Free-text clinical notes entered by the reviewing clinician during the prior authorization evaluation, capturing clinical rationale, additional context, or instructions for the prescriber or pharmacy. Contains Protected Health Information (PHI).']
  pa_reference_number varchar [note: 'Externally-known, human-readable prior authorization reference number assigned by the Pharmacy Benefit Management (PBM) system (RxClaim or Argus) or Utilization Management (UM) system (InterQual/MCG). Used on Explanation of Benefits (EOB) and communicated to prescribers and pharmacies.']
  pa_status varchar [note: 'Current lifecycle status of the prior authorization request. Drives dispensing eligibility at the pharmacy and CMS Part D PA reporting. [ENUM-REF-CANDIDATE: approved|denied|pending|cancelled|expired|appealed — promote to reference product if additional statuses are needed]']
  pa_type varchar [note: 'Category of prior authorization criteria applied, indicating the clinical or formulary reason the drug requires PA review (e.g., specialty drug, non-preferred tier, step therapy requirement, quantity limit, age restriction, off-label use). [ENUM-REF-CANDIDATE: specialty|non_preferred|step_therapy|quantity_limit|age_restriction|off_label — promote to reference product]']
  quantity_limit_applied boolean [note: 'Indicates whether a quantity limit restriction was a factor in the prior authorization evaluation. True = quantity limit rules were applied during adjudication.']
  received_timestamp timestamp [note: 'Exact date and time the prior authorization request was received by the Utilization Management (UM) system (InterQual/MCG) or PBM system (RxClaim/Argus). Used for precise turnaround time calculation and regulatory compliance.']
  request_date date [note: 'Calendar date on which the prior authorization request was submitted by the prescriber or pharmacy. Used for turnaround time measurement and CMS Part D compliance reporting.']
  request_type varchar [note: 'Classification of the prior authorization request indicating whether it is a new request, renewal of an existing authorization, appeal of a denial, expedited urgent request, or retrospective review.']
  review_level varchar [note: 'Level of clinical review applied to the prior authorization request, indicating whether it was reviewed by a pharmacist, physician, peer-to-peer consultation, or medical director. Escalation level affects turnaround time standards.']
  source_system_pa_code varchar [note: 'Native prior authorization identifier from the originating operational system (RxClaim, Argus, InterQual, or MCG). Preserved for reconciliation, audit, and cross-system traceability in the Silver Layer.']
  specialty_drug_flag boolean [note: 'Indicates whether the requested drug is classified as a specialty drug requiring specialty pharmacy dispensing and enhanced clinical review. Specialty drugs typically have higher cost-sharing and stricter PA criteria.']
  step_therapy_completed boolean [note: 'Indicates whether the member has documented evidence of completing the required step therapy (tried and failed prerequisite drugs) as required by the formulary PA criteria. Populated when step_therapy_required = True.']
  step_therapy_required boolean [note: 'Indicates whether the prior authorization requires the member to have tried and failed one or more preferred or lower-tier drugs (step therapy) before the requested drug is authorized. True = step therapy applies.']
  updated_timestamp timestamp [note: 'Timestamp when this prior authorization record was last modified in the Silver Layer data platform, reflecting status changes, decision updates, or data corrections. Used for change data capture and audit.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Prior authorization (PA) record for specialty and non-preferred drugs requiring clinical review before dispensing. Captures PA request date, requesting prescriber NPI, member ID, drug NDC, diagnosis codes (ICD), clinical criteria applied (InterQual/MCG), authorization status (approved/denied/pending), approved quantity, approved days supply, effective date range, and denial reason codes. Interfaces with the Utilization Management system and supports CMS Part D PA reporting. [FHIR-aligned]'
}

Table pharmacy.dispensing_pharmacy {
  dispensing_pharmacy_id varchar [pk, note: 'Unique surrogate identifier for the dispensing pharmacy record within the PBM network master. Primary key for this entity.']
  network_config_id varchar [note: 'Foreign key linking to plan.network_config. Business justification: Dispensing pharmacy network tier assignment (in-network vs. out-of-network, preferred vs. standard) is governed by the plan\'s network_config. This link enables accurate in/out-of-network determination']
  party_id varchar [note: 'Foreign key linking to contract.party. Business justification: Dispensing pharmacies are contracted network parties. Health plan pharmacy network management — credentialing, NPI validation, sanction checks, network participation status — requires linking each dis']
  pbm_contract_id varchar [note: 'Foreign key linking to pharmacy.pbm_contract. Business justification: dispensing_pharmacy carries contract_type, contract_effective_date, and contract_termination_date as denormalized attributes. pbm_contract is the authoritative record governing PBM network participati']
  accepts_electronic_prescriptions boolean [note: 'Indicates whether the pharmacy is enabled to receive electronic prescriptions (e-prescribing) via NCPDP SCRIPT standard. Required for controlled substance e-prescribing (EPCS) compliance in many states.']
  address_line1 varchar [note: 'Primary street address of the pharmacy dispensing location. Used for member pharmacy locator, network directory, and regulatory reporting.']
  address_line2 varchar [note: 'Secondary address information (suite, unit, floor) for the pharmacy dispensing location.']
  awp_discount_percent decimal(5,2) [note: 'The contracted discount percentage applied to the AWP for brand drug ingredient cost reimbursement. For example, AWP minus 15% means awp_discount_percent = 15.00. Applies when ingredient_cost_basis is \'awp_discount\'. Commercially sensitive contract term.']
  chain_independent_flag boolean [note: 'Indicates whether the pharmacy is part of a chain organization (e.g., CVS, Walgreens, Rite Aid) or operates as an independent pharmacy. Affects contract terms, reimbursement rates, and network tier assignment.']
  chain_organization_name varchar [note: 'Name of the parent chain organization if the pharmacy is a chain location (e.g., CVS Health, Walgreens Boots Alliance). Null for independent pharmacies. Used for chain-level contract management and performance reporting.']
  city varchar [note: 'City of the pharmacy dispensing location. Used for geographic network analysis, member access reporting, and CMS Part D network adequacy compliance.']
  cold_chain_certified boolean [note: 'Indicates whether the pharmacy holds cold chain certification for temperature-sensitive drug storage and shipping (e.g., biologics, insulin, vaccines). Required for specialty and mail-order pharmacies dispensing refrigerated or frozen medications.']
  created_timestamp timestamp [note: 'Timestamp when the dispensing pharmacy record was first created in the PBM network master. Supports audit trail, data lineage, and regulatory record retention requirements.']
  dispensing_fee_amount decimal(8,2) [note: 'The contracted per-prescription dispensing fee paid to the pharmacy in addition to ingredient cost reimbursement. Expressed in USD. May vary by pharmacy type, drug type, or days supply. Commercially sensitive contract term.']
  dispensing_state_code varchar [note: 'Two-letter USPS state code of the state in which the pharmacy is licensed to dispense. May differ from the physical address state for mail-order pharmacies licensed in multiple states. Used for state-level regulatory compliance and claim adjudication.']
  doing_business_as_name varchar [note: 'Trade name or DBA name under which the pharmacy operates if different from the legal business name. Used in member-facing directories and communications.']
  fax_number varchar [note: 'Fax number for the pharmacy dispensing location. Used for prior authorization transmissions, prescription transfers, and clinical communications.']
  ingredient_cost_basis decimal(18,2) [note: 'The pricing benchmark used to calculate ingredient cost reimbursement for drug claims. AWP (Average Wholesale Price) discount is most common for brand drugs; MAC (Maximum Allowable Cost) applies to generics; WAC (Wholesale Acquisition Cost) and NADAC (National Average Drug Acquisition Cost) are alternative benchmarks. Sourced from PBM contract terms in RxClaim/Argus.']
  line_of_business varchar [note: 'The health insurance line of business for which this pharmacy network participation record applies. A pharmacy may have separate network records per LOB with different contract terms. Drives claim adjudication routing and formulary selection.']
  mail_order_capable boolean [note: 'Indicates whether the pharmacy is certified and operationally capable of fulfilling mail-order prescriptions (90-day supply, home delivery). Drives claim routing and member benefit design enforcement.']
  ncpdp_chain_code varchar [note: 'NCPDP-assigned 4-digit chain code identifying the pharmacy chain organization. Used for chain-level contract application and bulk reimbursement rate assignment in the PBM system.']
  ncpdp_provider_number varchar [note: 'The 7-digit NCPDP pharmacy identifier (formerly NABP number) used as the primary pharmacy identifier in PBM claim transactions, formulary lookups, and pharmacy network directories. Sourced from RxClaim or Argus PBM system.']
  network_effective_date date [note: 'Date on which the pharmacy\'s current network participation status became effective. Distinct from contract_effective_date; captures the most recent network status change date (e.g., reactivation after suspension).']
  network_participation_status varchar [note: 'Current status of the pharmacy\'s participation in the PBM network. Drives real-time claim adjudication eligibility checks in RxClaim/Argus. Active pharmacies are eligible to dispense covered drugs; inactive/terminated pharmacies are rejected at point-of-sale.']
  network_termination_date date [note: 'Date on which the pharmacy\'s network participation was or is scheduled to be terminated. Null for currently active network participants. Used for claim eligibility validation and network adequacy gap analysis.']
  network_tier varchar [note: 'Pharmacy network tier designation that determines member cost-sharing levels and reimbursement rates. Preferred pharmacies offer lower member cost-sharing; specialty tier applies to specialty drug dispensing locations.']
  performance_audit_provision boolean [note: 'Indicates whether the pharmacy contract includes audit provisions allowing the PBM or health plan to conduct on-site or desk audits of dispensing records, pricing, and compliance. Required for CMS Part D sponsor oversight obligations.']
  pharmacy_name varchar [note: 'Legal business name of the dispensing pharmacy as registered with the state board of pharmacy and NCPDP. Used in member-facing communications, EOB documents, and provider directory.']
  pharmacy_type varchar [note: 'Classification of the pharmacy by dispensing channel and operational model. Drives claim routing, reimbursement logic, and formulary applicability within the PBM system (RxClaim/Argus). [ENUM-REF-CANDIDATE: retail|mail_order|specialty|long_term_care|compounding — promote to reference product if additional types emerge]']
  phone_number varchar [note: 'Primary telephone number for the pharmacy dispensing location. Used for member contact, prior authorization coordination, and provider directory.']
  signature_required_flag boolean [note: 'Indicates whether the pharmacy requires patient or authorized representative signature upon delivery for mail-order or specialty drug shipments. Relevant for controlled substances and high-value specialty medications.']
  source_system_code varchar [note: 'Identifies the operational source system from which this pharmacy record was ingested (e.g., RxClaim, Argus PBM, Cactus credentialing system). Supports data lineage tracking and reconciliation in the Databricks lakehouse Silver layer.']
  specialty_accreditation_code varchar [note: 'Accreditation body certification held by the pharmacy for specialty drug dispensing. URAC, ACHC, and NABP PCAB are the primary specialty pharmacy accreditation bodies recognized by health plans and PBMs. Required for specialty network participation. [ENUM-REF-CANDIDATE: urac|achc|jcaho|nabp_pcab|none — promote to reference product if multi-accreditation tracking is needed]']
  state_code varchar [note: 'Two-letter USPS state abbreviation for the pharmacy dispensing location. Used for state-level licensure validation, network adequacy reporting, and regulatory compliance.']
  twenty_four_hour_flag boolean [note: 'Indicates whether the pharmacy operates 24 hours per day, 7 days per week. Used for network adequacy reporting and member access analysis, particularly for CMS Part D access requirements.']
  updated_timestamp timestamp [note: 'Timestamp when the dispensing pharmacy record was most recently updated. Used for change data capture, data quality monitoring, and audit trail in the Databricks Silver layer.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']
  zip_code varchar [note: 'US ZIP or ZIP+4 postal code for the pharmacy dispensing location. Used for geographic network adequacy analysis, member proximity calculations, and CMS Part D access reporting.']

  Note: 'Master record for retail, mail-order, and specialty pharmacies participating in the PBM network. Captures pharmacy identity: NPI, NCPDP provider ID, pharmacy name, chain/independent flag, pharmacy type (retail/mail/specialty/long-term care/compounding), address, phone, DEA number, state license. Captures network participation and contractual reimbursement terms: network tier (preferred/standard/specialty), network participation status, dispensing fee schedule, ingredient cost reimbursement basis (AWP discount/MAC/WAC), contract type (direct/PBM-administered), contract effective date range, performance requirements, audit provisions, mail-order fulfillment capabilities (cold chain certification, signature requirements), and per-pharmacy or per-chain contract variations. This is the SSOT for pharmacy provider identity, network participation, and all pharmacy-level reimbursement contract terms within the pharmacy domain; detailed credentialing lives in the provider/credential domains. [FHIR-aligned]'
}

Table pharmacy.pbm_contract {
  pbm_contract_id varchar [pk, note: 'Unique surrogate identifier for the PBM contract record in the pharmacy domain silver layer. Primary key for this entity. Role: MASTER_AGREEMENT.']
  formulary_id varchar [note: 'Reference to the drug formulary associated with this PBM contract. The formulary defines covered drugs, tier assignments, and utilization management rules governed by this contract.']
  party_id varchar [note: 'Foreign key linking to contract.party. Business justification: The PBM is a contracted legal entity tracked as a contract.party (TIN, NPI, legal name, credentialing status). PBM contract management, vendor oversight, and regulatory reporting (CMS PBM transparency']
  amendment_date date [note: 'Date of the most recent amendment or addendum executed against this PBM contract. Null if no amendments have been made since original execution. Used to track contract evolution and ensure current terms are applied in adjudication.']
  audit_frequency varchar [note: 'Contractually specified frequency at which the health plan may exercise audit rights over the PBM. Relevant only when audit_rights_flag is True. Drives compliance calendar and vendor oversight scheduling.']
  audit_rights_flag boolean [note: 'Indicates whether the health plan has contractual audit rights to inspect PBM financial records, rebate calculations, MAC list pricing, and claims adjudication data. True = audit rights granted; False = not included. Critical for compliance and financial oversight.']
  auto_renewal_flag boolean [note: 'Indicates whether the PBM contract automatically renews at the end of the contract term unless notice of termination is provided. True = auto-renews; False = requires affirmative renewal action.']
  awp_discount_mail_pct decimal(7,4) [note: 'Contracted discount percentage off AWP (Average Wholesale Price) applied to drug ingredient cost reimbursement at mail-order pharmacies. Typically deeper than retail AWP discounts due to mail-order volume.']
  awp_discount_retail_pct decimal(7,4) [note: 'Contracted discount percentage off AWP (Average Wholesale Price) applied to brand and generic drug ingredient cost reimbursement at retail pharmacies. A core financial term in PBM contracts (e.g., AWP minus 18% for generics).']
  cms_contract_number varchar [note: 'CMS (Centers for Medicare and Medicaid Services) contract number associated with the Medicare Part D plan under which this PBM contract operates (e.g., H1234 for MA-PD, S1234 for PDP). Required for CMS Part D reporting and RAPS/EDPS submissions. Null for non-Medicare LOBs.']
  contract_name varchar [note: 'Descriptive name of the PBM contract (e.g., \'Express Scripts ASO Agreement FY2024\'). Used for display in reporting dashboards and contract management workflows.']
  contract_number varchar [note: 'Externally-known, human-readable contract reference number assigned by the health plan or PBM vendor at execution. Used for correspondence, audits, and regulatory filings. Maps to the contract identifier in RxClaim or Argus PBM system.']
  contract_owner_name varchar [note: 'Name of the health plan employee or department responsible for managing this PBM contract relationship. Used for escalation routing, audit coordination, and vendor governance.']
  contract_status varchar [note: 'Current lifecycle state of the PBM contract. Draft indicates the contract is under negotiation; active indicates it is in force; suspended indicates temporarily halted; terminated indicates early cancellation; expired indicates natural end-of-term; pending_renewal indicates renewal is in progress.']
  contract_type varchar [note: 'Classification of the PBM contract arrangement. ASO (Administrative Services Only) means the health plan retains financial risk; full_risk means the PBM assumes drug spend risk; carve_out means pharmacy benefits are separated from medical; pass_through means drug costs are passed at actual cost; hybrid combines elements. [ENUM-REF-CANDIDATE: ASO|full_risk|carve_out|pass_through|hybrid — promote to reference product if additional types emerge]']
  contract_version varchar [note: 'Version identifier for the PBM contract document, incremented with each amendment or renewal (e.g., \'1.0\', \'2.1\', \'Amendment_3\'). Supports contract lifecycle management and audit trail for regulatory examinations.']
  dispensing_fee_mail_order decimal(10,4) [note: 'Contracted dispensing fee in USD paid per prescription claim fulfilled through mail-order pharmacy channels under this PBM contract. Typically lower than retail due to volume efficiencies.']
  dispensing_fee_retail decimal(10,4) [note: 'Contracted dispensing fee in USD paid to retail network pharmacies per prescription claim under this PBM contract. Part of the pharmacy reimbursement formula alongside ingredient cost (AWP/WAC/MAC).']
  dispensing_fee_specialty decimal(10,4) [note: 'Contracted dispensing fee in USD paid per specialty drug prescription claim under this PBM contract. Specialty pharmacy dispensing fees are negotiated separately due to the high-cost, high-touch nature of specialty drugs.']
  dur_program_flag boolean [note: 'Indicates whether Drug Utilization Review (DUR) — including prospective, concurrent, and retrospective DUR — is included as a service under this PBM contract. True = DUR services included; False = not included.']
  effective_date date [note: 'Date on which the PBM contract becomes legally binding and operationally active. Governs when PBM services, pricing schedules, and rebate guarantees take effect. Format: yyyy-MM-dd.']
  generic_dispensing_rate_guarantee decimal(7,4) [note: 'Contractually guaranteed minimum generic dispensing rate (GDR) as a percentage of total prescription claims. If the PBM fails to achieve this rate, financial penalties or credits apply. Key cost-management metric in PBM contracts.']
  governing_state_code varchar [note: 'Two-letter US state code of the state whose laws govern this PBM contract for dispute resolution and regulatory compliance purposes. Relevant for state DOI oversight, MAC transparency laws, and PBM regulation.']
  ingredient_cost_basis decimal(18,2) [note: 'The drug pricing benchmark used as the basis for ingredient cost reimbursement under this contract. AWP (Average Wholesale Price), WAC (Wholesale Acquisition Cost), MAC (Maximum Allowable Cost), NADAC (National Average Drug Acquisition Cost), or AAC (Actual Acquisition Cost). Determines the reimbursement formula for drug ingredient costs.']
  lob_scope varchar [note: 'Line of Business (LOB) covered under this PBM contract. Determines which member populations and benefit programs are governed by this agreement. A single contract may cover one or multiple LOBs. [ENUM-REF-CANDIDATE: commercial|medicare_part_d|medicaid|exchange|all — promote to reference product for multi-LOB support]']
  mac_list_reference varchar [note: 'Identifier or name of the MAC (Maximum Allowable Cost) list applied under this PBM contract for generic and multi-source drug reimbursement. MAC lists cap reimbursement for generics below AWP. References the specific MAC list version maintained by the PBM.']
  mail_order_flag boolean [note: 'Indicates whether mail-order pharmacy dispensing services are included in the scope of this PBM contract. True = mail order included; False = retail-only or carved out.']
  mail_order_penetration_guarantee decimal(7,4) [note: 'Contractually guaranteed minimum mail-order pharmacy utilization rate as a percentage of eligible maintenance drug claims. Drives cost savings through mail-order channel incentives.']
  performance_guarantee_flag boolean [note: 'Indicates whether the PBM contract includes financial performance guarantees (e.g., generic dispensing rate, mail-order penetration, member satisfaction scores). True = performance guarantees included; False = not included.']
  prior_auth_flag boolean [note: 'Indicates whether prior authorization (PA) requirements for specialty and non-formulary drugs are administered by the PBM under this contract. True = PBM manages PA; False = health plan manages PA internally.']
  quantity_limit_flag boolean [note: 'Indicates whether quantity limit (QL) utilization management rules are in scope under this PBM contract. Quantity limits restrict the amount of a drug dispensed per fill or per time period. True = quantity limits apply; False = not applicable.']
  rebate_guarantee_pmpm decimal(18,4) [note: 'Contractually guaranteed minimum rebate amount expressed as Per Member Per Month (PMPM) in USD that the PBM must remit to the health plan. A key financial performance guarantee in PBM contracts. Used for actuarial reserving and financial reconciliation.']
  rebate_pass_through_pct decimal(7,4) [note: 'Percentage of manufacturer drug rebates that the PBM is contractually obligated to pass through to the health plan (e.g., 100% pass-through vs. spread-based retention). Critical for MLR (Medical Loss Ratio) calculations and CMS Part D compliance.']
  rebate_reconciliation_lag_days decimal(18,2) [note: 'Number of calendar days after the close of a settlement period within which the PBM must provide rebate invoices and supporting data to the health plan. Used for financial close scheduling and IBNR reserve calculations.']
  rebate_settlement_frequency decimal(18,2) [note: 'Contractually specified frequency at which the PBM remits drug manufacturer rebates to the health plan. Drives cash flow forecasting, accounts receivable management, and actuarial IBNR (Incurred But Not Reported) rebate estimates.']
  record_created_timestamp timestamp [note: 'Timestamp when this PBM contract record was first created in the data platform. Used for audit trail, data lineage, and compliance with HIPAA record retention requirements. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  record_updated_timestamp timestamp [note: 'Timestamp when this PBM contract record was most recently modified in the data platform. Supports change detection, SCD (Slowly Changing Dimension) processing, and audit trail requirements. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  renewal_notice_days varchar [note: 'Number of calendar days prior to contract termination_date by which either party must provide written notice of intent not to renew. Operationally critical for contract management and vendor transitions.']
  source_system_code varchar [note: 'Identifies the operational source system from which this PBM contract record was ingested into the lakehouse silver layer (e.g., RxClaim, Argus, manual entry). Supports data lineage and reconciliation.']
  specialty_pharmacy_flag boolean [note: 'Indicates whether specialty pharmacy benefit management (high-cost biologics, specialty injectables) is within the scope of this PBM contract. True = specialty pharmacy included; False = carved out or not applicable.']
  step_therapy_flag boolean [note: 'Indicates whether step therapy protocols are included in the scope of this PBM contract. Step therapy requires members to try lower-cost drugs before coverage of higher-cost alternatives is authorized. True = step therapy applies; False = not applicable.']
  termination_date date [note: 'Date on which the PBM contract ends or was terminated. Null for open-ended contracts. Distinguishes between scheduled expiration and early termination when combined with contract_status. Format: yyyy-MM-dd.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Master record for PBM (Pharmacy Benefit Manager) contracts governing the relationship between the health plan and the PBM (e.g., RxClaim, Argus). Captures contract name, PBM vendor, contract type (ASO/full-risk/carve-out), effective date range, rebate guarantee terms, dispensing fee schedules, MAC list reference, performance guarantees, audit rights, and LOB scope. This is the SSOT for PBM contractual terms within the pharmacy domain. [FHIR-aligned]'
}

Table pharmacy.benefit_accumulator {
  benefit_accumulator_id varchar [pk, note: 'Primary key for benefit_accumulator']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Accumulator limits (deductible_limit_amt, moop_limit_amt) are defined at the benefit_package level. Multi-package plans require benefit_accumulator to reference the specific package to apply correct t']
  eligibility_span_id varchar [note: 'Foreign key linking to enrollment.enrollment_eligibility_span. Business justification: Benefit accumulators (deductible, OOP, MOOP) are scoped to a member\'s eligibility span — reset dates, benefit period, and coverage category on the accumulator must align with the governing eligibility']
  formulary_id varchar [note: 'Foreign key linking to pharmacy.formulary. Business justification: benefit_accumulator carries formulary_tier_applied as a denormalized STRING. Accumulator balances are tracked per benefit period and are formulary-specific (different formularies have different cost-s']
  health_plan_id varchar [note: 'Identifier for the health benefit plan under which the member is enrolled, determining the applicable deductible, OOP maximum, and Part D benefit phase thresholds.']
  medicare_entitlement_id varchar [note: 'Foreign key linking to enrollment.medicare_entitlement. Business justification: Medicare Part D accumulators (TrOOP, ICL, catastrophic phase) are exclusively governed by Medicare entitlement. benefit_accumulator carries part_d_benefit_phase, troop_applied_amt, icl_applied_amt — a']
  member_risk_score_id varchar [note: 'Foreign key linking to risk.member_risk_score. Business justification: CMS Part D payment reconciliation and LIS tier assignment (lis_level, lis_copay_tier, part_d_benefit_phase on benefit_accumulator) are directly driven by member risk scores. CMS requires linking accum']
  member_subscriber_id varchar [note: 'Unique identifier for the health plan member whose pharmacy benefit accumulators are being tracked. Links to the member master record in the enrollment system (Facets/QNXT).']
  pharmacy_claim_id varchar [note: 'Identifier of the most recent pharmacy claim that triggered an update to this accumulator record. Supports audit trail and real-time adjudication reconciliation.']
  plan_election_id varchar [note: 'Foreign key linking to enrollment.plan_election. Business justification: Accumulators are scoped to a member\'s specific plan election — the elected plan determines deductible, OOP, and MOOP limits. Mid-year plan changes via QLE require new accumulator records per election.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Accumulators (deductible, OOP, TROOP) are policy-specific. COB scenarios require per-policy accumulator tracking. Annual reset logic and CMS Part D reconciliation depend on policy linkage. benefit_acc']
  accumulator_reset_date date [note: 'Date on which the accumulator balances were last reset to zero, typically at the start of a new benefit year. Supports annual reconciliation and audit of accumulator lifecycle.']
  accumulator_source_system varchar [note: 'Identifies the operational system of record that originated or last updated this accumulator record (e.g., RxClaim, Argus PBM, Facets, QNXT). Supports data lineage, reconciliation, and audit trail requirements.']
  accumulator_status varchar [note: 'Current lifecycle state of the accumulator record. \'active\' indicates in-use for real-time adjudication; \'suspended\' indicates member eligibility gap; \'closed\' indicates benefit period ended; \'pending_reset\' indicates awaiting annual reset; \'reconciled\' indicates CMS or plan reconciliation completed.']
  accumulator_version varchar [note: 'Optimistic locking version counter incremented with each update to the accumulator record. Supports concurrent adjudication event handling and prevents race conditions in real-time point-of-sale updates.']
  benefit_period_end_date date [note: 'Last date of the benefit year or coverage period to which this accumulator record applies. Defines the boundary for annual accumulator reset.']
  benefit_period_start_date date [note: 'First date of the benefit year or coverage period to which this accumulator record applies. Accumulators reset at the start of each new benefit period.']
  catastrophic_applied_amt decimal(18,2) [note: 'Cumulative drug cost amounts applied toward the Medicare Part D catastrophic coverage threshold. Tracks member spend after exiting the coverage gap and entering catastrophic coverage.']
  catastrophic_limit_amt decimal(18,2) [note: 'The Medicare Part D catastrophic coverage threshold amount for the current benefit year. Once TrOOP reaches this level, the member qualifies for catastrophic cost-sharing rates. Published annually by CMS.']
  cms_reconciliation_status varchar [note: 'Status of the CMS annual Part D reconciliation process for this accumulator record. Tracks whether the accumulator data has been submitted to and accepted by CMS via RAPS/EDPS for risk adjustment and subsidy reconciliation.']
  coordination_of_benefits_type varchar [note: 'Indicates the coordination of benefits (COB) role of this plan for the member\'s pharmacy benefit. Determines how accumulator amounts are applied when multiple payers are involved.']
  coverage_gap_discount_applied_amt decimal(18,2) [note: 'Cumulative manufacturer discount amounts applied to brand-name drugs while the member is in the Medicare Part D coverage gap (donut hole). These discounts count toward TrOOP under the ACA Coverage Gap Discount Program.']
  created_timestamp timestamp [note: 'Date and time when this accumulator record was first created in the Silver Layer lakehouse. Supports audit trail and data lineage requirements.']
  deductible_applied_amt decimal(18,2) [note: 'Cumulative dollar amount the member has applied toward their pharmacy deductible in the current benefit period. Updated with each pharmacy claim adjudication event. Used at point of sale to determine member cost-sharing responsibility.']
  deductible_limit_amt decimal(18,2) [note: 'Total pharmacy deductible amount the member must satisfy before plan cost-sharing begins, as defined in the benefit plan design for the current benefit period.']
  eob_generated_flag boolean [note: 'Indicates whether an Explanation of Benefits (EOB) has been generated for the member reflecting the current accumulator balances. Supports member communication and regulatory EOB delivery requirements.']
  family_deductible_applied_amt decimal(18,2) [note: 'Cumulative dollar amount applied toward the family-level pharmacy deductible for plans with embedded or aggregate family deductible structures. Applicable for commercial group plans with family coverage tiers.']
  family_oop_applied_amt decimal(18,2) [note: 'Cumulative out-of-pocket spend applied toward the family-level MOOP for plans with family OOP limits. Tracks combined member cost-sharing across all family members enrolled under the same plan.']
  hsa_eligible_applied_amt decimal(18,2) [note: 'Cumulative amount of pharmacy cost-sharing that qualifies as HSA-eligible expenses under IRS rules for members enrolled in a High Deductible Health Plan (HDHP). Supports member HSA contribution and tax reporting.']
  icl_applied_amt decimal(18,2) [note: 'Cumulative total drug costs (plan paid plus member cost-sharing) applied toward the Medicare Part D Initial Coverage Limit (ICL). When this amount reaches the ICL threshold, the member enters the coverage gap (donut hole).']
  icl_limit_amt decimal(18,2) [note: 'The Medicare Part D Initial Coverage Limit (ICL) threshold amount for the current benefit year, as published annually by CMS. Defines the boundary between the initial coverage phase and the coverage gap (donut hole).']
  is_deductible_met boolean [note: 'Indicates whether the member has fully satisfied their pharmacy deductible for the current benefit period. When true, plan cost-sharing (copay/coinsurance) applies rather than full deductible responsibility.']
  is_moop_met boolean [note: 'Indicates whether the member has reached their maximum out-of-pocket (MOOP) limit for the current benefit period. When true, the plan covers 100% of covered pharmacy costs for the remainder of the benefit period.']
  last_adjudication_timestamp timestamp [note: 'Date and time of the most recent pharmacy claim adjudication event that updated this accumulator record. Critical for real-time point-of-sale cost-sharing calculation and concurrency control.']
  line_of_business varchar [note: 'The line of business (LOB) under which the member\'s pharmacy benefit is administered. Determines applicable regulatory framework, benefit phase rules, and accumulator logic (e.g., Part D coverage gap applies only to Medicare Part D).']
  lis_copay_tier decimal(18,2) [note: 'The applicable LIS copay tier for the member, determining the fixed copay amounts for generic, preferred brand, non-preferred, and specialty drugs under the Low-Income Subsidy (LIS) program.']
  lis_level varchar [note: 'Low-Income Subsidy (LIS) eligibility level for Medicare Part D members, determining reduced cost-sharing amounts. \'full\' indicates 100% subsidy; \'partial_1/2/3\' indicate graduated subsidy tiers; \'none\' indicates no LIS. Affects TrOOP accumulation rules.']
  mail_order_applied_amt decimal(18,2) [note: 'Cumulative cost-sharing amount applied for drugs dispensed through mail-order pharmacy channels in the current benefit period. Supports mail-order utilization reporting and member EOB generation.']
  moop_limit_amt decimal(18,2) [note: 'The maximum out-of-pocket (MOOP) dollar threshold the member must reach before the plan covers 100% of covered pharmacy costs for the remainder of the benefit period. Set per plan design and ACA/CMS requirements.']
  oop_applied_amt decimal(18,2) [note: 'Cumulative out-of-pocket (OOP) spend by the member for pharmacy benefits in the current benefit period, including deductible, copays, and coinsurance. Used to track progress toward the maximum out-of-pocket (MOOP) limit.']
  part_d_benefit_phase varchar [note: 'Current Medicare Part D benefit phase for the member based on accumulated TrOOP and ICL amounts. Drives cost-sharing calculation at point of sale. \'not_applicable\' for non-Part D lines of business.']
  pbm_member_code varchar [note: 'Member identifier assigned by the Pharmacy Benefit Manager (PBM) system (RxClaim or Argus). Used to cross-reference accumulator balances between the health plan and PBM for reconciliation.']
  rx_claim_count varchar [note: 'Total number of pharmacy claims adjudicated and applied to this accumulator record in the current benefit period. Used for utilization reporting and EOB generation.']
  specialty_drug_applied_amt decimal(18,2) [note: 'Cumulative cost-sharing amount applied specifically for specialty tier drugs in the current benefit period. Tracked separately to support specialty pharmacy reporting, prior authorization analytics, and plan design evaluation.']
  third_party_applied_amt decimal(18,2) [note: 'Cumulative dollar amount paid by third parties (e.g., manufacturer copay assistance programs, other insurance) toward the member\'s pharmacy cost-sharing. Tracked separately as these amounts may not count toward TrOOP under CMS rules.']
  troop_applied_amt decimal(18,2) [note: 'Cumulative true out-of-pocket (TrOOP) expenditure for Medicare Part D members, counting only qualifying cost-sharing amounts toward the catastrophic coverage threshold. Excludes amounts paid by third parties not qualifying under CMS TrOOP rules. Required for CMS Part D benefit phase determination.']
  troop_limit_amt decimal(18,2) [note: 'The annual TrOOP threshold amount that, when reached, transitions a Medicare Part D member into catastrophic coverage. Published annually by CMS as part of the Part D benefit parameters.']
  updated_timestamp timestamp [note: 'Date and time when this accumulator record was most recently modified, reflecting the latest claim adjudication event or manual adjustment. Supports concurrency control and audit trail.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Tracks member-level pharmacy benefit accumulator balances including deductible applied, out-of-pocket (OOP) spend, maximum out-of-pocket (MOOP) progress, true out-of-pocket (TrOOP) for Medicare Part D, initial coverage limit (ICL) progress, and catastrophic coverage threshold. Updated in real-time with each pharmacy claim adjudication event. Supports real-time cost-sharing calculation at point of sale, coverage gap (donut hole) determination for Part D members, low-income subsidy (LIS) cost-sharing adjustments, and member Explanation of Benefits (EOB) generation. Critical for CMS Part D benefit phase tracking and annual reconciliation. [FHIR-aligned]'
}

Table billing.premium_invoice {
  premium_invoice_id decimal(18,2) [pk, note: 'System-generated unique identifier for the premium invoice record.']
  account_id varchar [note: 'Foreign key linking to billing.account. Business justification: Every premium invoice is issued against a master billing account. The account entity represents the financial relationship between the health plan and the billing entity (employer group or individual)']
  aptc_subsidy_id decimal(18,2) [note: 'Foreign key linking to billing.aptc_subsidy. Business justification: ACA premium invoices for subsidized members are directly tied to an APTC/CSR subsidy record. The aptc_subsidy table is the authoritative source for subsidy amounts and types. Adding aptc_subsidy_id to']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Premium invoices are generated for a specific benefit package enrollment. Invoice amount, coverage tier, and billing period are directly driven by the benefit_package. Premium billing reconciliation a']
  member_identity_id varchar [note: 'Identifier of the individual member associated with the invoice, if applicable.']
  plan_election_id varchar [note: 'Foreign key linking to enrollment.plan_election. Business justification: Premium invoices are initiated by plan elections — the election determines premium amount, coverage tier, and billing frequency. Billing operations and premium audit processes require tracing each inv']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Premium invoices are generated per policy. Invoice generation, premium rate application, coverage-period billing, and policy renewal billing all require the direct policy link. A health insurance bill']
  billing_period_end date [note: 'Last day of the coverage period for which the premium is billed.']
  billing_period_start date [note: 'First day of the coverage period for which the premium is billed.']
  collection_status varchar [note: 'Current state of the collection effort for the invoice.']
  created_timestamp timestamp [note: 'Timestamp when the invoice record was first created in the data lake.']
  currency_code varchar [note: 'Three‑letter ISO currency code for monetary amounts.']
  delivery_method varchar [note: 'Channel used to deliver the invoice to the recipient.']
  discount_amount decimal(18,2) [note: 'Any discount (e.g., early‑pay, promotional) applied to the invoice.']
  due_date date [note: 'Date by which payment must be received to avoid delinquency.']
  grace_period_days varchar [note: 'Number of days after due date before the invoice is considered delinquent.']
  invoice_number varchar [note: 'External invoice number assigned by the billing system, used for member and regulator reference.']
  invoice_status varchar [note: 'Current processing state of the invoice.']
  invoice_type varchar [note: 'Classification of the invoice based on the recipient and billing arrangement.']
  is_eligible_for_subsidy boolean [note: 'Flag indicating whether the member/group qualifies for a premium subsidy.']
  issue_timestamp timestamp [note: 'Exact time the invoice was generated and issued to the recipient.']
  line_of_business varchar [note: 'Business segment to which the invoice belongs.']
  net_amount_due decimal(18,2) [note: 'Final amount the recipient must pay after adjustments.']
  notes varchar [note: 'Optional comments or remarks added by billing staff.']
  payment_channel varchar [note: 'Interface through which the payment was made.']
  payment_method varchar [note: 'Primary instrument used to settle the invoice.']
  refund_amount decimal(18,2) [note: 'Amount returned to the payer for over‑payment or claim reversal.']
  regulatory_reporting_flag boolean [note: 'Indicates if the invoice must be reported to CMS or state DOI for compliance.']
  retroactive_adjustment_amount decimal(18,2) [note: 'Adjustment for prior‑period premium changes applied to the current invoice.']
  source_system_invoice_reference varchar [note: 'Original invoice identifier from the source billing system.']
  statement_number varchar [note: 'Unique identifier for an individual member statement when invoice_type is individual_statement.']
  tax_amount decimal(18,2) [note: 'Tax applied to the premium, if applicable.']
  total_premium_amount decimal(18,2) [note: 'Gross premium before any subsidies, taxes, or discounts.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the invoice record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Core billing document representing a premium invoice or statement issued to an employer group, individual member (IFP/ACA marketplace direct-pay), COBRA qualified beneficiary, or government sponsor for a specific billing period. Captures invoice number, billing period start/end, total premium due, subsidy/APTC amounts applied, net amount due, invoice status (draft, issued, paid, partially paid, void, delinquent), due date, document type (group list-bill invoice, group self-bill invoice, individual member statement, COBRA invoice, government remittance request), delivery method (mail, email, member portal), line-of-business (LOB), statement-specific fields for IFP direct-pay members (statement number, member reference, plan name, statement delivery preference), and source system reference from HealthEdge or custom billing platform. SSOT for ALL premium billing documents — both group invoices and individual member statements — in the billing domain. [FHIR-aligned]'
}

Table billing.invoice_line {
  invoice_line_id varchar [pk, note: 'System-generated unique identifier for the invoice line record.']
  aptc_subsidy_id decimal(18,2) [note: 'Foreign key linking to billing.aptc_subsidy. Business justification: Invoice lines for ACA members carry APTC and CSR subsidy amounts. Linking invoice_line to aptc_subsidy enables line-level subsidy reconciliation and joins to the authoritative subsidy record. aptc_sub']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Each invoice line represents a premium charge for a specific benefit package. CSR adjustments, APTC allocation, and coverage tier pricing on invoice lines are all benefit_package-driven. Regulatory AC']
  member_identity_id varchar [note: 'Unique identifier of the covered member or subscriber for this premium charge.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Each invoice line item corresponds to a specific policy\'s coverage period and premium tier. Policy-level line-item detail is required for premium reconciliation, retroactive adjustment processing, and']
  premium_invoice_id decimal(18,2) [note: 'Identifier of the parent invoice header to which this line belongs.']
  program_id varchar [note: 'Foreign key linking to care.program. Business justification: Care Management Program Fee Billing: health insurers bill employer groups and members PMPM fees for specific disease management and case management programs. Invoice lines representing these program f']
  rate_id varchar [note: 'Foreign key linking to plan.rate. Business justification: Each invoice line premium amount is computed from a specific rate record. Billing integrity audits, rate change impact analysis, and state regulatory rate filing reconciliation require tracing each in']
  adjustment_reason_code varchar [note: 'Code indicating the business reason for a premium adjustment.']
  adjustment_reason_description varchar [note: 'Human‑readable description of the adjustment reason.']
  aptc_subsidy_amount decimal(18,2) [note: 'Advanced Premium Tax Credit amount applied to reduce the member\'s premium.']
  billing_period_end date [note: 'End date of the billing period associated with this line.']
  billing_period_start date [note: 'Start date of the billing period associated with this line.']
  coverage_end_date date [note: 'Last day of coverage for which the premium is billed (nullable for open‑ended coverage).']
  coverage_start_date date [note: 'First day of coverage for which the premium is billed.']
  coverage_tier varchar [note: 'Classification of the coverage level for the member (e.g., employee only, employee + spouse, employee + child, family).']
  created_timestamp timestamp [note: 'Date‑time when the invoice line record was first created in the system.']
  csr_adjustment_amount decimal(18,2) [note: 'Amount of cost-sharing reduction (CSR) applied to the premium.']
  employee_contribution decimal(12,2) [note: 'Portion of the premium paid by the employee (or subscriber).']
  employer_contribution decimal(12,2) [note: 'Portion of the premium paid by the employer on behalf of the member.']
  is_refund boolean [note: 'True if this line represents a refund rather than a charge.']
  line_sequence varchar [note: 'Sequential order of the line within the invoice.']
  payment_due_date date [note: 'Date by which payment for this premium line is due.']
  payment_status varchar [note: 'Current payment status for the premium line.']
  premium_amount decimal(18,2) [note: 'Base premium amount before any contributions, subsidies, or adjustments.']
  premium_currency varchar [note: 'Three‑letter ISO currency code for the premium amounts.']
  premium_line_description varchar [note: 'Free‑form description of the premium line (e.g., "Monthly medical premium for employee only").']
  premium_reconciliation_flag boolean [note: 'Indicates whether the line has been reconciled to the general ledger.']
  premium_source_system varchar [note: 'Name of the source system that generated the premium line (e.g., HealthEdge, CustomBilling).']
  premium_status varchar [note: 'Current processing status of the premium line.']
  refund_amount decimal(18,2) [note: 'Amount refunded to the member or employer for this line (if applicable).']
  regulatory_reporting_flag boolean [note: 'True if this line must be included in regulatory reports (e.g., CMS, state DOI).']
  retroactive_adjustment_flag boolean [note: 'Flag indicating whether this line reflects a retroactive premium adjustment.']
  tax_amount decimal(18,2) [note: 'Tax component applied to the premium line, if applicable.']
  total_amount decimal(18,2) [note: 'Final amount after employer/employee contributions, subsidies, adjustments, and taxes.']
  updated_timestamp timestamp [note: 'Date‑time of the most recent update to the invoice line record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Line-item detail within a premium invoice, representing a single member or subscriber coverage charge for a billing period. Captures member/subscriber reference, plan code, coverage tier (EE, EE+SP, EE+CH, FAM), rate type, gross premium, employer contribution, employee contribution, APTC subsidy amount, CSR adjustment, retroactive adjustment indicator, and effective coverage dates. Supports PMPM-level billing reconciliation. [FHIR-aligned]'
}

Table billing.premium_payment {
  premium_payment_id decimal(18,2) [pk, note: 'System-generated unique identifier for the premium payment record.']
  account_id varchar [note: 'Foreign key linking to billing.account. Business justification: Premium payments are made against a billing account. The account is the financial entity that owns the payment relationship with the health plan. Linking premium_payment to account enables account-lev']
  member_identity_id varchar [note: 'Identifier of the member associated with the premium payment.']
  payment_method_id decimal(18,2) [note: 'Foreign key linking to billing.payment_method. Business justification: A premium payment is executed using a specific authorized payment method (ACH, credit card, check) registered in the payment_method table. The existing `payment_method` column on premium_payment is ty']
  policy_id varchar [note: 'Identifier of the insurance policy to which the premium payment applies.']
  premium_invoice_id decimal(18,2) [note: 'Identifier of the premium invoice that this payment is applied to.']
  adjustment_amount decimal(18,2) [note: 'Total of fees, discounts, or other adjustments applied to the gross amount.']
  batch_number varchar [note: 'Identifier of the processing batch that included this payment.']
  created_timestamp timestamp [note: 'Timestamp when the payment record was first created in the system.']
  currency_code varchar [note: 'Three‑letter ISO currency code of the payment.']
  fee_amount decimal(18,2) [note: 'Any processing or service fees associated with the payment.']
  net_amount decimal(18,2) [note: 'Final amount after adjustments, representing the amount applied to the invoice.']
  nsf_indicator boolean [note: 'True if the payment was returned due to non‑sufficient funds.']
  payer_account_number varchar [note: 'Account number or identifier used by the payer for the transaction.']
  payer_name varchar [note: 'Legal name of the entity making the payment.']
  payer_type varchar [note: 'Classification of the payer (e.g., employer, individual member, CMS, state Medicaid agency).']
  payment_amount decimal(18,2) [note: 'Total amount received before any adjustments.']
  payment_channel decimal(18,2) [note: 'Interface through which the payment was submitted.']
  payment_description decimal(18,2) [note: 'Free‑form description or notes about the payment.']
  payment_number decimal(18,2) [note: 'Unique payment reference number assigned by the billing system.']
  payment_timestamp decimal(18,2) [note: 'Date and time when the payment was received.']
  premium_payment_status decimal(18,2) [note: 'Current lifecycle state of the payment.']
  reconciliation_status varchar [note: 'Status of the payment in the accounting reconciliation process.']
  resolution_date date [note: 'Date the suspense item was resolved.']
  resolution_due_date date [note: 'Target date by which the suspense item should be resolved.']
  resolution_outcome varchar [note: 'Result of the suspense investigation.']
  suspense_reason_code varchar [note: 'Code indicating why the payment is in suspense (e.g., unidentified payer, amount mismatch).']
  suspense_resolver varchar [note: 'Name of the employee or system responsible for investigating the suspense item.']
  suspense_status varchar [note: 'Current status of the payment within the suspense workflow.']
  tax_amount decimal(18,2) [note: 'Tax component of the payment, if applicable.']
  transaction_type varchar [note: 'Classification of the payment transaction.']
  unapplied_amount decimal(18,2) [note: 'Portion of the payment that could not be matched to an invoice and is placed in suspense.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the payment record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Records an actual payment received against a premium invoice, capturing payment date, payment amount, payment method (ACH, check, wire, credit card, EFT), payment reference number, payer type (employer group, individual member, CMS, state Medicaid agency), applied invoice reference, unapplied/suspense balance, NSF/return indicator, reconciliation status, and full suspense management lifecycle (suspense status, suspense reason code — unidentified payer, amount mismatch, duplicate payment, missing invoice reference — received amount, receipt date, payer name, payer account reference, assigned resolver, resolution due date, resolution outcome — applied to invoice, refunded, written off — resolution date). Payments in suspense status are tracked inline with complete resolution workflow rather than in a separate suspense entity. SSOT for all inbound premium cash receipts including suspense items, their investigation, and resolution lifecycle. [FHIR-aligned]'
}

Table billing.payment_allocation {
  payment_allocation_id decimal(18,2) [pk, note: 'System-generated unique identifier for each payment allocation record.']
  invoice_line_id varchar [note: 'Identifier of the invoice line to which the payment amount is allocated.']
  outcome_id varchar [note: 'Foreign key linking to appeal.outcome. Business justification: Appeal-driven payment remediation: when an appeal outcome mandates a financial remedy (refund, credit, reallocation), a payment_allocation record executes that remedy. Linking allocation to the trigge']
  premium_payment_id decimal(18,2) [note: 'Identifier of the premium payment that is being allocated.']
  allocated_amount decimal(18,2) [note: 'Monetary amount of the premium that is allocated to the invoice line.']
  allocated_quantity decimal(12,2) [note: 'Quantity of premium units (e.g., member‑months) allocated to the invoice line.']
  allocation_date date [note: 'Calendar date on which the allocation was recorded.']
  allocation_sequence varchar [note: 'Sequential order of allocation lines within the same payment.']
  allocation_status varchar [note: 'Current processing status of the allocation record.']
  allocation_type varchar [note: 'Classification of the allocation purpose (e.g., standard payment, partial payment, over‑payment, suspense resolution, adjustment, refund).']
  created_timestamp timestamp [note: 'Timestamp when the allocation record was first created in the system.']
  currency_code varchar [note: 'Three‑letter ISO 4217 code of the currency for the allocated amount.']
  discount_amount decimal(18,2) [note: 'Discount or credit applied to the allocated premium.']
  effective_from date [note: 'Date when the allocation becomes effective for accounting purposes.']
  effective_until date [note: 'Date when the allocation ceases to be effective (null if open‑ended).']
  is_overpayment boolean [note: 'Indicates whether the allocation represents an overpayment scenario.']
  is_suspense_resolution boolean [note: 'True when the allocation resolves a suspense balance.']
  notes varchar [note: 'Free‑form comments or remarks about the allocation.']
  payment_channel varchar [note: 'Channel through which the payment was submitted.']
  payment_method varchar [note: 'Instrument used to make the premium payment.']
  reconciliation_period varchar [note: 'Period identifier (e.g., 2023-04) for the premium reconciliation cycle.']
  reconciliation_status varchar [note: 'Current lifecycle state of the reconciliation record.']
  reconciliation_type varchar [note: 'Frequency classification of the reconciliation (e.g., monthly, quarterly).']
  tax_amount decimal(18,2) [note: 'Tax component associated with the allocated premium.']
  total_adjustments decimal(18,2) [note: 'Aggregate of all adjustments (e.g., refunds, credits) applied during the period.']
  total_billed decimal(18,2) [note: 'Sum of all invoice line amounts billed for the reconciliation period.']
  total_collected decimal(18,2) [note: 'Sum of all payments collected for the reconciliation period.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the allocation record.']
  variance_amount decimal(18,2) [note: 'Difference between total billed and total collected after adjustments.']
  variance_reason varchar [note: 'Explanation for any variance observed in the reconciliation.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Association and reconciliation entity linking premium payments to invoice lines, tracking line-level allocation, and managing periodic premium reconciliation outcomes. For allocation: captures allocated amount, allocation date, allocation type (standard, partial, overpayment, suspense resolution), and line-level reconciliation status. Supports many-to-many payment-to-invoice matching and enables accurate accounts receivable aging. For periodic reconciliation: captures reconciliation period, total billed, total collected, total adjustments, variance amount, variance reason, reconciliation status (open, in review, approved, closed), approver reference, and reconciliation type (monthly, quarterly, annual). Supports MLR calculation inputs, financial close processes, CMS premium reconciliation, and end-to-end premium reconciliation from individual line-level allocation through period-level summary and variance analysis. SSOT for all payment allocation and premium reconciliation in the billing domain. [FHIR-aligned]'
}

Table billing.account {
  account_id varchar [pk, note: 'System-generated unique identifier for the billing account.']
  party_id varchar [note: 'Foreign key linking to contract.party. Business justification: Employer group and provider billing accounts must be linked to their contracting party entity for group premium billing setup, contract compliance verification, and billing eligibility determination. ']
  account_number varchar [note: 'External account number assigned to the billing entity for invoicing and payment processing.']
  account_status varchar [note: 'Current lifecycle status of the billing account.']
  account_type varchar [note: 'Classification of the billing entity (e.g., employer group, individual subscriber, government program).']
  apr_rate decimal(5,2) [note: 'Percentage rate applied to calculate the annual premium for the account.']
  aptc_amount decimal(18,2) [note: 'Amount of ACA premium tax credit applied to the account.']
  auto_pay_authorization_date date [note: 'Date when the auto‑pay authorization was granted.']
  auto_pay_authorization_flag boolean [note: 'Indicates whether the account holder has authorized automatic payments.']
  auto_pay_enrollment boolean [note: 'Indicates whether the account is enrolled in automatic payment processing.']
  auto_renewal_flag boolean [note: 'Indicates whether the account automatically renews at the end of its term.']
  billing_calendar_reference varchar [note: 'Identifier for the calendar configuration governing billing cycles.']
  billing_cycle_type varchar [note: 'Configuration of the recurring billing cycle for the account.']
  billing_frequency varchar [note: 'How often invoices are generated for this account.']
  billing_method varchar [note: 'Method used to deliver bills to the account holder.']
  collection_status varchar [note: 'Current status of the collection effort for overdue balances.']
  created_timestamp timestamp [note: 'Timestamp when the billing account record was first created in the system.']
  credit_limit decimal(15,2) [note: 'Maximum credit amount authorized for the billing entity.']
  currency_code varchar [note: 'Three‑letter ISO currency code for all monetary amounts on the account.']
  current_balance decimal(18,2) [note: 'Outstanding monetary balance on the account as of the latest reconciliation.']
  effective_from date [note: 'Date when the billing account became effective.']
  effective_until date [note: 'Date when the billing account is scheduled to terminate (null if open‑ended).']
  grace_period_days varchar [note: 'Number of days after the due date before the account is considered delinquent.']
  invoice_generation_day varchar [note: 'Day of month when the invoice is generated (1‑31).']
  last_invoice_date date [note: 'Date when the most recent invoice was generated.']
  last_payment_amount decimal(18,2) [note: 'Monetary amount of the most recent payment.']
  last_payment_date date [note: 'Date of the most recent payment received for the account.']
  next_invoice_date date [note: 'Scheduled date for the next invoice issuance.']
  notes varchar [note: 'Free‑form text field for internal comments or special instructions related to the account.']
  payment_due_amount decimal(18,2) [note: 'Total amount currently due on the account, including any pending charges.']
  payment_due_day varchar [note: 'Day of month by which payment must be received.']
  payment_terms varchar [note: 'Contractual terms defining when payment is due after invoice issuance.']
  pmpm_rate decimal(5,2) [note: 'Rate used to calculate monthly charges on a per‑member basis.']
  regulatory_reporting_flag boolean [note: 'Indicates whether the account is subject to special regulatory reporting (e.g., CMS, state DOI).']
  subsidy_amount decimal(18,2) [note: 'Total subsidy applied to the account (e.g., employer or government subsidies).']
  tax_exempt_flag boolean [note: 'Indicates whether the account is exempt from sales or other applicable taxes.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the billing account record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Master billing account representing the financial relationship between the health plan and a billing entity — employer group, individual subscriber, or government program (Medicare, Medicaid, CHIP). Captures account number, account type, billing frequency (monthly, quarterly, annual), billing method (self-bill, list-bill, direct-bill), payment terms, auto-pay enrollment, current balance, credit limit, account status, assigned billing representative, billing cycle configuration (cycle type — monthly/quarterly/semi-annual/annual, invoice generation date, payment due date, grace period days, next/last invoice dates, auto-renewal flag, billing calendar reference), and registered payment methods (payment method type — ACH/EFT, check, wire transfer, credit card, debit card, HSA/FSA — with masked/tokenized bank routing and account numbers, card last four digits, card expiration date, auto-pay authorization flag, authorization date and reference, active/inactive status per method, PCI-DSS compliant storage). SSOT for billing account identity, billing cycle configuration, and authorized payment methods. [FHIR-aligned]'
}

Table billing.grace_period {
  grace_period_id varchar [pk, note: 'System-generated unique identifier for the grace period record.']
  account_id varchar [note: 'Identifier of the billing account to which this grace period applies.']
  aptc_subsidy_id decimal(18,2) [note: 'Foreign key linking to billing.aptc_subsidy. Business justification: ACA grace periods are specifically governed by APTC subsidy eligibility — the 3-month grace period rule applies to APTC-receiving members. Linking grace_period to aptc_subsidy identifies which subsidy']
  member_identity_id varchar [note: 'Identifier of the member associated with the account for this grace period.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Grace periods are tracked per policy under ACA rules (3-month grace for APTC recipients). Policy termination processing, reinstatement decisions, and state regulatory compliance all require knowing wh']
  premium_invoice_id decimal(18,2) [note: 'Identifier of the invoice that triggered the grace period.']
  premium_payment_id decimal(18,2) [note: 'Foreign key linking to billing.premium_payment. Business justification: A grace period is resolved when a premium payment is received. Linking grace_period to the resolving premium_payment enables tracking of which specific payment closed the grace period. grace_period al']
  created_timestamp timestamp [note: 'Timestamp when the grace period record was first created in the system.']
  day_count varchar [note: 'Number of days elapsed since the start of the grace period.']
  description varchar [note: 'Free-text description providing additional context for the grace period.']
  end_date date [note: 'Date when the grace period is scheduled to end.']
  extension_end_date date [note: 'New end date if the grace period was extended.']
  extension_flag boolean [note: 'Indicates whether the original grace period was extended.']
  grace_period_number varchar [note: 'External business identifier for the grace period, used in reporting and member communications.']
  grace_period_status varchar [note: 'Current lifecycle status of the grace period.']
  grace_period_type varchar [note: 'Classification of the grace period based on product or regulatory rules.']
  is_eligible_for_aptc boolean [note: 'Indicates if the member is eligible for Advanced Premium Tax Credit during this grace period.']
  jurisdiction varchar [note: 'Regulatory jurisdiction applicable to the grace period.']
  notes varchar [note: 'Additional free-form notes captured by the billing team.']
  outcome varchar [note: 'Result of the grace period after it ends.']
  payment_due_date date [note: 'The date by which the premium payment was originally due before the grace period started.']
  payment_received_date date [note: 'Date on which the overdue payment was received, if applicable.']
  reason_code varchar [note: 'Code indicating why the grace period was initiated.']
  regulatory_reporting_flag boolean [note: 'Indicates whether this grace period must be reported to CMS or state DOI.']
  start_date date [note: 'Date when the grace period began.']
  state_code varchar [note: 'Two-letter state abbreviation for jurisdictional reporting. [ENUM-REF-CANDIDATE: AL|AK|AZ|AR|CA|CO|CT|DE|FL|GA|HI|ID|IL|IN|IA|KS|KY|LA|ME|MD|MA|MI|MN|MS|MO|MT|NE|NV|NH|NJ|NM|NY|NC|ND|OH|OK|OR|PA|RI|SC|SD|TN|TX|UT|VT|VA|WA|WV|WI|WY — promote to reference product]']
  subsidy_amount decimal(18,2) [note: 'Monetary amount of any subsidy applied during the grace period.']
  termination_warning_issued boolean [note: 'Indicates whether a termination warning has been sent to the member.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the grace period record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Tracks the grace period status for a billing account or member when premium payment is overdue. Captures grace period start date, grace period end date (typically 30 days for individual/ACA, 31 days for group), grace period type (ACA APTC grace period is 90 days), triggering invoice reference, current grace period day count, termination warning issued flag, and resolution outcome (paid, terminated, reinstated). Required for ACA compliance and state DOI reporting. [FHIR-aligned]'
}

Table billing.aptc_subsidy {
  aptc_subsidy_id decimal(18,2) [pk, note: 'System-generated unique identifier for the APTC subsidy record.']
  member_identity_id varchar [note: 'Unique identifier of the member receiving the subsidy.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: APTC subsidies are applied to specific QHP policies on the ACA exchange. CMS annual reconciliation (Form 8962), subsidy cap enforcement, and 1095-A tax form generation all require linking the subsidy ']
  annual_aptc_cap decimal(12,2) [note: 'Maximum total APTC amount the member may receive in a calendar year.']
  aptc_monthly_amount decimal(18,2) [note: 'Monthly amount of APTC applied to the member\'s premium.']
  aptc_subsidy_status varchar [note: 'Overall lifecycle status of the subsidy record.']
  cms_reconciliation_status varchar [note: 'Current status of the subsidy record in CMS premium remittance reconciliation.']
  created_timestamp timestamp [note: 'Timestamp when the subsidy record was first created in the system.']
  csr_variant varchar [note: 'CSR variant percentage (73%, 87%, or 94%) applicable to the member.']
  exchange_code varchar [note: 'Identifier of the marketplace exchange where the member enrolled.']
  subsidy_effective_date date [note: 'Date when the subsidy becomes effective.']
  subsidy_number varchar [note: 'External business identifier assigned to the subsidy agreement.']
  subsidy_termination_date date [note: 'Date when the subsidy ends or is terminated; null if still active.']
  subsidy_type varchar [note: 'Indicates whether the record is an Advance Premium Tax Credit (APTC) or Cost‑Sharing Reduction (CSR) subsidy.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the subsidy record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']
  ytd_aptc_applied decimal(12,2) [note: 'Cumulative APTC amount applied to the member\'s premiums to date.']

  Note: 'Tracks Advance Premium Tax Credit (APTC) and Cost-Sharing Reduction (CSR) subsidy amounts for ACA marketplace members. Captures member reference, QHP plan code, marketplace exchange ID, APTC monthly amount, CSR variant level (73%, 87%, 94%), annual APTC cap, year-to-date APTC applied, subsidy effective date, subsidy termination date, and CMS reconciliation status. Required for ACA Section 1401/1402 compliance and CMS premium remittance reporting. [FHIR-aligned]'
}

Table billing.cms_remittance {
  cms_remittance_id varchar [pk, note: 'System-generated unique identifier for each CMS remittance record.']
  aptc_subsidy_id decimal(18,2) [note: 'Foreign key linking to billing.aptc_subsidy. Business justification: CMS remittance for ACA QHP plans directly corresponds to APTC subsidy payments — CMS remits the APTC portion to the health plan on behalf of subsidized members. Linking cms_remittance to aptc_subsidy ']
  cms_transaction_id varchar [note: 'Unique identifier for the transaction as assigned by CMS.']
  eligibility_span_id varchar [note: 'Foreign key linking to enrollment.enrollment_eligibility_span. Business justification: CMS remittance payments (APTC, risk adjustment, reinsurance) are reconciled against specific enrollment eligibility spans. CMS reconciliation and MLR reporting require matching each remittance record ']
  health_plan_id varchar [note: 'Identifier of the health plan or benefit package for which the remittance applies.']
  member_identity_id varchar [note: 'Unique identifier of the member associated with the remittance.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: CMS remittance payments (APTC advance payments, risk adjustment transfers) are reconciled at the policy level. MLR reporting, CMS reconciliation submissions, and risk adjustment data validation all re']
  radv_audit_id varchar [note: 'Foreign key linking to risk.radv_audit. Business justification: RADV audit findings (extrapolated_payment_error, final_settlement_amount) directly trigger CMS remittance adjustments. The CMS RADV settlement process requires linking audit outcomes to the resulting ']
  raps_submission_id varchar [note: 'Foreign key linking to risk.raps_submission. Business justification: CMS remittance reconciliation process directly ties payment amounts to the RAPS submission that generated the risk adjustment factor. Regulators and plan finance teams reconcile cms_remittance.risk_ad']
  vbc_contract_id varchar [note: 'Foreign key linking to contract.vbc_contract. Business justification: CMS remittance payments include risk adjustment and shared savings amounts that must be reconciled against VBC contract performance periods and settlement dates. Finance and actuarial teams require th']
  adjustment_reason varchar [note: 'Free‑text description explaining any manual adjustments applied to the remittance.']
  created_timestamp timestamp [note: 'Timestamp when the remittance record was first loaded into the data lake.']
  currency_code varchar [note: 'Three‑letter ISO 4217 currency code for the remittance amounts (e.g., USD).']
  edi_820_reference varchar [note: 'Reference number of the associated EDI 820 payment file.']
  gross_payment_amount decimal(18,2) [note: 'Total amount paid by CMS before any adjustments or offsets.']
  is_eligible boolean [note: 'Indicates whether the member was eligible for the payment period.']
  mlr_rebate_offset_amount decimal(18,2) [note: 'Medical Loss Ratio rebate offset applied to the gross payment.']
  net_remittance_amount decimal(18,2) [note: 'Final amount after all adjustments, representing the amount to be credited to the insurer.']
  payment_period_end date [note: 'Last day of the payment period for which the remittance applies.']
  payment_period_start date [note: 'First day of the payment period for which the remittance applies.']
  payment_type varchar [note: 'Category of CMS payment such as capitation, risk corridor, reinsurance, or risk adjustment.']
  reconciliation_status varchar [note: 'Current status of the remittance reconciliation process.']
  remittance_number varchar [note: 'External reference number assigned by CMS for the remittance transaction.']
  remittance_status varchar [note: 'Lifecycle state of the remittance record within the insurer\'s system.']
  remittance_timestamp timestamp [note: 'Date and time when the remittance was received from CMS.']
  risk_adjustment_amount decimal(18,2) [note: 'Amount related to risk adjustment transfers included in the remittance.']
  submission_type varchar [note: 'Method by which the remittance data was submitted to the insurer.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the remittance record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Records CMS premium remittance transactions for Medicare Advantage (MA), Part D, and ACA QHP plans. Captures CMS payment type (capitation, risk corridor, reinsurance, risk adjustment transfer), payment period, gross payment amount, risk adjustment amount, MLR rebate offset, net remittance amount, CMS transaction ID, 820 EDI transaction reference, and reconciliation status. SSOT for government premium remittance from CMS. [FHIR-aligned]'
}

Table billing.payment_method {
  payment_method_id decimal(18,2) [pk, note: 'System-generated unique identifier for the payment method record.']
  account_id varchar [note: 'Identifier of the billing account to which this payment method is attached.']
  member_identity_id varchar [note: 'Identifier of the member (policyholder) who owns the payment method.']
  authorization_date date [note: 'Date the payment method was authorized for use.']
  authorization_reference varchar [note: 'External reference or token returned by the payment processor confirming authorization.']
  bank_name varchar [note: 'Name of the financial institution that holds the account.']
  billing_address_line1 varchar [note: 'First line of the billing address associated with the payment method.']
  billing_address_line2 varchar [note: 'Second line of the billing address (optional).']
  billing_city varchar [note: 'City component of the billing address.']
  billing_country varchar [note: 'Three‑letter ISO country code for the billing address.']
  billing_postal_code varchar [note: 'Postal/ZIP code of the billing address.']
  billing_state varchar [note: 'State/Province component of the billing address.']
  card_expiration_date date [note: 'Expiration date of the credit/debit card.']
  card_last_four varchar [note: 'Last four digits of the credit/debit card for display purposes.']
  card_type varchar [note: 'Network brand of the credit/debit card.']
  created_timestamp timestamp [note: 'Timestamp when the payment method record was first created in the system.']
  effective_from date [note: 'Date the payment method becomes effective for billing.']
  effective_until date [note: 'Date the payment method expires or is deactivated (null if open‑ended).']
  holder_name varchar [note: 'Legal name of the individual to whom the card is issued.']
  is_auto_pay boolean [note: 'Indicates whether the member has authorized automatic recurring payments using this method.']
  masked_account_number varchar [note: 'Bank account number with middle digits masked for PCI‑DSS compliance.']
  masked_routing_number varchar [note: 'Bank routing number with middle digits masked to meet PCI‑DSS requirements.']
  method_type varchar [note: 'Category of the payment instrument (e.g., ACH, Check, Wire, Credit Card, Debit Card, Health Savings Account).']
  notes varchar [note: 'Free‑form text for operational comments or special handling instructions.']
  payment_method_status varchar [note: 'Current lifecycle state of the payment method.']
  pci_compliance_flag boolean [note: 'Indicates whether the stored payment method meets PCI‑DSS compliance.']
  risk_score decimal(5,2) [note: 'Fraud risk score assigned by the payment processor (0.00‑99.99).']
  tokenized_account_number varchar [note: 'PCI‑token representing the full bank account number for secure storage.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the payment method record.']
  verification_status varchar [note: 'Result of the payment method verification process.']
  verification_timestamp timestamp [note: 'Date‑time when verification was performed.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Master record of authorized payment methods registered for a billing account, capturing payment method type (ACH/EFT, check, wire transfer, credit card, debit card, HSA/FSA), bank routing number (masked), bank account number (masked/tokenized), card last four digits, card expiration date, auto-pay authorization flag, authorization date, authorization reference, and active/inactive status. Supports PCI-DSS compliant payment processing. [FHIR-aligned]'
}

Table utilization.pa_request {
  pa_request_id varchar [pk, note: 'Unique identifier for the prior authorization request.']
  benefit_id varchar [note: 'Foreign key linking to plan.benefit. Business justification: PA requests are submitted for specific covered benefits. UM staff must validate the requested service against the benefit definition (coverage type, authorization_required, limits) during PA adjudicat']
  clinical_criteria_id varchar [note: 'Identifier of the specific clinical rule applied.']
  contract_network_participation_id varchar [note: 'Foreign key linking to contract.network_participation. Business justification: PA routing and requirements depend on the requesting provider\'s network participation status (in_network_flag, prior_authorization_required_flag, network_tier). UM operations use this link to apply co']
  plan_election_id varchar [note: 'Identifier of the health plan under which the member is covered.']
  practice_location_id varchar [note: 'Foreign key linking to provider.provider_provider. Business justification: Required for Prior Authorization request processing to link each request to the provider entity for reporting, compliance, and performance metrics.']
  appeal_deadline_date date [note: 'Final date by which an appeal must be filed.']
  clinical_criteria_version varchar [note: 'Version of the clinical criteria set applied to the request.']
  created_timestamp timestamp [note: 'Timestamp when the request record was first created in the data warehouse.']
  currency_code varchar [note: 'Three-letter ISO currency code for the estimated amounts.']
  decision_maker_role varchar [note: 'Professional role of the decision maker.']
  denial_reason_code varchar [note: 'Code representing the reason for denial, if applicable.']
  diagnosis_code varchar [note: 'Diagnosis code supporting the medical necessity of the request.']
  estimated_adjustment_amount decimal(12,2) [note: 'Estimated adjustments (e.g., discounts, co-pays) applied to the gross amount.']
  estimated_gross_amount decimal(12,2) [note: 'Initial estimated gross cost of the requested service before adjustments.']
  estimated_net_amount decimal(12,2) [note: 'Final estimated net cost after adjustments.']
  is_appealable boolean [note: 'Indicates whether the member may appeal a denial.']
  is_duplicate_request boolean [note: 'Indicates whether this request is a duplicate of an existing request.']
  last_air_due_date date [note: 'Due date for the most recent additional information request.']
  last_air_received_date date [note: 'Date the last additional information request was received.']
  notes varchar [note: 'Additional comments or notes related to the request.']
  pa_request_status varchar [note: 'Current lifecycle status of the prior authorization request.']
  patient_age_at_request varchar [note: 'Age of the member at the time of request submission.']
  patient_gender varchar [note: 'Gender of the member at the time of request.']
  prior_auth_decision_date date [note: 'Date the prior authorization decision was made.']
  quantity varchar [note: 'Number of units or sessions requested.']
  request_number varchar [note: 'Business identifier assigned to the prior authorization request.']
  request_timestamp timestamp [note: 'Timestamp when the prior authorization request was submitted.']
  request_type varchar [note: 'Urgency classification of the prior authorization request.']
  service_code varchar [note: 'Procedure, service, or drug code associated with the request.']
  service_type varchar [note: 'Category of the service being requested for prior authorization.']
  submission_channel varchar [note: 'Channel through which the prior authorization request was submitted.']
  turnaround_time_days varchar [note: 'Number of days from submission to final decision.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the request record.']
  vreq_validated boolean [note: 'VREQ validation marker']

  Note: 'Core master entity representing a prior authorization (PA) request submitted by a provider or member for a proposed service, procedure, drug, or admission. Captures requesting provider NPI, member ID, requested service codes (CPT/HCPCS/ICD), urgency type (standard, expedited, urgent), submission channel (portal, fax, phone, EDI 278), submission timestamp, current PA status, and full status transition history. Also tracks additional information requests (AIRs) issued during review — information type requested, requested-from party, due date, received date, and TAT clock extension impact. Authoritative SSOT for all PA requests, their status lifecycle, and associated documentation requests. [FHIR-aligned]'
}

Table utilization.pa_decision {
  pa_decision_id varchar [pk, note: 'System-generated unique identifier for each prior authorization decision record.']
  clinical_criteria_id varchar [note: 'Foreign key linking to utilization.clinical_criteria. Business justification: PA decisions are made based on specific clinical criteria (InterQual/MCG criteria sets). pa_decision has clinical_criteria_set (STRING) and clinical_criteria_version (STRING) but no FK to the clinical']
  medical_policy_id varchar [note: 'Foreign key linking to utilization.medical_policy. Business justification: pa_decision references the medical policy that governs the decision; child (decision) gets FK to parent (medical_policy).']
  member_identity_id varchar [note: 'Unique identifier of the member/patient associated with the request.']
  pa_request_id varchar [note: 'Identifier of the prior‑authorization request to which this decision belongs.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: PA decisions must be documented against the specific policy to satisfy regulatory compliance (e.g., URAC, CMS), validate authorized services against coverage terms, and support appeals. Auditors and r']
  amendment_indicator varchar [note: 'Indicates if this record is the original decision or an amendment/reversal.']
  appeal_eligibility_flag boolean [note: 'Indicates whether the member is eligible to appeal the decision.']
  authorization_end_date date [note: 'Effective end date of the approved authorization period.']
  authorization_period_type varchar [note: 'Specifies if the authorization period is a fixed date range or rolling.']
  authorization_quantity varchar [note: 'Number of units (e.g., days, visits, doses) authorized.']
  authorization_start_date date [note: 'Effective start date of the approved authorization period.']
  authorization_units varchar [note: 'Unit of measure for the authorized quantity.']
  clinical_criteria_version varchar [note: 'Version identifier of the criteria set used for the decision.']
  clinical_rationale decimal(18,6) [note: 'Free‑text explanation of the clinical reasoning behind the decision.']
  created_timestamp timestamp [note: 'Timestamp when the decision record was first inserted into the data lake.']
  criteria_effective_date date [note: 'Date on which the applied clinical criteria version became effective.']
  criteria_met_flag boolean [note: 'Indicates whether the request met all required clinical criteria (true) or not (false).']
  decision_date timestamp [note: 'Timestamp when the prior authorization decision was rendered.']
  decision_number varchar [note: 'External business identifier assigned to the decision, often used in communications and audit trails.']
  decision_status varchar [note: 'Current lifecycle status of the decision record.']
  decision_type varchar [note: 'Classification of the decision outcome.']
  denial_reason_category varchar [note: 'High‑level category of the denial reason.']
  denial_reason_code varchar [note: 'Standardized code representing the specific reason for denial.']
  denial_regulatory_citation varchar [note: 'Reference to the regulatory or policy citation supporting the denial.']
  diagnosis_codes varchar [note: 'Pipe‑separated list of ICD‑10 diagnosis codes supporting the medical necessity determination.']
  is_telehealth boolean [note: 'True if the service requested is delivered via telehealth.']
  is_urgent boolean [note: 'True if the request was marked urgent.']
  notes varchar [note: 'Free‑form field for any supplemental information.']
  prior_auth_number varchar [note: 'Business number assigned to the prior‑authorization request.']
  regulatory_compliance_flag boolean [note: 'Indicates compliance with NCQA UM accreditation or state PA regulations.']
  reviewer_credentials varchar [note: 'Professional credentials of the reviewer (e.g., MD, RN, PharmD, NP).']
  reviewer_npi varchar [note: 'National Provider Identifier of the clinician or reviewer who rendered the decision.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the decision record.']
  vreq_validated boolean [note: 'VREQ validation marker']

  Note: 'Transactional record capturing the authorization decision and underlying medical necessity determination rendered on a PA request. Stores decision date, decision type (approved, denied, partially approved, pended, withdrawn), clinical criteria applied (InterQual/MCG criteria set, version, effective date), criteria met/not met flag, clinical rationale narrative, ICD diagnosis codes supporting the determination, deciding reviewer NPI and credentials (MD, RN, PharmD), denial reason code and category (medical necessity, administrative, benefit exclusion, out-of-network, experimental/investigational), denial regulatory citation, appeal eligibility flag, and effective authorization period (start/end dates). Each PA request may have one or more decision records reflecting amendments, P2P reversals, or appeal overrides. Serves as the single evidentiary record for NCQA audits, state DOI market conduct exams, and denial defense. [FHIR-aligned]'
}

Table utilization.auth_service_line {
  auth_service_line_id varchar [pk, note: 'System-generated unique identifier for each line item within a prior authorization request.']
  benefit_id varchar [note: 'Foreign key linking to plan.benefit. Business justification: Each authorized service line authorizes a specific covered benefit. Benefit limits (limit_value, limit_period, oop_max_amount) must be checked against the benefit definition during authorization. Clai']
  clinical_criteria_id varchar [note: 'Identifier of the specific clinical rule set (InterQual/MCG) applied to this line.']
  cost_share_rule_id varchar [note: 'Foreign key linking to plan.cost_share_rule. Business justification: The authorized_price on each service line is determined by the applicable cost-share rule (copay, coinsurance, deductible applicability). UM and claims operations require this link to calculate member']
  member_identity_id varchar [note: 'Unique identifier of the member for whom the service is authorized.']
  pa_decision_id varchar [note: 'Foreign key linking to utilization.pa_decision. Business justification: Each authorized service line is governed by a specific PA decision. auth_service_line already references pa_request_id, but the direct link to pa_decision is missing. Adding pa_decision_id enables dir']
  pa_request_id varchar [note: 'Identifier of the parent prior authorization request to which this service line belongs.']
  reimbursement_policy_id varchar [note: 'Foreign key linking to contract.reimbursement_policy. Business justification: Authorized service lines are adjudicated against reimbursement policies governing NCCI edits, modifier rules, max units per day, and global surgery periods. Claims adjudication and UM audit reports re']
  authorization_status varchar [note: 'Current status of the service line within the prior authorization workflow.']
  authorized_end_date date [note: 'Expiration date after which the authorization is no longer valid.']
  authorized_price decimal(12,2) [note: 'Maximum reimbursable amount per unit for the authorized service.']
  authorized_quantity decimal(10,2) [note: 'Number of units of the service or product approved for the member.']
  authorized_start_date date [note: 'Effective date when the authorized service may begin.']
  clinical_criteria_version varchar [note: 'Version of the clinical criteria used for medical necessity determination.']
  cpt_code varchar [note: 'Standard CPT code representing the clinical service or procedure authorized.']
  created_timestamp timestamp [note: 'System timestamp when the service line record was first created in the data lake.']
  currency_code varchar [note: 'Three‑letter ISO currency code for the authorized price.']
  decision_timestamp timestamp [note: 'Date‑time when the authorization decision for this line was made.']
  denial_reason varchar [note: 'Explanation code or text why the service line was denied or partially approved.']
  diagnosis_icd_code varchar [note: 'ICD code linking the authorized service to the clinical diagnosis supporting medical necessity.']
  hcpcs_code varchar [note: 'HCPCS code (Level II) for services, supplies, or drugs not covered by CPT.']
  is_emergency boolean [note: 'True if the authorized service is classified as an emergency.']
  is_experimental boolean [note: 'True if the service is considered experimental or investigational.']
  is_partial_approval boolean [note: 'Indicates whether only a portion of the requested service quantity was approved.']
  line_sequence varchar [note: 'Sequential order of the line within the prior authorization request.']
  notes varchar [note: 'Free‑text field for additional comments or special instructions from the reviewer.']
  place_of_service varchar [note: 'Location type where the service is to be rendered.']
  request_submitted_timestamp timestamp [note: 'Date‑time when the prior authorization request containing this line was submitted.']
  service_category varchar [note: 'Broad classification of the authorized service (e.g., inpatient, outpatient, DME, pharmacy).']
  unit_of_measure varchar [note: 'Measurement unit for the authorized quantity (e.g., tablets, sessions, days).']
  updated_timestamp timestamp [note: 'System timestamp of the most recent update to the service line record.']
  vreq_validated boolean [note: 'VREQ validation marker']

  Note: 'Line-item detail for each service, procedure, or drug authorized within a PA request. Captures CPT/HCPCS code, ICD diagnosis code, authorized quantity, authorized units of service, service category (inpatient, outpatient, DME, pharmacy, behavioral health), place of service, authorized facility NPI, and approved date range. Supports partial approvals where only a subset of requested services are authorized. [FHIR-aligned]'
}

Table utilization.concurrent_review {
  concurrent_review_id varchar [pk, note: 'System-generated unique identifier for the concurrent review record.']
  care_plan_id varchar [note: 'Foreign key linking to care.care_plan. Business justification: Concurrent review discharge planning: during inpatient concurrent review, the UM nurse references and updates the member\'s active care plan for discharge destination planning and post-acute service au']
  coordinator_id varchar [note: 'Identifier of the care coordinator assigned to the member for this episode.']
  health_plan_id varchar [note: 'Foreign key linking to plan.health_plan. Business justification: Concurrent Review Utilization Management reports require linking each review to the member\'s health plan.']
  inpatient_admission_id varchar [note: 'Identifier of the inpatient admission linked to this review.']
  medical_policy_id varchar [note: 'Foreign key linking to utilization.medical_policy. Business justification: Concurrent review applies medical policies and clinical criteria to evaluate continued inpatient stay necessity. concurrent_review has benchmark_source and benchmark_source_detail (STRING) and criteri']
  member_risk_score_id varchar [note: 'Foreign key linking to risk.member_risk_score. Business justification: Concurrent review discharge planning and next_review_date scheduling are clinically informed by member risk scores. Reviewers use risk scores to assess readmission risk and authorize post-acute servic']
  member_subscriber_id varchar [note: 'Unique identifier of the member whose stay is under review.']
  pa_decision_id varchar [note: 'Foreign key linking to utilization.pa_decision. Business justification: Concurrent review is the ongoing UM review process that results in authorization decisions. concurrent_review already has pa_request_id but lacks a direct FK to the resulting pa_decision. Adding pa_de']
  pa_request_id varchar [note: 'Identifier of the originating prior‑authorization request.']
  practice_location_id varchar [note: 'Foreign key linking to provider.provider_provider. Business justification: Connects concurrent review records to the admitting provider for LOS benchmarking and clinical oversight reporting.']
  um_case_id varchar [note: 'Identifier of the overarching UM case that this review belongs to.']
  actual_discharge_date decimal(18,2) [note: 'Date the member actually left the hospital.']
  admission_date date [note: 'Date the member was admitted to the hospital.']
  approved_length_of_stay varchar [note: 'Maximum number of days approved for continued stay based on the review.']
  authorized_post_acute_service varchar [note: 'Post‑acute care service(s) approved during the review (e.g., physical therapy, home health).']
  benchmark_source varchar [note: 'Source of the LOS benchmark values.']
  benchmark_source_detail varchar [note: 'Free‑text description of the benchmark source (e.g., specific CMS report or Milliman model).']
  clinical_reviewer_npi varchar [note: 'NPI of the clinician performing the review.']
  concurrent_review_status varchar [note: 'Current state of the review workflow.']
  criteria_version varchar [note: 'Version of InterQual or MCG criteria applied.']
  current_length_of_stay varchar [note: 'Number of days the member has been hospitalized to date.']
  discharge_barriers decimal(18,2) [note: 'Identified obstacles preventing timely discharge (e.g., equipment, placement).']
  discharge_destination decimal(18,2) [note: 'Intended location after hospital discharge.']
  is_critical boolean [note: 'True if the review is flagged as critical due to high acuity or risk.']
  justification varchar [note: 'Narrative explanation for why continued stay is medically necessary.']
  los_benchmark_mean decimal(5,2) [note: 'Average LOS for the DRG or service line used as a benchmark.']
  los_benchmark_outlier_threshold decimal(5,2) [note: 'Threshold beyond which the stay is considered an outlier.']
  los_benchmark_target decimal(5,2) [note: 'Plan‑specific target LOS for the case.']
  next_review_date date [note: 'Scheduled date for the subsequent concurrent review.']
  planned_discharge_date decimal(18,2) [note: 'Projected date for member discharge as determined by the reviewer.']
  readmission_risk_category varchar [note: 'Risk tier derived from the readmission risk score.']
  readmission_risk_score decimal(4,2) [note: 'Predictive score indicating likelihood of readmission within 30 days.']
  record_audit_created timestamp [note: 'Timestamp when the review record was first created in the system.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent modification to the review record.']
  review_end_timestamp timestamp [note: 'Date‑time when the review was completed or closed.']
  review_notes varchar [note: 'Additional free‑text comments entered by the reviewer.']
  review_number varchar [note: 'Human‑readable unique code assigned to the review for tracking and communication.']
  review_start_timestamp timestamp [note: 'Date‑time when the concurrent review was initiated.']
  review_type varchar [note: 'Specifies whether the review is concurrent (ongoing) or retrospective.']
  social_work_involved boolean [note: 'Indicates whether a social worker was consulted for discharge planning.']
  vreq_validated boolean [note: 'VREQ validation marker']

  Note: 'Manages inpatient concurrent review records for admitted members — the ongoing UM review process evaluating continued medical necessity during a hospital stay. Captures admission date, current and approved length of stay (LOS), LOS benchmarks by DRG (geometric/arithmetic mean LOS, plan-specific target, outlier threshold, benchmark source — CMS, Milliman, plan actuarial), next review date, clinical reviewer NPI, InterQual/MCG criteria version applied, continued stay justification. Includes integrated discharge planning: planned discharge date, discharge destination (home, SNF, LTAC, home health, hospice), post-acute services authorized, barriers to discharge, social work involvement, care coordinator assigned, actual discharge date, and readmission risk score. Links to the originating PA request, UM case, and inpatient admission. [FHIR-aligned]'
}

Table utilization.um_case {
  um_case_id varchar [pk, note: 'System-generated unique identifier for the UM case.']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: UM cases are worked under a specific benefit package that determines which services require PA, applicable cost-sharing, and coverage limits. UM coordinators need benefit package context to make cover']
  coordinator_id varchar [note: 'Foreign key linking to care.care_coordinator. Business justification: Case Management Process assigns a care coordinator to each utilization case; linking enables case‑to‑coordinator reporting and workload tracking.']
  episode_of_care_id varchar [note: 'Identifier linking the case to the broader episode of care.']
  member_identity_id varchar [note: 'Unique identifier of the member associated with the case.']
  pa_request_id varchar [note: 'Foreign key linking to utilization.pa_request. Business justification: um_case may be initiated by a PA request; child (um_case) gets FK to parent (pa_request).']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: UM case managers must reference the member\'s active policy to validate medical necessity criteria against coverage terms, apply correct benefit limits, and document authorization decisions. Case manag']
  program_id varchar [note: 'Foreign key linking to care.program. Business justification: Program-level UM reporting: UM cases are opened under specific care management programs (complex case management, transplant, oncology). Linking um_case to care.program enables program directors to tr']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: UM cases are managed in relation to a primary treating provider. Provider-level UM case volume, denial rates, and outlier reporting are standard health plan operations. primary_provider_npi is a denor']
  appeal_indicator boolean [note: 'True if the case has been appealed.']
  assigned_nurse_name varchar [note: 'Full name of the UM nurse or case manager handling the case.']
  case_close_date date [note: 'Date the UM case was closed or completed; null if still open.']
  case_number varchar [note: 'Business-visible case number used for tracking and communication.']
  case_open_date date [note: 'Date the UM case was opened and became active.']
  case_priority varchar [note: 'Priority level assigned to the case for workload management.']
  case_severity varchar [note: 'Severity rating reflecting clinical urgency and complexity.']
  case_status varchar [note: 'Current lifecycle status of the UM case.']
  case_type varchar [note: 'Category of the case based on care setting or service type.']
  clinical_criteria_set varchar [note: 'Source set of clinical criteria applied (InterQual or MCG).']
  clinical_criteria_version varchar [note: 'Version identifier of the clinical criteria set used for the case.']
  compliance_flag boolean [note: 'Indicates whether the case meets NCQA UM accreditation requirements.']
  created_timestamp timestamp [note: 'Timestamp when the UM case record was first created in the system.']
  denial_reason_code varchar [note: 'Code indicating why a prior authorization or claim was denied.']
  denial_reason_description varchar [note: 'Textual explanation of the denial reason.']
  disposition_code varchar [note: 'Standard code representing the final outcome of the case.']
  disposition_description varchar [note: 'Human‑readable description of the case outcome.']
  length_of_stay_actual varchar [note: 'Observed length of stay for the episode, expressed in days.']
  length_of_stay_target varchar [note: 'Planned maximum length of stay for the episode, expressed in days.']
  notes varchar [note: 'Free‑text field for clinical or administrative comments.']
  primary_diagnosis_code varchar [note: 'ICD code representing the principal diagnosis driving the case.']
  primary_diagnosis_description varchar [note: 'Text description of the principal diagnosis.']
  prior_authorization_decision_date date [note: 'Date the prior authorization decision was rendered.']
  prior_authorization_number varchar [note: 'Reference number for the prior authorization request linked to the case.']
  prior_authorization_status varchar [note: 'Current status of the prior authorization request.']
  turnaround_time_days varchar [note: 'Number of days from case open to final disposition.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the UM case record.']
  urgency_flag boolean [note: 'True if the case requires expedited review per clinical criteria.']
  vreq_validated boolean [note: 'VREQ validation marker']

  Note: 'Master entity representing a utilization management (UM) case — the overarching workflow container grouping all UM activities (PA requests, concurrent reviews, retrospective reviews, P2P reviews, appeals) for a single member episode of care. Captures case type (inpatient, outpatient, behavioral health, DME, pharmacy), case open/close dates, assigned UM nurse or case manager, episode of care identifier, primary diagnosis, and case disposition. Enables end-to-end UM workflow tracking, workload management, and NCQA UM accreditation reporting. [FHIR-aligned]'
}

Table utilization.inpatient_admission {
  inpatient_admission_id varchar [pk, note: 'System-generated unique identifier for the inpatient admission record.']
  admitting_provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: The attending/admitting physician drives UM decisions, LOS benchmarking, and HEDIS quality reporting. Linking to provider.provider enables provider-level utilization analytics and credentialing verifi']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Inpatient admissions are covered under a specific benefit package defining inpatient coinsurance, deductibles, and LOS limits. Claims adjudication, concurrent review, and cost benchmarking require the']
  clinical_criteria_id varchar [note: 'Identifier of the specific clinical rule used for concurrent review.']
  pa_request_id varchar [note: 'Foreign key linking to utilization.pa_request. Business justification: An inpatient admission in UM context is authorized via a PA request. inpatient_admission already has authorization_number and payer_authorization_status as string columns, but lacks a direct FK to the']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Inpatient admission management requires policy context for coverage determination, deductible and out-of-pocket max tracking, and claims adjudication. Concurrent review and discharge planning decision']
  actual_cost_amount decimal(12,2) [note: 'Final cost incurred for the admission after discharge.']
  actual_los_days varchar [note: 'Number of days the member actually stayed in the facility.']
  admission_date date [note: 'Date the member was admitted to the facility.']
  admission_number varchar [note: 'Business identifier assigned to the admission by the health plan.']
  admission_status varchar [note: 'Current lifecycle status of the admission.']
  admission_type varchar [note: 'Classification of the admission based on urgency.']
  authorization_number varchar [note: 'Unique identifier of the payer\'s authorization for this admission.']
  clinical_criteria_version varchar [note: 'Version of the clinical criteria set (e.g., InterQual v2023) applied to the admission.']
  created_timestamp timestamp [note: 'Timestamp when the admission record was first created in the system.']
  currency_code varchar [note: 'Three‑letter ISO currency code for cost fields.']
  denial_reason_code varchar [note: 'Standardized code representing why the admission was denied.']
  denial_reason_description varchar [note: 'Narrative description of the denial reason.']
  discharge_date decimal(18,2) [note: 'Date the member was discharged from the facility.']
  discharge_disposition decimal(18,2) [note: 'Post‑discharge destination of the member.']
  drg_code varchar [note: 'DRG assignment for the admission used for payment and benchmarking.']
  expected_cost_amount decimal(12,2) [note: 'Projected cost of the admission before services are rendered.']
  expected_los_days varchar [note: 'Projected number of days the member is expected to stay, based on clinical criteria.']
  fhir_class varchar [note: 'FHIR Encounter.class mapping']
  fhir_period varchar [note: 'FHIR Encounter.period mapping']
  fhir_status varchar [note: 'FHIR Encounter.status mapping']
  fhir_subject varchar [note: 'FHIR Encounter.subject mapping']
  is_critical_care boolean [note: 'Indicates whether the admission involved critical care services.']
  is_readmission boolean [note: 'True if the admission is a readmission within the defined look‑back period.']
  los_benchmark_met_flag boolean [note: 'Indicates whether actual LOS met the benchmark target.']
  los_target_days varchar [note: 'Benchmark target days for LOS based on plan and diagnosis.']
  payer_authorization_status varchar [note: 'Current status of the payer\'s prior‑authorization for the admission.']
  primary_diagnosis_code varchar [note: 'ICD code representing the principal diagnosis for the admission.']
  readmission_within_30_days boolean [note: 'True if the admission occurs within 30 days of a prior discharge.']
  review_decision varchar [note: 'Outcome of the utilization management review.']
  review_decision_date date [note: 'Date the UM reviewer rendered a decision.']
  review_status varchar [note: 'Current status of the utilization management review.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the admission record.']
  vreq_validated boolean [note: 'VREQ validation marker']

  Note: 'UM-managed inpatient admission record for admissions subject to concurrent review. Captures admitting facility NPI, admitting physician NPI, admission date, admission type (elective, urgent, emergent), primary admitting diagnosis (ICD), DRG assignment, expected LOS, actual discharge date, discharge disposition (home, SNF, rehab, expired), and payer authorization status. Serves as the anchor for concurrent review workflows and LOS benchmark comparisons. Distinct from the claim domain\'s institutional claim — this is the clinical/UM view of the admission, not the billing view. [FHIR-aligned]'
}

Table utilization.medical_policy {
  medical_policy_id varchar [pk, note: 'System-generated unique identifier for the medical policy record.']
  clinical_criteria_id varchar [note: 'Foreign key linking to utilization.clinical_criteria. Business justification: Medical policies are grounded in clinical criteria (InterQual, MCG criteria sets). medical_policy has clinical_criteria_source (STRING) and clinical_criteria_version (STRING) as denormalized reference']
  parent_medical_policy_id varchar [note: 'Self-referencing FK on medical_policy (parent_medical_policy_id)']
  applicable_cpt_codes varchar [note: 'Comma‑separated list of CPT procedure codes covered under the policy.']
  applicable_hcpcs_codes varchar [note: 'Comma‑separated list of HCPCS codes (including drugs) covered under the policy.']
  clinical_category varchar [note: 'High‑level clinical grouping (e.g., cardiology, orthopedics) to which the policy applies.']
  clinical_criteria_source varchar [note: 'Origin of the clinical criteria used in the policy.']
  clinical_criteria_version varchar [note: 'Version identifier of the clinical criteria set applied.']
  compliance_status varchar [note: 'Current compliance posture of the policy with respect to external regulations.']
  coverage_limit_amount decimal(12,2) [note: 'Monetary cap applied to the total covered amount for the policy period.']
  coverage_limit_currency varchar [note: 'Three‑letter ISO currency code for the coverage limit amount.']
  coverage_limit_units varchar [note: 'Unit of measure for the coverage limit (e.g., visits, days).']
  created_timestamp timestamp [note: 'Date‑time when the policy record was first created in the system.']
  effective_from date [note: 'Date on which the policy becomes binding for members.']
  effective_until date [note: 'Date on which the policy ceases to be binding; null for open‑ended policies.']
  is_emergency_covered boolean [note: 'Indicates whether emergency services are covered without prior authorization.']
  is_exempt boolean [note: 'True if the policy includes exemptions for specific services or member groups.']
  is_experimental_covered boolean [note: 'True if experimental or investigational services are permitted under the policy.']
  is_prior_auth_required boolean [note: 'Indicates whether a prior authorization must be obtained for services covered by this policy.']
  is_telehealth_covered boolean [note: 'Indicates whether telehealth services are covered under the policy.']
  last_reviewed_by varchar [note: 'Identifier of the user who performed the most recent policy review.']
  last_reviewed_timestamp timestamp [note: 'Date‑time when the policy was last reviewed for clinical or regulatory updates.']
  medical_policy_status varchar [note: 'Current lifecycle state of the policy.']
  notes varchar [note: 'Free‑form text for additional comments, special considerations, or audit remarks.']
  policy_name varchar [note: 'Human‑readable name of the policy for reporting and UI display.']
  policy_number varchar [note: 'External business identifier assigned to the policy, used in member communications and claim adjudication.']
  policy_type varchar [note: 'Category of the policy indicating the primary clinical domain it governs.']
  prior_auth_approval_timeframe_days varchar [note: 'Maximum number of calendar days allowed to approve a prior authorization request.']
  regulatory_reference varchar [note: 'Citation to the regulatory rule or guideline that mandates this policy.']
  updated_timestamp timestamp [note: 'Date‑time of the most recent modification to the policy record.']
  version_effective_date date [note: 'Date when this version of the policy became effective.']
  version_expiration_date date [note: 'Date when this version of the policy was superseded or retired.']
  version_number varchar [note: 'Sequential version identifier for policy revisions.']
  vreq_validated boolean [note: 'VREQ validation marker']
  created_by varchar [note: 'Identifier of the user or system that created the policy record.']

  Note: 'Master reference for medical policies and clinical criteria used in utilization management decisions — including medical necessity criteria, clinical guidelines, evidence-based medicine references, and policy effective dates. Captures policy ID, policy name, clinical category, applicable CPT/HCPCS codes, review criteria source (InterQual, MCG, internal), and version history. [FHIR-aligned]'
}

Table utilization.clinical_criteria {
  clinical_criteria_id varchar [pk, note: 'Primary key for clinical_criteria']
  parent_clinical_criteria_id varchar [note: 'Self-referencing FK on clinical_criteria (parent_clinical_criteria_id)']
  created_timestamp timestamp [note: 'Timestamp when the record was first created in the system.']
  criteria_category varchar [note: 'Broad category indicating the clinical setting or context of the criteria.']
  criteria_code varchar [note: 'Unique code assigned to the clinical criteria, used for lookup and integration.']
  criteria_description varchar [note: 'Detailed description of the clinical criteria, including its purpose and application.']
  criteria_detail varchar [note: 'Textual or structured detail of the rule or logic that defines the criteria.']
  criteria_effective_date date [note: 'Date when the clinical criteria becomes effective and applicable.']
  criteria_expiration_date date [note: 'Date when the clinical criteria is no longer valid or applicable.']
  criteria_limit_unit varchar [note: 'Unit of measurement for the limit value (e.g., days, dollars).']
  criteria_limit_value decimal(10,2) [note: 'Numeric limit value used in the criteria rule (e.g., maximum allowed).']
  criteria_name varchar [note: 'Human-readable name of the clinical criteria.']
  criteria_notes varchar [note: 'Additional notes or comments about the clinical criteria.']
  criteria_reference varchar [note: 'Reference to external standard or guideline that the criteria aligns with.']
  criteria_rule_expression varchar [note: 'Formal expression or logic that defines how the criteria is evaluated.']
  criteria_source varchar [note: 'Originating system or authority that defines the clinical criteria.']
  criteria_status varchar [note: 'Current lifecycle status of the clinical criteria.']
  criteria_subcategory varchar [note: 'More specific classification within the category to refine the criteria context.']
  criteria_threshold_unit varchar [note: 'Unit of measurement for the threshold value (e.g., days, dollars).']
  criteria_threshold_value decimal(10,2) [note: 'Numeric threshold value used in the criteria rule (e.g., maximum days, minimum cost).']
  criteria_type varchar [note: 'Category of the clinical criteria indicating the type of clinical element it applies to.']
  criteria_version varchar [note: 'Version identifier of the clinical criteria to track updates and revisions.']
  record_status varchar [note: 'Current status of the record for data lifecycle management.']
  updated_by varchar [note: 'Identifier of the user or process that last updated the record.']
  updated_timestamp timestamp [note: 'Timestamp when the record was last updated in the system.']
  vreq_validated boolean [note: 'VREQ validation marker']
  created_by varchar [note: 'Identifier of the user or process that created the record.']

  Note: 'Master reference table for clinical_criteria. Referenced by clinical_criteria_id. [FHIR-aligned]'
}

Table utilization.episode_of_care {
  episode_of_care_id varchar [pk, note: 'Primary key for episode_of_care']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Episodes of care are governed by the member\'s benefit package, which defines covered services, cost-sharing, and authorization requirements for the episode. Care management reporting and episode cost ']
  identity_id varchar [note: 'System identifier for the patient associated with this episode of care.']
  inpatient_admission_id varchar [note: 'Foreign key linking to utilization.inpatient_admission. Business justification: An episode of care is the FHIR-aligned clinical container that may encompass an inpatient admission. episode_of_care has admission_date, discharge_date, length_of_stay_days, and fhir-aligned fields th']
  pa_request_id varchar [note: 'Foreign key linking to utilization.pa_request. Business justification: An episode of care in the UM domain is directly associated with a PA request — the episode captures the clinical journey that required prior authorization. episode_of_care has prior_authorization_stat']
  parent_episode_of_care_id varchar [note: 'Self-referencing FK on episode_of_care (parent_episode_of_care_id)']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Episode-level financial reporting (total_charges, total_payments, net_amount_due) and claims adjudication require the policy in force during the episode. Value-based care and bundled payment programs ']
  program_id varchar [note: 'Foreign key linking to care.program. Business justification: Program outcome reporting: disease management programs (oncology, diabetes, maternity) track episodes of care to measure program ROI and clinical outcomes. Linking episode_of_care to care.program enab']
  radv_audit_id varchar [note: 'Foreign key linking to risk.radv_audit. Business justification: RADV audits validate diagnosis codes across all encounter types including outpatient episodes. Episodes of care aggregate diagnosis codes (procedure_codes, primary_diagnosis_code) used in HCC risk adj']
  admission_date date [note: 'Date the patient was admitted to the facility for this episode.']
  claim_approval_date date [note: 'Date the claim was approved by the insurer.']
  claim_denial_reason varchar [note: 'Reason code or description for claim denial, if applicable.']
  claim_status varchar [note: 'Current status of the claim associated with this episode.']
  claim_submission_date date [note: 'Date the claim was submitted to the insurer.']
  classification_or_type varchar [note: 'The type of care episode, indicating the setting and nature of services.']
  created_at timestamp [note: 'Timestamp when the episode record was first created in the system.']
  discharge_date decimal(18,2) [note: 'Date the patient was discharged from the facility.']
  effective_from date [note: 'Date when the episode of care becomes effective.']
  effective_until date [note: 'Date when the episode of care ends or is terminated. Nullable for ongoing episodes.']
  episode_number varchar [note: 'External business identifier for the episode of care, used in communications and reporting.']
  length_of_stay_days varchar [note: 'Number of days the patient stayed in the facility during this episode.']
  lifecycle_status varchar [note: 'Current state of the episode of care within its lifecycle.']
  medical_necessity_decision varchar [note: 'Decision on medical necessity for the episode.']
  medical_necessity_decision_date date [note: 'Date the medical necessity decision was made.']
  net_amount_due decimal(15,2) [note: 'Net amount due after applying payments and adjustments.']
  primary_diagnosis_code varchar [note: 'ICD-10 code representing the primary diagnosis for the episode.']
  prior_authorization_decision_date date [note: 'Date the prior authorization decision was made.']
  prior_authorization_request_date date [note: 'Date the prior authorization was requested.']
  prior_authorization_status varchar [note: 'Current status of the prior authorization request.']
  procedure_codes varchar [note: 'Comma-separated list of procedure codes (e.g., CPT) performed during the episode.']
  total_adjustments decimal(15,2) [note: 'Total adjustments applied to the charges (e.g., discounts, write-offs).']
  total_charges decimal(15,2) [note: 'Total billed amount for services rendered in this episode.']
  total_payments decimal(15,2) [note: 'Total payments received from insurer and patient for this episode.']
  updated_at timestamp [note: 'Timestamp of the most recent update to the episode record.']
  utilization_review_date date [note: 'Date the utilization review was conducted.']
  utilization_review_decision varchar [note: 'Decision outcome of the utilization review.']
  utilization_review_decision_date date [note: 'Date the utilization review decision was finalized.']
  utilization_review_status varchar [note: 'Status of the utilization review process for this episode.']
  vreq_validated boolean [note: 'VREQ validation marker']

  Note: 'Master reference table for episode_of_care. Referenced by episode_of_care_id. [FHIR-aligned]'
}

Table care.program {
  program_id varchar [pk, note: 'System-generated unique identifier for the care program.']
  vbc_contract_id varchar [note: 'Foreign key linking to contract.vbc_contract. Business justification: Care programs are operationally created and governed by VBC contracts — the VBC contract defines quality targets, HEDIS measure requirements, and performance benchmarks that the care program must exec']
  accreditation_body varchar [note: 'Organization that provides accreditation for the program.']
  accreditation_status varchar [note: 'Current accreditation state of the program (e.g., NCQA, URAC).']
  category varchar [note: 'More granular category within the program type (e.g., diabetes, CHF, COPD).']
  clinical_protocol varchar [note: 'Standardized clinical pathway or guideline applied within the program.']
  code varchar [note: 'Internal code used to reference the program in operational systems.']
  contact_email varchar [note: 'Primary email address for program inquiries.']
  contact_phone varchar [note: 'Primary phone number for program inquiries.']
  created_timestamp timestamp [note: 'Date‑time when the program record was first created.']
  data_source_system varchar [note: 'Operational system that provides the master program data (e.g., Casenet TruCare).']
  description varchar [note: 'Detailed narrative describing the program\'s purpose, services, and scope.']
  eligibility_criteria varchar [note: 'Business rules that determine member eligibility for enrollment in the program.']
  end_date date [note: 'Date the program is retired or no longer offered (nullable for open‑ended).']
  enrollment_cap varchar [note: 'Maximum number of members allowed to enroll in the program.']
  enrollment_current varchar [note: 'Number of members currently enrolled.']
  enrollment_end_date date [note: 'Date when enrollment closes for the program.']
  enrollment_start_date date [note: 'Date when enrollment opens for the program.']
  evidence_source varchar [note: 'Reference to the clinical study or guideline that validates the program.']
  hcc_included varchar [note: 'Comma‑separated list of HCC codes that are counted toward the program\'s risk adjustment.']
  hcc_version varchar [note: 'Version of the HCC model used for the program (e.g., 2024).']
  is_evidence_based boolean [note: 'Indicates whether the program is supported by clinical evidence.']
  last_review_date date [note: 'Date the program was last reviewed for clinical relevance or compliance.']
  name varchar [note: 'Human‑readable name of the care program.']
  outcome_actual varchar [note: 'Most recent observed value for the outcome measure.']
  outcome_measure varchar [note: 'Key performance indicator used to evaluate program effectiveness.']
  outcome_target varchar [note: 'Target value or threshold for the outcome measure.']
  program_status varchar [note: 'Current lifecycle status of the program.']
  program_type varchar [note: 'Broad classification of the program offering.']
  review_frequency varchar [note: 'How often the program is scheduled for review.']
  risk_adjustment_factor decimal(5,4) [note: 'Factor used for risk‑adjusted payment calculations (e.g., 0.1234).']
  start_date date [note: 'Date the program becomes effective and available to members.']
  target_population varchar [note: 'Demographic or clinical segment the program is designed for.']
  updated_timestamp timestamp [note: 'Date‑time of the most recent update to the program record.']
  version_number varchar [note: 'Version identifier for the program definition.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Master registry of all care management, disease management, and case management programs offered by the health plan — including chronic condition programs (diabetes, CHF, COPD, asthma), complex case management, maternity management, behavioral health programs, and population health initiatives. Tracks program type, eligibility criteria, clinical protocols, accreditation standards (NCQA/URAC), program status, and line-of-business applicability. Source: Casenet TruCare or Altruista program configuration. [FHIR-aligned]'
}

Table care.care_enrollment {
  care_enrollment_id varchar [pk, note: 'System-generated unique identifier for each care enrollment record.']
  capitation_arrangement_id varchar [note: 'Foreign key linking to contract.capitation_arrangement. Business justification: Member enrollment in care programs under capitation models must be linked to the capitation arrangement for PMPM payment reconciliation, attributed member count tracking, and RAF adjustment. Capitatio']
  coordinator_id varchar [note: 'Identifier of the care coordinator assigned to the member for this enrollment.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Care program enrollment eligibility is policy-dependent. Care managers must confirm active coverage and benefit limits under a specific policy when enrolling members in disease/case management program']
  program_id varchar [note: 'Identifier of the care, disease, or case management program to which the member is enrolled.']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Care management enrollment is triggered by or attributed to a PCP or specialist. Provider-level enrollment reporting, referral tracking, and value-based care performance measurement require linking ea']
  acuity_level varchar [note: 'Clinical acuity assigned to the member for this program.']
  care_manager_assigned_date date [note: 'Date the care manager was officially assigned to the member.']
  consent_status varchar [note: 'Member\'s consent status for participation and data sharing within the program.']
  created_timestamp timestamp [note: 'Timestamp when the enrollment record was first created in the system.']
  disenrollment_date date [note: 'Actual date the member left the program.']
  effective_end_date date [note: 'Planned termination date of the enrollment (null if open‑ended).']
  effective_start_date date [note: 'Date when the enrollment becomes effective.']
  enrollment_number varchar [note: 'Business identifier assigned to the enrollment, used in operational reporting and member communications.']
  enrollment_source varchar [note: 'Origin of the enrollment request, indicating how the member entered the program.']
  enrollment_status varchar [note: 'Current lifecycle state of the enrollment.']
  enrollment_type varchar [note: 'Category of care program (e.g., disease management).']
  hcc_score decimal(5,2) [note: 'Aggregated HCC score associated with the member at enrollment.']
  notes varchar [note: 'Free‑form notes entered by care staff regarding the enrollment.']
  program_tier varchar [note: 'Level of service intensity offered by the program.']
  reason varchar [note: 'Business reason or clinical trigger for enrolling the member.']
  risk_score decimal(5,2) [note: 'Quantitative risk score used for prioritizing outreach (0‑100).']
  status_reason varchar [note: 'Explanation for the current enrollment status (e.g., member request, clinical criteria).']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the enrollment record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: '[SSOT:enrollment] Reference to canonical SSOT member.member_enrollment for the \'enrollment\' concept; do not duplicate authoritative data here. Tracks member enrollment into specific care management, disease management, or case management programs — capturing enrollment date, disenrollment date, enrollment source (outreach, referral, self-referral, claims-triggered, HRA-triggered), consent status, program tier, enrollment status, and acuity level. Represents the active participation record linking a member to a care program. Coordinator assignment details are maintained on the care_coordinator product. Distinct from health plan enrollment (owned by the enrollment domain). Source: Casenet TruCare or Altruista. SSOT NOTE: Canonical source of truth for the \'enrollment\' concept is member.member_enrollment; this product is retained as a domain-specific view/duplicate and must defer to the canonical entity. [FHIR-aligned] SSOT duplicate; single source of truth is member.member_enrollment.'
}

Table care.care_plan {
  care_plan_id varchar [pk, note: 'System-generated unique identifier for the care plan record.']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Care coordinators reference the member\'s benefit package to identify covered services, prior auth requirements, and cost-sharing when building care plans. Benefit-package-level care management reporti']
  coordinator_id varchar [note: 'Identifier of the care coordinator assigned to manage the plan.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Care plans are executed within a specific coverage period. Care coordinators and UM teams reference the active policy to confirm covered services, authorization requirements, and benefit limits when b']
  program_id varchar [note: 'Foreign key linking to care.program. Business justification: Plan belongs to a program; adding program_id FK establishes parent-child relationship and enables join to program attributes.']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Care plan authorship and accountability: a care plan is owned by a specific treating/managing provider. Care coordination workflows, provider outreach, and regulatory care management reporting require']
  barriers_to_care varchar [note: 'Identified obstacles that may impede goal achievement (e.g., transportation, language).']
  care_plan_status varchar [note: 'Current lifecycle status of the care plan.']
  creation_timestamp timestamp [note: 'Timestamp when the care plan record was first created in the system.']
  effective_end_date date [note: 'Date when the care plan expires or is terminated; null if open‑ended.']
  effective_start_date date [note: 'Date when the care plan becomes effective for the member.']
  fhir_activity varchar [note: 'FHIR CarePlan.activity mapping']
  fhir_goal varchar [note: 'FHIR CarePlan.goal mapping']
  fhir_intent varchar [note: 'FHIR CarePlan.intent mapping']
  fhir_status varchar [note: 'FHIR CarePlan.status mapping']
  fhir_subject varchar [note: 'FHIR CarePlan.subject mapping']
  high_risk_flag boolean [note: 'Indicates whether the member meets high‑risk criteria for intensive management.']
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent update to the care plan.']
  plan_name varchar [note: 'Descriptive name of the care plan, e.g., "Diabetes Management Plan".']
  plan_number varchar [note: 'External business identifier assigned to the care plan, used in member communications and reporting.']
  plan_type varchar [note: 'Category of the care plan indicating its primary focus area.']
  privacy_consent_flag boolean [note: 'Indicates whether the member has consented to share health information for care planning.']
  progress_notes varchar [note: 'Free‑text notes documenting progress toward the goal.']
  version varchar [note: 'Incremental version number tracking revisions to the care plan.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Individualized care plan created for a member enrolled in a care or case management program — documenting clinical and behavioral goals (goal description, category, target value, target date, status: active/achieved/abandoned, progress notes), interventions, barriers to care, target dates, care coordinator assignments, plan status, and clinical/progress notes. Goals are modeled as embedded detail records within the care plan with independent status tracking, enabling multi-dimensional progress measurement across clinical, behavioral, and SDOH goal categories. Single source of truth for all care plan goal lifecycle management. Supports longitudinal tracking of member health outcomes. Aligns with NCQA care management standards and CMS chronic care management (CCM) requirements. Source: Casenet TruCare or Altruista. [FHIR-aligned]'
}

Table care.plan_goal {
  plan_goal_id varchar [pk, note: 'System-generated unique identifier for the care plan goal.']
  care_plan_id varchar [note: 'Identifier of the care plan to which this goal belongs.']
  coordinator_id varchar [note: 'Identifier of the staff member responsible for overseeing the goal.']
  actual_date date [note: 'Date when the actual value was recorded.']
  actual_value decimal(10,2) [note: 'Measured value achieved toward the goal.']
  compliance_flag boolean [note: 'Indicates whether the goal complies with clinical guidelines or regulatory requirements.']
  created_timestamp timestamp [note: 'Timestamp when the goal record was first created in the system.']
  goal_category varchar [note: 'Classification of the goal indicating its domain (e.g., clinical, behavioral, social determinant).']
  goal_code varchar [note: 'Business identifier or code assigned to the goal for reference and reporting.']
  goal_name varchar [note: 'Human‑readable name or title of the care plan goal.']
  measurement_type varchar [note: 'Source or method of the measurement (e.g., lab result, vital sign).']
  plan_goal_status varchar [note: 'Current lifecycle status of the goal.']
  priority varchar [note: 'Priority level assigned to the goal to guide care team focus.']
  progress_notes varchar [note: 'Free‑text notes documenting progress, barriers, or interventions related to the goal.']
  risk_score decimal(5,2) [note: 'Calculated risk score associated with the goal (e.g., based on HCC/RAF models).']
  target_date date [note: 'Date by which the goal is expected to be met.']
  target_unit varchar [note: 'Unit of measure for the target value.']
  target_value decimal(10,2) [note: 'Numeric target the member should achieve (e.g., HbA1c 7.0).']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the goal record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Individual clinical or behavioral goals defined within a member care plan — including goal description, goal category (clinical, behavioral, social determinants), target value, target date, goal status (active, achieved, abandoned), and progress notes. Each goal has its own lifecycle independent of the parent care plan, enabling granular tracking of member progress across multiple care dimensions. [FHIR-aligned]'
}

Table care.gap {
  gap_id varchar [pk, note: 'Unique identifier for the care gap record.']
  assigned_care_coordinator_id varchar [note: 'Identifier of the care coordinator assigned to address the gap.']
  claim_line_id varchar [note: 'Foreign key linking to claim.line. Business justification: Gap closure is determined at the claim line level — a specific procedure code on a specific service line satisfies a HEDIS or clinical gap. Line-level precision is required for gap closure audits; the']
  hcc_mapping_id varchar [note: 'Foreign key linking to risk.hcc_mapping. Business justification: Care gaps are frequently HCC-specific — closing a gap (e.g., documenting a chronic condition) directly impacts risk adjustment scores. This FK links each gap to the specific HCC code it targets, suppo']
  hedis_measure_id varchar [note: 'Foreign key linking to care.hedis_measure. Business justification: gap.hedis_measure_code is a denormalized string reference to the HEDIS measure catalog. Care gaps are frequently defined by non-compliance with specific HEDIS measures (e.g., a gap for HbA1c testing m']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: HEDIS care gap identification and closure tracking is tied to a member\'s active policy/coverage period. Gap closure outreach and compliance reporting require knowing which policy was in force when the']
  responsible_provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: HEDIS/quality gap closure is attributed to a responsible provider for provider scorecards, gap closure outreach, and pay-for-performance reporting. Role-prefix \'responsible\' used because the business ']
  actual_resolution_date date [note: 'Date when the care gap was actually resolved.']
  clinical_category varchar [note: 'Clinical domain or condition associated with the gap (e.g., diabetes, cardiovascular).']
  close_date date [note: 'Date when the care gap was resolved or closed (nullable if still open).']
  closure_method varchar [note: 'Method by which the care gap was closed.']
  created_timestamp timestamp [note: 'Timestamp when the care gap record was created in the lakehouse.']
  description varchar [note: 'Narrative description of the identified care gap.']
  documentation_status varchar [note: 'Status of required documentation for the care gap.']
  gap_status varchar [note: 'Current lifecycle status of the care gap.']
  gap_type varchar [note: 'Category of the care gap (e.g., preventive service, chronic condition management).']
  is_critical boolean [note: 'Indicates whether the gap is considered critical for member health.']
  measure_target_value decimal(18,2) [note: 'Expected target value for the measure (e.g., HbA1c <7%).']
  open_date date [note: 'Date when the care gap was first identified.']
  priority_level varchar [note: 'Business-assigned priority for addressing the care gap.']
  risk_score decimal(5,2) [note: 'Quantitative risk score associated with the gap (e.g., based on HCC/RAF).']
  target_date date [note: 'Desired date by which the care gap should be closed.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the care gap record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Registry of identified care gaps for members — preventive services, chronic condition management measures, and HEDIS-aligned quality measures that have not been completed (e.g., HbA1c testing, mammography, colorectal cancer screening, medication adherence). Tracks gap type, HEDIS measure code, gap open date, gap close date, closure method (claim, supplemental data, attestation), and gap status. Core to HEDIS performance and Star Ratings improvement programs. [FHIR-aligned]'
}

Table care.coordinator {
  coordinator_id varchar [pk, note: 'Surrogate primary key uniquely identifying each care coordinator record.']
  assigned_lob varchar [note: 'Business line for which the coordinator primarily provides services.']
  caseload_capacity varchar [note: 'Maximum number of members the coordinator can actively manage.']
  caseload_weight decimal(5,2) [note: 'Weighted factor reflecting case complexity for workload balancing.']
  certification_codes varchar [note: 'Comma‑separated list of professional certifications (e.g., CCM, ACM, CPH).']
  coordinator_status varchar [note: 'Current lifecycle status of the coordinator record.']
  current_caseload_count varchar [note: 'Number of members currently assigned to the coordinator.']
  email_address varchar [note: 'Primary email address used for secure communications with the coordinator.']
  employment_status varchar [note: 'Current employment state of the coordinator.']
  first_name varchar [note: 'Given name of the care coordinator.']
  full_name varchar [note: 'Legal full name of the care coordinator as used in member communications and credentialing.']
  hire_date date [note: 'Date the coordinator was hired by the organization.']
  last_name varchar [note: 'Family name of the care coordinator.']
  last_training_date date [note: 'Date of the most recent mandatory training completed by the coordinator.']
  notes varchar [note: 'Free‑form notes entered by supervisors or administrators about the coordinator.']
  organization_unit varchar [note: 'Department or unit within the health plan where the coordinator is assigned.']
  phone_number varchar [note: 'Primary telephone number for reaching the coordinator.']
  primary_contact_method varchar [note: 'Preferred channel for contacting the coordinator.']
  record_audit_created timestamp [note: 'Timestamp when the coordinator record was first created in the system.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent update to the coordinator record.']
  role_type varchar [note: 'Functional role of the coordinator within the care management domain.']
  specialty_area varchar [note: 'Clinical specialty or disease focus of the coordinator.']
  termination_date date [note: 'Date the coordinator\'s employment ended, if applicable.']
  training_certifications varchar [note: 'Comma‑separated list of completed training programs (e.g., HEDIS, STAR).']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Master record for care coordinators, case managers, disease management nurses, and health coaches — capturing demographics, credentials (RN, LCSW, CHW), certifications (CCM, ACM), caseload capacity, specialty focus areas, assigned LOB, active status, and supervisor hierarchy. Single source of truth for coordinator-to-member assignment history including assignment date, assignment type (primary, backup, specialist), assignment reason, caseload weight, assignment status, reassignment/handoff tracking, and continuity-of-care documentation. Enables caseload management, workload balancing, continuity-of-care reporting, and coordinator performance analytics. Source: Casenet TruCare or Altruista workforce configuration. [FHIR-aligned]'
}

Table care.condition_registry {
  condition_registry_id varchar [pk, note: 'System-generated unique identifier for each condition registry record.']
  care_plan_id varchar [note: 'Identifier of the care plan linked to this condition, if any.']
  diagnosing_provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Risk adjustment and HCC coding workflows require knowing which provider diagnosed each condition. CMS risk adjustment audits and RADV reviews trace HCC codes to diagnosing providers. Role-prefix \'diag']
  hcc_mapping_id varchar [note: 'Foreign key linking to risk.hcc_mapping. Business justification: CMS risk adjustment requires each diagnosed condition in the registry to map to a specific HCC code record. This FK drives RAF score calculation and RAPS submission workflows. hcc_code on condition_re']
  member_identity_id varchar [note: 'Unique identifier of the member to whom the condition applies.']
  source_claim_diagnosis_id varchar [note: 'Foreign key linking to claim.diagnosis. Business justification: Chronic condition registry entries are sourced from claim diagnoses (ICD codes). This FK supports HCC coding, risk adjustment, and chronic condition identification workflows — a domain expert expects ']
  active_flag boolean [note: 'Indicates whether the condition is currently active for the member.']
  condition_category varchar [note: 'Business classification of the condition (e.g., HCC‑mapped, HEDIS chronic, behavioral health).']
  condition_code varchar [note: 'Standard ICD-10 diagnosis code representing the clinical condition.']
  condition_description varchar [note: 'Human‑readable description of the condition.']
  confirmation_status varchar [note: 'Current confirmation state of the condition record.']
  created_timestamp timestamp [note: 'Timestamp when the condition record was first created.']
  data_quality_status varchar [note: 'Current data quality assessment of the condition record.']
  effective_end_date date [note: 'Date the condition ceased to be effective (null if still active).']
  effective_start_date date [note: 'Date the condition became effective for care program eligibility.']
  fhir_clinical_status varchar [note: 'FHIR Condition.clinicalStatus mapping']
  fhir_code varchar [note: 'FHIR Condition.code mapping']
  fhir_subject varchar [note: 'FHIR Condition.subject mapping']
  identification_date date [note: 'Date the condition was first identified for the member.']
  identification_method varchar [note: 'Method used to identify the condition for the member.']
  is_chronic boolean [note: 'Flag indicating whether the condition is considered chronic for HEDIS and risk adjustment.']
  last_review_date date [note: 'Date the condition record was last reviewed for accuracy.']
  notes varchar [note: 'Free‑text clinical notes or comments about the condition.']
  onset_date date [note: 'Date when the condition first manifested.']
  population_segment varchar [note: 'Segment of the member population based on the condition\'s risk level.']
  raf_score decimal(5,2) [note: 'Calculated RAF score associated with the condition.']
  resolution_date date [note: 'Date when the condition was resolved or considered inactive.']
  risk_adjustment_flag boolean [note: 'Indicates if the condition contributes to risk‑adjusted payments.']
  severity varchar [note: 'Clinical severity level of the condition.']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the condition record.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Chronic condition registry identifying members with specific diagnosed conditions — including ICD-10 condition code, condition category (HCC-mapped, HEDIS chronic condition, behavioral health), identification method (claims-based, EHR, provider attestation, HRA), identification date, confirmation status, and active/inactive flag. Serves as the authoritative clinical condition roster within the care domain for care program targeting, population health stratification, and HEDIS measure eligibility determination. References the risk domain for authoritative HCC/RAF scoring. Source: Casenet TruCare or Altruista clinical data. [FHIR-aligned]'
}

Table care.hedis_measure {
  hedis_measure_id varchar [pk, note: 'Unique identifier for the HEDIS measure. [_canonical_skip_reason: REFERENCE_LOOKUP - catalog of HEDIS quality measures]']
  hcc_mapping_id varchar [note: 'Foreign key linking to risk.hcc_mapping. Business justification: CMS Star Ratings and risk adjustment programs require HEDIS measures to be aligned with specific HCC codes. This FK supports integrated quality-risk reporting and regulatory submissions. measure_relat']
  created_timestamp timestamp [note: 'Timestamp when the measure record was first created in the data lake.']
  data_collection_methodology varchar [note: 'Method used to collect data for the measure (administrative, hybrid, or survey).']
  denominator_definition varchar [note: 'Exact definition of the denominator component of the measure.']
  effective_date date [note: 'Date when the measure became effective for reporting.']
  eligible_population_criteria varchar [note: 'Eligibility rules that define the member cohort for the measure.']
  exclusion_criteria varchar [note: 'Conditions or member attributes that exclude a member from the denominator.']
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent update to the measure record.']
  measure_code varchar [note: 'Official NCQA code that uniquely identifies the measure.']
  measure_denominator_logic varchar [note: 'Detailed logical expression or algorithm used to compute the denominator.']
  measure_description varchar [note: 'Full textual description of what the measure evaluates.']
  measure_domain varchar [note: 'High‑level domain of the measure (e.g., effectiveness of care, access/availability, utilization).']
  measure_exclusion_logic varchar [note: 'Detailed logical expression defining exclusions from the denominator.']
  measure_last_reviewed_date date [note: 'Date when the measure definition was last reviewed for accuracy.']
  measure_last_updated_by varchar [note: 'User or system that performed the most recent update.']
  measure_name varchar [note: 'Descriptive name of the HEDIS quality measure.']
  measure_national_benchmark decimal(5,2) [note: 'National average performance for the measure (percentage).']
  measure_notes varchar [note: 'Free‑form notes or comments about the measure.']
  measure_numerator_logic varchar [note: 'Detailed logical expression or algorithm used to compute the numerator.']
  measure_owner varchar [note: 'Business unit or team responsible for the measure.']
  measure_related_raf decimal(18,6) [note: 'Comma‑separated list of Risk Adjustment Factor (RAF) variables linked to the measure.']
  measure_reporting_frequency varchar [note: 'How often the measure is reported (annual, semi‑annual, quarterly).']
  measure_scoring_method varchar [note: 'Method used to calculate the final score (e.g., rate, percentage, binary).']
  measure_star_rating_impact varchar [note: 'Explanation of how the measure influences Medicare Star Ratings.']
  measure_state_benchmark decimal(5,2) [note: 'State‑level average performance for the measure (percentage).']
  measure_status varchar [note: 'Current lifecycle status of the measure.']
  measure_target_value decimal(10,2) [note: 'Target performance value or threshold for the measure.']
  measure_url varchar [note: 'Link to the official documentation or specification for the measure.']
  measurement_year varchar [note: 'Calendar year for which the measure is defined.']
  numerator_definition varchar [note: 'Exact definition of the numerator component of the measure.']
  retirement_date date [note: 'Date when the measure was retired or superseded (null if still active).']
  version_number varchar [note: 'Version of the measure definition, incremented on each change.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Reference catalog of HEDIS (Healthcare Effectiveness Data and Information Set) quality measures maintained by NCQA — including measure ID, measure name, measure domain (effectiveness of care, access/availability, utilization), measurement year, eligible population criteria, numerator definition, denominator definition, exclusion criteria, and data collection methodology (administrative, hybrid, survey). Authoritative reference for HEDIS performance tracking and Star Ratings. [FHIR-aligned]'
}

Table care.hedis_result {
  hedis_result_id varchar [pk, note: 'System-generated unique identifier for each HEDIS result record.']
  adjudication_id varchar [note: 'Foreign key linking to claim.adjudication. Business justification: HEDIS compliance status depends on whether a claim was adjudicated as paid or denied. NCQA HEDIS audit trails require linking each result to the adjudication record that confirmed claim payment, suppo']
  claim_line_id varchar [note: 'Foreign key linking to claim.line. Business justification: HEDIS numerator and denominator criteria are evaluated at the claim line level (procedure codes, service dates, revenue codes). NCQA HEDIS audit requirements demand traceability from each result to th']
  eligibility_span_id varchar [note: 'Foreign key linking to enrollment.enrollment_eligibility_span. Business justification: NCQA and CMS HEDIS reporting requires that measure results be tied to the specific enrollment period qualifying the member for the denominator. The eligibility span defines the continuous enrollment c']
  group_practice_id varchar [note: 'Foreign key linking to provider.group_practice. Business justification: HEDIS results are reported at group practice level for ACO/PCMH performance reporting and value-based contracts. Group-level quality scorecards and CMS ACO reporting require aggregating measure result']
  health_plan_id varchar [note: 'Identifier of the health plan under which the member is enrolled.']
  hedis_measure_id varchar [note: 'Standard code for the HEDIS quality measure (e.g., HM-001).']
  member_identity_id varchar [note: 'Unique identifier for the member to whom the HEDIS result applies.']
  practice_location_id varchar [note: 'Identifier of the provider associated with the source claim or service.']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: HEDIS results are attributed to rendering providers for provider-level quality reporting, star ratings, and pay-for-performance calculations. Health plans must identify which provider\'s attributed mem']
  vbc_contract_id varchar [note: 'Foreign key linking to contract.vbc_contract. Business justification: VBC contracts specify HEDIS measure targets as quality gates (vbc_contract.hedis_measure_targets, quality_gate_met, quality_score). Actual HEDIS results must be linked to the VBC contract for shared s']
  audit_created timestamp [note: 'Timestamp when the HEDIS result record was first created in the lakehouse.']
  audit_updated timestamp [note: 'Timestamp of the most recent update to the HEDIS result record.']
  collection_method varchar [note: 'Methodology used to collect the underlying data for the measure.']
  compliance_status varchar [note: 'Overall compliance outcome for the member on this measure.']
  data_source varchar [note: 'Origin of the data used to determine the HEDIS result.']
  denominator_criteria_met boolean [note: 'Indicates whether the member satisfied the denominator condition (typically eligibility).']
  eligibility_criteria varchar [note: 'Logical definition of the member population eligible for the measure.']
  exclusion_criteria varchar [note: 'Specific criteria that triggered the member\'s exclusion.']
  exclusion_reason varchar [note: 'Reason or code describing why the member was excluded.']
  is_excluded boolean [note: 'True if the member is excluded from the measure based on exclusion criteria.']
  measure_category varchar [note: 'Category grouping of the measure (e.g., preventive, chronic).']
  measure_score decimal(5,2) [note: 'Numeric score assigned to the member for the measure (if applicable).']
  measure_type varchar [note: 'Classification of the measure as process, outcome, or structure.']
  measure_version varchar [note: 'Version or edition of the measure as published by NCQA.']
  measurement_year varchar [note: 'Calendar year for which the HEDIS measurement is reported.']
  numerator_criteria_met boolean [note: 'Indicates whether the member satisfied the numerator condition for the measure.']
  result_timestamp timestamp [note: 'Date and time when the HEDIS result was calculated.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Single source of truth for HEDIS (Healthcare Effectiveness Data and Information Set) quality measure definitions and member-level compliance results. Contains the authoritative NCQA-published measure catalog (measure ID, name, domain: effectiveness of care/access/availability/utilization, measurement year, eligible population criteria, numerator/denominator definitions, exclusion criteria, data collection methodology: administrative/hybrid/survey) and member-level results indicating whether each member met numerator criteria for a given measurement year. Tracks data source (claim, lab, supplemental, medical record), compliance status (compliant, non-compliant, excluded), and hybrid audit trail. Aggregated to produce plan-level HEDIS rates submitted to NCQA for Star Ratings, accreditation, and quality bonus payments. [FHIR-aligned]'
}

Table care.member_risk_tier {
  member_risk_tier_id varchar [pk, note: 'System‑generated unique identifier for each risk‑tier record.']
  capitation_arrangement_id varchar [note: 'Foreign key linking to contract.capitation_arrangement. Business justification: Capitation arrangements include raf_adjustment_factor and risk_adjustment_applicable fields. Member risk tier directly determines which capitation rate tier and RAF adjustment applies. This FK enables']
  member_identity_id varchar [note: 'Unique identifier of the member to which the tier assignment applies.']
  member_risk_score_id varchar [note: 'Foreign key linking to risk.member_risk_score. Business justification: Risk tier assignment is operationally derived from a specific member risk score calculation. This FK enables tier-to-score traceability for population health stratification reports and audit trails. r']
  recommended_care_program_id varchar [note: 'Foreign key linking to care.program. Business justification: member_risk_tier.recommended_care_program is a free-text STRING field that denormalizes a reference to a care management program. Population health stratification and risk tiering directly drives prog']
  assignment_date date [note: 'Date the tier was assigned to the member.']
  assignment_method varchar [note: 'Method used to assign the tier to a member.']
  chronic_condition_flag boolean [note: 'True if the member has at least one chronic condition flagged.']
  claims_count_last_year varchar [note: 'Number of claims submitted by the member in the prior 12 months.']
  created_timestamp timestamp [note: 'Timestamp when the tier record was first created.']
  demographic_group varchar [note: 'Broad demographic segment of the member.']
  effective_from date [note: 'Date when the tier definition becomes effective.']
  effective_until date [note: 'Date when the tier definition expires (null for open‑ended).']
  hcc_score decimal(5,2) [note: 'Hierarchical Condition Category score used for RAF calculations.']
  inclusion_criteria varchar [note: 'Business rules that determine member eligibility for this tier.']
  is_current boolean [note: 'Indicates whether this row represents the member\'s current active tier.']
  member_risk_tier_status varchar [note: 'Current lifecycle status of the tier definition.']
  model_type varchar [note: 'Type of model used to generate the tier assignment.']
  next_reassessment_date date [note: 'Planned date for the next risk‑tier reassessment.']
  notes varchar [note: 'Free‑form comments or audit notes.']
  pmpm_cost_band decimal(18,2) [note: 'Per‑Member‑Per‑Month cost band associated with the tier.']
  risk_factor_weight decimal(5,2) [note: 'Weight applied to the risk factor in the predictive model.']
  segment_description varchar [note: 'Detailed description of the segment criteria.']
  segment_name varchar [note: 'Name of the population segment definition linked to this tier.']
  tier_band varchar [note: 'Broad risk band classification.']
  tier_code varchar [note: 'Business identifier/code used to reference the tier in downstream systems.']
  tier_name varchar [note: 'Human‑readable name of the risk tier (e.g., "High Risk").']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the tier record.']
  version_number varchar [note: 'Version of the tier definition for change tracking.']
  vreq_validated boolean [note: 'Validation marker for VREQ preservation requirement']

  Note: 'Member-level risk tier assignment and population health stratification — containing population segment definitions (segment name, stratification model: predictive risk model/HCC-based/claims-based, risk tier bands: low/rising risk/high/catastrophic, inclusion criteria, recommended care program, PMPM cost band, effective date) and member-specific tier assignments (risk score, assignment date, assignment method: automated model/manual override/clinical review, next reassessment date). Single source of truth for both population segment configuration and member-level risk tier history. Tracks risk tier changes over time to support longitudinal population health management and care program targeting. Distinct from CMS RAF scores (owned by the risk domain) — this covers all LOBs and internal stratification models. Source: Casenet TruCare or Altruista population health module. [FHIR-aligned]'
}

Table contract.party {
  party_id varchar [pk, note: 'Unique surrogate identifier for each party record in the provider contract domain. Serves as the primary key for all contractual party references across the health plan enterprise.']
  aco_indicator boolean [note: 'Indicates whether this party is an Accountable Care Organization (ACO) participating in a value-based care (VBC) arrangement. Triggers ACO-specific contract terms, shared savings calculations, and CMS reporting requirements.']
  capitation_eligible_indicator boolean [note: 'Indicates whether this party is eligible to receive capitation payments (Per Member Per Month - PMPM) under the contract. Drives capitation payment processing and actuarial PMPM rate application.']
  contract_party_number varchar [note: 'Externally-known alphanumeric identifier assigned to this party within the contract management system (e.g., Cactus or ProviderSource provider contract number). Used for cross-system reconciliation, EDI transactions, and provider directory publication.']
  credentialing_date date [note: 'Date on which the party was most recently credentialed or re-credentialed by the health plan. NCQA requires re-credentialing every 36 months. Used to trigger re-credentialing workflows and network compliance reporting.']
  credentialing_status varchar [note: 'Current credentialing status of the party as maintained in the Provider Management System (Cactus/ProviderSource). Determines whether the party is eligible to provide services to plan members. Credentialing must be current for claims to be adjudicated as in-network.']
  delegation_indicator boolean [note: 'Indicates whether this party is a delegated entity authorized to perform functions on behalf of the health plan (e.g., credentialing, utilization management, claims processing). Triggers delegation oversight and audit requirements per NCQA and state DOI standards.']
  delegation_scope varchar [note: 'Specifies the functional scope of delegation authority granted to this party. Applicable only when delegation_indicator is true. Defines which health plan functions the delegated entity is authorized to perform on behalf of the payer.']
  doing_business_as_name varchar [note: 'Trade name or DBA name under which the party operates, if different from the legal entity name. Commonly used for group practices and hospital systems that operate under a brand name distinct from their legal registration.']
  effective_date date [note: 'Date on which this party\'s participation in the contract becomes effective. Drives claims adjudication eligibility windows, network directory publication, and provider credentialing timelines.']
  legal_entity_name varchar [note: 'Full legal name of the contracting party as registered with state or federal authorities. Used for contract execution, credentialing, and regulatory reporting. May be an individual provider name, group practice name, IPA, ACO, or hospital system name.']
  license_expiration_date date [note: 'Date on which the party\'s primary state professional or business license expires. Triggers credentialing re-verification workflows and may result in contract suspension if not renewed. Critical for NCQA and URAC credentialing compliance.']
  license_state varchar [note: 'Two-letter USPS state abbreviation where the party holds its primary professional or business license. Used for network adequacy reporting, credentialing, and state-specific regulatory compliance.']
  line_of_business varchar [note: 'Health plan line of business under which this party is contracted. Determines applicable regulatory requirements, reimbursement methodologies, and network adequacy standards. [ENUM-REF-CANDIDATE: commercial|medicare_advantage|medicaid|marketplace|cobra|fehb — promote to reference product]']
  malpractice_coverage_indicator boolean [note: 'Indicates whether the party maintains active professional liability (malpractice) insurance coverage as required by the contract. Failure to maintain coverage may trigger contract suspension or termination per NCQA credentialing standards.']
  malpractice_expiration_date date [note: 'Date on which the party\'s professional liability (malpractice) insurance policy expires. Triggers credentialing re-verification and contract compliance monitoring workflows.']
  network_participation_type varchar [note: 'Indicates whether the party is a participating (PAR) in-network provider, a non-participating (non-PAR) provider, or an out-of-network provider. Drives member cost-sharing calculations, claims adjudication rules, and EOB generation.']
  notes varchar [note: 'Free-text field for capturing supplemental information about the party that does not fit structured attributes. May include contract negotiation notes, special arrangement details, or credentialing exceptions. Classified as confidential due to potential inclusion of sensitive business information.']
  npi varchar [note: 'The 10-digit National Provider Identifier assigned by CMS to uniquely identify the provider party. Type 1 NPI for individual providers; Type 2 NPI for organizational providers. Required for all HIPAA-covered transactions including 837 claims and 270/271 eligibility inquiries.']
  npi_type varchar [note: 'Indicates whether the NPI is Type 1 (individual/solo practitioner) or Type 2 (organizational entity such as group practice, hospital, or IPA). Determines credentialing requirements and contract structure.']
  oig_exclusion_indicator boolean [note: 'Indicates whether the party appears on the OIG List of Excluded Individuals/Entities (LEIE). Excluded parties are prohibited from participating in Medicare, Medicaid, and other federal healthcare programs. Checked monthly per CMS compliance requirements.']
  party_role varchar [note: 'Functional role of this party within the contract relationship. Identifies whether the party is the health plan (payer), a contracting provider, a delegated entity, an Independent Practice Association (IPA), an Accountable Care Organization (ACO), a hospital system, or a group practice. [ENUM-REF-CANDIDATE: payer|provider|delegated_entity|ipa|aco|hospital_system|group_practice — promote to reference product]']
  party_status varchar [note: 'Current lifecycle status of the party within the contract. Indicates whether the party is actively bound by the contract, pending execution, suspended, terminated, or inactive. Drives eligibility verification and claims adjudication routing.']
  party_type varchar [note: 'Classifies the party as an individual (natural person, e.g., solo practitioner with individual NPI) or an organization (legal entity, e.g., group practice, hospital, IPA, ACO). Drives NPI type assignment and credentialing workflow.']
  primary_specialty_code varchar [note: 'NUCC Health Care Provider Taxonomy Code representing the party\'s primary clinical specialty. Used for network adequacy analysis, claims routing, prior authorization rules, and provider directory classification.']
  raf_applicable_indicator boolean [note: 'Indicates whether Risk Adjustment Factor (RAF) scoring applies to this party\'s contract arrangement. Relevant for Medicare Advantage and ACA marketplace contracts where Hierarchical Condition Category (HCC) risk scores drive capitation payments.']
  record_created_timestamp timestamp [note: 'Timestamp when this party record was first created in the data platform. Supports audit trail, data lineage, and compliance reporting requirements. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  record_updated_timestamp timestamp [note: 'Timestamp when this party record was most recently modified in the data platform. Supports change data capture, audit trail, and SCD Type 2 processing in the Databricks Silver Layer.']
  recredentialing_due_date date [note: 'Date by which the party must complete re-credentialing to maintain active network participation. Calculated as 36 months from the credentialing_date per NCQA standards. Drives automated re-credentialing workflow initiation.']
  sanction_indicator boolean [note: 'Indicates whether the party has an active sanction, exclusion, or adverse action recorded by OIG, SAM, or state licensing boards. A true value triggers contract suspension review and claims payment hold per CMS and HIPAA compliance requirements.']
  service_area_state varchar [note: 'Two-letter USPS state abbreviation representing the primary state in which this party provides services under the contract. Used for network adequacy reporting, state regulatory compliance, and geographic claims routing.']
  service_area_zip_code varchar [note: 'Primary ZIP code of the party\'s principal service location. Used for network adequacy geo-mapping, member-to-provider distance calculations, and CMS network adequacy submissions.']
  signatory_name varchar [note: 'Full name of the authorized individual who signed or has authority to sign the contract on behalf of this party. Required for contract execution validation and legal enforceability. Typically the CEO, CMO, or designated contracting officer.']
  signatory_title varchar [note: 'Official title or position of the authorized signatory (e.g., Chief Executive Officer, Medical Director, Contracting Officer). Validates the authority level of the individual executing the contract on behalf of the party.']
  source_system_code varchar [note: 'Identifies the operational system of record from which this party record originated (e.g., Cactus, ProviderSource, Facets, QNXT). Supports data lineage tracking, reconciliation, and ETL audit in the Databricks Silver Layer.']
  source_system_party_reference varchar [note: 'The native identifier of this party record in the originating operational system (e.g., Cactus provider ID, ProviderSource contract party key). Enables cross-system reconciliation and traceability from the Silver Layer back to the system of record.']
  state_license_number varchar [note: 'State-issued professional or business license number for the contracting party. Required for credentialing verification and network participation. For individual providers, this is the state medical license; for organizations, the state business license or certificate of authority.']
  termination_date date [note: 'Date on which this party\'s participation in the contract ends. Null for open-ended or currently active parties. Used to determine network participation windows, claims payment eligibility, and member notification requirements.']
  tin varchar [note: 'Federal Tax Identification Number (EIN or SSN) used for payment processing, 1099 reporting, and IRS compliance. Critical for remittance and premium payment routing. Stored as 9-digit numeric string without hyphens.']
  vbc_arrangement_type varchar [note: 'Specifies the payment methodology or value-based care arrangement type applicable to this party under the contract. Drives reimbursement calculation logic, risk-sharing model application, and financial reporting. [ENUM-REF-CANDIDATE: fee_for_service|capitation|bundled_payment|shared_savings|global_risk — promote to reference product]']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Identifies all parties bound by a provider contract — the health plan entity, the contracting provider (individual NPI or organizational NPI), group practice, IPA, ACO, or hospital system. Tracks party role (payer, provider, delegated entity), NPI, TIN, legal entity name, signatory authority, and party effective dates. Supports multi-party and delegated contracting arrangements. [FHIR-aligned]'
}

Table contract.term {
  term_id varchar [pk, note: 'Unique surrogate identifier for a contract term record in the provider contract management system (Facets/QNXT or Provider Management System). Serves as the primary key for the term entity.']
  fee_schedule_id decimal(18,2) [note: 'Reference to the fee schedule associated with this term when payment_methodology is fee_for_service. Links to the rate table governing allowed amounts for procedure codes under this term.']
  party_id varchar [note: 'Foreign key linking to contract.party. Business justification: Contract terms are negotiated with and applicable to specific contracting parties. Linking term to party establishes which party is bound by each term, enabling party-specific term retrieval and contr']
  reimbursement_policy_id varchar [note: 'Foreign key linking to contract.reimbursement_policy. Business justification: term has a reimbursement_policy_subtype field indicating that contract terms reference specific reimbursement policies. This FK formalizes that relationship, linking each term to the reimbursement pol']
  vbc_contract_id varchar [note: 'Foreign key linking to contract.vbc_contract. Business justification: VBC contracts have specific terms governing risk-sharing, quality metrics, and performance obligations. Linking term to vbc_contract allows VBC-specific terms (risk_sharing_model, quality_metric_thres']
  audit_rights_period_years varchar [note: 'The number of years the health plan retains the right to audit provider records under this audit rights term. Typically 7 years per HIPAA and CMS requirements. Applicable when term_type is \'audit_rights\'.']
  auto_renew boolean [note: 'Indicates whether this term automatically renews upon expiration without requiring renegotiation (True). Supports contract lifecycle management and renewal notification workflows.']
  capitation_rate decimal(12,4) [note: 'The Per Member Per Month (PMPM) capitation rate defined by this term when payment_methodology is capitation. Represents the fixed monthly payment per enrolled member to the provider regardless of services rendered. Classified confidential as proprietary pricing.']
  compliance_checkpoint_date date [note: 'The scheduled date for the next compliance review or audit checkpoint associated with this term. Used by the compliance team to track regulatory obligations, CMS audit readiness, and DOI examination preparation.']
  cpt_range_end varchar [note: 'The ending CPT or HCPCS procedure code of the range to which this reimbursement rule term applies. Used in conjunction with cpt_range_start to define the applicable procedure code range for adjudication.']
  cpt_range_start varchar [note: 'The starting CPT or HCPCS procedure code of the range to which this reimbursement rule term applies. Used in conjunction with cpt_range_end to define the applicable procedure code range for adjudication.']
  created_timestamp timestamp [note: 'The timestamp when this contract term record was first created in the system. Supports audit trail, data lineage, and regulatory record retention requirements.']
  dispute_resolution_method varchar [note: 'The contractually agreed method for resolving disputes arising under this term: Arbitration, Mediation, Litigation, or Internal Review. Applicable for hold-harmless, indemnification, and audit rights terms.']
  drg_grouper_version varchar [note: 'The DRG grouper version (e.g., \'MS-DRG v41.0\', \'APR-DRG v39\') applicable to this term when payment_methodology is \'drg_based\'. Ensures adjudication uses the correct DRG weight tables for inpatient reimbursement.']
  effective_date date [note: 'The date on which this contract term becomes legally binding and operationally enforceable. Used to determine applicability during claims adjudication in Facets/QNXT.']
  expiration_date date [note: 'The date on which this contract term ceases to be binding. Null for open-ended terms with no defined end date. Used in adjudication date-range checks.']
  governing_state varchar [note: 'The two-letter US state code whose laws govern this contract term. Determines applicable state DOI regulations, insurance code requirements, and state-specific provider contract mandates.']
  hipaa_baa_required boolean [note: 'Indicates whether this term constitutes or requires a HIPAA Business Associate Agreement (BAA) (True). Triggers compliance tracking and ensures Protected Health Information (PHI) handling obligations are documented per HIPAA 45 CFR Part 164.']
  icd_version varchar [note: 'Specifies the ICD diagnosis coding version applicable to this term when the term references diagnosis-based reimbursement rules or Hierarchical Condition Category (HCC) risk adjustment provisions.']
  incentive_amount decimal(15,2) [note: 'The maximum dollar amount of quality incentive payment available to the provider under this term upon meeting quality_metric_threshold. Applicable for VBC, ACO, and pay-for-performance contract terms. Classified confidential as proprietary financial terms.']
  is_adjudication_rule boolean [note: 'Indicates whether this term directly drives claims adjudication logic in Facets/QNXT (True). When True, the term\'s reimbursement_policy_subtype, cpt_range_start/end, and reduction_percentage are loaded into the adjudication engine.']
  is_negotiable boolean [note: 'Indicates whether this contract term is open to negotiation (True) or is standard non-negotiable boilerplate language (False). Supports contract negotiation workflow and template management.']
  is_standard_boilerplate boolean [note: 'Indicates whether this term is sourced from the organization\'s standard contract template library (True) or is a custom-negotiated term specific to this contract (False). Supports template governance and deviation tracking.']
  lob_applicability varchar [note: 'Specifies which Line of Business (LOB) this contract term applies to. Enables selective application of reimbursement rules and contractual obligations across Commercial, Medicare Advantage, Medicaid, Marketplace (ACA/QHP), or all lines of business.']
  mac_pricing_basis varchar [note: 'The drug pricing benchmark used for pharmacy reimbursement terms: Average Wholesale Price (AWP), Wholesale Acquisition Cost (WAC), Maximum Allowable Cost (MAC), National Average Drug Acquisition Cost (NADAC), or a custom contracted rate. Applicable for terms covering pharmacy benefits.']
  payment_methodology decimal(18,2) [note: 'The reimbursement payment methodology defined by this term when term_type is \'payment_methodology\' or \'reimbursement_rule\'. Drives adjudication logic in Facets/QNXT. Includes Fee-for-Service (FFS), Capitation, Bundled Payment, Case Rate, Per Diem, Diagnosis Related Group (DRG)-based, Reference Based Pricing (RBP), and Value-Based Care (VBC). [ENUM-REF-CANDIDATE: fee_for_service|capitation|bundled_payment|case_rate|per_diem|drg_based|rbp|vbc — 8 candidates stripped; promote to reference product]']
  pos_code varchar [note: 'The CMS Place of Service (POS) code to which this term\'s reimbursement differential applies, when reimbursement_policy_subtype is \'pos_differential\'. Two-digit code per CMS POS code set (e.g., \'11\' for Office, \'21\' for Inpatient Hospital).']
  quality_metric_threshold decimal(5,2) [note: 'The minimum quality performance threshold (expressed as a percentage or score) that the provider must achieve to qualify for incentive payments or avoid penalties under quality incentive terms. Linked to HEDIS or STAR measures.']
  reduction_percentage decimal(5,2) [note: 'The percentage reduction applied to the allowed amount under this reimbursement rule term (e.g., 50.00 for a 50% reduction on secondary procedures under multiple procedure reduction policy). Applicable when reimbursement_policy_subtype is set. Classified confidential as it represents proprietary pricing.']
  renewal_notice_days varchar [note: 'The number of calendar days prior to expiration_date by which either party must provide notice of intent not to renew this term. Applicable when auto_renew is True.']
  risk_sharing_model varchar [note: 'Defines the risk-sharing arrangement under Value-Based Care (VBC) or Accountable Care Organization (ACO) contract terms. Specifies whether the provider participates in shared savings only (upside), shared risk (two-sided), or full risk (global capitation).']
  source_system_term_ref varchar [note: 'The native identifier of this term record in the originating operational system (e.g., Cactus contract clause ID, QNXT reimbursement rule ID, or ProviderSource term reference). Supports data lineage and reconciliation with source systems.']
  summary varchar [note: 'Plain-language operational summary of the term\'s intent and impact, authored by the contracting team. Used for training, audits, and quick reference without reading full legal text.']
  term_number varchar [note: 'Human-readable external identifier for the term, typically formatted as a section or clause reference (e.g., \'TERM-2024-0042\' or \'Section 4.2.1\'). Used in contract documents and correspondence.']
  term_status varchar [note: 'Current lifecycle state of the contract term. \'active\' indicates the term is currently in force; \'superseded\' indicates it has been replaced by an amendment; \'expired\' indicates the effective period has lapsed.']
  term_type varchar [note: 'Categorical classification of the contract term defining its legal or operational purpose. Drives downstream adjudication logic and compliance tracking. [ENUM-REF-CANDIDATE: reimbursement_rule|payment_methodology|exclusivity|termination_clause|audit_rights|hold_harmless|indemnification|confidentiality|hipaa_baa|quality_incentive — promote to reference product]']
  termination_cause_type varchar [note: 'Specifies the basis under which termination is permitted by this term: For Cause (material breach, fraud, license revocation), Without Cause (convenience), Mutual Agreement, or Regulatory (required by law or CMS/DOI directive).']
  termination_notice_days varchar [note: 'The number of calendar days of advance written notice required to terminate the contract under this termination clause term. Applicable when term_type is \'termination_clause\'. Typically 30, 60, or 90 days per regulatory requirements.']
  text varchar [note: 'Full verbatim legal text of the contract term as negotiated and executed. Contains the binding contractual language. Classified confidential as it represents proprietary reimbursement and legal obligations.']
  title varchar [note: 'Short descriptive title of the contract term as it appears in the contract document (e.g., \'Multiple Procedure Reduction Policy\', \'Termination for Cause Clause\'). Supports search and display in contract management UIs.']
  updated_timestamp timestamp [note: 'The timestamp when this contract term record was last modified. Supports change tracking, audit trail, and Silver layer incremental processing in the Databricks Lakehouse.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']
  withhold_percentage decimal(5,2) [note: 'The percentage of reimbursement withheld from provider payments pending quality performance or risk settlement under VBC or capitation arrangements. Classified confidential as proprietary financial terms.']

  Note: 'Defines the specific terms, conditions, obligations, and reimbursement policies within a provider contract. Captures term type (payment methodology, exclusivity, termination clause, audit rights, hold-harmless, indemnification, confidentiality, HIPAA BAA, reimbursement rule), term text, effective date, expiration date, and whether the term is negotiable or standard boilerplate. For reimbursement rule terms: captures policy sub-type (multiple procedure reduction, bilateral procedure, assistant surgeon, global surgery, unbundling rules, place-of-service differential), applicable CPT/HCPCS ranges, reduction percentage, and LOB applicability. Enables granular tracking of contractual obligations, compliance checkpoints, and reimbursement adjudication rules. Bridges contract terms to claims adjudication logic in Facets/QNXT. [FHIR-aligned]'
}

Table contract.fee_schedule {
  fee_schedule_id decimal(18,2) [pk, note: 'Unique surrogate identifier for the fee schedule record in the contract domain. Primary key for the fee_schedule data product.']
  party_id varchar [note: 'Foreign key linking to contract.party. Business justification: A fee schedule is negotiated with and belongs to a specific contracting party (provider or provider group). This FK establishes the essential link between the fee schedule and the party it governs. Th']
  superseded_by_fee_schedule_id decimal(18,2) [note: 'Reference to the fee_schedule_id of the newer fee schedule that replaced this one when schedule_status is \'superseded\'. Enables fee schedule version chain navigation and historical rate lookups.']
  amendment_number varchar [note: 'Identifier for the contract amendment that introduced or modified this fee schedule version. Null for the original fee schedule. Enables traceability between fee schedule versions and contract amendments.']
  anesthesia_applicable boolean [note: 'Indicates whether this fee schedule includes anesthesia service reimbursement, which uses base units plus time units multiplied by a conversion factor rather than standard CPT-based rates.']
  anesthesia_conversion_factor decimal(10,4) [note: 'Dollar amount per anesthesia unit (base units + time units) used to calculate anesthesia reimbursement when anesthesia_applicable is True. Negotiated rate specific to this fee schedule.']
  approval_date date [note: 'Date on which the fee schedule was formally approved by the authorized contracting officer or governance body. Required for audit and regulatory compliance.']
  cms_fee_schedule_year decimal(18,2) [note: 'The CMS Medicare fee schedule calendar year used as the basis or benchmark for this fee schedule when fee_schedule_source is \'cms_medicare\'. Enables tracking of which CMS annual update cycle the rates are derived from.']
  conversion_factor decimal(10,4) [note: 'Dollar amount multiplied by the total Relative Value Units (RVUs) to calculate the reimbursement amount for RVU-based fee schedules. Applicable when payment_basis is \'rvu_based\'. Sourced from CMS RBRVS conversion factor or negotiated contract rate.']
  coordination_of_benefits_applicable boolean [note: 'Indicates whether Coordination of Benefits (COB) rules apply to claims adjudicated under this fee schedule. When True, COB logic determines primary vs. secondary payer responsibilities.']
  cpt_code_range_end varchar [note: 'Ending CPT procedure code in the range of services covered by this fee schedule. Used in conjunction with cpt_code_range_start to define the scope of applicable procedure codes.']
  cpt_code_range_start varchar [note: 'Starting CPT procedure code in the range of services covered by this fee schedule. Used in conjunction with cpt_code_range_end to define the scope of applicable procedure codes. Null if the fee schedule applies to all CPT codes or uses ICD/DRG-based scoping.']
  created_timestamp timestamp [note: 'Timestamp when this fee schedule record was first created in the system. Audit field capturing the initial record creation event in the Databricks Silver Layer.']
  description decimal(18,2) [note: 'Free-text narrative description of the fee schedule, including its purpose, scope, special provisions, or notes relevant to adjudication staff and contract analysts.']
  drg_applicable boolean [note: 'Indicates whether this fee schedule uses Diagnosis Related Group (DRG)-based reimbursement for inpatient facility claims. When True, DRG weights and base rates govern payment rather than individual procedure codes.']
  drg_base_rate decimal(12,2) [note: 'The negotiated base dollar rate per DRG weight unit used for inpatient facility reimbursement when drg_applicable is True. Multiplied by the DRG relative weight to calculate the total inpatient payment.']
  effective_date date [note: 'Date on which the fee schedule becomes effective and applicable for claim adjudication and reimbursement calculations. Inclusive start date of the fee schedule validity period.']
  geographic_modifier_applicable boolean [note: 'Indicates whether geographic adjustment factors (e.g., CMS Geographic Practice Cost Indices - GPCI) are applied to rates under this fee schedule. True when locality-based adjustments are in effect; False for flat national rates.']
  global_surgery_applicable boolean [note: 'Indicates whether global surgery payment rules apply under this fee schedule, bundling pre-operative, intra-operative, and post-operative services into a single reimbursement amount.']
  lob_code varchar [note: 'Identifies the Line of Business (LOB) to which this fee schedule applies (e.g., commercial, Medicare Advantage, Medicaid, ACA Marketplace, COBRA, FEHB). Determines which member populations and plan types are subject to this fee schedule during adjudication.']
  locality_code varchar [note: 'CMS Medicare locality code identifying the geographic pricing area applicable to this fee schedule when geographic_modifier_applicable is True. Used to apply GPCI adjustments to RVU-based rates.']
  medicare_crossover_applicable boolean [note: 'Indicates whether this fee schedule applies to Medicare crossover claims where Medicare is the primary payer and the health plan is the secondary payer. Relevant for Medicare Advantage and Medigap plans.']
  modifier_applicable boolean [note: 'Indicates whether CPT or HCPCS modifiers affect reimbursement rates under this fee schedule (e.g., modifier 26 for professional component, modifier TC for technical component, modifier 50 for bilateral procedures).']
  outlier_threshold_amt decimal(12,2) [note: 'Dollar threshold above which a claim qualifies as a cost outlier, triggering additional reimbursement beyond the standard DRG or bundled payment. Applicable for institutional fee schedules with outlier payment provisions.']
  payment_basis decimal(18,2) [note: 'The methodology used to calculate reimbursement amounts under this fee schedule. Options include: pct_medicare (percentage of Medicare allowable), pct_billed_charges (percentage of provider billed charges), flat_rate (fixed dollar amount per service), rvu_based (Relative Value Unit-based), bundled (bundled payment for episode of care), capitation (per-member per-month), rbp (Reference Based Pricing). [ENUM-REF-CANDIDATE: pct_medicare|pct_billed_charges|flat_rate|rvu_based|bundled|capitation|rbp — promote to reference product]']
  payment_basis_pct decimal(7,4) [note: 'The percentage rate applied when payment_basis is \'pct_medicare\' or \'pct_billed_charges\' (e.g., 110.0000 for 110% of Medicare). Null when payment_basis is flat_rate, rvu_based, bundled, or capitation. Stored as a decimal percentage value.']
  prior_authorization_required boolean [note: 'Indicates whether Prior Authorization (PA) is required for services reimbursed under this fee schedule. When True, claims must have an approved PA on file before adjudication at the scheduled rates.']
  referral_required boolean [note: 'Indicates whether a primary care physician (PCP) referral is required for services covered under this fee schedule. Applicable primarily for HMO and POS plan types.']
  schedule_code varchar [note: 'Externally-known alphanumeric code uniquely identifying the fee schedule within the Core Administration Platform (Facets/QNXT). Used in EDI transactions and cross-system references.']
  schedule_name varchar [note: 'Human-readable name identifying the fee schedule (e.g., \'Commercial PPO Professional 2024\', \'Medicare Advantage Institutional Q1 2024\'). Used for display and reporting in Facets/QNXT Benefits Configuration.']
  schedule_status varchar [note: 'Current lifecycle state of the fee schedule. \'draft\' indicates under review; \'active\' indicates currently in use for adjudication; \'suspended\' indicates temporarily inactive; \'terminated\' indicates permanently closed; \'superseded\' indicates replaced by a newer version.']
  schedule_type varchar [note: 'Categorizes the fee schedule by the type of services covered: professional (physician/practitioner), institutional (hospital/facility), ancillary (therapy/home health), DME (Durable Medical Equipment), lab (laboratory), or pharmacy. Drives claim adjudication logic in Facets/QNXT.']
  service_category varchar [note: 'Broad clinical or administrative category of services covered by this fee schedule (e.g., \'Evaluation and Management\', \'Surgery\', \'Radiology\', \'Pathology\', \'Inpatient Facility\', \'Outpatient Facility\', \'Home Health\', \'Behavioral Health\'). Supports fee schedule segmentation and reporting. [ENUM-REF-CANDIDATE: evaluation_management|surgery|radiology|pathology|inpatient_facility|outpatient_facility|home_health|behavioral_health|physical_therapy|dme — promote to reference product]']
  source decimal(18,2) [note: 'Identifies the origin or benchmark source of the fee schedule rates: cms_medicare (based on CMS Medicare fee schedule), cms_medicaid (based on state Medicaid fee schedule), negotiated (directly negotiated with provider), custom (health plan proprietary rates), rbp_benchmark (Reference Based Pricing benchmark).']
  state_code varchar [note: 'Two-letter US state code indicating the geographic scope of this fee schedule. Used for state-specific rate variations and regulatory compliance with State Departments of Insurance (DOI) requirements.']
  stop_loss_applicable boolean [note: 'Indicates whether a stop-loss provision applies to this fee schedule, capping the health plan\'s reimbursement liability per claim or per member. Relevant for risk-sharing and capitation arrangements.']
  stop_loss_threshold_amt decimal(12,2) [note: 'Dollar amount per claim or per member above which the stop-loss provision activates, limiting the health plan\'s reimbursement exposure. Applicable when stop_loss_applicable is True.']
  termination_date date [note: 'Date on which the fee schedule expires and is no longer applicable for claim adjudication. Null indicates an open-ended fee schedule with no defined end date.']
  updated_timestamp timestamp [note: 'Timestamp when this fee schedule record was last modified. Audit field supporting change tracking, data lineage, and regulatory audit requirements.']
  version_number varchar [note: 'Version identifier for the fee schedule, enabling tracking of amendments and updates over time (e.g., \'1.0\', \'2.1\', \'3.0\'). Incremented when rates or terms are modified. Supports fee schedule history and audit trail.']

  Note: 'Master fee schedule defining reimbursement rates for covered services under a provider contract. Captures fee schedule name, version, effective and termination dates, payment basis (% of Medicare, % of billed charges, flat rate, RVU-based), geographic modifier applicability, LOB scope, and fee schedule type (professional, institutional, ancillary, DME, lab). SSOT for all fee-for-service reimbursement rates. Sourced from Facets/QNXT Benefits Configuration. [FHIR-aligned]'
}

Table contract.fee_schedule_rate {
  fee_schedule_rate_id decimal(18,2) [pk, note: 'Unique surrogate identifier for each fee schedule rate line record in the contract domain. Primary key for this entity.']
  fee_schedule_id decimal(18,2) [note: 'Reference to the parent fee schedule header that this rate line belongs to. Links the rate to its governing fee schedule agreement.']
  prior_rate_fee_schedule_rate_id decimal(18,2) [note: 'Self-referencing identifier pointing to the previous version of this rate record that was superseded by the current record. Enables full rate history chain traversal for audit and compliance purposes.']
  allowed_amount decimal(18,4) [note: 'The contracted allowed amount or maximum reimbursable dollar amount for the specified procedure code, modifier, and place of service combination. This is the principal monetary value used by adjudication systems to price claims against contracted rates. Expressed in USD.']
  awp_percent decimal(7,4) [note: 'When rate_derivation_method is AWP_PCT, this field stores the percentage of the Average Wholesale Price (AWP) used to derive the drug or supply reimbursement rate. For example, 0.8500 represents AWP minus 15%. Commonly used in pharmacy and DME fee schedules.']
  bilateral_indicator boolean [note: 'Indicates whether this rate applies to a bilateral procedure (performed on both sides of the body). When true, the allowed amount may be adjusted per CMS bilateral surgery payment rules (150% of the unilateral rate).']
  bundled_payment_amount decimal(18,4) [note: 'Single episode-of-care payment amount covering all services within a defined clinical episode (e.g., joint replacement, maternity). Applicable when payment_methodology is BUNDLED. Supports Value-Based Care (VBC) and ACO payment models.']
  capitation_rate_pmpm decimal(18,4) [note: 'Fixed monthly payment per enrolled member paid to a provider under a capitation arrangement, regardless of services rendered. Expressed as a Per Member Per Month (PMPM) dollar amount. Applicable only when payment_methodology is CAPITATION.']
  created_timestamp timestamp [note: 'The timestamp when this fee schedule rate record was first created in the system. Used for audit trail, data lineage, and compliance reporting. Conforms to ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).']
  drg_code varchar [note: 'CMS Diagnosis Related Group code used for inpatient hospital reimbursement. When the payment methodology is DRG-based, this code identifies the patient classification group that determines the base payment rate.']
  effective_date date [note: 'The date on which this fee schedule rate becomes effective and applicable for claims adjudication. Claims with service dates on or after this date and before the termination_date will be priced using this rate.']
  geographic_region varchar [note: 'Geographic region or market area to which this rate applies. Rates may vary by state, CMS locality, metropolitan statistical area (MSA), or health plan-defined region. Expressed as a state code, CMS locality code, or internal region identifier.']
  global_surgery_days varchar [note: 'Number of days in the global surgery period for surgical procedure codes. Defines the pre-operative and post-operative period during which related services are bundled into the surgical payment (0=endoscopic/minor, 10=minor, 90=major surgery).']
  line_of_business varchar [note: 'The Line of Business (LOB) to which this fee schedule rate applies. Rates are often differentiated by LOB as Medicare, Medicaid, and commercial plans have distinct reimbursement structures and regulatory requirements.']
  mac_amount decimal(18,4) [note: 'The Maximum Allowable Cost (MAC) dollar amount set as the ceiling for reimbursement of a specific drug or service. When rate_derivation_method is MAC, this value represents the maximum the plan will pay regardless of billed charges.']
  max_units_per_day varchar [note: 'Maximum number of units of this procedure code that will be reimbursed per day per member. Used to enforce utilization limits during claims adjudication and prevent overbilling.']
  max_units_per_year varchar [note: 'Maximum number of units of this procedure code that will be reimbursed per benefit year per member. Enforces annual utilization limits during adjudication for services with frequency restrictions.']
  medicare_fee_schedule_pct decimal(7,4) [note: 'When rate_derivation_method is MEDICARE_PCT, this field stores the percentage of the applicable Medicare fee schedule rate used to derive the allowed amount. For example, 1.1500 represents 115% of Medicare. Used for rate benchmarking and contract analytics.']
  ncci_edit_indicator boolean [note: 'Indicates whether this procedure code is subject to National Correct Coding Initiative (NCCI) bundling edits during claims adjudication. When true, the adjudication system will apply NCCI column 1/column 2 and mutually exclusive code edits.']
  network_tier varchar [note: 'Identifies the provider network tier to which this rate applies. Rates differ by network participation level: IN_NETWORK (contracted), OUT_OF_NETWORK (non-contracted), or tiered preferred network levels (TIER_1, TIER_2, TIER_3, PREFERRED). Drives member cost-sharing calculations.']
  payment_methodology decimal(18,2) [note: 'The reimbursement methodology governing how the provider is paid for this service. FFS=Fee-for-Service (fixed allowed amount per procedure), CAPITATION=fixed PMPM regardless of utilization, BUNDLED=single payment for episode of care, DRG=Diagnosis Related Group inpatient payment, PER_DIEM=daily rate for facility stays, PERCENT_OF_BILLED=percentage of submitted charges, RBP=Reference Based Pricing, CASE_RATE=flat rate per case. [ENUM-REF-CANDIDATE: FFS|CAPITATION|BUNDLED|DRG|PER_DIEM|PERCENT_OF_BILLED|RBP|CASE_RATE — promote to reference product]']
  per_diem_rate decimal(18,4) [note: 'Daily reimbursement rate paid to a facility provider for each day of an inpatient or residential stay. Applicable when payment_methodology is PER_DIEM. May vary by level of care (e.g., ICU vs. medical/surgical).']
  place_of_service_code varchar [note: 'CMS two-digit place of service code indicating the setting where the service was rendered (e.g., 11=Office, 21=Inpatient Hospital, 22=Outpatient Hospital, 23=Emergency Room). Rates may vary by place of service.']
  procedure_code varchar [note: 'The CPT or HCPCS procedure code identifying the specific medical service, procedure, or supply for which this rate applies. Core identifier used in claims adjudication to match services to contracted rates.']
  procedure_code_type varchar [note: 'Classifies the coding system used for the procedure_code field. Distinguishes between CPT (physician services), HCPCS Level II (supplies/DME), CDT (dental), ICD-10-PCS (inpatient procedures), Revenue Code (facility billing), DRG (diagnosis-related group), APC (ambulatory payment classification), or NDC (drug). [ENUM-REF-CANDIDATE: CPT|HCPCS_II|CDT|ICD_PCS|REVENUE|DRG|APC|NDC — promote to reference product]']
  procedure_modifier_1 varchar [note: 'First CPT or HCPCS modifier code appended to the procedure code to indicate special circumstances affecting the service (e.g., bilateral procedure, assistant surgeon, professional component). Modifiers can alter the allowed reimbursement amount.']
  procedure_modifier_2 varchar [note: 'Second CPT or HCPCS modifier code when multiple modifiers apply to the same procedure code. Used in conjunction with procedure_modifier_1 for complex billing scenarios.']
  product_type varchar [note: 'The health plan product type to which this rate applies. HMO=Health Maintenance Organization, PPO=Preferred Provider Organization, EPO=Exclusive Provider Organization, POS=Point of Service, HDHP=High Deductible Health Plan, INDEMNITY=traditional indemnity plan. Rates may vary by product type.']
  provider_type varchar [note: 'Classification of the provider type to which this rate applies. Distinguishes between physician/professional services, facility (hospital/SNF), ancillary services, Durable Medical Equipment (DME) suppliers, pharmacy, and behavioral health providers.']
  rate_derivation_method double [note: 'Describes how the allowed amount was derived or calculated. MEDICARE_PCT=percentage of Medicare fee schedule, AWP_PCT=percentage of Average Wholesale Price, WAC_PCT=percentage of Wholesale Acquisition Cost, MAC=Maximum Allowable Cost, RBP=Reference Based Pricing benchmark, NEGOTIATED=directly negotiated flat rate, COST_PLUS=cost plus margin, BILLED_PCT=percent of billed charges. Critical for audit and rate validation. [ENUM-REF-CANDIDATE: MEDICARE_PCT|AWP_PCT|WAC_PCT|MAC|RBP|NEGOTIATED|COST_PLUS|BILLED_PCT — promote to reference product]']
  rate_line_number varchar [note: 'Sequential line number identifying the position of this rate record within the parent fee schedule. Used for ordering and referencing individual rate lines.']
  rate_note double [note: 'Free-text notes or comments providing additional context about this fee schedule rate, such as special billing instructions, exceptions, or conditions under which the rate applies. Used by contracting and claims operations staff.']
  rate_percent_of_billed decimal(7,4) [note: 'Reimbursement rate expressed as a percentage of the provider\'s billed charges, used when the payment methodology is percent-of-billed rather than a fixed allowed amount. For example, 0.8500 represents 85% of billed charges.']
  rate_source double [note: 'Identifies the origin or source of this fee schedule rate. CONTRACT=directly negotiated in provider contract, CMS_PUBLISHED=derived from published CMS fee schedule, CROSSWALK=mapped from another code or schedule, MANUAL=manually entered by contracting staff, SYSTEM_GENERATED=automatically generated by the fee schedule management system.']
  rate_status double [note: 'Current lifecycle status of this fee schedule rate record. ACTIVE=currently in effect and used for adjudication, INACTIVE=not currently in use, PENDING=approved but not yet effective, SUPERSEDED=replaced by a newer rate version, TERMINATED=permanently ended.']
  rate_version varchar [note: 'Incrementing version number tracking amendments and updates to this fee schedule rate line. Version 1 is the original rate; subsequent amendments increment this counter. Supports rate history and audit trail requirements.']
  rbp_reference_amount decimal(18,4) [note: 'The benchmark dollar amount used as the basis for Reference Based Pricing (RBP) reimbursement. Typically anchored to Medicare rates or a cost-based benchmark. The actual allowed amount is derived as a percentage of this reference amount.']
  revenue_code decimal(18,2) [note: 'Four-digit UB-04 revenue code identifying the type of accommodation, ancillary service, or billing classification for facility claims. Used in conjunction with or as an alternative to procedure codes for hospital and facility fee schedule rates.']
  service_category varchar [note: 'Broad clinical or administrative category grouping the service type covered by this rate (e.g., Evaluation and Management, Surgery, Radiology, Laboratory, Anesthesia, Durable Medical Equipment, Behavioral Health, Preventive Care). Used for rate analytics and reporting. [ENUM-REF-CANDIDATE: promote to reference product]']
  specialty_code varchar [note: 'CMS three-digit provider specialty code indicating the clinical specialty for which this rate applies. Rates may be differentiated by provider specialty (e.g., 01=General Practice, 06=Cardiology, 93=Emergency Medicine). Null if rate applies to all specialties.']
  state_code varchar [note: 'Two-letter US state code identifying the state jurisdiction in which this fee schedule rate is applicable. Used for state-specific rate differentiation and regulatory compliance reporting.']
  termination_date date [note: 'The date on which this fee schedule rate expires and is no longer applicable for claims adjudication. Null indicates the rate is open-ended with no defined end date. Claims with service dates after this date will not be priced using this rate.']
  units_of_service decimal(10,2) [note: 'The number of units of service to which the allowed_amount applies. For most procedure codes, this is 1 unit. For time-based codes or quantity-based services, this may represent the standard unit quantity (e.g., 15-minute increments for therapy codes).']
  updated_timestamp timestamp [note: 'The timestamp when this fee schedule rate record was last modified. Tracks the most recent update for change management, audit trail, and data synchronization purposes. Conforms to ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).']

  Note: 'Line-level reimbursement rates within a fee schedule. Each record defines the allowed amount or rate for a specific procedure code (CPT/HCPCS), revenue code, DRG, or service category. Captures procedure code, modifier, place of service, allowed amount, MAC/AWP/WAC reference, RBP rate, effective date, and rate derivation method. Enables adjudication systems to price claims against contracted rates. [FHIR-aligned]'
}

Table contract.capitation_arrangement {
  capitation_arrangement_id varchar [pk, note: 'Unique surrogate identifier for the capitation arrangement record in the Silver Layer lakehouse. Primary key for this entity.']
  fee_schedule_id decimal(18,2) [note: 'Foreign key linking to contract.fee_schedule. Business justification: Capitation arrangements frequently reference fee schedules for carve-out services that are paid fee-for-service rather than under capitation (carve_out_services field on capitation_arrangement). The f']
  party_id varchar [note: 'Foreign key linking to contract.party. Business justification: A capitation arrangement is contracted with a specific provider party. The party table identifies the health plan entity and the contracting provider. This FK links the capitation arrangement to the p']
  raps_submission_id varchar [note: 'Foreign key linking to risk.raps_submission. Business justification: Capitation arrangement RAF adjustment factors are derived from CMS RAPS submission cycles. Finance and actuarial teams must trace which RAPS submission informed the raf_adjustment_factor used in each ']
  vbc_contract_id varchar [note: 'Foreign key linking to contract.vbc_contract. Business justification: capitation_arrangement has a vbc_arrangement_flag boolean indicating that some capitation arrangements operate under VBC contracts. When this flag is true, the arrangement should reference the specifi']
  aco_arrangement_flag boolean [note: 'Indicates whether this capitation arrangement is part of an Accountable Care Organization (ACO) or integrated delivery network model, which may have additional shared savings or risk-sharing components.']
  aggregate_stop_loss_threshold decimal(14,2) [note: 'Total dollar amount for the attributed member population above which the health plan assumes financial responsibility for claims costs. Protects the provider from population-level adverse risk. Expressed in USD.']
  amendment_number varchar [note: 'Identifier of the most recent contract amendment that modified this capitation arrangement. Tracks the amendment history for audit and compliance purposes.']
  annual_rate_escalator decimal(5,2) [note: 'Contractually agreed annual percentage increase applied to the PMPM rate at each rate renewal period (e.g., 3.50 for 3.5% annual escalation). Used for multi-year capitation arrangements.']
  approval_date date [note: 'Date on which the capitation arrangement was formally approved by the health plan\'s contracting authority. Required for audit trail and regulatory compliance documentation.']
  approved_by varchar [note: 'Name or employee identifier of the contracting authority who approved this capitation arrangement. Supports audit trail and delegation-of-authority compliance.']
  arrangement_name varchar [note: 'Human-readable descriptive name for the capitation arrangement (e.g., \'Primary Care Capitation - HMO Commercial 2024\'), used in reporting and provider communications.']
  arrangement_number varchar [note: 'Externally-known business identifier for the capitation arrangement, used in provider communications, payment remittances, and reconciliation processes. Assigned by the Core Administration Platform (Facets/QNXT).']
  arrangement_status varchar [note: 'Current lifecycle status of the capitation arrangement. Controls whether PMPM payments are generated and whether members can be attributed to this arrangement.']
  arrangement_type varchar [note: 'Classification of the capitation arrangement by scope of covered services. Global capitation covers all services; primary care capitation covers PCP services only; specialty capitation covers specialist services; institutional covers facility-based care. [ENUM-REF-CANDIDATE: global_capitation|primary_care_capitation|specialty_capitation|institutional_capitation|behavioral_health_capitation|pharmacy_capitation — promote to reference product]']
  attributed_member_count varchar [note: 'Current number of members attributed to this capitation arrangement for the active payment period. Used to calculate total monthly capitation payment disbursement.']
  attribution_method varchar [note: 'Methodology used to attribute members to this capitation arrangement. PCP assignment uses enrollment data; claims-based uses plurality of visits; voluntary selection allows member choice; geographic assigns by service area.']
  auto_renewal_flag boolean [note: 'Indicates whether this capitation arrangement automatically renews at the end of the contract term unless either party provides notice of termination within the contractually specified notice period.']
  carve_out_services varchar [note: 'Description of services explicitly excluded from the capitation scope and reimbursed separately (e.g., \'Mental Health, Substance Abuse, Transplants, Neonatal ICU\'). Carve-outs are paid fee-for-service or under separate capitation arrangements.']
  created_timestamp timestamp [note: 'Timestamp when this capitation arrangement record was first created in the data platform. Supports audit trail, data lineage, and regulatory compliance requirements.']
  effective_date date [note: 'Date on which the capitation arrangement becomes binding and PMPM payments begin. Aligns with the contract effective period.']
  geographic_service_area varchar [note: 'Description or code of the geographic service area (county, state, or region) within which this capitation arrangement applies. Members outside this area may not be attributed to this arrangement.']
  individual_stop_loss_threshold decimal(12,2) [note: 'Dollar amount per member per year above which the health plan assumes financial responsibility for claims costs, protecting the provider from catastrophic individual member costs. Expressed in USD.']
  lob_code varchar [note: 'Line of Business to which this capitation arrangement applies (e.g., Commercial HMO, Medicare Advantage, Medicaid Managed Care). Determines regulatory requirements and rate-setting methodology.']
  network_tier varchar [note: 'Network tier classification of the provider under this capitation arrangement. Tier 1 providers typically receive higher capitation rates in exchange for meeting quality and cost-efficiency benchmarks.']
  payment_frequency decimal(18,2) [note: 'Frequency at which capitation payments are disbursed to the provider. Monthly is standard for most capitation arrangements; quarterly or annual may apply for certain specialty or institutional arrangements.']
  payment_methodology decimal(18,2) [note: 'Specific payment calculation methodology applied to this capitation arrangement. Pure capitation pays flat PMPM; withhold arrangements retain a percentage pending performance; risk-adjusted capitation applies RAF multipliers. [ENUM-REF-CANDIDATE: pure_capitation|capitation_with_withhold|capitation_with_bonus|risk_adjusted_capitation|tiered_capitation — promote to reference product]']
  pmpm_rate decimal(12,4) [note: 'Fixed dollar amount paid to the provider per attributed member per calendar month, regardless of services rendered. The core financial parameter of the capitation arrangement. Expressed in USD.']
  pmpm_rate_currency double [note: 'ISO 4217 three-letter currency code for the PMPM rate (typically USD for domestic health plans). Required for multi-currency reporting and regulatory submissions.']
  quality_withhold_release_criteria varchar [note: 'Description of the quality performance benchmarks or HEDIS/STAR measure thresholds that must be met for the provider to receive release of withheld capitation amounts. Defines the performance contract terms.']
  raf_adjustment_factor decimal(8,4) [note: 'Multiplier applied to the base PMPM rate to account for the relative health risk of the attributed member population. A RAF above 1.0 indicates a sicker-than-average population; below 1.0 indicates healthier-than-average.']
  rate_effective_date date [note: 'Date on which the current PMPM rate became effective. Supports rate history tracking when rates are renegotiated mid-contract without creating a new arrangement record.']
  rate_expiration_date date [note: 'Date on which the current PMPM rate expires and is subject to renegotiation or automatic escalation. Null if the rate is open-ended for the arrangement term.']
  risk_adjustment_applicable boolean [note: 'Indicates whether the PMPM rate is subject to risk adjustment based on the attributed member population\'s Hierarchical Condition Category (HCC) Risk Adjustment Factor (RAF) scores. Applicable primarily for Medicare Advantage and ACA Exchange arrangements.']
  risk_pool_participant boolean [note: 'Indicates whether the provider participates in a shared risk pool under this capitation arrangement. Risk pool participants share in surpluses or deficits relative to the capitation budget.']
  risk_share_percentage decimal(5,2) [note: 'Percentage of risk pool surplus or deficit allocated to the provider under this capitation arrangement. Expressed as a percentage (0.00–100.00). Applicable only when risk_pool_participant is True.']
  service_category_scope varchar [note: 'Comma-delimited list or narrative description of the covered service categories included under this capitation arrangement (e.g., \'Primary Care, Preventive Services, Lab, Radiology\'). Defines the scope of services the provider is financially responsible for under capitation.']
  source_system_code varchar [note: 'Code identifying the operational system of record from which this capitation arrangement record was sourced (e.g., FACETS, QNXT for Core Administration Platform; CACTUS or PROVIDER_SOURCE for Provider Management System).']
  source_system_record_reference varchar [note: 'Native record identifier from the operational source system (Facets, QNXT, or Provider Management System) for this capitation arrangement. Supports data lineage, reconciliation, and back-referencing to the system of record.']
  stop_loss_type varchar [note: 'Type of stop-loss protection included in the capitation arrangement. Individual stop-loss limits exposure per member; aggregate stop-loss limits total population exposure; both applies both thresholds.']
  termination_date date [note: 'Date on which the capitation arrangement ends and PMPM payments cease. Null for open-ended arrangements. Distinct from contract termination date when partial termination applies.']
  termination_notice_days varchar [note: 'Number of calendar days advance notice required by either party to terminate this capitation arrangement without cause. Typically 90–180 days for managed care capitation contracts.']
  updated_timestamp timestamp [note: 'Timestamp when this capitation arrangement record was last modified in the data platform. Used for change data capture, incremental processing, and audit trail maintenance.']
  vbc_arrangement_flag boolean [note: 'Indicates whether this capitation arrangement includes Value-Based Care (VBC) performance incentive components such as quality bonuses, shared savings, or outcome-based adjustments beyond the base PMPM.']
  withhold_percentage decimal(5,2) [note: 'Percentage of the PMPM rate withheld from each payment cycle pending performance or quality metric achievement. Withheld amounts are returned upon meeting contractual benchmarks. Expressed as a percentage (0.00–100.00).']

  Note: 'Defines capitation payment arrangements where providers receive a fixed PMPM (Per Member Per Month) payment to cover a defined scope of services. Captures capitation rate, covered service categories, risk pool participation, stop-loss thresholds, carve-out services, attributed member population criteria, LOB applicability, and payment frequency. Supports HMO and managed care capitation models. [FHIR-aligned]'
}

Table contract.capitation_payment {
  capitation_payment_id decimal(18,2) [pk, note: 'Unique surrogate identifier for each capitation payment disbursement record in the Silver Layer lakehouse. Primary key for this entity.']
  capitation_arrangement_id varchar [note: 'Reference to the specific capitation arrangement or rate schedule within the contract, identifying the applicable PMPM rate table, risk pool configuration, and attributed population definition.']
  eligibility_span_id varchar [note: 'Foreign key linking to enrollment.enrollment_eligibility_span. Business justification: Capitation payments are made for specific member eligibility spans. Linking capitation_payment to enrollment_eligibility_span enables payment-to-enrollment reconciliation, supports audit of enrollment']
  health_plan_id varchar [note: 'Reference to the health plan or benefit product under which the attributed members are enrolled. Determines the applicable benefit structure and capitation rate tier.']
  member_risk_score_id varchar [note: 'Foreign key linking to risk.member_risk_score. Business justification: Risk-adjusted PMPM capitation payments are computed directly from member risk scores. Payment operations and audit teams must link each capitation payment to the specific risk score that determined th']
  original_payment_capitation_payment_id decimal(18,2) [note: 'Reference to the original capitation payment record that this record adjusts, reverses, or supplements. Populated only when prior_period_adjustment_flag is True. Enables audit trail linking of adjustment chains.']
  radv_audit_id varchar [note: 'Foreign key linking to risk.radv_audit. Business justification: RADV audit findings trigger retroactive capitation payment adjustments and prior-period corrections. Payment operations teams must link capitation payments to the RADV audit that caused the adjustment']
  vbc_contract_id varchar [note: 'Foreign key linking to contract.vbc_contract. Business justification: capitation_payment has a vbc_contract_flag boolean indicating that some capitation payments are made under VBC contracts. When this flag is true, the payment should reference the specific VBC contract']
  ap_voucher_number varchar [note: 'Accounts Payable (AP) voucher or invoice number assigned in Oracle Financials when the capitation payment is posted as a payable. Links the capitation disbursement to the AP subledger for financial reporting and audit trail.']
  attributed_member_count varchar [note: 'Total number of members attributed to the provider for the payment period. This is the primary driver of the gross capitation payment calculation (attributed_member_count × pmpm_rate = gross_payment_amount).']
  capitation_rate_tier double [note: 'Rate tier or member category applied to determine the PMPM rate for this payment (e.g., adult, pediatric, senior, ESRD, dual-eligible). Different member demographics may attract different PMPM rates under the same contract.']
  check_eft_trace_number varchar [note: 'Check number or EFT/ACH trace number assigned by the financial institution for the actual disbursement of this capitation payment. Used for bank reconciliation in Oracle Financials (AP module) and provider payment dispute resolution.']
  created_timestamp timestamp [note: 'Timestamp when this capitation payment record was first created in the Silver Layer data platform. Supports audit trail, data lineage, and SLA monitoring for payment processing cycles.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for all monetary amounts on this capitation payment record. Typically USD for domestic health insurance operations. Required for multi-currency financial reconciliation and GAAP/SAP reporting.']
  enrollment_adjustment_amount decimal(18,2) [note: 'Dollar adjustment to the gross payment resulting from retroactive enrollment changes (late enrollments, disenrollments, or eligibility corrections) identified after the initial payment calculation. Can be positive (additional payment) or negative (recoupment).']
  gl_cost_center decimal(18,2) [note: 'General Ledger (GL) cost center code in Oracle Financials to which this capitation payment expense is allocated. Supports financial reporting by LOB, product, and organizational unit per GAAP and SAP statutory reporting requirements.']
  gross_payment_amount decimal(18,2) [note: 'Total gross capitation payment amount before any adjustments, calculated as attributed_member_count multiplied by the pmpm_rate. Represents the base payment obligation for the period prior to retroactive enrollment changes, risk pool withholds, or stop-loss recoveries.']
  line_of_business varchar [note: 'Line of Business (LOB) under which the capitation payment is made. Determines regulatory requirements, rate-setting methodology, and CMS reporting obligations applicable to the payment.']
  net_payment_amount decimal(18,2) [note: 'Final net amount disbursed to the provider after all adjustments: gross_payment_amount + enrollment_adjustment_amount - risk_pool_withhold_amount + stop_loss_recovery_amount + other_adjustment_amount. This is the actual amount reflected in the 835 ERA remittance advice.']
  payment_approval_date decimal(18,2) [note: 'Date on which the capitation payment was formally approved for disbursement by the authorized approver in the billing or finance system. Supports segregation of duties controls and audit trail requirements.']
  payment_date decimal(18,2) [note: 'Actual date the capitation payment was disbursed to the provider via EFT, check, or ACH. Used for accounts payable reconciliation and provider remittance reporting.']
  payment_method decimal(18,2) [note: 'Mechanism by which the capitation payment was or will be disbursed to the provider. EFT (Electronic Funds Transfer) and ACH (Automated Clearing House) are most common for capitation arrangements.']
  payment_number decimal(18,2) [note: 'Externally-visible business identifier for this capitation payment disbursement, used in provider remittance advice (835 ERA), accounts payable records, and provider portal references. Format: CAP-YYYYMM-NNNNNN.']
  payment_period_end_date decimal(18,2) [note: 'Last day of the coverage month or period for which this capitation payment is being made. Typically the last day of the calendar month in monthly capitation cycles.']
  payment_period_start_date decimal(18,2) [note: 'First day of the coverage month or period for which this capitation payment is being made. Typically the first day of the calendar month in monthly capitation cycles.']
  payment_run_number decimal(18,2) [note: 'Identifier of the capitation payment run or batch cycle that generated this payment record. Used to group all payments processed in the same cycle for reconciliation, audit, and reprocessing purposes in the Core Administration Platform (Facets/QNXT).']
  payment_status decimal(18,2) [note: 'Current lifecycle state of the capitation payment disbursement. \'pending\' = calculated but not yet approved; \'approved\' = authorized for payment; \'paid\' = disbursed to provider; \'voided\' = cancelled before disbursement; \'reversed\' = clawed back after disbursement; \'on_hold\' = suspended pending investigation or contract dispute.']
  payment_type decimal(18,2) [note: 'Classification of the capitation payment by its business purpose. \'standard\' = routine monthly capitation; \'retroactive\' = payment for prior periods due to enrollment changes; \'adjustment\' = correction to a previously issued payment; \'stop_loss_recovery\' = reimbursement under stop-loss provisions; \'risk_pool_settlement\' = periodic risk pool distribution or withhold settlement.']
  pmpm_rate decimal(12,4) [note: 'Per Member Per Month (PMPM) capitation rate applied for this payment period, as defined in the contract rate schedule. This is the contractually negotiated amount paid per attributed member per month. Classified confidential as it represents proprietary contract pricing.']
  prior_period_adjustment_flag boolean [note: 'Indicates whether this capitation payment includes or represents an adjustment to a prior payment period. True when the payment corrects or supplements a previously issued capitation payment due to retroactive enrollment changes or rate corrections.']
  quality_withhold_amount decimal(18,2) [note: 'Amount withheld from the capitation payment pending achievement of quality performance targets (e.g., HEDIS measures, STAR ratings thresholds). Released or forfeited at the end of the performance measurement period based on provider quality scores.']
  remittance_advice_number varchar [note: 'Reference number of the 835 Electronic Remittance Advice (ERA) transaction sent to the provider for this capitation payment. Used to reconcile capitation disbursements with provider accounts receivable and the EDI clearinghouse (Availity/Change Healthcare) transaction log.']
  risk_pool_withhold_amount decimal(18,2) [note: 'Amount withheld from the gross capitation payment and placed into a shared risk pool per the contract terms. Risk pool withholds are held and distributed (or forfeited) at the end of the risk settlement period based on actual utilization versus targets.']
  source_system_payment_reference decimal(18,2) [note: 'Native identifier of this capitation payment record in the originating operational system (Facets, QNXT, or HealthEdge). Used for cross-system reconciliation and data lineage tracing between the Silver Layer and the system of record.']
  stop_loss_recovery_amount decimal(18,2) [note: 'Amount recovered from or credited to the provider under stop-loss provisions of the capitation contract. Positive values indicate plan reimbursement to provider for catastrophic cases exceeding the stop-loss threshold; negative values indicate provider liability adjustments.']
  updated_timestamp timestamp [note: 'Timestamp when this capitation payment record was last modified in the Silver Layer data platform. Tracks the most recent update for change data capture (CDC), audit trail, and reconciliation purposes.']
  vbc_contract_flag boolean [note: 'Indicates whether this capitation payment is made under a Value-Based Care (VBC) or Accountable Care Organization (ACO) contract arrangement, as opposed to a standard fee-for-service capitation. Drives VBC performance reporting and quality incentive calculations.']
  void_reason varchar [note: 'Business reason code or description explaining why this capitation payment was voided or reversed. Populated only when payment_status is \'voided\' or \'reversed\'. Examples: contract_termination, duplicate_payment, enrollment_error, rate_correction.']

  Note: 'Transactional record of each capitation payment disbursed to a provider under a capitation arrangement. Captures payment period (month/year), attributed member count, PMPM rate applied, gross payment amount, adjustments (retroactive enrollment changes, risk pool settlements, stop-loss recoveries), net payment amount, payment date, payment status, and remittance advice reference. Feeds accounts payable, provider remittance reporting (835 ERA), and contract financial summary reconciliation. [FHIR-aligned]'
}

Table contract.vbc_contract {
  vbc_contract_id varchar [pk, note: 'Unique surrogate identifier for the Value-Based Care (VBC) contract record in the Silver layer lakehouse. Primary key for all VBC contract master records including ACO agreements, shared savings, bundled payment, and risk-sharing arrangements.']
  fee_schedule_id decimal(18,2) [note: 'Foreign key linking to contract.fee_schedule. Business justification: VBC contracts reference a fee schedule as the baseline for expenditure benchmarking and shared savings calculations. The benchmark_expenditure_target and actual_expenditure on vbc_contract are compute']
  party_id varchar [note: 'Foreign key linking to contract.party. Business justification: A VBC contract is established with a specific provider entity or ACO party. The party table has aco_indicator, legal_entity_name, and tin attributes that make it the authoritative source for the contr']
  aco_cms_identifier varchar [note: 'CMS-assigned unique identifier for the ACO participating in the Medicare Shared Savings Program (MSSP) or other CMS Innovation Center models. Required for RAPS/EDPS submissions and CMS regulatory reporting.']
  actual_expenditure decimal(18,2) [note: 'Total actual claims expenditure (in USD) incurred by attributed members or episode participants during the performance period. Compared against the benchmark expenditure target to determine shared savings or shared loss amounts.']
  amendment_effective_date date [note: 'Date on which the most recent contract amendment became effective. Used to determine which contract terms apply to claims and reconciliation calculations for a given service date.']
  attributed_member_count varchar [note: 'Number of health plan members attributed to this VBC contract/ACO entity for the current performance period. Used as the denominator for PMPM calculations, benchmark setting, and population health reporting.']
  attribution_methodology varchar [note: 'Method used to assign health plan members to this VBC contract/ACO entity for performance measurement. Prospective: members assigned at start of period based on prior utilization; Retrospective: members assigned at end of period based on actual utilization; Voluntary: member elects assignment.']
  auto_renewal_flag boolean [note: 'Indicates whether this VBC contract is configured to automatically renew at the end of the current term without requiring a new execution. True = auto-renews; False = requires affirmative renewal action.']
  benchmark_expenditure_target decimal(18,2) [note: 'The risk-adjusted, trend-adjusted target expenditure amount (in USD) against which actual expenditures are compared during reconciliation. Calculated using historical claims data, risk scores (HCC/RAF), and applicable trend factors per the contract methodology.']
  cms_program_track varchar [note: 'Specific CMS Innovation Center program track or model under which this contract operates (e.g., \'MSSP_BASIC_A\', \'MSSP_BASIC_E\', \'MSSP_ENHANCED\', \'BPCI_A\', \'CJR\', \'PCF\'). Null for commercial VBC contracts not affiliated with a CMS program. [ENUM-REF-CANDIDATE: MSSP_BASIC_A|MSSP_BASIC_B|MSSP_BASIC_C|MSSP_BASIC_D|MSSP_BASIC_E|MSSP_ENHANCED|BPCI_A|CJR|PCF|DCE — promote to reference product]']
  contract_amendment_number varchar [note: 'Sequential identifier for the most recent amendment to this VBC contract (e.g., \'AMD-003\'). Tracks contract modifications including rate changes, term extensions, quality measure updates, and risk arrangement adjustments. Null for original, unamended contracts.']
  created_timestamp timestamp [note: 'Timestamp when this VBC contract record was first created in the system. Used for audit trail, data lineage, and regulatory record-keeping. Conforms to ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).']
  episode_target_price decimal(18,2) [note: 'The risk-adjusted target price (in USD) for a single bundled payment episode. Calculated from historical claims data with applicable discounts and trend adjustments. Actual episode expenditures are compared to this target for reconciliation. Null for non-bundled VBC models.']
  episode_trigger_code varchar [note: 'The CPT procedure code or DRG (Diagnosis Related Group) code that initiates a bundled payment episode. For example, DRG 470 triggers a major joint replacement episode under BPCI-A. Null for non-bundled VBC models.']
  episode_type varchar [note: 'For bundled payment contracts, the clinical episode category being bundled (e.g., \'joint_replacement\', \'cardiac_surgery\', \'maternity\', \'hip_fracture\', \'spinal_fusion\'). Null for non-bundled VBC models. Determines the trigger event, episode window, and target price methodology. [ENUM-REF-CANDIDATE: joint_replacement|cardiac_surgery|maternity|hip_fracture|spinal_fusion|pneumonia|copd|stroke — promote to reference product]']
  episode_window_days varchar [note: 'Total number of days in the bundled payment episode window, measured from the trigger event (e.g., 90 days post-discharge for BPCI-A). Defines the period during which all included services are attributed to the bundle for reconciliation.']
  hedis_measure_targets varchar [note: 'Pipe-delimited list of HEDIS or CMS STAR measure identifiers and their contractual target thresholds included as quality gate requirements for this VBC contract (e.g., \'CBP:75.0|CDC-HbA1c:80.0|W34:85.0\'). Supports quality performance monitoring and NCQA reporting.']
  line_of_business varchar [note: 'Line of business under which this VBC contract operates. Determines applicable regulatory framework, benchmark methodology, and quality measure set (e.g., HEDIS for commercial, STAR for Medicare Advantage, MSSP for fee-for-service Medicare). [ENUM-REF-CANDIDATE: commercial|medicare_advantage|medicaid|mssp|bpci_a|exchange|dual_eligible — promote to reference product]']
  max_shared_loss_rate decimal(7,4) [note: 'The maximum percentage of benchmark expenditure (expressed as a decimal) that can be assessed as shared loss against the ACO/provider entity. Caps the provider\'s downside financial exposure in two-sided risk arrangements.']
  max_shared_savings_rate decimal(7,4) [note: 'The maximum percentage of benchmark expenditure (expressed as a decimal) that can be distributed as shared savings to the ACO/provider entity, regardless of actual savings achieved. Caps the health plan\'s financial exposure on the upside.']
  minimum_loss_rate decimal(7,4) [note: 'The minimum percentage threshold (expressed as a decimal) by which actual expenditures must exceed the benchmark before any shared loss is assessed. Applicable to two-sided risk arrangements. Symmetric counterpart to the Minimum Savings Rate (MSR).']
  minimum_savings_rate decimal(7,4) [note: 'The minimum percentage threshold (expressed as a decimal, e.g., 0.02 = 2%) by which actual expenditures must fall below the benchmark before any shared savings are distributed. Protects against random variation triggering unearned payments. Required field for MSSP Track 1 and Track 1+ contracts.']
  performance_period_end date [note: 'End date of the current performance measurement period. Marks the close of the measurement window after which actual expenditures are compared to the benchmark target for reconciliation and settlement.']
  performance_period_start date [note: 'Start date of the current performance measurement period for this VBC contract. Defines the window during which attributed member expenditures, quality scores, and utilization are measured against the benchmark.']
  performance_year varchar [note: 'Calendar or contract year for which performance is being measured and reconciled under this VBC contract. Used to track year-over-year performance trends, benchmark updates, and quality score progression. Typically a 4-digit year (e.g., 2024).']
  quality_gate_met boolean [note: 'Indicates whether the ACO/provider entity met the minimum quality performance threshold (quality gate) required to be eligible for shared savings distribution. True = quality gate satisfied; False = quality gate not met, shared savings withheld or reduced.']
  quality_score decimal(7,4) [note: 'Composite quality performance score (expressed as a decimal percentage, e.g., 0.85 = 85%) achieved by the ACO/provider entity during the performance period. Derived from HEDIS measures, STAR ratings, or contract-specific quality metrics. May gate or adjust shared savings distribution.']
  reconciliation_methodology varchar [note: 'Approach used to calculate and settle financial performance under this VBC contract. Prospective: target price set in advance; Retrospective: actual costs compared to historical benchmark after the period; Hybrid: combination of prospective target with retrospective quality adjustment.']
  reconciliation_status varchar [note: 'Current status of the financial reconciliation process for the performance period. Tracks the lifecycle from initial calculation through dispute resolution to final settlement: pending (not yet started), in_progress (under calculation), completed (finalized), disputed (under appeal), settled (payment processed).']
  risk_arrangement_type varchar [note: 'Specifies the financial risk-sharing structure between the health plan and the provider/ACO entity. Upside_only: provider shares in savings only; two_sided: provider shares in both savings and losses; full_risk: provider assumes full financial risk (global capitation); partial_risk: provider assumes a defined portion of risk.']
  risk_corridor_lower decimal(7,4) [note: 'Lower bound of the risk corridor (expressed as a decimal percentage below benchmark) within which no financial settlement occurs. Protects both parties from small random expenditure variations. Equivalent to the Minimum Savings Rate in MSSP terminology.']
  risk_corridor_upper decimal(7,4) [note: 'Upper bound of the risk corridor (expressed as a decimal percentage above benchmark) beyond which the health plan absorbs excess losses (stop-loss protection). Limits the provider\'s maximum financial exposure in two-sided risk arrangements.']
  savings_sharing_rate decimal(7,4) [note: 'The percentage (expressed as a decimal, e.g., 0.50 = 50%) of qualifying shared savings that is distributed to the ACO/provider entity. Negotiated contractually and may vary by quality score tier or performance band.']
  settlement_date date [note: 'Date on which the shared savings distribution or shared loss recoupment payment was or is scheduled to be processed. Used for financial accrual, IBNR reserve release, and cash flow reporting.']
  shared_savings_amount decimal(18,2) [note: 'Net shared savings (positive) or shared loss (negative) amount in USD calculated after reconciliation. Represents the financial settlement due to or owed by the ACO/provider entity based on performance against the benchmark. Positive = savings distribution; negative = loss recoupment.']
  stop_loss_threshold decimal(18,2) [note: 'Maximum dollar amount of shared loss that the ACO/provider entity is obligated to repay in a given performance period. Provides downside protection and is a key negotiated term in two-sided risk VBC contracts.']
  updated_timestamp timestamp [note: 'Timestamp when this VBC contract record was most recently modified. Used for change data capture (CDC), incremental ETL processing, and audit trail maintenance. Conforms to ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).']
  vbc_model_type varchar [note: 'Classification of the VBC payment model governing this contract. Determines the financial risk structure and reconciliation methodology: shared_savings (upside only), shared_risk (two-sided), full_capitation (global budget), bundled_payment (episode-based), pay_for_performance (quality incentive). [ENUM-REF-CANDIDATE: shared_savings|shared_risk|full_capitation|bundled_payment|pay_for_performance|global_budget — promote to reference product if additional models are needed]']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Master record for Value-Based Care (VBC) contracts, ACO agreements, risk-sharing arrangements, and bundled payment programs. Captures VBC model type (shared savings, shared risk, full capitation, bundled payment, pay-for-performance), ACO/IPA entity details, and reconciliation status. Includes performance period definitions with performance year, benchmark expenditure target, actual expenditure, quality score, shared savings or loss amount, reconciliation status, settlement date, minimum savings rate (MSR), maximum shared savings/loss rate, and quality gate requirements (HEDIS/STAR measure targets). For bundled payment models, captures episode definitions including episode type (joint replacement, cardiac surgery, maternity), trigger event (procedure code, DRG), episode window (days pre/post trigger), target price, included/excluded services, reconciliation methodology, and quality metrics. Supports CMS MSSP, BPCI-A, and commercial ACO/VBC reporting. SSOT for all VBC, risk-sharing, episode-based payment contractual structures, performance period tracking, bundled episode definitions, and year-over-year performance trend analysis. [FHIR-aligned]'
}

Table contract.reimbursement_policy {
  reimbursement_policy_id varchar [pk, note: 'Unique surrogate identifier for the reimbursement policy record in the Silver Layer lakehouse. Primary key for this entity.']
  fee_schedule_id decimal(18,2) [note: 'Reference to the fee schedule that serves as the base rate table for this reimbursement policy. The policy reduction or adjustment is applied against the rates defined in the referenced fee schedule.']
  superseded_policy_reimbursement_policy_id varchar [note: 'Reference to the prior reimbursement policy record that this policy replaces or supersedes. Enables policy lineage tracking and ensures historical adjudication records can be traced to the correct policy version.']
  applies_to_facility boolean [note: 'Indicates whether this reimbursement policy applies to facility (institutional) claims (CMS-1450/UB-04). When True, the policy is enforced on facility claims submitted via 837I transactions.']
  applies_to_professional boolean [note: 'Indicates whether this reimbursement policy applies to professional (physician) claims (CMS-1500). When True, the policy is enforced on professional claims submitted via 837P transactions.']
  cpt_range_end varchar [note: 'Ending CPT or HCPCS procedure code in the range to which this reimbursement policy applies. Used in conjunction with cpt_range_start to define the applicable procedure code range. If equal to cpt_range_start, the policy applies to a single procedure code.']
  cpt_range_start varchar [note: 'Starting CPT or HCPCS procedure code in the range to which this reimbursement policy applies. Used in conjunction with cpt_range_end to define the applicable procedure code range for adjudication logic in Facets/QNXT.']
  created_timestamp timestamp [note: 'Timestamp when this reimbursement policy record was first created in the system. Supports audit trail requirements and policy lifecycle tracking.']
  denial_reason_code varchar [note: 'CARC (Claim Adjustment Reason Code) or RARC (Remittance Advice Remark Code) applied to claims denied or reduced under this policy. Populated on the 835 ERA transaction to communicate the adjudication outcome to providers. Aligns with HIPAA-mandated reason codes.']
  diagnosis_code_required boolean [note: 'Indicates whether a specific ICD diagnosis code must be present on the claim for this reimbursement policy to apply. When True, the adjudication engine validates the presence of qualifying diagnosis codes before applying the policy.']
  effective_date date [note: 'Date on which the reimbursement policy becomes effective and is applied to claims adjudication. Claims with service dates on or after this date are subject to the policy rules.']
  eob_message_code varchar [note: 'Code referencing the EOB message displayed to members when a claim is adjusted or denied under this reimbursement policy. Ensures member-facing communications are clear and compliant with ACA transparency requirements.']
  facets_policy_code varchar [note: 'System-specific policy code as configured in the Facets or QNXT core administration platform. Used to map this Silver Layer record back to the source adjudication system configuration for reconciliation and troubleshooting.']
  global_surgery_period_days varchar [note: 'Number of days in the global surgery package period during which related pre-operative and post-operative services are bundled into the surgical reimbursement. Standard CMS values are 0, 10, or 90 days. Applies only to global surgery policy types.']
  icd_version varchar [note: 'Version of the ICD diagnosis/procedure code set applicable to this reimbursement policy when diagnosis-based adjudication rules are enforced. Ensures correct code set is applied during claims processing.']
  lob varchar [note: 'Line of Business to which this reimbursement policy applies (e.g., Commercial, Medicare Advantage, Medicaid). Determines which claims populations are subject to this policy during adjudication. A policy may be LOB-specific or apply across multiple LOBs.']
  max_procedures_allowed varchar [note: 'Maximum number of procedures that can be reimbursed under this policy in a single claim or service encounter. Procedures exceeding this limit are denied or reduced per adjudication rules. Null indicates no limit.']
  modifier_code varchar [note: 'CPT or HCPCS modifier code associated with this reimbursement policy (e.g., 50=Bilateral, 51=Multiple Procedures, 80=Assistant Surgeon, 62=Two Surgeons). Triggers or qualifies the policy application during claims adjudication.']
  ncci_edit_type varchar [note: 'Indicates the NCCI edit category applicable to this reimbursement policy. Column 1/Column 2 edits identify procedure code pairs where one code is a component of another. Mutually exclusive edits identify code pairs that cannot be billed together. Used for unbundling policy enforcement.']
  network_tier varchar [note: 'Provider network tier to which this reimbursement policy applies. Policies may differ between in-network and out-of-network providers, or across tiered network structures (e.g., Tier 1 preferred, Tier 2 standard). Null indicates the policy applies across all network tiers.']
  override_allowed boolean [note: 'Indicates whether a manual override of this reimbursement policy is permitted during claims adjudication (e.g., by a claims examiner or medical reviewer). When True, authorized users may bypass the policy with documented justification.']
  override_requires_auth boolean [note: 'Indicates whether overriding this reimbursement policy requires a prior authorization (PA) or supervisory approval. When True, an authorization reference must be documented before the override is accepted in Facets/QNXT.']
  payment_methodology decimal(18,2) [note: 'Reimbursement payment methodology under which this policy operates. Determines the base payment structure to which the policy rules are applied (e.g., fee-for-service rate reduction, bundled payment adjustment).']
  place_of_service_code varchar [note: 'CMS-defined two-digit Place of Service code indicating the setting where services are rendered (e.g., 11=Office, 21=Inpatient Hospital, 22=Outpatient Hospital). Used for place-of-service differential policies to apply site-of-service payment adjustments. Null if the policy applies regardless of setting.']
  policy_description varchar [note: 'Detailed narrative description of the reimbursement policy, including the business rationale, adjudication logic, and any exceptions or special conditions. Used for provider communications, EOB narratives, and internal training documentation.']
  policy_name varchar [note: 'Human-readable name or title of the reimbursement policy (e.g., \'Multiple Procedure Reduction Policy\', \'Bilateral Procedure Policy\'). Used in provider communications, EOB narratives, and adjudication configuration.']
  policy_number varchar [note: 'Externally-known alphanumeric identifier for the reimbursement policy as referenced in Facets/QNXT and communicated to providers. Used for cross-system reconciliation and provider inquiries.']
  policy_source varchar [note: 'Originating authority or source that defines this reimbursement policy. Distinguishes between federally mandated policies (CMS NCCI, MPPR), AMA CPT guidelines, state-mandated rules, and internally plan-defined or contract-specific policies.']
  policy_status varchar [note: 'Current lifecycle state of the reimbursement policy. Controls whether the policy is applied during claims adjudication in Facets/QNXT. Active policies are enforced; retired policies are retained for historical adjudication reference.']
  policy_type varchar [note: 'Categorical classification of the reimbursement policy governing how claims are adjudicated. Drives the adjudication logic applied in Facets/QNXT. [ENUM-REF-CANDIDATE: multiple_procedure_reduction|bilateral_procedure|assistant_surgeon|global_surgery|unbundling|place_of_service_differential|anesthesia|assistant_at_surgery|co_surgery|team_surgery|modifier_impact|site_of_service — promote to reference product]']
  policy_version varchar [note: 'Version identifier for this reimbursement policy, incremented when the policy terms are amended (e.g., \'1.0\', \'2.3\'). Supports policy lifecycle management and historical adjudication audits by identifying which version was active at a given service date.']
  primary_procedure_rank varchar [note: 'Ranking order used to determine which procedure is designated as the primary (highest-paid) procedure when multiple procedures are performed. The procedure with rank 1 is reimbursed at 100%; subsequent ranks receive the reduction percentage. Applies to multiple procedure reduction policies.']
  provider_specialty_code varchar [note: 'CMS or NUCC provider specialty code restricting this reimbursement policy to a specific provider specialty (e.g., 02=General Surgery, 93=Radiation Oncology). Null indicates the policy applies to all specialties. Used for specialty-specific reimbursement rules.']
  reduction_pct decimal(5,2) [note: 'Percentage by which the allowed amount is reduced when this policy is triggered during claims adjudication. For example, a value of 50.00 indicates the secondary procedure is reimbursed at 50% of the contracted rate. Applies to policies such as multiple procedure reduction and assistant surgeon.']
  regulatory_mandate_flag boolean [note: 'Indicates whether this reimbursement policy is mandated by a federal or state regulatory authority (e.g., CMS NCCI edits, state prompt payment laws). Regulatory mandate policies cannot be waived or overridden without regulatory approval.']
  regulatory_reference varchar [note: 'Citation to the specific regulatory rule, CMS manual chapter, state statute, or contractual clause that mandates or governs this reimbursement policy (e.g., \'CMS NCCI Chapter 4, Section 4.2\', \'42 CFR 422.520\'). Populated when regulatory_mandate_flag is True.']
  retroactive_adjustment_allowed boolean [note: 'Indicates whether this reimbursement policy can be applied retroactively to previously adjudicated claims when the policy is newly activated or amended. When True, claims reprocessing may be triggered for the applicable service date range.']
  revenue_code_range_end decimal(18,2) [note: 'Ending UB-04 revenue code in the range to which this reimbursement policy applies for facility claims. Used in conjunction with revenue_code_range_start to define applicable revenue code ranges for institutional claim adjudication.']
  revenue_code_range_start decimal(18,2) [note: 'Starting UB-04 revenue code in the range to which this reimbursement policy applies for facility claims. Used in conjunction with revenue_code_range_end to define applicable revenue code ranges for institutional claim adjudication.']
  termination_date date [note: 'Date on which the reimbursement policy expires and is no longer applied to new claims. Null indicates an open-ended policy with no defined end date. Claims with service dates after this date are not subject to this policy.']
  updated_timestamp timestamp [note: 'Timestamp when this reimbursement policy record was last modified. Used for change data capture (CDC) in the Databricks Silver Layer pipeline and for audit trail compliance.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Defines payer reimbursement policies that govern how claims are adjudicated against contracted rates. Captures policy type (multiple procedure reduction, bilateral procedure, assistant surgeon, global surgery, unbundling rules, place-of-service differential), applicable CPT/HCPCS ranges, reduction percentage, effective date, and LOB applicability. Bridges contract terms to claims adjudication logic in Facets/QNXT. [FHIR-aligned]'
}

Table contract.contract_network_participation {
  contract_network_participation_id varchar [pk, note: 'Unique identifier for the network participation record. Primary key for this entity.']
  network_config_id varchar [note: 'Foreign key linking to plan.network_config. Business justification: Network participation records must be associated with a specific plan network configuration for network adequacy reporting, provider directory publication, and CMS network adequacy standard compliance']
  party_id varchar [note: 'Foreign key linking to contract.party. Business justification: Network participation records which provider party participates in a given network configuration. The party table is the SSOT for provider identity in this domain. This FK connects network_participati']
  service_area_id varchar [note: 'Foreign key linking to plan.plan_service_area. Business justification: CMS and state network adequacy standards require validating provider participation against specific plan service areas. Network adequacy reports and provider directory management require knowing which']
  vbc_contract_id varchar [note: 'Foreign key linking to contract.vbc_contract. Business justification: network_participation has a vbc_arrangement_type field indicating that some network participation records are associated with VBC arrangements. This FK links network participation to the specific VBC ']
  accepting_new_patients_flag boolean [note: 'Indicator whether the provider is currently accepting new patient enrollments under this network participation arrangement.']
  aco_participant_flag boolean [note: 'Boolean indicator whether this provider participates in an ACO arrangement under this network participation for value-based care programs.']
  amendment_number varchar [note: 'Reference to the contract amendment that established or modified this network participation arrangement.']
  approval_date date [note: 'Date when this network participation arrangement was formally approved by authorized plan personnel.']
  auto_renewal_flag boolean [note: 'Boolean indicator whether this network participation automatically renews at the end of the term unless either party provides termination notice.']
  claims_adjudication_priority varchar [note: 'Numeric priority ranking used by claims processing systems when multiple network participations exist for the same provider, with lower numbers indicating higher priority.']
  credentialing_date date [note: 'Date when the provider was most recently credentialed or re-credentialed for participation in this network.']
  credentialing_status varchar [note: 'Current credentialing verification status of the provider for this network participation, ensuring compliance with quality and safety standards.']
  directory_publication_flag boolean [note: 'Boolean indicator whether this network participation should be published in member-facing provider directories and online search tools.']
  effective_date date [note: 'Date when the provider\'s participation in this network configuration becomes active and binding for claims adjudication and directory publication.']
  geographic_service_area varchar [note: 'Geographic region or service area where this network participation is valid, typically defined by state, county, or ZIP code ranges.']
  in_network_flag boolean [note: 'Boolean indicator whether this provider is considered in-network for claims adjudication and member cost-sharing calculations.']
  lob varchar [note: 'Product line or market segment that this network participation applies to, determining regulatory requirements and benefit structures.']
  network_tier varchar [note: 'Tiering classification that determines member cost-sharing levels and provider reimbursement rates. Tier 1 typically represents highest value providers with lowest member cost-sharing.']
  out_of_network_flag boolean [note: 'Boolean indicator whether this provider arrangement allows out-of-network benefits and reimbursement under specific circumstances.']
  participation_number varchar [note: 'Business identifier for this network participation arrangement, used for operational reference and tracking.']
  participation_status varchar [note: 'Current lifecycle status of the network participation arrangement indicating whether the provider is actively participating in the network.']
  pcp_assignment_eligible_flag boolean [note: 'Boolean indicator whether this provider can be assigned as a Primary Care Physician for members in HMO or POS plans requiring PCP selection.']
  prior_authorization_required_flag boolean [note: 'Indicator whether services from this provider under this network arrangement require prior authorization for coverage and payment.']
  product_line varchar [note: 'Health plan product type that this network participation covers, defining network access rules and referral requirements.']
  quality_tier_designation varchar [note: 'Quality performance tier assigned to this provider based on HEDIS, STAR, or other quality metrics, influencing network tier placement and incentives.']
  record_created_timestamp timestamp [note: 'Timestamp when this network participation record was first created in the data platform, supporting audit trail and data lineage requirements.']
  record_updated_timestamp timestamp [note: 'Timestamp when this network participation record was most recently modified in the data platform, supporting change tracking and audit requirements.']
  recredentialing_due_date date [note: 'Date when the provider\'s credentials must be reverified to maintain active network participation status.']
  referral_required_flag boolean [note: 'Indicator whether members must obtain a referral from their PCP to access this provider under the network participation terms.']
  risk_share_percentage decimal(5,2) [note: 'Percentage of financial risk shared between the health plan and provider under value-based care arrangements for this network participation.']
  service_area_county varchar [note: 'County name or FIPS code defining the local geographic area covered by this network participation arrangement.']
  service_area_state varchar [note: 'Two-letter state code identifying the primary state where this network participation applies for regulatory and directory purposes.']
  service_area_zip_codes varchar [note: 'Comma-separated list or range of ZIP codes where this network participation is valid for member access and claims processing.']
  source_system_record_reference varchar [note: 'Unique identifier for this network participation record in the source operational system, used for data lineage and reconciliation.']
  telehealth_eligible_flag boolean [note: 'Indicator whether this provider is eligible to deliver covered telehealth or virtual care services under this network participation.']
  termination_date date [note: 'Date when the provider\'s participation in this network ends. Null indicates open-ended participation with no scheduled termination.']
  termination_notice_days varchar [note: 'Number of days advance notice required for termination of this network participation per contractual terms.']
  termination_reason varchar [note: 'Business reason or cause for termination of this network participation arrangement, such as contract expiration, quality issues, or provider request.']
  vbc_arrangement_type varchar [note: 'Type of value-based care or alternative payment model applied to this network participation, defining financial incentive structure.']
  vreq_validated varchar [note: 'Marker indicating VREQ validation pass']

  Note: 'Association entity linking a provider contract to specific network configurations, defining which provider networks the contract covers. Captures network ID reference, participation tier (tier 1, tier 2, preferred, standard, narrow), in-network effective and termination dates, out-of-network flag, geographic service area, product line applicability (commercial, Medicare Advantage, Medicaid, exchange/QHP), and participation status (active, pending, terminated). Bridges the contract domain to the network domain for directory accuracy and claims adjudication network matching. [FHIR-aligned]'
}

Table appeal.grievance {
  grievance_id varchar [pk, note: 'Primary key for appeal grievance record.']
  adverse_determination_id varchar [note: 'Foreign key linking to appeal.adverse_determination. Business justification: A grievance or appeal is filed directly in response to a specific adverse benefit determination. This is a core business relationship in health insurance appeals: the adverse_determination is the prox']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Grievances are filed against specific benefit package determinations. Appeals operations teams must identify which benefit package rules governed the disputed service. Regulatory grievance tracking an']
  case_id varchar [note: 'FK to the appeal case.']
  denial_id varchar [note: 'Foreign key linking to claim.denial. Business justification: NCQA/URAC grievance tracking requires direct linkage from a grievance filing to the specific claim denial that prompted it. Grievance analysts and compliance officers need to identify the originating ']
  eligibility_span_id varchar [note: 'Foreign key linking to enrollment.enrollment_eligibility_span. Business justification: Grievances are frequently filed about coverage eligibility disputes (e.g., wrongful termination, incorrect benefit period). Linking the grievance directly to the eligibility span enables grievance roo']
  filing_party_id varchar [note: 'FK to the filing party.']
  health_plan_id varchar [note: 'FK to health plan.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Grievances are filed in the context of a specific policy — regulatory grievance reporting (NCQA, CMS) requires tracking grievances by policy type and coverage period. Adjudicators need the policy reco']
  practice_location_id varchar [note: 'FK to provider.']
  program_id varchar [note: 'Foreign key linking to care.program. Business justification: Members file grievances about mandatory care management program participation or program-related service denials. Linking appeal_grievance to the specific care program enables grievance trend analysis']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Providers file grievances directly against health plans (e.g., payment disputes, network issues). filing_party_type=\'PROVIDER\' is a common scenario. A direct provider_id FK supports provider relations']
  term_id varchar [note: 'Foreign key linking to contract.term. Business justification: Provider grievances are frequently filed disputing a specific contract term (payment methodology, reduction percentage, dispute_resolution_method). Contract administrators and appeal coordinators must']
  acknowledgment_date date [note: 'Date the grievance was acknowledged.']
  appeal_grievance_status varchar [note: 'Current status of the grievance.']
  appeal_reference_number varchar [note: 'Reference number for the appeal.']
  case_notes varchar [note: 'Free-text notes on the case.']
  compliance_flag boolean [note: 'Indicates compliance status.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  escalation_level varchar [note: 'Level of escalation for the grievance.']
  external_review_outcome varchar [note: 'Outcome of external review if requested.']
  external_review_requested boolean [note: 'Whether external review was requested.']
  filing_channel varchar [note: 'Channel through which grievance was filed.']
  filing_date date [note: 'Date the grievance was filed.']
  filing_party_type varchar [note: 'Type of party filing the grievance.']
  grievance_number varchar [note: 'Unique grievance identifier number.']
  grievance_type varchar [note: 'Classification type of the grievance.']
  investigation_end_date date [note: 'Date investigation ended.']
  investigation_start_date date [note: 'Date investigation started.']
  is_appeal boolean [note: 'Whether this record is an appeal vs grievance.']
  is_confidential boolean [note: 'Whether the grievance is confidential.']
  priority varchar [note: 'Priority level of the grievance.']
  regulatory_classification varchar [note: 'Regulatory classification code.']
  resolution_date date [note: 'Date the grievance was resolved.']
  resolution_detail varchar [note: 'Details of the resolution.']
  resolution_type varchar [note: 'Type of resolution applied.']
  state_code varchar [note: 'State jurisdiction code.']
  title varchar [note: 'Title of the grievance.']
  updated_timestamp timestamp [note: 'Record last updated timestamp.']
  zip_code varchar [note: 'Zip code of the filing party.']

  Note: 'Records grievances and appeals filed by members, providers, or other parties against health plan decisions. SSOT for appeal-side grievances with reference to member.member_grievance.'
}

Table appeal.case {
  case_id varchar [pk, note: 'Primary key for appeal case.']
  adjudication_id varchar [note: 'Foreign key linking to claim.adjudication. Business justification: Appeal reviewers must examine the exact adjudication decision being contested. Linking claim.case directly to claim.adjudication supports the appeal review workflow — reviewers need adjudication deta']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Appeal cases are opened to dispute specific benefit package determinations. Case management workflows require direct access to the benefit package under dispute for applying correct clinical criteria ']
  care_coordinator_id varchar [note: 'Foreign key linking to care.coordinator. Business justification: When a member appeals a care management decision, the responsible care coordinator is a named party in the case. Role-prefix \'care_coordinator\' distinguishes from party_id. Enables coordinator perform']
  claim_header_id varchar [note: 'FK to related claim.']
  denial_id varchar [note: 'Foreign key linking to claim.denial. Business justification: ERISA/ACA appeal tracking requires direct traceability from an appeal case to the specific claim denial that triggered it. Appeal processors and regulators need to identify which denial originated eac']
  pa_request_id varchar [note: 'Foreign key linking to utilization.pa_request. Business justification: Appeal cases are primarily triggered by PA denials. Linking case to pa_request enables appeal-to-PA workflow tracking, NCQA/CMS regulatory reporting on denial appeal rates, and overturn analysis by PA']
  party_id varchar [note: 'FK to contract party.']
  pharmacy_claim_id varchar [note: 'Foreign key linking to pharmacy.pharmacy_claim. Business justification: When a member appeals a pharmacy claim denial (e.g., rejected fill, incorrect cost-sharing), the appeal case must directly reference the specific pharmacy claim. CMS Part D grievance and appeal report']
  plan_election_id varchar [note: 'FK to plan election.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Appeals cases are adjudicated against specific policy terms — benefit limits, deductibles, and coverage rules are policy-specific. Appeals coordinators and compliance teams require direct policy linka']
  premium_invoice_id decimal(18,2) [note: 'FK to premium invoice.']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Provider-level appeal tracking: health plans must report overturn rates and appeal volumes by treating provider for network management, credentialing review triggers, and CMS/state regulatory reportin']
  um_case_id varchar [note: 'Foreign key linking to utilization.um_case. Business justification: Appeals frequently arise from UM case decisions including concurrent review denials and discharge planning disputes. Linking utilization.case to um_case enables UM-to-appeal tracking, regulatory reporting ']
  appeal_assigned_to varchar [note: 'Name/ID of person assigned to the appeal.']
  appeal_escalation_flag boolean [note: 'Whether the appeal has been escalated.']
  appeal_number varchar [note: 'Unique appeal case number.']
  appeal_priority varchar [note: 'Priority level of the appeal.']
  appeal_review_cycle_days varchar [note: 'Number of days in the review cycle.']
  appeal_status varchar [note: 'Current status of the appeal case.']
  appeal_type varchar [note: 'Type/category of the appeal.']
  completeness_determination varchar [note: 'Whether the appeal submission is complete.']
  decision_author_npi varchar [note: 'NPI of the decision author.']
  decision_rationale decimal(18,6) [note: 'Rationale for the decision.']
  decision_timestamp timestamp [note: 'Timestamp of the decision.']
  decision_type varchar [note: 'Type of decision rendered.']
  effective_benefit_change_date date [note: 'Date benefit change takes effect.']
  expedited_clinical_urgency_basis varchar [note: 'Clinical basis for expedited processing.']
  expedited_trigger boolean [note: 'Whether expedited processing was triggered.']
  filing_channel varchar [note: 'Channel used to file the appeal.']
  filing_method varchar [note: 'Method used to file the appeal.']
  filing_party_type varchar [note: 'Type of party filing the appeal.']
  filing_timestamp timestamp [note: 'Timestamp when appeal was filed.']
  line_of_business varchar [note: 'Line of business for the appeal.']
  member_notification_date date [note: 'Date member was notified.']
  original_claim_number varchar [note: 'Original claim number being appealed.']
  overturn_reason varchar [note: 'Reason for overturning the decision.']
  provider_notification_date date [note: 'Date provider was notified.']
  record_created_timestamp timestamp [note: 'Record creation timestamp.']
  record_updated_timestamp timestamp [note: 'Record last update timestamp.']
  regulatory_tier varchar [note: 'Regulatory tier classification.']
  supporting_documentation_checklist varchar [note: 'Checklist of supporting documents.']

  Note: 'Represents an appeal case encompassing all related reviews, documents, communications, and outcomes.'
}

Table appeal.adverse_determination {
  adverse_determination_id varchar [pk, note: 'Primary key.']
  adjudication_id varchar [note: 'Foreign key linking to claim.adjudication. Business justification: An adverse determination is a formal output of an adjudication decision. Regulatory reporting (NCQA, URAC) and clinical review require direct linkage between the adverse determination and the specific']
  benefit_id varchar [note: 'Foreign key linking to plan.benefit. Business justification: An adverse determination (denial) is issued against a specific covered benefit. Clinical reviewers and appeals processors must reference the exact benefit definition and coverage rules when evaluating']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Adverse determinations are governed by the benefit package in effect at time of service. Appeals reviewers must apply the correct cost-sharing and coverage rules from the specific benefit package. ERI']
  case_id varchar [note: 'Foreign key linking to appeal.case. Business justification: An adverse determination is the triggering event for an appeal case. When a member or provider files an appeal, a case is opened to track the full lifecycle of that appeal against the adverse determin']
  claim_header_id varchar [note: 'FK to claim header.']
  denial_id varchar [note: 'Foreign key linking to claim.denial. Business justification: Regulatory adverse determination reporting (ACA, ERISA) requires linking each adverse determination to the originating claim denial. An adverse determination is the formal escalation of a denial; revi']
  drug_master_id varchar [note: 'Foreign key linking to pharmacy.drug_master. Business justification: CMS Part D adverse determination reporting requires drug-level identification (NDC/drug class) on each denial record. adverse_determination has service_code but no structured drug reference. Direct dr']
  medical_policy_id varchar [note: 'Foreign key linking to utilization.medical_policy. Business justification: Adverse determinations cite the specific medical policy under which coverage was denied. This link supports regulatory compliance reporting, appeal overturn analysis by policy version, and NCQA/URAC a']
  member_identity_id varchar [note: 'FK to member identity.']
  pa_decision_id varchar [note: 'Foreign key linking to utilization.pa_decision. Business justification: An adverse determination is the formal denial record generated from a pa_decision. Linking to pa_decision (not just pa_request) captures the clinical rationale, denial reason category, and reviewer cr']
  pa_request_id varchar [note: 'FK to PA request.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Adverse determinations (denials) are issued under a specific policy — the denial reason, appeal rights, and monetary amounts denied are all policy-dependent. URAC and state regulatory reporting of adv']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Adverse determinations are issued against a specific treating provider\'s service. Provider-level denial rate reporting, credentialing review triggers (high denial rates), and HEDIS/regulatory audits a']
  reimbursement_policy_id varchar [note: 'Foreign key linking to contract.reimbursement_policy. Business justification: Adverse determinations (claim denials) are directly driven by reimbursement policy rules (NCCI edits, bundling, max procedures). Appeal reviewers must trace denial_reason_code back to the governing re']
  appeal_deadline_date date [note: 'Deadline to file an appeal.']
  appeal_eligibility_flag boolean [note: 'Whether the determination is eligible for appeal.']
  appeal_filed_date date [note: 'Date appeal was filed.']
  appeal_outcome varchar [note: 'Outcome of the appeal if filed.']
  appeal_resolution_date date [note: 'Date appeal was resolved.']
  appeal_status varchar [note: 'Status of the appeal.']
  basis_of_denial varchar [note: 'Basis for the denial.']
  clinical_criteria_version varchar [note: 'Version of clinical criteria used.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  currency_code varchar [note: 'Currency code for monetary amounts.']
  denial_reason_code varchar [note: 'Code for the denial reason.']
  denial_reason_description varchar [note: 'Description of the denial reason.']
  determination_date date [note: 'Date of the determination.']
  determination_number varchar [note: 'Unique determination number.']
  determination_status varchar [note: 'Status of the determination.']
  determination_type varchar [note: 'Type of determination.']
  diagnosis_code varchar [note: 'Related diagnosis code.']
  effective_date date [note: 'Effective date of the determination.']
  monetary_amount_adjusted decimal(18,2) [note: 'Amount adjusted.']
  monetary_amount_denied decimal(18,2) [note: 'Amount denied.']
  network_status varchar [note: 'In/out of network status.']
  notes varchar [note: 'Additional notes.']
  prior_authorization_required_flag boolean [note: 'Whether PA was required.']
  reviewer_name varchar [note: 'Name of the reviewer.']
  reviewer_npi varchar [note: 'NPI of the reviewer.']
  service_code varchar [note: 'Service/procedure code.']
  service_date date [note: 'Date of service.']
  updated_timestamp timestamp [note: 'Record last update timestamp.']

  Note: 'Records adverse benefit determinations that may trigger member appeal rights.'
}

Table appeal.review {
  review_id varchar [pk, note: 'Primary key.']
  benefit_id varchar [note: 'Foreign key linking to plan.benefit. Business justification: A clinical review evaluates whether a specific benefit was correctly denied or approved. Linking review to the specific benefit enables benefit-level review analytics (e.g., overturn rates by benefit ']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Clinical reviewers must apply the specific benefit package\'s coverage rules and clinical criteria during a review. Without this FK, reviewers cannot directly retrieve the applicable benefit package te']
  case_id varchar [note: 'FK to appeal case.']
  clinical_criteria_id varchar [note: 'Foreign key linking to utilization.clinical_criteria. Business justification: Appeal reviews apply specific clinical criteria to evaluate whether the original denial was appropriate. Linking review to clinical_criteria enables criteria-level appeal outcome analysis, policy impr']
  hcc_mapping_id varchar [note: 'Foreign key linking to risk.hcc_mapping. Business justification: Clinical appeal reviewers validate whether ICD-10 diagnosis codes are correctly mapped to HCC categories when evaluating denials. Linking review to hcc_mapping records which specific HCC mapping versi']
  reimbursement_policy_id varchar [note: 'Foreign key linking to contract.reimbursement_policy. Business justification: Appeal reviewers must reference the reimbursement policy governing the original denial to assess correct application of policy rules. The review\'s criteria_version and cpt_codes_reviewed map directly ']
  reviewer_provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Internal appeal reviewers must be credentialed providers. Linking reviewer to provider.provider supports credentialing validation of reviewers, audit trails for regulatory compliance (URAC, NCQA), and']
  reviewer_specialty_id varchar [note: 'Foreign key linking to provider.specialty. Business justification: State regulations (e.g., NAIC model act) require specialty-matched reviewers for clinical appeals. Linking reviewer_specialty_id to provider.specialty enables specialty-match validation, NCQA/URAC aud']
  appeal_case_number varchar [note: 'Appeal case number reference.']
  appeal_reason_code varchar [note: 'Reason code for the appeal.']
  appeal_status_at_review varchar [note: 'Status of appeal at time of review.']
  appeal_submission_date date [note: 'Date appeal was submitted.']
  clinical_rationale decimal(18,6) [note: 'Clinical rationale for the review decision.']
  compliance_flag boolean [note: 'Compliance status flag.']
  cpt_codes_reviewed varchar [note: 'CPT codes reviewed.']
  drg_code varchar [note: 'DRG code if applicable.']
  duration_minutes varchar [note: 'Duration of the review in minutes.']
  icd_codes_reviewed varchar [note: 'ICD codes reviewed.']
  is_independent_reviewer boolean [note: 'Whether reviewer is independent.']
  location varchar [note: 'Location of the review.']
  notes varchar [note: 'Review notes.']
  outcome varchar [note: 'Outcome of the review.']
  record_audit_created timestamp [note: 'Audit creation timestamp.']
  record_audit_updated timestamp [note: 'Audit update timestamp.']
  review_number varchar [note: 'Unique review number.']
  review_status varchar [note: 'Current status of the review.']
  review_timestamp timestamp [note: 'Timestamp of the review.']
  review_type varchar [note: 'Type of review conducted.']
  reviewer_npi varchar [note: 'NPI of the reviewer.']
  reviewer_type varchar [note: 'Type of reviewer.']

  Note: 'Records individual reviews conducted as part of an appeal case, including internal and peer reviews.'
}

Table appeal.external_review {
  external_review_id varchar [pk, note: 'Primary key.']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Independent Review Organizations (IROs) conducting external reviews must evaluate the denial against the specific benefit package terms. State and federal regulations require external review decisions']
  case_id varchar [note: 'FK to appeal case.']
  claim_header_id varchar [note: 'FK to claim header.']
  denial_id varchar [note: 'Foreign key linking to claim.denial. Business justification: IRO (Independent Review Organization) regulatory reporting requires direct reference to the specific claim denial being externally reviewed. State mandates and ACA external review rules require tracki']
  eligibility_span_id varchar [note: 'Foreign key linking to enrollment.enrollment_eligibility_span. Business justification: Independent external reviewers require the member\'s coverage details (benefit limits, OOP, deductible) from the eligibility span to render binding determinations. State external review regulations req']
  member_subscriber_id varchar [note: 'FK to member subscriber.']
  pa_request_id varchar [note: 'Foreign key linking to utilization.pa_request. Business justification: External IRO reviews are triggered by PA denials escalated beyond internal appeal. Linking external_review to pa_request supports state regulatory reporting on external review outcomes by PA type, bin']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: External reviews are triggered by disputes over a treating provider\'s denied service. Provider-level external review tracking is required for state regulatory reporting, network adequacy analysis, and']
  adjustment_amount decimal(18,2) [note: 'Financial adjustment amount.']
  appeal_reason_code varchar [note: 'Reason code for the appeal.']
  appeal_reason_description varchar [note: 'Description of appeal reason.']
  binding_determination_flag boolean [note: 'Whether the determination is binding.']
  claim_amount decimal(18,2) [note: 'Original claim amount.']
  compliance_action_taken varchar [note: 'Compliance action taken.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  currency_code varchar [note: 'Currency code.']
  deadline_date date [note: 'Deadline for external review.']
  decision varchar [note: 'Decision rendered.']
  decision_date date [note: 'Date of decision.']
  decision_rationale decimal(18,6) [note: 'Rationale for the decision.']
  diagnosis_code varchar [note: 'Related diagnosis code.']
  external_review_status varchar [note: 'Status of the external review.']
  external_review_type varchar [note: 'Type of external review.']
  iro_accreditation_status varchar [note: 'Accreditation status of the IRO.']
  is_urgent boolean [note: 'Whether the review is urgent.']
  last_status_change_timestamp timestamp [note: 'Timestamp of last status change.']
  net_amount decimal(18,2) [note: 'Net financial amount.']
  notes varchar [note: 'Additional notes.']
  overdue_flag boolean [note: 'Whether the review is overdue.']
  patient_relationship varchar [note: 'Patient relationship to subscriber.']
  procedure_code varchar [note: 'Related procedure code.']
  regulatory_reporting_flag boolean [note: 'Whether regulatory reporting is required.']
  reporting_status varchar [note: 'Status of regulatory reporting.']
  reporting_submission_date date [note: 'Date of regulatory submission.']
  request_timestamp timestamp [note: 'Timestamp of the review request.']
  review_category varchar [note: 'Category of the review.']
  review_number varchar [note: 'Unique review number.']
  review_priority varchar [note: 'Priority of the review.']
  service_date date [note: 'Date of service.']
  source varchar [note: 'Source of the external review.']
  state varchar [note: 'State jurisdiction.']
  transmission_date date [note: 'Date of transmission to IRO.']
  updated_timestamp timestamp [note: 'Record last update timestamp.']

  Note: 'Records external/independent reviews conducted by IROs as part of the appeal process.'
}

Table appeal.document {
  document_id varchar [pk, note: 'Primary key.']
  case_id varchar [note: 'FK to appeal case.']
  member_identity_id varchar [note: 'FK to member identity.']
  appeal_document_description varchar [note: 'Description of the document.']
  appeal_document_status varchar [note: 'Status of the document.']
  audit_trail varchar [note: 'Audit trail information.']
  considered_in_decision boolean [note: 'Whether document was considered in decision.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  document_number varchar [note: 'Unique document number.']
  document_type varchar [note: 'Type of document.']
  file_size_bytes varchar [note: 'File size in bytes.']
  format varchar [note: 'File format.']
  is_confidential boolean [note: 'Whether document is confidential.']
  is_redacted boolean [note: 'Whether document is redacted.']
  last_accessed_timestamp timestamp [note: 'Last access timestamp.']
  phi_classification varchar [note: 'PHI classification level.']
  receipt_date date [note: 'Date document was received.']
  redaction_status varchar [note: 'Redaction status.']
  retention_period_years varchar [note: 'Retention period in years.']
  source varchar [note: 'Source of the document.']
  storage_path varchar [note: 'Storage path/URI.']
  title varchar [note: 'Document title.']
  updated_timestamp timestamp [note: 'Record last update timestamp.']
  version_number varchar [note: 'Document version number.']

  Note: 'Documents associated with appeal cases. SSOT reference to credential.credential_document for cross-domain deduplication.'
}

Table appeal.expedited_review {
  expedited_review_id varchar [pk, note: 'Primary key.']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Expedited reviews are time-sensitive clinical reviews (72-hour turnaround) that must apply the specific benefit package\'s coverage rules. Regulatory compliance tracking for expedited review timeliness']
  case_id varchar [note: 'FK to appeal case.']
  claim_header_id varchar [note: 'FK to claim header.']
  denial_id varchar [note: 'Foreign key linking to claim.denial. Business justification: The 72-hour expedited review regulatory requirement (ACA, ERISA) mandates tracking which specific denial triggered an urgent review. Compliance monitoring of expedited review timelines requires direct']
  eligibility_span_id varchar [note: 'Foreign key linking to enrollment.enrollment_eligibility_span. Business justification: Expedited reviews involve urgent clinical situations where active coverage must be confirmed within 72-hour regulatory windows. Linking to the eligibility span enables real-time coverage validation du']
  member_subscriber_id varchar [note: 'FK to member subscriber.']
  pa_request_id varchar [note: 'Foreign key linking to utilization.pa_request. Business justification: Expedited reviews are almost exclusively triggered by urgent PA denials (concurrent review denials for ongoing inpatient care). Linking to pa_request supports CMS 72-hour turnaround compliance reporti']
  parent_expedited_review_id varchar [note: 'Self-referencing FK for parent expedited review.']
  practice_location_id varchar [note: 'FK to provider.']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Expedited reviews involve clinically urgent services tied to a specific treating provider. Provider-level expedited review tracking supports network management, credentialing review, and CMS/state reg']
  actual_decision_date date [note: 'Actual date of decision.']
  adjustment_amount decimal(18,2) [note: 'Financial adjustment amount.']
  claim_amount decimal(18,2) [note: 'Original claim amount.']
  clinical_urgency_classification varchar [note: 'Classification of clinical urgency.']
  compliance_flag boolean [note: 'Compliance status flag.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  currency_code varchar [note: 'Currency code.']
  decision_due_date date [note: 'Due date for decision.']
  decision_outcome varchar [note: 'Outcome of the decision.']
  decision_rationale decimal(18,6) [note: 'Rationale for the decision.']
  expedited_notification_required boolean [note: 'Whether expedited notification is required.']
  expedited_reason varchar [note: 'Reason for expedited processing.']
  expedited_review_status varchar [note: 'Status of the expedited review.']
  is_confidential boolean [note: 'Whether review is confidential.']
  net_amount decimal(18,2) [note: 'Net financial amount.']
  notes varchar [note: 'Additional notes.']
  notification_method varchar [note: 'Method of notification.']
  notified_timestamp timestamp [note: 'Timestamp of notification.']
  regulatory_body varchar [note: 'Regulatory body.']
  request_timestamp timestamp [note: 'Timestamp of the request.']
  review_request_number varchar [note: 'Unique review request number.']
  state_code varchar [note: 'State code.']
  supporting_document_count varchar [note: 'Number of supporting documents.']
  updated_timestamp timestamp [note: 'Record last update timestamp.']

  Note: 'Expedited reviews for urgent appeal cases requiring accelerated processing.'
}

Table appeal.outcome {
  outcome_id varchar [pk, note: 'Primary key.']
  benefit_package_id varchar [note: 'Foreign key linking to plan.benefit_package. Business justification: Appeal outcomes (overturn, uphold, partial) are rendered in the context of a specific benefit package. Benefit-package-level outcome reporting is required for CMS and state regulatory submissions. Pla']
  case_id varchar [note: 'FK to appeal case.']
  claim_header_id varchar [note: 'FK to claim header.']
  denial_id varchar [note: 'Foreign key linking to claim.denial. Business justification: Denial resolution tracking and regulatory reporting on appeal outcomes require direct linkage from the appeal outcome to the specific denial it resolves. Compliance reports (denial overturn rates, res']
  eligibility_span_id varchar [note: 'Foreign key linking to enrollment.enrollment_eligibility_span. Business justification: Appeal outcomes that overturn denials or reinstate coverage must reference the specific eligibility span to trigger retroactive enrollment adjustments. The downstream_action field on outcome drives en']
  invoice_line_id varchar [note: 'Foreign key linking to billing.invoice_line. Business justification: Appeal outcome financial remediation targets specific invoice line charges. When an outcome reverses a line-level charge, the downstream_action and financial_impact_amount on outcome must trace to the']
  member_identity_id varchar [note: 'FK to member identity.']
  pa_request_id varchar [note: 'Foreign key linking to utilization.pa_request. Business justification: Appeal outcomes that overturn PA denials must link back to the originating PA request to trigger re-authorization workflows, update authorization status, and support financial reconciliation of adjust']
  parent_outcome_id varchar [note: 'Self-referencing FK for parent outcome.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: Appeal outcomes that overturn denials trigger downstream policy actions — benefit reinstatements, premium adjustments, or coverage amendments. Policy administration teams require direct policy linkage']
  premium_payment_id decimal(18,2) [note: 'Foreign key linking to billing.premium_payment. Business justification: Appeal outcome financial remediation process: when an outcome overturns a denial or billing dispute, the specific premium payment under dispute must be referenced to execute refunds, credits, or reall']
  provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: Appeal outcomes must be communicated to the treating provider within regulatory timeframes (ACA, state mandates). provider_notification_timestamp already exists on outcome, confirming this business pr']
  compliance_flag boolean [note: 'Compliance status flag.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  currency_code varchar [note: 'Currency code.']
  downstream_action varchar [note: 'Downstream action required.']
  financial_impact_amount decimal(18,2) [note: 'Financial impact amount.']
  jurisdiction_state varchar [note: 'State jurisdiction.']
  member_notification_timestamp timestamp [note: 'Timestamp member was notified.']
  notes varchar [note: 'Additional notes.']
  outcome_number varchar [note: 'Unique outcome number.']
  outcome_status varchar [note: 'Status of the outcome.']
  outcome_timestamp timestamp [note: 'Timestamp of the outcome.']
  outcome_type varchar [note: 'Type of outcome.']
  provider_notification_timestamp timestamp [note: 'Timestamp provider was notified.']
  reason_code varchar [note: 'Reason code.']
  reason_description varchar [note: 'Description of reason.']
  regulatory_body varchar [note: 'Regulatory body.']
  source_system_record_code varchar [note: 'Source system record code.']
  updated_timestamp timestamp [note: 'Record last update timestamp.']

  Note: 'Records the final outcomes of appeal cases including financial impacts and notifications.'
}

Table risk.member_risk_score {
  member_risk_score_id varchar [pk, note: 'Primary key for member risk score record.']
  member_identity_id varchar [note: 'FK to member identity.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: CMS risk adjustment (HCC/RAPS) is calculated per policy/coverage period. Risk analysts and compliance teams must tie each risk score to the specific policy it was submitted for, enabling payment recon']
  raps_submission_id varchar [note: 'Foreign key linking to risk.raps_submission. Business justification: Individual member risk scores are submitted to CMS via RAPS batch submissions. Adding raps_submission_id to member_risk_score links each risk score record to the specific RAPS submission batch it was ']
  audit_user varchar [note: 'User who last audited the score.']
  cms_published_score decimal(10,4) [note: 'CMS-published risk adjustment score.']
  cms_submission_status varchar [note: 'Status of CMS submission for this score.']
  corrective_action varchar [note: 'Corrective action taken if score variance detected.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  demographic_factor_score decimal(10,4) [note: 'Demographic component of risk score.']
  diagnosis_count varchar [note: 'Number of diagnoses contributing to score.']
  effective_timestamp timestamp [note: 'When the score became effective.']
  expiration_date date [note: 'Date the score expires.']
  is_manual_override boolean [note: 'Whether score was manually overridden.']
  manual_override_reason varchar [note: 'Reason for manual override.']
  model_name varchar [note: 'Name of the risk model used.']
  model_version varchar [note: 'Version of the risk model.']
  payment_year decimal(18,2) [note: 'CMS payment year for risk adjustment.']
  plan_calculated_score decimal(10,4) [note: 'Plan-calculated risk score before CMS reconciliation.']
  record_status varchar [note: 'Status of the risk score record.']
  resubmission_reference varchar [note: 'Reference ID for resubmitted scores.']
  risk_adjustment_factor_category double [note: 'Category of risk adjustment factor.']
  risk_score_code double [note: 'Coded risk score value.']
  risk_score_confidence_score decimal(5,2) [note: 'Confidence level of the risk score.']
  risk_score_label double [note: 'Label for the risk score tier.']
  risk_score_notes double [note: 'Notes associated with risk score.']
  risk_score_source double [note: 'Source system of the risk score.']
  risk_score_status double [note: 'Current status of the risk score.']
  risk_score_type double [note: 'Type classification of risk score.']
  risk_score_value decimal(10,4) [note: 'Numeric risk score value.']
  score_components double [note: 'Breakdown of score components.']
  score_effective_date date [note: 'Date the score becomes effective.']
  score_variance decimal(10,4) [note: 'Variance between plan and CMS scores.']
  updated_timestamp timestamp [note: 'Last update timestamp.']
  variance_category varchar [note: 'Category of score variance.']

  Note: 'Stores individual member risk scores calculated via CMS-HCC or prospective models for risk adjustment and payment reconciliation.'
}

Table risk.hcc_mapping {
  hcc_mapping_id varchar [pk, note: 'Primary key.']
  age_adjustment_factor decimal(5,4) [note: 'Age-based adjustment factor.']
  coefficient decimal(10,6) [note: 'HCC coefficient for risk score calculation.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  demographic_adjustment_factor decimal(5,4) [note: 'Demographic-based adjustment.']
  disease_interaction_group varchar [note: 'Disease interaction group code.']
  effective_date date [note: 'Mapping effective date.']
  expiration_date date [note: 'Mapping expiration date.']
  gender_adjustment_factor decimal(5,4) [note: 'Gender-based adjustment factor.']
  hcc_code varchar [note: 'Hierarchical Condition Category code.']
  hcc_description varchar [note: 'Description of the HCC.']
  hcc_mapping_status varchar [note: 'Status of the mapping record.']
  hierarchy_level varchar [note: 'Level in the HCC hierarchy.']
  icd10_code varchar [note: 'ICD-10 diagnosis code.']
  icd10_description varchar [note: 'Description of the ICD-10 code.']
  interaction_flag boolean [note: 'Whether this HCC participates in disease interactions.']
  is_excluded boolean [note: 'Whether this mapping is excluded from scoring.']
  is_mapped boolean [note: 'Whether the ICD-10 code is mapped to an HCC.']
  last_review_date date [note: 'Date of last clinical review.']
  last_updated_by varchar [note: 'User who last updated the mapping.']
  last_updated_timestamp timestamp [note: 'Last update timestamp.']
  mapping_source varchar [note: 'Source of the mapping (CMS, internal).']
  model_year varchar [note: 'CMS model year for the mapping.']
  notes varchar [note: 'Additional notes.']
  parent_hcc_code varchar [note: 'Parent HCC in the hierarchy.']
  plan_type_adjustment_factor decimal(5,4) [note: 'Plan type adjustment factor.']
  region_adjustment_factor decimal(5,4) [note: 'Regional adjustment factor.']
  review_status varchar [note: 'Clinical review status.']
  risk_score_weight decimal(5,4) [note: 'Weight contribution to risk score.']
  source_version varchar [note: 'Version of the source mapping file.']

  Note: 'Maps ICD-10 diagnosis codes to CMS Hierarchical Condition Categories (HCCs) for risk adjustment scoring.'
}

Table risk.raps_submission {
  raps_submission_id varchar [pk, note: 'Primary key.']
  accepted_record_count varchar [note: 'Number of records accepted by CMS.']
  batch_number varchar [note: 'Submission batch identifier.']
  cms_acknowledgment_status varchar [note: 'CMS acknowledgment status.']
  created_timestamp timestamp [note: 'Record creation timestamp.']
  error_disposition varchar [note: 'Disposition of submission errors.']
  payment_year decimal(18,2) [note: 'CMS payment year.']
  plan_contract_number varchar [note: 'CMS contract number.']
  plan_type varchar [note: 'Type of plan submitted.']
  raps_submission_status varchar [note: 'Overall submission status.']
  rejected_record_count varchar [note: 'Number of records rejected.']
  risk_adjustment_factor decimal(5,4) [note: 'Calculated risk adjustment factor.']
  risk_adjustment_year varchar [note: 'Year of risk adjustment.']
  risk_score decimal(10,4) [note: 'Aggregate risk score for submission.']
  submission_file_checksum varchar [note: 'File integrity checksum.']
  submission_file_name varchar [note: 'Name of submitted file.']
  submission_timestamp timestamp [note: 'When submission was sent.']
  submission_user_name varchar [note: 'User who submitted.']
  total_record_count decimal(18,2) [note: 'Total records in submission.']
  updated_timestamp timestamp [note: 'Last update timestamp.']

  Note: 'Tracks Risk Adjustment Processing System (RAPS) submissions to CMS for Medicare Advantage risk adjustment.'
}

Table risk.radv_audit {
  radv_audit_id varchar [pk, note: 'Primary key.']
  policy_id varchar [note: 'Foreign key linking to member.policy. Business justification: RADV audits validate risk scores against a specific policy year and coverage period. CMS auditors require the policy record to confirm coverage dates, plan type, and premium amounts align with submitt']
  raps_submission_id varchar [note: 'Foreign key linking to risk.raps_submission. Business justification: CMS RADV audits are triggered to validate the accuracy of risk adjustment data submitted via RAPS. Each RADV audit is associated with a specific RAPS submission (or set of submissions for a given cont']
  rendering_provider_id varchar [note: 'Foreign key linking to provider.provider. Business justification: CMS RADV audits identify the rendering provider whose clinical documentation supports the audited HCC. Auditors must contact the rendering provider for medical records. Role-prefix \'rendering_\' distin']
  audit_end_timestamp timestamp [note: 'When audit ended.']
  audit_error_description varchar [note: 'Description of audit errors.']
  audit_error_flag boolean [note: 'Whether errors were found.']
  audit_notes varchar [note: 'Audit notes.']
  audit_source varchar [note: 'Source of audit.']
  audit_start_timestamp timestamp [note: 'When audit started.']
  audit_status varchar [note: 'Current audit status.']
  audit_type varchar [note: 'Type of RADV audit.']
  audit_updated_by varchar [note: 'User who last updated.']
  audit_year varchar [note: 'Year of audit.']
  cms_findings varchar [note: 'CMS audit findings.']
  currency_code varchar [note: 'Currency code.']
  extrapolated_payment_error decimal(18,2) [note: 'Extrapolated payment error amount.']
  final_settlement_amount decimal(18,2) [note: 'Final settlement amount.']
  hcc_mapping_version varchar [note: 'HCC mapping version used.']
  medical_record_receipt_date date [note: 'Date medical records received.']
  medical_record_request_status varchar [note: 'Status of medical record request.']
  record_created timestamp [note: 'Record creation timestamp.']
  record_updated timestamp [note: 'Record update timestamp.']
  risk_adjustment_factor decimal(5,4) [note: 'Risk adjustment factor.']
  sampled_member_count varchar [note: 'Number of members sampled.']
  validated_hcc_count varchar [note: 'Number of validated HCCs.']

  Note: 'Tracks CMS Risk Adjustment Data Validation (RADV) audits including medical record reviews and payment error calculations.'
}

Table risk.score_hcc_assignment {
  score_hcc_assignment_id varchar [pk, note: 'Primary key for the risk_score_hcc_assignment association']
  hcc_mapping_id varchar [note: 'Foreign key linking to the specific HCC mapping record (ICD-10 to HCC with model year and coefficient) assigned to this member score.']
  member_risk_score_id varchar [note: 'Foreign key linking to the member risk score record that this HCC contributes to.']
  contribution_weight decimal [note: 'The weighted contribution of this specific HCC to the member\'s total RAF score. Derived from the HCC coefficient adjusted for demographic and interaction factors specific to this member-HCC pairing. Belongs to the assignment, not to the score or the mapping alone.']
  effective_date date [note: 'The date on which this HCC assignment became effective for the member\'s risk score calculation period. Distinct from the hcc_mapping effective_date (which governs the mapping rule) and the score effective_timestamp (which governs the overall score).']
  hcc_codes varchar [note: 'Comma-separated HCC codes contributing to score. [Moved from member_risk_score: This denormalized comma-separated STRING column is the flattened representation of the M:N relationship being replaced by this association table. Once risk_score_hcc_assignment is in place, individual HCC codes are accessible via JOIN to hcc_mapping. Retaining hcc_codes creates a data quality risk (divergence between the string and the junction records) and prevents proper RADV audit traceability.]']
  inclusion_reason varchar [note: 'The clinical or administrative basis for including this HCC in the member\'s risk score. Required for RADV audit defense to demonstrate that each HCC assignment is supported by adequate medical record documentation.']
  is_primary_hcc boolean [note: 'Indicates whether this HCC is the dominant condition driver for the member\'s risk score. Used in RADV audit prioritization to identify the highest-impact HCC assignments for clinical documentation review.']

  Note: 'This association product represents the Assignment (Role) between member_risk_score and hcc_mapping. It captures the specific contribution of each Hierarchical Condition Category to an individual member\'s risk adjustment factor score, as required for CMS RADV audit documentation. Each record links one member_risk_score to one hcc_mapping and carries the contribution weight, primacy flag, effective date, and inclusion reason that exist only in the context of this specific member-HCC assignment.. Existence Justification: In Medicare Advantage risk adjustment, a member\'s RAF (Risk Adjustment Factor) score is computed as the sum of contributions from multiple HCC codes — a single member risk score record is built from many HCC mappings, and a single HCC mapping (e.g., HCC 85 - Congestive Heart Failure) contributes to thousands of member risk scores across the plan. CMS requires plans to document and defend each individual HCC-to-member assignment during RADV audits, meaning this relationship is actively created, maintained, and audited as an operational business record. The current denormalized `hcc_codes` STRING column on `member_risk_score` is a known data quality gap that prevents proper audit traceability and must be replaced by a proper junction table.'
}

