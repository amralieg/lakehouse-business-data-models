ind:pbmContractId rdf:type rdf:Property ;
    rdfs:label 'Pbm Contract Id' ;
    rdfs:comment 'Foreign key linking to pharmacy.pbm_contract. Business justification: rx_benefit_config defines pharmacy benefit parameters administered under a PBM contract. pbm_vendor is a denormalized text field violating 3NF. Replacing it with pbm_contract_id enables contract-level' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PbmContract .

