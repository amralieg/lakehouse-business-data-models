    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToAncillary rdf:type rdf:Property ;
    rdfs:label 'Applies To Ancillary' ;
    rdfs:comment 'True if the rule applies to ancillary services (lab, imaging).' ;
