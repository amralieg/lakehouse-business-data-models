ind:authorizedFacilityId rdf:type rdf:Property ;
    rdfs:label 'Authorized Facility Id' ;
    rdfs:comment 'Foreign key linking to provider.facility. Business justification: Each authorized service line specifies the facility where the service is authorized to be performed. Linking to provider.facility enables in-network facility verification, claims adjudication matching' ;
    rdfs:domain ind:AuthServiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current status of the service line within the prior authorization workflow.' ;
    rdfs:domain ind:AuthServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedEndDate rdf:type rdf:Property ;
    rdfs:label 'Authorized End Date' ;
    rdfs:comment 'Expiration date after which the authorization is no longer valid.' ;
    rdfs:domain ind:AuthServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedPrice rdf:type rdf:Property ;
    rdfs:label 'Authorized Price' ;
    rdfs:comment 'Maximum reimbursable amount per unit for the authorized service.' ;
    rdfs:domain ind:AuthServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedQuantity rdf:type rdf:Property ;
    rdfs:label 'Authorized Quantity' ;
    rdfs:comment 'Number of units of the service or product approved for the member.' ;
    rdfs:domain ind:AuthServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedStartDate rdf:type rdf:Property ;
    rdfs:label 'Authorized Start Date' ;
    rdfs:comment 'Effective date when the authorized service may begin.' ;
    rdfs:domain ind:AuthServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cptCode rdf:type rdf:Property ;
    rdfs:label 'Cpt Code' ;
    rdfs:comment 'Standard CPT code representing the clinical service or procedure authorized.' ;
    rdfs:domain ind:AuthServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisIcdCode rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Icd Code' ;
    rdfs:comment 'ICD code linking the authorized service to the clinical diagnosis supporting medical necessity.' ;
    rdfs:domain ind:AuthServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcpcsCode rdf:type rdf:Property ;
    rdfs:label 'Hcpcs Code' ;
    rdfs:comment 'HCPCS code (Level II) for services, supplies, or drugs not covered by CPT.' ;
    rdfs:domain ind:AuthServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExperimental rdf:type rdf:Property ;
    rdfs:label 'Is Experimental' ;
    rdfs:comment 'True if the service is considered experimental or investigational.' ;
    rdfs:domain ind:AuthServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialApproval rdf:type rdf:Property ;
    rdfs:label 'Is Partial Approval' ;
    rdfs:comment 'Indicates whether only a portion of the requested service quantity was approved.' ;
    rdfs:domain ind:AuthServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placeOfService rdf:type rdf:Property ;
    rdfs:label 'Place Of Service' ;
    rdfs:comment 'Location type where the service is to be rendered.' ;
    rdfs:domain ind:AuthServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Submitted Timestamp' ;
    rdfs:comment 'Date-time when the prior authorization request containing this line was submitted.' ;
    rdfs:domain ind:AuthServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'Broad classification of the authorized service (e.g., inpatient, outpatient, DME, pharmacy).' ;
    rdfs:domain ind:AuthServiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concurrentReviewId rdf:type rdf:Property ;
    rdfs:label 'Concurrent Review Id' ;
    rdfs:comment 'System-generated unique identifier for the concurrent review record.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDischargeDate rdf:type rdf:Property ;
    rdfs:label 'Actual Discharge Date' ;
    rdfs:comment 'Date the member actually left the hospital.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedLengthOfStay rdf:type rdf:Property ;
    rdfs:label 'Approved Length Of Stay' ;
    rdfs:comment 'Maximum number of days approved for continued stay based on the review.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedPostAcuteService rdf:type rdf:Property ;
    rdfs:label 'Authorized Post Acute Service' ;
    rdfs:comment 'Post-acute care service(s) approved during the review (e.g., physical therapy, home health).' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkSource rdf:type rdf:Property ;
    rdfs:label 'Benchmark Source' ;
    rdfs:comment 'Source of the LOS benchmark values.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkSourceDetail rdf:type rdf:Property ;
    rdfs:label 'Benchmark Source Detail' ;
    rdfs:comment 'Free-text description of the benchmark source (e.g., specific CMS report or Milliman model).' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalReviewerNpi rdf:type rdf:Property ;
    rdfs:label 'Clinical Reviewer Npi' ;
    rdfs:comment 'NPI of the clinician performing the review.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concurrentReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Concurrent Review Status' ;
    rdfs:comment 'Current state of the review workflow.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteriaVersion rdf:type rdf:Property ;
    rdfs:label 'Criteria Version' ;
    rdfs:comment 'Version of InterQual or MCG criteria applied.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentLengthOfStay rdf:type rdf:Property ;
    rdfs:label 'Current Length Of Stay' ;
    rdfs:comment 'Number of days the member has been hospitalized to date.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dischargeBarriers rdf:type rdf:Property ;
    rdfs:label 'Discharge Barriers' ;
    rdfs:comment 'Identified obstacles preventing timely discharge (e.g., equipment, placement).' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeDestination rdf:type rdf:Property ;
    rdfs:label 'Discharge Destination' ;
    rdfs:comment 'Intended location after hospital discharge.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCritical rdf:type rdf:Property ;
    rdfs:label 'Is Critical' ;
    rdfs:comment 'True if the review is flagged as critical due to high acuity or risk.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Narrative explanation for why continued stay is medically necessary.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:losBenchmarkMean rdf:type rdf:Property ;
    rdfs:label 'Los Benchmark Mean' ;
    rdfs:comment 'Average LOS for the DRG or service line used as a benchmark.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:losBenchmarkOutlierThreshold rdf:type rdf:Property ;
    rdfs:label 'Los Benchmark Outlier Threshold' ;
    rdfs:comment 'Threshold beyond which the stay is considered an outlier.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:losBenchmarkTarget rdf:type rdf:Property ;
    rdfs:label 'Los Benchmark Target' ;
    rdfs:comment 'Plan-specific target LOS for the case.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDischargeDate rdf:type rdf:Property ;
    rdfs:label 'Planned Discharge Date' ;
    rdfs:comment 'Projected date for member discharge as determined by the reviewer.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:readmissionRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Readmission Risk Category' ;
    rdfs:comment 'Risk tier derived from the readmission risk score.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readmissionRiskScore rdf:type rdf:Property ;
    rdfs:label 'Readmission Risk Score' ;
    rdfs:comment 'Predictive score indicating likelihood of readmission within 30 days.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review End Timestamp' ;
    rdfs:comment 'Date-time when the review was completed or closed.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Additional free-text comments entered by the reviewer.' ;
