ind:feeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Id' ;
    rdfs:comment 'Foreign key linking to contract.fee_schedule. Business justification: Pharmacy benefit configurations govern drug coverage; pharmacy fee schedules (AWP-based, MAC pricing) define allowed amounts for drug claims. Pharmacy claims adjudication requires linking rx_benefit_c' ;
    rdfs:domain ind:HealthInsurance ;
