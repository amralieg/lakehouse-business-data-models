    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobOrder rdf:type rdf:Property ;
    rdfs:label 'Cob Order' ;
    rdfs:comment 'Sequencing of the carrier in the coordination of benefits hierarchy.' ;
    rdfs:domain ind:CobRecord ;
