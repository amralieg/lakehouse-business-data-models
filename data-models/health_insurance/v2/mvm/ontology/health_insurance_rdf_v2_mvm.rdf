ind:medicalPolicyId rdf:type rdf:Property ;
    rdfs:label 'Medical Policy Id' ;
    rdfs:comment 'Foreign key linking to utilization.medical_policy. Business justification: Procedure codes are adjudicated against medical policies for coverage determination. Direct FK from procedure to medical_policy enables policy-based procedure audits, experimental/investigational cove' ;
    rdfs:domain ind:HealthInsurance ;
