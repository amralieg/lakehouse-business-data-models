ind:appealCaseId rdf:type rdf:Property ;
    rdfs:label 'Appeal Case Id' ;
    rdfs:comment 'Foreign key linking to appeal.case. Business justification: When a claim denial creates or perpetuates a HEDIS care gap, the gap record must reference the active appeal case. Care gap managers track which open gaps are under appeal to avoid duplicate outreach ' ;
    rdfs:domain ind:Gap ;
