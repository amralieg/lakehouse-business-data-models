    rdfs:comment 'Reason for participation status change' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationReasonCode rdf:type rdf:Property ;
