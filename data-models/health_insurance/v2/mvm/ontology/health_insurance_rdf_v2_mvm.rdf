    rdfs:comment 'Employer or group identifier shown on the card.' ;
    rdfs:domain ind:IdCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:idCardStatus rdf:type rdf:Property ;
