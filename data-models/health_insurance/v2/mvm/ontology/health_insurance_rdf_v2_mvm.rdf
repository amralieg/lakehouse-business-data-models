    rdfs:comment 'OON benefit type' ;
    rdfs:domain ind:NetworkConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfNetworkCoinsurancePct rdf:type rdf:Property ;
    rdfs:label 'Out Of Network Coinsurance Pct' ;
