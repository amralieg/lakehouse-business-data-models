ind:isCriticalCare rdf:type rdf:Property ;
    rdfs:label 'Is Critical Care' ;
    rdfs:comment 'Indicates whether the admission involved critical care services.' ;
    rdfs:domain ind:InpatientAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReadmission rdf:type rdf:Property ;
    rdfs:label 'Is Readmission' ;
    rdfs:comment 'True if the admission is a readmission within the defined look-back period.' ;
    rdfs:domain ind:InpatientAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:losBenchmarkMetFlag rdf:type rdf:Property ;
    rdfs:label 'Los Benchmark Met Flag' ;
    rdfs:comment 'Indicates whether actual LOS met the benchmark target.' ;
    rdfs:domain ind:InpatientAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:losTargetDays rdf:type rdf:Property ;
    rdfs:label 'Los Target Days' ;
    rdfs:comment 'Benchmark target days for LOS based on plan and diagnosis.' ;
    rdfs:domain ind:InpatientAdmission ;
