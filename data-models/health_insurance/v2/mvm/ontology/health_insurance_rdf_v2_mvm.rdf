ind:accumulatorUnit rdf:type rdf:Property ;
    rdfs:label 'Accumulator Unit' ;
    rdfs:comment 'Unit of measure for the accumulator threshold.' ;
    rdfs:domain ind:CostShareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:afterDeductible rdf:type rdf:Property ;
    rdfs:label 'After Deductible' ;
    rdfs:comment 'True if the cost-share applies after the deductible is satisfied.' ;
