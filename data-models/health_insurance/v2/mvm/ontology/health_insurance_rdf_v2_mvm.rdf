    rdfs:comment 'Reference to the health plan product.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthPlan .

ind:primaryCareCoordinatorId rdf:type rdf:Property ;
    rdfs:label 'Primary Care Coordinator Id' ;
    rdfs:comment 'Foreign key linking to care.care_coordinator. Business justification: Primary Care Coordinator Assignment: case-management reports need each subscriber linked to their assigned care coordinator.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Coordinator .

ind:primaryProviderId rdf:type rdf:Property ;
    rdfs:label 'Primary Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.provider_provider. Business justification: REQUIRED: Primary Care Provider assignment for each subscriber is needed for care coordination, network adequacy reporting, and member portal display.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:annualIncome rdf:type rdf:Property ;
    rdfs:label 'Annual Income' ;
    rdfs:comment 'Subscriber\'s reported annual income (for subsidy eligibility).' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chipNumber rdf:type rdf:Property ;
