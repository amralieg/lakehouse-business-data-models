    rdfs:range xsd:string .

ind:dependentId rdf:type rdf:Property ;
    rdfs:label 'Dependent Id' ;
    rdfs:comment 'Primary key for dependent' ;
    rdfs:domain ind:Dependent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Foreign key linking to member.member_address. Business justification: The dependent table currently embeds raw address fields (address_line1, address_line2, city, state, postal_code, country) inline, duplicating the address management capability already provided by the ' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Foreign key linking to member.member_contact. Business justification: The dependent table embeds contact fields (email_address, phone_number) inline, duplicating the contact management capability provided by the member_contact product. member_contact is the authoritativ' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:identityId rdf:type rdf:Property ;
    rdfs:label 'Identity Id' ;
    rdfs:comment 'Foreign key linking to member.identity. Business justification: The identity table is the authoritative identity resolution record for ALL insured individuals — both subscribers AND dependents. The identity table contains fields like relationship_to_subscriber and' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Identity .

ind:ageOutEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Age Out Eligibility Flag' ;
    rdfs:comment 'True if the dependent is eligible for age-out coverage under plan rules.' ;
    rdfs:domain ind:Dependent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chipEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Chip Eligibility Flag' ;
    rdfs:comment 'Indicates eligibility for the Children\'s Health Insurance Program.' ;
    rdfs:domain ind:Dependent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageEndDate rdf:type rdf:Property ;
    rdfs:label 'Coverage End Date' ;
    rdfs:comment 'Date when dependent\'s coverage terminated or is scheduled to end.' ;
