ind:oopMaxAmount rdf:type rdf:Property ;
    rdfs:label 'Oop Max Amount' ;
    rdfs:comment 'Maximum out-of-pocket expense a member can incur in a benefit year.' ;
    rdfs:domain ind:Benefit ;
    rdf:type owl:DatatypeProperty ;
