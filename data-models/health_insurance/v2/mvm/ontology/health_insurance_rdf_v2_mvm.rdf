    rdfs:range xsd:string .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Human-readable unique code assigned to the review for tracking and communication.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Start Timestamp' ;
    rdfs:comment 'Date-time when the concurrent review was initiated.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Specifies whether the review is concurrent (ongoing) or retrospective.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialWorkInvolved rdf:type rdf:Property ;
    rdfs:label 'Social Work Involved' ;
    rdfs:comment 'Indicates whether a social worker was consulted for discharge planning.' ;
    rdfs:domain ind:ConcurrentReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentEventId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Event Id' ;
    rdfs:comment 'Foreign key linking to enrollment.event. Business justification: Enrollment events such as terminations, plan changes, or COBRA elections directly trigger UM case status changes — active cases must be resolved or transferred when coverage ends. Compliance reporting' ;
    rdfs:domain ind:UmCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Event .

ind:memberRiskTierId rdf:type rdf:Property ;
    rdfs:label 'Member Risk Tier Id' ;
    rdfs:comment 'Foreign key linking to care.member_risk_tier. Business justification: UM case prioritization, assignment, and intensity of management are driven by the member\'s risk tier. Case managers use risk tier to determine intervention level. Population health reports on case man' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberRiskTier .

ind:assignedNurseName rdf:type rdf:Property ;
    rdfs:label 'Assigned Nurse Name' ;
    rdfs:comment 'Full name of the UM nurse or case manager handling the case.' ;
    rdfs:domain ind:UmCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseCloseDate rdf:type rdf:Property ;
    rdfs:label 'Case Close Date' ;
    rdfs:comment 'Date the UM case was closed or completed; null if still open.' ;
    rdfs:domain ind:UmCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseComplexityScore rdf:type rdf:Property ;
    rdfs:label 'Case Complexity Score' ;
    rdfs:domain ind:UmCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Business-visible case number used for tracking and communication.' ;
    rdfs:domain ind:UmCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseOpenDate rdf:type rdf:Property ;
    rdfs:label 'Case Open Date' ;
    rdfs:comment 'Date the UM case was opened and became active.' ;
    rdfs:domain ind:UmCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:casePriority rdf:type rdf:Property ;
    rdfs:label 'Case Priority' ;
    rdfs:comment 'Priority level assigned to the case for workload management.' ;
    rdfs:domain ind:UmCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseSeverity rdf:type rdf:Property ;
    rdfs:label 'Case Severity' ;
    rdfs:comment 'Severity rating reflecting clinical urgency and complexity.' ;
    rdfs:domain ind:UmCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the UM case.' ;
    rdfs:domain ind:UmCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Category of the case based on care setting or service type.' ;
