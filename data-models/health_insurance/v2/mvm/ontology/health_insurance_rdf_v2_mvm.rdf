ind:participationType rdf:type rdf:Property ;
    rdfs:label 'Participation Type' ;
    rdfs:comment 'Type of participation (par/non-par).' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Provider quality score' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementRate rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Rate' ;
    rdfs:comment 'Negotiated reimbursement rate.' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:telehealthAvailable rdf:type rdf:Property ;
    rdfs:label 'Telehealth Available' ;
    rdfs:comment 'Whether telehealth services are available' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierAssignment rdf:type rdf:Property ;
    rdfs:label 'Tier Assignment' ;
    rdfs:comment 'Added business attribute tier_assignment' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierLevel rdf:type rdf:Property ;
    rdfs:label 'Tier Level' ;
    rdfs:comment 'The tier level for this record.' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeDistanceCompliant rdf:type rdf:Property ;
    rdfs:label 'Time Distance Compliant' ;
    rdfs:comment 'Indicates compliance with time/distance standards' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vbcParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Vbc Participation Flag' ;
    rdfs:comment 'Whether provider participates in value-based care' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Wait Time Days' ;
    rdfs:comment 'Average wait time for appointments in days' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weekendHoursFlag rdf:type rdf:Property ;
    rdfs:label 'Weekend Hours Flag' ;
    rdfs:comment 'Indicates if provider offers weekend hours' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headerId rdf:type rdf:Property ;
    rdfs:label 'Header Id' ;
    rdfs:comment 'Primary key for header' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:careEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Care Enrollment Id' ;
    rdfs:comment 'Foreign key linking to care.care_enrollment. Business justification: Supports enrollment-specific claim tracking required by regulatory reporting (e.g., CMS program-level cost reporting) linking claim to the exact enrollment record.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CareEnrollment .

ind:episodeOfCareId rdf:type rdf:Property ;
    rdfs:label 'Episode Of Care Id' ;
    rdfs:comment 'Foreign key linking to utilization.episode_of_care. Business justification: Claims are assigned to episodes of care for bundled payment programs, value-based care contracts, and population health cost rollups. Direct FK from claim header to episode_of_care enables episode-lev' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpisodeOfCare .

ind:paDecisionId rdf:type rdf:Property ;
    rdfs:label 'Pa Decision Id' ;
    rdfs:comment 'Foreign key linking to utilization.pa_decision. Business justification: Outpatient claims adjudicate against the PA decision record (authorized dates, quantity, service codes) without necessarily having a UM case. Direct FK from claim header to pa_decision enables authori' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaDecision .

ind:paRequestId rdf:type rdf:Property ;
    rdfs:label 'Pa Request Id' ;
    rdfs:comment 'Foreign key linking to utilization.pa_request. Business justification: Claims must be validated against the originating PA request during adjudication — a core regulatory and operational requirement. utilization.header.prior_authorization_number is a denormalized text field; r' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaRequest .

ind:providerPartyId rdf:type rdf:Property ;
    rdfs:label 'Provider Party Id' ;
    rdfs:comment 'Foreign key linking to contract.party. Business justification: Needed to associate each claim with the contracting party (provider organization) for regulatory reporting and payment reconciliation.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:radvAuditId rdf:type rdf:Property ;
    rdfs:label 'Radv Audit Id' ;
    rdfs:comment 'Foreign key linking to risk.radv_audit. Business justification: CMS RADV audits sample specific claims to validate HCC-supporting medical records. Auditors and compliance teams must identify exactly which claim headers were sampled in a given RADV audit for medica' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RadvAudit .

ind:renderingProviderId rdf:type rdf:Property ;
    rdfs:label 'Rendering Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.provider. Business justification: Provider-level claim analytics (HEDIS, network adequacy reporting, credentialing status at time of service) require linking claim headers to the rendering provider entity. billing_provider_npi is a se' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:renderingProviderPracticeLocationId rdf:type rdf:Property ;
    rdfs:label 'Rendering Provider Practice Location Id' ;
    rdfs:comment 'FK to provider.provider.provider_id — Every claim must resolve to a rendering provider for network status determination, fee schedule lookup, and provider payment. This is the second most critical operational join in health insurance.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeLocation .

ind:renderingSpecialtyId rdf:type rdf:Property ;
    rdfs:label 'Rendering Specialty Id' ;
    rdfs:comment 'Foreign key linking to provider.specialty. Business justification: HEDIS specialty reporting, network adequacy analysis by specialty, and specialty-specific medical policy application require linking claim headers to the rendering provider\'s specialty. Role-prefixed ' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specialty .

ind:adjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Flag' ;
    rdfs:comment 'Indicates if the claim includes any adjustments.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:admissionDate rdf:type rdf:Property ;
    rdfs:label 'Admission Date' ;
    rdfs:comment 'Date of patient admission for inpatient claims.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allowedAmount rdf:type rdf:Property ;
    rdfs:label 'Allowed Amount' ;
    rdfs:comment 'Maximum amount the insurer permits for the services.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billedAmount rdf:type rdf:Property ;
    rdfs:label 'Billed Amount' ;
    rdfs:comment 'Total amount billed to the insurer before adjustments.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingProviderNpi rdf:type rdf:Property ;
