    rdfs:comment 'Date after which the card is no longer valid.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalSystemCode rdf:type rdf:Property ;
    rdfs:label 'External System Code' ;
    rdfs:comment 'Identifier of the card record in the source operational system (e.g., Facets).' ;
    rdfs:domain ind:IdCard ;
    rdf:type owl:DatatypeProperty ;
