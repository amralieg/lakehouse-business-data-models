    rdfs:comment 'The par status reason for this record.' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Participation Agreement Date' ;
    rdfs:comment 'Date participation agreement was signed' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Participation Effective Date' ;
    rdfs:comment 'Date when provider participation in network becomes effective' ;
