ind:outOfPocketMaxIndividual rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Max Individual' ;
    rdfs:comment 'Maximum amount an individual pays in a year before the plan pays 100% of covered services.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planAcaCompliant rdf:type rdf:Property ;
    rdfs:label 'Plan Aca Compliant' ;
