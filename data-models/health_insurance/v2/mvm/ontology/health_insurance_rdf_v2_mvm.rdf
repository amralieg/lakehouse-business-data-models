    rdfs:domain ind:NetworkConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adequacyStandardId rdf:type rdf:Property ;
    rdfs:label 'Adequacy Standard Id' ;
    rdfs:comment 'Foreign key linking to network.adequacy_standard. Business justification: Network configurations are governed by specific regulatory adequacy standards (e.g., CMS time-distance standards). This FK enables automated regulatory filing, network adequacy compliance reporting, a' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdequacyStandard .

ind:accessType rdf:type rdf:Property ;
    rdfs:label 'Access Type' ;
    rdfs:comment 'Access model of the plan for this network (e.g., HMO closed, PPO open).' ;
    rdfs:domain ind:NetworkConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAdequacyMeasure rdf:type rdf:Property ;
    rdfs:label 'Network Adequacy Measure' ;
    rdfs:comment 'Metric or description used to assess network adequacy (e.g., provider-to-member ratio).' ;
    rdfs:domain ind:NetworkConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkConfigStatus rdf:type rdf:Property ;
    rdfs:label 'Network Config Status' ;
    rdfs:comment 'Current lifecycle status of the configuration record.' ;
    rdfs:domain ind:NetworkConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkContractNumber rdf:type rdf:Property ;
    rdfs:label 'Network Contract Number' ;
    rdfs:comment 'Identifier of the contractual agreement governing the provider network.' ;
    rdfs:domain ind:NetworkConfig ;
