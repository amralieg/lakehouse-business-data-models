ind:costShareRuleId rdf:type rdf:Property ;
    rdfs:label 'Cost Share Rule Id' ;
    rdfs:comment 'System-generated unique identifier for the cost share rule.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostShareRule .

ind:accumulatorThreshold rdf:type rdf:Property ;
    rdfs:label 'Accumulator Threshold' ;
    rdfs:comment 'Threshold amount that triggers a change in cost-share (e.g., after $1,000 of spend).' ;
