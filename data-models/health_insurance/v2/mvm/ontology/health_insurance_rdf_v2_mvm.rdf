ind:appliesToServiceCategory rdf:type rdf:Property ;
    rdfs:label 'Applies To Service Category' ;
    rdfs:comment 'Service categories to which the rule applies.' ;
    rdfs:domain ind:CostShareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coinsuranceRate rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Rate' ;
    rdfs:comment 'Percentage of allowed amount the member pays after deductible (in-network).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
