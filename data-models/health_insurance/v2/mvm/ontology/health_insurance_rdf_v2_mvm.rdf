    rdfs:range ind:Dependent .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Foreign key linking to member.member_address. Business justification: dependent has inline address fields (address_line1, address_line2, city, state, postal_code, country) that duplicate the authoritative member_address table. Adding member_address_id FK normalizes depe' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Foreign key linking to member.member_contact. Business justification: dependent has inline phone_number and email_address fields that duplicate the authoritative member_contact table. Adding member_contact_id FK normalizes dependent contact data to the single source of ' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:pcpProviderId rdf:type rdf:Property ;
    rdfs:label 'Pcp Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.provider. Business justification: Dependents have independent PCP assignments separate from the subscriber in health insurance operations. Care coordination, HEDIS reporting, and PCP panel management all require knowing each dependent' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:policyId rdf:type rdf:Property ;
    rdfs:label 'Policy Id' ;
    rdfs:comment 'Foreign key linking to member.policy. Business justification: A dependent is covered under a specific policy. While policy already FKs to subscriber, the dependent\'s coverage is under a specific policy instance (which may differ from the subscriber\'s primary pol' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:ageOutEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Age Out Eligibility Flag' ;
    rdfs:comment 'True if the dependent is eligible for age-out coverage under plan rules.' ;
    rdfs:domain ind:Dependent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

