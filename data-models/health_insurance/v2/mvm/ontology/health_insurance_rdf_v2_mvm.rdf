    rdfs:comment 'FHIR Claim.patient mapping' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fhirProvider rdf:type rdf:Property ;
