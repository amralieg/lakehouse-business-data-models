ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business code used to reference the rule in downstream systems.' ;
    rdfs:domain ind:CostShareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name of the cost-share rule.' ;
    rdfs:domain ind:CostShareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Category of cost-share rule (e.g., deductible, copay, coinsurance).' ;
