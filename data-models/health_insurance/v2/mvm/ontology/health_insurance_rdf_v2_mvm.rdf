    rdfs:domain ind:Dependent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date when the dependent relationship ended, if applicable.' ;
    rdfs:domain ind:Dependent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date when the dependent relationship became effective.' ;
    rdfs:domain ind:Dependent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
