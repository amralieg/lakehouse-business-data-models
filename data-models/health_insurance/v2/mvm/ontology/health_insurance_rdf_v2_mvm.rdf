ind:costShareCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Share Category' ;
    rdfs:comment 'Logical grouping of the rule relative to deductible and out-of-pocket phases.' ;
    rdfs:domain ind:CostShareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costShareRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Share Rule Status' ;
    rdfs:comment 'Current lifecycle status of the rule.' ;
    rdfs:domain ind:CostShareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAggregateFlag rdf:type rdf:Property ;
    rdfs:label 'Deductible Aggregate Flag' ;
    rdfs:comment 'True if the deductible aggregates across multiple services or members.' ;
    rdfs:domain ind:CostShareRule ;
    rdf:type owl:DatatypeProperty ;
