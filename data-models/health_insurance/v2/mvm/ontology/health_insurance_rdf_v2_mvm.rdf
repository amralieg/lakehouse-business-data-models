    rdfs:label 'Enrollment Open Enrollment Period Id' ;
    rdfs:comment 'Foreign key linking to enrollment.open_enrollment_period. Business justification: Each enrollment transaction occurs within a defined open enrollment period; linking transaction to period enables period-based reporting and ensures the period is not a silo.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OpenEnrollmentPeriod .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Foreign key linking to care.care_plan. Business justification: Each enrollment transaction can generate a Care Plan; linking enables cost, outcome, and compliance reporting per transaction.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarePlan .

ind:qualifyingLifeEventId rdf:type rdf:Property ;
    rdfs:label 'Qualifying Life Event Id' ;
    rdfs:comment 'Foreign key linking to enrollment.qualifying_life_event. Business justification: An enrollment transaction can be triggered by a qualifying life event (QLE) that opens a special enrollment period (SEP). Linking transaction.qualifying_life_event_id -> qualifying_life_event provides' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualifyingLifeEvent .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Monetary adjustment (e.g., discount, surcharge) applied to the gross premium.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Standard code describing why a financial or coverage adjustment was made.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or role of the individual or system that approved the enrollment change.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditUserRole rdf:type rdf:Property ;
    rdfs:label 'Audit User Role' ;
    rdfs:comment 'Role of the audit user (e.g., admin, operator, system).' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsReprocessFlag rdf:type rdf:Property ;
    rdfs:label 'Claims Reprocess Flag' ;
    rdfs:comment 'True if the enrollment change requires downstream claims to be re-processed.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of the transaction with applicable regulations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveragePeriodType rdf:type rdf:Property ;
    rdfs:label 'Coverage Period Type' ;
    rdfs:comment 'Indicates whether the coverage is continuous, intermittent, or contains a gap.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentComment rdf:type rdf:Property ;
    rdfs:label 'Enrollment Comment' ;
    rdfs:comment 'Free-form text field for notes or comments entered by the processor.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentOrigin rdf:type rdf:Property ;
    rdfs:label 'Enrollment Origin' ;
    rdfs:comment 'Channel through which the enrollment was initiated.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Transaction Number' ;
    rdfs:comment 'External business identifier assigned to the enrollment transaction, used for tracking and reference.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Type' ;
    rdfs:comment 'Category of enrollment event: open enrollment, special enrollment period, automatic enrollment, special manual enrollment, or other.' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Error code associated with the transaction' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorDescription rdf:type rdf:Property ;
    rdfs:label 'Error Description' ;
    rdfs:comment 'Description of any error that occurred during the transaction processing' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Exact date-time when the enrollment event occurred in the source system.' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeCode rdf:type rdf:Property ;
    rdfs:label 'Exchange Code' ;
    rdfs:comment 'Identifier of the marketplace exchange where the member enrolled.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Original filename of the inbound 834 transaction as received from the EDI gateway.' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Flag' ;
    rdfs:comment 'True when the enrollment change has a direct impact on premium billing or financial reporting.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gracePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Grace Period End Date' ;
    rdfs:comment 'Date when the applicable grace period expires.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total premium amount before any adjustments for the enrollment period.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthPlanType rdf:type rdf:Property ;
    rdfs:label 'Health Plan Type' ;
    rdfs:comment 'Classification of the health plan (e.g., HMO, PPO, EPO, POS, HDHP).' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hiosCode rdf:type rdf:Property ;
    rdfs:label 'Hios Code' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGracePeriod rdf:type rdf:Property ;
    rdfs:label 'Is Grace Period' ;
    rdfs:comment 'True if the enrollment is being processed within a grace period after termination.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:masterEntityCode rdf:type rdf:Property ;
    rdfs:label 'Master Entity Code' ;
    rdfs:comment 'Cross-domain master/golden entity key for SSOT resolution.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Final premium amount after adjustments, representing the amount to be billed.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalTerminationReference rdf:type rdf:Property ;
    rdfs:label 'Original Termination Reference' ;
    rdfs:comment 'Reference to the prior termination transaction that is being reinstated.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorAuthorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Required' ;
    rdfs:comment 'Indicates whether the enrollment change triggers a prior authorization requirement.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current processing stage of the transaction within the enrollment workflow.' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactivationDate rdf:type rdf:Property ;
    rdfs:label 'Reactivation Date' ;
    rdfs:comment 'Effective date of coverage reactivation for reinstatement events.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether this transaction must be reported to a regulatory body (e.g., CMS, NAIC).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retroactiveAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Retroactive Adjustment Flag' ;
    rdfs:comment 'Flag indicating whether the transaction represents a retroactive adjustment to prior coverage dates.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the enrollment transaction.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventId rdf:type rdf:Property ;
    rdfs:label 'Event Id' ;
    rdfs:comment 'System-generated unique identifier for each enrollment event record.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openEnrollmentPeriodId rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment Period Id' ;
    rdfs:comment 'Foreign key linking to enrollment.open_enrollment_period. Business justification: Enrollment lifecycle events are scoped to an open enrollment period — e.g., OEP opened, OEP closed, enrollment deadline approaching, volume target met events. Linking event.open_enrollment_period_id -' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OpenEnrollmentPeriod .

ind:planElectionId rdf:type rdf:Property ;
    rdfs:label 'Plan Election Id' ;
    rdfs:comment 'Foreign key linking to enrollment.plan_election. Business justification: Enrollment lifecycle events (submitted, pended, approved, terminated) can be directly associated with a specific plan election — e.g., a plan election approval event, a termination event for a specifi' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanElection .

ind:actorType rdf:type rdf:Property ;
    rdfs:label 'Actor Type' ;
    rdfs:comment 'Classifies the party that triggered the event.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Free-text narrative providing additional context for the event.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Categorizes the nature of the state transition (e.g., submitted, approved).' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isManual rdf:type rdf:Property ;
    rdfs:label 'Is Manual' ;
    rdfs:comment 'Indicates whether the event was entered manually (True) or generated automatically (False).' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'Enrollment status after the event was applied.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'Enrollment status before the event was applied.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when the event record was first persisted in the data lake.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the event record.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appealReference rdf:type rdf:Property ;
    rdfs:label 'Appeal Reference' ;
    rdfs:comment 'Reference number of any appeal filed against a denial.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsSepOutcome rdf:type rdf:Property ;
    rdfs:label 'Cms Sep Outcome' ;
    rdfs:comment 'Result of the CMS SEP eligibility determination.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'Explanation why the SEP request was denied, if applicable.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Documentation Received Flag' ;
    rdfs:comment 'Flag indicating whether required documentation has been received for the qualifying life event' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationType rdf:type rdf:Property ;
    rdfs:label 'Documentation Type' ;
    rdfs:comment 'Type of supporting document submitted for the event.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Calendar date on which the qualifying life event occurred.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qleTypeCode rdf:type rdf:Property ;
    rdfs:label 'Qle Type Code' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingLifeEventStatus rdf:type rdf:Property ;
    rdfs:label 'Qualifying Life Event Status' ;
    rdfs:comment 'Overall lifecycle status of the qualifying life event record.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sepCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Sep Category Code' ;
    rdfs:comment 'CMS-defined code that classifies the SEP category for the qualifying life event.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sepWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Sep Window End' ;
    rdfs:comment 'Last date the special enrollment period (SEP) is open for this event.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sepWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Sep Window End Date' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sepWindowStart rdf:type rdf:Property ;
    rdfs:label 'Sep Window Start' ;
    rdfs:comment 'First date the special enrollment period (SEP) is open for this event.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sepWindowStatus rdf:type rdf:Property ;
    rdfs:label 'Sep Window Status' ;
    rdfs:comment 'Current state of the SEP window based on dates and actions.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Verified Flag' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceAreaId rdf:type rdf:Property ;
    rdfs:label 'Service Area Id' ;
    rdfs:comment 'Foreign key linking to plan.plan_service_area. Business justification: Open enrollment periods are geographically scoped to plan service areas. Market-level OEP planning, enrollment capacity management (enrollment_capacity on plan_service_area), and CMS exchange reportin' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceArea .

ind:eligibilitySegment rdf:type rdf:Property ;
    rdfs:label 'Eligibility Segment' ;
    rdfs:comment 'Population segment eligible for this enrollment period (e.g., group, individual, Medicare).' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Last calendar day for submitting enrollment applications; after this date the window closes.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Enrollment Cutoff Time' ;
    rdfs:comment 'Daily cut-off time (in local time) after which submissions on the deadline date are rejected.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:enrollmentDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Deadline Date' ;
    rdfs:comment 'Final calendar date by which all enrollment submissions must be received.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeType rdf:type rdf:Property ;
    rdfs:label 'Exchange Type' ;
    rdfs:comment 'Marketplace or exchange through which the enrollment is offered.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAnnual rdf:type rdf:Property ;
    rdfs:label 'Is Annual' ;
    rdfs:comment 'True if the enrollment period recurs each year on the same schedule.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRetrospectiveAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Retrospective Allowed' ;
    rdfs:comment 'True if members may submit enrollment changes that become effective prior to the submission date.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openEnrollmentPeriodStatus rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment Period Status' ;
    rdfs:comment 'Current lifecycle status of the enrollment window.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodCode rdf:type rdf:Property ;
    rdfs:label 'Period Code' ;
    rdfs:comment 'Short alphanumeric code that uniquely identifies the enrollment window across systems.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Descriptive name of the enrollment window, e.g., "2025 Individual Marketplace OE".' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required' ;
    rdfs:comment 'Indicates whether this enrollment period triggers mandatory regulatory reporting (e.g., CMS filings).' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'First calendar day on which members may submit enrollment applications.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:volumeActual rdf:type rdf:Property ;
    rdfs:label 'Volume Actual' ;
    rdfs:comment 'Actual count of enrollments captured within the window.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTarget rdf:type rdf:Property ;
    rdfs:label 'Volume Target' ;
    rdfs:comment 'Planned number of enrollments the organization aims to achieve during the window.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTargetMet rdf:type rdf:Property ;
    rdfs:label 'Volume Target Met' ;
    rdfs:comment 'Indicates whether the actual enrollment volume met or exceeded the target.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediTransactionId rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Id' ;
    rdfs:comment 'Primary key for edi_transaction' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdiTransaction .

ind:averageRecordSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Average Record Size Bytes' ;
    rdfs:comment 'Average size of each member record within the file, calculated as file_size_bytes divided by member_count.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentActionCode rdf:type rdf:Property ;
    rdfs:label 'Enrollment Action Code' ;
    rdfs:comment 'Standard X12 834 code indicating Add (A), Delete (D), Modify (M), or Correct (C) action.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'File Received Timestamp' ;
    rdfs:comment 'Date-time when the 834 file was first ingested into the lakehouse.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Total size of the inbound 834 file in bytes.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groupControlNumber rdf:type rdf:Property ;
    rdfs:label 'Group Control Number' ;
    rdfs:comment 'Control number identifying the GS functional group for the transaction.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Interchange Control Number' ;
    rdfs:comment 'Control number identifying the ISA interchange envelope for the transaction.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAttemptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Attempt Timestamp' ;
    rdfs:comment 'Timestamp of the most recent processing attempt.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Overall lifecycle state of the transaction from ingestion to final disposition.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Number of individual member enrollment records contained in the 834 file.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingAttempts rdf:type rdf:Property ;
    rdfs:label 'Processing Attempts' ;
    rdfs:comment 'Number of times the transaction has been attempted for processing.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receiverCode rdf:type rdf:Property ;
    rdfs:label 'Receiver Code' ;
    rdfs:comment 'Identifier of the trading partner that receives the 834 file (typically the health insurer).' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Result of matching the transaction to internal enrollment records.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordAuditCreated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Created' ;
    rdfs:comment 'Timestamp when the transaction record was first created in the lakehouse.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordAuditUpdated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Updated' ;
    rdfs:comment 'Timestamp of the most recent update to the transaction record.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionSetControlNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Set Control Number' ;
    rdfs:comment 'Control number that uniquely identifies the 834 transaction set within the interchange.' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Timestamp representing the business event time encoded in the 834 transaction (e.g., effective date of the enrollment action).' ;
    rdfs:domain ind:EdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Indicates whether the 834 file adds new enrollments, changes existing ones, terminates coverage, or corrects prior data.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityVerificationId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verification Id' ;
    rdfs:comment 'Primary key for eligibility_verification' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EligibilityVerification .

ind:benefitId rdf:type rdf:Property ;
    rdfs:label 'Benefit Id' ;
    rdfs:comment 'Foreign key linking to plan.benefit. Business justification: HIPAA 270/271 eligibility transactions are benefit-specific — providers query eligibility for a specific service/benefit category. Linking eligibility_verification to plan.benefit enables precise bene' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Benefit .

ind:eligibilityOriginalEdiTransactionId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Original Edi Transaction Id' ;
    rdfs:comment 'add column transaction_270_id (BIGINT) with FK to enrollment.edi_transaction.edi_transaction_id - 270/271 verification is delivered via EDI' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdiTransaction .

ind:participationStatusId rdf:type rdf:Property ;
    rdfs:label 'Participation Status Id' ;
    rdfs:comment 'Foreign key linking to provider.participation_status. Business justification: Real-time eligibility verification (270/271 EDI) must confirm the provider\'s active participation status in the member\'s plan/network at the time of service. This link directly supports in-network vs.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ParticipationStatus .

ind:primaryEligibilityEdiTransactionId rdf:type rdf:Property ;
    rdfs:label 'Primary Eligibility Edi Transaction Id' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdiTransaction .

ind:providerDirectoryId rdf:type rdf:Property ;
    rdfs:label 'Provider Directory Id' ;
    rdfs:comment 'Foreign key linking to network.provider_directory. Business justification: Real-time eligibility verification (270/271 EDI transactions) confirms a provider\'s in-network status by consulting a specific directory listing. Linking eligibility_verification to the provider_direc' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProviderDirectory .

ind:providerId rdf:type rdf:Property ;
    rdfs:label 'Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.provider_provider. Business justification: Required for automated provider credential checks during eligibility verification; the process matches providers to member eligibility inquiries.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:authorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Number' ;
    rdfs:comment 'Authorization number returned when prior authorization is required.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Authorization Required' ;
    rdfs:comment 'Indicates whether prior authorization is required for the service.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:benefitCategory rdf:type rdf:Property ;
    rdfs:label 'Benefit Category' ;
    rdfs:comment 'High-level category of benefits being queried (e.g., medical, dental).' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitLimit rdf:type rdf:Property ;
    rdfs:label 'Benefit Limit' ;
    rdfs:comment 'Maximum dollar amount allowed for the queried benefit.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitRemaining rdf:type rdf:Property ;
    rdfs:label 'Benefit Remaining' ;
    rdfs:comment 'Remaining dollar amount of the benefit available.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitUsed rdf:type rdf:Property ;
    rdfs:label 'Benefit Used' ;
    rdfs:comment 'Dollar amount of the benefit already utilized in the current period.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductibleRemaining rdf:type rdf:Property ;
    rdfs:label 'Deductible Remaining' ;
    rdfs:comment 'Member\'s remaining deductible balance for the benefit period.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diagnosisCode rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Code' ;
    rdfs:comment 'ICD diagnosis code associated with the request, if applicable.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inquiryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Inquiry Reference Number' ;
    rdfs:comment 'External reference number assigned by the source system (e.g., Availity) for the eligibility request.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inquiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inquiry Timestamp' ;
    rdfs:comment 'Date-time when the eligibility request was sent to the payer.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:memberIdentifierType rdf:type rdf:Property ;
    rdfs:label 'Member Identifier Type' ;
    rdfs:comment 'Type of identifier supplied for the member (SSN, MRN, or internal member ID).' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oopRemaining rdf:type rdf:Property ;
    rdfs:label 'Oop Remaining' ;
    rdfs:comment 'Remaining out-of-pocket amount before maximum OOP is reached.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseMessage rdf:type rdf:Property ;
    rdfs:label 'Response Message' ;
    rdfs:comment 'Free-form message returned by the payer providing additional context.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Response Time Seconds' ;
    rdfs:comment 'Elapsed time between request and response, measured in seconds.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Date-time when the eligibility response was received.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'CPT code of the service/procedure for which eligibility is being checked.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberRiskScoreId rdf:type rdf:Property ;
    rdfs:label 'Member Risk Score Id' ;
    rdfs:comment 'Foreign key linking to risk.member_risk_score. Business justification: CMS risk-adjusted premium reconciliation requires linking each plan election to the member\'s risk score for that payment year. Risk adjustment payment validation (RAPS/EDGE) depends on confirming that' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberRiskScore .

ind:pbmContractId rdf:type rdf:Property ;
    rdfs:label 'Pbm Contract Id' ;
    rdfs:comment 'Foreign key linking to pharmacy.pbm_contract. Business justification: A plan election\'s pharmacy benefits are administered under a specific PBM contract. Claims routing, pharmacy benefit adjudication, PBM performance reporting, and rebate reconciliation all require know' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PbmContract .

ind:pcpProviderAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Pcp Provider Assignment Id' ;
    rdfs:comment 'Foreign key linking to network.provider_assignment. Business justification: HMO and gatekeeper plans require PCP selection at enrollment. The elected PCP is a specific provider_assignment record (provider credentialed and paneled in the network). This drives care coordination' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProviderAssignment .

ind:planAssociationId rdf:type rdf:Property ;
    rdfs:label 'Plan Association Id' ;
    rdfs:comment 'Foreign key linking to network.plan_association. Business justification: Plan elections must reference the specific plan-network association active at election time. This governs network access rules, PCP selection requirements, directory lookups, and adequacy compliance r' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanAssociation .

ind:priorPlanElectionId rdf:type rdf:Property ;
    rdfs:label 'Prior Plan Election Id' ;
    rdfs:comment 'Reference to the previous election record when this election is a change or reinstatement.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanElection .

ind:cobraEligibilityEndDate rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligibility End Date' ;
    rdfs:comment 'Date when COBRA eligibility expires.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'Level of coverage elected (e.g., employee only, employee + spouse, employee + children, family).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dentalRiderFlag rdf:type rdf:Property ;
    rdfs:label 'Dental Rider Flag' ;
    rdfs:comment 'Indicates if a dental coverage rider was elected.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:electionNumber rdf:type rdf:Property ;
    rdfs:label 'Election Number' ;
    rdfs:comment 'External reference number assigned to the election by the enrollment system.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionType rdf:type rdf:Property ;
    rdfs:label 'Election Type' ;
    rdfs:comment 'Nature of the election event (new enrollment, change, termination, reinstatement).' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentEventType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Event Type' ;
    rdfs:comment 'Type of enrollment event that triggered the election.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsaElectionFlag rdf:type rdf:Property ;
    rdfs:label 'Fsa Election Flag' ;
    rdfs:comment 'Indicates if a Flexible Spending Account was elected.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hraElectionFlag rdf:type rdf:Property ;
    rdfs:label 'Hra Election Flag' ;
    rdfs:comment 'Indicates if a Health Reimbursement Arrangement was elected.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hsaElectionFlag rdf:type rdf:Property ;
    rdfs:label 'Hsa Election Flag' ;
    rdfs:comment 'Indicates if a Health Savings Account was elected.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCobraEligible rdf:type rdf:Property ;
    rdfs:label 'Is Cobra Eligible' ;
    rdfs:comment 'Indicates if the election is eligible for COBRA continuation coverage.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planElectionStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Election Status' ;
    rdfs:comment 'Current processing status of the election record.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumContributionEmployee rdf:type rdf:Property ;
    rdfs:label 'Premium Contribution Employee' ;
    rdfs:comment 'Portion of the premium paid by the employee.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumContributionEmployer rdf:type rdf:Property ;
    rdfs:label 'Premium Contribution Employer' ;
    rdfs:comment 'Portion of the premium paid by the employer.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPremium rdf:type rdf:Property ;
    rdfs:label 'Total Premium' ;
    rdfs:comment 'Total premium amount for the elected coverage (employer + employee).' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visionRiderFlag rdf:type rdf:Property ;
    rdfs:label 'Vision Rider Flag' ;
    rdfs:comment 'Indicates if a vision coverage rider was elected.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Id' ;
    rdfs:comment 'Primary key for reconciliation' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:premiumInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Premium Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.premium_invoice. Business justification: Enrollment reconciliation compares membership records against billing invoices to identify financial discrepancies (adds, terms, demographic mismatches). Financial impact reporting and discrepancy res' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PremiumInvoice .

ind:autoResolutionFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Resolution Flag' ;
    rdfs:comment 'Indicates whether the system automatically resolved the discrepancy.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-form notes captured by the analyst about the reconciliation outcome.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyAddCount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Add Count' ;
    rdfs:comment 'Count of enrollment records present in the source but missing in the internal system.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discrepancyChangeCount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Change Count' ;
    rdfs:comment 'Count of enrollment attribute changes (e.g., plan, coverage) that differ between systems.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discrepancyDemographicMismatchCount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Demographic Mismatch Count' ;
    rdfs:comment 'Number of records where member demographic data (name, DOB, SSN) does not match.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discrepancyDetailFilePath rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Detail File Path' ;
    rdfs:comment 'File system or object storage path to the detailed discrepancy report generated by the run.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyTerminationCount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Termination Count' ;
    rdfs:comment 'Count of enrollment records terminated in the source but still active internally.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discrepancyTotalCount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Total Count' ;
    rdfs:comment 'Aggregate number of mismatches identified in the reconciliation run.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financialImpactAdjustment rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Adjustment' ;
    rdfs:comment 'Sum of adjustments (credits, penalties) applied to the gross impact.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactGross rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Gross' ;
    rdfs:comment 'Total gross monetary impact of all unresolved discrepancies before adjustments.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactNet rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Net' ;
    rdfs:comment 'Net monetary impact after adjustments; the amount that may affect premium billing.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manualResolutionFlag rdf:type rdf:Property ;
    rdfs:label 'Manual Resolution Flag' ;
    rdfs:comment 'Indicates whether human intervention is required to resolve the discrepancy.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodEnd rdf:type rdf:Property ;
    rdfs:label 'Period End' ;
    rdfs:comment 'End date of the enrollment coverage period being reconciled.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStart rdf:type rdf:Property ;
    rdfs:label 'Period Start' ;
    rdfs:comment 'Start date of the enrollment coverage period being reconciled.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionDeadline rdf:type rdf:Property ;
    rdfs:label 'Resolution Deadline' ;
    rdfs:comment 'Date by which outstanding discrepancies must be resolved to avoid financial impact.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Sequential number assigned to each reconciliation execution for tracking and audit purposes.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Timestamp' ;
    rdfs:comment 'Date-time when the reconciliation run was initiated.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Indicates whether the run was a full reconciliation or an incremental update.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyFormularyId rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Formulary Id' ;
    rdfs:comment 'Reference to the formulary that defines drug tiering and coverage for the plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Formulary .

ind:benefitDesignVersion rdf:type rdf:Property ;
    rdfs:label 'Benefit Design Version' ;
    rdfs:comment 'Version identifier for the benefit design configuration.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsPlanCode rdf:type rdf:Property ;
    rdfs:label 'Cms Plan Code' ;
    rdfs:comment 'CMS plan identifier used for regulatory reporting.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coinsurancePercentage rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Percentage' ;
    rdfs:comment 'Percentage of allowed amount the member pays after deductible is met.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayPrimaryCare rdf:type rdf:Property ;
    rdfs:label 'Copay Primary Care' ;
    rdfs:comment 'Fixed copayment amount for a primary care office visit.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copaySpecialist rdf:type rdf:Property ;
    rdfs:label 'Copay Specialist' ;
    rdfs:comment 'Fixed copayment amount for a specialist office visit.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductibleFamily rdf:type rdf:Property ;
    rdfs:label 'Deductible Family' ;
    rdfs:comment 'Annual amount a family must pay before cost-sharing begins.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductibleIndividual rdf:type rdf:Property ;
    rdfs:label 'Deductible Individual' ;
    rdfs:comment 'Annual amount an individual member must pay before cost-sharing begins.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment End Date' ;
    rdfs:comment 'Last date members may enroll in the plan for the plan year.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Start Date' ;
    rdfs:comment 'First date members may enroll in the plan for the plan year.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fhirCoveragePlanResourceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Fhir Coverage Plan Resource Identifier' ;
    rdfs:comment 'FHIR resource identifier for interoperability' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hiosPlanCode rdf:type rdf:Property ;
    rdfs:label 'Hios Plan Code' ;
    rdfs:comment 'CMS-assigned HIOS identifier for the plan.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExemptFromMlr rdf:type rdf:Property ;
    rdfs:label 'Is Exempt From Mlr' ;
    rdfs:comment 'Indicates whether the plan is exempt from Medical Loss Ratio reporting requirements.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date the plan design was last reviewed for compliance or pricing updates.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'Target market for the plan: individual, small group, large group, Medicare, or Medicaid.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfPocketMaxFamily rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Max Family' ;
