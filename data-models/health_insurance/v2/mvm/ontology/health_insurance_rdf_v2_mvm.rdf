ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current status of the utilization management review.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentMedicalPolicyId rdf:type rdf:Property ;
    rdfs:label 'Parent Medical Policy Id' ;
    rdfs:comment 'Self-referencing FK on medical_policy (parent_medical_policy_id)' ;
    rdfs:domain ind:MedicalPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicalPolicy .

ind:applicableCptCodes rdf:type rdf:Property ;
    rdfs:label 'Applicable Cpt Codes' ;
    rdfs:comment 'Comma-separated list of CPT procedure codes covered under the policy.' ;
    rdfs:domain ind:MedicalPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableHcpcsCodes rdf:type rdf:Property ;
    rdfs:label 'Applicable Hcpcs Codes' ;
    rdfs:comment 'Comma-separated list of HCPCS codes (including drugs) covered under the policy.' ;
    rdfs:domain ind:MedicalPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalCategory rdf:type rdf:Property ;
    rdfs:label 'Clinical Category' ;
    rdfs:comment 'High-level clinical grouping (e.g., cardiology, orthopedics) to which the policy applies.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalCriteriaSource rdf:type rdf:Property ;
    rdfs:label 'Clinical Criteria Source' ;
    rdfs:comment 'Origin of the clinical criteria used in the policy.' ;
    rdfs:domain ind:MedicalPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageLimitUnits rdf:type rdf:Property ;
    rdfs:label 'Coverage Limit Units' ;
    rdfs:comment 'Unit of measure for the coverage limit (e.g., visits, days).' ;
    rdfs:domain ind:MedicalPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceGradeCode rdf:type rdf:Property ;
    rdfs:label 'Evidence Grade Code' ;
    rdfs:domain ind:MedicalPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergencyCovered rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Covered' ;
    rdfs:comment 'Indicates whether emergency services are covered without prior authorization.' ;
    rdfs:domain ind:MedicalPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExperimentalCovered rdf:type rdf:Property ;
    rdfs:label 'Is Experimental Covered' ;
    rdfs:comment 'True if experimental or investigational services are permitted under the policy.' ;
