ind:attributedProviderId rdf:type rdf:Property ;
    rdfs:label 'Attributed Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.provider. Business justification: HEDIS gap closure workflows require identifying the attributed provider responsible for closing each care gap. Provider outreach campaigns and gap closure reporting are driven by this attribution. Rol' ;
    rdfs:domain ind:Gap ;
