ind:coinsuranceRateOutOfNetwork rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Rate Out Of Network' ;
    rdfs:comment 'Percentage of allowed amount the member pays after deductible (out-of-network).' ;
    rdfs:domain ind:CostShareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayAmountOutOfNetwork rdf:type rdf:Property ;
    rdfs:label 'Copay Amount Out Of Network' ;
    rdfs:comment 'Fixed dollar copay applied to a service when out-of-network.' ;
