    rdfs:range xsd:string .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:domain ind:MemberRiskTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carePlanId rdf:type rdf:Property ;
    rdfs:label 'Care Plan Id' ;
    rdfs:comment 'Unique identifier for the care plan.' ;
    rdfs:domain ind:CarePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planCareMemberSubscriberId rdf:type rdf:Property ;
    rdfs:label 'Plan Care Member Subscriber Id' ;
    rdfs:comment 'FK to the member subscriber.' ;
    rdfs:domain ind:CarePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:planCareSubscriberId rdf:type rdf:Property ;
    rdfs:label 'Plan Care Subscriber Id' ;
    rdfs:comment 'FK to the subscriber.' ;
    rdfs:domain ind:CarePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:primaryProviderAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Provider Assignment Id' ;
    rdfs:comment 'Foreign key linking to network.provider_assignment. Business justification: Care plan execution requires verifying the primary provider\'s current network participation status (panel open/closed, credentialing, tier designation). Role-prefix \'primary_\' used because care_plan a' ;
    rdfs:domain ind:CarePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProviderAssignment .

ind:barriersToCare rdf:type rdf:Property ;
    rdfs:label 'Barriers To Care' ;
    rdfs:comment 'Identified barriers to care for the member.' ;
    rdfs:domain ind:CarePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carePlanStatus rdf:type rdf:Property ;
    rdfs:label 'Care Plan Status' ;
    rdfs:comment 'Current status of the care plan.' ;
    rdfs:domain ind:CarePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Creation Timestamp' ;
    rdfs:comment 'Timestamp when the care plan was created.' ;
    rdfs:domain ind:CarePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:highRiskFlag rdf:type rdf:Property ;
    rdfs:label 'High Risk Flag' ;
    rdfs:comment 'Indicates if the member is high risk.' ;
    rdfs:domain ind:CarePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Business plan number.' ;
    rdfs:domain ind:CarePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Privacy Consent Flag' ;
    rdfs:comment 'Whether privacy consent was obtained.' ;
    rdfs:domain ind:CarePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acoParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Aco Participation Flag' ;
    rdfs:comment 'Indicates whether this network includes participation in ACO arrangements. True if ACO providers are part of the network, False otherwise.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmsNetworkCode rdf:type rdf:Property ;
    rdfs:label 'Cms Network Code' ;
    rdfs:comment 'The unique identifier assigned by CMS for Medicare Advantage and Part D networks. Required for all Medicare networks. Format: one letter followed by five digits.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCount rdf:type rdf:Property ;
    rdfs:label 'Facility Count' ;
    rdfs:comment 'The number of hospitals, skilled nursing facilities, and other institutional providers in this network. Used for facility access adequacy assessments.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicFootprint rdf:type rdf:Property ;
    rdfs:label 'Geographic Footprint' ;
    rdfs:comment 'Comma-separated list of states, counties, or service areas where this network operates. Defines the geographic scope of provider availability and member eligibility.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAdequacyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Adequacy Review Date' ;
    rdfs:comment 'The date of the most recent internal or regulatory network adequacy review. Used to track compliance with annual review requirements.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:memberEnrollmentCount rdf:type rdf:Property ;
    rdfs:label 'Member Enrollment Count' ;
    rdfs:comment 'The current number of members enrolled in plans associated with this network. Used for provider-to-member ratio calculations and capacity planning.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ncqaAccreditationDate rdf:type rdf:Property ;
    rdfs:label 'Ncqa Accreditation Date' ;
    rdfs:comment 'The date when NCQA accreditation was granted or last renewed for this network. Null if not accredited.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ncqaAccreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Ncqa Accreditation Status' ;
    rdfs:comment 'The current NCQA accreditation status for this network. Accredited (full accreditation), Provisional (conditional approval), Denied (failed accreditation), Not Applicable (not seeking accreditation), Pending (under review).' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncqaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Ncqa Expiration Date' ;
    rdfs:comment 'The date when the current NCQA accreditation expires and renewal is required. Null if not accredited.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:networkAdequacyFilingDate rdf:type rdf:Property ;
    rdfs:label 'Network Adequacy Filing Date' ;
    rdfs:comment 'The date when the most recent network adequacy filing was submitted to CMS or state regulators. Required annually for Medicare Advantage and Exchange plans.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:networkAdequacyStatus rdf:type rdf:Property ;
    rdfs:label 'Network Adequacy Status' ;
    rdfs:comment 'Regulatory assessment of whether the network meets time-and-distance and provider-to-member ratio standards. Adequate (meets all standards), Deficient (fails standards), Conditional (approved with corrective action plan), Pending Review (under regulatory evaluation).' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCode rdf:type rdf:Property ;
    rdfs:label 'Network Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the network in operational systems, claims processing, and provider directories. Externally-known business identifier.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkDescription rdf:type rdf:Property ;
    rdfs:label 'Network Description' ;
    rdfs:comment 'Detailed narrative description of the network\'s design, provider composition, geographic coverage, and unique features. Used in member materials and regulatory filings.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkDirectoryUrl rdf:type rdf:Property ;
    rdfs:label 'Network Directory Url' ;
    rdfs:comment 'The web URL where members and providers can access the online provider directory for this network. Required for ACA and Medicare Advantage compliance.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkName rdf:type rdf:Property ;
    rdfs:label 'Network Name' ;
    rdfs:comment 'The official business name of the provider network (e.g., \'HMO Narrow Network\', \'PPO Broad Network\', \'Medicare Advantage Network\'). Human-readable identifier used in member communications and plan documents.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkStatus rdf:type rdf:Property ;
    rdfs:label 'Network Status' ;
    rdfs:comment 'Current operational status of the provider network. Active (accepting enrollments and claims), Inactive (closed to new enrollments), Suspended (temporary hold), Pending (awaiting regulatory approval), Terminated (permanently closed).' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAdequacyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Adequacy Review Date' ;
    rdfs:comment 'The scheduled date for the next network adequacy review. Typically annual for Medicare Advantage and Exchange networks.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pcpCount rdf:type rdf:Property ;
    rdfs:label 'Pcp Count' ;
    rdfs:comment 'The number of primary care physicians in this network. Key metric for network adequacy and member-to-PCP ratio calculations.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pcpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pcp Required Flag' ;
    rdfs:comment 'Indicates whether members enrolled in this network are required to select a primary care physician. True for HMO and POS networks, False for PPO and EPO.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerCount rdf:type rdf:Property ;
    rdfs:label 'Provider Count' ;
    rdfs:comment 'The total number of unique providers (physicians, facilities, ancillary) participating in this network. Used for network adequacy calculations and member communications.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referralRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Referral Required Flag' ;
    rdfs:comment 'Indicates whether specialist visits require a referral from the PCP. True for HMO networks, False for PPO, EPO, and most POS networks.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialistCount rdf:type rdf:Property ;
    rdfs:label 'Specialist Count' ;
    rdfs:comment 'The number of specialist physicians in this network. Used for specialty access adequacy assessments.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:starRating rdf:type rdf:Property ;
    rdfs:label 'Star Rating' ;
    rdfs:comment 'The CMS Star Rating for Medicare Advantage networks, ranging from 1.0 to 5.0 stars. Based on quality measures including network access, member satisfaction, and clinical outcomes. Null for non-Medicare networks.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierClassification rdf:type rdf:Property ;
    rdfs:label 'Tier Classification' ;
    rdfs:comment 'The tiering structure of the network for cost-sharing purposes. Tier 1 (lowest cost-sharing, narrow network), Tier 2 (moderate cost-sharing), Tier 3 (highest cost-sharing, broadest access), Single Tier (no tiering), Tiered (multi-tier structure).' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vbcArrangementFlag rdf:type rdf:Property ;
    rdfs:label 'Vbc Arrangement Flag' ;
    rdfs:comment 'Indicates whether this network includes value-based care arrangements with providers (e.g., shared savings, bundled payments, capitation). True if VBC arrangements exist, False otherwise.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coinsuranceDifferentialPercentage rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Differential Percentage' ;
    rdfs:comment 'Percentage coinsurance differential for this tier. Used when cost_share_differential_type is coinsurance or hybrid. Null if not applicable.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayDifferentialAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Differential Amount' ;
    rdfs:comment 'Fixed dollar copay differential for this tier compared to baseline tier. Used when cost_share_differential_type is copay or hybrid. Null if not applicable.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costShareDifferentialType rdf:type rdf:Property ;
    rdfs:label 'Cost Share Differential Type' ;
    rdfs:comment 'Type of cost-sharing differential applied to this tier (copay, coinsurance, deductible, hybrid, or none). Determines how member out-of-pocket (OOP) costs are calculated.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAppliesFlag rdf:type rdf:Property ;
    rdfs:label 'Deductible Applies Flag' ;
    rdfs:comment 'Indicates whether the plan deductible applies to services rendered by providers in this tier before cost-sharing begins.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayLabel rdf:type rdf:Property ;
    rdfs:label 'Display Label' ;
    rdfs:comment 'Member-facing display label for the tier shown in EOB, member portal, and Summary of Benefits and Coverage (SBC). May differ from internal tier name for clarity.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Facility Type Applicability' ;
    rdfs:comment 'Defines which facility types this tier applies to (all, hospital, Skilled Nursing Facility (SNF), Durable Medical Equipment (DME), lab, imaging, pharmacy, home health, or custom list). Used to segment tier assignment rules by facility type. [ENUM-REF-CANDIDATE: all|hospital|snf|dme|lab|imaging|pharmacy|home_health|custom — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal operational notes or comments about this tier configuration. Not visible to members or external parties.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberSteerageIncentiveDescription rdf:type rdf:Property ;
    rdfs:label 'Member Steerage Incentive Description' ;
    rdfs:comment 'Description of any member steerage incentives or rewards offered for using providers in this tier (e.g., reduced cost-sharing, waived deductible, wellness credits).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAdequacyCreditFlag rdf:type rdf:Property ;
    rdfs:label 'Network Adequacy Credit Flag' ;
    rdfs:comment 'Indicates whether providers in this tier count toward CMS network adequacy standards and state Department of Insurance (DOI) access requirements.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oopMaxAppliesFlag rdf:type rdf:Property ;
    rdfs:label 'Oop Max Applies Flag' ;
    rdfs:comment 'Indicates whether member cost-sharing for this tier counts toward the plan Maximum Out-of-Pocket (MOOP) limit.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorAuthorizationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Required Flag' ;
    rdfs:comment 'Indicates whether services from providers in this tier require Prior Authorization (PA) or Utilization Management (UM) review.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityTierFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Tier Flag' ;
    rdfs:comment 'Indicates whether this tier is designated as a quality tier based on HEDIS, STAR ratings, or other quality performance metrics.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rank rdf:type rdf:Property ;
    rdfs:label 'Rank' ;
    rdfs:comment 'Numeric ranking of the tier indicating preference and cost-share level. Lower rank indicates preferred tier with lower member cost-sharing (e.g., 1=Tier 1 Preferred, 2=Tier 2 Standard, 3=Tier 3 Specialty, 99=Out-of-Network).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryFilingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Reference' ;
    rdfs:comment 'Reference number or identifier for the state Department of Insurance (DOI) or CMS filing that approved this tier structure. Used for compliance audit trails.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sbcDisclosureText rdf:type rdf:Property ;
    rdfs:label 'Sbc Disclosure Text' ;
    rdfs:comment 'Standardized disclosure text for this tier that appears in the Summary of Benefits and Coverage (SBC) document provided to members under ACA requirements.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyApplicability rdf:type rdf:Property ;
    rdfs:label 'Specialty Applicability' ;
    rdfs:comment 'Defines which provider specialties this tier applies to (all, primary care only, specialist only, facility, ancillary, behavioral health, or custom list). Used to segment tier assignment rules by provider type. [ENUM-REF-CANDIDATE: all|primary_care|specialist|facility|ancillary|behavioral_health|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Current lifecycle status of the network tier configuration (active, inactive, pending approval, suspended, or retired).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierType rdf:type rdf:Property ;
    rdfs:label 'Tier Type' ;
    rdfs:comment 'Classification of the tier indicating its strategic purpose within the network design (preferred, standard, specialty, out-of-network, value-based, narrow network).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vbcArrangementEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Vbc Arrangement Eligible Flag' ;
    rdfs:comment 'Indicates whether this tier is eligible for Value-Based Care (VBC) or Accountable Care Organization (ACO) performance incentives and shared savings arrangements.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adequacyCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Adequacy Certification Date' ;
    rdfs:comment 'The date when this plan-network association was certified as meeting network adequacy requirements by the regulatory authority or internal compliance review.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adequacyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Adequacy Review Date' ;
    rdfs:comment 'The date of the most recent network adequacy review or assessment for this plan-network association. Used to track compliance monitoring cycles.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:associationCode rdf:type rdf:Property ;
    rdfs:label 'Association Code' ;
    rdfs:comment 'Business identifier code for this plan-to-network association, used in eligibility verification (270/271 EDI transactions) and claims adjudication routing.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associationName rdf:type rdf:Property ;
    rdfs:label 'Association Name' ;
    rdfs:comment 'Human-readable name for this plan-to-network association, typically combining plan name and network name for operational reference.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associationType rdf:type rdf:Property ;
    rdfs:label 'Association Type' ;
    rdfs:comment 'Classification of the network\'s role for this plan. Primary indicates the main network for member access; supplemental provides additional coverage; specialty covers specific service categories; out-of-area supports members outside primary service area; reciprocal represents shared network arrangements; tertiary provides fallback coverage.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoAssignmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Assignment Eligible Flag' ;
    rdfs:comment 'Indicates whether members can be automatically assigned to providers in this network under this plan. Relevant for Medicaid and some Medicare programs that use auto-assignment for members who do not actively select a provider. True means eligible for auto-assignment; false means member must actively select.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference to the master contract or agreement document that governs this plan-network association. Links to contract management systems for terms, rates, and legal provisions.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directoryPublicationFlag rdf:type rdf:Property ;
    rdfs:label 'Directory Publication Flag' ;
    rdfs:comment 'Indicates whether providers in this network for this plan should be published in member-facing provider directories and online search tools. True means include in directory; false means exclude (e.g., for internal or specialty networks).' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pcpSelectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pcp Selection Required Flag' ;
    rdfs:comment 'Indicates whether members enrolled in this plan with this network must select a primary care provider. Typically true for HMO and POS plans; false for PPO and EPO plans.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planAssociationStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Association Status' ;
    rdfs:comment 'Current lifecycle status of the plan-network association. Active indicates operational; inactive means temporarily disabled; pending awaits regulatory approval or contract execution; suspended indicates temporary hold; terminated means permanently ended.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:starRatingImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Star Rating Impact Flag' ;
    rdfs:comment 'Indicates whether provider performance in this network impacts the plan\'s CMS Star Ratings. Applicable primarily to Medicare Advantage plans. True means network performance affects Star metrics; false means no Star impact.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adequacyStandardStatus rdf:type rdf:Property ;
    rdfs:label 'Adequacy Standard Status' ;
    rdfs:comment 'Current lifecycle status of this adequacy standard: active (currently enforced), inactive (not currently enforced), proposed (pending regulatory approval), superseded (replaced by newer standard), or under-review (being evaluated for changes).' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:afterHoursAvailabilityRequired rdf:type rdf:Property ;
    rdfs:label 'After Hours Availability Required' ;
    rdfs:comment 'Indicates whether after-hours availability (evenings, weekends, holidays) is required for this specialty and geography. True if after-hours access is mandated, false otherwise.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:afterHoursDefinition rdf:type rdf:Property ;
    rdfs:label 'After Hours Definition' ;
    rdfs:comment 'Definition of what constitutes after-hours for this standard (e.g., weekdays after 5pm, weekends, 24/7 access). Null if after-hours availability is not required.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentType rdf:type rdf:Property ;
    rdfs:label 'Appointment Type' ;
    rdfs:comment 'Type of appointment this wait-time standard applies to: routine (non-urgent care), urgent (same-day/next-day need), preventive (wellness visits), behavioral-health (mental health/substance abuse), specialist (referral appointments), or emergency. Null if standard is not appointment-access based.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Reporting Frequency' ;
    rdfs:comment 'How often compliance with this standard must be assessed and reported to regulators: annual, semi-annual, quarterly, monthly, or on-demand (event-triggered).' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exception Criteria' ;
    rdfs:comment 'Conditions under which an exception or waiver to this standard may be granted (e.g., provider shortage area designation, rural exception, temporary hardship). Null if no exceptions allowed.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicClassification rdf:type rdf:Property ;
    rdfs:label 'Geographic Classification' ;
    rdfs:comment 'Geographic area classification for which this standard applies: urban (metropolitan areas), suburban (surrounding metro areas), rural (non-metropolitan), or frontier (very low population density areas). Standards vary by geography.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumDistanceMiles rdf:type rdf:Property ;
    rdfs:label 'Maximum Distance Miles' ;
    rdfs:comment 'Maximum allowable distance in miles from member residence to nearest in-network provider of this specialty in this geographic area. Null if standard is not distance-based.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumTravelTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Maximum Travel Time Minutes' ;
    rdfs:comment 'Maximum allowable travel time in minutes from member residence to nearest in-network provider of this specialty in this geographic area. Null if standard is not time-based.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumWaitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Wait Time Days' ;
    rdfs:comment 'Maximum allowable wait time in days from appointment request to appointment date for this appointment type and specialty. Null if standard is not appointment-access based.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'Description of how compliance with this standard is measured (e.g., GeoAccess analysis, member survey, claims-based appointment tracking, provider attestation). Defines the assessment approach.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumProviderCount rdf:type rdf:Property ;
    rdfs:label 'Minimum Provider Count' ;
    rdfs:comment 'Absolute minimum number of providers of this specialty required in the network for this geography, regardless of member count. Null if not applicable.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyForNonCompliance rdf:type rdf:Property ;
    rdfs:label 'Penalty For Non Compliance' ;
    rdfs:comment 'Description of regulatory penalties or consequences for failing to meet this standard (e.g., corrective action plan, fines, enrollment suspension, Star rating impact). Null if no specific penalty defined.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerToMemberRatio rdf:type rdf:Property ;
    rdfs:label 'Provider To Member Ratio' ;
    rdfs:comment 'Required ratio of providers to members for this specialty and geography, expressed as ratio string (e.g., 1:2000 for PCPs, 1:5000 for specialists). Null if standard is not ratio-based.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySource rdf:type rdf:Property ;
    rdfs:label 'Regulatory Source' ;
    rdfs:comment 'Governing body or regulatory authority that mandates this standard: CMS (Centers for Medicare and Medicaid Services), state-DOI (State Department of Insurance), NCQA (National Committee for Quality Assurance), URAC, ACA (Affordable Care Act), or internal (company-defined standard exceeding regulatory minimums).' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyCategory rdf:type rdf:Property ;
    rdfs:label 'Specialty Category' ;
    rdfs:comment 'Provider specialty or facility type this standard applies to (e.g., PCP, cardiology, behavioral-health, hospital, SNF, DME). May be broad category or specific specialty code.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCategory rdf:type rdf:Property ;
    rdfs:label 'Standard Category' ;
    rdfs:comment 'Classification of the adequacy standard type: time-distance (geographic access), provider-ratio (provider-to-member ratios), appointment-access (wait time standards), after-hours (availability requirements), telehealth-equivalency (virtual care standards), or network-composition (network mix requirements).' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCode rdf:type rdf:Property ;
    rdfs:label 'Standard Code' ;
    rdfs:comment 'Business identifier code for the adequacy standard (e.g., PCP_URBAN_TIME, BH_RURAL_RATIO). Used for external reference and reporting.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardName rdf:type rdf:Property ;
    rdfs:label 'Standard Name' ;
    rdfs:comment 'Human-readable name of the adequacy standard (e.g., Primary Care Physician Urban Time-Distance Standard).' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardVersion rdf:type rdf:Property ;
    rdfs:label 'Standard Version' ;
    rdfs:comment 'Version identifier for this standard, used to track changes over time (e.g., 2024.1, v3.0). Supports historical analysis and regulatory audit trails.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telehealthEquivalencyAllowed rdf:type rdf:Property ;
    rdfs:label 'Telehealth Equivalency Allowed' ;
    rdfs:comment 'Indicates whether telehealth/virtual care providers can be counted toward meeting this adequacy standard. True if telehealth equivalency is permitted, false if only in-person providers count.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:telehealthPercentageCap rdf:type rdf:Property ;
    rdfs:label 'Telehealth Percentage Cap' ;
    rdfs:comment 'Maximum percentage of the adequacy requirement that can be met through telehealth providers (e.g., 25.00 means up to 25% of required providers can be telehealth-only). Null if no cap or telehealth not allowed.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Threshold Percentage' ;
    rdfs:comment 'Percentage of members or geographic area that must meet this standard (e.g., 90.00 means 90% of members must have access within the specified time/distance). Used for compliance measurement.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adequacyAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Adequacy Assessment Id' ;
    rdfs:comment 'Unique identifier for the network adequacy assessment record. Primary key.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdequacyAssessment .

ind:appointmentTypeRequested rdf:type rdf:Property ;
    rdfs:label 'Appointment Type Requested' ;
    rdfs:comment 'Type of appointment requested during mystery shopper or survey assessment: routine care, urgent care, preventive visit, follow-up visit, new patient intake, or specialist referral.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business identifier for the adequacy assessment, used for external reference and regulatory submissions.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Period End Date' ;
    rdfs:comment 'End date of the evaluation period covered by this assessment.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Period Start Date' ;
    rdfs:comment 'Start date of the evaluation period covered by this assessment.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Name of the individual or team responsible for conducting the network adequacy assessment.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorOrganization rdf:type rdf:Property ;
    rdfs:label 'Assessor Organization' ;
    rdfs:comment 'Organization or department that conducted the assessment (e.g., internal network management team, third-party consultant, regulatory auditor).' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOutcome rdf:type rdf:Property ;
    rdfs:label 'Compliance Outcome' ;
    rdfs:comment 'Overall compliance result of the network adequacy assessment: compliant (meets all standards), non-compliant (fails standards), partially-compliant (meets some but not all standards), under-review (pending final determination), or remediation-required (corrective action needed).' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gap Identified Flag' ;
    rdfs:comment 'Indicates whether network gaps or deficiencies were identified during the assessment. True if gaps exist, False otherwise.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gapSeverity rdf:type rdf:Property ;
    rdfs:label 'Gap Severity' ;
    rdfs:comment 'Severity level of identified network gaps: critical (immediate member access risk), high (significant access limitation), moderate (minor access concern), or low (minimal impact).' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goldCardProviderCount rdf:type rdf:Property ;
    rdfs:label 'Gold Card Provider Count' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberToPcpRatio rdf:type rdf:Property ;
    rdfs:label 'Member To Pcp Ratio' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memberToProviderRatio rdf:type rdf:Property ;
    rdfs:label 'Member To Provider Ratio' ;
    rdfs:comment 'Calculated ratio of enrolled members to available providers in the assessed specialty or facility type, expressed as members per provider.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkTypeCode rdf:type rdf:Property ;
    rdfs:label 'Network Type Code' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerCountAvailable rdf:type rdf:Property ;
    rdfs:label 'Provider Count Available' ;
    rdfs:comment 'Number of in-network providers or facilities available in the assessed specialty or facility type within the service area.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:providerCountRequired rdf:type rdf:Property ;
    rdfs:label 'Provider Count Required' ;
    rdfs:comment 'Minimum number of providers or facilities required by regulatory standards to meet network adequacy thresholds for the assessed specialty or facility type.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatorySubmissionType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Type' ;
    rdfs:comment 'Type of regulatory body or framework for which this assessment is being conducted: CMS Medicare, CMS Marketplace, State Department of Insurance (DOI), NCQA accreditation, internal monitoring, or ACA Qualified Health Plan (QHP) certification.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationActionTaken rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Taken' ;
    rdfs:comment 'Description of corrective actions taken to address identified network gaps, such as provider recruitment, contract expansion, telehealth deployment, or member outreach.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which remediation actions must be completed to resolve identified network gaps and achieve compliance.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of remediation efforts: not-started (action plan pending), in-progress (corrective actions underway), completed (actions finished), verified (compliance confirmed), or overdue (past due date).' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date on which the network adequacy assessment was submitted to the regulatory body (CMS, State DOI, NCQA).' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Status of the regulatory submission: draft (not yet submitted), submitted (under review), accepted (approved by regulator), rejected (not approved), or resubmission-required (corrections needed).' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyMethod rdf:type rdf:Property ;
    rdfs:label 'Survey Method' ;
    rdfs:comment 'Methodology used to conduct the assessment: member survey (CAHPS or custom), secret shopper call (mystery shopper study), provider survey (direct provider inquiry), administrative data (claims and enrollment analysis), or geospatial analysis (GIS mapping).' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telehealthOfferedFlag rdf:type rdf:Property ;
    rdfs:label 'Telehealth Offered Flag' ;
    rdfs:comment 'Indicates whether telehealth or virtual care options were offered as an alternative during the assessment. True if telehealth was available, False otherwise.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeDistanceCompliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Time Distance Compliance Percentage' ;
    rdfs:comment 'Percentage of members in the service area who have access to the assessed provider specialty or facility type within the required time and distance standards.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeDistanceCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Time Distance Compliant Flag' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeDistanceStandardMiles rdf:type rdf:Property ;
    rdfs:label 'Time Distance Standard Miles' ;
    rdfs:comment 'Maximum distance in miles that members should travel to access the assessed provider specialty or facility type, as defined by regulatory standards.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeDistanceStandardMinutes rdf:type rdf:Property ;
    rdfs:label 'Time Distance Standard Minutes' ;
    rdfs:comment 'Maximum travel time in minutes that members should travel to access the assessed provider specialty or facility type, as defined by regulatory standards.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitTimeDaysRoutine rdf:type rdf:Property ;
    rdfs:label 'Wait Time Days Routine' ;
    rdfs:comment 'Average number of days members wait for a routine appointment with the assessed provider specialty, measured through survey or mystery shopper methodology.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitTimeDaysUrgent rdf:type rdf:Property ;
    rdfs:label 'Wait Time Days Urgent' ;
    rdfs:comment 'Average number of days members wait for an urgent appointment with the assessed provider specialty, measured through survey or mystery shopper methodology.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Board Certification Status' ;
    rdfs:comment 'Indicates whether the provider is board-certified in their specialty. Used for quality assessment and member directory filtering.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directoryPublicationChannel rdf:type rdf:Property ;
    rdfs:label 'Directory Publication Channel' ;
    rdfs:comment 'The channel through which this directory entry is published and accessible to members. Supports multi-channel directory distribution tracking.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directoryStatus rdf:type rdf:Property ;
    rdfs:label 'Directory Status' ;
    rdfs:comment 'Current status of the provider directory entry. Indicates whether the entry is actively published, pending verification, or suspended from member-facing display.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Last Verification Method' ;
    rdfs:comment 'Method used for the most recent directory verification. Tracks how the provider information was validated for audit and compliance purposes.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Last Verification Outcome' ;
    rdfs:comment 'Outcome of the most recent verification attempt. Indicates whether information was confirmed, updated, or if verification was unsuccessful.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedFields rdf:type rdf:Property ;
    rdfs:label 'Verified Fields' ;
    rdfs:comment 'Comma-separated list of fields that were verified during the last verification event. Examples include address, phone, accepting_new_patients, specialty.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifyingAgent rdf:type rdf:Property ;
    rdfs:label 'Verifying Agent' ;
    rdfs:comment 'Name or identifier of the person or system that performed the last verification. Used for audit trail and quality assurance.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentParAgreementId rdf:type rdf:Property ;
    rdfs:label 'Parent Par Agreement Id' ;
    rdfs:comment 'Self-referencing FK on par_agreement (parent_par_agreement_id)' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ParAgreement .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'External reference number assigned to the agreement by the health plan.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Agreement Scope Description' ;
    rdfs:comment 'Narrative description of the services, specialties, and geographic areas covered.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classifies the agreement as individual provider, group practice, or other entity.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementVersion rdf:type rdf:Property ;
    rdfs:label 'Agreement Version' ;
    rdfs:comment 'Version identifier for the agreement document (e.g., v1, v2).' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Effective Date' ;
    rdfs:comment 'Date the amendment becomes effective.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Flag' ;
    rdfs:comment 'Indicates whether this record represents an amendment to a prior agreement.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Identifier for the amendment (e.g., A1, A2).' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Termination Date' ;
    rdfs:comment 'Date the amendment expires, if different from the base agreement.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceStatusFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Status Flag' ;
    rdfs:comment 'Indicates whether the agreement meets all applicable regulatory requirements.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignatureFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Flag' ;
    rdfs:comment 'True if the agreement was signed electronically.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paperSignatureFlag rdf:type rdf:Property ;
    rdfs:label 'Paper Signature Flag' ;
    rdfs:comment 'True if the agreement was signed on paper.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Par Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the agreement.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerCredentialingDate rdf:type rdf:Property ;
    rdfs:label 'Provider Credentialing Date' ;
    rdfs:comment 'Date the provider completed credentialing for the network.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:providerCredentialingStatus rdf:type rdf:Property ;
    rdfs:label 'Provider Credentialing Status' ;
    rdfs:comment 'Credentialing state of the provider for network participation.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerDirectoryLastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Provider Directory Last Verified Date' ;
    rdfs:comment 'Date the provider\'s directory information was last verified.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:providerDirectoryListingFlag rdf:type rdf:Property ;
    rdfs:label 'Provider Directory Listing Flag' ;
    rdfs:comment 'Indicates whether the provider is listed in the public network directory.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerNetworkStatus rdf:type rdf:Property ;
    rdfs:label 'Provider Network Status' ;
    rdfs:comment 'Current network participation status of the provider.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerParticipationRole rdf:type rdf:Property ;
    rdfs:label 'Provider Participation Role' ;
    rdfs:comment 'Role of the provider within the network (e.g., primary care, specialist).' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerRecredentialingDueDate rdf:type rdf:Property ;
    rdfs:label 'Provider Recredentialing Due Date' ;
    rdfs:comment 'Next scheduled date for provider re-credentialing.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reimbursementMethodology rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Methodology' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Flag' ;
    rdfs:comment 'Indicates whether the agreement is set for automatic renewal.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatoryName rdf:type rdf:Property ;
    rdfs:label 'Signatory Name' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date the agreement was signed by the provider.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signedByName rdf:type rdf:Property ;
    rdfs:label 'Signed By Name' ;
    rdfs:comment 'Legal name of the individual who signed the agreement on behalf of the provider.' ;
    rdfs:domain ind:ParAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedByNpi rdf:type rdf:Property ;
    rdfs:label 'Signed By Npi' ;
    rdfs:comment 'National Provider Identifier of the signing individual.' ;
    rdfs:domain ind:ParAgreement ;
