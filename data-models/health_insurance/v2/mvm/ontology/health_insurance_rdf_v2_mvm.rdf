    rdfs:range xsd:string .

ind:expectedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Cost Amount' ;
    rdfs:comment 'Projected cost of the admission before services are rendered.' ;
    rdfs:domain ind:InpatientAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedLosDays rdf:type rdf:Property ;
    rdfs:label 'Expected Los Days' ;
    rdfs:comment 'Projected number of days the member is expected to stay, based on clinical criteria.' ;
    rdfs:domain ind:InpatientAdmission ;
    rdf:type owl:DatatypeProperty ;
