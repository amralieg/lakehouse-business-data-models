    rdfs:label 'Audit Year' ;
    rdfs:comment 'Year of audit.' ;
    rdfs:domain ind:RadvAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cmsFindings rdf:type rdf:Property ;
    rdfs:label 'Cms Findings' ;
    rdfs:comment 'CMS audit findings.' ;
    rdfs:domain ind:RadvAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extrapolatedPaymentError rdf:type rdf:Property ;
    rdfs:label 'Extrapolated Payment Error' ;
    rdfs:comment 'Extrapolated payment error amount.' ;
    rdfs:domain ind:RadvAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Final Settlement Amount' ;
    rdfs:comment 'Final settlement amount.' ;
    rdfs:domain ind:RadvAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hccMappingVersion rdf:type rdf:Property ;
    rdfs:label 'Hcc Mapping Version' ;
    rdfs:comment 'HCC mapping version used.' ;
    rdfs:domain ind:RadvAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalRecordReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Medical Record Receipt Date' ;
    rdfs:comment 'Date medical records received.' ;
    rdfs:domain ind:RadvAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalRecordRequestStatus rdf:type rdf:Property ;
    rdfs:label 'Medical Record Request Status' ;
    rdfs:comment 'Status of medical record request.' ;
    rdfs:domain ind:RadvAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreated rdf:type rdf:Property ;
    rdfs:label 'Record Created' ;
    rdfs:comment 'Record creation timestamp.' ;
    rdfs:domain ind:RadvAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdated rdf:type rdf:Property ;
    rdfs:label 'Record Updated' ;
    rdfs:comment 'Record update timestamp.' ;
    rdfs:domain ind:RadvAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampledMemberCount rdf:type rdf:Property ;
    rdfs:label 'Sampled Member Count' ;
    rdfs:comment 'Number of members sampled.' ;
    rdfs:domain ind:RadvAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validatedHccCount rdf:type rdf:Property ;
    rdfs:label 'Validated Hcc Count' ;
    rdfs:comment 'Number of validated HCCs.' ;
    rdfs:domain ind:RadvAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scoreHccAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Score Hcc Assignment Id' ;
    rdfs:comment 'Primary key for the risk_score_hcc_assignment association' ;
    rdfs:domain ind:ScoreHccAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contributionWeight rdf:type rdf:Property ;
    rdfs:label 'Contribution Weight' ;
    rdfs:comment 'The weighted contribution of this specific HCC to the member\'s total RAF score. Derived from the HCC coefficient adjusted for demographic and interaction factors specific to this member-HCC pairing. Belongs to the assignment, not to the score or the mapping alone.' ;
    rdfs:domain ind:ScoreHccAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hccCodes rdf:type rdf:Property ;
    rdfs:label 'Hcc Codes' ;
    rdfs:comment 'Comma-separated HCC codes contributing to score. [Moved from member_risk_score: This denormalized comma-separated STRING column is the flattened representation of the M:N relationship being replaced by this association table. Once risk_score_hcc_assignment is in place, individual HCC codes are accessible via JOIN to hcc_mapping. Retaining hcc_codes creates a data quality risk (divergence between the string and the junction records) and prevents proper RADV audit traceability.]' ;
    rdfs:domain ind:ScoreHccAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionReason rdf:type rdf:Property ;
    rdfs:label 'Inclusion Reason' ;
    rdfs:comment 'The clinical or administrative basis for including this HCC in the member\'s risk score. Required for RADV audit defense to demonstrate that each HCC assignment is supported by adequate medical record documentation.' ;
    rdfs:domain ind:ScoreHccAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryHcc rdf:type rdf:Property ;
    rdfs:label 'Is Primary Hcc' ;
    rdfs:comment 'Indicates whether this HCC is the dominant condition driver for the member\'s risk score. Used in RADV audit prioritization to identify the highest-impact HCC assignments for clinical documentation review.' ;
    rdfs:domain ind:ScoreHccAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privilegeId rdf:type rdf:Property ;
    rdfs:label 'Privilege Id' ;
    rdfs:comment 'Primary key for the provider_privilege association' ;
    rdfs:domain ind:Privilege ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privilegeStatus rdf:type rdf:Property ;
    rdfs:label 'Privilege Status' ;
    rdfs:comment 'Current operational status of the privilege grant. Drives claims adjudication eligibility checks and network directory accuracy.' ;
    rdfs:domain ind:Privilege ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privilegeType rdf:type rdf:Property ;
    rdfs:label 'Privilege Type' ;
    rdfs:comment 'Classification of the clinical privilege granted to the provider at this facility. Determines the scope of clinical activities the provider is authorized to perform.' ;
    rdfs:domain ind:Privilege ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
