ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify the COB information.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:idCardId rdf:type rdf:Property ;
    rdfs:label 'Id Card Id' ;
    rdfs:comment 'Surrogate primary key for the ID card record.' ;
    rdfs:domain ind:IdCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:healthPlanId rdf:type rdf:Property ;
    rdfs:label 'Health Plan Id' ;
    rdfs:comment 'Foreign key linking to plan.health_plan. Business justification: ID cards are issued per health plan; linking enables tracking issuance per plan for regulatory reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthPlan .

ind:memberIdentityId rdf:type rdf:Property ;
    rdfs:label 'Member Identity Id' ;
    rdfs:comment 'Unique identifier of the member to whom the card is issued.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Identity .

ind:pcpPracticeLocationId rdf:type rdf:Property ;
    rdfs:label 'Pcp Practice Location Id' ;
    rdfs:comment 'Foreign key linking to provider.practice_location. Business justification: ID cards display the PCP\'s office address and phone number. A FK to practice_location enables accurate, normalized retrieval of the PCP\'s specific practice site for card printing, member portal displa' ;
    rdfs:domain ind:IdCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeLocation .

ind:pcpProviderId rdf:type rdf:Property ;
    rdfs:label 'Pcp Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.provider. Business justification: ID card issuance requires printing the member\'s PCP name, sourced from the provider record. The denormalized pcp_name on id_card violates 3NF; a FK to provider.provider normalizes this and supports ac' ;
    rdfs:domain ind:IdCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:planElectionId rdf:type rdf:Property ;
    rdfs:label 'Plan Election Id' ;
    rdfs:comment 'Foreign key linking to enrollment.plan_election. Business justification: ID cards are issued or reissued when a plan election is made or changed. Linking id_card to plan_election enables ID card reissuance workflows, election change tracking, and member services operations' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanElection .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'Machine-readable barcode value encoded on the card.' ;
    rdfs:domain ind:IdCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardFormat rdf:type rdf:Property ;
    rdfs:label 'Card Format' ;
    rdfs:comment 'Delivery format of the card: physical plastic, digital image, or mobile app representation.' ;
    rdfs:domain ind:IdCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardNumber rdf:type rdf:Property ;
    rdfs:label 'Card Number' ;
    rdfs:comment 'The alphanumeric identifier printed on the ID card, used for member identification.' ;
    rdfs:domain ind:IdCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardType rdf:type rdf:Property ;
    rdfs:label 'Card Type' ;
    rdfs:comment 'Category of coverage the card provides (e.g., medical, dental).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardVersion rdf:type rdf:Property ;
    rdfs:label 'Card Version' ;
    rdfs:comment 'Version identifier for the card design/layout.' ;
    rdfs:domain ind:IdCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copayAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Amount' ;
