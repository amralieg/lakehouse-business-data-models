    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumType rdf:type rdf:Property ;
    rdfs:label 'Premium Type' ;
    rdfs:comment 'Frequency at which the premium is billed.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
