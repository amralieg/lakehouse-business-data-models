    rdfs:comment 'The par non par indicator for this record.' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parNonparIndicator rdf:type rdf:Property ;
    rdfs:label 'Par Nonpar Indicator' ;
    rdfs:comment 'The par nonpar indicator for this record.' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parStatus rdf:type rdf:Property ;
    rdfs:label 'Par Status' ;
    rdfs:comment 'Added business attribute par_status' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parStatusFlag rdf:type rdf:Property ;
    rdfs:label 'Par Status Flag' ;
    rdfs:comment 'Depth attribute added by thin-product expansion (3b) for par_status_flag.' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parStatusReason rdf:type rdf:Property ;
