ind:adverseDeterminationId rdf:type rdf:Property ;
    rdfs:label 'Adverse Determination Id' ;
    rdfs:comment 'Foreign key linking to appeal.adverse_determination. Business justification: EOBs communicate adverse determination outcomes to members and contain appeal_rights_text/appeal_rights_version fields that are directly derived from the adverse determination. Linking EOB to the spec' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdverseDetermination .

ind:renderingProviderId rdf:type rdf:Property ;
    rdfs:label 'Rendering Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.provider. Business justification: ACA-mandated EOBs must identify the rendering provider for member-facing communications. EOB generation and regulatory compliance require a direct FK to provider; provider_name and provider_npi are de' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:appealRightsText rdf:type rdf:Property ;
    rdfs:label 'Appeal Rights Text' ;
