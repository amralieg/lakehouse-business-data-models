    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Version' ;
    rdfs:comment 'Incremental version number for change management.' ;
    rdfs:domain ind:CostShareRule ;
    rdf:type owl:DatatypeProperty ;
