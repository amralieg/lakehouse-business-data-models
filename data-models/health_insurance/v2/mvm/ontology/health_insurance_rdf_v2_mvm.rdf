    rdfs:comment 'True if the admission occurs within 30 days of a prior discharge.' ;
    rdfs:domain ind:InpatientAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewDecision rdf:type rdf:Property ;
    rdfs:label 'Review Decision' ;
    rdfs:comment 'Outcome of the utilization management review.' ;
    rdfs:domain ind:InpatientAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Review Decision Date' ;
    rdfs:comment 'Date the UM reviewer rendered a decision.' ;
    rdfs:domain ind:InpatientAdmission ;
    rdf:type owl:DatatypeProperty ;
