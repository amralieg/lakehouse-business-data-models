    rdfs:comment 'Currency code for the renewal out-of-pocket maximum amount.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Renewal Premium Amount' ;
