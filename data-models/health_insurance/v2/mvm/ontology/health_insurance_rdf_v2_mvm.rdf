    rdfs:comment 'Date of last provider directory information update' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:networkAdequacyRole rdf:type rdf:Property ;
    rdfs:label 'Network Adequacy Role' ;
    rdfs:comment 'Role this provider fills for network adequacy (e.g., essential community provider)' ;
    rdfs:domain ind:ProviderNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
