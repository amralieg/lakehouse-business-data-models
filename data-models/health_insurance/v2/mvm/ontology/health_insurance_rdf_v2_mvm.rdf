ind:lengthOfStayTarget rdf:type rdf:Property ;
    rdfs:label 'Length Of Stay Target' ;
    rdfs:comment 'Planned maximum length of stay for the episode, expressed in days.' ;
    rdfs:domain ind:UmCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDiagnosisCode rdf:type rdf:Property ;
    rdfs:label 'Primary Diagnosis Code' ;
    rdfs:comment 'ICD code representing the principal diagnosis driving the case.' ;
    rdfs:domain ind:Utilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDiagnosisDescription rdf:type rdf:Property ;
    rdfs:label 'Primary Diagnosis Description' ;
    rdfs:comment 'Text description of the principal diagnosis.' ;
    rdfs:domain ind:UmCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProviderNpi rdf:type rdf:Property ;
    rdfs:label 'Primary Provider Npi' ;
    rdfs:comment 'National Provider Identifier of the primary provider.' ;
    rdfs:domain ind:UmCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevelCode rdf:type rdf:Property ;
    rdfs:label 'Priority Level Code' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgencyCode rdf:type rdf:Property ;
    rdfs:label 'Urgency Code' ;
    rdfs:domain ind:UmCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgencyFlag rdf:type rdf:Property ;
    rdfs:label 'Urgency Flag' ;
    rdfs:comment 'True if the case requires expedited review per clinical criteria.' ;
    rdfs:domain ind:UmCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attendingProviderId rdf:type rdf:Property ;
    rdfs:label 'Attending Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.provider. Business justification: The attending physician on an inpatient admission is a distinct role from the PA-requesting provider. Credentialing validation, network participation verification, quality reporting (HEDIS, CMS), and ' ;
    rdfs:domain ind:InpatientAdmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Final cost incurred for the admission after discharge.' ;
    rdfs:domain ind:InpatientAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualLosDays rdf:type rdf:Property ;
    rdfs:label 'Actual Los Days' ;
    rdfs:comment 'Number of days the member actually stayed in the facility.' ;
    rdfs:domain ind:InpatientAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:admissionNumber rdf:type rdf:Property ;
    rdfs:label 'Admission Number' ;
    rdfs:comment 'Business identifier assigned to the admission by the health plan.' ;
    rdfs:domain ind:InpatientAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admissionStatus rdf:type rdf:Property ;
    rdfs:label 'Admission Status' ;
    rdfs:comment 'Current lifecycle status of the admission.' ;
    rdfs:domain ind:InpatientAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admissionType rdf:type rdf:Property ;
    rdfs:label 'Admission Type' ;
    rdfs:comment 'Classification of the admission based on urgency.' ;
    rdfs:domain ind:InpatientAdmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeDisposition rdf:type rdf:Property ;
