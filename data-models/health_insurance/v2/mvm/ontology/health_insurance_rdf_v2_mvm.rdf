    rdfs:range xsd:boolean .

ind:networkProviderCount rdf:type rdf:Property ;
    rdfs:label 'Network Provider Count' ;
    rdfs:comment 'Provider count' ;
    rdfs:domain ind:NetworkConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outOfNetworkBenefitType rdf:type rdf:Property ;
