ind:hsaCompatible rdf:type rdf:Property ;
    rdfs:label 'Hsa Compatible' ;
    rdfs:comment 'True if the rule is compatible with a Health Savings Account (HDHP).' ;
    rdfs:domain ind:CostShareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultRule rdf:type rdf:Property ;
    rdfs:label 'Is Default Rule' ;
    rdfs:comment 'True if this rule is the default for its benefit when no other rule matches.' ;
    rdfs:domain ind:CostShareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Max Benefit Amount' ;
    rdfs:comment 'Maximum dollar amount payable under this rule per service occurrence.' ;
