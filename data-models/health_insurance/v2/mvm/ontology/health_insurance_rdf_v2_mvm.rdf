    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outOfNetworkCopayAmount rdf:type rdf:Property ;
    rdfs:label 'Out Of Network Copay Amount' ;
    rdfs:comment 'Fixed dollar copay amount for out-of-network services when benefit type is copay.' ;
    rdfs:domain ind:NetworkConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outOfNetworkCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Network Coverage Flag' ;
    rdfs:comment 'Indicates whether the plan provides any benefit for out-of-network services.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierPriority rdf:type rdf:Property ;
    rdfs:label 'Tier Priority' ;
    rdfs:comment 'Numeric priority used to order tiers when multiple tiers exist.' ;
    rdfs:domain ind:NetworkConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:county rdf:type rdf:Property ;
    rdfs:label 'County' ;
    rdfs:comment 'County name within the state for the service area.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentCapacity rdf:type rdf:Property ;
    rdfs:label 'Enrollment Capacity' ;
    rdfs:comment 'Maximum number of members that can be enrolled in this service area.' ;
    rdfs:domain ind:ServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exchangeMarket rdf:type rdf:Property ;
    rdfs:label 'Exchange Market' ;
    rdfs:comment 'Name of the ACA exchange market (if applicable) where the plan is offered.' ;
    rdfs:domain ind:ServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeMarketCode rdf:type rdf:Property ;
    rdfs:label 'Exchange Market Code' ;
    rdfs:comment 'Unique identifier for the exchange market.' ;
    rdfs:domain ind:ServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Region Code' ;
    rdfs:comment 'Standard code representing the broader geographic region for the service area.' ;
    rdfs:domain ind:ServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Indicates whether the service area is exclusive to this plan (True) or shared (False).' ;
    rdfs:domain ind:ServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFederalFunded rdf:type rdf:Property ;
    rdfs:label 'Is Federal Funded' ;
    rdfs:comment 'Indicates whether the service area receives federal funding.' ;
    rdfs:domain ind:ServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMedicaidEligible rdf:type rdf:Property ;
    rdfs:label 'Is Medicaid Eligible' ;
    rdfs:comment 'Indicates if the service area is eligible for Medicaid plans.' ;
    rdfs:domain ind:ServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMedicareEligible rdf:type rdf:Property ;
    rdfs:label 'Is Medicare Eligible' ;
    rdfs:comment 'Indicates if the service area is eligible for Medicare Advantage plans.' ;
    rdfs:domain ind:ServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Compliant' ;
    rdfs:comment 'Indicates whether the service area meets all regulatory requirements.' ;
    rdfs:domain ind:ServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStateFunded rdf:type rdf:Property ;
    rdfs:label 'Is State Funded' ;
    rdfs:comment 'Indicates whether the service area receives state funding.' ;
    rdfs:domain ind:ServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Current status of regulatory approval for the service area.' ;
    rdfs:domain ind:ServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Number' ;
    rdfs:comment 'Reference number for the regulatory filing associated with this service area.' ;
    rdfs:domain ind:ServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaType rdf:type rdf:Property ;
    rdfs:label 'Service Area Type' ;
    rdfs:comment 'Geographic granularity of the service area.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zipCodesExcluded rdf:type rdf:Property ;
    rdfs:label 'Zip Codes Excluded' ;
    rdfs:comment 'Comma-separated list of ZIP codes excluded from the service area.' ;
    rdfs:domain ind:ServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zipCodesIncluded rdf:type rdf:Property ;
    rdfs:label 'Zip Codes Included' ;
    rdfs:comment 'Comma-separated list of ZIP codes included in the service area.' ;
    rdfs:domain ind:ServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyId rdf:type rdf:Property ;
    rdfs:label 'Specialty Id' ;
    rdfs:comment 'Primary key for specialty' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specialty .

ind:acceptingNewPatientsFlag rdf:type rdf:Property ;
    rdfs:label 'Accepting New Patients Flag' ;
    rdfs:comment 'Indicates whether the provider is currently accepting new patients for this specialty. True if accepting; False if panel is closed. Used for provider directory accuracy.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boardCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Board Certified Flag' ;
    rdfs:comment 'Indicates whether the provider is board certified in this specialty. True if certified by a recognized medical board; False otherwise.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'The date on which the provider was initially certified by the board in this specialty. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiration Date' ;
    rdfs:comment 'The date on which the board certification expires and requires renewal. Null if certification does not expire or is lifetime. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'The unique certification number or identifier issued by the certifying board for this specialty. Used for verification purposes.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBoardName rdf:type rdf:Property ;
    rdfs:label 'Certifying Board Name' ;
    rdfs:comment 'The name of the medical board or certifying organization that granted board certification for this specialty (e.g., American Board of Internal Medicine, American Board of Surgery). Null if not board certified.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialingEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing Effective Date' ;
    rdfs:comment 'The date on which the provider\'s credentialing for this specialty became effective within the health plan\'s network. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:credentialingEndDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing End Date' ;
    rdfs:comment 'The date on which the provider\'s credentialing for this specialty ended or will end. Null if currently active with no planned end date. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:credentialingReviewDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing Review Date' ;
    rdfs:comment 'The date of the most recent credentialing review or recredentialing for this specialty. NCQA requires recredentialing at least every three years. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:credentialingStatus rdf:type rdf:Property ;
    rdfs:label 'Credentialing Status' ;
    rdfs:comment 'The current credentialing status of the provider for this specific specialty within the health plan\'s network. Active indicates the provider is credentialed and authorized to provide services in this specialty.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentRecordFlag rdf:type rdf:Property ;
    rdfs:label 'Current Record Flag' ;
    rdfs:comment 'Indicates whether this is the current active version of the specialty record. True for the current record; False for historical versions. Supports slowly changing dimension (SCD) Type 2 historization.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fellowshipCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Fellowship Completed Flag' ;
    rdfs:comment 'Indicates whether the provider completed a fellowship program in this specialty or subspecialty. True if fellowship training was completed; False otherwise.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fellowshipCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Fellowship Completion Date' ;
    rdfs:comment 'The date on which the provider completed the fellowship program. Format: yyyy-MM-dd. Null if no fellowship was completed.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fellowshipProgramName rdf:type rdf:Property ;
    rdfs:label 'Fellowship Program Name' ;
    rdfs:comment 'The name of the fellowship program and institution where the provider completed subspecialty training. Null if no fellowship was completed.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fhirVersion rdf:type rdf:Property ;
    rdfs:label 'Fhir Version' ;
    rdfs:comment 'FHIR meta.versionId optimistic concurrency token' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedisSpecialtyFlag rdf:type rdf:Property ;
    rdfs:label 'Hedis Specialty Flag' ;
    rdfs:comment 'Indicates whether this specialty is relevant for HEDIS measure attribution and quality reporting. True if the specialty is used in HEDIS measure calculations; False otherwise.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkAdequacyCategory rdf:type rdf:Property ;
    rdfs:label 'Network Adequacy Category' ;
    rdfs:comment 'The network adequacy category or specialty grouping used for regulatory reporting and network adequacy analysis. Maps specialty to state-specific or CMS network adequacy standards.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCredentialingReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Credentialing Review Date' ;
    rdfs:comment 'The scheduled date for the next credentialing review or recredentialing for this specialty. Used for compliance tracking and proactive credentialing management. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pcpEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Pcp Eligible Flag' ;
    rdfs:comment 'Indicates whether this specialty qualifies the provider to serve as a Primary Care Provider (PCP) for member assignment. True for specialties such as Family Medicine, Internal Medicine, Pediatrics, and General Practice.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primarySpecialtyFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Specialty Flag' ;
    rdfs:comment 'Identifies the provider\'s primary specialty.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recertificationCycleYears rdf:type rdf:Property ;
    rdfs:label 'Recertification Cycle Years' ;
    rdfs:comment 'The number of years in the recertification cycle (e.g., 10 years for most ABMS boards). Null if recertification is not required.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recertification Required Flag' ;
    rdfs:comment 'Indicates whether the board certification requires periodic recertification or maintenance of certification (MOC). True if recertification is required; False if lifetime certification.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Record Effective Date' ;
    rdfs:comment 'The date from which this version of the specialty record is effective for business purposes. Supports slowly changing dimension (SCD) Type 2 historization. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordEndDate rdf:type rdf:Property ;
    rdfs:label 'Record End Date' ;
    rdfs:comment 'The date on which this version of the specialty record ceased to be effective. Null for the current active record. Supports slowly changing dimension (SCD) Type 2 historization. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'The unique identifier for this specialty record in the source system. Used for data lineage, reconciliation, and troubleshooting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialistReferralRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Specialist Referral Required Flag' ;
    rdfs:comment 'Indicates whether members require a referral from their PCP to see this provider in this specialty, based on plan type (e.g., HMO requires referrals; PPO typically does not). True if referral is required; False otherwise.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialtyType rdf:type rdf:Property ;
    rdfs:label 'Specialty Type' ;
    rdfs:comment 'Indicates whether this is the provider\'s primary specialty, secondary specialty, or tertiary specialty. Primary specialty is the main area of practice; secondary and tertiary are additional areas of expertise.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subspecialtyCode rdf:type rdf:Property ;
    rdfs:label 'Subspecialty Code' ;
    rdfs:comment 'Additional NUCC taxonomy code representing a subspecialty within the primary specialty (e.g., Interventional Cardiology within Cardiology). Null if no subspecialty designation.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subspecialtyName rdf:type rdf:Property ;
    rdfs:label 'Subspecialty Name' ;
    rdfs:comment 'The human-readable name of the subspecialty, if applicable. Provides additional granularity beyond the primary specialty for network adequacy and member search.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyCode rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Code' ;
    rdfs:comment 'Provider taxonomy code; reference attribute, not a contract artifact.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telehealthEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Telehealth Enabled Flag' ;
    rdfs:comment 'Indicates whether the provider offers telehealth or telemedicine services for this specialty. True if telehealth services are available; False otherwise. Important for provider directory accuracy.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yearsInSpecialty rdf:type rdf:Property ;
    rdfs:label 'Years In Specialty' ;
    rdfs:comment 'The number of years the provider has been practicing in this specialty. Calculated from the date the provider first began practicing in this specialty area.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Foreign key linking to provider.facility. Business justification: A practice location may be physically housed within a healthcare facility (e.g., a hospital outpatient clinic, ASC, or FQHC satellite site). Adding facility_id to practice_location establishes this st' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:groupPracticeId rdf:type rdf:Property ;
    rdfs:label 'Group Practice Id' ;
    rdfs:comment 'Foreign key linking to provider.group_practice. Business justification: A practice location belongs to a group practice or medical group. The group_practice table is the authoritative record for medical groups and IPAs. Adding group_practice_id normalizes the medical_grou' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupPractice .

ind:primaryPracticeMedicaidEnrolledProviderId rdf:type rdf:Property ;
    rdfs:label 'Primary Practice Medicaid Enrolled Provider Id' ;
    rdfs:comment 'State-specific Medicaid provider identifier for this practice location. Required for Medicaid claims submission.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:tertiaryPrimaryProviderId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Primary Provider Id' ;
    rdfs:comment 'Reference to the primary provider associated with this practice location. A provider may have multiple practice locations.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:adaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ada Compliant Flag' ;
    rdfs:comment 'Indicates whether the practice location meets ADA accessibility requirements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the practice location (street number and name).' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information such as suite, floor, building, or unit number.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countyName rdf:type rdf:Property ;
    rdfs:label 'County Name' ;
    rdfs:comment 'County name where the practice location is situated. Used for network adequacy geographic access analysis.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directoryDisplayFlag rdf:type rdf:Property ;
    rdfs:label 'Directory Display Flag' ;
    rdfs:comment 'Indicates whether this practice location should be displayed in the member-facing provider directory. May be false even if active (e.g., administrative locations).' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fipsCode rdf:type rdf:Property ;
    rdfs:label 'Fips Code' ;
    rdfs:comment '5-digit FIPS county code for geographic identification and network adequacy reporting.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagesSpoken rdf:type rdf:Property ;
    rdfs:label 'Languages Spoken' ;
    rdfs:comment 'Comma-separated list of languages spoken by staff at this practice location (e.g., \'English, Spanish, Mandarin\'). Supports member language access requirements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date when the practice location information was last verified for accuracy. CMS requires quarterly verification for provider directory data.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Business name or designation of the practice location (e.g., \'Main Street Family Medicine\', \'Downtown Urgent Care Center\').' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the practice location type indicating the care delivery setting.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npi rdf:type rdf:Property ;
    rdfs:label 'Npi' ;
    rdfs:comment '10-digit National Provider Identifier for this practice location if it has a Type 2 (organizational) NPI. May be null if location uses only the provider\'s individual NPI.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeHours rdf:type rdf:Property ;
    rdfs:label 'Office Hours' ;
    rdfs:comment 'Operating hours of the practice location (e.g., \'Mon-Fri 8:00 AM - 5:00 PM, Sat 9:00 AM - 1:00 PM\'). Free-text field for member-facing display.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Parking Available Flag' ;
    rdfs:comment 'Indicates whether on-site or nearby parking is available for patients.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:participationStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Status' ;
    rdfs:comment 'Current participation status of this practice location in the provider network. Determines whether location appears in member-facing provider directory.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientAgeMaximum rdf:type rdf:Property ;
    rdfs:label 'Patient Age Maximum' ;
    rdfs:comment 'Maximum patient age accepted at this practice location (e.g., 18 for pediatrics only). Null if no maximum restriction.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patientAgeMinimum rdf:type rdf:Property ;
    rdfs:label 'Patient Age Minimum' ;
    rdfs:comment 'Minimum patient age accepted at this practice location (e.g., 0 for all ages, 18 for adults only). Null if no minimum restriction.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patientGenderRestriction rdf:type rdf:Property ;
    rdfs:label 'Patient Gender Restriction' ;
    rdfs:comment 'Gender restriction for patients served at this location (e.g., \'female_only\' for women\'s health clinics).' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicTransportationAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Public Transportation Access Flag' ;
    rdfs:comment 'Indicates whether the practice location is accessible via public transportation.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Federal Tax Identification Number (EIN) for the practice location or medical group. Used for claims payment and 1099 reporting.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telehealthAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Telehealth Available Flag' ;
    rdfs:comment 'Indicates whether telehealth services are available at this practice location.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used for the most recent verification of practice location information.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wheelchairAccessibleFlag rdf:type rdf:Property ;
    rdfs:label 'Wheelchair Accessible Flag' ;
    rdfs:comment 'Indicates whether the practice location has wheelchair accessibility features (ramps, elevators, accessible restrooms).' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zipCode rdf:type rdf:Property ;
    rdfs:label 'Zip Code' ;
    rdfs:comment '5-digit or ZIP+4 postal code for the practice location.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseId rdf:type rdf:Property ;
    rdfs:label 'License Id' ;
    rdfs:comment 'Primary key for license' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attestationDate rdf:type rdf:Property ;
    rdfs:label 'Attestation Date' ;
    rdfs:comment 'The date the provider attested to the accuracy and currency of this license information. Used for credentialing and recredentialing cycles.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedSchedules rdf:type rdf:Property ;
    rdfs:label 'Authorized Schedules' ;
    rdfs:comment 'For DEA and CDS registrations, the controlled substance schedules the provider is authorized to prescribe (Schedule II, III, IV, V). Stored as comma-separated list. Critical for pharmacy benefit management and prior authorization workflows.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compactParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Compact Participation Flag' ;
    rdfs:comment 'Indicates whether this license is part of an interstate licensure compact (e.g., Interstate Medical Licensure Compact, Nurse Licensure Compact). True if the license grants multi-state practice privileges; false otherwise.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compactPrivilegeStates rdf:type rdf:Property ;
    rdfs:label 'Compact Privilege States' ;
    rdfs:comment 'Comma-separated list of state abbreviations where the provider has practice privileges under the interstate compact. Used for multi-state network adequacy and provider directory management.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compactType rdf:type rdf:Property ;
    rdfs:label 'Compact Type' ;
    rdfs:comment 'The specific interstate licensure compact this license participates in. IMLC is Interstate Medical Licensure Compact for physicians. Populated only when compact_participation_flag is true. [ENUM-REF-CANDIDATE: imlc|nurse_licensure_compact|psychology_compact|physical_therapy_compact|ems_compact|counseling_compact|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours Required' ;
    rdfs:comment 'The number of continuing education or CME hours required per renewal cycle to maintain this license. Varies by state and license type.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:continuingEducationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Required Flag' ;
    rdfs:comment 'Indicates whether continuing education (CE) or continuing medical education (CME) is required to maintain this license. True if CE/CME is mandatory for renewal; false otherwise.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disciplinaryActionDate rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Date' ;
    rdfs:comment 'The date disciplinary action was taken against the license. Used for credentialing review timelines and risk assessment.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disciplinaryActionDetails rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Details' ;
    rdfs:comment 'Detailed description of any disciplinary actions, sanctions, or restrictions imposed by the licensing authority. Includes nature of violation, dates, and resolution. Populated only when disciplinary_action_flag is true.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryActionFlag rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Flag' ;
    rdfs:comment 'Indicates whether any disciplinary action has been taken against this license by the issuing authority. True if disciplinary action exists; false otherwise. Critical for credentialing risk assessment.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'The regulatory body or government agency that issued the license or registration. Examples include State Medical Board, State Board of Nursing, Drug Enforcement Administration (DEA), State Pharmacy Board, or Centers for Medicare and Medicaid Services (CMS).' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingState rdf:type rdf:Property ;
    rdfs:label 'Issuing State' ;
    rdfs:comment 'The U.S. state or territory that issued the license. Uses two-letter state abbreviation. Critical for multi-state licensure tracking and Interstate Medical Licensure Compact compliance. [ENUM-REF-CANDIDATE: AL|AK|AZ|AR|CA|CO|CT|DE|FL|GA|HI|ID|IL|IN|IA|KS|KY|LA|ME|MD|MA|MI|MN|MS|MO|MT|NE|NV|NH|NJ|NM|NY|NC|ND|OH|OK|OR|PA|RI|SC|SD|TN|TX|UT|VT|VA|WA|WV|WI|WY|DC — 51 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'The unique license or registration number issued by the licensing authority. For DEA registrations, this is the DEA number; for state medical licenses, this is the state-issued license number.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current status of the license or registration in its lifecycle. Active indicates the license is valid and in good standing; suspended, revoked, or expired indicate the provider cannot practice under this credential. [ENUM-REF-CANDIDATE: active|inactive|suspended|revoked|expired|surrendered|pending_renewal|probation|restricted — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'The category of professional license or registration. Includes state medical licenses (MD, DO), nursing licenses (RN, LPN, NP), DEA controlled substance registrations, state CDS permits, pharmacy licenses, and other professional certifications. [ENUM-REF-CANDIDATE: medical_license|nursing_license|dea_registration|cds_permit|pharmacy_license|dental_license|optometry_license|podiatry_license|chiropractic_license|physical_therapy_license|occupational_therapy_license|behavioral_health_license|advanced_practice_license|physician_assistant_license|other — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceRestrictions rdf:type rdf:Property ;
    rdfs:label 'Practice Restrictions' ;
    rdfs:comment 'Any limitations or restrictions placed on the license by the issuing authority. May include supervision requirements, practice setting restrictions, or specific clinical limitations.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySourceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Primary Source Verification Date' ;
    rdfs:comment 'The date the license was last verified directly with the issuing authority (primary source). NCQA requires PSV within 180 days of credentialing decision and every 36 months thereafter.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primarySourceVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Primary Source Verification Method' ;
    rdfs:comment 'The method used to verify the license with the primary source. Includes online state board portals, written correspondence, phone verification, third-party credentialing services, or automated API integration.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCurrentFlag rdf:type rdf:Property ;
    rdfs:label 'Record Current Flag' ;
    rdfs:comment 'Indicates whether this is the current active version of the license record. True for the current record; false for historical versions. Supports Type 2 slowly changing dimension queries.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordEffectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Effective Timestamp' ;
    rdfs:comment 'The date and time from which this version of the license record is effective for business reporting. Supports Type 2 slowly changing dimension tracking.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record End Timestamp' ;
    rdfs:comment 'The date and time when this version of the license record was superseded by a new version. Null for the current active record. Supports Type 2 slowly changing dimension tracking.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:renewalCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Cycle Months' ;
    rdfs:comment 'The number of months between required renewals for this license type. Common values are 12, 24, or 36 months depending on state and license type.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeOfPractice rdf:type rdf:Property ;
    rdfs:label 'Scope Of Practice' ;
    rdfs:comment 'Description of the clinical activities and services the provider is authorized to perform under this license. Varies by license type and state regulations. Used for state-specific scope-of-practice validation.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telemedicineAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Telemedicine Authorized Flag' ;
    rdfs:comment 'Indicates whether the provider is authorized to deliver telemedicine services under this license. True if telemedicine practice is permitted; false otherwise. Critical for virtual care network management.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationSource rdf:type rdf:Property ;
    rdfs:label 'Verification Source' ;
    rdfs:comment 'The specific entity or system used to perform primary source verification. Examples include state medical board website, NPDB, third-party credentialing verification organization (CVO), or automated verification service.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationUrl rdf:type rdf:Property ;
    rdfs:label 'Verification Url' ;
    rdfs:comment 'The web address of the state licensing board or regulatory authority where the license can be verified online. Used for automated primary source verification workflows.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliationId rdf:type rdf:Property ;
    rdfs:label 'Affiliation Id' ;
    rdfs:comment 'Primary key for affiliation' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parAgreementId rdf:type rdf:Property ;
    rdfs:label 'Par Agreement Id' ;
    rdfs:comment 'Foreign key linking to network.par_agreement. Business justification: Credentialing and contracting operations require linking a provider\'s organizational affiliation (facility/group) to the governing participation agreement. Network operations teams use this to validat' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ParAgreement .

ind:admittingPrivilegesFlag rdf:type rdf:Property ;
    rdfs:label 'Admitting Privileges Flag' ;
    rdfs:comment 'Boolean indicator denoting whether the provider has admitting privileges at the affiliated hospital or facility. True indicates admitting privileges are granted; False indicates no admitting privileges.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affiliationStatus rdf:type rdf:Property ;
    rdfs:label 'Affiliation Status' ;
    rdfs:comment 'Current lifecycle status of the provider affiliation. Indicates whether the affiliation is active and in effect, inactive, suspended, pending approval, or terminated.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliationType rdf:type rdf:Property ;
    rdfs:label 'Affiliation Type' ;
    rdfs:comment 'Categorical classification of the affiliation relationship. Indicates whether the provider is affiliated with a medical group, Independent Practice Association (IPA), Accountable Care Organization (ACO), health system, hospital, or other facility type.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingNpi rdf:type rdf:Property ;
    rdfs:label 'Billing Npi' ;
    rdfs:comment 'The National Provider Identifier (NPI) used for billing purposes in this affiliation context. May represent the organizational NPI (Type 2) of the affiliated entity.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialingVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing Verification Date' ;
    rdfs:comment 'The date on which the provider\'s credentials and affiliation with the organization were last verified. Used to track compliance with credentialing re-verification requirements.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'The name of the department, division, or service line within the affiliated organization where the provider practices. Examples include Cardiology, Emergency Medicine, Orthopedic Surgery, Primary Care.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'The user ID or system identifier of the person or process that last updated this affiliation record. Supports audit and accountability requirements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The date and time when this affiliation record was last modified. Used for audit trail and change tracking.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:medicalStaffCategory rdf:type rdf:Property ;
    rdfs:label 'Medical Staff Category' ;
    rdfs:comment 'The category of medical staff membership the provider holds at the affiliated hospital or facility. Categories include Active Staff, Courtesy Staff, Consulting Staff, Honorary Staff, Affiliate Staff, and Provisional Staff.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Network Participation Flag' ;
    rdfs:comment 'Boolean indicator denoting whether this affiliation makes the provider eligible for participation in the health plan\'s provider network. True indicates network participation; False indicates non-participating affiliation.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextCredentialingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Credentialing Due Date' ;
    rdfs:comment 'The date by which the next credentialing verification for this affiliation is due. Supports proactive credentialing workflow management.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryAffiliationFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Affiliation Flag' ;
    rdfs:comment 'Boolean indicator denoting whether this is the provider\'s primary organizational affiliation. True indicates this is the main affiliation; False indicates a secondary or additional affiliation.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleTitle rdf:type rdf:Property ;
    rdfs:label 'Role Title' ;
    rdfs:comment 'The provider\'s role or title within the affiliated organization. Examples include Staff Physician, Medical Director, Department Chair, Attending Physician, Consulting Physician.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The unique identifier of this affiliation record in the source system. Used for traceability and reconciliation with upstream systems.' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tin rdf:type rdf:Property ;
    rdfs:label 'Tin' ;
    rdfs:comment 'The Tax Identification Number (TIN) or Employer Identification Number (EIN) under which the provider bills for services rendered through this affiliation. Used for claims routing and payment processing.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'The user ID or system identifier of the person or process that created this affiliation record. Supports audit and accountability requirements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryGroupMedicaidProviderId rdf:type rdf:Property ;
    rdfs:label 'Primary Group Medicaid Provider Id' ;
    rdfs:comment 'The state-assigned Medicaid provider identifier for the group practice, used for Medicaid claims submission.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:acceptingNewPatients rdf:type rdf:Property ;
    rdfs:label 'Accepting New Patients' ;
    rdfs:comment 'Indicates whether the group practice is currently accepting new patients. Used for provider directory accuracy and member access.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accessibilityAccommodations rdf:type rdf:Property ;
    rdfs:label 'Accessibility Accommodations' ;
    rdfs:comment 'Description of accessibility accommodations available at the group practice (e.g., wheelchair access, hearing loop, accessible exam tables) to comply with ADA requirements.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acoName rdf:type rdf:Property ;
    rdfs:label 'Aco Name' ;
    rdfs:comment 'The name of the ACO in which the group practice participates, if applicable.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acoParticipant rdf:type rdf:Property ;
    rdfs:label 'Aco Participant' ;
    rdfs:comment 'Indicates whether the group practice participates in an Accountable Care Organization (ACO) for value-based care arrangements.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmsCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Cms Certification Number' ;
    rdfs:comment 'The CMS Certification Number (CCN) assigned to FQHC, RHC, or other certified facilities. Required for Medicare/Medicaid billing.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialingDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing Date' ;
    rdfs:comment 'The date on which the group practice was initially credentialed and approved for network participation.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'The name of the source system from which this group practice record originated (e.g., Cactus, ProviderSource, NPPES).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doingBusinessAsName rdf:type rdf:Property ;
    rdfs:label 'Doing Business As Name' ;
    rdfs:comment 'The trade name or DBA name under which the group practice operates, if different from the legal name.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupName rdf:type rdf:Property ;
    rdfs:label 'Group Name' ;
    rdfs:comment 'The legal business name of the medical group, physician organization, or practice entity as registered with state authorities and CMS.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupNpi rdf:type rdf:Property ;
    rdfs:label 'Group Npi' ;
    rdfs:comment 'The 10-digit Type 2 NPI assigned to the group practice organization by CMS. This is the organizational NPI distinct from individual provider NPIs.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupSize rdf:type rdf:Property ;
    rdfs:label 'Group Size' ;
    rdfs:comment 'The total number of individual providers (physicians, nurse practitioners, physician assistants) affiliated with and practicing under this group.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groupType rdf:type rdf:Property ;
    rdfs:label 'Group Type' ;
    rdfs:comment 'Classification of the group practice organizational structure: solo practice (single physician), single specialty group, multi-specialty group, Independent Practice Association (IPA), Federally Qualified Health Center (FQHC), or Rural Health Clinic (RHC).' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hospitalAffiliation rdf:type rdf:Property ;
    rdfs:label 'Hospital Affiliation' ;
    rdfs:comment 'The name of the primary hospital or health system with which the group practice is affiliated or has admitting privileges.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageServicesOffered rdf:type rdf:Property ;
    rdfs:label 'Language Services Offered' ;
    rdfs:comment 'Comma-separated list of languages in which the group practice offers clinical services, used for provider directory cultural competency and member access.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcmhRecognitionLevel rdf:type rdf:Property ;
    rdfs:label 'Pcmh Recognition Level' ;
    rdfs:comment 'The NCQA PCMH recognition level achieved by the group practice (Level 1, 2, or 3), with Level 3 being the highest.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcmhRecognized rdf:type rdf:Property ;
    rdfs:label 'Pcmh Recognized' ;
    rdfs:comment 'Indicates whether the group practice has achieved NCQA Patient-Centered Medical Home (PCMH) recognition, qualifying for enhanced reimbursement and quality incentives.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primarySpecialty rdf:type rdf:Property ;
    rdfs:label 'Primary Specialty' ;
    rdfs:comment 'The primary medical specialty or service focus of the group practice (e.g., Family Medicine, Cardiology, Orthopedic Surgery, Multi-Specialty).' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recredentialingDueDate rdf:type rdf:Property ;
    rdfs:label 'Recredentialing Due Date' ;
    rdfs:comment 'The date by which the group practice must complete recredentialing to maintain network participation. NCQA requires recredentialing at least every 36 months.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:telehealthEnabled rdf:type rdf:Property ;
    rdfs:label 'Telehealth Enabled' ;
    rdfs:comment 'Indicates whether the group practice offers telehealth or telemedicine services to members.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'The public website URL for the group practice, used in provider directory listings.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningProviderId rdf:type rdf:Property ;
    rdfs:label 'Owning Provider Id' ;
    rdfs:comment 'FK to provider.provider for facilities that are providers with NPIs' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'Organization that has accredited the facility. Values: joint_commission (The Joint Commission), dnv (DNV Healthcare), cihq (Center for Improvement in Healthcare Quality), aoa (American Osteopathic Association), aaahc (Accreditation Association for Ambulatory Health Care), achc (Accreditation Commission for Health Care), none (not accredited). [ENUM-REF-CANDIDATE: joint_commission|dnv|cihq|aoa|aaahc|achc|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiration Date' ;
    rdfs:comment 'Date when the current accreditation expires. Null if facility is not accredited.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bedCount rdf:type rdf:Property ;
    rdfs:label 'Bed Count' ;
    rdfs:comment 'Total number of licensed beds at the facility. Used for network adequacy calculations and capacity planning.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ccn rdf:type rdf:Property ;
    rdfs:label 'Ccn' ;
    rdfs:comment 'Six-character alphanumeric identifier assigned by CMS to Medicare/Medicaid certified facilities. Also known as Provider Number.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cliaNumber rdf:type rdf:Property ;
    rdfs:label 'Clia Number' ;
    rdfs:comment 'Ten-character identifier issued by CMS for facilities performing laboratory testing. Format: 2-digit state code + 1 letter + 7 digits.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing Expiration Date' ;
    rdfs:comment 'Date when the current credentialing approval expires and recredentialing is required.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:criticalAccessHospitalFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Access Hospital Flag' ;
    rdfs:comment 'Indicates whether the facility is designated as a Critical Access Hospital under the Medicare Rural Hospital Flexibility Program.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyServicesFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Services Flag' ;
    rdfs:comment 'Indicates whether the facility provides 24/7 emergency department services.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the healthcare facility. Values: hospital (acute care hospital), snf (Skilled Nursing Facility), asc (Ambulatory Surgical Center), fqhc (Federally Qualified Health Center), rhc (Rural Health Clinic), behavioral_health (behavioral health facility). [ENUM-REF-CANDIDATE: hospital|snf|asc|fqhc|rhc|behavioral_health|home_health|hospice|dialysis_center|dme_supplier|ltac|irf|imaging_center — promote to reference product]' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicaidCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Medicaid Certified Flag' ;
    rdfs:comment 'Indicates whether the facility is certified to participate in the Medicaid program.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicareCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Medicare Certified Flag' ;
    rdfs:comment 'Indicates whether the facility is certified to participate in the Medicare program.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Legal ownership structure of the facility. Values: for_profit (investor-owned), non_profit (tax-exempt), government (federal/state/local), tribal (Indian Health Service or tribal).' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Overall quality rating score for the facility on a scale of 1.00 to 5.00. Derived from CMS Star Ratings, HEDIS measures, or internal quality assessments.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teachingHospitalFlag rdf:type rdf:Property ;
    rdfs:label 'Teaching Hospital Flag' ;
    rdfs:comment 'Indicates whether the facility is a teaching hospital affiliated with a medical school and residency programs.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:traumaLevel rdf:type rdf:Property ;
    rdfs:label 'Trauma Level' ;
    rdfs:comment 'Trauma center designation level assigned by state or American College of Surgeons. Level 1 is highest capability. Not_designated indicates facility is not a trauma center.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directoryEntryId rdf:type rdf:Property ;
    rdfs:label 'Directory Entry Id' ;
    rdfs:comment 'Primary key for directory_entry' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessibilityFeatures rdf:type rdf:Property ;
    rdfs:label 'Accessibility Features' ;
    rdfs:comment 'Description of accessibility features available at the practice location (wheelchair access, hearing loop, accessible parking). Supports ADA compliance and member access.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestationMethod rdf:type rdf:Property ;
    rdfs:label 'Attestation Method' ;
    rdfs:comment 'Method used to verify the directory information with the provider. Documents the verification approach for audit and compliance purposes.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestationStatus rdf:type rdf:Property ;
    rdfs:label 'Attestation Status' ;
    rdfs:comment 'Status of the provider attestation or verification process for this directory entry. Tracks compliance with CMS directory accuracy requirements.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardCertifications rdf:type rdf:Property ;
    rdfs:label 'Board Certifications' ;
    rdfs:comment 'Comma-separated list of board certifications held by the provider. Demonstrates advanced training and specialty expertise.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directoryDisplayName rdf:type rdf:Property ;
    rdfs:label 'Directory Display Name' ;
    rdfs:comment 'Consumer-facing display name of the provider as it appears in the published directory. May differ from legal name for readability and member experience.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directoryPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Directory Publication Date' ;
    rdfs:comment 'Date when this directory entry was published or last updated in the member-facing provider directory. Required for CMS directory accuracy attestation.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:graduationYear rdf:type rdf:Property ;
    rdfs:label 'Graduation Year' ;
    rdfs:comment 'Year the provider graduated from medical school or professional training program. Helps members assess provider experience.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicalSchool rdf:type rdf:Property ;
    rdfs:label 'Medical School' ;
    rdfs:comment 'Name of the medical school or professional training institution where the provider received their degree. Provides credential transparency for members.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextVerificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Verification Due Date' ;
    rdfs:comment 'Date by which the next directory verification must be completed to maintain compliance with CMS and state DOI accuracy mandates.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pcpFlag rdf:type rdf:Property ;
    rdfs:label 'Pcp Flag' ;
    rdfs:comment 'Indicates whether this provider is eligible to serve as a Primary Care Provider (PCP) for plan members. Relevant for HMO and POS plans requiring PCP selection.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:practiceWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Practice Website Url' ;
    rdfs:comment 'Website URL for the practice or provider. Published in directory to enable members to learn more about the provider and services offered.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'High-level classification of the provider entity type. Determines directory presentation and search filtering options for members.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsAdjudicationFlag rdf:type rdf:Property ;
    rdfs:label 'Claims Adjudication Flag' ;
    rdfs:comment 'Indicates whether claims from this provider should be adjudicated as in-network for this plan and network. This is the authoritative flag for claims processing network determination.' ;
    rdfs:domain ind:ParticipationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:continuityOfCareEndDate rdf:type rdf:Property ;
    rdfs:label 'Continuity Of Care End Date' ;
    rdfs:comment 'The date through which continuity of care provisions apply for members in active treatment with this provider. Allows in-network benefits to continue for a transition period after provider termination.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:credentialingApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing Approval Date' ;
    rdfs:comment 'The date on which the provider was approved through the credentialing process for this participation arrangement.' ;
    rdfs:domain ind:ParticipationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:memberNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Member Notification Date' ;
    rdfs:comment 'The date on which affected members were notified of the provider participation status change. Required for regulatory compliance with provider termination notification requirements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:memberNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Member Notification Method' ;
    rdfs:comment 'The communication channel used to notify members of the provider participation status change.' ;
    rdfs:domain ind:ParticipationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRecredentialingDate rdf:type rdf:Property ;
    rdfs:label 'Next Recredentialing Date' ;
    rdfs:comment 'The date by which the provider must complete recredentialing to maintain active participation status. Typically occurs every 24-36 months per NCQA standards.' ;
    rdfs:domain ind:ParticipationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationCategory rdf:type rdf:Property ;
    rdfs:label 'Participation Category' ;
    rdfs:comment 'The category of participation indicating the scope of services the provider is authorized to deliver under this arrangement.' ;
    rdfs:domain ind:ParticipationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySanctionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Sanction Flag' ;
    rdfs:comment 'Indicates whether the provider is currently under regulatory sanction that affects their participation status. Sanctions may be imposed by state medical boards, CMS, or other regulatory bodies.' ;
    rdfs:domain ind:ParticipationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskArrangementCode rdf:type rdf:Property ;
    rdfs:label 'Risk Arrangement Code' ;
    rdfs:comment 'The financial risk arrangement under which the provider participates. Indicates whether the provider is paid fee-for-service, capitation, or under a value-based care model.' ;
    rdfs:domain ind:ParticipationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Sanction Effective Date' ;
    rdfs:comment 'The date on which a regulatory sanction affecting participation status became effective.' ;
    rdfs:domain ind:ParticipationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionEndDate rdf:type rdf:Property ;
    rdfs:label 'Sanction End Date' ;
    rdfs:comment 'The date on which a regulatory sanction affecting participation status is scheduled to end or was lifted.' ;
    rdfs:domain ind:ParticipationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialistFlag rdf:type rdf:Property ;
    rdfs:label 'Specialist Flag' ;
    rdfs:comment 'Indicates whether the provider is participating as a specialist in this network and plan. Used for network adequacy reporting and referral management.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusChangeTrigger rdf:type rdf:Property ;
    rdfs:label 'Status Change Trigger' ;
    rdfs:comment 'The business event or process that triggered this participation status change. Used for audit trail and root cause analysis of network changes. [ENUM-REF-CANDIDATE: CREDENTIALING_DECISION|CONTRACT_EXECUTION|CONTRACT_TERMINATION|SANCTION_IMPOSED|VOLUNTARY_REQUEST|NETWORK_CHANGE|RECREDENTIALING_OUTCOME — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ParticipationStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Termination Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for participation termination. Required for regulatory reporting and member notification requirements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Termination Reason Description' ;
    rdfs:comment 'Detailed explanation of the termination reason. Provides additional context beyond the standardized termination reason code.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headerId rdf:type rdf:Property ;
    rdfs:label 'Header Id' ;
    rdfs:comment 'Primary key for header' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:billingGroupPracticeId rdf:type rdf:Property ;
    rdfs:label 'Billing Group Practice Id' ;
    rdfs:comment 'Foreign key linking to provider.group_practice. Business justification: Claims submitted by group practices require group-level aggregation for contract performance monitoring, capitation reconciliation, and value-based care reporting. billing_provider_npi is a denormaliz' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupPractice .

ind:gracePeriodId rdf:type rdf:Property ;
    rdfs:label 'Grace Period Id' ;
    rdfs:comment 'Foreign key linking to billing.grace_period. Business justification: ACA regulatory requirement: claims for services during a member\'s grace period (months 2-3 for APTC recipients) must be pended per 45 CFR 156.270. Adjudicators must identify the active grace period at' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GracePeriod .

ind:inpatientAdmissionId rdf:type rdf:Property ;
    rdfs:label 'Inpatient Admission Id' ;
    rdfs:comment 'Foreign key linking to utilization.inpatient_admission. Business justification: Required for Admission-to-Claim reconciliation report; claims are generated from inpatient admissions, so linking each claim to its admission record is standard practice.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InpatientAdmission .

ind:paDecisionId rdf:type rdf:Property ;
    rdfs:label 'Pa Decision Id' ;
    rdfs:comment 'Foreign key linking to utilization.pa_decision. Business justification: Claim-level PA decision tracking is required for MLR reporting, auto-adjudication workflows, and regulatory audits. Direct FK from claim header to pa_decision enables claim-level authorization outcome' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaDecision .

ind:paRequestId rdf:type rdf:Property ;
    rdfs:label 'Pa Request Id' ;
    rdfs:comment 'Foreign key linking to utilization.pa_request. Business justification: CMS and state regulators require PA-to-claim reconciliation reporting. The claim header\'s \'prior_authorization_number\' is a denormalized reference to pa_request. A direct FK enables automated PA valid' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaRequest .

ind:primaryBillingProviderId rdf:type rdf:Property ;
    rdfs:label 'Primary Billing Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.provider_provider. Business justification: Required for network participation and quality reporting; each claim must be linked to the provider entity for regulatory and performance analytics.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:renderingFacilityFacilityId rdf:type rdf:Property ;
    rdfs:label 'Rendering Facility Facility Id' ;
    rdfs:comment 'Foreign key linking to provider.facility. Business justification: Inpatient/outpatient claims must reference the rendering facility for DRG grouping, network tier determination, and facility fee adjudication. Health plan operations require facility-level claim aggre' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:tertiaryRenderingProviderId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Rendering Provider Id' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:umCaseId rdf:type rdf:Property ;
    rdfs:label 'Um Case Id' ;
    rdfs:comment 'Foreign key linking to utilization.um_case. Business justification: Needed for Case Management Dashboard; each claim must be tied to the utilization case that governs its clinical and financial review.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UmCase .

ind:adjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Flag' ;
    rdfs:comment 'Indicates if the claim includes any adjustments.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:admissionDate rdf:type rdf:Property ;
    rdfs:label 'Admission Date' ;
    rdfs:comment 'Date of patient admission for inpatient claims.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allowedAmount rdf:type rdf:Property ;
    rdfs:label 'Allowed Amount' ;
    rdfs:comment 'Maximum amount the insurer permits for the services.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billedAmount rdf:type rdf:Property ;
    rdfs:label 'Billed Amount' ;
    rdfs:comment 'Total amount billed to the insurer before adjustments.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingProviderNpi rdf:type rdf:Property ;
    rdfs:label 'Billing Provider Npi' ;
    rdfs:comment 'NPI of the provider responsible for billing.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingType rdf:type rdf:Property ;
    rdfs:label 'Billing Type' ;
    rdfs:comment 'Method of billing for the claim.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Claim Event Timestamp' ;
    rdfs:comment 'Date and time of the primary service rendered for the claim.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:claimLineCount rdf:type rdf:Property ;
    rdfs:label 'Claim Line Count' ;
    rdfs:comment 'Number of line detail records associated with this claim.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Unique claim identifier assigned by the insurer.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimPaidDate rdf:type rdf:Property ;
    rdfs:label 'Claim Paid Date' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Claim Received Date' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimSource rdf:type rdf:Property ;
    rdfs:label 'Claim Source' ;
    rdfs:comment 'Origin of the claim submission.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current processing status of the claim.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Category of claim based on service type.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimVersion rdf:type rdf:Property ;
    rdfs:label 'Claim Version' ;
    rdfs:comment 'Version number of the claim for tracking revisions.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:denialReasonCode rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Code' ;
    rdfs:comment 'Code representing the reason for claim denial, if applicable.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisCodes rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Codes' ;
    rdfs:comment 'Pipe-separated list of diagnosis codes associated with the claim.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeDate rdf:type rdf:Property ;
    rdfs:label 'Discharge Date' ;
    rdfs:comment 'Date of patient discharge for inpatient claims.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drgCode rdf:type rdf:Property ;
    rdfs:label 'Drg Code' ;
    rdfs:comment 'DRG assignment for inpatient claims.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fhirResourceCode rdf:type rdf:Property ;
    rdfs:label 'Fhir Resource Code' ;
    rdfs:comment 'Stable FHIR logical resource id for interop exchange' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHipaaCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Hipaa Compliant' ;
    rdfs:comment 'Flag indicating whether the claim data complies with HIPAA regulations.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMlrExcluded rdf:type rdf:Property ;
    rdfs:label 'Is Mlr Excluded' ;
    rdfs:comment 'Indicates if the claim is excluded from MLR calculations.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSuspended rdf:type rdf:Property ;
    rdfs:label 'Is Suspended' ;
    rdfs:comment 'Indicates if the claim is currently suspended pending additional information.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lengthOfStay rdf:type rdf:Property ;
    rdfs:label 'Length Of Stay' ;
    rdfs:comment 'Number of days between admission and discharge.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Net amount paid to the provider after adjustments.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Status' ;
    rdfs:comment 'Previous status before the most recent transition.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureCodes rdf:type rdf:Property ;
    rdfs:label 'Procedure Codes' ;
    rdfs:comment 'Pipe-separated list of procedure codes billed on the claim.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralProviderNpi rdf:type rdf:Property ;
    rdfs:label 'Referral Provider Npi' ;
    rdfs:comment 'NPI of the referring provider, if applicable.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Due Date' ;
    rdfs:comment 'Date by which the claim must be processed to meet service level agreement.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaMet rdf:type rdf:Property ;
    rdfs:label 'Sla Met' ;
    rdfs:comment 'Flag indicating whether the claim met the SLA deadline.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Status Change Timestamp' ;
    rdfs:comment 'Timestamp of the most recent status transition.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Reason why the claim was suspended.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Primary key for line' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:authServiceLineId rdf:type rdf:Property ;
    rdfs:label 'Auth Service Line Id' ;
    rdfs:comment 'Foreign key linking to utilization.auth_service_line. Business justification: Audit of Prior Authorization compliance; claim line references the authorized service line to verify authorized quantity, price, and status.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuthServiceLine .

ind:claimHeaderId rdf:type rdf:Property ;
    rdfs:label 'Claim Header Id' ;
    rdfs:comment 'Identifier of the parent claim to which this line belongs.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:drugMasterId rdf:type rdf:Property ;
    rdfs:label 'Drug Master Id' ;
    rdfs:comment 'Foreign key linking to pharmacy.drug_master. Business justification: Medical claim lines for physician-administered drugs (chemotherapy, biologics, J-codes) carry NDC codes. Linking to drug_master normalizes drug reference data, enabling cross-channel drug utilization ' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugMaster .

ind:anesthesiaMinutes rdf:type rdf:Property ;
    rdfs:label 'Anesthesia Minutes' ;
    rdfs:comment 'Total minutes of anesthesia administered for the line (if applicable).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cobPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Cob Paid Amount' ;
    rdfs:comment 'Amount paid by secondary/tertiary payers under COB processing.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyIndicator rdf:type rdf:Property ;
    rdfs:label 'Emergency Indicator' ;
    rdfs:comment 'True if the service was rendered as an emergency.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epsdtIndicator rdf:type rdf:Property ;
    rdfs:label 'Epsdt Indicator' ;
    rdfs:comment 'True if the service qualifies for EPSDT coverage (for Medicaid).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:familyPlanningIndicator rdf:type rdf:Property ;
    rdfs:label 'Family Planning Indicator' ;
    rdfs:comment 'True if the service is related to family planning.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential number of the line within the claim.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current processing status of the claim line.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Category of service rendered on the line.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifier1 rdf:type rdf:Property ;
    rdfs:label 'Modifier 1' ;
    rdfs:comment 'First two-character modifier associated with the procedure code.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifier2 rdf:type rdf:Property ;
    rdfs:label 'Modifier 2' ;
    rdfs:comment 'Second two-character modifier associated with the procedure code.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifier3 rdf:type rdf:Property ;
    rdfs:label 'Modifier 3' ;
    rdfs:comment 'Third two-character modifier associated with the procedure code.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifier4 rdf:type rdf:Property ;
    rdfs:label 'Modifier 4' ;
    rdfs:comment 'Fourth two-character modifier associated with the procedure code.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientResponsibilityAmount rdf:type rdf:Property ;
    rdfs:label 'Patient Responsibility Amount' ;
    rdfs:comment 'Sum of copay, coinsurance, and deductible amounts owed by the member.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placeOfServiceCode rdf:type rdf:Property ;
    rdfs:label 'Place Of Service Code' ;
    rdfs:comment 'Two-digit code indicating where the service was provided.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Number' ;
    rdfs:comment 'Reference number of the prior authorization associated with the line.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureCode rdf:type rdf:Property ;
    rdfs:label 'Procedure Code' ;
    rdfs:comment 'Standard procedure code representing the service rendered.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarkCode rdf:type rdf:Property ;
    rdfs:label 'Remark Code' ;
    rdfs:comment 'Additional informational code attached to the line.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Code' ;
    rdfs:comment 'Four-digit code used for institutional billing to indicate type of service.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDate rdf:type rdf:Property ;
    rdfs:label 'Service Date' ;
    rdfs:comment 'Date on which the service was provided.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unitsOfService rdf:type rdf:Property ;
    rdfs:label 'Units Of Service' ;
    rdfs:comment 'Quantity of the service rendered (e.g., number of visits, dosage units).' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisId rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Id' ;
    rdfs:comment 'Primary key for diagnosis' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clinicalCriteriaId rdf:type rdf:Property ;
    rdfs:label 'Clinical Criteria Id' ;
    rdfs:comment 'Foreign key linking to utilization.clinical_criteria. Business justification: Claim diagnoses are evaluated against clinical criteria during medical necessity review. Direct FK enables medical necessity audit trails linking specific diagnosis codes to the criteria version appli' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalCriteria .

ind:riskHccMappingId rdf:type rdf:Property ;
    rdfs:label 'Risk Hcc Mapping Id' ;
    rdfs:comment 'Foreign key linking to risk.hcc_mapping. Business justification: Clinical quality and risk-adjustment reports need each diagnosis linked to its HCC mapping for proper risk score calculations.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HccMapping .

ind:diagnosisDate rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Date' ;
    rdfs:comment 'Calendar date the diagnosis was documented on the claim.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:diagnosisStatus rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Status' ;
    rdfs:comment 'Operational status indicating if the diagnosis line is active, pending review, or logically deleted.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisType rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Type' ;
    rdfs:comment 'Specifies the role of the diagnosis (e.g., principal, admitting, external cause, other).' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drgDescription rdf:type rdf:Property ;
    rdfs:label 'Drg Description' ;
    rdfs:comment 'Textual description of the DRG code.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hccCategory rdf:type rdf:Property ;
    rdfs:label 'Hcc Category' ;
    rdfs:comment 'HCC category code used for risk-adjustment and RAF calculations.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icd10Code rdf:type rdf:Property ;
    rdfs:label 'Icd10 Code' ;
    rdfs:comment 'Standard ICD-10 diagnosis code associated with the mapping.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icdVersion rdf:type rdf:Property ;
    rdfs:label 'Icd Version' ;
    rdfs:comment 'Indicates whether the diagnosis code follows ICD-9-CM or ICD-10-CM standards.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineQuantity rdf:type rdf:Property ;
    rdfs:label 'Line Quantity' ;
    rdfs:comment 'Number of times the same diagnosis appears on the claim; typically 1.' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:poaIndicator rdf:type rdf:Property ;
    rdfs:label 'Poa Indicator' ;
    rdfs:comment 'Indicates if the condition was present at the time of admission (Y=Yes, N=No, U=Unknown).' ;
    rdfs:domain ind:Diagnosis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentOnAdmissionIndicator rdf:type rdf:Property ;
    rdfs:label 'Present On Admission Indicator' ;
    rdfs:domain ind:Diagnosis ;
