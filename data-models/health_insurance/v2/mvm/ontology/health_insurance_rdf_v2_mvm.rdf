    rdfs:comment 'Foreign key linking to plan.benefit_package. Business justification: A policy is written against a specific benefit package that defines its deductibles, copays, and OOP maximums. This link is essential for claims adjudication, cost-sharing calculation, renewal process' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPackage .

ind:groupPartyId rdf:type rdf:Property ;
    rdfs:label 'Group Party Id' ;
    rdfs:comment 'Foreign key linking to contract.party. Business justification: Group insurance policies are issued under employer group contracts where the employer is a contract.party. Group billing, COBRA administration, and employer reporting all require linking a policy to i' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:parentPolicyId rdf:type rdf:Property ;
    rdfs:label 'Parent Policy Id' ;
    rdfs:comment 'Self-referencing FK on policy (parent_policy_id)' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:vbcContractId rdf:type rdf:Property ;
    rdfs:label 'Vbc Contract Id' ;
    rdfs:comment 'Foreign key linking to contract.vbc_contract. Business justification: VBC/ACO programs attribute members to a vbc_contract based on their active policy. Performance period reporting, shared savings calculations, and CMS reconciliation all require knowing which policies ' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VbcContract .

ind:coverageLimitAmount rdf:type rdf:Property ;
