    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfNetworkCoinsurancePct rdf:type rdf:Property ;
    rdfs:label 'Out Of Network Coinsurance Pct' ;
    rdfs:comment 'Percentage of allowed amount the member pays for out-of-network services when benefit type is coinsurance.' ;
