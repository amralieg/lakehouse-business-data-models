    rdfs:comment 'FDA-issued establishment identifier for facilities manufacturing FDA-regulated products (cosmetics, OTC drugs, food). Required for US market distribution.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Gmp Certification Date' ;
    rdfs:comment 'Date when the facility received its current GMP certification.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpCertified rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified' ;
    rdfs:comment 'Indicates whether the facility holds current Good Manufacturing Practice certification required for consumer goods production.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Gmp Expiration Date' ;
    rdfs:comment 'Date when the current GMP certification expires and requires renewal.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
