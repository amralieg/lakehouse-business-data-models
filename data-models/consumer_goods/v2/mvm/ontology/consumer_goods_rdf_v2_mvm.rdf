    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverTimeStandardMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Standard Minutes' ;
    rdfs:comment 'Standard time in minutes required to change over the production line from one product or batch to another. Used for production scheduling and OEE loss calculation.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleaningValidationProtocol rdf:type rdf:Property ;
    rdfs:label 'Cleaning Validation Protocol' ;
    rdfs:comment 'Reference to the cleaning validation protocol document applicable to this production line. Ensures GMP compliance and prevents cross-contamination.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewSizeStandard rdf:type rdf:Property ;
