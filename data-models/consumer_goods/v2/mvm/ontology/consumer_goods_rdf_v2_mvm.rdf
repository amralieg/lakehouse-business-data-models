ind:humidityRangePercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Range Percent' ;
    rdfs:comment 'Acceptable relative humidity range for the production line as a percentage. Format: min-max (e.g., 40-60). Used for environmental monitoring and compliance.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installedPowerKw rdf:type rdf:Property ;
    rdfs:label 'Installed Power Kw' ;
