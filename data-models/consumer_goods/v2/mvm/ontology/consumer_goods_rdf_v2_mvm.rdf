    rdfs:label 'Inspection Result Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_result. Business justification: A nonconformance event is frequently triggered by a specific failed inspection result (e.g., a characteristic measurement outside specification limits). Adding inspection_result_id to nonconformance f' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionResult .

ind:characteristicCode rdf:type rdf:Property ;
    rdfs:label 'Characteristic Code' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicName rdf:type rdf:Property ;
