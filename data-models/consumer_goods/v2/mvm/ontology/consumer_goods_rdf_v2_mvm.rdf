    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Standard operating shift pattern for the facility: single (8 hours), two_shift (16 hours), three_shift (24 hours), continuous (24/7), flexible (variable).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:squareFootage rdf:type rdf:Property ;
    rdfs:label 'Square Footage' ;
    rdfs:comment 'Total floor area of the manufacturing facility in square feet, including production, warehouse, and administrative spaces.' ;
