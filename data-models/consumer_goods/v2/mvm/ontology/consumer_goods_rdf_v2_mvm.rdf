    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:efficiencyPct rdf:type rdf:Property ;
    rdfs:label 'Efficiency Pct' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyConsumptionKwhPerHour rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Hour' ;
    rdfs:comment 'Average energy consumption in kilowatt-hours per operating hour, supporting sustainability reporting and cost allocation per ISO 14001 environmental management.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Qualification Status' ;
    rdfs:comment 'Current qualification status of the work center per GMP requirements. IQ (Installation Qualification), OQ (Operational Qualification), PQ (Performance Qualification) track equipment validation stages per ISO 22716.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousAreaClassification rdf:type rdf:Property ;
    rdfs:label 'Hazardous Area Classification' ;
    rdfs:comment 'Electrical area classification for work centers handling flammable or explosive materials, ensuring compliance with Occupational Safety and Health Administration (OSHA) and ATEX directives. [ENUM-REF-CANDIDATE: non_hazardous|class_1_div_1|class_1_div_2|class_2_div_1|class_2_div_2|atex_zone_0|atex_zone_1|atex_zone_2 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityControlledFlag rdf:type rdf:Property ;
