    rdfs:range xsd:boolean .

ind:iso22716ComplianceTier rdf:type rdf:Property ;
    rdfs:label 'Iso 22716 Compliance Tier' ;
    rdfs:comment 'Internal classification of the facility\'s compliance level with ISO 22716 cosmetics GMP standards: tier_1 (full compliance), tier_2 (partial compliance), tier_3 (basic compliance), non_compliant.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the facility holds ISO 9001 Quality Management System certification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditDate rdf:type rdf:Property ;
