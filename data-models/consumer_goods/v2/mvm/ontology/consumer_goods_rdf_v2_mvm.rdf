ind:nonconformanceId rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Id' ;
    rdfs:comment 'Foreign key linking to quality.nonconformance. Business justification: Supplier nonconformance management: when received goods fail inspection, a nonconformance record is raised against the receipt. This FK enables supplier quality tracking, CAPA initiation from receipt ' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
