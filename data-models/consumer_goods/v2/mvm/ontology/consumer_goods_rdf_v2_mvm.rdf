    rdfs:comment 'Standard time in minutes required to clean, sanitize, and reset the work center after production completion per Good Manufacturing Practice (GMP) requirements.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether this work center operates in a temperature-controlled environment requiring environmental monitoring per GMP standards.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utilizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Percent' ;
    rdfs:comment 'Target utilization rate as a percentage of available capacity, used for capacity planning and Overall Equipment Effectiveness (OEE) benchmarking.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Work Center Status' ;
    rdfs:comment 'Current operational status of the work center indicating availability for production scheduling and capacity planning.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterType rdf:type rdf:Property ;
    rdfs:label 'Work Center Type' ;
    rdfs:comment 'Classification of the work center by its primary function in the manufacturing process. Categorizes equipment by operational role.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingBomId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Bom Id' ;
    rdfs:comment 'Unique identifier for the bill of materials record. Primary key for the manufacturing BOM entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufacturingBom .

ind:primaryManufacturingSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Manufacturing Sku Id' ;
    rdfs:comment 'Reference to the finished good or semi-finished SKU that this BOM defines. Links to the product master for which this material structure applies.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:specificationId rdf:type rdf:Property ;
    rdfs:label 'Specification Id' ;
    rdfs:comment 'Foreign key linking to quality.specification. Business justification: Manufacturing BOMs reference quality specifications for components (raw materials, packaging). The manufacturing_bom.regulatory_compliance_notes and inci_name attributes indicate spec-level compliance' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:allergenFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Flag' ;
    rdfs:comment 'Indicates whether this component contains or may contain allergens as defined by FDA and EU REACH regulations. True if allergen present. Used for product labeling, consumer safety warnings, and regulatory compliance.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternativeItemPriority rdf:type rdf:Property ;
    rdfs:label 'Alternative Item Priority' ;
    rdfs:comment 'The selection priority for this component within its alternative item group. Lower numbers indicate higher priority. Used by MRP to determine preferred material selection when multiple alternatives are available.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date when this BOM version was formally approved for production use. Establishes the official release date for regulatory compliance and change control purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'The name or identifier of the person who approved this BOM version for production use. Required for GMP compliance and quality assurance. Typically a product development manager, quality manager, or regulatory affairs specialist.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Indicates whether this component is automatically consumed (backflushed) when the finished good is confirmed in the MES system, rather than requiring explicit material issue transactions. True if backflushed. Common for high-volume, low-value components.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the base quantity (e.g., EA for each, KG for kilogram, L for liter, BOX for box). Must align with the SKU primary UOM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM. Active BOMs are used for production planning and MRP runs. Inactive or obsolete BOMs are retained for historical reference and regulatory traceability.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentEffectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Component Effective End Date' ;
    rdfs:comment 'The date after which this specific component is no longer valid within the BOM structure. Nullable for open-ended components. Used for material phase-out and supplier transition management.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:componentEffectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Component Effective Start Date' ;
    rdfs:comment 'The date from which this specific component becomes valid within the BOM structure. Supports phased material transitions, supplier changes, and cost optimization initiatives.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:componentItemCategory rdf:type rdf:Property ;
    rdfs:label 'Component Item Category' ;
    rdfs:comment 'Classification of the component type. Stock items are inventory-managed materials, non-stock are direct procurement items, phantom are intermediate assemblies not physically stocked, text items are instructions, and variable size items have flexible dimensions.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentItemNumber rdf:type rdf:Property ;
    rdfs:label 'Component Item Number' ;
    rdfs:comment 'Sequential line number for each component within the BOM structure. Defines the order of components for display, reporting, and regulatory ingredient listing (descending order by weight for INCI compliance).' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentQuantity rdf:type rdf:Property ;
    rdfs:label 'Component Quantity' ;
    rdfs:comment 'The quantity of this component required to produce the base quantity of the finished good. Used for MRP explosion, production order material requirements, and COGS calculation.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Component Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the component quantity (e.g., KG for raw materials, EA for packaging units, L for liquids). Must align with the component material master UOM.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Percentage' ;
    rdfs:comment 'The percentage of total product cost attributed to this component. Used for COGS calculation, profitability analysis, and cost optimization initiatives. Sum of all component cost allocations should equal 100% for the BOM.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalComponentFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Component Flag' ;
    rdfs:comment 'Indicates whether this component is critical for product quality, safety, or regulatory compliance. True if critical. Triggers enhanced quality control, supplier qualification requirements, and inventory safety stock policies.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The date after which this BOM version is no longer valid for new production orders. Nullable for open-ended BOMs. Used for phase-out management and regulatory compliance transitions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The date from which this BOM version becomes valid for production planning and MRP explosion. Supports planned material transitions and new product launches.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotSizeRequirement rdf:type rdf:Property ;
    rdfs:label 'Lot Size Requirement' ;
    rdfs:comment 'Defines the lot sizing rule for this component in production orders. Exact requires precise quantity, minimum allows overages, multiple requires quantities in specific increments, none has no restriction. Impacts material planning and waste management.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingBomStatus rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Bom Status' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumLotSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Lot Size' ;
    rdfs:comment 'The minimum quantity that must be procured or produced for this component. Driven by supplier MOQ, production batch constraints, or economic order quantity calculations. Nullable if no minimum applies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plmSystemReference rdf:type rdf:Property ;
    rdfs:label 'Plm System Reference' ;
    rdfs:comment 'External reference identifier linking this BOM to the source PLM system record. Enables traceability to engineering change orders, formulation documents, and R&D specifications.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text field capturing regulatory compliance requirements, restrictions, or special handling instructions for this component. Includes FDA registration numbers, EU REACH compliance status, GMP requirements, and safety data sheet references.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapFactorPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Percentage' ;
    rdfs:comment 'The expected waste or loss percentage for this component during production. Used to adjust gross material requirements in MRP runs. Typical values range from 0% to 10% depending on material type and process complexity.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Unique identifier for the production routing master record. Primary key.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when this routing was approved for production use. Supports audit trail and compliance requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeoverTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Minutes' ;
    rdfs:comment 'Time required to transition production lines from the previous product to this routing. Critical for production scheduling and minimizing downtime.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedScrapPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Scrap Percentage' ;
    rdfs:comment 'Overall expected scrap percentage for the routing, representing anticipated waste or defects. Used for material planning and cost estimation.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Yield Percentage' ;
    rdfs:comment 'Overall expected yield percentage for the routing, representing the ratio of good output to total input. Used for production planning and variance analysis.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Critical Flag' ;
    rdfs:comment 'Indicates whether this routing includes GMP-critical operations requiring enhanced documentation, validation, and compliance controls per ISO 22716 and FDA regulations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipcCheckpointCount rdf:type rdf:Property ;
    rdfs:label 'Ipc Checkpoint Count' ;
    rdfs:comment 'Number of in-process control checkpoints defined in this routing. IPC checkpoints are quality inspection points during production per ISO 22716 and GMP requirements.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotSizeRestriction rdf:type rdf:Property ;
    rdfs:label 'Lot Size Restriction' ;
    rdfs:comment 'Constraint on production lot sizes for this routing. Fixed requires exact base quantity; minimum/maximum define bounds; multiple requires lot sizes to be multiples of base quantity; none allows any lot size.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumLotSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Lot Size' ;
    rdfs:comment 'Maximum production lot size allowed for this routing. Nullable if no maximum constraint exists.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationCount rdf:type rdf:Property ;
    rdfs:label 'Operation Count' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationSequence rdf:type rdf:Property ;
    rdfs:label 'Operation Sequence' ;
    rdfs:comment 'JSON array or delimited string capturing the complete sequence of operation steps. Each operation includes: operation_number, work_center_code, operation_description, control_key (internal_processing|external_processing|milestone), setup_time_minutes, machine_time_minutes, labor_time_minutes, yield_quantity, scrap_percentage, gmp_critical_step_flag, ipc_checkpoint_flag. This is the single authoritative source for all routing operation data — no separate operation entity exists.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionSchedulerCode rdf:type rdf:Property ;
    rdfs:label 'Production Scheduler Code' ;
    rdfs:comment 'Code identifying the production scheduling strategy or algorithm used for this routing (e.g., forward scheduling, backward scheduling, finite capacity).' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Business identifier for the routing. Externally-known unique code used in production planning and scheduling systems.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Status' ;
    rdfs:comment 'Current lifecycle status of the routing. Active routings are available for production scheduling; draft routings are under development; inactive routings are temporarily disabled; obsolete routings are retired; under_review routings are pending approval.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingType rdf:type rdf:Property ;
    rdfs:label 'Routing Type' ;
    rdfs:comment 'Classification of the routing defining its usage pattern. Standard routings are default production paths; reference routings are templates; rate routings define production rates; alternative routings provide backup paths; special routings are for one-time or custom production runs.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Amount' ;
    rdfs:comment 'Standard production cost per base quantity for this routing, including labor, machine, and overhead costs. Used for cost accounting and variance analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLaborTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Labor Time Minutes' ;
    rdfs:comment 'Cumulative labor time across all operations in the routing, used for workforce planning and standard cost calculation.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMachineTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Machine Time Minutes' ;
    rdfs:comment 'Cumulative machine processing time across all operations in the routing, used for capacity planning and Overall Equipment Effectiveness (OEE) calculations.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSetupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Setup Time Minutes' ;
    rdfs:comment 'Cumulative setup time across all operations in the routing, used for capacity planning and scheduling.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStandardLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Standard Lead Time Hours' ;
    rdfs:comment 'Total cumulative lead time in hours required to complete all operations in this routing, including setup, processing, and queue times. Used for Material Requirements Planning (MRP) and capacity planning.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStandardTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Standard Time Minutes' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Order Id' ;
    rdfs:comment 'Unique identifier for the production order. Primary key for the production order entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:demandPlanId rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.demand_plan. Business justification: In consumer goods S&OP, production orders are created to fulfill demand plan signals. This FK enables demand-to-production traceability for production planning reports, OTIF analysis, and IBP reconcil' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandPlan .

ind:eventId rdf:type rdf:Property ;
    rdfs:label 'Event Id' ;
    rdfs:comment 'Foreign key linking to promotion.promotion_event. Business justification: Consumer goods manufacturers create production orders for specific promotion events (e.g., display-ready pallet builds, promotional bundles). This link enables post-event analysis comparing actual pro' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Event .

ind:planningRunId rdf:type rdf:Property ;
    rdfs:label 'Planning Run Id' ;
    rdfs:comment 'Foreign key linking to supply.planning_run. Business justification: Production orders created directly by MRP runs (without planned order conversion) need traceability to the planning run. Enables planning run impact analysis and production schedule reconciliation — s' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanningRun .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Foreign key linking to sales.order. Business justification: Order fulfillment process requires linking each production order to the originating sales order to track manufacturing against sales commitments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:tradePromotionId rdf:type rdf:Property ;
    rdfs:label 'Trade Promotion Id' ;
    rdfs:comment 'Foreign key linking to promotion.trade_promotion. Business justification: Production orders in consumer goods are frequently created to fulfill promotional volume commitments. Linking production_order to trade_promotion enables S&OP reconciliation reports comparing planned ' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradePromotion .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual cost incurred for the production order. Includes material, labor, and overhead costs. Used for variance analysis.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Timestamp' ;
    rdfs:comment 'Actual date and time when production execution completed. Used for OEE calculation and performance analysis.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when production execution began on the shop floor. Captured from MES system.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Unique batch or lot number assigned to the production run. Critical for traceability and recall management per GMP requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'Actual quantity produced and confirmed as good output. Represents yield after quality inspection.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costObject rdf:type rdf:Property ;
    rdfs:label 'Cost Object' ;
    rdfs:comment 'Cost object (production order number or process order) used for collecting actual costs. Links to CO-PC product costing.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Minutes' ;
    rdfs:comment 'Total unplanned downtime in minutes during production execution. Impacts OEE availability component.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Flag' ;
    rdfs:comment 'Indicates whether this production order is subject to GMP compliance requirements per ISO 22716 standards. True for regulated products.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'Inspection lot number created for quality control of the production output. Links to QM inspection results.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'SAP material number for the finished good being produced. Business identifier for the product in ERP system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpController rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller' ;
    rdfs:comment 'Three-character code identifying the MRP controller responsible for planning this material. Links to planner master data.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeePercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Percentage' ;
    rdfs:comment 'Overall Equipment Effectiveness percentage for this production run. Calculated as Availability × Performance × Quality. Industry standard KPI.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business identifier for the production order. Externally-known unique order number assigned by SAP S/4HANA PP system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Quantity' ;
    rdfs:comment 'Planned quantity to be produced in base unit of measure. Target output for the production order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the production order. CRTD=Created, REL=Released, PCNF=Partially Confirmed, TECO=Technically Complete, CNF=Confirmed, DLV=Delivered, CLSD=Closed. [ENUM-REF-CANDIDATE: CRTD|REL|PCNF|TECO|CNF|DLV|CLSD — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of production order. PP01=Standard Production, PP03=Rework, PP05=Co-Product, PP10=Process Order, PP20=Batch Order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCost rdf:type rdf:Property ;
    rdfs:label 'Planned Cost' ;
    rdfs:comment 'Standard or planned cost for producing the order quantity. Calculated from BOM and routing costs.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'The quantity of the SKU planned to be produced or procured in this order, expressed in the base unit of measure.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level for production scheduling. 1=Highest priority (rush/expedite), 5=Lowest priority (standard). Used for sequencing and resource allocation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionSupervisor rdf:type rdf:Property ;
    rdfs:label 'Production Supervisor' ;
    rdfs:comment 'Name of the production supervisor responsible for overseeing execution of this order on the shop floor.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Indicates whether quality inspection is mandatory before goods receipt. Drives QM integration and inspection lot creation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releasedBy rdf:type rdf:Property ;
    rdfs:label 'Released By' ;
    rdfs:comment 'User ID of the person who released the production order for execution. Audit trail for production authorization.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'Date and time when the production order was released for shop floor execution. Triggers material availability check and capacity reservation.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledFinishDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Date' ;
    rdfs:comment 'Planned date when production is scheduled to complete. Used for capacity planning and delivery commitments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date when production is scheduled to begin. Set during production planning and MRP run.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'Quantity of material scrapped or rejected during production. Used for yield analysis and cost accounting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementRule rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule' ;
    rdfs:comment 'Rule for settling production order costs. FUL=Full settlement, PAR=Partial settlement, PER=Periodic settlement.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uom rdf:type rdf:Property ;
    rdfs:label 'Uom' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'Actual yield percentage calculated as (confirmed_quantity / order_quantity) * 100. Key performance metric for production efficiency.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchRecordId rdf:type rdf:Property ;
    rdfs:label 'Batch Record Id' ;
    rdfs:comment 'Unique identifier for the electronic batch manufacturing record (eBMR). Primary key for GMP-compliant batch traceability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Batch-to-PO traceability is needed for audit, recall, and cost allocation linking each manufactured batch to its sourcing PO.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Actual cost per unit incurred for this batch. Includes material, labor, and overhead variances.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSize rdf:type rdf:Property ;
    rdfs:label 'Batch Size' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeActual rdf:type rdf:Property ;
    rdfs:label 'Batch Size Actual' ;
    rdfs:comment 'Actual production quantity achieved for this batch. Used for yield calculation and inventory reconciliation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizePlanned rdf:type rdf:Property ;
    rdfs:label 'Batch Size Planned' ;
    rdfs:comment 'Planned production quantity for this batch as specified in the production order. Measured in base unit of measure.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the batch. Controls inventory availability and distribution eligibility per GMP workflow.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchUom rdf:type rdf:Property ;
    rdfs:label 'Batch Uom' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Minutes' ;
    rdfs:comment 'Time in minutes required for line changeover before this batch. Key metric for SMED and lean manufacturing initiatives.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:electronicSignatureCount rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Count' ;
    rdfs:comment 'Number of electronic signatures captured during batch record lifecycle. Required for FDA 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant Flag' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Gmp Deviation Count' ;
    rdfs:comment 'Number of GMP deviations recorded for this batch. Used for quality trend analysis and CAPA tracking.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Deviation Flag' ;
    rdfs:comment 'Indicates whether any GMP deviations were recorded during batch production. Triggers quality review workflow.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotGenealogyCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Lot Genealogy Complete Flag' ;
    rdfs:comment 'Indicates whether complete raw material lot traceability has been captured for this batch. Required for recall readiness.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date when the product was manufactured by the supplier. Used for shelf-life calculations and FEFO inventory rotation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'Calendar date of batch production. Printed on product packaging for consumer information and regulatory compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing End Timestamp' ;
    rdfs:comment 'Date and time when batch production was completed and final packaging finished. Used for cycle time analysis.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manufacturingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Start Timestamp' ;
    rdfs:comment 'Date and time when batch production was initiated on the shop floor. Captured from MES system.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Release Flag' ;
    rdfs:comment 'Indicates whether the batch has been released by Quality Assurance for distribution. Required before inventory availability.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Quality Release Timestamp' ;
    rdfs:comment 'Date and time when Quality Assurance approved the batch for release. Marks transition from quarantine to available inventory.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether this batch is subject to a product recall. Triggers supply chain hold and customer notification.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Recall Initiated Date' ;
    rdfs:comment 'Date when recall was initiated for this batch. Used for regulatory reporting and recall effectiveness tracking.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordLockedFlag rdf:type rdf:Property ;
    rdfs:label 'Record Locked Flag' ;
    rdfs:comment 'Indicates whether this batch record is locked from further edits. Required for GMP record integrity after quality release.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether batch is on regulatory hold pending investigation or approval. Prevents distribution until cleared.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'The date when this standard cost estimate was officially released and became active for inventory valuation and COGS calculation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Lifecycle status of the cost estimate: draft (in progress), released (approved for use), locked (frozen for audit), archived (historical).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkQuantity rdf:type rdf:Property ;
    rdfs:label 'Rework Quantity' ;
    rdfs:comment 'Quantity of product requiring rework during batch production. Indicator of process capability and quality issues.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:veevaVaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Reference' ;
    rdfs:comment 'Reference to the master batch record document stored in Veeva Vault. Links to regulatory document management system.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPct rdf:type rdf:Property ;
    rdfs:label 'Yield Pct' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Production Confirmation Id' ;
    rdfs:comment 'Unique identifier for the production confirmation record. Primary key for shop floor execution tracking.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_lot. Business justification: In-process control (IPC) inspections are triggered at production confirmation milestones. The production_confirmation.quality_inspection_required_flag signals an inspection lot must be created. Direct' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'SAP CO activity type code representing the type of work performed (e.g., machine hours, labor hours, setup hours) for cost allocation purposes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual date and time when the operation was completed and confirmed by the operator. Used for OEE calculation and production order settlement.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLaborTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Time Minutes' ;
    rdfs:comment 'Actual operator labor time spent on this operation including manual work, monitoring, and quality checks. Measured in minutes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMachineTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Machine Time Minutes' ;
    rdfs:comment 'Actual time the machine or equipment was actively running during this operation. Excludes setup and downtime. Measured in minutes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSetupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Setup Time Minutes' ;
    rdfs:comment 'Actual time spent on machine setup, changeover, and preparation activities before production began. Measured in minutes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual date and time when the operator began executing this operation on the shop floor. Captured from MES or manual confirmation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationNotes rdf:type rdf:Property ;
    rdfs:label 'Confirmation Notes' ;
    rdfs:comment 'Free-text notes or comments entered by the operator or supervisor regarding this operation execution, including any issues or observations.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'System timestamp when this confirmation record was created and submitted to the ERP or MES system.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationType rdf:type rdf:Property ;
    rdfs:label 'Confirmation Type' ;
    rdfs:comment 'Classification of the confirmation event indicating whether this is a partial progress update, final completion, milestone checkpoint, rework confirmation, or cancellation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedScrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Scrap Quantity' ;
    rdfs:comment 'Actual quantity of defective or waste material generated during this operation. Used for yield variance analysis and quality tracking.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedYieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Yield Quantity' ;
    rdfs:comment 'Actual quantity of good output produced and confirmed for this operation. Measured in the base unit of measure for the material.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFinalConfirmation rdf:type rdf:Property ;
    rdfs:label 'Is Final Confirmation' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mesTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Mes Transaction Reference' ;
    rdfs:comment 'Unique transaction reference from the Siemens Opcenter MES system that originated this confirmation. Used for traceability and system reconciliation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeAvailabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Availability Percent' ;
    rdfs:comment 'Calculated availability component of OEE for this operation, representing the percentage of scheduled time that equipment was available for production.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeePerformancePercent rdf:type rdf:Property ;
    rdfs:label 'Oee Performance Percent' ;
    rdfs:comment 'Calculated performance component of OEE for this operation, representing actual production speed versus ideal speed.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeQualityPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Quality Percent' ;
    rdfs:comment 'Calculated quality component of OEE for this operation, representing the percentage of good output versus total output produced.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationStatus rdf:type rdf:Property ;
    rdfs:label 'Operation Status' ;
    rdfs:comment 'Current lifecycle status of the manufacturing operation indicating its execution state in the production workflow.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'Financial posting date when this confirmation was recorded in the ERP system for inventory and cost accounting purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether this operation output requires quality inspection before release to inventory or next operation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this confirmation has been reversed or cancelled due to error correction or process adjustment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Standardized code explaining why this confirmation was reversed, if applicable. Used for process improvement and error tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Flag' ;
    rdfs:comment 'Indicates whether this confirmation represents a rework operation to correct defects from a previous production run.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:runTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Run Time Minutes' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'Planned completion date and time for this operation as determined by production scheduling or MES system.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'Planned start date and time for this operation as determined by production scheduling or MES system.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Production shift identifier during which this operation was executed (e.g., SHIFT_1, DAY, NIGHT). Used for shift performance analysis.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Standardized code explaining any significant variance between planned and actual quantities or times. Used for root cause analysis.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Business identifier for the work order assigned to this manufacturing operation. Externally visible reference used across shop floor systems.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedOrderId rdf:type rdf:Property ;
    rdfs:label 'Planned Order Id' ;
    rdfs:comment 'Unique system-generated identifier for the planned order record. Primary key for the planned order entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlannedOrder .

ind:convertedProductionOrderId rdf:type rdf:Property ;
    rdfs:label 'Converted Production Order Id' ;
    rdfs:comment 'Reference to the production order that was created from this planned order upon conversion. Null if not yet converted.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:convertedPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Converted Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: MRP plan-to-procure conversion: planned orders with procurement_type=\'external\' convert to purchase orders. Role-prefixed \'converted_\' mirrors existing converted_production_order_id pattern. Enables M' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:safetyStockId rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Id' ;
    rdfs:comment 'Foreign key linking to supply.safety_stock. Business justification: In consumer goods MRP, planned orders are triggered by safety stock replenishment signals. This FK links the planned order to the safety stock record that triggered it, enabling safety stock coverage ' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyStock .

ind:availabilityDate rdf:type rdf:Property ;
    rdfs:label 'Availability Date' ;
    rdfs:comment 'The date when the produced or procured material from this planned order is expected to be available for consumption or shipment.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'The date when this planned order was converted to a production order. Null if not yet converted.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'Indicates whether this planned order has been converted to a production order: NOT_CONVERTED (still in planning), PARTIALLY_CONVERTED (split conversion), FULLY_CONVERTED (completely converted).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User ID or system identifier of the person or automated process that created this planned order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSourceType rdf:type rdf:Property ;
    rdfs:label 'Demand Source Type' ;
    rdfs:comment 'Classification of the demand signal that triggered this planned order: FORECAST (demand planning), CUSTOMER_ORDER (firm sales order), STOCK_TRANSFER (inter-plant), SAFETY_STOCK (replenishment), PROMOTION (trade promotion demand).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionMessageCode rdf:type rdf:Property ;
    rdfs:label 'Exception Message Code' ;
    rdfs:comment 'Code representing MRP exception conditions (e.g., EX01 = reschedule in, EX02 = reschedule out, EX03 = cancel, EX10 = expedite). Empty if no exception.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionMessageText rdf:type rdf:Property ;
    rdfs:label 'Exception Message Text' ;
    rdfs:comment 'Human-readable description of the MRP exception condition requiring planner attention.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmedFlag rdf:type rdf:Property ;
    rdfs:label 'Firmed Flag' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firmingDate rdf:type rdf:Property ;
    rdfs:label 'Firming Date' ;
    rdfs:comment 'The date when this planned order was firmed by a planner. Null if not yet firmed.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firmingIndicator rdf:type rdf:Property ;
    rdfs:label 'Firming Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this planned order is firmed (locked from automatic MRP changes). True = firmed, False = subject to MRP rescheduling.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ibpPlanVersion rdf:type rdf:Property ;
    rdfs:label 'Ibp Plan Version' ;
    rdfs:comment 'Version identifier from SAP IBP system that generated the demand signal driving this planned order. Format: IBP-YYYYMM.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User ID or system identifier of the person or automated process that last modified this planned order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeKey rdf:type rdf:Property ;
    rdfs:label 'Lot Size Key' ;
    rdfs:comment 'Code indicating the lot-sizing procedure used: EX (exact lot size), HB (lot-for-lot), FX (fixed lot size), PD (periodic lot size), WM (weekly lot size).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedFinishDate rdf:type rdf:Property ;
    rdfs:label 'Planned Finish Date' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Planned Order Number' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriod rdf:type rdf:Property ;
    rdfs:label 'Planning Period' ;
    rdfs:comment 'The planning time bucket this order belongs to, expressed as YYYY-Wnn (week), YYYY-Mnn (month), or YYYY-Qn (quarter). Used for MPS and S&OP alignment.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningStrategyGroup rdf:type rdf:Property ;
    rdfs:label 'Planning Strategy Group' ;
    rdfs:comment 'Two-digit code defining the planning strategy (e.g., 10 = make-to-stock, 20 = make-to-order, 40 = planning with final assembly, 50 = planning without final assembly).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Priority level assigned to this planned order for scheduling and resource allocation: LOW, NORMAL, HIGH, URGENT.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'Indicates whether this planned order is for in-house production (IN_HOUSE), external procurement (EXTERNAL), or can be either (BOTH).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'The inventory level that triggers generation of a planned order for replenishment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'The safety stock level maintained for this SKU at this plant, influencing planned order generation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version identifier for the MPS schedule that generated or governs this planned order. Enables tracking of schedule changes over time.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopCycleReference rdf:type rdf:Property ;
    rdfs:label 'Sop Cycle Reference' ;
    rdfs:comment 'Reference to the S&OP planning cycle that this planned order aligns with. Format: SOP-YYYY-Mnn or SOP-YYYY-Qn.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentId rdf:type rdf:Property ;
    rdfs:label 'Equipment Id' ;
    rdfs:comment 'Primary key for equipment' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:parentEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Equipment Id' ;
    rdfs:comment 'Self-referencing FK on equipment (parent_equipment_id)' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:supplierContractId rdf:type rdf:Property ;
    rdfs:label 'Supplier Contract Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_contract. Business justification: Equipment service/maintenance contract management: links manufacturing equipment to its active supplier maintenance contract. Consumer Goods facilities track OEM service agreements per equipment asset' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierContract .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Purchase price paid for the equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetTag rdf:type rdf:Property ;
    rdfs:label 'Asset Tag' ;
    rdfs:comment 'Internal tag or barcode used to physically label the equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Calibration Required Flag' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Units' ;
    rdfs:comment 'Unit of measure for the equipment\'s capacity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityValue rdf:type rdf:Property ;
    rdfs:label 'Capacity Value' ;
    rdfs:comment 'Numeric capacity of the equipment expressed in the specified units.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceGmp rdf:type rdf:Property ;
    rdfs:label 'Compliance Gmp' ;
    rdfs:comment 'Indicates whether the equipment complies with GMP standards.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'Currency in which the acquisition cost is expressed.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organizational department responsible for the equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationEndDate rdf:type rdf:Property ;
    rdfs:label 'Depreciation End Date' ;
    rdfs:comment 'Date when the equipment is fully depreciated.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationStartDate rdf:type rdf:Property ;
    rdfs:label 'Depreciation Start Date' ;
    rdfs:comment 'Date when depreciation of the equipment begins.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:energyConsumptionKwh rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh' ;
    rdfs:comment 'Total energy consumed by the equipment in kilowatt-hours.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Number' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Status' ;
    rdfs:comment 'Current operational state of the equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Category of equipment based on function or form factor.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpQualifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Qualified Flag' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'Level of hazard associated with equipment operation.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installDate rdf:type rdf:Property ;
    rdfs:label 'Install Date' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date the equipment was installed and became operational.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent scheduled maintenance.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Code identifying the plant or facility where the equipment resides.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceCost rdf:type rdf:Property ;
    rdfs:label 'Maintenance Cost' ;
    rdfs:comment 'Cost incurred for the most recent maintenance activity.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Maintenance Frequency Days' ;
    rdfs:comment 'Number of days between routine maintenance events.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Company that produced the equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtbfHours rdf:type rdf:Property ;
    rdfs:label 'Mtbf Hours' ;
    rdfs:comment 'Average operating hours between equipment failures.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mttrHours rdf:type rdf:Property ;
    rdfs:label 'Mttr Hours' ;
    rdfs:comment 'Average time required to repair equipment after a failure.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextMaintenanceDue rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due' ;
    rdfs:comment 'Planned date for the next maintenance activity.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oeeActual rdf:type rdf:Property ;
    rdfs:label 'Oee Actual' ;
    rdfs:comment 'Measured Overall Equipment Effectiveness percentage.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeTarget rdf:type rdf:Property ;
    rdfs:label 'Oee Target' ;
    rdfs:comment 'Target Overall Equipment Effectiveness percentage.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerRatingKw rdf:type rdf:Property ;
    rdfs:label 'Power Rating Kw' ;
    rdfs:comment 'Maximum power consumption of the equipment in kilowatts.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'Date the equipment was purchased.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyRating rdf:type rdf:Property ;
    rdfs:label 'Safety Rating' ;
    rdfs:comment 'Safety classification of the equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUsageHours rdf:type rdf:Property ;
    rdfs:label 'Total Usage Hours' ;
    rdfs:comment 'Cumulative operating hours since installation.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voltage rdf:type rdf:Property ;
    rdfs:label 'Voltage' ;
    rdfs:comment 'Nominal operating voltage of the equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyEndDate rdf:type rdf:Property ;
    rdfs:label 'Warranty End Date' ;
    rdfs:comment 'Date when the equipment warranty expires.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Date' ;
    rdfs:comment 'Date when the equipment warranty period begins.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retailStoreId rdf:type rdf:Property ;
    rdfs:label 'Retail Store Id' ;
    rdfs:comment 'Foreign key linking to sales.retail_store. Business justification: Store-level demand planning is standard in consumer goods for DSD and VMI accounts. Demand plans are built at individual store granularity for promotional events and new product launches. Direct FK to' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailStore .

ind:skuPlanningParamId rdf:type rdf:Property ;
    rdfs:label 'Sku Planning Param Id' ;
    rdfs:comment 'Foreign key linking to supply.sku_planning_param. Business justification: Demand plans are generated using SKU-level planning parameters (forecast_model_type, planning_horizon_days, demand_pattern_type). Linking demand_plan to sku_planning_param formalizes this dependency. ' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuPlanningParam .

ind:standardCostId rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Id' ;
    rdfs:comment 'Foreign key linking to finance.standard_cost. Business justification: Demand plans are converted to gross margin forecasts using standard cost in consumer goods S&OP financial reviews. Linking demand plan volumes to standard cost enables automated gross profit planning ' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StandardCost .

ind:tradeCalendarId rdf:type rdf:Property ;
    rdfs:label 'Trade Calendar Id' ;
    rdfs:comment 'Foreign key linking to promotion.trade_calendar. Business justification: CPG demand plans are structured around trade calendar periods (planning_period_start_date, planning_period_end_date). Linking demand_plan to trade_calendar aligns demand planning cycles with promotion' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeCalendar .

ind:commercialOverlayQuantity rdf:type rdf:Property ;
    rdfs:label 'Commercial Overlay Quantity' ;
    rdfs:comment 'Demand adjustment quantity applied by field sales teams based on customer intelligence, market conditions, and sales pipeline visibility.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Planner-assigned confidence rating in the demand forecast based on data quality, market visibility, and forecast stability.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consensusQuantity rdf:type rdf:Property ;
    rdfs:label 'Consensus Quantity' ;
    rdfs:comment 'Agreed demand forecast quantity representing the single demand signal passed to supply planning after S&OP consensus process. This is the authoritative demand plan.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByPersona rdf:type rdf:Property ;
    rdfs:label 'Created By Persona' ;
    rdfs:comment 'Role or persona of the user who created this demand plan version, used for accountability and collaboration tracking.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandPatternType rdf:type rdf:Property ;
    rdfs:label 'Demand Pattern Type' ;
    rdfs:comment 'Classification of historical demand behavior pattern used to select appropriate statistical forecasting algorithm.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Status' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSensingSignal rdf:type rdf:Property ;
    rdfs:label 'Demand Sensing Signal' ;
    rdfs:comment 'Short-term demand trend indicator derived from real-time POS data, shipment data, and market signals to enable rapid forecast adjustments.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this demand plan version becomes active and is used for supply planning and ATP calculations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date until which this demand plan version remains active. Null indicates the version is currently active with no planned expiration.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastAccuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Percentage' ;
    rdfs:comment 'Historical forecast accuracy metric for this SKU/location/channel combination, used for forecast quality benchmarking and continuous improvement.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastBiasPercentage rdf:type rdf:Property ;
    rdfs:label 'Forecast Bias Percentage' ;
    rdfs:comment 'Systematic tendency to over-forecast or under-forecast, calculated as average percentage deviation from actual demand.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastQuantity rdf:type rdf:Property ;
    rdfs:label 'Forecast Quantity' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isConsensusVersion rdf:type rdf:Property ;
    rdfs:label 'Is Consensus Version' ;
    rdfs:comment 'Flag indicating whether this version represents the official consensus demand plan approved through the S&OP process and used for supply planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingEventUpliftQuantity rdf:type rdf:Property ;
    rdfs:label 'Marketing Event Uplift Quantity' ;
    rdfs:comment 'Incremental demand quantity expected from planned marketing campaigns, promotions, and brand activation events.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npdLaunchVolumeQuantity rdf:type rdf:Property ;
    rdfs:label 'Npd Launch Volume Quantity' ;
    rdfs:comment 'Forecasted demand quantity for new product launches or product line extensions during the planning period.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannerNotes rdf:type rdf:Property ;
    rdfs:label 'Planner Notes' ;
    rdfs:comment 'Free-text comments and annotations from demand planners explaining assumptions, adjustments, risks, or special considerations for this forecast.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningBucket rdf:type rdf:Property ;
    rdfs:label 'Planning Bucket' ;
    rdfs:comment 'Time granularity of the demand plan (daily, weekly, monthly, quarterly) used for aggregation and reporting.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the planning period (week or month) for which demand is forecasted.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the planning period (week or month) for which demand is forecasted.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalOverlayQuantity rdf:type rdf:Property ;
    rdfs:label 'Promotional Overlay Quantity' ;
    rdfs:comment 'Demand uplift quantity attributed to trade promotions, price discounts, and retail execution activities.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Classification of the primary risk factor affecting demand plan reliability and supply fulfillment capability.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Flag' ;
    rdfs:comment 'Indicator that this demand plan carries elevated supply risk due to capacity constraints, material shortages, or demand volatility.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'Original unique identifier of this demand plan record in the source system, used for data lineage and reconciliation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalBaselineQuantity rdf:type rdf:Property ;
    rdfs:label 'Statistical Baseline Quantity' ;
    rdfs:comment 'Unconstrained demand forecast quantity generated by statistical forecasting algorithms before any commercial overlays or adjustments.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToBaselineQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance To Baseline Quantity' ;
    rdfs:comment 'Difference between consensus quantity and statistical baseline quantity, indicating the net impact of all commercial adjustments and overlays.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionName rdf:type rdf:Property ;
    rdfs:label 'Version Name' ;
    rdfs:comment 'Human-readable name of the demand plan version (e.g., \'Statistical Baseline Q1 2024\', \'Consensus Final March 2024\').' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Version Sequence Number' ;
    rdfs:comment 'Sequential version number within the planning cycle, used to track iteration history and version progression.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionType rdf:type rdf:Property ;
    rdfs:label 'Version Type' ;
    rdfs:comment 'Classification of the demand plan version indicating its stage in the S&OP process. Statistical baseline represents unconstrained forecast; consensus represents agreed demand signal passed to supply planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastVersionId rdf:type rdf:Property ;
    rdfs:label 'Forecast Version Id' ;
    rdfs:comment 'Unique identifier for the forecast version record. Primary key.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ForecastVersion .

ind:baselineForecastVersionId rdf:type rdf:Property ;
    rdfs:label 'Baseline Forecast Version Id' ;
    rdfs:comment 'Reference to the parent or baseline forecast version from which this version was derived (e.g., statistical baseline that was then adjusted). Nullable for original baseline versions.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ForecastVersion .

ind:aggregationLevel rdf:type rdf:Property ;
    rdfs:label 'Aggregation Level' ;
    rdfs:comment 'The level of aggregation at which this forecast version is maintained: Stock Keeping Unit (SKU) level, product family, brand, category, sales channel, customer account, geographic region, or global total. [ENUM-REF-CANDIDATE: sku|product_family|brand|category|channel|customer|region|global — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Comments or notes provided by the approver during the approval process, documenting any conditions, concerns, or guidance related to this forecast version. Nullable if not yet approved or no notes provided.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'The date and time when this forecast version was archived and moved out of active planning use. Nullable if not yet archived.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:biasPercentage rdf:type rdf:Property ;
    rdfs:label 'Bias Percentage' ;
    rdfs:comment 'Forecast bias percentage indicating systematic over-forecasting (positive bias) or under-forecasting (negative bias). A value near zero indicates an unbiased forecast. Nullable if not yet calculated.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandSensingApplied rdf:type rdf:Property ;
    rdfs:label 'Demand Sensing Applied' ;
    rdfs:comment 'Boolean flag indicating whether demand sensing algorithms (short-term forecast adjustments based on real-time Point of Sale (POS) data, shipment data, or other leading indicators) were applied to this forecast version.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Forecast Source System' ;
    rdfs:comment 'Name or identifier of the source system or application that generated or contributed to this forecast version (e.g., \'SAP IBP\', \'TradeEdge\', \'Excel Upload\', \'Salesforce CG Cloud\').' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastVersionStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Version Status' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActiveVersion rdf:type rdf:Property ;
    rdfs:label 'Is Active Version' ;
    rdfs:comment 'Boolean flag indicating whether this forecast version is currently active and being used for planning and execution. Only one version per planning cycle should typically be active at a time.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFinalApprovedVersion rdf:type rdf:Property ;
    rdfs:label 'Is Final Approved Version' ;
    rdfs:comment 'Boolean flag indicating whether this version is the final approved forecast that will be used for operational execution, Material Requirements Planning (MRP), and Distribution Requirements Planning (DRP).' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meanAbsolutePercentageError rdf:type rdf:Property ;
    rdfs:label 'Mean Absolute Percentage Error' ;
    rdfs:comment 'Mean Absolute Percentage Error (MAPE) metric for this forecast version, measuring the average magnitude of forecast errors as a percentage. Lower values indicate better forecast accuracy. Nullable if not yet calculated.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newProductIntroductionIncluded rdf:type rdf:Property ;
    rdfs:label 'New Product Introduction Included' ;
    rdfs:comment 'Boolean flag indicating whether New Product Development (NPD) or New Product Introduction (NPI) launches were incorporated into this forecast version.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End Date' ;
    rdfs:comment 'The last date of the planning period covered by this forecast version (e.g., end of the fiscal quarter or rolling 18-month horizon).' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start Date' ;
    rdfs:comment 'The first date of the planning period covered by this forecast version (e.g., start of the fiscal quarter or month).' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalEventsIncluded rdf:type rdf:Property ;
    rdfs:label 'Promotional Events Included' ;
    rdfs:comment 'Boolean flag indicating whether trade promotions, marketing campaigns, and promotional events were factored into this forecast version.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation or reason provided when this forecast version was rejected during the approval process. Nullable if version was not rejected.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statisticalModelApplied rdf:type rdf:Property ;
    rdfs:label 'Statistical Model Applied' ;
    rdfs:comment 'Name or identifier of the statistical forecasting model or algorithm applied to generate or adjust this forecast version (e.g., \'Exponential Smoothing\', \'ARIMA\', \'Machine Learning Ensemble\', \'Holt-Winters\'). Nullable if no statistical model was used.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeBucket rdf:type rdf:Property ;
    rdfs:label 'Time Bucket' ;
    rdfs:comment 'The time granularity or bucket size used for this forecast version: daily, weekly, monthly, quarterly, or annual periods.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionCode rdf:type rdf:Property ;
    rdfs:label 'Version Code' ;
    rdfs:comment 'Short alphanumeric code or identifier for the forecast version used in system integrations and reporting (e.g., \'STAT_BASE\', \'CONS_V1\', \'FINAL_APR\').' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionDescription rdf:type rdf:Property ;
    rdfs:label 'Version Description' ;
    rdfs:comment 'Detailed textual description or notes about this forecast version, including assumptions, adjustments made, special considerations, or rationale for key changes.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of the forecast version: draft (under construction), in review (submitted for approval), approved (validated and accepted), rejected (not accepted), archived (historical record), or active (currently in use for planning).' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryPolicyId rdf:type rdf:Property ;
    rdfs:label 'Inventory Policy Id' ;
    rdfs:comment 'Unique identifier for the inventory policy record. Primary key for this entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryPolicy .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the supply planning manager or director who approved this inventory policy for operational use.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerOtifCommitmentPercent rdf:type rdf:Property ;
    rdfs:label 'Customer Otif Commitment Percent' ;
    rdfs:comment 'Specific OTIF performance level committed to a customer or channel, which may differ from internal targets and may be contractually binding.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleStockTargetUnits rdf:type rdf:Property ;
    rdfs:label 'Cycle Stock Target Units' ;
    rdfs:comment 'Target cycle stock quantity representing the average inventory held to meet expected demand between replenishments, excluding safety stock.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandVariabilityCoefficient rdf:type rdf:Property ;
    rdfs:label 'Demand Variability Coefficient' ;
    rdfs:comment 'Statistical measure of demand variability (coefficient of variation or standard deviation) used in safety stock calculations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fillRateTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Target Percent' ;
    rdfs:comment 'Target percentage of customer demand that should be fulfilled from available inventory without backorders or stockouts.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryPolicyStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Policy Status' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date when this inventory policy was last reviewed and validated by the supply planning team.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeVariabilityDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Variability Days' ;
    rdfs:comment 'Standard deviation or variance of replenishment lead time in days, used to account for supply uncertainty in safety stock calculations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumStockLevelUnits rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level Units' ;
    rdfs:comment 'Maximum inventory level allowed at this location for this SKU, used to prevent overstocking and manage warehouse capacity constraints.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementWindowDays rdf:type rdf:Property ;
    rdfs:label 'Measurement Window Days' ;
    rdfs:comment 'Time period in days over which service level performance is measured and evaluated against targets (e.g., rolling 30 days, 90 days, quarterly).' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumStockLevelUnits rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Level Units' ;
    rdfs:comment 'Minimum inventory level that should be maintained at this location for this SKU, typically aligned with safety stock or regulatory requirements.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next review and update of this inventory policy, ensuring policies remain aligned with business conditions.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onTimeDeliveryTargetPercent rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Target Percent' ;
    rdfs:comment 'Target percentage of orders that should be delivered by the customer-requested or committed delivery date.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifCompositeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Otif Composite Target Percent' ;
    rdfs:comment 'Composite OTIF (On Time In Full) target percentage representing orders delivered both on time and in full quantity, a critical customer service metric.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseIndicator rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Indicator' ;
    rdfs:comment 'Indicates whether failure to meet the defined service level targets will result in financial penalties, chargebacks, or other contractual consequences.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Business identifier code for the inventory policy, used for external reference and reporting.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNotes rdf:type rdf:Property ;
    rdfs:label 'Policy Notes' ;
    rdfs:comment 'Free-text notes capturing special considerations, exceptions, seasonal adjustments, or business context relevant to this inventory policy.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the inventory policy indicating its approval and operational state. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|expired|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPointUnits rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Units' ;
    rdfs:comment 'Inventory level at which a replenishment order should be triggered, calculated as lead time demand plus safety stock.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentMethod rdf:type rdf:Property ;
    rdfs:label 'Replenishment Method' ;
    rdfs:comment 'The inventory replenishment strategy applied: MRP (Material Requirements Planning), DRP (Distribution Requirements Planning), VMI (Vendor Managed Inventory), JIT (Just In Time), Kanban, or Fixed Order Quantity.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerMandatedTargetFlag rdf:type rdf:Property ;
    rdfs:label 'Retailer Mandated Target Flag' ;
    rdfs:comment 'Indicates whether the service level targets are mandated by a retail customer as part of their supplier requirements or vendor compliance program.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCycleDays rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Days' ;
    rdfs:comment 'Frequency in days at which inventory levels are reviewed and replenishment decisions are made for this SKU-location combination.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Review Period Days' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockCalculatedUnits rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Calculated Units' ;
    rdfs:comment 'System-calculated safety stock quantity based on demand variability, lead time variability, and service level inputs before manual approval or adjustment.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Calculation Method' ;
    rdfs:comment 'The methodology used to calculate safety stock: fixed value, forecast error-based, demand variability, lead time variability, combined variability, or service level-driven calculation.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockDaysOfSupply rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Days Of Supply' ;
    rdfs:comment 'Safety stock expressed as the number of days of average demand coverage, providing a time-based view of inventory buffer.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockTargetUnits rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Target Units' ;
    rdfs:comment 'Target safety stock quantity in base units of measure, representing the buffer inventory to protect against demand and supply variability.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Service Level Target Percent' ;
    rdfs:comment 'Target service level percentage (e.g., 95%, 98%, 99.5%) representing the desired probability of not stocking out during the replenishment lead time.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetServiceLevelPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Service Level Percentage' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'The ABC classification of the SKU based on revenue contribution or volume. A items are high-value requiring tight control; B items are moderate; C items are low-value. Influences service level targets and safety stock investment decisions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'The date and time when the safety stock calculation was approved by the planner. Marks the transition from calculated to approved state in the workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedSafetyStockUnits rdf:type rdf:Property ;
    rdfs:label 'Approved Safety Stock Units' ;
    rdfs:comment 'The final approved safety stock quantity in base units of measure after planner review and adjustment. This is the target value used for inventory policy execution and Available to Promise (ATP) calculations.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyDemandUnits rdf:type rdf:Property ;
    rdfs:label 'Average Daily Demand Units' ;
    rdfs:comment 'The mean daily demand quantity in base units of measure. Used as input to safety stock calculations and represents expected consumption rate.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Average Lead Time Days' ;
    rdfs:comment 'The mean replenishment lead time in days from order placement to receipt. Used in safety stock calculations to determine the exposure period for demand and supply variability.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedSafetyStockUnits rdf:type rdf:Property ;
    rdfs:label 'Calculated Safety Stock Units' ;
    rdfs:comment 'The system-calculated safety stock quantity in base units of measure. This is the raw output from the calculation engine before any manual adjustments or approvals.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The methodology used to calculate the safety stock quantity. Statistical methods use demand and lead time variability; days-of-supply uses fixed coverage targets; manual override represents planner judgment; service level and lead time methods focus on specific risk factors; hybrid combines multiple approaches.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'The date and time when the safety stock calculation was executed by the planning system. Provides audit trail for calculation runs and version control.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Score indicating the quality of the data record' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOfSupply rdf:type rdf:Property ;
    rdfs:label 'Days Of Supply' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOfSupplyTarget rdf:type rdf:Property ;
    rdfs:label 'Days Of Supply Target' ;
    rdfs:comment 'The target safety stock coverage expressed in days of average demand. Used when calculation method is days-of-supply based. Represents the buffer duration to protect against stockouts.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandClassification rdf:type rdf:Property ;
    rdfs:label 'Demand Classification' ;
    rdfs:comment 'The demand pattern category for this SKU-location. Steady indicates consistent demand; seasonal shows periodic peaks; erratic has high variability; lumpy has infrequent large orders; intermittent has sporadic demand; obsolete indicates phase-out. Influences calculation method selection.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date when this safety stock target expires and is replaced by a new calculation. Used to manage the lifecycle of safety stock policies and trigger recalculation cycles.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastAccuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Percent' ;
    rdfs:comment 'The historical forecast accuracy for this SKU-location combination expressed as a percentage. Used to adjust safety stock calculations based on forecasting reliability. Lower accuracy typically requires higher safety stock.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Holding Cost Per Unit' ;
    rdfs:comment 'The annual cost to hold one unit of inventory including warehousing, insurance, obsolescence, and capital cost. Used in inventory optimization to balance service level against carrying cost. Expressed in local currency.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Boolean flag indicating whether this safety stock record is currently active and being used for inventory policy execution. True means active; False means superseded or inactive.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Review Timestamp' ;
    rdfs:comment 'The date and time when the safety stock record was last reviewed by a planner, regardless of whether changes were made. Used to track planner engagement and ensure regular review cycles.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderMultiple rdf:type rdf:Property ;
    rdfs:label 'Order Multiple' ;
    rdfs:comment 'The order quantity increment or lot size multiple required by supplier or production constraints. Safety stock and reorder quantities must align with this multiple.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideNotes rdf:type rdf:Property ;
    rdfs:label 'Override Notes' ;
    rdfs:comment 'Free-text explanation provided by the planner when manually overriding the calculated safety stock. Documents the business context and rationale for the adjustment.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'The business reason code when approved safety stock differs from calculated safety stock. Captures planner judgment factors such as promotional events, seasonal peaks, supply chain risks, new product introductions, product phase-outs, or quality concerns.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Contracted quantity' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordSource rdf:type rdf:Property ;
    rdfs:label 'Record Source' ;
    rdfs:comment 'Source system or process that created this record' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'The approval workflow status of the safety stock calculation. Pending review indicates awaiting planner action; approved means active for execution; rejected requires recalculation; under revision is being adjusted; expired indicates the planning period has passed.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Status' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockoutCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Stockout Cost Per Unit' ;
    rdfs:comment 'The estimated cost of a stockout per unit including lost sales, expediting costs, customer dissatisfaction, and brand impact. Used in service level optimization to quantify the cost of Out of Stock (OOS) events. Expressed in local currency.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyRiskScore rdf:type rdf:Property ;
    rdfs:label 'Supply Risk Score' ;
    rdfs:comment 'A quantitative risk score assessing supply chain vulnerability for this SKU-location. Higher scores indicate greater risk from supplier reliability, geopolitical factors, transportation disruptions, or single-source dependencies. Used to adjust safety stock buffers.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetServiceLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Target Service Level Percent' ;
    rdfs:comment 'The desired in-stock probability or fill rate target expressed as a percentage (e.g., 95.00, 98.50). Drives the safety stock buffer size to achieve the specified On Shelf Availability (OSA) or Service Level Agreement (SLA).' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:xyzClassification rdf:type rdf:Property ;
    rdfs:label 'Xyz Classification' ;
    rdfs:comment 'The XYZ classification based on demand variability. X items have low variability (predictable); Y items have moderate variability; Z items have high variability (unpredictable). Used alongside ABC to determine safety stock strategy.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zScore rdf:type rdf:Property ;
    rdfs:label 'Z Score' ;
    rdfs:comment 'The standard normal distribution value corresponding to the target service level. Used in statistical safety stock formulas to translate service level percentage into buffer quantity.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Id' ;
    rdfs:comment 'Unique identifier for the supply replenishment order record. Primary key for this entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplenishmentOrder .

ind:destinationLocationSupplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Supply Network Node Id' ;
    rdfs:comment 'Identifier of the supply network node to which inventory will be delivered (distribution center, warehouse, or retail location).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:networkLaneId rdf:type rdf:Property ;
    rdfs:label 'Network Lane Id' ;
    rdfs:comment 'Foreign key linking to supply.network_lane. Business justification: Each supply replenishment order travels along a specific network lane between source and destination nodes. Linking to network_lane provides access to lane-level attributes (lead time, cost, transport' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkLane .

ind:primarySupplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Supply Network Node Id' ;
    rdfs:comment 'Identifier of the supply network node from which inventory will be shipped (plant, distribution center, or warehouse).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:supplierSiteId rdf:type rdf:Property ;
    rdfs:label 'Supplier Site Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_site. Business justification: A replenishment order sourced externally ships from a specific supplier site. This FK enables shipment origin tracking, supplier site OTIF performance analysis per replenishment order, and inbound log' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierSite .

ind:triggeringOrderId rdf:type rdf:Property ;
    rdfs:label 'Triggering Order Id' ;
    rdfs:comment 'Foreign key linking to sales.order. Business justification: Order-to-replenish fulfillment process: a customer sales order triggers a supply replenishment order. Supply planners and fulfillment teams trace replenishment back to the originating customer order f' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'Actual date the goods were received at the destination location.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'Actual date the shipment departed from the source location.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availableToPromiseQuantity rdf:type rdf:Property ;
    rdfs:label 'Available To Promise Quantity' ;
    rdfs:comment 'ATP quantity at the source location at the time the replenishment order was created, used to validate supply availability.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Reason code or description explaining why the replenishment order was cancelled, if applicable.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drpRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Drp Run Timestamp' ;
    rdfs:comment 'Date and time when the DRP execution run that generated this order was executed.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forecastDemandQuantity rdf:type rdf:Property ;
    rdfs:label 'Forecast Demand Quantity' ;
    rdfs:comment 'Forecasted demand quantity at the destination location that drove the replenishment calculation.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderCostAmount rdf:type rdf:Property ;
    rdfs:label 'Order Cost Amount' ;
    rdfs:comment 'Total cost associated with this replenishment order, including product cost, transportation cost, and handling fees.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Free-text notes or special instructions related to this replenishment order, such as handling requirements or routing constraints.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Date' ;
    rdfs:comment 'Target date for goods receipt at the destination location, accounting for transit lead time.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedShipDate rdf:type rdf:Property ;
    rdfs:label 'Planned Ship Date' ;
    rdfs:comment 'Target date for shipment departure from the source location as calculated by the DRP engine.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Actual quantity of the SKU received at the destination location, captured at goods receipt.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Number' ;
    rdfs:comment 'Business-facing unique order number for the replenishment order, used for tracking and reference across systems and communications.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity' ;
    rdfs:comment 'Quantity of the SKU requested for replenishment as calculated by the DRP engine or demand planner.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Trigger Flag' ;
    rdfs:comment 'Indicates whether this replenishment order was triggered by inventory falling below safety stock threshold at the destination location.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'Actual quantity of the SKU shipped from the source location, captured at dispatch.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyReplenishmentOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Supply Replenishment Order Status' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transit Lead Time Days' ;
    rdfs:comment 'Planned number of days for goods to travel from source to destination location.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportationMode rdf:type rdf:Property ;
    rdfs:label 'Transportation Mode' ;
    rdfs:comment 'Primary mode of transportation planned or used for this replenishment shipment.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkNodeId rdf:type rdf:Property ;
    rdfs:label 'Network Node Id' ;
    rdfs:comment 'Primary key for network_node' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityClass rdf:type rdf:Property ;
    rdfs:label 'Capacity Class' ;
    rdfs:comment 'Classification of the supply network node storage and throughput capacity used in IBP supply planning for capacity-constrained optimization.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDockEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Enabled Flag' ;
    rdfs:comment 'Indicates whether this supply network node supports cross-docking operations (direct transfer without storage). Used in transportation and distribution planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dsdEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Enabled Flag' ;
    rdfs:comment 'Indicates whether this supply network node supports Direct Store Delivery operations. Used in distribution planning and route optimization.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gln rdf:type rdf:Property ;
    rdfs:label 'Gln' ;
    rdfs:comment 'GS1 Global Location Number uniquely identifying the physical location of the supply network node for EDI transactions and supply chain visibility.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether this supply network node is certified to handle and store hazardous materials. Used for product allocation and regulatory compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkNodeStatus rdf:type rdf:Property ;
    rdfs:label 'Network Node Status' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classification of the supply network node indicating its role in the supply chain (manufacturing plant, regional distribution center, forward distribution center, co-manufacturer, third-party logistics warehouse, cross-dock facility, or supplier location). [ENUM-REF-CANDIDATE: manufacturing_plant|regional_dc|forward_dc|co_manufacturer|3pl_warehouse|cross_dock|supplier_location — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningGroup rdf:type rdf:Property ;
    rdfs:label 'Planning Group' ;
    rdfs:comment 'Planning group or cluster assignment for the supply network node used in IBP and S&OP processes to aggregate nodes for planning purposes.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Replenishment Frequency' ;
    rdfs:comment 'Standard replenishment frequency for inventory at this supply network node. Used in DRP planning and inventory policy definition.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockDays rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Days' ;
    rdfs:comment 'Target safety stock coverage in days of supply maintained at this network node. Used in inventory optimization and S&OP planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingPriority rdf:type rdf:Property ;
    rdfs:label 'Sourcing Priority' ;
    rdfs:comment 'Priority ranking of this supply network node in sourcing rules and allocation logic (lower number = higher priority). Used in IBP supply planning and ATP/CTP allocation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Units' ;
    rdfs:comment 'Maximum storage capacity of the supply network node measured in standard storage units (pallets, cases, or cubic meters). Used for inventory optimization and DRP planning.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCapacityUom rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Uom' ;
    rdfs:comment 'Unit of measure for the storage capacity (pallets, cases, cubic meters, square meters). Aligns with WMS and IBP planning units.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputCapacityDaily rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity Daily' ;
    rdfs:comment 'Maximum daily throughput capacity of the supply network node measured in standard units (cases, pallets, or production units per day). Used for production and distribution planning.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputCapacityUom rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity Uom' ;
    rdfs:comment 'Unit of measure for the daily throughput capacity. Used in production scheduling and distribution planning.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Enabled Flag' ;
    rdfs:comment 'Indicates whether this supply network node participates in Vendor Managed Inventory programs. Used in collaborative planning and replenishment processes.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Network Node Id' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:originNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Origin Network Node Id' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:capacityQuantity rdf:type rdf:Property ;
    rdfs:label 'Capacity Quantity' ;
    rdfs:comment 'Maximum throughput capacity of this lane per planning period (day, week, month), representing the upper limit of goods that can be moved. Used by Supply Planning and Sales and Operations Planning (S&OP) for capacity-constrained optimization.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUom rdf:type rdf:Property ;
    rdfs:label 'Capacity Uom' ;
    rdfs:comment 'Unit of measure for the capacity quantity field, indicating how lane capacity is measured and constrained. [ENUM-REF-CANDIDATE: EA|CS|PL|TU|KG|LB|L|GAL — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Regulatory or business compliance requirements applicable to this lane, such as temperature control (Good Manufacturing Practice - GMP), hazardous materials handling (Environmental Protection Agency - EPA), or cross-border customs (Food and Drug Administration - FDA).' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'Standard transportation or transfer cost per unit of measure for moving goods along this lane. Used for supply chain cost modeling and total landed cost calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryLane rdf:type rdf:Property ;
    rdfs:label 'Is Primary Lane' ;
    rdfs:comment 'Boolean flag indicating whether this lane is the primary (preferred) sourcing route for the destination. True if this is the default lane used under normal conditions; false for backup or secondary lanes.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneCode rdf:type rdf:Property ;
    rdfs:label 'Lane Code' ;
    rdfs:comment 'Business identifier for the supply network lane, typically a concatenation or encoded representation of source-destination pair used in planning systems and operational communications.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneCost rdf:type rdf:Property ;
    rdfs:label 'Lane Cost' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laneName rdf:type rdf:Property ;
    rdfs:label 'Lane Name' ;
    rdfs:comment 'Human-readable descriptive name for the supply network lane, often including source and destination location names for easy identification in reports and dashboards.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneType rdf:type rdf:Property ;
    rdfs:label 'Lane Type' ;
    rdfs:comment 'Classification of the supply network lane based on the nature of the sourcing relationship: production (from manufacturing plant), transfer (between internal facilities), external procurement (from supplier), direct shipment (plant to customer), cross-dock (no storage), or drop-ship (supplier to customer).' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'Identifier of the user or system process that last modified this supply network lane record, used for audit trail and data governance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Lot Size Quantity' ;
    rdfs:comment 'Standard batch or lot size for replenishment orders on this lane. Orders are typically rounded to multiples of this quantity for operational efficiency (e.g., full pallet, full truckload).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum quantity that can be ordered or shipped on this lane in a single replenishment cycle, constrained by capacity, vehicle limits, or storage restrictions.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkLaneStatus rdf:type rdf:Property ;
    rdfs:label 'Network Lane Status' ;
    rdfs:comment 'Current lifecycle status of the supply network lane: active (operational), inactive (temporarily disabled), suspended (on hold), planned (future activation), or decommissioned (permanently closed).' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otif Target Pct' ;
    rdfs:comment 'Specific target percentage for On Time In Full delivery performance on this lane, a key supply chain Key Performance Indicator (KPI) measuring the percentage of orders delivered on time and complete.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Processing Lead Time Days' ;
    rdfs:comment 'Time in days required for order processing, picking, packing, and loading at the source location before shipment begins.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelTargetPct rdf:type rdf:Property ;
    rdfs:label 'Service Level Target Pct' ;
    rdfs:comment 'Target service level percentage for on-time and in-full delivery performance on this lane, expressed as a percentage (e.g., 95.00 for 95%). Used to measure On Time In Full (OTIF) performance.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Standard Lead Time Days' ;
    rdfs:comment 'Total planned lead time in days from order placement to goods receipt at destination, including processing time, transportation time, and buffer. Used by Material Requirements Planning (MRP) and Distribution Requirements Planning (DRP) for replenishment calculations.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transit Time Days' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportationLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transportation Lead Time Days' ;
    rdfs:comment 'Transit time in days for goods to move from source to destination, excluding processing and handling time. Component of the total standard lead time.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atpRecordId rdf:type rdf:Property ;
    rdfs:label 'Atp Record Id' ;
    rdfs:comment 'Primary key for atp_record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AtpRecord .

ind:batchReleaseId rdf:type rdf:Property ;
    rdfs:label 'Batch Release Id' ;
    rdfs:comment 'Foreign key linking to quality.batch_release. Business justification: Quality-Gated ATP Calculation: ATP commitments in Consumer_Goods must exclude unreleased batches. The batch_release status directly gates whether on-hand inventory is available for promise. Supply pla' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRelease .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Foreign key linking to sales.order. Business justification: ATP check is performed against a specific customer order during order promising. The atp_record stores the result of that check. Linking to the sales order enables order-promising accuracy reporting a' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'The quantity already committed or reserved for existing sales orders, reducing available ATP.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atpCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Atp Calculation Method' ;
    rdfs:comment 'The method used to calculate ATP. Simple ATP considers only on-hand inventory minus allocations. Cumulative ATP includes planned receipts over time. Multi-level ATP considers BOM components. Product allocation ATP applies allocation rules across customer segments.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpCheckHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Atp Check Horizon Days' ;
    rdfs:comment 'The number of days into the future that the ATP check considers for availability. Defines the planning horizon for promise calculations.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atpConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Atp Confirmation Number' ;
    rdfs:comment 'Unique confirmation number generated when ATP is reserved for a sales order, providing traceability between ATP records and order promising.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpDate rdf:type rdf:Property ;
    rdfs:label 'Atp Date' ;
    rdfs:comment 'The date for which ATP quantity is calculated. Represents the promise date for order fulfillment.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:atpQuantity rdf:type rdf:Property ;
    rdfs:label 'Atp Quantity' ;
    rdfs:comment 'The confirmed quantity available to promise to customers for the given SKU, location, and date. Represents uncommitted inventory available for new orders.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atpRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Atp Record Status' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpStatus rdf:type rdf:Property ;
    rdfs:label 'Atp Status' ;
    rdfs:comment 'The current status of the ATP record. Available indicates positive ATP. Constrained indicates limited availability. Blocked indicates ATP is not available for promising. Expired indicates the ATP date has passed.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backorderQuantity rdf:type rdf:Property ;
    rdfs:label 'Backorder Quantity' ;
    rdfs:comment 'The quantity of unfulfilled demand from previous periods that impacts current ATP availability.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctpQuantity rdf:type rdf:Property ;
    rdfs:label 'Ctp Quantity' ;
    rdfs:comment 'The quantity that can be promised considering both current inventory and planned production or supply receipts. Extends ATP by including future supply.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeAtpQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Atp Quantity' ;
    rdfs:comment 'The cumulative ATP quantity calculated across multiple time periods, showing total available quantity from current date through the ATP date.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerPriorityTier rdf:type rdf:Property ;
    rdfs:label 'Customer Priority Tier' ;
    rdfs:comment 'The priority tier of the customer or channel for which ATP is being calculated, used in allocation scenarios where high-priority customers receive preferential ATP.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandPeggingReference rdf:type rdf:Property ;
    rdfs:label 'Demand Pegging Reference' ;
    rdfs:comment 'Reference identifier linking ATP consumption to specific demand sources such as sales orders, forecasts, or customer reservations.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastConsumptionQuantity rdf:type rdf:Property ;
    rdfs:label 'Forecast Consumption Quantity' ;
    rdfs:comment 'The quantity of forecast demand consumed by actual sales orders, used in ATP calculations to avoid double-counting demand.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intransitQuantity rdf:type rdf:Property ;
    rdfs:label 'Intransit Quantity' ;
    rdfs:comment 'The quantity currently in transit to the location that will contribute to ATP upon arrival.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Shelf Life Days' ;
    rdfs:comment 'The minimum remaining shelf life in days required for the product to be available for promising, ensuring customers receive products with adequate shelf life.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onHandInventory rdf:type rdf:Property ;
    rdfs:label 'On Hand Inventory' ;
    rdfs:comment 'The physical inventory quantity available at the location at the time of ATP calculation.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Quantity' ;
    rdfs:comment 'The quantity expected to be received from production orders, purchase orders, or transfers by the ATP date.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningVersion rdf:type rdf:Property ;
    rdfs:label 'Planning Version' ;
    rdfs:comment 'The planning scenario or version identifier in SAP IBP under which this ATP calculation was performed, enabling what-if analysis and scenario planning.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productAllocationGroup rdf:type rdf:Property ;
    rdfs:label 'Product Allocation Group' ;
    rdfs:comment 'The allocation group or priority segment assigned to this ATP calculation, used when ATP is allocated across customer tiers or channels.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Production Order Quantity' ;
    rdfs:comment 'The quantity scheduled for production that will be available by the ATP date.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Quantity' ;
    rdfs:comment 'The quantity on open purchase orders expected to be received by the ATP date.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyPeggingReference rdf:type rdf:Property ;
    rdfs:label 'Supply Pegging Reference' ;
    rdfs:comment 'Reference identifier linking ATP availability to specific supply sources such as production orders, purchase orders, or stock transfers.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedSupplierListId rdf:type rdf:Property ;
    rdfs:label 'Approved Supplier List Id' ;
    rdfs:comment 'Foreign key linking to procurement.approved_supplier_list. Business justification: SKU planning parameters (lead time, MOQ, procurement type) are governed by the approved supplier list. This FK enables planners to validate planning parameters against current ASL status and supports ' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovedSupplierList .

ind:backorderAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Allowed Flag' ;
    rdfs:comment 'Indicates whether backorders are permitted for this SKU when inventory is insufficient. True allows demand to be backordered, false requires immediate fulfillment or cancellation.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageProfileDays rdf:type rdf:Property ;
    rdfs:label 'Coverage Profile Days' ;
    rdfs:comment 'Target days of supply to maintain in inventory. Represents desired inventory coverage horizon based on demand forecast and replenishment frequency.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalPartFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Part Flag' ;
    rdfs:comment 'Indicates whether this SKU is classified as a critical part requiring special planning attention. Critical parts may have higher service levels or expedited replenishment.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixedLotSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Fixed Lot Size Quantity' ;
    rdfs:comment 'Fixed production or procurement lot size quantity when using fixed lot size method. Represents standard batch size for manufacturing or ordering.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastModelType rdf:type rdf:Property ;
    rdfs:label 'Forecast Model Type' ;
    rdfs:comment 'Statistical or machine learning model used for demand forecasting. Determines the algorithm applied during forecast generation in IBP or demand planning systems.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptProcessingTimeDays rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Processing Time Days' ;
    rdfs:comment 'Time required for quality inspection and goods receipt processing after physical delivery. Adds to total replenishment lead time.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryValuationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Method' ;
    rdfs:comment 'Method used for inventory valuation and consumption. FIFO (First In First Out), FEFO (First Expired First Out), LIFO (Last In First Out), or weighted average costing.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeMethod rdf:type rdf:Property ;
    rdfs:label 'Lot Size Method' ;
    rdfs:comment 'Method used to calculate production or procurement lot sizes. Determines how order quantities are calculated in MRP and supply planning runs.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeRule rdf:type rdf:Property ;
    rdfs:label 'Lot Size Rule' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStockLevelQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level Quantity' ;
    rdfs:comment 'Maximum inventory level target for this SKU. Used in min-max planning to cap inventory investment and prevent overstock situations.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Order Quantity' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRemainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Remaining Shelf Life Days' ;
    rdfs:comment 'Minimum remaining shelf life required at time of shipment to customer or retail delivery. Ensures product quality and retailer acceptance.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrpControllerCode rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller Code' ;
    rdfs:comment 'Code identifying the MRP controller or planner responsible for this SKU. Used for workload assignment and exception management routing.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpType rdf:type rdf:Property ;
    rdfs:label 'Mrp Type' ;
    rdfs:comment 'MRP procedure that controls how the planning system generates procurement proposals. Determines planning logic and automation level.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderMultipleQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Multiple Quantity' ;
    rdfs:comment 'Quantity increment in which orders must be placed. All order quantities must be multiples of this value due to packaging or production constraints.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parameterNotes rdf:type rdf:Property ;
    rdfs:label 'Parameter Notes' ;
    rdfs:comment 'Free-text notes documenting special planning considerations, parameter rationale, or exceptions for this SKU. Provides context for planning decisions.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterStatus rdf:type rdf:Property ;
    rdfs:label 'Parameter Status' ;
    rdfs:comment 'Current lifecycle status of the planning parameter record. Active parameters are used in planning runs, inactive parameters are ignored.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDeliveryTimeDays rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Time Days' ;
    rdfs:comment 'Standard lead time in days from order placement to goods receipt. Used for MRP scheduling and supply plan timing calculations.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Days' ;
    rdfs:comment 'Number of days into the future for which demand and supply planning is performed. Defines the forward-looking planning window for this SKU.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningMethod rdf:type rdf:Property ;
    rdfs:label 'Planning Method' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningStrategy rdf:type rdf:Property ;
    rdfs:label 'Planning Strategy' ;
    rdfs:comment 'Manufacturing planning strategy that determines how the SKU is planned and produced. Make-to-stock produces to forecast, make-to-order produces against customer orders.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningTimeFenceDays rdf:type rdf:Property ;
    rdfs:label 'Planning Time Fence Days' ;
    rdfs:comment 'Number of days within which the planning system cannot automatically change planned orders without planner approval. Protects near-term production schedule stability.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roundingProfileCode rdf:type rdf:Property ;
    rdfs:label 'Rounding Profile Code' ;
    rdfs:comment 'Code defining rounding rules for planned order quantities. Ensures quantities align with packaging units, pallet configurations, or production batch constraints.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockMethod rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Method' ;
    rdfs:comment 'Method used to calculate safety stock levels. Fixed quantity uses static buffer, service level based uses demand variability and lead time uncertainty.' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalityProfileCode rdf:type rdf:Property ;
    rdfs:label 'Seasonality Profile Code' ;
    rdfs:comment 'Code identifying the seasonality pattern applied to this SKU for demand forecasting. Links to predefined seasonal index curves (e.g., summer peak, holiday spike).' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuPlanningParamStatus rdf:type rdf:Property ;
    rdfs:label 'Sku Planning Param Status' ;
    rdfs:domain ind:SkuPlanningParam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousPlanningRunId rdf:type rdf:Property ;
    rdfs:label 'Previous Planning Run Id' ;
    rdfs:comment 'Self-referencing FK on planning_run (previous_planning_run_id)' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanningRun .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Origin of the input data used for the planning run.' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total elapsed time of the run measured in minutes.' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Error details captured when the run fails or encounters issues.' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeMetric rdf:type rdf:Property ;
    rdfs:label 'Outcome Metric' ;
    rdfs:comment 'Key quantitative metric produced by the run (e.g., total forecast error, service level).' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Planning Algorithm' ;
    rdfs:comment 'Name or code of the algorithm/model used to generate the plan.' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonEnd rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End' ;
    rdfs:comment 'Last date of the planning horizon covered by the run.' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStart rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start' ;
    rdfs:comment 'First date of the planning horizon covered by the run.' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningRunStatus rdf:type rdf:Property ;
    rdfs:label 'Planning Run Status' ;
    rdfs:comment 'Current lifecycle state of the planning run.' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultSummary rdf:type rdf:Property ;
    rdfs:label 'Result Summary' ;
    rdfs:comment 'High-level textual summary of the planning outcomes.' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Completed Timestamp' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run End Timestamp' ;
    rdfs:comment 'Timestamp when the planning run execution finished.' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runName rdf:type rdf:Property ;
    rdfs:label 'Run Name' ;
    rdfs:comment 'Human-readable name given to the planning run for easy identification.' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'External reference number or code used by business users to identify the run.' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runPriority rdf:type rdf:Property ;
    rdfs:label 'Run Priority' ;
    rdfs:comment 'Business-assigned priority level influencing scheduling and resource allocation.' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Start Timestamp' ;
    rdfs:comment 'Timestamp when the planning run execution began.' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Started Timestamp' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Category of planning activity performed in the run (e.g., demand, supply, inventory, S&OP, optimization).' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioCode rdf:type rdf:Property ;
    rdfs:label 'Scenario Code' ;
    rdfs:comment 'Code representing the scenario (e.g., baseline, best-case, worst-case) used for this run.' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successFlag rdf:type rdf:Property ;
    rdfs:label 'Success Flag' ;
    rdfs:comment 'True if the run completed without errors; otherwise False.' ;
    rdfs:domain ind:PlanningRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentTradeAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Trade Account Id' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAccount .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Primary key' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The full descriptive name of the GL account as it appears in financial reports and statements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The externally-known unique account number in the chart of accounts. This is the business identifier used in financial postings and reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'The current lifecycle status of the GL account: active (in use), inactive (not currently used but retained), pending approval (awaiting activation), or archived (historical only).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'The fundamental accounting classification of the account: asset, liability, equity, revenue, expense, or statistical (non-monetary).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Credit limit amount' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'D&B DUNS number' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:industryCode rdf:type rdf:Property ;
    rdfs:label 'Industry Code' ;
    rdfs:comment 'Standard industry classification (e.g., NAICS) for the entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
