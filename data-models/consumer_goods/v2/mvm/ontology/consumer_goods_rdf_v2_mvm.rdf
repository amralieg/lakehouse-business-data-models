    rdfs:label 'Dropship Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Drop-ship fulfillment: in CPG, sales orders are frequently fulfilled directly by a supplier bypassing the warehouse. Operations and supply chain teams must know which supplier fulfills each drop-ship ' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:pricingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Id' ;
    rdfs:comment 'Foreign key linking to sales.pricing_agreement. Business justification: In consumer goods sales, orders are frequently placed under a specific negotiated pricing agreement (e.g., a promotional deal or contract price). Linking order to pricing_agreement allows the system t' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingAgreement .

ind:repId rdf:type rdf:Property ;
    rdfs:label 'Rep Id' ;
    rdfs:comment 'Foreign key linking to sales.rep. Business justification: Sales orders in consumer goods are placed or managed by a specific sales representative. Linking order to rep enables sales performance tracking, commission calculation, and field sales KPI reporting ' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Date when the outbound order was created or received from the customer. Principal business event timestamp for order lifecycle tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalAmount rdf:type rdf:Property ;
