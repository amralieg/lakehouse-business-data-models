    rdfs:range ind:ProductionLine .

ind:allergenHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Handling Flag' ;
    rdfs:comment 'Indicates whether this production line handles products containing allergens. Critical for cross-contamination prevention and regulatory compliance.' ;
