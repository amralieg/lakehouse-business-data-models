ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the distribution center ceased operations. Null for active facilities. Used for historical analysis and network optimization studies.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary contact email address for the distribution center. Organizational contact data classified as confidential business information.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary contact phone number for the distribution center. Organizational contact data classified as confidential business information.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency Days' ;
    rdfs:comment 'Standard frequency in days for cycle counting inventory at this facility. Used for inventory accuracy management and audit compliance.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dcCode rdf:type rdf:Property ;
    rdfs:label 'Dc Code' ;
    rdfs:comment 'Business identifier code for the distribution center used across operational systems. Externally-known unique code for the facility.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dcName rdf:type rdf:Property ;
    rdfs:label 'Dc Name' ;
    rdfs:comment 'Official business name of the distribution center or warehouse facility.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionFacilityStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Facility Status' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorsInbound rdf:type rdf:Property ;
    rdfs:label 'Dock Doors Inbound' ;
    rdfs:comment 'Number of dock doors designated for inbound receiving operations. Impacts receiving throughput capacity and scheduling.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dockDoorsOutbound rdf:type rdf:Property ;
    rdfs:label 'Dock Doors Outbound' ;
    rdfs:comment 'Number of dock doors designated for outbound shipping operations. Impacts shipping throughput capacity and carrier scheduling.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dsdHubFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Hub Flag' ;
    rdfs:comment 'Indicates whether this facility serves as a DSD hub for direct-to-retail delivery operations. DSD hubs bypass traditional distribution channels for faster store replenishment.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fscCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Fsc Certified Flag' ;
    rdfs:comment 'Indicates whether the facility is certified under FSC chain of custody standards for sustainable sourcing. Required for handling FSC-certified paper and wood-based products.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified Flag' ;
    rdfs:comment 'Indicates whether the facility is certified under Good Manufacturing Practice standards. Required for handling cosmetics, personal care, and certain consumer goods products.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryRotationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Rotation Method' ;
    rdfs:comment 'Primary inventory rotation method used at this facility. FIFO (First In First Out) for standard goods, FEFO (First Expired First Out) for perishables and date-sensitive products, LIFO (Last In First Out) for specific use cases.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Expiration date of the facility lease agreement. Null for owned facilities. Used for lease renewal planning and facility strategy.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date when the distribution center commenced operations. Used for facility age analysis and depreciation calculations.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for weekdays in format HH:MM-HH:MM. Used for scheduling inbound deliveries, outbound shipments, and workforce planning.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Standard operating hours for weekends in format HH:MM-HH:MM. Used for scheduling weekend operations and carrier coordination.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osaTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Osa Target Percentage' ;
    rdfs:comment 'Target OSA performance percentage for stores served by this distribution center. OSA measures product availability at retail shelf level.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Otif Target Percentage' ;
    rdfs:comment 'Target OTIF performance percentage for this distribution center. OTIF measures the percentage of orders delivered on time and in full, a key supply chain KPI.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Purpose classification: distribution, cross-dock, hub' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPlantCode rdf:type rdf:Property ;
    rdfs:label 'Sap Plant Code' ;
    rdfs:comment 'SAP S/4HANA plant code representing this distribution center in the ERP system. Maps to the SAP MM and WM modules for material management and warehouse management.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Sap Storage Location' ;
    rdfs:comment 'SAP S/4HANA storage location code within the plant. Represents the primary storage location identifier for inventory transactions in SAP WM module.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftsPerDay rdf:type rdf:Property ;
    rdfs:label 'Shifts Per Day' ;
    rdfs:comment 'Number of operational shifts per day at the facility. Used for labor planning, throughput capacity modeling, and operational cost analysis.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageCapacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Pallet Positions' ;
    rdfs:comment 'Maximum number of pallet positions available for storage. Key metric for inventory capacity planning and space utilization analysis.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Sqft' ;
    rdfs:comment 'Total warehouse floor space capacity in square feet. Includes all storage, staging, and operational areas within the facility.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsSiteCode rdf:type rdf:Property ;
    rdfs:label 'Wms Site Code' ;
    rdfs:comment 'Unique site identifier in the Blue Yonder WMS system. Used for integration and synchronization between the lakehouse and the operational WMS platform.' ;
    rdfs:domain ind:DistributionFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Primary key for storage_location' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:aisle rdf:type rdf:Property ;
    rdfs:label 'Aisle' ;
    rdfs:comment 'Aisle designation within the warehouse layout for physical navigation and picking route optimization.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bay rdf:type rdf:Property ;
    rdfs:label 'Bay' ;
    rdfs:comment 'Bay or column position within the aisle for precise horizontal location reference.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binPosition rdf:type rdf:Property ;
    rdfs:label 'Bin Position' ;
    rdfs:comment 'Specific bin or slot position within the level for granular inventory placement and retrieval.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedDate rdf:type rdf:Property ;
    rdfs:label 'Blocked Date' ;
    rdfs:comment 'Date when the storage location was blocked or made unavailable for operations.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockedFlag rdf:type rdf:Property ;
    rdfs:label 'Blocked Flag' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockedReason rdf:type rdf:Property ;
    rdfs:label 'Blocked Reason' ;
    rdfs:comment 'Explanation for why the location is blocked or unavailable, such as maintenance, damage, safety hold, or quality quarantine.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountFrequency rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency' ;
    rdfs:comment 'Scheduled frequency for cycle counting inventory at this location to maintain inventory accuracy and compliance.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStorageLocationLevel rdf:type rdf:Property ;
    rdfs:label 'Distribution Storage Location Level' ;
    rdfs:comment 'Vertical level or shelf position within the bay for height-based slotting and equipment compatibility.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStorageLocationStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Storage Location Status' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Eligible Flag' ;
    rdfs:comment 'Indicates whether the location is designated for DSD operations where products bypass the DC and are delivered directly to retail stores.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Required' ;
    rdfs:comment 'Type of material handling equipment required to access this storage location for put-away and picking operations.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fefo Eligible Flag' ;
    rdfs:comment 'Indicates whether the location supports FEFO inventory rotation logic for expiry-sensitive products (pharmaceuticals, food, cosmetics).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fifoEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fifo Eligible Flag' ;
    rdfs:comment 'Indicates whether the location supports FIFO inventory rotation logic for age-based stock management.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Physical height dimension of the storage location in centimeters for vertical clearance and equipment reach validation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date when the most recent cycle count was performed at this storage location.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Physical length dimension of the storage location in centimeters for dimensional slotting and equipment compatibility.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name or description of the storage location for operational reference.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational status of the storage location indicating availability for inventory placement and retrieval.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the storage location by operational function: bulk storage, active pick face, reserve inventory, staging area, dock door, or cross-dock zone.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mixedLotAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Mixed Lot Allowed Flag' ;
    rdfs:comment 'Indicates whether the location permits storage of multiple lot or batch numbers for the same SKU or requires lot segregation.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mixedSkuAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Mixed Sku Allowed Flag' ;
    rdfs:comment 'Indicates whether the location permits storage of multiple SKUs simultaneously or requires single-SKU dedication.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickFaceFlag rdf:type rdf:Property ;
    rdfs:label 'Pick Face Flag' ;
    rdfs:comment 'Indicates whether this location is designated as an active pick face for order fulfillment operations.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickingStrategy rdf:type rdf:Property ;
    rdfs:label 'Picking Strategy' ;
    rdfs:comment 'Order fulfillment picking method supported by this location: batch picking, wave picking, zone picking, discrete (single-order), or cluster picking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayStrategy rdf:type rdf:Property ;
    rdfs:label 'Putaway Strategy' ;
    rdfs:comment 'Algorithm used to assign incoming inventory to this location: directed (system-assigned), random, fixed (dedicated SKU), or dynamic (velocity-based).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentPriority rdf:type rdf:Property ;
    rdfs:label 'Replenishment Priority' ;
    rdfs:comment 'Priority ranking for automated replenishment from reserve to pick locations, with lower numbers indicating higher priority.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Temperature control classification for the storage location to ensure product integrity and regulatory compliance (ambient, refrigerated 2-8°C, frozen <-18°C, controlled room temperature).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Volume Capacity M3' ;
    rdfs:comment 'Maximum volume capacity of the storage location in cubic meters for space utilization and slotting algorithms.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Kg' ;
    rdfs:comment 'Maximum weight capacity of the storage location in kilograms for safe load management and slotting optimization.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Physical width dimension of the storage location in centimeters for dimensional slotting and equipment compatibility.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Logical zone classification within the distribution center for grouping locations by product category, velocity, or operational workflow (e.g., FAST-PICK, SLOW-MOVE, HAZMAT).' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundReceiptId rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Id' ;
    rdfs:comment 'Unique identifier for the inbound receipt transaction. Primary key for this entity.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundReceipt .

ind:primaryInboundDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Inbound Distribution Facility Id' ;
    rdfs:comment 'Identifier of the distribution center facility where the goods were received.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:actualReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Timestamp' ;
    rdfs:comment 'Precise date and time when the physical goods arrived and were checked in at the receiving dock, representing the principal business event for this transaction.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'Reference to the Advanced Shipping Notice document sent by the supplier prior to shipment arrival, enabling pre-receipt planning and dock scheduling.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseCount rdf:type rdf:Property ;
    rdfs:label 'Case Count' ;
    rdfs:comment 'Number of cases or cartons received in this inbound shipment.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'ISO standard container identifier for ocean freight shipments, following the BIC (Bureau International des Containers) format.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicator of whether any discrepancies (quantity, quality, or documentation) were identified during the receiving process.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text description providing additional details about any discrepancies identified during the receiving process.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyReason rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Reason' ;
    rdfs:comment 'Classification of the type of discrepancy identified during receiving, used for root cause analysis and supplier performance management.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorNumber rdf:type rdf:Property ;
    rdfs:label 'Dock Door Number' ;
    rdfs:comment 'Physical dock door location where the inbound shipment was unloaded, used for labor planning and dock utilization tracking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity' ;
    rdfs:comment 'Total quantity of goods expected to be received based on the ASN or purchase order, used for discrepancy detection.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Status' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Compliant Flag' ;
    rdfs:comment 'Indicator of whether this receipt met both on-time delivery and complete quantity requirements, key supplier performance metric.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Number of pallets received in this inbound shipment, used for dock capacity planning and labor allocation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:putawayCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Putaway Completion Timestamp' ;
    rdfs:comment 'Date and time when all received goods were moved from the receiving dock to their designated storage locations, completing the inbound process.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Current status of the quality inspection process for this receipt, tracking progression through quality control workflow.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Completion Timestamp' ;
    rdfs:comment 'Date and time when all receiving activities (unloading, inspection, put-away) were completed and the receipt was closed in the WMS.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The date when the inventory lot was received into the distribution center. Used for inventory aging and supplier performance tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Externally-known business identifier for the inbound receipt, used for tracking and reference across systems and with suppliers.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the inbound receipt transaction, tracking progression from scheduling through completion or exception handling.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptType rdf:type rdf:Property ;
    rdfs:label 'Receipt Type' ;
    rdfs:comment 'Classification of the inbound receipt based on the source and nature of the goods being received.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Receipt Date' ;
    rdfs:comment 'Planned date for the inbound shipment to arrive at the distribution center, based on ASN or supplier commitment.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Indicator of whether the security seal was found intact upon arrival, critical for quality control and loss prevention.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Security seal identifier applied to the trailer or container, verified upon receipt to ensure shipment integrity and prevent tampering.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Check Required Flag' ;
    rdfs:comment 'Indicator of whether temperature verification was required for this receipt due to cold chain or temperature-sensitive product requirements.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Compliant Flag' ;
    rdfs:comment 'Indicator of whether the recorded temperature was within acceptable range per product specifications and cold chain requirements.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureReadingCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Reading Celsius' ;
    rdfs:comment 'Actual temperature reading in Celsius recorded during receipt inspection for temperature-sensitive products, critical for cold chain compliance.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trailerNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Number' ;
    rdfs:comment 'Unique identifier of the trailer or truck that delivered the shipment, used for tracking and carrier performance analysis.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundReceiptLineId rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Line Id' ;
    rdfs:comment 'Unique identifier for the inbound receipt line. Primary key for this entity.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Foreign key linking to procurement.po_line. Business justification: Three-way match (PO qty vs. received qty vs. invoice qty) is a core procurement control in consumer goods. Linking receipt lines to PO lines enables automated variance detection, OTIF measurement at l' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:putawayDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Putaway Distribution Storage Location Id' ;
    rdfs:comment 'Foreign key linking to distribution.distribution_storage_location. Business justification: Each inbound receipt line is put away to a specific storage location within the DC. This FK captures the physical putaway destination at the line level, enabling FEFO/FIFO rotation tracking, cycle cou' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:asnLineNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Line Number' ;
    rdfs:comment 'Line number within the ASN document corresponding to this receipt line. Enables automated matching between ASN and physical receipt.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionCode rdf:type rdf:Property ;
    rdfs:label 'Condition Code' ;
    rdfs:comment 'Quality condition assessment of the received goods. Determines whether product can be put away into available inventory or requires special handling.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Free-text description of any damage, defects, or quality issues observed during receipt inspection. Used for claims and supplier performance tracking.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedQuantityCases rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity Cases' ;
    rdfs:comment 'Expected quantity in cases as specified in the Advanced Shipping Notice (ASN) or purchase order. Used for variance detection.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedQuantityEaches rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity Eaches' ;
    rdfs:comment 'Expected quantity in eaches as specified in the Advanced Shipping Notice (ASN) or purchase order. Used for variance detection.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedCost rdf:type rdf:Property ;
    rdfs:label 'Extended Cost' ;
    rdfs:comment 'Total cost for this receipt line calculated as unit cost multiplied by received quantity. Used for inventory valuation and financial reconciliation.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundReceiptLineStatus rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Line Status' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Manufacturing lot or batch number assigned by the supplier. Critical for traceability, quality control, and recall management in consumer goods.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletCode rdf:type rdf:Property ;
    rdfs:label 'Pallet Code' ;
    rdfs:comment 'Unique identifier for the pallet or handling unit containing this receipt line. Used for put-away and storage location assignment.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putAwayTimestamp rdf:type rdf:Property ;
    rdfs:label 'Put Away Timestamp' ;
    rdfs:comment 'Date and time when the goods were put away into their assigned storage location. Used for warehouse productivity and cycle time measurement.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivedQuantityCases rdf:type rdf:Property ;
    rdfs:label 'Received Quantity Cases' ;
    rdfs:comment 'Quantity of product received measured in cases. Represents the outer packaging unit typically used for warehouse handling.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedQuantityEaches rdf:type rdf:Property ;
    rdfs:label 'Received Quantity Eaches' ;
    rdfs:comment 'Quantity of product received measured in individual units (eaches). Represents the consumer-facing unit count.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time when the goods were physically received at the warehouse dock. Critical for OTIF performance measurement and cycle time analytics.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sscc rdf:type rdf:Property ;
    rdfs:label 'Sscc' ;
    rdfs:comment '18-digit Serial Shipping Container Code identifying the logistics unit. Global standard for tracking pallets and containers in the supply chain.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtReceiptCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature At Receipt Celsius' ;
    rdfs:comment 'Temperature measurement in Celsius recorded at the time of receipt. Critical for cold chain compliance and product quality verification.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantityCases rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity Cases' ;
    rdfs:comment 'Difference between expected and received quantity in cases. Positive values indicate overages, negative values indicate shortages.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantityEaches rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity Eaches' ;
    rdfs:comment 'Difference between expected and received quantity in eaches. Positive values indicate overages, negative values indicate shortages.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Code' ;
    rdfs:comment 'Code identifying the distribution center or warehouse facility where the receipt occurred. Used for multi-site inventory management.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundOrderId rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Id' ;
    rdfs:comment 'Unique identifier for the outbound fulfillment order. Primary key for the outbound order entity.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundOrder .

ind:primaryOutboundDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Outbound Distribution Facility Id' ;
    rdfs:comment 'Identifier of the distribution center fulfilling the outbound order. Determines inventory source and warehouse operations responsible for order execution.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:primaryOutboundSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Outbound Sales Order Id' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Date when the order was actually delivered to the customer destination. Used to calculate OTIF performance and delivery lead time.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backorderFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Flag' ;
    rdfs:comment 'Indicates whether any line items on the order are backordered due to insufficient inventory. True when ordered quantity exceeds available stock.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Carrier-issued document number serving as receipt of goods and contract of carriage. Required for freight claims and proof of delivery.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Date and time when the order was cancelled. Null for active orders. Used for cancellation rate analysis and order lifecycle reporting.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fillRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Percentage' ;
    rdfs:comment 'Percentage of ordered quantity that was fulfilled from available inventory. Calculated as (shipped quantity / ordered quantity) * 100. Key metric for inventory availability and customer service.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'International Commercial Terms defining the division of costs and risks between buyer and seller. Critical for export orders and freight responsibility determination. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Commitment Flag' ;
    rdfs:comment 'Indicates whether this order is subject to formal OTIF performance measurement and customer scorecard reporting. True for orders with contractual delivery commitments.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outboundOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Status' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingSlipNumber rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Number' ;
    rdfs:comment 'Document number for the packing slip accompanying the shipment. Used for customer receiving and invoice reconciliation.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Pick Ticket Number' ;
    rdfs:comment 'Warehouse document number used to direct picking operations for this order. Generated by WMS when order is released to the warehouse floor.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Timestamp' ;
    rdfs:comment 'Date and time when delivery was confirmed by the recipient. Captured from carrier POD or customer signature. Used for OTIF measurement and freight audit.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Customer\'s purchase order number provided for order tracking and invoice reconciliation. Required for EDI (Electronic Data Interchange) transactions with retail customers.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'Date when the customer or system requests the order to be shipped from the distribution center. Used for warehouse planning and scheduling.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the order must be delivered to the customer destination. Critical for OTIF (On Time In Full) performance measurement and SLA compliance.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Delivery speed commitment for the outbound order. Determines carrier selection, freight cost, and OTIF measurement criteria.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Transportation mode used for order delivery. Ground for truck, air for expedited freight, ocean for international, rail for bulk, parcel for small packages, LTL (Less Than Truckload) for partial loads, FTL (Full Truckload) for full loads. [ENUM-REF-CANDIDATE: ground|air|ocean|rail|parcel|ltl|ftl — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text instructions for warehouse and logistics teams regarding special handling requirements. May include temperature control, fragile handling, hazmat procedures, or customer-specific delivery instructions.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Order Quantity' ;
    rdfs:comment 'Total quantity of units across all line items in the outbound order. Used for warehouse capacity planning and OTIF fill rate calculation.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Total monetary value of the outbound order before taxes and freight charges. Used for order prioritization, credit limit checks, and revenue forecasting.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Order Volume M3' ;
    rdfs:comment 'Total volume of the outbound order in cubic meters. Used for warehouse space planning, truck cube utilization, and pallet configuration.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Order Weight Kg' ;
    rdfs:comment 'Total weight of the outbound order in kilograms. Used for freight cost calculation, carrier capacity planning, and vehicle loading optimization.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-provided tracking number for shipment visibility and customer self-service tracking. Used for parcel and LTL shipments.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveCode rdf:type rdf:Property ;
    rdfs:label 'Wave Code' ;
    rdfs:comment 'Identifier of the warehouse wave that includes this order. Wave picking groups orders for efficient batch picking and resource optimization.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outboundOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Line Id' ;
    rdfs:comment 'Unique identifier for the outbound order line item.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundOrderLine .

ind:baseUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Unit Quantity' ;
    rdfs:comment 'Quantity converted to base unit of measure for standardized reporting and inventory tracking.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerPoLineNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Po Line Number' ;
    rdfs:comment 'Customer\'s purchase order line number for cross-reference and reconciliation.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Flag' ;
    rdfs:comment 'Indicates whether this line is part of a direct store delivery order bypassing retailer distribution centers.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediLineReference rdf:type rdf:Property ;
    rdfs:label 'Edi Line Reference' ;
    rdfs:comment 'EDI transaction line reference number for electronic order processing and ASN generation.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingUnitCode rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Code' ;
    rdfs:comment 'Serial shipping container code (SSCC) or handling unit identifier for the container holding this line item.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Line Volume M3' ;
    rdfs:comment 'Total volume of the shipped quantity for this line in cubic meters.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineWeightKg rdf:type rdf:Property ;
    rdfs:label 'Line Weight Kg' ;
    rdfs:comment 'Total weight of the shipped quantity for this line in kilograms.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'Quantity of the SKU originally requested by the customer in the order.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifStatus rdf:type rdf:Property ;
    rdfs:label 'Otif Status' ;
    rdfs:comment 'Line-level OTIF performance status indicating whether the line was delivered on time and in full quantity.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundOrderLineStatus rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Line Status' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Timestamp' ;
    rdfs:comment 'Date and time when the line item was packed into shipping containers.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packedQuantity rdf:type rdf:Property ;
    rdfs:label 'Packed Quantity' ;
    rdfs:comment 'Quantity packed into shipping containers and ready for dispatch.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Timestamp' ;
    rdfs:comment 'Date and time when the line item was picked from warehouse inventory.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickZone rdf:type rdf:Property ;
    rdfs:label 'Pick Zone' ;
    rdfs:comment 'Warehouse pick zone designation for labor management and routing optimization.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickedQuantity rdf:type rdf:Property ;
    rdfs:label 'Picked Quantity' ;
    rdfs:comment 'Quantity physically picked from warehouse storage locations during fulfillment.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumbers rdf:type rdf:Property ;
    rdfs:label 'Serial Numbers' ;
    rdfs:comment 'Comma-separated list of serial numbers for serialized inventory items shipped on this line.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ship Timestamp' ;
    rdfs:comment 'Date and time when the line item was shipped from the distribution center.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shortShipFlag rdf:type rdf:Property ;
    rdfs:label 'Short Ship Flag' ;
    rdfs:comment 'Indicates whether this line was short-shipped (shipped quantity less than ordered quantity).' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortShipReasonCode rdf:type rdf:Property ;
    rdfs:label 'Short Ship Reason Code' ;
    rdfs:comment 'Reason code for short shipment (OOS=Out of Stock, DAMAGE=Damaged Inventory, RECALL=Product Recall, EXPIRED=Expired Product, ALLOCATION=Allocation Constraint).' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Unit Volume M3' ;
    rdfs:comment 'Volume per unit of the SKU in cubic meters for space utilization and load planning.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitWeightKg rdf:type rdf:Property ;
    rdfs:label 'Unit Weight Kg' ;
    rdfs:comment 'Weight per unit of the SKU in kilograms for freight calculation and capacity planning.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseLocationCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Code' ;
    rdfs:comment 'Distribution center or warehouse location code from which this line was fulfilled.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickTaskId rdf:type rdf:Property ;
    rdfs:label 'Pick Task Id' ;
    rdfs:comment 'Unique identifier for the pick task record. Primary key for the pick_task data product.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Distribution Storage Location Id' ;
    rdfs:comment 'Reference to the target location where picked items are staged or packed (e.g., pack station, staging lane, loading dock).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:primaryPickDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Pick Distribution Storage Location Id' ;
    rdfs:comment 'Reference to the warehouse storage location (bin, shelf, pallet position) from which inventory is picked.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:shipmentDistributionShipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Distribution Shipment Id' ;
    rdfs:comment 'Foreign key linking to distribution.distribution_shipment. Business justification: Pick and pack tasks are the operational execution units that feed into outbound shipments. Many pick tasks are consolidated into a single distribution shipment (one shipment = many cartons/tasks). Thi' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:cartonCode rdf:type rdf:Property ;
    rdfs:label 'Carton Code' ;
    rdfs:comment 'Unique identifier for the carton or shipping container into which items are packed. May be a license plate number (LPN) or SSCC (Serial Shipping Container Code).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Code identifying any exception or issue encountered during task execution (e.g., short pick, damaged goods, location discrepancy). Null if no exception.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text notes entered by the operator or supervisor describing the exception or issue encountered during task execution.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gs1128Label rdf:type rdf:Property ;
    rdfs:label 'Gs1 128 Label' ;
    rdfs:comment 'The GS1-128 barcode label data applied to the carton or pallet, encoding SSCC, GTIN, lot, expiry, and other supply chain attributes.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether this pick task is subject to OTIF (On Time In Full) performance measurement (true = OTIF tracked, false = not tracked).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packStationCode rdf:type rdf:Property ;
    rdfs:label 'Pack Station Code' ;
    rdfs:comment 'Reference to the packing station where the packing operation is performed. Applicable when task_type includes packing.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packagingMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Code' ;
    rdfs:comment 'Code identifying the type of packaging material used (e.g., corrugated box, poly bag, shrink wrap). Used for cartonization and sustainability tracking.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickAccuracyFlag rdf:type rdf:Property ;
    rdfs:label 'Pick Accuracy Flag' ;
    rdfs:comment 'Boolean indicator of whether the pick was accurate (true = picked quantity matches requested quantity and correct SKU/lot; false = discrepancy detected).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickListNumber rdf:type rdf:Property ;
    rdfs:label 'Pick List Number' ;
    rdfs:comment 'Human-readable pick list reference number assigned by the WMS for operator identification and tracking.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickQuantity rdf:type rdf:Property ;
    rdfs:label 'Pick Quantity' ;
    rdfs:comment 'The quantity of SKU units to be picked for this task, measured in the SKU\'s base unit of measure.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickTaskStatus rdf:type rdf:Property ;
    rdfs:label 'Pick Task Status' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Priority classification of the pick task for sequencing and resource allocation: urgent (immediate), high (expedited), normal (standard), low (backlog).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskAssignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Assigned Timestamp' ;
    rdfs:comment 'Timestamp when the pick task was assigned to an operator by the WMS. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Completed Timestamp' ;
    rdfs:comment 'Timestamp when the pick task was completed and confirmed by the operator or WMS. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Task Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from task start to completion. Used for labor productivity analysis and standard time calculation.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Started Timestamp' ;
    rdfs:comment 'Timestamp when the operator began executing the pick task (scanned start or confirmed task initiation). Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the pick task: pending (awaiting assignment), assigned (allocated to operator), in_progress (actively being executed), completed (finished successfully), cancelled (voided), on_hold (temporarily suspended).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Discriminator indicating the type of fulfillment task: pick (picking only), pack (packing only), pick_and_pack (combined operation), or replenishment_pick (internal stock movement).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Unique identifier for the distribution shipment record. Primary key for the distribution shipment entity.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Actual date and time when the shipment was delivered and received at the destination. Used for final OTIF calculation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual date and time when the shipment departed the DC. Critical for OTIF calculation and carrier performance tracking.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Level' ;
    rdfs:comment 'Service tier selected for this shipment defining speed and handling requirements.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartonCount rdf:type rdf:Property ;
    rdfs:label 'Carton Count' ;
    rdfs:comment 'Total number of cartons or cases included in the shipment. Used for piece-level tracking and receiving verification.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Destination Address Line1' ;
    rdfs:comment 'Primary street address line of the shipment destination. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCity rdf:type rdf:Property ;
    rdfs:label 'Destination City' ;
    rdfs:comment 'City name of the shipment destination address.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Code' ;
    rdfs:comment 'Business identifier of the destination location (store number, DC code, customer account number) where goods are being delivered.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the shipment destination for customs and routing purposes.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationName rdf:type rdf:Property ;
    rdfs:label 'Destination Name' ;
    rdfs:comment 'Human-readable name of the destination location for display and confirmation purposes.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the shipment destination. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStateProvince rdf:type rdf:Property ;
    rdfs:label 'Destination State Province' ;
    rdfs:comment 'State or province code of the shipment destination address.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationType rdf:type rdf:Property ;
    rdfs:label 'Destination Type' ;
    rdfs:comment 'Classification of the shipment destination entity type for routing and handling purposes.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionShipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Shipment Status' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Timestamp' ;
    rdfs:comment 'Current estimated delivery date and time based on real-time tracking and carrier updates. Updated dynamically during transit.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Amount' ;
    rdfs:comment 'Total freight cost charged for this shipment in the transaction currency. Used for logistics cost analysis and freight audit.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the freight charge amount.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Terms defining which party is responsible for freight payment and at what point ownership transfers. Critical for cost allocation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Document Number' ;
    rdfs:comment 'SAP SD goods issue document number linking the physical shipment to the ERP inventory transaction. Critical for inventory accuracy.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inFullFlag rdf:type rdf:Property ;
    rdfs:label 'In Full Flag' ;
    rdfs:comment 'Boolean indicator of whether the shipment was delivered complete with all ordered quantities. Component of OTIF calculation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemCount rdf:type rdf:Property ;
    rdfs:label 'Line Item Count' ;
    rdfs:comment 'Total number of distinct SKU line items included in the shipment. Used for picking complexity and receiving planning.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadNumber rdf:type rdf:Property ;
    rdfs:label 'Load Number' ;
    rdfs:comment 'Identifier of the load plan that consolidated multiple orders or shipments into this trailer. Used for load optimization tracking.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Flag' ;
    rdfs:comment 'Boolean indicator of whether the shipment was delivered within the committed delivery window. Component of OTIF calculation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Carrier-assigned progressive number used for tracking and tracing the shipment in the carriers system.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'Planned date for the shipment to arrive at the destination. Used for customer commitment and OTIF measurement.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Timestamp' ;
    rdfs:comment 'Planned date and time for the shipment to arrive at the destination. Precision timestamp for delivery window commitments.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Timestamp' ;
    rdfs:comment 'Planned date and time for the shipment to depart from the DC dock. Precision timestamp for appointment scheduling and carrier coordination.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledShipDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Ship Date' ;
    rdfs:comment 'Planned date for the shipment to depart from the distribution center. Used for OTIF performance measurement baseline.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally-known unique business identifier for the shipment assigned by the WMS. Used for tracking and reference across systems and with carriers.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment in the outbound fulfillment workflow. Tracks progression from planning through final delivery. [ENUM-REF-CANDIDATE: planned|staged|loading|loaded|departed|in_transit|delivered|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Classification of the shipment based on delivery method and business purpose. DSD indicates Direct Store Delivery channel.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUnits rdf:type rdf:Property ;
    rdfs:label 'Total Units' ;
    rdfs:comment 'Total quantity of individual sellable units (eaches) included in the shipment across all SKUs.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cubic Meters' ;
    rdfs:comment 'Total cube or volume of the shipment in cubic meters. Critical for trailer utilization and dimensional weight calculations.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment in kilograms including product and packaging. Used for freight rating and load planning.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waveNumber rdf:type rdf:Property ;
    rdfs:label 'Wave Number' ;
    rdfs:comment 'Identifier of the warehouse picking wave that generated the orders included in this shipment. Links shipment to WMS wave planning.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryPositionId rdf:type rdf:Property ;
    rdfs:label 'Inventory Position Id' ;
    rdfs:comment 'Primary key for inventory_position' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualWeight rdf:type rdf:Property ;
    rdfs:label 'Actual Weight' ;
    rdfs:comment 'The actual measured weight of the inventory for catch weight items. Used for billing and compliance when item weight varies.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asOfDate rdf:type rdf:Property ;
    rdfs:label 'As Of Date' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:catchWeightFlag rdf:type rdf:Property ;
    rdfs:label 'Catch Weight Flag' ;
    rdfs:comment 'Indicates whether the SKU is a catch weight item requiring actual weight capture at transaction time (true) or standard weight (false).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysOnHand rdf:type rdf:Property ;
    rdfs:label 'Days On Hand' ;
    rdfs:comment 'The number of days the inventory has been on hand since receipt. Calculated as current date minus receipt date. Used for aging analysis.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysToExpiry rdf:type rdf:Property ;
    rdfs:label 'Days To Expiry' ;
    rdfs:comment 'The number of days remaining until the inventory lot expires. Calculated as expiry date minus current date. Critical for FEFO rotation and markdown decisions.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryCondition rdf:type rdf:Property ;
    rdfs:label 'Inventory Condition' ;
    rdfs:comment 'The physical condition classification of the inventory. Used for disposition decisions and channel restrictions.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'The current operational status of the inventory position. Determines availability for picking and order fulfillment.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'The date when inventory was last moved into or out of this storage location. Used for slow-moving inventory identification.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementType rdf:type rdf:Property ;
    rdfs:label 'Last Movement Type' ;
    rdfs:comment 'The type of the last inventory movement transaction that affected this position (receipt, putaway, pick, replenishment, transfer, adjustment, return). [ENUM-REF-CANDIDATE: receipt|putaway|pick|replenishment|transfer|adjustment|return — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensePlateNumber rdf:type rdf:Property ;
    rdfs:label 'License Plate Number' ;
    rdfs:comment 'The warehouse management system license plate number assigned to the handling unit. Used for tracking and automated material handling.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onHandQuantity rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Indicates the ownership model of the inventory (owned by company, consignment from supplier, customer-owned for returns, vendor-managed inventory).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayDate rdf:type rdf:Property ;
    rdfs:label 'Putaway Date' ;
    rdfs:comment 'The date when the inventory was put away into this storage location after receiving. Used for aging analysis and FEFO compliance.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityAllocated rdf:type rdf:Property ;
    rdfs:label 'Quantity Allocated' ;
    rdfs:comment 'The quantity of on-hand inventory that has been allocated to outbound orders or reservations but not yet picked. Reduces available-to-pick quantity.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'The quantity available for new order allocation and picking. Calculated as quantity_on_hand minus quantity_allocated minus quantity_quarantine minus quantity_hold.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDamaged rdf:type rdf:Property ;
    rdfs:label 'Quantity Damaged' ;
    rdfs:comment 'The quantity of inventory identified as damaged and not suitable for sale or distribution. Typically awaiting disposal or return to supplier.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityHold rdf:type rdf:Property ;
    rdfs:label 'Quantity Hold' ;
    rdfs:comment 'The quantity of inventory placed on hold due to quality issues, customer complaints, or pending investigation. Not available for picking.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'The total physical quantity of the SKU-lot currently present in the storage location. Measured in the SKU\'s base unit of measure.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityQuarantine rdf:type rdf:Property ;
    rdfs:label 'Quantity Quarantine' ;
    rdfs:comment 'The quantity of inventory placed in quarantine status pending quality inspection or regulatory clearance. Not available for picking.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'The quantity of inventory reserved for specific customers, channels, or promotional programs. Subset of allocated quantity with additional business constraints.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentFlag rdf:type rdf:Property ;
    rdfs:label 'Replenishment Flag' ;
    rdfs:comment 'Indicates whether this inventory position requires replenishment from reserve to pick face (true) or not (false). Triggers automated replenishment tasks.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'The timestamp when this inventory position snapshot was captured. Used for point-in-time inventory reporting and trend analysis.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:storageZone rdf:type rdf:Property ;
    rdfs:label 'Storage Zone' ;
    rdfs:comment 'The logical zone within the distribution center where the inventory is stored (e.g., ambient, refrigerated, frozen, hazmat, high-velocity, reserve).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalInventoryValue rdf:type rdf:Property ;
    rdfs:label 'Total Inventory Value' ;
    rdfs:comment 'The total financial value of the inventory position calculated as quantity_on_hand multiplied by cost_per_unit. Used for balance sheet reporting. Business confidential financial data.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Weight Unit Of Measure' ;
    rdfs:comment 'The unit of measure for actual weight (Pound, Kilogram, Ounce, Gram). Applicable for catch weight items.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMinorityOwned rdf:type rdf:Property ;
    rdfs:label 'Is Minority Owned' ;
    rdfs:comment 'Minority-owned business flag' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStrategicSupplier rdf:type rdf:Property ;
    rdfs:label 'Is Strategic Supplier' ;
    rdfs:comment 'Strategic supplier flag' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWomanOwned rdf:type rdf:Property ;
    rdfs:label 'Is Woman Owned' ;
    rdfs:comment 'Woman-owned business flag' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onTimeDeliveryPct rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Pct' ;
    rdfs:comment 'OTD percentage' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Quality performance rating' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Status' ;
    rdfs:comment 'Active, inactive, blocked' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierType rdf:type rdf:Property ;
    rdfs:label 'Supplier Type' ;
    rdfs:comment 'Type of supplier (raw material, packaging, service)' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimarySite rdf:type rdf:Property ;
    rdfs:label 'Is Primary Site' ;
    rdfs:comment 'Primary site flag' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Unique site code' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Site name' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Manufacturing, warehouse, office' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Auto-renewal flag' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Contract number' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Active, expired, terminated' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Type of contract' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Contract end date' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'Incoterms' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Contract start date' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Total contract value' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractLineId rdf:type rdf:Property ;
    rdfs:label 'Contract Line Id' ;
    rdfs:comment 'Primary key' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractLine .

ind:lineValue rdf:type rdf:Property ;
    rdfs:label 'Line Value' ;
    rdfs:comment 'Line total value' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'PO date' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'PO number' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Draft, issued, received, closed' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originOrderId rdf:type rdf:Property ;
    rdfs:label 'Origin Order Id' ;
    rdfs:comment 'Foreign key linking to sales.order. Business justification: Demand-driven procurement traceability: in make-to-order and direct replenishment CPG scenarios, PO lines are created in response to specific sales orders. Supply chain analysts and auditors require e' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Requested delivery date' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'Line total' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Supplier Invoice Id' ;
    rdfs:comment 'Primary key' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierInvoice .

ind:invoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Amount' ;
    rdfs:comment 'Invoice amount' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Primary key' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPreferredSupplier rdf:type rdf:Property ;
    rdfs:label 'Is Preferred Supplier' ;
    rdfs:comment 'Preferred supplier flag' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ranking rdf:type rdf:Property ;
    rdfs:label 'Ranking' ;
    rdfs:comment 'Supplier ranking' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accrualAmount rdf:type rdf:Property ;
    rdfs:label 'Accrual Amount' ;
    rdfs:comment 'Total accrued trade spend liability for this promotion, representing funds reserved or committed but not yet paid to the retailer.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Authorized Budget Amount' ;
    rdfs:comment 'Total authorized trade spend budget allocated for this promotion, including all funding mechanisms (off-invoice, scan-back, display allowances, etc.). Expressed in the company\'s reporting currency.' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Baseline Volume Units' ;
    rdfs:comment 'Expected sales volume in units without the promotion, used as the baseline for calculating incremental lift and ROI.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Retail channel classification where this promotion is executed. Grocery (supermarkets), mass merchandiser (Walmart/Target), drug (pharmacy chains), convenience (c-stores), club (warehouse clubs), ecommerce (online retail).' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponFlag rdf:type rdf:Property ;
    rdfs:label 'Coupon Flag' ;
    rdfs:comment 'Indicates whether this promotion includes manufacturer or retailer coupons (print, digital, or mobile). True if coupons are part of the promotion, false otherwise.' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deductionAmount rdf:type rdf:Property ;
    rdfs:label 'Deduction Amount' ;
    rdfs:comment 'Total deductions taken by the retailer against invoices for this promotion. Used for reconciliation and settlement tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:displayType rdf:type rdf:Property ;
    rdfs:label 'Display Type' ;
    rdfs:comment 'Type of in-store merchandising display associated with this promotion. End-cap (end of aisle), free-standing (floor display), shelf-talker (shelf signage), pallet (bulk display), cooler (refrigerated display), none (no special display).' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedRoiPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Roi Percentage' ;
    rdfs:comment 'Expected return on investment for this promotion, calculated as (incremental profit / trade spend) * 100. Used for pre-event planning and approval.' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureAdFlag rdf:type rdf:Property ;
    rdfs:label 'Feature Ad Flag' ;
    rdfs:comment 'Indicates whether this promotion includes feature advertising in retailer circulars, flyers, or digital media. True if featured, false otherwise.' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fundingType rdf:type rdf:Property ;
    rdfs:label 'Funding Type' ;
    rdfs:comment 'Mechanism by which trade funds are provided to the retailer. Off-invoice (deducted at purchase), scan-back (reimbursed based on POS sales), bill-back (invoiced after event), lump-sum (fixed payment), accrual (reserved funds).' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPurchaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Purchase Quantity' ;
    rdfs:comment 'Maximum number of units a consumer can purchase at the promotional price. Null if no maximum limit applies.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumPurchaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Purchase Quantity' ;
    rdfs:comment 'Minimum number of units a consumer must purchase to qualify for the promotional offer. Null if no minimum applies.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'Retailer pricing strategy context for this promotion. Hi-Lo (high-low promotional pricing with deep discounts), EDLP (everyday low price with minimal promotions), hybrid (combination approach).' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionName rdf:type rdf:Property ;
    rdfs:label 'Promotion Name' ;
    rdfs:comment 'Descriptive name of the trade promotion program for business user identification and reporting purposes.' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionNumber rdf:type rdf:Property ;
    rdfs:label 'Promotion Number' ;
    rdfs:comment 'Business-facing unique identifier for the trade promotion program, typically generated by the TPM system. Format: TPM-YYYYNNNN where YYYY is year and NNNN is sequence.' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionObjective rdf:type rdf:Property ;
    rdfs:label 'Promotion Objective' ;
    rdfs:comment 'Primary business objective driving the trade promotion strategy. Volume growth (increase unit sales), market share gain (capture competitor share), new product launch (trial generation), competitive defense (respond to competitor activity), inventory clearance (reduce excess stock), seasonal event (holiday/event-driven).' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionStatus rdf:type rdf:Property ;
    rdfs:label 'Promotion Status' ;
    rdfs:comment 'Current lifecycle status of the trade promotion. Planned (in design), approved (authorized for execution), active (currently running), closed (completed with results finalized), cancelled (terminated before completion), on-hold (temporarily suspended).' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionType rdf:type rdf:Property ;
    rdfs:label 'Promotion Type' ;
    rdfs:comment 'Classification of the trade promotion mechanism. Temporary price reduction (Hi-Lo), feature ad (retailer circular), display (end-cap/shelf), BOGO (buy-one-get-one), multi-buy (quantity discount), scan-back (post-sale rebate). [ENUM-REF-CANDIDATE: temporary_price_reduction|feature_ad|display|bogo|multi_buy|scan_back|off_invoice|coupon|loyalty_reward|edlp|slotting_allowance|markdown_allowance — promote to reference product]' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Status of financial settlement and reconciliation for trade promotion deductions and accruals. Pending (awaiting settlement), in-progress (reconciliation underway), settled (fully reconciled and paid), disputed (discrepancies under review).' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Target Volume Units' ;
    rdfs:comment 'Target sales volume in units expected to be achieved during the promotion period, including baseline and incremental lift.' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tpmSystemReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Tpm System Reference Code' ;
    rdfs:comment 'External reference identifier from the source Trade Promotion Management system (e.g., Salesforce Consumer Goods Cloud TPM module). Used for system integration and traceability.' ;
    rdfs:domain ind:TradePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualTradeSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Trade Spend Amount' ;
    rdfs:comment 'The realized trade spend for this promotional event, representing the total investment actually incurred by the manufacturer.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Actual Volume Units' ;
    rdfs:comment 'The realized sales volume in units achieved during the promotional event, used for post-event analysis and lift measurement.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The date when this promotional event was cancelled, if applicable.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Business-facing unique identifier for the promotion event, used for external communication and reporting.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the promotional event. Planned: event scheduled but not yet approved; Approved: event approved for execution; In Execution: event currently active; Completed: event finished; Cancelled: event terminated before completion.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the promotional event mechanism. Feature Ad: product featured in retailer circular; Display: in-store display placement; Temporary Price Reduction (TPR): short-term price discount; BOGO: Buy One Get One offer; Scan-Back: post-sale rebate based on scanned sales; Coupon: manufacturer or retailer coupon redemption.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'The primary source of funding for this promotional event. Manufacturer: fully funded by manufacturer; Retailer: fully funded by retailer; Cooperative: jointly funded by both parties.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographyCode rdf:type rdf:Property ;
    rdfs:label 'Geography Code' ;
    rdfs:comment 'Three-letter ISO country code representing the geographic market where the event is executed.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmroiRatio rdf:type rdf:Property ;
    rdfs:label 'Gmroi Ratio' ;
    rdfs:comment 'The gross margin return on investment for this promotional event, calculated as Gross Margin / Average Inventory Investment, measuring profitability efficiency.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTradeSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Trade Spend Amount' ;
    rdfs:comment 'The budgeted trade spend allocation for this promotional event, representing the total investment planned by the manufacturer.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Planned Volume Units' ;
    rdfs:comment 'The forecasted sales volume in units expected during the promotional event, used for planning and ROI estimation.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postEventAnalysisCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Post Event Analysis Completed Flag' ;
    rdfs:comment 'Boolean indicator of whether post-event analysis has been completed for this promotional event, including lift measurement and ROI calculation.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postEventAnalysisDate rdf:type rdf:Property ;
    rdfs:label 'Post Event Analysis Date' ;
    rdfs:comment 'The date when post-event analysis was completed for this promotional event.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalLiftPercentage rdf:type rdf:Property ;
    rdfs:label 'Promotional Lift Percentage' ;
    rdfs:comment 'The percentage increase in sales volume attributable to the promotional event, calculated as (Actual Volume - Baseline Volume) / Baseline Volume * 100.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount' ;
    rdfs:comment 'The total rebate amount paid to the retailer for this promotional event, typically calculated post-event based on performance metrics.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roiPercentage rdf:type rdf:Property ;
    rdfs:label 'Roi Percentage' ;
    rdfs:comment 'The return on investment for this promotional event, calculated as (Incremental Profit - Trade Spend) / Trade Spend * 100, measuring promotional effectiveness.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesforceTpmEventCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Tpm Event Code' ;
    rdfs:comment 'The unique identifier from Salesforce Consumer Goods Cloud Trade Promotion Management system for this event record, used for system integration and data lineage.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date when financial settlement for this promotional event was completed and all trade spend obligations were resolved.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventSkuId rdf:type rdf:Property ;
    rdfs:label 'Event Sku Id' ;
    rdfs:comment 'Unique identifier for the promotion event SKU association record. Primary key for this entity.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retailerFundingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Retailer Funding Agreement Id' ;
    rdfs:comment 'Reference to the retailer funding agreement or trade contract governing the promotional terms for this SKU.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundingAgreement .

ind:actualPromotionalVolumeCases rdf:type rdf:Property ;
    rdfs:label 'Actual Promotional Volume Cases' ;
    rdfs:comment 'Actual volume of cases sold during the promotion period for this SKU. Captured post-event from POS or shipment data.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPromotionalVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Actual Promotional Volume Units' ;
    rdfs:comment 'Actual volume of consumer units sold during the promotion period for this SKU. Used for promotional lift and ROI analysis.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineVolumeEstimateUnits rdf:type rdf:Property ;
    rdfs:label 'Baseline Volume Estimate Units' ;
    rdfs:comment 'Estimated volume of units that would have been sold without the promotion. Used to calculate incremental lift. Typically derived from historical sales trends.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Status' ;
    rdfs:comment 'Status of promotional pricing compliance verification for this SKU. Ensures promotional pricing was executed as agreed with the retailer.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified Date' ;
    rdfs:comment 'Date when promotional pricing compliance was verified for this SKU through retail execution audits or POS data validation.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:displayLocationType rdf:type rdf:Property ;
    rdfs:label 'Display Location Type' ;
    rdfs:comment 'Type of in-store display location where this promotional SKU is merchandised. Impacts visibility and promotional lift. [ENUM-REF-CANDIDATE: Shelf|End Cap|Free Standing Display|Pallet|Cooler|Checkout|Secondary Placement — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureType rdf:type rdf:Property ;
    rdfs:label 'Feature Type' ;
    rdfs:comment 'Type of promotional feature or advertising support provided for this SKU during the promotion event. [ENUM-REF-CANDIDATE: Circular Ad|Digital Ad|In-Store Signage|Shelf Talker|Coupon|Loyalty Offer|None — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incrementalLiftPercent rdf:type rdf:Property ;
    rdfs:label 'Incremental Lift Percent' ;
    rdfs:comment 'Percentage lift in volume due to the promotion. Calculated as (incremental_lift_volume_units / baseline_volume_estimate_units) * 100.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalLiftVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Incremental Lift Volume Units' ;
    rdfs:comment 'Incremental volume of units sold above baseline due to the promotion. Calculated as actual_promotional_volume_units - baseline_volume_estimate_units.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFeaturedSku rdf:type rdf:Property ;
    rdfs:label 'Is Featured Sku' ;
    rdfs:comment 'Indicates whether this SKU is a featured hero product in the promotion event. Featured SKUs typically receive premium merchandising and advertising support.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Name or identifier of the user who last modified this promotion event SKU record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedPromotionalVolumeCases rdf:type rdf:Property ;
    rdfs:label 'Planned Promotional Volume Cases' ;
    rdfs:comment 'Forecasted volume of cases expected to be sold during the promotion period for this SKU. Used for trade spend budgeting and supply planning.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedPromotionalVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Planned Promotional Volume Units' ;
    rdfs:comment 'Forecasted volume of consumer units expected to be sold during the promotion period for this SKU.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceReductionDepthPercent rdf:type rdf:Property ;
    rdfs:label 'Price Reduction Depth Percent' ;
    rdfs:comment 'Percentage discount from regular shelf price to promoted price. Calculated as ((regular_shelf_price - promoted_price) / regular_shelf_price) * 100.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Approval Status' ;
    rdfs:comment 'Current approval status of the promotional pricing for this SKU. Tracks the workflow state from draft through execution to completion. [ENUM-REF-CANDIDATE: Draft|Pending Approval|Approved|Rejected|Active|Completed|Cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pricing Approved Timestamp' ;
    rdfs:comment 'Date and time when the promotional pricing for this SKU was approved.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:promotedPrice rdf:type rdf:Property ;
    rdfs:label 'Promoted Price' ;
    rdfs:comment 'The temporary promotional price offered to consumers during the promotion event. Expressed in the base currency of the business.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotedPriceType rdf:type rdf:Property ;
    rdfs:label 'Promoted Price Type' ;
    rdfs:comment 'Type of promotional pricing mechanism applied to this SKU. Hi-Lo: temporary price reduction; EDLP: everyday low price; Multi-Buy: quantity discount; BOGO: buy-one-get-one; Scan-Back: retailer scanned rebate; Off-Invoice: deduction at invoice; Bill-Back: post-event settlement. [ENUM-REF-CANDIDATE: Hi-Lo|EDLP|Multi-Buy|BOGO|Scan-Back|Off-Invoice|Bill-Back — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionEffectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotion Effective End Date' ;
    rdfs:comment 'The date when the promotional pricing for this SKU expires and regular pricing resumes.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionEffectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Promotion Effective Start Date' ;
    rdfs:comment 'The date when the promotional pricing for this SKU becomes effective at retail.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalDiscountPerUnit rdf:type rdf:Property ;
    rdfs:label 'Promotional Discount Per Unit' ;
    rdfs:comment 'Absolute discount amount per unit (regular_shelf_price - promoted_price). Represents the per-unit trade spend investment.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalGmroi rdf:type rdf:Property ;
    rdfs:label 'Promotional Gmroi' ;
    rdfs:comment 'Gross margin return on investment for this promotional SKU. Calculated as incremental_gross_margin / total_trade_spend_amount.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalRoiPercent rdf:type rdf:Property ;
    rdfs:label 'Promotional Roi Percent' ;
    rdfs:comment 'Return on investment for this promotional SKU. Calculated as (incremental_gross_profit - total_trade_spend_amount) / total_trade_spend_amount * 100.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTradeSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Total Trade Spend Amount' ;
    rdfs:comment 'Total trade spend investment for this SKU in this promotion event. Calculated as promotional_discount_per_unit * actual_promotional_volume_units.' ;
    rdfs:domain ind:EventSku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentCalendarTradeCalendarId rdf:type rdf:Property ;
    rdfs:label 'Parent Calendar Trade Calendar Id' ;
    rdfs:comment 'Identifier of the parent promotional calendar if this is a sub-calendar or regional variant. Links to another promotional calendar entity.' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeCalendar .

ind:actualEventCount rdf:type rdf:Property ;
    rdfs:label 'Actual Event Count' ;
    rdfs:comment 'The actual number of promotional events executed or in-flight within this calendar period.' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarCode rdf:type rdf:Property ;
    rdfs:label 'Calendar Code' ;
    rdfs:comment 'Short alphanumeric code for the promotional calendar used in reporting and system integration (e.g., \'FY24Q1-RET\', \'CAL-2024-BRX\').' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarName rdf:type rdf:Property ;
    rdfs:label 'Calendar Name' ;
    rdfs:comment 'Business name of the promotional calendar (e.g., \'FY2024 Q1 Retail Promo Calendar\', \'Annual Brand X Trade Plan\').' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarStatus rdf:type rdf:Property ;
    rdfs:label 'Calendar Status' ;
    rdfs:comment 'Current lifecycle status of the promotional calendar (draft, submitted, approved, locked, active, closed).' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year this promotional calendar covers (e.g., 2024, 2025).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaselineCalendar rdf:type rdf:Property ;
    rdfs:label 'Is Baseline Calendar' ;
    rdfs:comment 'Flag indicating whether this is the baseline or master promotional calendar for the fiscal year (true) or a variant/supplemental calendar (false).' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockedDate rdf:type rdf:Property ;
    rdfs:label 'Locked Date' ;
    rdfs:comment 'The date when this promotional calendar was locked to prevent further changes, typically after approval and before execution.' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEventCount rdf:type rdf:Property ;
    rdfs:label 'Planned Event Count' ;
    rdfs:comment 'The total number of promotional events planned within this calendar period.' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningCycle rdf:type rdf:Property ;
    rdfs:label 'Planning Cycle' ;
    rdfs:comment 'The planning frequency or cycle for this promotional calendar (annual, semi-annual, quarterly, monthly).' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Geographic region or market code this promotional calendar applies to (e.g., \'NA-EAST\', \'EU-WEST\', \'APAC\').' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPlannedTradeSpend rdf:type rdf:Property ;
    rdfs:label 'Total Planned Trade Spend' ;
    rdfs:comment 'The total budgeted trade spend envelope allocated for all promotional events within this calendar, in the base currency.' ;
    rdfs:domain ind:TradeCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tpmSystemCode rdf:type rdf:Property ;
    rdfs:label 'Tpm System Code' ;
    rdfs:comment 'External system identifier from the Trade Promotion Management (TPM) or Trade Promotion Optimization (TPO) system (e.g., Salesforce TPM, TradeEdge).' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeSpendAllocationId rdf:type rdf:Property ;
    rdfs:label 'Trade Spend Allocation Id' ;
    rdfs:comment 'Unique identifier for the trade spend allocation record. Primary key for this transactional entity capturing budget allocation to promotion events.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Funding Agreement Id' ;
    rdfs:comment 'Foreign key linking to promotion.funding_agreement. Business justification: Trade spend allocations are funded through formal retailer funding agreements (RFAs/JBPs). Linking trade_spend_allocation to funding_agreement enables tracking of how committed funding agreement amoun' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundingAgreement .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'The actual amount of trade spend executed or paid out. Populated post-event for variance analysis and reconciliation with accounts payable.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualVolume rdf:type rdf:Property ;
    rdfs:label 'Actual Volume' ;
    rdfs:comment 'The actual sales volume achieved during the promotion period. Populated post-event from POS or shipment data for lift analysis and ROI calculation.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The monetary amount of trade spend allocated to this promotion event, account, brand, or SKU group. Represents the planned or budgeted spend.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationAmount rdf:type rdf:Property ;
    rdfs:label 'Allocation Amount' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business date when the trade spend allocation was created or committed. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Business-readable unique identifier for the trade spend allocation. Used for external communication, audit trails, and reconciliation with finance systems.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'The percentage of the funding agreement\'s total committed amount that is allocated to this specific trade promotion. Enables trade finance teams to track how agreement budgets are distributed across promotions.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle status of the trade spend allocation. Tracks progression from planning through approval, execution, and final settlement with retailer. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|committed|executed|settled|cancelled|rejected — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineVolume rdf:type rdf:Property ;
    rdfs:label 'Baseline Volume' ;
    rdfs:comment 'The expected sales volume without promotional activity, used as the baseline for measuring promotional lift. Expressed in units or cases.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'The amount of trade spend formally committed after approval. May differ from allocated amount due to negotiation or budget adjustments.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month or quarter) within the fiscal year to which this allocation is assigned. Used for period-level spend tracking and variance analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmroiPercentage rdf:type rdf:Property ;
    rdfs:label 'Gmroi Percentage' ;
    rdfs:comment 'The gross margin return on investment for this trade spend allocation. Measures gross margin dollars generated per dollar of trade spend invested.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotion End Date' ;
    rdfs:comment 'The end date of the promotion event to which this spend is allocated. Defines the promotional activity window for ROI measurement and post-event analysis.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionStartDate rdf:type rdf:Property ;
    rdfs:label 'Promotion Start Date' ;
    rdfs:comment 'The start date of the promotion event to which this spend is allocated. Used for temporal analysis and matching spend to promotional activity periods.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'The final settled amount paid to the retailer after reconciliation of accruals, deductions, and actual performance. Represents the true cost of the promotion.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendCategory rdf:type rdf:Property ;
    rdfs:label 'Spend Category' ;
    rdfs:comment 'High-level classification of trade spend for strategic analysis and reporting. Groups spend types into broader business categories for executive dashboards.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendType rdf:type rdf:Property ;
    rdfs:label 'Spend Type' ;
    rdfs:comment 'Classification of the trade spend mechanism. [ENUM-REF-CANDIDATE: off_invoice_discount|scan_back|bill_back|lump_sum|coop_advertising|slotting_fee|display_allowance|free_goods|volume_rebate|growth_incentive — promote to reference product]' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetVolume rdf:type rdf:Property ;
    rdfs:label 'Target Volume' ;
    rdfs:comment 'The target sales volume expected with this trade spend allocation. Used for performance measurement and ROI calculation.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The difference between committed and actual spend amounts. Positive variance indicates under-spend; negative indicates over-spend. Used for budget control and post-event analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUom rdf:type rdf:Property ;
    rdfs:label 'Volume Uom' ;
    rdfs:comment 'The unit of measure for baseline, target, and actual volume fields. Ensures consistent interpretation of volume metrics across different product categories.' ;
    rdfs:domain ind:TradeSpendAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousAgreementFundingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Previous Agreement Funding Agreement Id' ;
    rdfs:comment 'Reference to the prior funding agreement that this agreement renews or replaces, if applicable.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundingAgreement .

ind:accrualMethod rdf:type rdf:Property ;
    rdfs:label 'Accrual Method' ;
    rdfs:comment 'Method used to accrue trade spend liability over the agreement period: straight-line (evenly over time), event-based (per promotional event), scan-based (per unit sold), or milestone-based (upon achievement of targets).' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accruedToDateAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued To Date Amount' ;
    rdfs:comment 'Cumulative amount of trade spend accrued under this agreement as of the current date, based on the accrual method.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Human-readable name or title of the funding agreement, often including retailer name and fiscal year.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'URL or file path to the signed contract document stored in the document management system (e.g., Salesforce Files, SharePoint, Veeva Vault).' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionSettlementTerms rdf:type rdf:Property ;
    rdfs:label 'Deduction Settlement Terms' ;
    rdfs:comment 'Terms and conditions governing how retailer deductions are validated, matched, and settled against this funding agreement (e.g., backup documentation requirements, dispute resolution process, settlement timeline).' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Funding Period End Date' ;
    rdfs:comment 'The date when the funding agreement expires and the funding period ends. Nullable for open-ended agreements.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Funding Period Start Date' ;
    rdfs:comment 'The date when the funding agreement becomes effective and the funding period begins.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmroiTarget rdf:type rdf:Property ;
    rdfs:label 'Gmroi Target' ;
    rdfs:comment 'Target gross margin return on investment for this funding agreement, measuring gross profit generated per dollar of trade spend invested.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Signatory Name' ;
    rdfs:comment 'Full name of the manufacturer representative who signed the funding agreement on behalf of the CPG company.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Signatory Title' ;
    rdfs:comment 'Job title or role of the manufacturer signatory (e.g., VP of Sales, Director of Trade Marketing, Key Account Manager).' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Signature Date' ;
    rdfs:comment 'Date when the manufacturer signatory signed the funding agreement.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paidToDateAmount rdf:type rdf:Property ;
    rdfs:label 'Paid To Date Amount' ;
    rdfs:comment 'Cumulative amount of funding actually paid out to the retailer under this agreement as of the current date.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Frequency at which payments are made under this agreement: one-time (lump sum), monthly, quarterly, semi-annual, annual, or event-based (triggered by specific promotional events).' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceConditions rdf:type rdf:Property ;
    rdfs:label 'Performance Conditions' ;
    rdfs:comment 'Detailed description of performance metrics, targets, or conditions that must be met for funding to be released or for rebates to be earned (e.g., minimum sales volume, market share targets, display compliance).' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance Amount' ;
    rdfs:comment 'Remaining uncommitted or unpaid funding balance available under this agreement (total committed minus paid to date).' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Flag' ;
    rdfs:comment 'Indicates whether this funding agreement is a renewal of a previous agreement (true) or a new agreement (false).' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retailerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Retailer Signatory Name' ;
    rdfs:comment 'Full name of the retailer representative who signed the funding agreement on behalf of the retail account.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Retailer Signatory Title' ;
    rdfs:comment 'Job title or role of the retailer signatory (e.g., Category Manager, Buyer, VP of Merchandising).' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Retailer Signature Date' ;
    rdfs:comment 'Date when the retailer signatory signed the funding agreement.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roiTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Roi Target Percentage' ;
    rdfs:comment 'Target return on investment percentage for this funding agreement, used to measure promotional effectiveness and justify trade spend allocation.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date when the agreement was terminated early, if applicable. Null if the agreement was not terminated.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the agreement prior to the end date.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Explanation or reason code for early termination of the agreement (e.g., breach of contract, mutual agreement, business restructuring, poor performance).' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCommittedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Committed Amount' ;
    rdfs:comment 'Total funding amount committed by the manufacturer to the retailer under this agreement, in the agreement currency.' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Total Funding Amount' ;
    rdfs:domain ind:FundingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accrualId rdf:type rdf:Property ;
    rdfs:label 'Accrual Id' ;
    rdfs:comment 'Unique identifier for the promotion accrual record. Primary key.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accrualDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Date' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualNumber rdf:type rdf:Property ;
    rdfs:label 'Accrual Number' ;
    rdfs:comment 'Business-readable unique identifier for the accrual record, used for tracking and reconciliation.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accrualStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Status' ;
    rdfs:comment 'Current lifecycle status of the accrual: open (recognized but not yet settled), pending approval, approved, settled (paid out), reversed (accounting adjustment), or cancelled.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accrualType rdf:type rdf:Property ;
    rdfs:label 'Accrual Type' ;
    rdfs:comment 'Classification of the promotional accrual mechanism: scan-back (retailer submits proof of sale), bill-back (post-event invoice deduction), off-invoice (immediate discount), lump-sum (fixed payment), volume rebate, or performance bonus.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:context rdf:type rdf:Property ;
    rdfs:label 'Context' ;
    rdfs:comment 'Promotion-specific accrual context' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Deduction Claim Number' ;
    rdfs:comment 'Reference number for the retailer deduction claim associated with this accrual, used for deduction management and reconciliation. Nullable if no claim submitted.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Explanation of why the accrual is disputed. Nullable if not disputed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmroi rdf:type rdf:Property ;
    rdfs:label 'Gmroi' ;
    rdfs:comment 'Gross margin return on investment for the promotional spend, measuring profitability efficiency. Nullable if not yet calculated.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalVolume rdf:type rdf:Property ;
    rdfs:label 'Incremental Volume' ;
    rdfs:comment 'Additional sales volume generated by the promotion above the baseline, used for ROI and GMROI analysis. Nullable for non-lift-based accruals.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDisputed rdf:type rdf:Property ;
    rdfs:label 'Is Disputed' ;
    rdfs:comment 'Flag indicating whether the accrual is under dispute with the retailer or customer (true if disputed, false otherwise).' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Reference number for the payment transaction that settled this accrual. Nullable for unsettled accruals.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'End date of the accounting period during which the promotional liability is recognized.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'Start date of the accounting period during which the promotional liability is recognized.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantitySold rdf:type rdf:Property ;
    rdfs:label 'Quantity Sold' ;
    rdfs:comment 'Total quantity of product units sold during the promotional period that triggered the accrual. Nullable for non-volume-based accruals.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rate rdf:type rdf:Property ;
    rdfs:label 'Rate' ;
    rdfs:comment 'Rate or percentage applied to calculate the accrual amount (e.g., discount percentage, rebate rate per unit). Nullable for lump-sum accruals.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'Date on which the accrual was initially recognized in the financial system.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Date on which the accrual was reversed due to adjustment or cancellation. Nullable for non-reversed accruals.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapCoDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Co Document Number' ;
    rdfs:comment 'SAP CO document number for the controlling posting of the accrual, used for cost allocation and internal reporting.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapFiDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Document Number' ;
    rdfs:comment 'SAP FI document number for the financial posting of the accrual, used for audit trail and reconciliation.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionId rdf:type rdf:Property ;
    rdfs:label 'Deduction Id' ;
    rdfs:comment 'Unique identifier for the promotion deduction record. Primary key for the promotion deduction entity representing the complete lifecycle from initial short-payment through final settlement.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deduction .

ind:accrualImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Accrual Impact Flag' ;
    rdfs:comment 'Boolean indicator of whether this deduction impacts trade promotion accruals. True indicates the deduction should be reconciled against accrued trade spend, false indicates it is outside accrual scope.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agingDays rdf:type rdf:Property ;
    rdfs:label 'Aging Days' ;
    rdfs:comment 'Number of days the deduction has been open since the deduction date. Used for aging analysis and prioritization of dispute resolution activities.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Monetary amount of the deduction that was approved and accepted by the manufacturer after dispute resolution. May be less than, equal to, or zero relative to the original deduction amount.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'Business unit or division code responsible for managing this deduction. Used for organizational reporting and accountability.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Reference Number' ;
    rdfs:comment 'External reference number provided by the retailer for their deduction claim. Used for cross-referencing with retailer systems and documentation.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionDate rdf:type rdf:Property ;
    rdfs:label 'Deduction Date' ;
    rdfs:comment 'Date on which the retailer took the deduction from the invoice payment. Represents the business event timestamp for the deduction.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deductionNumber rdf:type rdf:Property ;
    rdfs:label 'Deduction Number' ;
    rdfs:comment 'Business-facing unique deduction number assigned by the retailer or internal system. Used for external communication and dispute tracking.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionStatus rdf:type rdf:Property ;
    rdfs:label 'Deduction Status' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionType rdf:type rdf:Property ;
    rdfs:label 'Deduction Type' ;
    rdfs:comment 'Classification of the deduction based on the reason for the short-payment. Promotional deductions relate to trade promotions, pricing deductions to price discrepancies, shortage to quantity issues, compliance to retailer policy violations, quality to product defects, freight to shipping issues, and administrative to processing errors. [ENUM-REF-CANDIDATE: promotional|pricing|shortage|compliance|quality|freight|administrative — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle status of the deduction in the dispute resolution workflow. Open indicates initial receipt, approved indicates full acceptance, disputed indicates challenge by manufacturer, partially_approved indicates partial acceptance, written_off indicates unrecoverable amount, and pending_review indicates under investigation.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'Monetary amount of the deduction that is currently under dispute or was rejected by the manufacturer. Represents the portion of the deduction not accepted.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmroiImpactPercentage rdf:type rdf:Property ;
    rdfs:label 'Gmroi Impact Percentage' ;
    rdfs:comment 'Percentage impact of this deduction on the gross margin return on investment for the associated promotion. Used for profitability analysis and promotional effectiveness measurement.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting the resolution process, communications with the retailer, and final settlement rationale. Provides audit trail and knowledge base for future similar deductions.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerClaimDate rdf:type rdf:Property ;
    rdfs:label 'Retailer Claim Date' ;
    rdfs:comment 'Date on which the retailer filed the deduction claim in their system. May differ from the deduction date.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retailerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Retailer Contact Email' ;
    rdfs:comment 'Email address of the retailer contact person for this deduction. Used for electronic communication during dispute resolution.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerContactName rdf:type rdf:Property ;
    rdfs:label 'Retailer Contact Name' ;
    rdfs:comment 'Name of the retailer contact person responsible for this deduction claim. Used for communication and relationship management during dispute resolution.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Roi Impact Amount' ;
    rdfs:comment 'Calculated impact of this deduction on the promotional return on investment. Represents the reduction in promotional effectiveness due to the deduction. Used for post-event analysis and promotional optimization.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settledAmount rdf:type rdf:Property ;
    rdfs:label 'Settled Amount' ;
    rdfs:comment 'Final monetary amount settled between the manufacturer and retailer after all dispute resolution activities. Represents the actual financial impact of the deduction.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementMethod rdf:type rdf:Property ;
    rdfs:label 'Settlement Method' ;
    rdfs:comment 'Method by which the deduction was settled. Credit memo indicates issuance of a credit note, check indicates physical or electronic check payment, offset_future_invoice indicates deduction from future invoices, write_off indicates unrecoverable amount expensed, and bank_transfer indicates direct electronic payment.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReasonCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for the settlement decision. Used for categorization and analysis of settlement patterns.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Date' ;
    rdfs:comment 'Target date by which the deduction should be resolved based on internal service level agreements or retailer contractual terms. Used for performance tracking and escalation management.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:source rdf:type rdf:Property ;
    rdfs:label 'Source' ;
    rdfs:comment 'Source system or channel through which the deduction was received. Retailer portal indicates web-based submission, EDI 846 indicates electronic data interchange, manual entry indicates internal creation, bank reconciliation indicates discovery during payment matching, and automated matching indicates system-generated from remittance data.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportingDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Url' ;
    rdfs:comment 'URL or file path to supporting documentation for the deduction claim, such as proof of performance, promotional materials, or retailer correspondence. Used for audit and dispute resolution.' ;
    rdfs:domain ind:Deduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionSettlementId rdf:type rdf:Property ;
    rdfs:label 'Deduction Settlement Id' ;
    rdfs:comment 'Unique identifier for the deduction settlement record. Primary key for the deduction settlement entity.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentSettlementDeductionSettlementId rdf:type rdf:Property ;
    rdfs:label 'Parent Settlement Deduction Settlement Id' ;
    rdfs:comment 'Reference to a parent settlement record if this is a follow-up or partial settlement. Enables tracking of multi-stage settlement processes for complex deductions.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeductionSettlement .

ind:deductionClaimedAmount rdf:type rdf:Property ;
    rdfs:label 'Deduction Claimed Amount' ;
    rdfs:comment 'The original amount claimed by the retailer in the deduction. Represents the initial disputed or taken amount before settlement negotiation.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'The approach used to resolve any disputes between the claimed and approved amounts. Documents the resolution process for compliance and process improvement.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPartialSettlement rdf:type rdf:Property ;
    rdfs:label 'Is Partial Settlement' ;
    rdfs:comment 'Boolean flag indicating whether this settlement represents a partial resolution of the deduction. True if the deduction requires additional settlements; false if fully resolved.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date on which the settlement payment was issued or credited to the retailer. Represents the actual financial transaction date.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Code' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCycleTimeDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle Time Days' ;
    rdfs:comment 'The number of days elapsed from deduction claim date to settlement completion. Used for process efficiency measurement and Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementNotes rdf:type rdf:Property ;
    rdfs:label 'Settlement Notes' ;
    rdfs:comment 'Free-form text field for additional comments, negotiation details, or special circumstances related to the settlement. Provides context for future reference and audit.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Number' ;
    rdfs:comment 'Business-readable unique identifier for the settlement transaction. Used for external communication and audit trails. Format: STL- followed by 8-12 digits.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Settlement Reason Description' ;
    rdfs:comment 'Detailed textual explanation of the reason for the settlement, including any specific circumstances, negotiations, or justifications documented during the settlement process.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether this settlement was completed within the agreed Service Level Agreement (SLA) timeframe. Used for performance monitoring and retailer relationship management.' ;
    rdfs:domain ind:DeductionSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotedPriceId rdf:type rdf:Property ;
    rdfs:label 'Promoted Price Id' ;
    rdfs:comment 'Primary key for promoted_price' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costOfGoodsSold rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold' ;
    rdfs:comment 'The manufacturer\'s cost of goods sold per unit for the SKU at the time this promotional price was defined. Used for promotional ROI and GMROI analysis.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedVolumeLift rdf:type rdf:Property ;
    rdfs:label 'Estimated Volume Lift' ;
    rdfs:comment 'The projected percentage increase in sales volume expected from this promotional price compared to baseline sales. Used for demand planning and promotional forecasting.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAdvertised rdf:type rdf:Property ;
    rdfs:label 'Is Advertised' ;
    rdfs:comment 'Boolean flag indicating whether this promotional price is featured in retailer advertising, circulars, or marketing campaigns. True if advertised, False if unadvertised in-store promotion.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStackable rdf:type rdf:Property ;
    rdfs:label 'Is Stackable' ;
    rdfs:comment 'Boolean flag indicating whether this promotional price can be combined (stacked) with other promotions, coupons, or discounts. True if stackable, False if exclusive.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceReductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Price Reduction Percentage' ;
    rdfs:comment 'The percentage discount from the regular shelf price, calculated as ((regular_shelf_price - promotional_price_amount) / regular_shelf_price) * 100. Represents the depth of the promotional discount.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingStrategyType rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy Type' ;
    rdfs:comment 'Classification of the promotional pricing strategy. Hi-Lo (High-Low temporary price reduction), EDLP (Everyday Low Price), multi-buy (e.g., 2 for $5), BOGO (Buy One Get One), scan-back (retailer scans at checkout for discount), temporary price reduction, rebate, or coupon-based pricing. [ENUM-REF-CANDIDATE: hi_lo|edlp|multi_buy|bogo|scan_back|temporary_price_reduction|rebate|coupon — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Promotional Allowance Amount' ;
    rdfs:comment 'The per-unit allowance or funding provided by the manufacturer to the retailer to support this promotional price. Used for trade spend accrual and settlement calculations.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Promotional Price Amount' ;
    rdfs:comment 'The promoted price point for the SKU during the promotional period. This is the actual selling price offered to consumers or retailers during the promotion.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPriceCode rdf:type rdf:Property ;
    rdfs:label 'Promotional Price Code' ;
    rdfs:comment 'Business identifier or code for this promotional price record. Used for external reference and integration with TPM systems.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPriceDescription rdf:type rdf:Property ;
    rdfs:label 'Promotional Price Description' ;
    rdfs:comment 'Detailed description of the promotional price offer, including terms, conditions, and any special instructions for retail execution or consumer communication.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPriceName rdf:type rdf:Property ;
    rdfs:label 'Promotional Price Name' ;
    rdfs:comment 'Human-readable name or label for this promotional price configuration, used for identification and reporting purposes.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retailerMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Retailer Margin Percentage' ;
    rdfs:comment 'The target or agreed-upon margin percentage for the retailer when selling at this promotional price. Used for trade negotiation and pricing strategy analysis.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scanBackRate rdf:type rdf:Property ;
    rdfs:label 'Scan Back Rate' ;
    rdfs:comment 'The per-unit reimbursement rate paid to the retailer for each unit sold at the promotional price under a scan-back pricing model. Nullable if not a scan-back promotion.' ;
    rdfs:domain ind:PromotedPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activityTypeIndicator rdf:type rdf:Property ;
    rdfs:label 'Activity Type Indicator' ;
    rdfs:comment 'Flag indicating whether this cost center performs activity-based costing. True if the center provides measurable activities (e.g., machine hours, labor hours) that are allocated to cost objects.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used for allocating costs from this cost center to other cost objects (products, profit centers). Critical for COGS calculation and overhead absorption.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetProfileCode rdf:type rdf:Property ;
    rdfs:label 'Budget Profile Code' ;
    rdfs:comment 'Budget control profile defining budget planning rules, tolerance limits, and approval workflows for this cost center. Determines budget availability check behavior.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'Business area classification for cross-company code reporting. Represents a distinct line of business or product category (e.g., Personal Care, Home Care, Beauty) for consolidated financial analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Legal entity company code in SAP S/4HANA FI module. Links cost center to the legal entity for statutory financial reporting and SOX compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group' ;
    rdfs:comment 'Logical grouping of cost centers for consolidated reporting and analysis. Enables flexible aggregation beyond standard hierarchy (e.g., all brand marketing centers, all R&D centers).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active centers accept postings; inactive centers are closed; blocked centers are temporarily suspended; planned centers are approved but not yet operational.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by functional area. Determines the nature of costs tracked and reporting hierarchy. Used for COGS allocation and EBITDA segmentation. [ENUM-REF-CANDIDATE: production|sales|marketing|distribution|administration|research_development|quality_assurance|procurement|finance|shared_services — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Department or functional unit code within the organization. Provides granular classification for workforce planning and departmental cost analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'Functional area classification for cost-of-sales accounting. Distinguishes between manufacturing, sales, marketing, R&D, and administrative functions for COGS and operating expense allocation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyArea rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Area' ;
    rdfs:comment 'Standard hierarchy assignment for organizational reporting. Defines the cost center\'s position in the corporate hierarchy tree for roll-up reporting and budget consolidation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Flag indicating whether the cost center is locked for actual postings. Used during period-end close and organizational changes to prevent unintended transactions.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Code' ;
    rdfs:comment 'Code of the parent cost center in the organizational hierarchy. Enables hierarchical roll-up of costs for management reporting and budget aggregation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Version number of the cost center master record. Incremented with each modification to support change history tracking and optimistic locking.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statisticalIndicator rdf:type rdf:Property ;
    rdfs:label 'Statistical Indicator' ;
    rdfs:comment 'Flag indicating whether this is a statistical cost center used only for informational reporting without actual cost postings. Used for tracking non-financial metrics.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Id' ;
    rdfs:comment 'Reference to the parent profit center in a hierarchical profit center structure. Enables roll-up reporting and EBITDA decomposition across organizational levels.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Brand identifier for brand-based profit centers. Enables brand-level P&L reporting and brand portfolio management.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Sales channel classification for channel-based profit centers: retail, wholesale, e-commerce, direct-to-consumer (DTC), foodservice, or export.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationUnitCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Unit Code' ;
    rdfs:comment 'Code of the consolidation unit for group reporting. Links profit center to the financial consolidation hierarchy for IFRS/GAAP reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroupCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group Code' ;
    rdfs:comment 'Code of the cost center group associated with this profit center. Links profit center accounting to cost center accounting for overhead allocation and COGS calculation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the profit center if applicable. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Region Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country or region code representing the primary geographic location of the profit center for regional segment reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Planning Enabled Flag' ;
    rdfs:comment 'Boolean flag indicating whether this profit center participates in budgeting and financial planning processes.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Product Category Code' ;
    rdfs:comment 'Product category or product line code associated with this profit center. Used for product-based segment reporting and portfolio analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center indicating whether it is operational, temporarily suspended, or permanently closed.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center by organizational dimension: product line, brand, geographic region, sales channel, or business unit. Determines the segment reporting structure.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsiblePersonEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Email' ;
    rdfs:comment 'Email address of the profit center manager for financial reporting notifications and escalations.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'Name of the business leader or manager accountable for the profit center\'s financial performance and operational results.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Segment code for external segment reporting per IFRS 8 and US GAAP ASC 280. Represents reportable operating segments for investor disclosures.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Boolean flag indicating whether this profit center is subject to SOX financial controls and audit requirements for publicly traded companies.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'State or province code for the profit center\'s location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction code for the profit center\'s location. Used for tax reporting and compliance with local tax authorities.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationView rdf:type rdf:Property ;
    rdfs:label 'Valuation View' ;
    rdfs:comment 'Valuation perspective for profit center accounting: legal (statutory), group (IFRS/GAAP consolidation), profit center (internal transfer pricing), or management (operational view).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Reference to the chart of accounts framework to which this account belongs. Links to the chart_of_accounts master data.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:accountCategory rdf:type rdf:Property ;
    rdfs:label 'Account Category' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'The account group classification that controls field status, number ranges, and posting rules in the ERP system.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountShortName rdf:type rdf:Property ;
    rdfs:label 'Account Short Name' ;
    rdfs:comment 'Abbreviated name or label for the GL account used in condensed reports and system displays.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:balanceAmount rdf:type rdf:Property ;
    rdfs:label 'Balance Amount' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceSheetAccount rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Account' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'For balance sheet accounts, indicates whether the account is a current asset, non-current asset, current liability, non-current liability, or equity. Not applicable for P&L accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockedForPostingFlag rdf:type rdf:Property ;
    rdfs:label 'Blocked For Posting Flag' ;
    rdfs:comment 'Indicates whether the account is currently blocked for all postings. Used to prevent transactions to accounts that are under review, closed, or being restructured.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetControlFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Control Flag' ;
    rdfs:comment 'Indicates whether budget availability checking is active for this account. When enabled, postings are validated against approved budgets.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashFlowCategory rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Category' ;
    rdfs:comment 'For accounts that impact cash flow, indicates the cash flow statement category: operating activities, investing activities, or financing activities. Not applicable for non-cash accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account Number' ;
    rdfs:comment 'The corresponding account number in the group consolidation chart of accounts. Used for mapping local accounts to group reporting structures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Center Required Flag' ;
    rdfs:comment 'Indicates whether a cost center assignment is mandatory when posting to this account. Used for internal cost allocation and management reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'For accounts that are cost elements, indicates whether it is a primary cost element (direct posting from FI) or secondary cost element (internal allocation only). Not applicable if not a cost element.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costElementFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Element Flag' ;
    rdfs:comment 'Indicates whether this GL account is also defined as a cost element in the Controlling (CO) module for cost center and internal order postings.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether the account normally carries a debit balance or credit balance in the general ledger.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'The field status group that controls which fields are required, optional, or suppressed when posting to this account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementCategory rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Category' ;
    rdfs:comment 'The primary financial statement where this account appears: balance sheet, income statement (P&L), cash flow statement, retained earnings, or statistical.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementLineItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Line Item' ;
    rdfs:comment 'The specific line item or section within the financial statement where this account balance is reported (e.g., Current Assets, Cost of Goods Sold, Operating Expenses).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountGroup rdf:type rdf:Property ;
    rdfs:label 'Gl Account Group' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Account Number' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Gl Account Status' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountType rdf:type rdf:Property ;
    rdfs:label 'Gl Account Type' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyClearingFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Clearing Flag' ;
    rdfs:comment 'Indicates whether this account is used for intercompany transactions that require clearing and elimination in consolidated financial statements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestIndicator rdf:type rdf:Property ;
    rdfs:label 'Interest Indicator' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOpenItemManaged rdf:type rdf:Property ;
    rdfs:label 'Is Open Item Managed' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReconciliationAccount rdf:type rdf:Property ;
    rdfs:label 'Is Reconciliation Account' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemDisplayFlag rdf:type rdf:Property ;
    rdfs:label 'Line Item Display Flag' ;
    rdfs:comment 'Indicates whether individual line item details are stored and can be displayed for this account. Required for detailed transaction analysis and audit trails.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Open Item Management Flag' ;
    rdfs:comment 'Indicates whether this account uses open item management for tracking and clearing individual line items (e.g., AR, AP, bank clearing accounts).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plAccount rdf:type rdf:Property ;
    rdfs:label 'Pl Account' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plCategory rdf:type rdf:Property ;
    rdfs:label 'Pl Category' ;
    rdfs:comment 'For income statement accounts, indicates the P&L category: gross revenue, net revenue, COGS, gross margin, operating expense (SG&A, marketing, trade spend), EBITDA, EBIT, or net income. Not applicable for balance sheet accounts. [ENUM-REF-CANDIDATE: gross_revenue|net_revenue|cogs|gross_margin|operating_expense|ebitda|ebit|net_income|not_applicable — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'The organizational level at which budget planning and forecasting is performed for this account (e.g., company code, profit center, cost center).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Flag' ;
    rdfs:comment 'Indicates whether direct postings are allowed to this account. Some accounts (e.g., summary or control accounts) may only accept postings from automated processes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Block Flag' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required Flag' ;
    rdfs:comment 'Indicates whether a profit center assignment is mandatory when posting to this account. Used for segment reporting and profitability analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Flag' ;
    rdfs:comment 'Indicates whether this is a reconciliation account (subledger control account) that summarizes detailed transactions from subsidiary ledgers such as AR, AP, or inventory.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Type' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainedEarningsAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Retained Earnings Account Flag' ;
    rdfs:comment 'Indicates whether this is the retained earnings account where net income/loss is transferred during year-end closing.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'The default sort key used for organizing and displaying line items within this account (e.g., posting date, document number, amount).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Account Flag' ;
    rdfs:comment 'Indicates whether this account is subject to SOX internal control requirements and enhanced audit procedures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'The tax treatment category for this account (e.g., taxable revenue, non-taxable revenue, input tax, output tax, tax-exempt). Used for VAT, sales tax, and GST reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCodeAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Code Allowed Flag' ;
    rdfs:comment 'Indicates whether tax codes can be entered when posting to this account. Typically true for revenue and expense accounts, false for balance sheet accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Relevant Flag' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerId rdf:type rdf:Property ;
    rdfs:label 'Ledger Id' ;
    rdfs:comment 'Unique identifier for the financial ledger record. Primary key for the ledger entity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:accountingPrinciple rdf:type rdf:Property ;
    rdfs:label 'Accounting Principle' ;
    rdfs:comment 'The accounting standard or principle applied in this ledger, such as International Financial Reporting Standards (IFRS), United States Generally Accepted Accounting Principles (US GAAP), local country-specific GAAP, tax accounting rules, or management accounting conventions.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailEnabled rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Enabled' ;
    rdfs:comment 'Boolean flag indicating whether comprehensive audit trail logging is enabled for all postings and changes to this ledger, supporting regulatory compliance and forensic analysis.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Base Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the base currency in which this ledger maintains balances (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationLedgerFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Ledger Flag' ;
    rdfs:comment 'Boolean flag indicating whether this ledger is used for group consolidation purposes, aggregating financial data from multiple legal entities for consolidated financial statements.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'Defines the currency perspective maintained in this ledger. Local currency represents the operating entity\'s functional currency, group currency is the consolidated reporting currency, hard currency is a stable reference currency (e.g., USD, EUR), and index currency supports inflation-adjusted reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'Code identifying the fiscal year calendar structure used by this ledger, defining the number of posting periods, special periods, and year-end closing rules. Common in SAP S/4HANA FI to support diverse fiscal calendars across global entities.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExtensionLedger rdf:type rdf:Property ;
    rdfs:label 'Is Extension Ledger' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeadingLedger rdf:type rdf:Property ;
    rdfs:label 'Is Leading Ledger' ;
    rdfs:comment 'Boolean flag indicating whether this is the leading ledger (primary book of record) for the company code. Only one ledger per company code can be designated as the leading ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerStatus rdf:type rdf:Property ;
    rdfs:label 'Ledger Status' ;
    rdfs:comment 'Current operational status of the ledger. Active ledgers accept postings, inactive ledgers are configured but not yet in use, closed ledgers are archived and no longer accept postings, and suspended ledgers are temporarily disabled.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerType rdf:type rdf:Property ;
    rdfs:label 'Ledger Type' ;
    rdfs:comment 'Classification of the ledger indicating its role in the financial reporting architecture. Leading ledger is the primary book of record, parallel ledgers support alternative accounting principles (e.g., local GAAP), and extension ledgers provide management reporting views.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingPeriodVariant rdf:type rdf:Property ;
    rdfs:label 'Posting Period Variant' ;
    rdfs:comment 'Code defining the posting period structure for this ledger, including the number of regular periods (typically 12 monthly periods) and special periods for year-end adjustments and closing entries.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years that financial data in this ledger must be retained to comply with statutory, tax, and regulatory record-keeping requirements. Common retention periods range from 7 to 10 years for financial records.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soxCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Compliant Flag' ;
    rdfs:comment 'Boolean flag indicating whether this ledger maintains controls and audit trails compliant with Sarbanes-Oxley Act Section 404 requirements for internal controls over financial reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsCostOfSalesAccounting rdf:type rdf:Property ;
    rdfs:label 'Supports Cost Of Sales Accounting' ;
    rdfs:comment 'Boolean flag indicating whether this ledger supports cost of sales (COGS) accounting method, which matches costs directly to revenue in the period of sale, as opposed to period-based cost accounting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportsProfitCenterAccounting rdf:type rdf:Property ;
    rdfs:label 'Supports Profit Center Accounting' ;
    rdfs:comment 'Boolean flag indicating whether this ledger maintains profit center accounting data for internal management reporting and profitability analysis by organizational unit.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportsSegmentReporting rdf:type rdf:Property ;
    rdfs:label 'Supports Segment Reporting' ;
    rdfs:comment 'Boolean flag indicating whether this ledger supports segment reporting as required by IFRS 8 Operating Segments. Segment reporting enables financial analysis by business unit, product line, or geographic region.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:underlyingLedgerCode rdf:type rdf:Property ;
    rdfs:label 'Underlying Ledger Code' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationApproach rdf:type rdf:Property ;
    rdfs:label 'Valuation Approach' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Reversed Journal Entry Id' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:baselinePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Payment Date' ;
    rdfs:comment 'The baseline date used for calculating payment terms and due dates for vendor invoices and customer receivables. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchInputSession rdf:type rdf:Property ;
    rdfs:label 'Batch Input Session' ;
    rdfs:comment 'Identifier of the batch input session if this journal entry was created through automated batch processing. Used for tracking mass data uploads and interface postings.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which this open item was cleared. Used for DSO and DIO calculation. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'Document number of the clearing document if this open item has been cleared (paid or offset). Used for accounts payable and receivable reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'Organizational unit in management accounting that represents a closed system for cost accounting. Used for internal management reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date printed on the source document (invoice, receipt, payment voucher). May differ from posting date. Used for document control and audit trail. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Unique alphanumeric identifier assigned to the accounting document within the company code and fiscal year. This is the externally visible business key for the journal entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification code indicating the nature and source of the journal entry. Examples: SA (General Ledger Document), AB (Accounting Document), KR (Vendor Invoice), DR (Customer Invoice), DZ (Customer Payment), KA (Vendor Payment), KG (Vendor Credit Memo), KN (Customer Credit Memo), KZ (Payment Request), RE (Invoice Receipt), RV (Invoice Reversal), WA (Goods Issue), WE (Goods Receipt), ZP (Payment Posting). [ENUM-REF-CANDIDATE: SA|AB|KR|DR|DZ|KA|KG|KN|KZ|RE|RV|WA|WE|ZP — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The date on which the journal entry was created or entered into the system. Used for audit trail and process monitoring. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The exchange rate used to convert document currency amounts to local currency. Expressed as local currency per one unit of document currency. Null if document currency equals local currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Code indicating the type of exchange rate used for currency translation. Examples: M (Average Rate), B (Bank Buying Rate), G (Bank Selling Rate), P (Posting Date Rate).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-form text field for additional information or explanation about the journal entry. Used for documentation and audit purposes.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry involves intercompany transactions between different company codes within the enterprise. True if intercompany, False otherwise.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:journalEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Number' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'Two-character code identifying the ledger or accounting principle under which this entry is recorded. Examples: 0L (Leading Ledger - IFRS), 2L (Local GAAP), 3L (Management Reporting). Supports parallel accounting for multiple reporting standards.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the company code local currency. All amounts are translated to this currency for statutory reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Code representing the payment terms applicable to this document (e.g., Net 30, 2/10 Net 30). Used for cash flow forecasting and DSO tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle status of the journal entry. Values: draft (entry created but not posted), posted (entry successfully posted to GL), parked (entry saved for later posting), cancelled (entry voided before posting), reversed (entry reversed by a subsequent document).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number from the source document (invoice number, purchase order number, payment reference). Used for cross-referencing and reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is a reversal of a previous entry. True if this is a reversal document, False otherwise.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'Document number of the original journal entry that is being reversed by this entry. Populated only when reversal_indicator is True.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingDate rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Date' ;
    rdfs:comment 'The date relevant for tax reporting purposes. May differ from posting date based on tax jurisdiction rules. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Amount' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'Identifier of the intercompany trading partner for intercompany transactions. Enables intercompany reconciliation and elimination entries.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'Company code of the intercompany trading partner if this is an intercompany transaction. Used for consolidation and elimination entries. Null if not an intercompany transaction.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Code' ;
    rdfs:comment 'SAP transaction code or Oracle program identifier used to create this journal entry. Examples: FB01 (Post Document), FB50 (G/L Account Posting), MIRO (Enter Invoice), F-28 (Post Incoming Payments). Used for audit trail and process analysis.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for granular cost allocation, COGS decomposition, and SOX-compliant audit trail tracing at the line level.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journalCostObjectCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Journal Cost Object Cost Center Id' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:journalPartnerCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Journal Partner Cost Center Id' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:journalPartnerProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Journal Partner Profit Center Id' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:journalProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Journal Profit Center Id' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:primaryCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Cost Center Id' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:amountCompanyCodeCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Company Code Currency' ;
    rdfs:comment 'Monetary amount converted to the local currency of the company code. Used for statutory reporting and local GAAP compliance.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Group Currency' ;
    rdfs:comment 'Monetary amount converted to the group reporting currency. Enables consolidated financial reporting across all subsidiaries.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Transaction Currency' ;
    rdfs:comment 'Monetary amount of this line item in the original transaction currency. Preserves the original posting amount before currency conversion.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'Free-text assignment field for additional reference information such as invoice number, purchase order, or payment reference. Enhances traceability.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReference rdf:type rdf:Property ;
    rdfs:label 'Assignment Reference' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'The reference date from which payment terms are calculated. Typically the invoice date or goods receipt date depending on payment term configuration.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:companyCodeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the company code local currency. Typically the statutory reporting currency of the legal entity.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costObjectType rdf:type rdf:Property ;
    rdfs:label 'Cost Object Type' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Account Number' ;
    rdfs:comment 'Customer account number for revenue and receivables postings. Links financial transactions to customer master data.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the group reporting currency. Typically USD or EUR for multinational consumer goods companies.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemText rdf:type rdf:Property ;
    rdfs:label 'Item Text' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Sequential line number within the journal entry header. Determines the ordering and position of this line in the document.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineText rdf:type rdf:Property ;
    rdfs:label 'Line Text' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localAmount rdf:type rdf:Property ;
    rdfs:label 'Local Amount' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openItemFlag rdf:type rdf:Property ;
    rdfs:label 'Open Item Flag' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit posting key controlling account type, debit/credit indicator, and field status. Fundamental to SAP FI posting logic.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialGlIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Gl Indicator' ;
    rdfs:comment 'Special GL indicator for down payments, bills of exchange, guarantees, or other special transactions. Enables special ledger processing.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Storage location within the plant for inventory-related postings. Enables warehouse-level inventory tracking and valuation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax code determining the tax treatment of this line item. Drives automatic tax calculation and tax reporting compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:textDescription rdf:type rdf:Property ;
    rdfs:label 'Text Description' ;
    rdfs:comment 'Descriptive text explaining the nature or purpose of this journal entry line. Provides human-readable context for audit and review.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the transaction amount. Identifies the currency in which the original transaction was denominated.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'Value date for cash management and bank reconciliation. Represents the effective date for interest calculation and cash position.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Account Number' ;
    rdfs:comment 'Vendor account number for procurement and payables postings. Links financial transactions to vendor master data.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'WBS element for project-related postings. Links costs and revenues to specific projects, phases, or deliverables in project accounting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable invoice record. Primary key for the AR invoice entity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:salesInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Sales Invoice Id' ;
    rdfs:comment 'Foreign key linking to sales.invoice. Business justification: AR invoice reconciliation process matches each AR invoice to the originating sales invoice for cash application.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:amountReceived rdf:type rdf:Property ;
    rdfs:label 'Amount Received' ;
    rdfs:comment 'Total amount received from the customer against this invoice. May be less than total amount due to partial payments or deductions. Null for unpaid invoices.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAddress rdf:type rdf:Property ;
    rdfs:label 'Billing Address' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDate rdf:type rdf:Property ;
    rdfs:label 'Billing Date' ;
    rdfs:comment 'Date when the invoice was created and issued to the customer. Principal business event timestamp for the invoice lifecycle.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingDocumentType rdf:type rdf:Property ;
    rdfs:label 'Billing Document Type' ;
    rdfs:comment 'SAP billing document type code indicating the nature of the invoice (e.g., F2=standard invoice, G2=credit memo, L2=debit memo). Determines accounting treatment and revenue recognition.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingReference rdf:type rdf:Property ;
    rdfs:label 'Clearing Reference' ;
    rdfs:comment 'Reference number assigned when the invoice is cleared in the financial system. Links to the clearing document for audit trail. Null for open invoices.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Deduction Reason Code' ;
    rdfs:comment 'Code indicating the reason for customer deductions (e.g., pricing dispute, damaged goods, short shipment, promotional allowance). Used for deduction root cause analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Cash discount or early payment discount amount taken by customer. Typically based on payment terms (e.g., 2/10 net 30).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether the invoice is currently under dispute by the customer. True if disputed, false otherwise. Disputed invoices are excluded from standard collection processes.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsoAgingBucket rdf:type rdf:Property ;
    rdfs:label 'Dso Aging Bucket' ;
    rdfs:comment 'Aging category based on number of days the invoice has been outstanding past the due date. Used for DSO reporting, collections prioritization, and bad debt provisioning.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning level indicating the escalation stage of collection efforts (0=no dunning, 1=first reminder, 2=second reminder, etc.). Higher levels indicate more aggressive collection actions.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date when the invoice was posted to the general ledger. Used for financial period assignment and month-end close processes.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total invoice amount before any trade discounts, deductions, or adjustments. Represents the full billed value of goods or services.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date when the most recent dunning notice was sent to the customer. Used to track collection activity frequency and determine next dunning action.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Invoice amount after trade discounts but before tax. This is the base amount subject to taxation and the primary value for revenue recognition.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid balance on the invoice. Calculated as total amount minus amount received. Zero when invoice is fully paid or cleared.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Method by which the customer is expected to remit payment. Used for cash application automation and payment reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date when revenue from this invoice is recognized in the financial statements under ASC 606/IFRS 15. May differ from billing date based on performance obligation fulfillment.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Number' ;
    rdfs:comment 'Reference to the originating sales order that generated this invoice. Links invoice to order fulfillment and enables order-to-cash traceability.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganization rdf:type rdf:Property ;
    rdfs:label 'Sales Organization' ;
    rdfs:comment 'SAP sales organization responsible for the sale. Used for sales performance reporting and commission calculation.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Trade Discount Amount' ;
    rdfs:comment 'Total trade discounts applied to the invoice, including volume discounts, promotional allowances, and negotiated rebates. Reduces gross amount to net amount.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Amount written off as uncollectible bad debt. Null for invoices not written off. Impacts bad debt expense and allowance for doubtful accounts.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'Date when the invoice or portion thereof was written off as uncollectible. Null for invoices not written off.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffFlag rdf:type rdf:Property ;
    rdfs:label 'Write Off Flag' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:writeOffReasonCode rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason Code' ;
    rdfs:comment 'Code indicating the reason for write-off (e.g., customer bankruptcy, uncollectible, small balance write-off). Used for bad debt analysis and credit policy refinement.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ar Payment Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable payment record. Primary key.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'Amount of payment applied to the invoice after deductions and adjustments. Net amount reducing accounts receivable balance.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Reference Number' ;
    rdfs:comment 'Bank transaction reference or confirmation number. Used for bank statement reconciliation and audit trail.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Check number when payment method is check. Used for check reconciliation and fraud prevention.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Cost center code for payment allocation. Used when payment processing costs need to be tracked by organizational unit.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysToPay rdf:type rdf:Property ;
    rdfs:label 'Days To Pay' ;
    rdfs:comment 'Number of days between invoice date and payment date. Key metric for Days Sales Outstanding (DSO) calculation and customer payment behavior analysis.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deductionNotes rdf:type rdf:Property ;
    rdfs:label 'Deduction Notes' ;
    rdfs:comment 'Free-text notes explaining the deduction or short payment. Captures customer explanation and internal investigation details.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountTakenAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Taken Amount' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediTransactionSetReference rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Set Reference' ;
    rdfs:comment 'EDI 820 transaction set control number when payment received via EDI. Used for EDI reconciliation and compliance.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'Payment amount converted to company local currency using the exchange rate. Used for consolidated financial reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lockboxBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Lockbox Batch Number' ;
    rdfs:comment 'Lockbox batch identifier when payment received through bank lockbox service. Used for lockbox reconciliation.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overpaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Overpayment Flag' ;
    rdfs:comment 'Indicates whether payment amount exceeds the invoice balance. True if customer paid more than owed.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partialPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Payment Flag' ;
    rdfs:comment 'Indicates whether this is a partial payment against the invoice. True if payment amount is less than invoice balance.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Total amount received in the payment transaction, in the payment currency. Gross payment before any deductions or adjustments.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'Channel through which payment was received. Distinguishes interface from payment instrument.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the payment amount. Identifies the currency in which payment was received.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'External payment document number or reference provided by the customer or payment processor. Used for reconciliation and audit trail.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessorCode rdf:type rdf:Property ;
    rdfs:label 'Payment Processor Code' ;
    rdfs:comment 'Transaction identifier from third-party payment processor (e.g., Stripe, PayPal, Adyen). Used for processor reconciliation.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of the payment in the cash application workflow. Tracks payment lifecycle from receipt through clearing. [ENUM-REF-CANDIDATE: received|cleared|applied|partially_applied|unapplied|reversed|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAdviceNumber rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Number' ;
    rdfs:comment 'Reference number from customer remittance advice document. Links payment to customer payment notification (EDI 820 or paper remittance).' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAdviceSent rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Sent' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Short Payment Flag' ;
    rdfs:comment 'Indicates whether customer paid less than invoice amount without authorized deduction. Triggers deduction management workflow.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Unique identifier for the accounts payable invoice record. Primary key for the AP invoice entity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:earlyPaymentDiscountTaken rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Taken' ;
    rdfs:comment 'The actual cash discount amount captured by paying the invoice within the early payment discount period. Key metric for working capital optimization.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceCategory rdf:type rdf:Property ;
    rdfs:label 'Invoice Category' ;
    rdfs:comment 'Classification of the invoice by spend category (e.g., raw materials, packaging, contract manufacturing, indirect goods, services). Used for spend analytics and procurement reporting. [ENUM-REF-CANDIDATE: raw_materials|packaging|contract_manufacturing|indirect_goods|services|freight|utilities|rent — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description or header text providing additional context about the invoice, such as the nature of goods or services purchased.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Status of the three-way match verification process comparing the invoice to the purchase order and goods receipt. Critical for payment approval workflow.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockCode rdf:type rdf:Property ;
    rdfs:label 'Payment Block Code' ;
    rdfs:comment 'Code indicating if the invoice is blocked for payment and the reason for the block (e.g., price variance, quantity variance, quality issue, pending approval).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Block Flag' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Description of the reason the payment was blocked (e.g., pending invoice verification, supplier on hold, duplicate payment suspected). Used for exception management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Flag' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorBankAccountCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Bank Account Code' ;
    rdfs:comment 'Reference to the vendor\'s bank account to which payment was or will be sent. Required for electronic payment processing.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Number' ;
    rdfs:comment 'The invoice number assigned by the vendor. This is the external reference number printed on the vendor\'s invoice document.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The amount of withholding tax deducted from the payment to the vendor as required by tax regulations. Must be remitted to tax authorities.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ap Payment Id' ;
    rdfs:comment 'Unique identifier for the accounts payable payment record. Primary key.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'The date by which the payment must be made to qualify for the early payment discount. Used for working capital optimization decisions.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'The net payment amount after applying early payment discounts and any other adjustments. This is the actual amount transferred to the supplier.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Approval Status' ;
    rdfs:comment 'Approval status of the payment. Pending indicates awaiting approval, approved indicates authorized for processing, rejected indicates payment was denied. Supports SOX-compliant approval workflows.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockReleasedBy rdf:type rdf:Property ;
    rdfs:label 'Payment Block Released By' ;
    rdfs:comment 'User ID or name of the person who released the payment block and authorized the payment to proceed. Supports SOX-compliant audit trails.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockReleasedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Block Released Date' ;
    rdfs:comment 'The date on which the payment block was released and the payment was authorized to proceed. Supports audit trails and payment cycle time analysis.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentNotes rdf:type rdf:Property ;
    rdfs:label 'Payment Notes' ;
    rdfs:comment 'Free-text notes or comments about the payment. Used to capture special instructions, exceptions, or additional context for audit and reconciliation purposes.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceAdviceSentDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Sent Date' ;
    rdfs:comment 'The date on which the remittance advice was sent to the supplier. Used for supplier communication tracking.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remittanceAdviceSentFlag rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Sent Flag' ;
    rdfs:comment 'Boolean flag indicating whether a remittance advice was sent to the supplier to notify them of the payment details. True indicates sent, False indicates not sent.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cogsAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cogs Allocation Id' ;
    rdfs:comment 'Unique identifier for the COGS allocation record. Primary key for the product costing and COGS allocation master.' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationBasis rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPeriod rdf:type rdf:Property ;
    rdfs:label 'Allocation Period' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingLotSize rdf:type rdf:Property ;
    rdfs:label 'Costing Lot Size' ;
    rdfs:comment 'Quantity basis used for cost calculation. Fixed costs are spread over this lot size to determine unit cost.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costingSheet rdf:type rdf:Property ;
    rdfs:label 'Costing Sheet' ;
    rdfs:comment 'Template defining overhead calculation rules and cost component structure for this allocation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costingType rdf:type rdf:Property ;
    rdfs:label 'Costing Type' ;
    rdfs:comment 'Type of cost estimate: standard (baseline for valuation), actual (realized costs), planned (budgeted), or simulated (what-if scenario).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costingVersion rdf:type rdf:Property ;
    rdfs:label 'Costing Version' ;
    rdfs:comment 'Version identifier for the costing run (e.g., standard cost, planned cost, actual cost). Enables parallel costing scenarios and version comparison.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationCost rdf:type rdf:Property ;
    rdfs:label 'Depreciation Cost' ;
    rdfs:comment 'Allocated depreciation expense for production equipment and facilities used in manufacturing.' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directLaborCost rdf:type rdf:Property ;
    rdfs:label 'Direct Labor Cost' ;
    rdfs:comment 'Cost component for direct production labor involved in manufacturing the product.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedOverheadCost rdf:type rdf:Property ;
    rdfs:label 'Fixed Overhead Cost' ;
    rdfs:comment 'Fixed manufacturing overhead costs that remain constant regardless of production volume (e.g., facility rent, salaries).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightInCost rdf:type rdf:Property ;
    rdfs:label 'Freight In Cost' ;
    rdfs:comment 'Inbound freight and logistics costs for raw materials and components. Part of landed cost calculation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Lot Size Unit' ;
    rdfs:comment 'Unit of measure for the costing lot size (e.g., EA for each, KG for kilogram, L for liter).' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:machineOverheadCost rdf:type rdf:Property ;
    rdfs:label 'Machine Overhead Cost' ;
    rdfs:comment 'Cost component for machine and equipment usage, including depreciation, maintenance, and operating costs.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialCostAmount rdf:type rdf:Property ;
    rdfs:label 'Material Cost Amount' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overheadCostAmount rdf:type rdf:Property ;
    rdfs:label 'Overhead Cost Amount' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingCost rdf:type rdf:Property ;
    rdfs:label 'Packaging Cost' ;
    rdfs:comment 'Cost component for primary, secondary, and tertiary packaging materials. Critical for CPG product costing.' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Price Control Indicator' ;
    rdfs:comment 'Indicates whether material is valued at standard price (S) or moving average price (V). Critical for inventory valuation method.' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityProduced rdf:type rdf:Property ;
    rdfs:label 'Quantity Produced' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Raw Material Cost' ;
    rdfs:comment 'Cost component for raw materials and ingredients used in production. Key driver of COGS in consumer goods manufacturing.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCogsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cogs Amount' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cost Amount' ;
    rdfs:comment 'Total allocated cost per unit including all cost components (raw material, packaging, labor, overhead, freight, depreciation).' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'End date until which this cost estimate remains valid. Null indicates open-ended validity.' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'Start date from which this cost estimate is valid and applicable for inventory valuation and margin calculation.' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'Classification code that determines which general ledger accounts are updated during inventory movements and COGS posting.' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variableOverheadCost rdf:type rdf:Property ;
    rdfs:label 'Variable Overhead Cost' ;
    rdfs:comment 'Variable manufacturing overhead costs that fluctuate with production volume (e.g., utilities, indirect materials).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceCategory rdf:type rdf:Property ;
    rdfs:label 'Variance Category' ;
    rdfs:comment 'Classification of cost variance by root cause: price (input cost change), quantity (usage deviation), mix (recipe change), yield (output efficiency), efficiency (labor/machine productivity), volume (fixed cost absorption).' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceType rdf:type rdf:Property ;
    rdfs:label 'Variance Type' ;
    rdfs:domain ind:CogsAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryStandardManufacturingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Standard Manufacturing Facility Id' ;
    rdfs:comment 'Reference to the manufacturing plant or production facility where this standard cost applies. Standard costs are plant-specific in CPG manufacturing.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufacturingFacility .

ind:primaryStandardSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Standard Sku Id' ;
    rdfs:comment 'Reference to the material (finished good, semi-finished good, or raw material) for which this standard cost is defined. Links to the product master.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:bomUsage rdf:type rdf:Property ;
    rdfs:label 'Bom Usage' ;
    rdfs:comment 'The BOM usage type (e.g., production, costing, engineering) that was used as the basis for material cost calculation in this estimate.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Created By' ;
    rdfs:comment 'The user ID or name of the cost accountant or system user who created this cost estimate. Used for audit trail and accountability.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costEstimateCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Created Timestamp' ;
    rdfs:comment 'The date and time when this standard cost record was first created in the source system. Critical for audit trail and SOX compliance.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costEstimateModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Modified By' ;
    rdfs:comment 'The user ID or name of the cost accountant or system user who last modified this cost estimate. Used for audit trail and change tracking.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costEstimateModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Modified Timestamp' ;
    rdfs:comment 'The date and time when this standard cost record was last modified in the source system. Critical for audit trail and SOX compliance.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costEstimateNumber rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Number' ;
    rdfs:comment 'The unique business identifier for the cost estimate document in the source ERP system. Used for audit trail and traceability.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Amount' ;
    rdfs:comment 'The absolute difference between the current standard cost and the previous standard cost. Positive indicates cost increase, negative indicates cost decrease.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Percentage' ;
    rdfs:comment 'The percentage change in standard cost compared to the previous period. Calculated as (current - previous) / previous * 100.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costingLotSizeUom rdf:type rdf:Property ;
    rdfs:label 'Costing Lot Size Uom' ;
    rdfs:comment 'The unit of measure for the costing lot size (e.g., EA, KG, L, CS). Must align with the materials base unit of measure.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costingRunNumber rdf:type rdf:Property ;
    rdfs:label 'Costing Run Number' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costingStatus rdf:type rdf:Property ;
    rdfs:label 'Costing Status' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingVariant rdf:type rdf:Property ;
    rdfs:label 'Costing Variant' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCost rdf:type rdf:Property ;
    rdfs:label 'Labor Cost' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Per Unit' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markedFlag rdf:type rdf:Property ;
    rdfs:label 'Marked Flag' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialCost rdf:type rdf:Property ;
    rdfs:label 'Material Cost' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Material Cost Per Unit' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overheadCost rdf:type rdf:Property ;
    rdfs:label 'Overhead Cost' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overheadCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Overhead Cost Per Unit' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Cost' ;
    rdfs:comment 'The cost component for packaging materials (primary, secondary, tertiary) used for one unit. Critical for CPG cost structure analysis.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousStandardCost rdf:type rdf:Property ;
    rdfs:label 'Previous Standard Cost' ;
    rdfs:comment 'The total standard cost from the prior costing period or version. Used for variance analysis and cost trend reporting.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releasedFlag rdf:type rdf:Property ;
    rdfs:label 'Released Flag' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
