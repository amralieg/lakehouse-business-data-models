ind:waterConsumptionCubicMetersPerYear rdf:type rdf:Property ;
    rdfs:label 'Water Consumption Cubic Meters Per Year' ;
    rdfs:comment 'Annual water consumption of the facility measured in cubic meters, tracked for environmental compliance and sustainability reporting.' ;
