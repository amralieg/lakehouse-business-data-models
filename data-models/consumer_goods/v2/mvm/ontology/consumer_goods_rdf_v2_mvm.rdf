ind:inspectionPlanId rdf:type rdf:Property ;
    rdfs:label 'Inspection Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_plan. Business justification: Inspection plans in consumer goods GMP are scoped to specific work centers (e.g., filling line IPC, checkweigher AQL). Linking work_center to inspection_plan enables work-center-specific quality plann' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
