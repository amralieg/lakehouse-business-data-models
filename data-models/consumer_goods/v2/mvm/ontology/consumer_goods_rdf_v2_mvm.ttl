    rdfs:comment 'Total quantity of goods expected to be received based on the ASN or purchase order, used for discrepancy detection.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Document Number' ;
    rdfs:comment 'SAP Material Management (MM) goods receipt document number generated upon posting the receipt to inventory, linking WMS to ERP.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Status' ;
    rdfs:comment 'The inbound receipt status of the inbound receipt record' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Compliant Flag' ;
    rdfs:comment 'Indicator of whether this receipt met both on-time delivery and complete quantity requirements, key supplier performance metric.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Number of pallets received in this inbound shipment, used for dock capacity planning and labor allocation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:putawayCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Putaway Completion Timestamp' ;
    rdfs:comment 'Date and time when all received goods were moved from the receiving dock to their designated storage locations, completing the inbound process.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Current status of the quality inspection process for this receipt, tracking progression through quality control workflow.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Completed Timestamp' ;
    rdfs:comment 'The receipt completed timestamp of the inbound receipt record' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Completion Timestamp' ;
    rdfs:comment 'Date and time when all receiving activities (unloading, inspection, put-away) were completed and the receipt was closed in the WMS.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The receipt date of the inbound receipt record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Externally-known business identifier for the inbound receipt, used for tracking and reference across systems and with suppliers.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the inbound receipt transaction, tracking progression from scheduling through completion or exception handling.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptType rdf:type rdf:Property ;
    rdfs:label 'Receipt Type' ;
    rdfs:comment 'Classification of the inbound receipt based on the source and nature of the goods being received.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledArrival rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival' ;
    rdfs:comment 'The scheduled arrival of the inbound receipt record' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Receipt Date' ;
    rdfs:comment 'Planned date for the inbound shipment to arrive at the distribution center, based on ASN or supplier commitment.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Indicator of whether the security seal was found intact upon arrival, critical for quality control and loss prevention.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Security seal identifier applied to the trailer or container, verified upon receipt to ensure shipment integrity and prevent tampering.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Check Required Flag' ;
    rdfs:comment 'Indicator of whether temperature verification was required for this receipt due to cold chain or temperature-sensitive product requirements.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Compliant Flag' ;
    rdfs:comment 'Indicator of whether the recorded temperature was within acceptable range per product specifications and cold chain requirements.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureReadingCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Reading Celsius' ;
    rdfs:comment 'Actual temperature reading in Celsius recorded during receipt inspection for temperature-sensitive products, critical for cold chain compliance.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLines rdf:type rdf:Property ;
    rdfs:label 'Total Lines' ;
    rdfs:comment 'The total lines of the inbound receipt record' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'The total quantity of the inbound receipt record' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnitsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Units Received' ;
    rdfs:comment 'The total units received of the inbound receipt record' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trailerNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Number' ;
    rdfs:comment 'Unique identifier of the trailer or truck that delivered the shipment, used for tracking and carrier performance analysis.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnLineNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Line Number' ;
    rdfs:comment 'Line number within the ASN document corresponding to this receipt line. Enables automated matching between ASN and physical receipt.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionCode rdf:type rdf:Property ;
    rdfs:label 'Condition Code' ;
    rdfs:comment 'Quality condition assessment of the received goods. Determines whether product can be put away into available inventory or requires special handling.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Free-text description of any damage, defects, or quality issues observed during receipt inspection. Used for claims and supplier performance tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damagedQuantity rdf:type rdf:Property ;
    rdfs:label 'Damaged Quantity' ;
    rdfs:comment 'The damaged quantity of the inbound receipt line record' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedQuantityCases rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity Cases' ;
    rdfs:comment 'Expected quantity in cases as specified in the Advanced Shipping Notice (ASN) or purchase order. Used for variance detection.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedQuantityEaches rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity Eaches' ;
    rdfs:comment 'Expected quantity in eaches as specified in the Advanced Shipping Notice (ASN) or purchase order. Used for variance detection.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedCost rdf:type rdf:Property ;
    rdfs:label 'Extended Cost' ;
    rdfs:comment 'Total cost for this receipt line calculated as unit cost multiplied by received quantity. Used for inventory valuation and financial reconciliation.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundReceiptLineStatus rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Line Status' ;
    rdfs:comment 'The inbound receipt line status of the inbound receipt line record' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletCode rdf:type rdf:Property ;
    rdfs:label 'Pallet Code' ;
    rdfs:comment 'Unique identifier for the pallet or handling unit containing this receipt line. Used for put-away and storage location assignment.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderLineNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Line Number' ;
    rdfs:comment 'Line number on the purchase order corresponding to this receipt line. Enables three-way matching between PO, receipt, and invoice.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:putAwayTimestamp rdf:type rdf:Property ;
    rdfs:label 'Put Away Timestamp' ;
    rdfs:comment 'Date and time when the goods were put away into their assigned storage location. Used for warehouse productivity and cycle time measurement.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:putawayStatus rdf:type rdf:Property ;
    rdfs:label 'Putaway Status' ;
    rdfs:comment 'The putaway status of the inbound receipt line record' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Flag' ;
    rdfs:comment 'The quality hold flag of the inbound receipt line record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedQuantityCases rdf:type rdf:Property ;
    rdfs:label 'Received Quantity Cases' ;
    rdfs:comment 'Quantity of product received measured in cases. Represents the outer packaging unit typically used for warehouse handling.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedQuantityEaches rdf:type rdf:Property ;
    rdfs:label 'Received Quantity Eaches' ;
    rdfs:comment 'Quantity of product received measured in individual units (eaches). Represents the consumer-facing unit count.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time when the goods were physically received at the warehouse dock. Critical for OTIF performance measurement and cycle time analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sscc rdf:type rdf:Property ;
    rdfs:label 'Sscc' ;
    rdfs:comment '18-digit Serial Shipping Container Code identifying the logistics unit. Global standard for tracking pallets and containers in the supply chain.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtReceiptCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature At Receipt Celsius' ;
    rdfs:comment 'Temperature measurement in Celsius recorded at the time of receipt. Critical for cold chain compliance and product quality verification.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantityCases rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity Cases' ;
    rdfs:comment 'Difference between expected and received quantity in cases. Positive values indicate overages, negative values indicate shortages.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantityEaches rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity Eaches' ;
    rdfs:comment 'Difference between expected and received quantity in eaches. Positive values indicate overages, negative values indicate shortages.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightOrderId rdf:type rdf:Property ;
    rdfs:label 'Freight Order Id' ;
    rdfs:comment 'Foreign key linking to logistics.freight_order. Business justification: Freight order creation for every outbound order manages carrier tendering, freight cost tracking, and audit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightOrder .

ind:primaryOutboundDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Outbound Distribution Facility Id' ;
    rdfs:comment 'Identifier of the distribution center fulfilling the outbound order. Determines inventory source and warehouse operations responsible for order execution.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:backorderFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Flag' ;
    rdfs:comment 'Indicates whether any line items on the order are backordered due to insufficient inventory. True when ordered quantity exceeds available stock.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Carrier-issued document number serving as receipt of goods and contract of carriage. Required for freight claims and proof of delivery.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Percentage' ;
    rdfs:comment 'Percentage of ordered quantity that was fulfilled from available inventory. Calculated as (shipped quantity / ordered quantity) * 100. Key metric for inventory availability and customer service.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Commitment Flag' ;
    rdfs:comment 'Indicates whether this order is subject to formal OTIF performance measurement and customer scorecard reporting. True for orders with contractual delivery commitments.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outboundOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Status' ;
    rdfs:comment 'The outbound order status of the outbound order record' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingSlipNumber rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Number' ;
    rdfs:comment 'Document number for the packing slip accompanying the shipment. Used for customer receiving and invoice reconciliation.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Pick Ticket Number' ;
    rdfs:comment 'Warehouse document number used to direct picking operations for this order. Generated by WMS when order is released to the warehouse floor.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Timestamp' ;
    rdfs:comment 'Date and time when delivery was confirmed by the recipient. Captured from carrier POD or customer signature. Used for OTIF measurement and freight audit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'Date when the customer or system requests the order to be shipped from the distribution center. Used for warehouse planning and scheduling.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the order must be delivered to the customer destination. Critical for OTIF (On Time In Full) performance measurement and SLA compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Delivery speed commitment for the outbound order. Determines carrier selection, freight cost, and OTIF measurement criteria.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text instructions for warehouse and logistics teams regarding special handling requirements. May include temperature control, fragile handling, hazmat procedures, or customer-specific delivery instructions.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Order Quantity' ;
    rdfs:comment 'Total quantity of units across all line items in the outbound order. Used for warehouse capacity planning and OTIF fill rate calculation.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Total monetary value of the outbound order before taxes and freight charges. Used for order prioritization, credit limit checks, and revenue forecasting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Order Volume M3' ;
    rdfs:comment 'Total volume of the outbound order in cubic meters. Used for warehouse space planning, truck cube utilization, and pallet configuration.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Order Weight Kg' ;
    rdfs:comment 'Total weight of the outbound order in kilograms. Used for freight cost calculation, carrier capacity planning, and vehicle loading optimization.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnits rdf:type rdf:Property ;
    rdfs:label 'Total Units' ;
    rdfs:comment 'The total units of the outbound order record' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Unit Quantity' ;
    rdfs:comment 'Quantity converted to base unit of measure for standardized reporting and inventory tracking.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerPoLineNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Po Line Number' ;
    rdfs:comment 'Customer\'s purchase order line number for cross-reference and reconciliation.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Flag' ;
    rdfs:comment 'Indicates whether this line is part of a direct store delivery order bypassing retailer distribution centers.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediLineReference rdf:type rdf:Property ;
    rdfs:label 'Edi Line Reference' ;
    rdfs:comment 'EDI transaction line reference number for electronic order processing and ASN generation.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingUnitCode rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Code' ;
    rdfs:comment 'Serial shipping container code (SSCC) or handling unit identifier for the container holding this line item.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Line Volume M3' ;
    rdfs:comment 'Total volume of the shipped quantity for this line in cubic meters.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineWeightKg rdf:type rdf:Property ;
    rdfs:label 'Line Weight Kg' ;
    rdfs:comment 'Total weight of the shipped quantity for this line in kilograms.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'Quantity of the SKU originally requested by the customer in the order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundOrderLineStatus rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Line Status' ;
    rdfs:comment 'The outbound order line status of the outbound order line record' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Timestamp' ;
    rdfs:comment 'Date and time when the line item was packed into shipping containers.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packedQuantity rdf:type rdf:Property ;
    rdfs:label 'Packed Quantity' ;
    rdfs:comment 'Quantity packed into shipping containers and ready for dispatch.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Timestamp' ;
    rdfs:comment 'Date and time when the line item was picked from warehouse inventory.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickZone rdf:type rdf:Property ;
    rdfs:label 'Pick Zone' ;
    rdfs:comment 'Warehouse pick zone designation for labor management and routing optimization.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickedQuantity rdf:type rdf:Property ;
    rdfs:label 'Picked Quantity' ;
    rdfs:comment 'Quantity physically picked from warehouse storage locations during fulfillment.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumbers rdf:type rdf:Property ;
    rdfs:label 'Serial Numbers' ;
    rdfs:comment 'Comma-separated list of serial numbers for serialized inventory items shipped on this line.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ship Timestamp' ;
    rdfs:comment 'Date and time when the line item was shipped from the distribution center.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shortShipFlag rdf:type rdf:Property ;
    rdfs:label 'Short Ship Flag' ;
    rdfs:comment 'Indicates whether this line was short-shipped (shipped quantity less than ordered quantity).' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortShipReasonCode rdf:type rdf:Property ;
    rdfs:label 'Short Ship Reason Code' ;
    rdfs:comment 'Reason code for short shipment (OOS=Out of Stock, DAMAGE=Damaged Inventory, RECALL=Product Recall, EXPIRED=Expired Product, ALLOCATION=Allocation Constraint).' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Unit Volume M3' ;
    rdfs:comment 'Volume per unit of the SKU in cubic meters for space utilization and load planning.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitWeightKg rdf:type rdf:Property ;
    rdfs:label 'Unit Weight Kg' ;
    rdfs:comment 'Weight per unit of the SKU in kilograms for freight calculation and capacity planning.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseLocationCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Code' ;
    rdfs:comment 'Distribution center or warehouse location code from which this line was fulfilled.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickTaskId rdf:type rdf:Property ;
    rdfs:label 'Pick Task Id' ;
    rdfs:comment 'Unique identifier for the pick task record. Primary key for the pick_task data product.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Distribution Storage Location Id' ;
    rdfs:comment 'Reference to the target location where picked items are staged or packed (e.g., pack station, staging lane, loading dock).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:primaryPickDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Pick Distribution Storage Location Id' ;
    rdfs:comment 'Reference to the warehouse storage location (bin, shelf, pallet position) from which inventory is picked.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:cartonCode rdf:type rdf:Property ;
    rdfs:label 'Carton Code' ;
    rdfs:comment 'Unique identifier for the carton or shipping container into which items are packed. May be a license plate number (LPN) or SSCC (Serial Shipping Container Code).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'The completed timestamp of the pick task record' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Code identifying any exception or issue encountered during task execution (e.g., short pick, damaged goods, location discrepancy). Null if no exception.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text notes entered by the operator or supervisor describing the exception or issue encountered during task execution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gs1128Label rdf:type rdf:Property ;
    rdfs:label 'Gs1 128 Label' ;
    rdfs:comment 'The GS1-128 barcode label data applied to the carton or pallet, encoding SSCC, GTIN, lot, expiry, and other supply chain attributes.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Length dimension of the packed carton or pallet, measured in centimeters.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether this pick task is subject to OTIF (On Time In Full) performance measurement (true = OTIF tracked, false = not tracked).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packStationCode rdf:type rdf:Property ;
    rdfs:label 'Pack Station Code' ;
    rdfs:comment 'Reference to the packing station where the packing operation is performed. Applicable when task_type includes packing.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packagingMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Code' ;
    rdfs:comment 'Code identifying the type of packaging material used (e.g., corrugated box, poly bag, shrink wrap). Used for cartonization and sustainability tracking.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickAccuracyFlag rdf:type rdf:Property ;
    rdfs:label 'Pick Accuracy Flag' ;
    rdfs:comment 'Boolean indicator of whether the pick was accurate (true = picked quantity matches requested quantity and correct SKU/lot; false = discrepancy detected).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickListNumber rdf:type rdf:Property ;
    rdfs:label 'Pick List Number' ;
    rdfs:comment 'Human-readable pick list reference number assigned by the WMS for operator identification and tracking.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickMethod rdf:type rdf:Property ;
    rdfs:label 'Pick Method' ;
    rdfs:comment 'The pick method of the pick task record' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickQuantity rdf:type rdf:Property ;
    rdfs:label 'Pick Quantity' ;
    rdfs:comment 'The quantity of SKU units to be picked for this task, measured in the SKU\'s base unit of measure.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickTaskStatus rdf:type rdf:Property ;
    rdfs:label 'Pick Task Status' ;
    rdfs:comment 'The pick task status of the pick task record' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickingStrategy rdf:type rdf:Property ;
    rdfs:label 'Picking Strategy' ;
    rdfs:comment 'The picking methodology applied: discrete (single order), batch (multiple orders), zone (by warehouse zone), wave (grouped by wave), cluster (multi-order cart picking).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Priority classification of the pick task for sequencing and resource allocation: urgent (immediate), high (expedited), normal (standard), low (backlog).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Started Timestamp' ;
    rdfs:comment 'The started timestamp of the pick task record' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskAssignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Assigned Timestamp' ;
    rdfs:comment 'Timestamp when the pick task was assigned to an operator by the WMS. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Completed Timestamp' ;
    rdfs:comment 'Timestamp when the pick task was completed and confirmed by the operator or WMS. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Task Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from task start to completion. Used for labor productivity analysis and standard time calculation.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'The task number of the pick task record' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Started Timestamp' ;
    rdfs:comment 'Timestamp when the operator began executing the pick task (scanned start or confirmed task initiation). Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the pick task: pending (awaiting assignment), assigned (allocated to operator), in_progress (actively being executed), completed (finished successfully), cancelled (voided), on_hold (temporarily suspended).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Discriminator indicating the type of fulfillment task: pick (picking only), pack (packing only), pick_and_pack (combined operation), or replenishment_pick (internal stock movement).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Width dimension of the packed carton or pallet, measured in centimeters.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Freight Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Freight cost GL account on shipments enables direct posting of outbound freight expenses to the correct P&L line in consumer goods. Required for freight cost accrual, carrier invoice matching, and log' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The delivery date of the distribution shipment record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionShipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Shipment Status' ;
    rdfs:comment 'The distribution shipment status of the distribution shipment record' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'The expected delivery date of the distribution shipment record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'The freight cost of the distribution shipment record' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'The shipment number of the distribution shipment record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'The shipment status of the distribution shipment record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCartons rdf:type rdf:Property ;
    rdfs:label 'Total Cartons' ;
    rdfs:comment 'The total cartons of the distribution shipment record' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'The total weight kg of the distribution shipment record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryPositionId rdf:type rdf:Property ;
    rdfs:label 'Inventory Position Id' ;
    rdfs:comment 'Primary key for inventory_position' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualWeight rdf:type rdf:Property ;
    rdfs:label 'Actual Weight' ;
    rdfs:comment 'The actual measured weight of the inventory for catch weight items. Used for billing and compliance when item weight varies.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:catchWeightFlag rdf:type rdf:Property ;
    rdfs:label 'Catch Weight Flag' ;
    rdfs:comment 'Indicates whether the SKU is a catch weight item requiring actual weight capture at transaction time (true) or standard weight (false).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysOnHand rdf:type rdf:Property ;
    rdfs:label 'Days On Hand' ;
    rdfs:comment 'The number of days the inventory has been on hand since receipt. Calculated as current date minus receipt date. Used for aging analysis.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysToExpiry rdf:type rdf:Property ;
    rdfs:label 'Days To Expiry' ;
    rdfs:comment 'The number of days remaining until the inventory lot expires. Calculated as expiry date minus current date. Critical for FEFO rotation and markdown decisions.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inTransitQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Quantity' ;
    rdfs:comment 'The in transit quantity of the inventory position record' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryCondition rdf:type rdf:Property ;
    rdfs:label 'Inventory Condition' ;
    rdfs:comment 'The physical condition classification of the inventory. Used for disposition decisions and channel restrictions.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryPositionStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Position Status' ;
    rdfs:comment 'The inventory position status of the inventory position record' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'The current operational status of the inventory position. Determines availability for picking and order fulfillment.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'The date when this inventory position was last physically counted during a cycle count operation. Used to schedule next count and assess inventory accuracy.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'The date when inventory was last moved into or out of this storage location. Used for slow-moving inventory identification.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementType rdf:type rdf:Property ;
    rdfs:label 'Last Movement Type' ;
    rdfs:comment 'The type of the last inventory movement transaction that affected this position (receipt, putaway, pick, replenishment, transfer, adjustment, return). [ENUM-REF-CANDIDATE: receipt|putaway|pick|replenishment|transfer|adjustment|return — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensePlateNumber rdf:type rdf:Property ;
    rdfs:label 'License Plate Number' ;
    rdfs:comment 'The warehouse management system license plate number assigned to the handling unit. Used for tracking and automated material handling.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onHoldQuantity rdf:type rdf:Property ;
    rdfs:label 'On Hold Quantity' ;
    rdfs:comment 'The on hold quantity of the inventory position record' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Indicates the ownership model of the inventory (owned by company, consignment from supplier, customer-owned for returns, vendor-managed inventory).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickFaceFlag rdf:type rdf:Property ;
    rdfs:label 'Pick Face Flag' ;
    rdfs:comment 'Indicates whether this inventory position is in a primary pick face location (true) or reserve storage (false). Pick face locations are optimized for order picking efficiency.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:putawayDate rdf:type rdf:Property ;
    rdfs:label 'Putaway Date' ;
    rdfs:comment 'The date when the inventory was put away into this storage location after receiving. Used for aging analysis and FEFO compliance.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityAllocated rdf:type rdf:Property ;
    rdfs:label 'Quantity Allocated' ;
    rdfs:comment 'The quantity of on-hand inventory that has been allocated to outbound orders or reservations but not yet picked. Reduces available-to-pick quantity.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'The quantity available for new order allocation and picking. Calculated as quantity_on_hand minus quantity_allocated minus quantity_quarantine minus quantity_hold.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDamaged rdf:type rdf:Property ;
    rdfs:label 'Quantity Damaged' ;
    rdfs:comment 'The quantity of inventory identified as damaged and not suitable for sale or distribution. Typically awaiting disposal or return to supplier.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityHold rdf:type rdf:Property ;
    rdfs:label 'Quantity Hold' ;
    rdfs:comment 'The quantity of inventory placed on hold due to quality issues, customer complaints, or pending investigation. Not available for picking.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'The total physical quantity of the SKU-lot currently present in the storage location. Measured in the SKU\'s base unit of measure.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityQuarantine rdf:type rdf:Property ;
    rdfs:label 'Quantity Quarantine' ;
    rdfs:comment 'The quantity of inventory placed in quarantine status pending quality inspection or regulatory clearance. Not available for picking.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'The quantity of inventory reserved for specific customers, channels, or promotional programs. Subset of allocated quantity with additional business constraints.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentFlag rdf:type rdf:Property ;
    rdfs:label 'Replenishment Flag' ;
    rdfs:comment 'Indicates whether this inventory position requires replenishment from reserve to pick face (true) or not (false). Triggers automated replenishment tasks.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stockStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Status' ;
    rdfs:comment 'The stock status of the inventory position record' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageZone rdf:type rdf:Property ;
    rdfs:label 'Storage Zone' ;
    rdfs:comment 'The logical zone within the distribution center where the inventory is stored (e.g., ambient, refrigerated, frozen, hazmat, high-velocity, reserve).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalInventoryValue rdf:type rdf:Property ;
    rdfs:label 'Total Inventory Value' ;
    rdfs:comment 'The total financial value of the inventory position calculated as quantity_on_hand multiplied by cost_per_unit. Used for balance sheet reporting. Business confidential financial data.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Weight Unit Of Measure' ;
    rdfs:comment 'The unit of measure for actual weight (Pound, Kilogram, Ounce, Gram). Applicable for catch weight items.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: In AP subledger accounting, each vendor/supplier master record references a reconciliation GL account that links the AP subledger to the general ledger. This is a standard SAP/ERP requirement for AP-t' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line for the supplier\'s registered business location or headquarters.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for additional location details such as suite, building, or floor number.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'Date when the current master supply agreement or contract with the supplier expires and requires renewal or renegotiation.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:diversityClassification rdf:type rdf:Property ;
    rdfs:label 'Diversity Classification' ;
    rdfs:comment 'Classification indicating if the supplier qualifies as a diverse supplier (e.g., minority-owned, women-owned, veteran-owned, small business).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediIdentifier rdf:type rdf:Property ;
    rdfs:label 'Edi Identifier' ;
    rdfs:comment 'Unique EDI identifier or interchange ID used for electronic document exchange with the supplier.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fscCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Fsc Certified Flag' ;
    rdfs:comment 'Indicates whether the supplier holds FSC certification for sustainable forestry and paper-based materials sourcing.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'Standard Incoterms code defining the responsibilities, costs, and risks between buyer and supplier for international shipments. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isApproved rdf:type rdf:Property ;
    rdfs:label 'Is Approved' ;
    rdfs:comment 'The is approved of the supplier record' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStrategic rdf:type rdf:Property ;
    rdfs:label 'Is Strategic' ;
    rdfs:comment 'The is strategic of the supplier record' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified Flag' ;
    rdfs:comment 'Indicates whether the supplier maintains ISO 9001 quality management system certification.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The legal name of the supplier record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqQuantity rdf:type rdf:Property ;
    rdfs:label 'Moq Quantity' ;
    rdfs:comment 'Minimum order quantity required by the supplier for purchase orders to be accepted.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqUnit rdf:type rdf:Property ;
    rdfs:label 'Moq Unit' ;
    rdfs:comment 'Unit of measure for the minimum order quantity (e.g., EA, KG, LB, L, cases, pallets).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date when the supplier was officially onboarded and approved for procurement activities.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Current stage of the supplier onboarding process tracking progress from initial registration through final approval.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceScore rdf:type rdf:Property ;
    rdfs:label 'Performance Score' ;
    rdfs:comment 'Overall performance score for the supplier based on quality, delivery, cost, and service metrics, typically on a 0-100 scale.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Risk assessment classification for the supplier based on financial stability, geopolitical factors, compliance history, and supply continuity.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rspoCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Rspo Certified Flag' ;
    rdfs:comment 'Indicates whether the supplier holds RSPO certification for sustainable palm oil sourcing practices.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Number' ;
    rdfs:comment 'The supplier number of the supplier record' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Status' ;
    rdfs:comment 'Current lifecycle status of the supplier relationship indicating whether the supplier is eligible for procurement activities.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierType rdf:type rdf:Property ;
    rdfs:label 'Supplier Type' ;
    rdfs:comment 'Classification of the supplier based on the category of goods or services provided to the business.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Government-issued tax identification number for the supplier (e.g., EIN in USA, VAT number in EU) used for tax reporting and compliance.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Strategic classification of the supplier indicating their relationship status and procurement priority level with the organization.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Eligible Flag' ;
    rdfs:comment 'Indicates whether the supplier is eligible and capable of participating in Vendor Managed Inventory programs.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Most recent audit score for this site, typically on a 0-100 scale, reflecting compliance and quality performance.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the site capacity metric (e.g., units_per_month, pallets, square_meters, kilograms_per_day).' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the primary site certifications expire and require renewal. Used for compliance monitoring and supplier audit scheduling.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'The contact email of the supplier site record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'The contact name of the supplier site record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapable rdf:type rdf:Property ;
    rdfs:label 'Edi Capable' ;
    rdfs:comment 'Indicates whether this site is capable of exchanging purchase orders, invoices, and shipping notices via EDI.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fscCertified rdf:type rdf:Property ;
    rdfs:label 'Fsc Certified' ;
    rdfs:comment 'Indicates whether this site holds FSC certification for sustainable forestry and paper sourcing.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryShipFrom rdf:type rdf:Property ;
    rdfs:label 'Is Primary Ship From' ;
    rdfs:comment 'The is primary ship from of the supplier site record' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso22716Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 22716 Certified' ;
    rdfs:comment 'Indicates whether this site holds ISO 22716 Good Manufacturing Practices for Cosmetics certification.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moqUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Moq Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the minimum order quantity (e.g., units, cases, pallets, kilograms).' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSiteFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Site Flag' ;
    rdfs:comment 'Indicates whether this site is designated as a preferred sourcing location based on performance, cost, or strategic criteria.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteCapacity rdf:type rdf:Property ;
    rdfs:label 'Site Capacity' ;
    rdfs:comment 'Maximum production or storage capacity of the site, measured in units relevant to the site type (e.g., units per month for manufacturing, pallets for warehouse).' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Internal or supplier-assigned unique code identifying this site location.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteManagerName rdf:type rdf:Property ;
    rdfs:label 'Site Manager Name' ;
    rdfs:comment 'Name of the site manager or primary contact person responsible for this location.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Business name or designation of the supplier site facility.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current operational status of the supplier site in the procurement system.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the site based on its primary business function.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierSiteStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Site Status' ;
    rdfs:comment 'The supplier site status of the supplier site record' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiEnabled rdf:type rdf:Property ;
    rdfs:label 'Vmi Enabled' ;
    rdfs:comment 'Indicates whether this site participates in a VMI program where the supplier manages inventory levels at the buyer\'s location.' ;
    rdfs:domain ind:SupplierSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique business identifier for the contract, used in procurement systems and supplier communications.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the contract: draft for initial creation, pending approval for review workflow, active for in-force agreements, suspended for temporary holds, expired for naturally ended contracts, terminated for early cancellation, or renewed for extended agreements. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|expired|terminated|renewed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the contract structure: framework agreement for multi-material commitments, blanket order for recurring purchases, spot purchase for one-time buys, long-term agreement for strategic partnerships, consignment for supplier-owned inventory, or vendor managed inventory (VMI) for supplier-controlled replenishment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValueTotal rdf:type rdf:Property ;
    rdfs:label 'Contract Value Total' ;
    rdfs:comment 'Total monetary value committed under this contract across all line items and periods, used for spend tracking and budget allocation.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryTerms rdf:type rdf:Property ;
    rdfs:label 'Delivery Terms' ;
    rdfs:comment 'Agreed delivery conditions including lead times, delivery windows, and logistics requirements.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction and governing law under which the contract is interpreted and enforced (e.g., State of Delaware, English Law).' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyClause rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause' ;
    rdfs:comment 'Terms defining financial penalties for supplier non-compliance, late delivery, quality failures, or other contractual breaches.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceEscalationFormula rdf:type rdf:Property ;
    rdfs:label 'Price Escalation Formula' ;
    rdfs:comment 'Mathematical formula or index reference used to adjust prices over time, such as CPI-based adjustments or commodity index linkage.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingMechanism rdf:type rdf:Property ;
    rdfs:label 'Pricing Mechanism' ;
    rdfs:comment 'Method by which prices are determined: fixed price for static rates, cost plus for markup on supplier costs, market indexed for commodity-linked pricing, volume tiered for quantity-based discounts, or rebate based for retrospective incentives.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'The buyer or procurement team assigned to manage this contract, responsible for execution and supplier relationship.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'The organizational unit responsible for negotiating and managing this contract, typically aligned with regional or divisional procurement teams.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualitySpecification rdf:type rdf:Property ;
    rdfs:label 'Quality Specification' ;
    rdfs:comment 'Reference to quality standards, specifications, or inspection criteria that supplied materials must meet (e.g., GMP, ISO 9001, internal spec codes).' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'Base unit of measure for quantity commitments (e.g., KG, LTR, EA, MT) aligned with material master data.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateTerms rdf:type rdf:Property ;
    rdfs:label 'Rebate Terms' ;
    rdfs:comment 'Description of volume-based or performance-based rebate conditions, including thresholds, percentages, and settlement periods.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'The renewal notice days of the supplier contract record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Period Days' ;
    rdfs:comment 'Number of days prior to expiry that either party must provide notice to prevent auto-renewal or initiate renewal negotiations.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sdsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Required Flag' ;
    rdfs:comment 'Indicates whether supplier must provide Safety Data Sheets for hazardous materials covered by this contract, per OSHA and EPA regulations.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierContractStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Contract Status' ;
    rdfs:comment 'The supplier contract status of the supplier contract record' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetQuantityTotal rdf:type rdf:Property ;
    rdfs:label 'Target Quantity Total' ;
    rdfs:comment 'Aggregate quantity commitment across all materials and line items over the contract period, used for volume-based pricing and rebate calculations.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date when the contract was terminated early, either by mutual agreement or due to breach. Null if contract expired naturally or is still active.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Business reason for early termination, such as supplier performance issues, strategic sourcing changes, or mutual agreement.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'The total contract value of the supplier contract record' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractLineId rdf:type rdf:Property ;
    rdfs:label 'Contract Line Id' ;
    rdfs:comment 'Unique identifier for the contract line item. Primary key for this entity.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractLine .

ind:contractLineStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Line Status' ;
    rdfs:comment 'The contract line status of the contract line record' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeInvoicedValue rdf:type rdf:Property ;
    rdfs:label 'Cumulative Invoiced Value' ;
    rdfs:comment 'Total invoiced value for all purchase orders released against this contract line to date. Used for spend tracking and budget management.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeOrderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Ordered Quantity' ;
    rdfs:comment 'Total quantity ordered against this contract line to date. Used for tracking contract utilization and remaining commitment.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeReceivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Received Quantity' ;
    rdfs:comment 'Total quantity received against this contract line to date. Used for tracking actual fulfillment and supplier performance.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterm Location' ;
    rdfs:comment 'Named place or port associated with the Incoterm. Specifies the geographic point where cost and risk transfer occurs (e.g., supplier factory, destination port, buyer warehouse).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroupCode rdf:type rdf:Property ;
    rdfs:label 'Material Group Code' ;
    rdfs:comment 'Classification code grouping similar materials for procurement analysis and reporting. Enables spend analysis by category (e.g., raw materials, packaging, indirect goods).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Order Quantity Uom' ;
    rdfs:comment 'Unit of measure for minimum and maximum order quantities. Defines the measurement basis for order quantity constraints.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'Quantity of the material to which the unit price applies. For example, if price is per 100 units, this field would be 100. Used in conjunction with unit_price to calculate effective per-unit cost.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchasingGroupCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group Code' ;
    rdfs:comment 'Code identifying the procurement team or buyer responsible for managing this contract line. Used for workload distribution and accountability tracking.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Code identifying the specific storage location within the plant where the material will be received and stored. Used for warehouse management and inventory tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetQuantity rdf:type rdf:Property ;
    rdfs:label 'Target Quantity' ;
    rdfs:comment 'Planned or target quantity of material to be procured over the contract validity period. Used for volume commitment tracking and supplier capacity planning.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Target Quantity Uom' ;
    rdfs:comment 'Unit of measure for the target quantity. Defines how the target volume is measured (e.g., EA, KG, L, M).' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax classification code determining the applicable tax rate and tax jurisdiction for this contract line. Used for tax calculation and compliance reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'Date on which the pricing and terms on this contract line expire. Purchase orders can reference this line only on or before this date. Nullable for open-ended agreements.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'Date from which the pricing and terms on this contract line become effective. Purchase orders can reference this line only on or after this date.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'The valid from of the contract line record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validTo rdf:type rdf:Property ;
    rdfs:label 'Valid To' ;
    rdfs:comment 'The valid to of the contract line record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Unique identifier for the purchase requisition record. Primary key.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseRequisition .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Foreign key linking to marketing.marketing_budget. Business justification: Marketing budget governance: purchase requisitions for marketing spend must be validated against the marketing budget at requisition stage. This link enables budget availability checks and committed-s' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:preferredSupplierId rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Id' ;
    rdfs:comment 'Identifier of the preferred or recommended supplier for this requisition, based on contracts or sourcing strategy.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:primaryPurchaseCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Cost Center Id' ;
    rdfs:comment 'The purchase cost center id of the purchase requisition record' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Current approval level in the multi-tier approval workflow (e.g., 1 for manager, 2 for director, 3 for VP).' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalWorkflowReference rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Reference' ;
    rdfs:comment 'Identifier of the approval workflow instance governing this requisition, based on value thresholds and organizational rules.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedTotalValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Value' ;
    rdfs:comment 'Total estimated value of the purchase requisition (quantity × estimated unit price), used for budget control and approval routing.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Price' ;
    rdfs:comment 'Estimated price per unit of the requested material or service, used for budgeting and approval thresholds.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'Internal order number for tracking costs related to specific internal activities or campaigns.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseRequisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the purchase requisition in the approval and procurement workflow. [ENUM-REF-CANDIDATE: draft|submitted|approved|rejected|partially_ordered|fully_ordered|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization Code' ;
    rdfs:comment 'Code of the purchasing organization responsible for procuring the requested materials or services.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Quantity of material or service units requested in the purchase requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requesterEmail rdf:type rdf:Property ;
    rdfs:label 'Requester Email' ;
    rdfs:comment 'Email address of the employee who created the requisition, used for notifications and approvals.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterName rdf:type rdf:Property ;
    rdfs:label 'Requester Name' ;
    rdfs:comment 'Full name of the employee who created the purchase requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDate rdf:type rdf:Property ;
    rdfs:label 'Required Date' ;
    rdfs:comment 'The required date of the purchase requisition record' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Date' ;
    rdfs:comment 'The requisition date of the purchase requisition record' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Business identifier for the purchase requisition, typically system-generated and externally visible to requesters and procurement teams.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'The requisition status of the purchase requisition record' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the purchase requisition based on procurement scenario: standard purchase, subcontracting, consignment, stock transfer, service procurement, or third-party order.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfSupply rdf:type rdf:Property ;
    rdfs:label 'Source Of Supply' ;
    rdfs:comment 'Recommended or assigned source for fulfilling the requisition (preferred supplier, existing contract, stock transfer, external procurement, internal production).' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEstimatedValue rdf:type rdf:Property ;
    rdfs:label 'Total Estimated Value' ;
    rdfs:comment 'The total estimated value of the purchase requisition record' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'Project work breakdown structure element for project-related requisitions, used for project cost tracking.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Unique identifier for the purchase order. Primary key for the purchase order entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:ediStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Status' ;
    rdfs:comment 'Status of EDI transmission to the supplier. Tracks whether PO was successfully sent via EDI 850, acknowledged via EDI 855, or encountered transmission errors. Critical for automated supplier integration.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransmissionDate rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Date' ;
    rdfs:comment 'Timestamp when the purchase order was transmitted to the supplier via EDI. Used for supplier response time tracking and transmission audit.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:goodsReceiptRequired rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Required' ;
    rdfs:comment 'Indicator whether physical goods receipt posting is required for this purchase order. True for materials, false for services or non-stock items. Controls three-way match process.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'Named place or port specified in the Incoterms clause where risk and cost transfer occurs. Examples: Shanghai Port, Supplier Warehouse, Buyer Plant.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReceiptRequired rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Required' ;
    rdfs:comment 'Indicator whether invoice verification is required before payment. Controls accounts payable workflow and three-way match completion.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Total purchase order value including taxes and freight. Represents the complete financial commitment to the supplier.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known business identifier for the purchase order. Used for supplier communication, EDI transactions, and cross-system reference.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order. Tracks progression from creation through approval, supplier confirmation, goods receipt, and closure. Critical for procurement workflow management and OTIF tracking. [ENUM-REF-CANDIDATE: draft|submitted|approved|confirmed|in_transit|partially_received|fully_received|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order based on procurement strategy. Standard for one-time orders, blanket for recurring deliveries against a master agreement, contract for long-term commitments, subcontracting for external manufacturing, consignment for supplier-owned inventory, framework for multi-release agreements.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Status' ;
    rdfs:comment 'The purchase order status of the purchase order record' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Supplier Confirmation Date' ;
    rdfs:comment 'Timestamp when the supplier confirmed acceptance of the purchase order. Used for supplier responsiveness measurement and order commitment tracking.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplierConfirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Supplier Confirmation Method' ;
    rdfs:comment 'Channel through which the supplier acknowledged the purchase order. EDI 855 for automated acknowledgment, supplier portal for web-based confirmation, email/phone/fax for manual confirmation.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'The total value of the purchase order record' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vmiIndicator rdf:type rdf:Property ;
    rdfs:label 'Vmi Indicator' ;
    rdfs:comment 'Flag indicating whether this purchase order is part of a VMI program where the supplier manages inventory levels and replenishment. True for VMI orders, false for buyer-managed procurement.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchManagementIndicator rdf:type rdf:Property ;
    rdfs:label 'Batch Management Indicator' ;
    rdfs:comment 'Flag indicating whether the material on this line is subject to batch management. When true, batch number must be assigned during goods receipt for traceability.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Flag indicating whether this purchase order line has been marked for deletion. When true, the line is logically deleted but retained for audit purposes.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether goods receipt is required for this purchase order line. When true, physical receipt must be posted before invoice can be processed.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Received Quantity' ;
    rdfs:comment 'Cumulative quantity of material received against this purchase order line. Updated with each goods receipt posting. Used for delivery tracking and invoice matching.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether invoice verification is required for this line. When true, supplier invoice must be matched and verified against this PO line.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'Cumulative quantity invoiced by the supplier for this purchase order line. Used for three-way matching between PO, goods receipt, and invoice.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Original manufacturer\'s part number for the material. Important for quality assurance and regulatory compliance tracking.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'Classification code grouping similar materials for procurement analysis and reporting. Used for spend categorization and supplier segmentation.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingQuantity rdf:type rdf:Property ;
    rdfs:label 'Outstanding Quantity' ;
    rdfs:comment 'Remaining quantity yet to be received on this purchase order line. Calculated as ordered quantity minus goods received quantity.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Over Delivery Tolerance Percent' ;
    rdfs:comment 'Acceptable percentage by which the supplier may over-deliver beyond the ordered quantity. Used to control goods receipt tolerances.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poLineStatus rdf:type rdf:Property ;
    rdfs:label 'Po Line Status' ;
    rdfs:comment 'The po line status of the po line record' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionerName rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Name' ;
    rdfs:comment 'Name of the employee or department that requested this material through a purchase requisition. Provides accountability and cost center traceability.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortText rdf:type rdf:Property ;
    rdfs:label 'Short Text' ;
    rdfs:comment 'Additional short text or notes specific to this purchase order line. Provides supplementary information for procurement and receiving teams.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Material Number' ;
    rdfs:comment 'Supplier\'s own material or part number for this item. Used for cross-referencing and communication with the supplier.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Under Delivery Tolerance Percent' ;
    rdfs:comment 'Acceptable percentage by which the supplier may under-deliver below the ordered quantity. Used to control goods receipt tolerances and automatic PO closure.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateOfAnalysisReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Received Flag' ;
    rdfs:comment 'Indicates whether the supplier-provided Certificate of Analysis was received with the shipment. Required for GMP compliance and quality assurance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'The supplier-provided delivery note or packing slip number accompanying the shipment. Used for cross-referencing and dispute resolution.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date printed on the supplier delivery note or packing slip. May differ from posting date due to processing delays.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Status' ;
    rdfs:comment 'The goods receipt status of the goods receipt record' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Document Number' ;
    rdfs:comment 'The externally-known unique document number assigned to this goods receipt transaction. Used for audit trails, supplier communication, and three-way match processing.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grReversalFlag rdf:type rdf:Property ;
    rdfs:label 'Gr Reversal Flag' ;
    rdfs:comment 'Indicates whether this goods receipt has been reversed (cancelled). True means the inventory posting has been negated due to return-to-vendor or data correction.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grStatus rdf:type rdf:Property ;
    rdfs:label 'Gr Status' ;
    rdfs:comment 'Current lifecycle status of the goods receipt. Indicates whether the receipt is active, has been reversed, or is awaiting quality inspection clearance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'The SAP movement type code that classifies the nature of the goods receipt transaction (e.g., 101 for GR against PO, 122 for return delivery). Determines inventory and financial posting logic.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Compliance Flag' ;
    rdfs:comment 'Indicates whether this goods receipt met the On Time In Full criteria (received on or before requested date with full ordered quantity). Used for supplier performance scorecards.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'The quality status of the goods receipt record' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'The document number of the reversing goods receipt transaction, if this receipt was cancelled. Links to the offsetting inventory movement.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainableSourcingCertification rdf:type rdf:Property ;
    rdfs:label 'Sustainable Sourcing Certification' ;
    rdfs:comment 'The sustainability certification standard under which the received material was sourced (e.g., FSC for paper/packaging, RSPO for palm oil). Supports ESG reporting and sustainable sourcing initiatives.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'The total inventory value of the received goods in the company currency, calculated as received quantity multiplied by standard or moving average price. Used for financial posting and COGS calculation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Supplier Invoice Id' ;
    rdfs:comment 'Unique identifier for the supplier invoice record. Primary key.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierInvoice .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'The baseline date used for calculating payment due date and cash discount periods.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockingReasonCode rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason Code' ;
    rdfs:comment 'Code indicating why the invoice is blocked from payment, if applicable. Empty if not blocked.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason Description' ;
    rdfs:comment 'Detailed description of the reason the invoice is blocked from payment.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashDiscountDays rdf:type rdf:Property ;
    rdfs:label 'Cash Discount Days' ;
    rdfs:comment 'The number of days within which payment must be made to qualify for the cash discount.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cashDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Cash Discount Percentage' ;
    rdfs:comment 'The percentage discount available for early payment per payment terms.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'The date goods were received or services were confirmed, used for three-way match validation.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Amount' ;
    rdfs:comment 'The invoice amount of the supplier invoice record' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description or notes about the invoice provided by the supplier or entered during processing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Date' ;
    rdfs:comment 'The date the invoice was received by the organization.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice type indicating the nature of the transaction.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemCount rdf:type rdf:Property ;
    rdfs:label 'Line Item Count' ;
    rdfs:comment 'Total number of line items included in this invoice.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'The match status of the supplier invoice record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The actual date payment was made to the supplier.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which payment is due to the supplier per payment terms.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierInvoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Invoice Status' ;
    rdfs:comment 'The supplier invoice status of the supplier invoice record' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Result of the three-way match validation comparing purchase order, goods receipt, and invoice at header level.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceCheckResult rdf:type rdf:Property ;
    rdfs:label 'Tolerance Check Result' ;
    rdfs:comment 'Indicates whether the invoice passed tolerance checks for price and quantity variances.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Amount of withholding tax deducted from the invoice payment per regulatory requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxCode rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Code' ;
    rdfs:comment 'Code representing the withholding tax type and rate applied.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Primary key for invoice_line' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySupplierInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Invoice Id' ;
    rdfs:comment 'Reference to the parent supplier invoice header. Links this line item to the overall invoice document.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierInvoice .

ind:amountVariance rdf:type rdf:Property ;
    rdfs:label 'Amount Variance' ;
    rdfs:comment 'Total amount variance for this line calculated as the difference between invoiced amount and expected amount based on PO and GR.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'Reason code or description explaining why this invoice line is blocked from payment. Common reasons include price variance, quantity variance, or missing goods receipt.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLineStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Status' ;
    rdfs:comment 'The invoice line status of the invoice line record' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'The line amount of the invoice line record' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Line Gross Amount' ;
    rdfs:comment 'Total gross amount for this invoice line including taxes and charges. Sum of line_net_amount and line_tax_amount.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Line Tax Amount' ;
    rdfs:comment 'Total tax amount applicable to this invoice line. Calculated based on the tax code and net amount.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineText rdf:type rdf:Property ;
    rdfs:label 'Line Text' ;
    rdfs:comment 'Free-form text field for additional notes, comments, or special instructions related to this invoice line. May include supplier remarks or internal annotations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceVariance rdf:type rdf:Property ;
    rdfs:label 'Price Variance' ;
    rdfs:comment 'Difference between invoiced unit price and PO unit price. Used to identify pricing discrepancies and trigger approval workflows.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'Difference between invoiced quantity and goods receipt quantity. Positive values indicate over-invoicing; negative values indicate under-invoicing.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'Tax rate percentage applied to this line. Derived from the tax code configuration.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or role of the person or committee who authorized the supplier approval. Provides accountability and audit trail.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalBasis rdf:type rdf:Property ;
    rdfs:label 'Approval Basis' ;
    rdfs:comment 'Method or evidence used to grant supplier approval. Audit = on-site supplier audit; Certification = third-party certification (ISO, FSC, RSPO); Qualification test = material sample testing; Performance review = historical performance analysis; Risk assessment = supply chain risk evaluation; Legacy approval = pre-existing authorization.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiration Date' ;
    rdfs:comment 'Date when the current approval expires and requires re-evaluation. Null indicates indefinite approval subject to periodic review.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedSupplierListStatus rdf:type rdf:Property ;
    rdfs:label 'Approved Supplier List Status' ;
    rdfs:comment 'The approved supplier list status of the approved supplier list record' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingDate rdf:type rdf:Property ;
    rdfs:label 'Blocking Date' ;
    rdfs:comment 'Date when the supplier was blocked, delisted, or suspended. Null when status is approved, conditional, or pending.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Regulatory and policy compliance status for this supplier-material combination. Compliant = meets all requirements; Non-compliant = violations identified; Under review = compliance assessment in progress; Exempted = waiver granted.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalTerms rdf:type rdf:Property ;
    rdfs:label 'Conditional Terms' ;
    rdfs:comment 'Specific restrictions or requirements when approval status is conditional. Examples: reduced order quantities, enhanced inspection, expedited payment terms, or geographic limitations. Null when status is not conditional.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryRating rdf:type rdf:Property ;
    rdfs:label 'Delivery Rating' ;
    rdfs:comment 'Supplier delivery performance rating for this material-plant combination. A = excellent (>95% OTIF); B = good (90-95% OTIF); C = acceptable (85-90% OTIF); D = marginal (80-85% OTIF); F = failing (<80% OTIF).' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Enabled Flag' ;
    rdfs:comment 'Indicates whether electronic purchase orders and confirmations are enabled for this supplier-material-plant combination. True = EDI transactions supported; False = manual processing.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether incoming goods from this supplier-material combination require quality inspection before goods receipt posting. True = inspection mandatory; False = direct posting allowed.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceRank rdf:type rdf:Property ;
    rdfs:label 'Preference Rank' ;
    rdfs:comment 'The preference rank of the approved supplier list record' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Flag' ;
    rdfs:comment 'Indicates whether this supplier is the preferred source for this material-plant combination. True = preferred supplier with priority allocation; False = approved but not preferred.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity End Date' ;
    rdfs:comment 'End date of the current pricing agreement. Null indicates open-ended pricing subject to change notification.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity Start Date' ;
    rdfs:comment 'Start date of the current pricing agreement for this supplier-material-plant combination. Used to enforce valid pricing periods in PO creation.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationLevel rdf:type rdf:Property ;
    rdfs:label 'Qualification Level' ;
    rdfs:comment 'The qualification level of the approved supplier list record' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Supplier quality performance rating for this material-plant combination. A = excellent (>98% acceptance); B = good (95-98%); C = acceptable (90-95%); D = marginal (85-90%); F = failing (<85%). Derived from quality inspection results.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reEvaluationDueDate rdf:type rdf:Property ;
    rdfs:label 'Re Evaluation Due Date' ;
    rdfs:comment 'Scheduled date for the next supplier performance review or qualification audit. Drives proactive supplier management activities.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soleSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Sole Source Flag' ;
    rdfs:comment 'Indicates whether this supplier is the only approved source for this material-plant combination. True = sole source (supply risk); False = multiple sources available.' ;
    rdfs:domain ind:ApprovedSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentBrandMarketingBrandId rdf:type rdf:Property ;
    rdfs:label 'Parent Brand Marketing Brand Id' ;
    rdfs:comment 'Reference to the parent brand in the brand hierarchy. Null for masterbrand level. Used to establish brand family relationships and roll-up reporting.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingBrand .

ind:annualMarketingBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Marketing Budget' ;
    rdfs:comment 'Total allocated marketing investment for the brand for the fiscal year, including media spend, trade promotion, consumer promotion, and agency fees.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenueTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Target' ;
    rdfs:comment 'Planned annual revenue goal for the brand in the base currency. Used for budget planning, performance tracking, and brand portfolio prioritization.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:architectureTier rdf:type rdf:Property ;
    rdfs:label 'Architecture Tier' ;
    rdfs:comment 'Classification of the brand within the corporate brand architecture hierarchy. Masterbrand represents the corporate umbrella, subbrand is a distinct offering under the masterbrand, endorsed carries both corporate and product brand, ingredient brand is a component brand, private label is retailer-owned, and house brand is a proprietary store brand.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awarenessPercent rdf:type rdf:Property ;
    rdfs:label 'Awareness Percent' ;
    rdfs:comment 'Percentage of target consumers who recognize or recall the brand when prompted or unprompted. Measured through consumer surveys and market research panels.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandCategory rdf:type rdf:Property ;
    rdfs:label 'Brand Category' ;
    rdfs:comment 'Primary product category or market segment in which the brand competes. Examples include personal care, household cleaning, health and wellness, beauty, food and beverage.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandDescription rdf:type rdf:Property ;
    rdfs:label 'Brand Description' ;
    rdfs:comment 'Detailed narrative describing the brand\'s purpose, value proposition, and positioning in the market. Used for internal reference and marketing brief development.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:considerationPercent rdf:type rdf:Property ;
    rdfs:label 'Consideration Percent' ;
    rdfs:comment 'Percentage of target consumers who would consider purchasing the brand when making a category purchase decision. Key indicator of brand relevance and competitive positioning.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityScore rdf:type rdf:Property ;
    rdfs:label 'Equity Score' ;
    rdfs:comment 'Composite metric measuring the overall strength and value of the brand based on consumer awareness, perceived quality, brand associations, and loyalty. Typically scaled 0-100 with higher scores indicating stronger brand equity.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicMarketScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Market Scope' ;
    rdfs:comment 'Geographic reach of the brand\'s distribution and marketing activities. Global indicates worldwide presence, regional covers multiple countries in a region, national is single-country, and local is sub-national markets.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalBrandFlag rdf:type rdf:Property ;
    rdfs:label 'Global Brand Flag' ;
    rdfs:comment 'The global brand flag of the marketing brand record' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guidelinesUrl rdf:type rdf:Property ;
    rdfs:label 'Guidelines Url' ;
    rdfs:comment 'URL or file path to the comprehensive brand guidelines document containing logo usage, color specifications, typography, tone of voice, and visual identity standards.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthIndex rdf:type rdf:Property ;
    rdfs:label 'Health Index' ;
    rdfs:comment 'The brand health index of the marketing brand record' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrivateLabel rdf:type rdf:Property ;
    rdfs:label 'Is Private Label' ;
    rdfs:comment 'Boolean flag indicating whether the brand is a private label or store brand owned by a retail customer rather than the manufacturer. True indicates private label, false indicates manufacturer-owned brand.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logoAssetUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Asset Url' ;
    rdfs:comment 'URL or file path to the official brand logo asset in the digital asset management system. Used for marketing materials, packaging design, and digital campaigns.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSharePct rdf:type rdf:Property ;
    rdfs:label 'Market Share Pct' ;
    rdfs:comment 'The market share pct of the marketing brand record' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingBrandStatus rdf:type rdf:Property ;
    rdfs:label 'Marketing Brand Status' ;
    rdfs:comment 'The marketing brand status of the marketing brand record' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Legal entity or business unit that owns the intellectual property rights to the brand. May differ from the manufacturing or distribution entity.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioRole rdf:type rdf:Property ;
    rdfs:label 'Portfolio Role' ;
    rdfs:comment 'The portfolio role of the marketing brand record' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positioning rdf:type rdf:Property ;
    rdfs:label 'Positioning' ;
    rdfs:comment 'The brand positioning of the marketing brand record' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferencePercent rdf:type rdf:Property ;
    rdfs:label 'Preference Percent' ;
    rdfs:comment 'Percentage of target consumers who prefer this brand over competitive alternatives. Indicates brand loyalty and pricing power potential.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryColorHex rdf:type rdf:Property ;
    rdfs:label 'Primary Color Hex' ;
    rdfs:comment 'Hexadecimal color code for the primary brand color used in packaging, marketing materials, and digital assets. Ensures consistent brand identity across touchpoints.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDistributionChannel rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Channel' ;
    rdfs:comment 'Main channel through which the brand reaches consumers. Examples include mass retail, specialty retail, e-commerce, DTC (Direct to Consumer), professional/salon, or foodservice.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:somPercent rdf:type rdf:Property ;
    rdfs:label 'Som Percent' ;
    rdfs:comment 'Brand\'s percentage of total category sales volume or value. Primary metric for competitive market position and growth tracking.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovPercent rdf:type rdf:Property ;
    rdfs:label 'Sov Percent' ;
    rdfs:comment 'Brand\'s share of total advertising and promotional activity within the category, measured across paid media, earned media, and owned channels. Key indicator of marketing investment relative to competitors.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetConsumerSegment rdf:type rdf:Property ;
    rdfs:label 'Target Consumer Segment' ;
    rdfs:comment 'Primary demographic and psychographic profile of the intended consumer audience for the brand. Includes age range, income level, lifestyle attributes, and purchase behaviors.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSegment rdf:type rdf:Property ;
    rdfs:label 'Target Segment' ;
    rdfs:comment 'The target segment of the marketing brand record' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSomPercent rdf:type rdf:Property ;
    rdfs:label 'Target Som Percent' ;
    rdfs:comment 'Strategic target for the brand\'s market share. Used for annual planning, performance evaluation, and resource allocation decisions.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSovPercent rdf:type rdf:Property ;
    rdfs:label 'Target Sov Percent' ;
    rdfs:comment 'Strategic target for the brand\'s share of voice in the category. Used for media planning and budget allocation decisions. Typically set to exceed current SOM (Share of Market) to drive growth.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trademarkExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Trademark Expiration Date' ;
    rdfs:comment 'Date when the current trademark registration expires and requires renewal. Critical for maintaining legal protection of brand assets.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trademarkRegistrationDate rdf:type rdf:Property ;
    rdfs:label 'Trademark Registration Date' ;
    rdfs:comment 'Date when the trademark was officially registered with the relevant trademark authority. Used for renewal tracking and IP portfolio management.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trademarkRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Trademark Registration Number' ;
    rdfs:comment 'Official registration number assigned by the trademark authority for the brand name, logo, or other protected brand elements. Used for legal protection and IP (Intellectual Property) management.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyId rdf:type rdf:Property ;
    rdfs:label 'Agency Id' ;
    rdfs:comment 'FK to marketing.agency' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agency .

ind:primarySkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Campaign planning and ROI attribution need a primary SKU reference to allocate budget and measure lift per product.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:targetSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Segment Id' ;
    rdfs:comment 'Reference to the predefined consumer segment this campaign is designed to reach. Links to consumer segmentation master data.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:actualMediaSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Media Spend Amount' ;
    rdfs:comment 'The actual total media spend incurred for this campaign, in the company\'s reporting currency. Includes all paid media costs across channels.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualProductionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Production Cost Amount' ;
    rdfs:comment 'The actual cost incurred for creative production, including all content creation, design, video production, and asset development expenses.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSpend rdf:type rdf:Property ;
    rdfs:label 'Actual Spend' ;
    rdfs:comment 'The actual spend of the campaign record' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'The budget amount of the campaign record' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle state of the campaign: draft (initial planning), planned (scheduled), approved (ready for execution), active (currently running), paused (temporarily suspended), completed (finished), or cancelled (terminated before completion). [ENUM-REF-CANDIDATE: draft|planned|approved|active|paused|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign by execution approach: ATL (Above The Line - mass media), BTL (Below The Line - targeted), digital (online channels), shopper (in-store/retail), influencer (social media partnerships), or integrated (multi-channel).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelMix rdf:type rdf:Property ;
    rdfs:label 'Channel Mix' ;
    rdfs:comment 'Comma-separated list or description of marketing channels used in the campaign (e.g., TV, digital display, social media, print, radio, OOH, in-store).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCodes rdf:type rdf:Property ;
    rdfs:label 'Country Codes' ;
    rdfs:comment 'Comma-separated list of three-letter ISO 3166-1 alpha-3 country codes where the campaign is executed (e.g., USA,CAN,MEX).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeConcept rdf:type rdf:Property ;
    rdfs:label 'Creative Concept' ;
    rdfs:comment 'High-level description of the creative theme, messaging strategy, and visual identity used in the campaign.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographyScope rdf:type rdf:Property ;
    rdfs:label 'Geography Scope' ;
    rdfs:comment 'Geographic reach of the campaign: global (worldwide), regional (multi-country region), national (single country), or local (city/metro area).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiTarget rdf:type rdf:Property ;
    rdfs:label 'Kpi Target' ;
    rdfs:comment 'The kpi target of the campaign record' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Primary business goal of the campaign: awareness (brand visibility), consideration (product evaluation), conversion (purchase), loyalty (retention), launch (new product introduction), or relaunch (product refresh).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedMediaSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Media Spend Amount' ;
    rdfs:comment 'The budgeted total media spend allocated to this campaign during the planning phase, in the company\'s reporting currency.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedProductionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Production Cost Amount' ;
    rdfs:comment 'The budgeted cost for creative production, including content creation, design, video production, and asset development.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roiPct rdf:type rdf:Property ;
    rdfs:label 'Roi Pct' ;
    rdfs:comment 'The roi pct of the campaign record' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Textual description of the intended consumer segment for this campaign, including demographic, psychographic, and behavioral characteristics.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetReach rdf:type rdf:Property ;
    rdfs:label 'Target Reach' ;
    rdfs:comment 'The target reach of the campaign record' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalBudget rdf:type rdf:Property ;
    rdfs:label 'Total Budget' ;
    rdfs:comment 'The total budget of the campaign record' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignFlightId rdf:type rdf:Property ;
    rdfs:label 'Campaign Flight Id' ;
    rdfs:comment 'Unique identifier for the campaign flight record. Primary key.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CampaignFlight .

ind:creativeAssetId rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Id' ;
    rdfs:comment 'Reference to the creative asset used in this flight. Links to creative asset management system for creative performance analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeAsset .

ind:mediaPlanId rdf:type rdf:Property ;
    rdfs:label 'Media Plan Id' ;
    rdfs:comment 'Foreign key linking to marketing.media_plan. Business justification: Campaign flights are the execution of media plans. Linking a flight to its originating media plan enables plan vs. actual comparison at the flight level — comparing planned impressions, planned spend,' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaPlan .

ind:actualImpressions rdf:type rdf:Property ;
    rdfs:label 'Actual Impressions' ;
    rdfs:comment 'Actual number of impressions delivered during the flight. Core metric for reach and frequency analysis.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionModel rdf:type rdf:Property ;
    rdfs:label 'Attribution Model' ;
    rdfs:comment 'Attribution methodology used to assign conversion credit to this flight. Critical for multi-touch attribution analysis.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Total budget allocated to this flight. Represents the planned media spend for this specific flight execution.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetSpentAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Spent Amount' ;
    rdfs:comment 'Actual amount spent on this flight. Used for budget variance analysis and Return on Ad Spend (ROAS) calculation.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignFlightStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Flight Status' ;
    rdfs:comment 'The campaign flight status of the campaign flight record' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clicks rdf:type rdf:Property ;
    rdfs:label 'Clicks' ;
    rdfs:comment 'Total number of clicks generated by the flight. Primary engagement metric for digital and search campaigns.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionRate rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate' ;
    rdfs:comment 'Conversion rate expressed as a decimal (conversions divided by clicks or impressions). Measures campaign effectiveness in driving desired actions.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversions rdf:type rdf:Property ;
    rdfs:label 'Conversions' ;
    rdfs:comment 'Total number of conversions attributed to this flight. Conversion definition varies by campaign objective (purchase, sign-up, download, etc.).' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpa rdf:type rdf:Property ;
    rdfs:label 'Cpa' ;
    rdfs:comment 'Average cost per conversion for this flight. Critical metric for performance marketing and Return on Investment (ROI) analysis.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpc rdf:type rdf:Property ;
    rdfs:label 'Cpc' ;
    rdfs:comment 'Average cost per click for this flight. Key efficiency metric for paid search and digital campaigns.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctr rdf:type rdf:Property ;
    rdfs:label 'Ctr' ;
    rdfs:comment 'Click-through rate expressed as a decimal (clicks divided by impressions). Key performance indicator for digital campaign effectiveness.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flightBudget rdf:type rdf:Property ;
    rdfs:label 'Flight Budget' ;
    rdfs:comment 'The flight budget of the campaign flight record' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flightCode rdf:type rdf:Property ;
    rdfs:label 'Flight Code' ;
    rdfs:comment 'The flight code of the campaign flight record' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightName rdf:type rdf:Property ;
    rdfs:label 'Flight Name' ;
    rdfs:comment 'Descriptive name of the campaign flight for business user identification and reporting.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightNumber rdf:type rdf:Property ;
    rdfs:label 'Flight Number' ;
    rdfs:comment 'Business identifier for the flight within the campaign. Used for external reporting and agency coordination.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightStatus rdf:type rdf:Property ;
    rdfs:label 'Flight Status' ;
    rdfs:comment 'Current lifecycle status of the campaign flight.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grp rdf:type rdf:Property ;
    rdfs:label 'Grp' ;
    rdfs:comment 'Gross Rating Points for traditional media (TV, radio, OOH). Measures total audience delivery as a percentage of target population multiplied by frequency.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressionsTarget rdf:type rdf:Property ;
    rdfs:label 'Impressions Target' ;
    rdfs:comment 'The impressions target of the campaign flight record' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketGeography rdf:type rdf:Property ;
    rdfs:label 'Market Geography' ;
    rdfs:comment 'Geographic market or region where the flight is executed. Supports market-level performance tracking and regional campaign optimization.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'Date on which performance metrics were measured or reported. Supports daily granular performance tracking at the campaign-channel-market-date grain.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:placementType rdf:type rdf:Property ;
    rdfs:label 'Placement Type' ;
    rdfs:comment 'Specific placement or ad format type within the channel (e.g., banner, video, native, sponsored post, display, search text ad). Enables placement-level optimization.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedImpressions rdf:type rdf:Property ;
    rdfs:label 'Planned Impressions' ;
    rdfs:comment 'The planned impressions of the campaign flight record' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platform rdf:type rdf:Property ;
    rdfs:label 'Platform' ;
    rdfs:comment 'Specific advertising platform or network (e.g., Meta, Google Ads, TikTok, programmatic DSP, linear TV network). Enables platform-specific performance analysis.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reach rdf:type rdf:Property ;
    rdfs:label 'Reach' ;
    rdfs:comment 'Estimated number of unique individuals exposed to the campaign flight. Used for audience coverage analysis.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roas rdf:type rdf:Property ;
    rdfs:label 'Roas' ;
    rdfs:comment 'Return on Ad Spend expressed as a ratio (revenue generated divided by ad spend). Primary metric for campaign profitability assessment.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetImpressions rdf:type rdf:Property ;
    rdfs:label 'Target Impressions' ;
    rdfs:comment 'Planned number of impressions for this flight. Used for media planning and performance target setting.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:videoCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Video Completion Rate' ;
    rdfs:comment 'Percentage of video views that were completed (watched to end). Measures creative engagement quality.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoViews rdf:type rdf:Property ;
    rdfs:label 'Video Views' ;
    rdfs:comment 'Total number of video views for video creative flights. Applicable to digital video, social, and TV campaigns.' ;
    rdfs:domain ind:CampaignFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAllocationPercent rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Percent' ;
    rdfs:comment 'Percentage of total campaign or brand budget allocated to this media plan line.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creativeFormat rdf:type rdf:Property ;
    rdfs:label 'Creative Format' ;
    rdfs:comment 'Format of the creative asset planned for this media (e.g., 30-second spot, banner ad, full-page print, billboard).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypart rdf:type rdf:Property ;
    rdfs:label 'Daypart' ;
    rdfs:comment 'Time segment of day for broadcast media (e.g., Prime Time, Early Morning, Late Night, Daytime).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightEndDate rdf:type rdf:Property ;
    rdfs:label 'Flight End Date' ;
    rdfs:comment 'End date of the media flight or execution period for this plan.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flightStartDate rdf:type rdf:Property ;
    rdfs:label 'Flight Start Date' ;
    rdfs:comment 'Start date of the media flight or execution period for this plan.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:market rdf:type rdf:Property ;
    rdfs:label 'Market' ;
    rdfs:comment 'Geographic market or Designated Market Area (DMA) targeted by this media plan (e.g., USA, New York DMA, UK).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaChannel rdf:type rdf:Property ;
    rdfs:label 'Media Channel' ;
    rdfs:comment 'Primary media channel category for this plan line (TV, digital, out-of-home, print, social, search, programmatic, radio, cinema, podcast). [ENUM-REF-CANDIDATE: tv|digital|ooh|print|social|search|programmatic|radio|cinema|podcast — promote to reference product]' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaOwner rdf:type rdf:Property ;
    rdfs:label 'Media Owner' ;
    rdfs:comment 'Name of the media owner or publisher (e.g., NBC, Google, Meta, Clear Channel).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Media Plan Status' ;
    rdfs:comment 'The media plan status of the media plan record' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaSubchannel rdf:type rdf:Property ;
    rdfs:label 'Media Subchannel' ;
    rdfs:comment 'Detailed subchannel or platform within the primary media channel (e.g., Facebook, Google Display, National TV, Local Radio).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaType rdf:type rdf:Property ;
    rdfs:label 'Media Type' ;
    rdfs:comment 'The media type of the media plan record' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planPeriod rdf:type rdf:Property ;
    rdfs:label 'Plan Period' ;
    rdfs:comment 'The plan period of the media plan record' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedBudget rdf:type rdf:Property ;
    rdfs:label 'Planned Budget' ;
    rdfs:comment 'The planned budget of the media plan record' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCpm rdf:type rdf:Property ;
    rdfs:label 'Planned Cpm' ;
    rdfs:comment 'Planned cost per thousand impressions for this media investment.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCpp rdf:type rdf:Property ;
    rdfs:label 'Planned Cpp' ;
    rdfs:comment 'Planned cost per rating point for broadcast media investments.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedFrequency rdf:type rdf:Property ;
    rdfs:label 'Planned Frequency' ;
    rdfs:comment 'Planned average number of times the target audience will be exposed to the media message.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedGrp rdf:type rdf:Property ;
    rdfs:label 'Planned Grp' ;
    rdfs:comment 'Planned Gross Rating Points representing the total reach multiplied by frequency for the target audience.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReach rdf:type rdf:Property ;
    rdfs:label 'Planned Reach' ;
    rdfs:comment 'The planned reach of the media plan record' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedReachPercent rdf:type rdf:Property ;
    rdfs:label 'Planned Reach Percent' ;
    rdfs:comment 'Planned percentage of the target audience reached at least once during the planning period.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Spend Amount' ;
    rdfs:comment 'Total planned media spend amount for this media plan in the base currency.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetGrp rdf:type rdf:Property ;
    rdfs:label 'Target Grp' ;
    rdfs:comment 'The target grp of the media plan record' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetReachPct rdf:type rdf:Property ;
    rdfs:label 'Target Reach Pct' ;
    rdfs:comment 'The target reach pct of the media plan record' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediaSpendId rdf:type rdf:Property ;
    rdfs:label 'Media Spend Id' ;
    rdfs:comment 'Unique identifier for the media spend transaction record. Primary key for the media spend data product.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agencyFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Agency Fee Amount' ;
    rdfs:comment 'The agency service fee or commission charged for managing the media buy.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyType rdf:type rdf:Property ;
    rdfs:label 'Buy Type' ;
    rdfs:comment 'The method by which the media inventory was purchased (e.g., Programmatic, Direct, Auction, Guaranteed).' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clicksDelivered rdf:type rdf:Property ;
    rdfs:label 'Clicks Delivered' ;
    rdfs:comment 'The total number of clicks generated by the media placement for this spend transaction.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpcActual rdf:type rdf:Property ;
    rdfs:label 'Cpc Actual' ;
    rdfs:comment 'The actual cost per click (CPC) achieved for this media spend, calculated as working spend divided by clicks delivered.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpm rdf:type rdf:Property ;
    rdfs:label 'Cpm' ;
    rdfs:comment 'The cpm of the media spend record' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpmActual rdf:type rdf:Property ;
    rdfs:label 'Cpm Actual' ;
    rdfs:comment 'The actual cost per thousand impressions (CPM) achieved for this media spend, calculated as (working spend / impressions) * 1000.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpvActual rdf:type rdf:Property ;
    rdfs:label 'Cpv Actual' ;
    rdfs:comment 'The actual cost per video view (CPV) achieved for this media spend, calculated as working spend divided by video views delivered.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressions rdf:type rdf:Property ;
    rdfs:label 'Impressions' ;
    rdfs:comment 'The impressions of the media spend record' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Impressions Delivered' ;
    rdfs:comment 'The total number of ad impressions delivered for this spend transaction.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoicedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Spend Amount' ;
    rdfs:comment 'The total amount invoiced by the media owner or agency for this media spend transaction.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketName rdf:type rdf:Property ;
    rdfs:label 'Market Name' ;
    rdfs:comment 'The name of the specific market or Designated Market Area (DMA) where the media was placed (e.g., New York, Los Angeles, London).' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaOwnerName rdf:type rdf:Property ;
    rdfs:label 'Media Owner Name' ;
    rdfs:comment 'The name of the media owner or publisher that provided the advertising inventory (e.g., Google, Meta, NBC Universal).' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaSpendStatus rdf:type rdf:Property ;
    rdfs:label 'Media Spend Status' ;
    rdfs:comment 'The media spend status of the media spend record' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaVehicle rdf:type rdf:Property ;
    rdfs:label 'Media Vehicle' ;
    rdfs:comment 'The media vehicle of the media spend record' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonWorkingSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Non Working Spend Amount' ;
    rdfs:comment 'The portion of invoiced spend allocated to agency fees, production costs, and other non-media expenses (non-working media).' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Production Cost Amount' ;
    rdfs:comment 'The cost of creative production, ad serving, and other production-related expenses included in this spend transaction.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciled Timestamp' ;
    rdfs:comment 'The timestamp when this media spend record was reconciled against the media plan and delivery metrics.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'The current reconciliation status of this spend transaction against the media plan and delivery metrics.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendAmount rdf:type rdf:Property ;
    rdfs:label 'Spend Amount' ;
    rdfs:comment 'The spend amount of the media spend record' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendDate rdf:type rdf:Property ;
    rdfs:label 'Spend Date' ;
    rdfs:comment 'The date on which the media spend was incurred or invoiced.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spendPeriod rdf:type rdf:Property ;
    rdfs:label 'Spend Period' ;
    rdfs:comment 'The fiscal or calendar period (e.g., 2024-Q1, 2024-03) to which this spend is allocated for reporting purposes.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceToPlanAmount rdf:type rdf:Property ;
    rdfs:label 'Variance To Plan Amount' ;
    rdfs:comment 'The difference between invoiced spend and planned spend (invoiced minus planned), indicating over- or under-spend.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'The vendor name of the media spend record' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoViewsDelivered rdf:type rdf:Property ;
    rdfs:label 'Video Views Delivered' ;
    rdfs:comment 'The total number of video views or completions delivered for video media placements.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workingSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Working Spend Amount' ;
    rdfs:comment 'The portion of invoiced spend that directly purchased media inventory (working media), excluding agency fees and production costs.' ;
    rdfs:domain ind:MediaSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentAssetCreativeAssetId rdf:type rdf:Property ;
    rdfs:label 'Parent Asset Creative Asset Id' ;
    rdfs:comment 'Identifier of the parent creative asset if this asset is a derivative, localized version, or variant of another asset.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeAsset .

ind:actualPublishDate rdf:type rdf:Property ;
    rdfs:label 'Actual Publish Date' ;
    rdfs:comment 'Actual date when the creative asset was published or went live.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetCode rdf:type rdf:Property ;
    rdfs:label 'Asset Code' ;
    rdfs:comment 'Unique business identifier or code assigned to the creative asset for tracking and reference purposes.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable name or title of the creative asset (e.g., \'Spring Campaign Hero Banner\', \'Product Launch Video 30s\').' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Classification of the creative asset by media type (video, image, audio, document, HTML, social post, email template). [ENUM-REF-CANDIDATE: video|image|audio|document|html|social_post|email_template — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Notes or comments from compliance and legal review regarding the creative asset.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Status' ;
    rdfs:comment 'Status of regulatory and legal compliance review for the creative asset (not required, pending, approved, rejected).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentCategory rdf:type rdf:Property ;
    rdfs:label 'Content Category' ;
    rdfs:comment 'Business category or use case of the creative asset (TV commercial, digital banner, social media, print ad, packaging visual, influencer brief, blog post, email content, landing page, infographic). [ENUM-REF-CANDIDATE: tv_commercial|digital_banner|social_media|print_ad|packaging_visual|influencer_brief|blog_post|email_content|landing_page|infographic — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentFormat rdf:type rdf:Property ;
    rdfs:label 'Content Format' ;
    rdfs:comment 'Specific file format or content format of the asset (e.g., MP4, JPEG, PNG, PDF, GIF, HTML5).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentStatus rdf:type rdf:Property ;
    rdfs:label 'Content Status' ;
    rdfs:comment 'Current publishing lifecycle status of the creative asset (planned, scheduled, published, archived, withdrawn).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAssetStatus rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Status' ;
    rdfs:comment 'The creative asset status of the creative asset record' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Dam Reference Code' ;
    rdfs:comment 'Unique identifier or reference code in the Digital Asset Management system where the asset is stored.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Duration of the creative asset in seconds (applicable to video and audio assets).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileReference rdf:type rdf:Property ;
    rdfs:label 'File Reference' ;
    rdfs:comment 'The file reference of the creative asset record' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the creative asset file in bytes.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileUrl rdf:type rdf:Property ;
    rdfs:label 'File Url' ;
    rdfs:comment 'The file url of the creative asset record' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'The format of the creative asset record' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightPixels rdf:type rdf:Property ;
    rdfs:label 'Height Pixels' ;
    rdfs:comment 'Height dimension of the creative asset in pixels (applicable to images, videos, and display ads).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isMasterVersion rdf:type rdf:Property ;
    rdfs:label 'Is Master Version' ;
    rdfs:comment 'Flag indicating whether this is the master or primary version of the creative asset (True) or a derivative/variant (False).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords or tags associated with the creative asset for search and discovery purposes.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
