    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Net weight of a single unit of material expressed in kilograms.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryCategoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Category Id' ;
    rdfs:comment 'Foreign key linking to product.category. Business justification: Manufacturing facilities specialize by product category (e.g., hair care, skin care), driving capacity planning, regulatory classification, and GMP requirements. primary_product_category is a denormal' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:supplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Supply Network Node Id' ;
    rdfs:comment 'Foreign key linking to supply.network_node. Business justification: Required for Supply Network Planning report to map each plant to its network node, enabling ATP, capacity, and logistics calculations; domain experts expect this mapping.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line for the manufacturing facility location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for suite, building, or additional location details. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitsPerYear rdf:type rdf:Property ;
    rdfs:label 'Capacity Units Per Year' ;
    rdfs:comment 'The capacity units per year of the manufacturing facility record' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the manufacturing facility is located.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date when the facility was officially commissioned and began production operations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO country code where the manufacturing facility is located (e.g., USA, DEU, CHN).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email contact for the manufacturing facility operations team. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyConsumptionKwhPerYear rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Year' ;
