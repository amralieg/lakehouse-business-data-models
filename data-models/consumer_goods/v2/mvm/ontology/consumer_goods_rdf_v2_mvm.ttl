    rdfs:range xsd:string .

ind:productionCapacityUnitsPerDay rdf:type rdf:Property ;
    rdfs:label 'Production Capacity Units Per Day' ;
    rdfs:comment 'Maximum daily production capacity of the facility measured in finished goods units per day under normal operating conditions.' ;
    rdfs:domain ind:ManufacturingFacility ;
