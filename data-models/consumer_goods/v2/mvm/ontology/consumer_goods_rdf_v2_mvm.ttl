    rdfs:label 'Marketing Budget Status' ;
    rdfs:comment 'The marketing budget status of the marketing budget record' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:period rdf:type rdf:Property ;
    rdfs:label 'Period' ;
    rdfs:comment 'The budget period of the marketing budget record' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Amount' ;
    rdfs:comment 'The remaining amount of the marketing budget record' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spentAmount rdf:type rdf:Property ;
    rdfs:label 'Spent Amount' ;
    rdfs:comment 'The spent amount of the marketing budget record' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activityTypeIndicator rdf:type rdf:Property ;
    rdfs:label 'Activity Type Indicator' ;
    rdfs:comment 'Flag indicating whether this cost center performs activity-based costing. True if the center provides measurable activities (e.g., machine hours, labor hours) that are allocated to cost objects.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used for allocating costs from this cost center to other cost objects (products, profit centers). Critical for COGS calculation and overhead absorption.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetProfileCode rdf:type rdf:Property ;
    rdfs:label 'Budget Profile Code' ;
    rdfs:comment 'Budget control profile defining budget planning rules, tolerance limits, and approval workflows for this cost center. Determines budget availability check behavior.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'Business area classification for code reporting. Represents a distinct line of business or product category (e.g., Personal Care, Home Care, Beauty) for consolidated financial analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group' ;
    rdfs:comment 'Logical grouping of cost centers for consolidated reporting and analysis. Enables flexible aggregation beyond standard hierarchy (e.g., all brand marketing centers, all R&D centers).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active centers accept postings; inactive centers are closed; blocked centers are temporarily suspended; planned centers are approved but not yet operational.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by functional area. Determines the nature of costs tracked and reporting hierarchy. Used for COGS allocation and EBITDA segmentation. [ENUM-REF-CANDIDATE: production|sales|marketing|distribution|administration|research_development|quality_assurance|procurement|finance|shared_services — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Department or functional unit code within the organization. Provides granular classification for workforce planning and departmental cost analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'Functional area classification for cost-of-sales accounting. Distinguishes between manufacturing, sales, marketing, R&D, and administrative functions for COGS and operating expense allocation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyArea rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Area' ;
    rdfs:comment 'Standard hierarchy assignment for organizational reporting. Defines the cost center\'s position in the corporate hierarchy tree for roll-up reporting and budget consolidation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyNode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node' ;
    rdfs:comment 'The hierarchy node of the cost center record' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Flag indicating whether the cost center is locked for actual postings. Used during period-end close and organizational changes to prevent unintended transactions.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Code' ;
    rdfs:comment 'Code of the parent cost center in the organizational hierarchy. Enables hierarchical roll-up of costs for management reporting and budget aggregation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Geographic region classification (e.g., NOAM, EMEA, APAC, LATAM) for regional financial reporting and performance benchmarking.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalIndicator rdf:type rdf:Property ;
    rdfs:label 'Statistical Indicator' ;
    rdfs:comment 'Flag indicating whether this is a statistical cost center used only for informational reporting without actual cost postings. Used for tracking non-financial metrics.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Id' ;
    rdfs:comment 'Reference to the parent profit center in a hierarchical profit center structure. Enables roll-up reporting and EBITDA decomposition across organizational levels.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:consolidationUnitCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Unit Code' ;
    rdfs:comment 'Code of the consolidation unit for. Links profit center to the financial consolidation hierarchy for IFRS/GAAP reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroupCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group Code' ;
    rdfs:comment 'Code of the cost center group associated with this profit center. Links profit center accounting to cost center accounting for overhead allocation and COGS calculation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Region Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country or region code representing the primary geographic location of the profit center for regional segment reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Planning Enabled Flag' ;
    rdfs:comment 'Boolean flag indicating whether this profit center participates in budgeting and financial planning processes.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center indicating whether it is operational, temporarily suspended, or permanently closed.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center by organizational dimension: product line, brand, geographic region, sales channel, or business unit. Determines the segment reporting structure.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Email' ;
    rdfs:comment 'Email address of the profit center manager for financial reporting notifications and escalations.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'Name of the business leader or manager accountable for the profit center\'s financial performance and operational results.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'The segment of the profit center record' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Boolean flag indicating whether this profit center is subject to SOX financial controls and audit requirements for publicly traded companies.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'State or province code for the profit center\'s location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationView rdf:type rdf:Property ;
    rdfs:label 'Valuation View' ;
    rdfs:comment 'Valuation perspective for profit center accounting: legal (statutory), group (IFRS/GAAP consolidation), profit center (internal transfer pricing), or management (operational view).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'The account group classification that controls field status, number ranges, and posting rules in the ERP system.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountShortName rdf:type rdf:Property ;
    rdfs:label 'Account Short Name' ;
    rdfs:comment 'Abbreviated name or label for the GL account used in condensed reports and system displays.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'For balance sheet accounts, indicates whether the account is a current asset, non-current asset, current liability, non-current liability, or equity. Not applicable for P&L accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetFlag rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Flag' ;
    rdfs:comment 'The balance sheet flag of the gl account record' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceSheetIndicator rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Indicator' ;
    rdfs:comment 'The balance sheet indicator of the gl account record' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockedForPosting rdf:type rdf:Property ;
    rdfs:label 'Blocked For Posting' ;
    rdfs:comment 'The blocked for posting of the gl account record' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockedForPostingFlag rdf:type rdf:Property ;
    rdfs:label 'Blocked For Posting Flag' ;
    rdfs:comment 'Indicates whether the account is currently blocked for all postings. Used to prevent transactions to accounts that are under review, closed, or being restructured.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetControlFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Control Flag' ;
    rdfs:comment 'Indicates whether budget availability checking is active for this account. When enabled, postings are validated against approved budgets.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashFlowCategory rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Category' ;
    rdfs:comment 'For accounts that impact cash flow, indicates the cash flow statement category: operating activities, investing activities, or financing activities. Not applicable for non-cash accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account Number' ;
    rdfs:comment 'The corresponding account number in the group consolidation chart of accounts. Used for mapping local accounts to structures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Center Required Flag' ;
    rdfs:comment 'Indicates whether a cost center assignment is mandatory when posting to this account. Used for internal cost allocation and management reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'For accounts that are cost elements, indicates whether it is a primary cost element (direct posting from FI) or secondary cost element (internal allocation only). Not applicable if not a cost element.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Element Flag' ;
    rdfs:comment 'Indicates whether this GL account is also defined as a cost element in the Controlling (CO) module for cost center and internal order postings.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether the account normally carries a debit balance or credit balance in the general ledger.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'The field status group that controls which fields are required, optional, or suppressed when posting to this account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementCategory rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Category' ;
    rdfs:comment 'The primary financial statement where this account appears: balance sheet, income statement (P&L), cash flow statement, retained earnings, or statistical.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementLineItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Line Item' ;
    rdfs:comment 'The specific line item or section within the financial statement where this account balance is reported (e.g., Current Assets, Cost of Goods Sold, Operating Expenses).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Account Number' ;
    rdfs:comment 'The gl account number of the gl account record' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Gl Account Status' ;
    rdfs:comment 'The gl account status of the gl account record' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyClearingFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Clearing Flag' ;
    rdfs:comment 'Indicates whether this account is used for intercompany transactions that require clearing and elimination in consolidated financial statements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemDisplayFlag rdf:type rdf:Property ;
    rdfs:label 'Line Item Display Flag' ;
    rdfs:comment 'Indicates whether individual line item details are stored and can be displayed for this account. Required for detailed transaction analysis and audit trails.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Open Item Management Flag' ;
    rdfs:comment 'Indicates whether this account uses open item management for tracking and clearing individual line items (e.g., AR, AP, bank clearing accounts).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plCategory rdf:type rdf:Property ;
    rdfs:label 'Pl Category' ;
    rdfs:comment 'For income statement accounts, indicates the P&L category: gross revenue, net revenue, COGS, gross margin, operating expense (SG&A, marketing, trade spend), EBITDA, EBIT, or net income. Not applicable for balance sheet accounts. [ENUM-REF-CANDIDATE: gross_revenue|net_revenue|cogs|gross_margin|operating_expense|ebitda|ebit|net_income|not_applicable — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plStatementFlag rdf:type rdf:Property ;
    rdfs:label 'Pl Statement Flag' ;
    rdfs:comment 'The pl statement flag of the gl account record' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'The organizational level at which budget planning and forecasting is performed for this account (e.g., company code, profit center, cost center).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Flag' ;
    rdfs:comment 'Indicates whether direct postings are allowed to this account. Some accounts (e.g., summary or control accounts) may only accept postings from automated processes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required Flag' ;
    rdfs:comment 'Indicates whether a profit center assignment is mandatory when posting to this account. Used for segment reporting and profitability analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Flag' ;
    rdfs:comment 'Indicates whether this is a reconciliation account (subledger control account) that summarizes detailed transactions from subsidiary ledgers such as AR, AP, or inventory.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retainedEarningsAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Retained Earnings Account Flag' ;
    rdfs:comment 'Indicates whether this is the retained earnings account where net income/loss is transferred during year-end closing.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'The default sort key used for organizing and displaying line items within this account (e.g., posting date, document number, amount).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Account Flag' ;
    rdfs:comment 'Indicates whether this account is subject to SOX internal control requirements and enhanced audit procedures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'The tax treatment category for this account (e.g., taxable revenue, non-taxable revenue, input tax, output tax, tax-exempt). Used for VAT, sales tax, and GST reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCodeAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Code Allowed Flag' ;
    rdfs:comment 'Indicates whether tax codes can be entered when posting to this account. Typically true for revenue and expense accounts, false for balance sheet accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerId rdf:type rdf:Property ;
    rdfs:label 'Ledger Id' ;
    rdfs:comment 'Unique identifier for the financial ledger record. Primary key for the ledger entity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:accountingPrinciple rdf:type rdf:Property ;
    rdfs:label 'Accounting Principle' ;
    rdfs:comment 'The accounting standard or principle applied in this ledger, such as International Financial Reporting Standards (IFRS), United States Generally Accepted Accounting Principles (US GAAP), local country-specific GAAP, tax accounting rules, or management accounting conventions.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailEnabled rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Enabled' ;
    rdfs:comment 'Boolean flag indicating whether comprehensive audit trail logging is enabled for all postings and changes to this ledger, supporting regulatory compliance and forensic analysis.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Base Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the base currency in which this ledger maintains balances (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationLedgerFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Ledger Flag' ;
    rdfs:comment 'Boolean flag indicating whether this ledger is used for group consolidation purposes, aggregating financial data from multiple legal entities for consolidated financial statements.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'Defines the currency perspective maintained in this ledger. Local currency represents the operating entity\'s functional currency, group currency is the consolidated reporting currency, hard currency is a stable reference currency (e.g., USD, EUR), and index currency supports inflation-adjusted reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'Code identifying the fiscal year calendar structure used by this ledger, defining the number of posting periods, special periods, and year-end closing rules. Common in SAP S/4HANA FI to support diverse fiscal calendars across global entities.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLeadingLedger rdf:type rdf:Property ;
    rdfs:label 'Is Leading Ledger' ;
    rdfs:comment 'Boolean flag indicating whether this is the leading ledger (primary book of record) for the company code. Only one ledger per company code can be designated as the leading ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadingLedgerFlag rdf:type rdf:Property ;
    rdfs:label 'Leading Ledger Flag' ;
    rdfs:comment 'The leading ledger flag of the ledger record' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerStatus rdf:type rdf:Property ;
    rdfs:label 'Ledger Status' ;
    rdfs:comment 'Current operational status of the ledger. Active ledgers accept postings, inactive ledgers are configured but not yet in use, closed ledgers are archived and no longer accept postings, and suspended ledgers are temporarily disabled.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerType rdf:type rdf:Property ;
    rdfs:label 'Ledger Type' ;
    rdfs:comment 'Classification of the ledger indicating its role in the financial reporting architecture. Leading ledger is the primary book of record, parallel ledgers support alternative accounting principles (e.g., local GAAP), and extension ledgers provide management reporting views.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingPeriodVariant rdf:type rdf:Property ;
    rdfs:label 'Posting Period Variant' ;
    rdfs:comment 'Code defining the posting period structure for this ledger, including the number of regular periods (typically 12 monthly periods) and special periods for year-end adjustments and closing entries.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years that financial data in this ledger must be retained to comply with statutory, tax, and regulatory record-keeping requirements. Common retention periods range from 7 to 10 years for financial records.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soxCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Compliant Flag' ;
    rdfs:comment 'Boolean flag indicating whether this ledger maintains controls and audit trails compliant with Sarbanes-Oxley Act Section 404 requirements for internal controls over financial reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsCostOfSalesAccounting rdf:type rdf:Property ;
    rdfs:label 'Supports Cost Of Sales Accounting' ;
    rdfs:comment 'Boolean flag indicating whether this ledger supports cost of sales (COGS) accounting method, which matches costs directly to revenue in the period of sale, as opposed to period-based cost accounting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsProfitCenterAccounting rdf:type rdf:Property ;
    rdfs:label 'Supports Profit Center Accounting' ;
    rdfs:comment 'Boolean flag indicating whether this ledger maintains profit center accounting data for internal management reporting and profitability analysis by organizational unit.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsSegmentReporting rdf:type rdf:Property ;
    rdfs:label 'Supports Segment Reporting' ;
    rdfs:comment 'Boolean flag indicating whether this ledger supports segment reporting as required by IFRS 8 Operating Segments. Segment reporting enables financial analysis by business unit, product line, or geographic region.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselinePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Payment Date' ;
    rdfs:comment 'The baseline date used for calculating payment terms and due dates for vendor invoices and customer receivables. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchInputSession rdf:type rdf:Property ;
    rdfs:label 'Batch Input Session' ;
    rdfs:comment 'Identifier of the batch input session if this journal entry was created through automated batch processing. Used for tracking mass data uploads and interface postings.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which this open item was cleared. Used for DSO and DIO calculation. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'Document number of the clearing document if this open item has been cleared (paid or offset). Used for accounts payable and receivable reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'Organizational unit in management accounting that represents a closed system for cost accounting. Used for internal management reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Unique alphanumeric identifier assigned to the accounting document within the company code and fiscal year. This is the externally visible business key for the journal entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification code indicating the nature and source of the journal entry. Examples: SA (General Ledger Document), AB (Accounting Document), KR (Vendor Invoice), DR (Customer Invoice), DZ (Customer Payment), KA (Vendor Payment), KG (Vendor Credit Memo), KN (Customer Credit Memo), KZ (Payment Request), RE (Invoice Receipt), RV (Invoice Reversal), WA (Goods Issue), WE (Goods Receipt), ZP (Payment Posting). [ENUM-REF-CANDIDATE: SA|AB|KR|DR|DZ|KA|KG|KN|KZ|RE|RV|WA|WE|ZP — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The date on which the journal entry was created or entered into the system. Used for audit trail and process monitoring. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'The entry status of the journal entry record' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'The entry type of the journal entry record' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The exchange rate used to convert document currency amounts to local currency. Expressed as local currency per one unit of document currency. Null if document currency equals local currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Code indicating the type of exchange rate used for currency translation. Examples: M (Average Rate), B (Bank Buying Rate), G (Bank Selling Rate), P (Posting Date Rate).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-form text field for additional information or explanation about the journal entry. Used for documentation and audit purposes.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry involves intercompany transactions between different company codes within the enterprise. True if intercompany, False otherwise.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:journalEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Number' ;
    rdfs:comment 'The journal entry number of the journal entry record' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryStatus rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Status' ;
    rdfs:comment 'The journal entry status of the journal entry record' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'Two-character code identifying the ledger or accounting principle under which this entry is recorded. Examples: 0L (Leading Ledger - IFRS), 2L (Local GAAP), 3L (Management Reporting). Supports parallel accounting for multiple reporting standards.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the company code local currency. All amounts are translated to this currency for statutory reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedBy rdf:type rdf:Property ;
    rdfs:label 'Posted By' ;
    rdfs:comment 'The posted by of the journal entry record' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle status of the journal entry. Values: draft (entry created but not posted), posted (entry successfully posted to GL), parked (entry saved for later posting), cancelled (entry voided before posting), reversed (entry reversed by a subsequent document).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number from the source document (invoice number, purchase order number, payment reference). Used for cross-referencing and reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is a reversal of a previous entry. True if this is a reversal document, False otherwise.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'Document number of the original journal entry that is being reversed by this entry. Populated only when reversal_indicator is True.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingDate rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Date' ;
    rdfs:comment 'The date relevant for tax reporting purposes. May differ from posting date based on tax jurisdiction rules. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalCredit rdf:type rdf:Property ;
    rdfs:label 'Total Credit' ;
    rdfs:comment 'The total credit of the journal entry record' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'The total credit amount of the journal entry record' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebit rdf:type rdf:Property ;
    rdfs:label 'Total Debit' ;
    rdfs:comment 'The total debit of the journal entry record' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Amount' ;
    rdfs:comment 'The total debit amount of the journal entry record' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'Company code of the intercompany trading partner if this is an intercompany transaction. Used for consolidation and elimination entries. Null if not an intercompany transaction.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Code' ;
    rdfs:comment 'SAP transaction code or Oracle program identifier used to create this journal entry. Examples: FB01 (Post Document), FB50 (G/L Account Posting), MIRO (Enter Invoice), F-28 (Post Incoming Payments). Used for audit trail and process analysis.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for granular cost allocation, COGS decomposition, and SOX-compliant audit trail tracing at the line level.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountCompanyCodeCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Company Code Currency' ;
    rdfs:comment 'Monetary amount converted to the local currency of the company code. Used for statutory reporting and local GAAP compliance.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Group Currency' ;
    rdfs:comment 'Monetary amount converted to the currency. Enables consolidated financial reporting across all subsidiaries.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Transaction Currency' ;
    rdfs:comment 'Monetary amount of this line item in the original transaction currency. Preserves the original posting amount before currency conversion.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'Free-text assignment field for additional reference information such as invoice number, purchase order, or payment reference. Enhances traceability.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Legal entity identifier representing the company or subsidiary for which this line is posted. Enables consolidated and statutory reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the company code local currency. Typically the statutory reporting currency of the legal entity.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Account Number' ;
    rdfs:comment 'Customer account number for revenue and receivables postings. Links financial transactions to customer master data.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentAmount rdf:type rdf:Property ;
    rdfs:label 'Document Amount' ;
    rdfs:comment 'The document amount of the journal entry line record' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the currency. Typically USD or EUR for consumer goods companies.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineStatus rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Status' ;
    rdfs:comment 'The journal entry line status of the journal entry line record' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Sequential line number within the journal entry header. Determines the ordering and position of this line in the document.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localAmount rdf:type rdf:Property ;
    rdfs:label 'Local Amount' ;
    rdfs:comment 'The local amount of the journal entry line record' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit posting key controlling account type, debit/credit indicator, and field status. Fundamental to SAP FI posting logic.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialGlIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Gl Indicator' ;
    rdfs:comment 'Special GL indicator for down payments, bills of exchange, guarantees, or other special transactions. Enables special ledger processing.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:textDescription rdf:type rdf:Property ;
    rdfs:label 'Text Description' ;
    rdfs:comment 'Descriptive text explaining the nature or purpose of this journal entry line. Provides human-readable context for audit and review.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'Identifier of the intercompany trading partner for intercompany transactions. Enables intercompany reconciliation and elimination entries.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the transaction amount. Identifies the currency in which the original transaction was denominated.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'Value date for cash management and bank reconciliation. Represents the effective date for interest calculation and cash position.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Account Number' ;
    rdfs:comment 'Vendor account number for procurement and payables postings. Links financial transactions to vendor master data.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'WBS element for project-related postings. Links costs and revenues to specific projects, phases, or deliverables in project accounting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Sales Invoice Id' ;
    rdfs:comment 'Foreign key linking to sales.invoice. Business justification: AR invoice reconciliation process matches each AR invoice to the originating sales invoice for cash application.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:amountReceived rdf:type rdf:Property ;
    rdfs:label 'Amount Received' ;
    rdfs:comment 'Total amount received from the customer against this invoice. May be less than total amount due to partial payments or deductions. Null for unpaid invoices.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Number' ;
    rdfs:comment 'The ar invoice number of the ar invoice record' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arInvoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Status' ;
    rdfs:comment 'The ar invoice status of the ar invoice record' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDate rdf:type rdf:Property ;
    rdfs:label 'Billing Date' ;
    rdfs:comment 'Date when the invoice was created and issued to the customer. Principal business event timestamp for the invoice lifecycle.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingDocumentType rdf:type rdf:Property ;
    rdfs:label 'Billing Document Type' ;
    rdfs:comment 'SAP billing document type code indicating the nature of the invoice (e.g., F2=standard invoice, G2=credit memo, L2=debit memo). Determines accounting treatment and revenue recognition.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingReference rdf:type rdf:Property ;
    rdfs:label 'Clearing Reference' ;
    rdfs:comment 'Reference number assigned when the invoice is cleared in the financial system. Links to the clearing document for audit trail. Null for open invoices.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionAmount rdf:type rdf:Property ;
    rdfs:label 'Deduction Amount' ;
    rdfs:comment 'Total amount of deductions taken by the customer against this invoice. Includes short-payments, chargebacks, and unauthorized deductions requiring resolution.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Deduction Reason Code' ;
    rdfs:comment 'Code indicating the reason for customer deductions (e.g., pricing dispute, damaged goods, short shipment, promotional allowance). Used for deduction root cause analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text description of the reason the customer is disputing the invoice. Used for dispute resolution and root cause analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsoAgingBucket rdf:type rdf:Property ;
    rdfs:label 'Dso Aging Bucket' ;
    rdfs:comment 'Aging category based on number of days the invoice has been outstanding past the due date. Used for DSO reporting, collections prioritization, and bad debt provisioning.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning level indicating the escalation stage of collection efforts (0=no dunning, 1=first reminder, 2=second reminder, etc.). Higher levels indicate more aggressive collection actions.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date when the invoice was posted to the general ledger. Used for financial period assignment and month-end close processes.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date when the most recent dunning notice was sent to the customer. Used to track collection activity frequency and determine next dunning action.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid balance on the invoice. Calculated as total amount minus amount received. Zero when invoice is fully paid or cleared.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date when revenue from this invoice is recognized in the financial statements under ASC 606/IFRS 15. May differ from billing date based on performance obligation fulfillment.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Number' ;
    rdfs:comment 'Reference to the originating sales order that generated this invoice. Links invoice to order fulfillment and enables order-to-cash traceability.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Amount written off as uncollectible bad debt. Null for invoices not written off. Impacts bad debt expense and allowance for doubtful accounts.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'Date when the invoice or portion thereof was written off as uncollectible. Null for invoices not written off.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffReasonCode rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason Code' ;
    rdfs:comment 'Code indicating the reason for write-off (e.g., customer bankruptcy, uncollectible, small balance write-off). Used for bad debt analysis and credit policy refinement.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ar Payment Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable payment record. Primary key.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'Amount of payment applied to the invoice after deductions and adjustments. Net amount reducing accounts receivable balance.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arPaymentNumber rdf:type rdf:Property ;
    rdfs:label 'Ar Payment Number' ;
    rdfs:comment 'The ar payment number of the ar payment record' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Ar Payment Status' ;
    rdfs:comment 'The ar payment status of the ar payment record' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Reference Number' ;
    rdfs:comment 'Bank transaction reference or confirmation number. Used for bank statement reconciliation and audit trail.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Check number when payment method is check. Used for check reconciliation and fraud prevention.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToPay rdf:type rdf:Property ;
    rdfs:label 'Days To Pay' ;
    rdfs:comment 'Number of days between invoice date and payment date. Key metric for Days Sales Outstanding (DSO) calculation and customer payment behavior analysis.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deductionNotes rdf:type rdf:Property ;
    rdfs:label 'Deduction Notes' ;
    rdfs:comment 'Free-text notes explaining the deduction or short payment. Captures customer explanation and internal investigation details.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransactionSetReference rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Set Reference' ;
    rdfs:comment 'EDI 820 transaction set control number when payment received via EDI. Used for EDI reconciliation and compliance.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'Payment amount converted to company local currency using the exchange rate. Used for consolidated financial reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lockboxBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Lockbox Batch Number' ;
    rdfs:comment 'Lockbox batch identifier when payment received through bank lockbox service. Used for lockbox reconciliation.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overpaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Overpayment Flag' ;
    rdfs:comment 'Indicates whether payment amount exceeds the invoice balance. True if customer paid more than owed.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partialPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Payment Flag' ;
    rdfs:comment 'Indicates whether this is a partial payment against the invoice. True if payment amount is less than invoice balance.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Total amount received in the payment transaction, in the payment currency. Gross payment before any deductions or adjustments.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'Channel through which payment was received. Distinguishes interface from payment instrument.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the payment amount. Identifies the currency in which payment was received.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'External payment document number or reference provided by the customer or payment processor. Used for reconciliation and audit trail.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessorCode rdf:type rdf:Property ;
    rdfs:label 'Payment Processor Code' ;
    rdfs:comment 'Transaction identifier from third-party payment processor (e.g., Stripe, PayPal, Adyen). Used for processor reconciliation.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'The payment reference of the ar payment record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAdviceNumber rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Number' ;
    rdfs:comment 'Reference number from customer remittance advice document. Links payment to customer payment notification (EDI 820 or paper remittance).' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Date when payment was reversed. Null if payment has not been reversed.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shortPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Short Payment Flag' ;
    rdfs:comment 'Indicates whether customer paid less than invoice amount without authorized deduction. Triggers deduction management workflow.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Unique identifier for the accounts payable invoice record. Primary key for the AP invoice entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:apInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Number' ;
    rdfs:comment 'The ap invoice number of the ap invoice record' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apInvoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Status' ;
    rdfs:comment 'The ap invoice status of the ap invoice record' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyPaymentDiscountTaken rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Taken' ;
    rdfs:comment 'The actual cash discount amount captured by paying the invoice within the early payment discount period. Key metric for working capital optimization.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceCategory rdf:type rdf:Property ;
    rdfs:label 'Invoice Category' ;
    rdfs:comment 'Classification of the invoice by spend category (e.g., raw materials, packaging, contract manufacturing, indirect goods, services). Used for spend analytics and procurement reporting. [ENUM-REF-CANDIDATE: raw_materials|packaging|contract_manufacturing|indirect_goods|services|freight|utilities|rent — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockCode rdf:type rdf:Property ;
    rdfs:label 'Payment Block Code' ;
    rdfs:comment 'Code indicating if the invoice is blocked for payment and the reason for the block (e.g., price variance, quantity variance, quality issue, pending approval).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorBankAccountCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Bank Account Code' ;
    rdfs:comment 'Reference to the vendor\'s bank account to which payment was or will be sent. Required for electronic payment processing.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Number' ;
    rdfs:comment 'The invoice number assigned by the vendor. This is the external reference number printed on the vendor\'s invoice document.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ap Payment Id' ;
    rdfs:comment 'Unique identifier for the accounts payable payment record. Primary key.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apPaymentNumber rdf:type rdf:Property ;
    rdfs:label 'Ap Payment Number' ;
    rdfs:comment 'The ap payment number of the ap payment record' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Ap Payment Status' ;
    rdfs:comment 'The ap payment status of the ap payment record' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'The date by which the payment must be made to qualify for the early payment discount. Used for working capital optimization decisions.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'The net payment amount after applying early payment discounts and any other adjustments. This is the actual amount transferred to the supplier.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Approval Status' ;
    rdfs:comment 'Approval status of the payment. Pending indicates awaiting approval, approved indicates authorized for processing, rejected indicates payment was denied. Supports SOX-compliant approval workflows.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Description of the reason the payment was blocked (e.g., pending invoice verification, supplier on hold, duplicate payment suspected). Used for exception management.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockReleasedBy rdf:type rdf:Property ;
    rdfs:label 'Payment Block Released By' ;
    rdfs:comment 'User ID or name of the person who released the payment block and authorized the payment to proceed. Supports SOX-compliant audit trails.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockReleasedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Block Released Date' ;
    rdfs:comment 'The date on which the payment block was released and the payment was authorized to proceed. Supports audit trails and payment cycle time analysis.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentNotes rdf:type rdf:Property ;
    rdfs:label 'Payment Notes' ;
    rdfs:comment 'Free-text notes or comments about the payment. Used to capture special instructions, exceptions, or additional context for audit and reconciliation purposes.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAdviceSentDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Sent Date' ;
    rdfs:comment 'The date on which the remittance advice was sent to the supplier. Used for supplier communication tracking.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remittanceAdviceSentFlag rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Sent Flag' ;
    rdfs:comment 'Boolean flag indicating whether a remittance advice was sent to the supplier to notify them of the payment details. True indicates sent, False indicates not sent.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryStandardManufacturingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Standard Manufacturing Facility Id' ;
    rdfs:comment 'Reference to the manufacturing plant or production facility where this standard cost applies. Standard costs are plant-specific in CPG manufacturing.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufacturingFacility .

ind:primaryStandardSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Standard Sku Id' ;
    rdfs:comment 'Reference to the material (finished good, semi-finished good, or raw material) for which this standard cost is defined. Links to the product master.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:bomUsage rdf:type rdf:Property ;
    rdfs:label 'Bom Usage' ;
    rdfs:comment 'The BOM usage type (e.g., production, costing, engineering) that was used as the basis for material cost calculation in this estimate.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Created By' ;
    rdfs:comment 'The user ID or name of the cost accountant or system user who created this cost estimate. Used for audit trail and accountability.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Created Timestamp' ;
    rdfs:comment 'The date and time when this standard cost record was first created in the source system. Critical for audit trail and SOX compliance.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costEstimateModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Modified By' ;
    rdfs:comment 'The user ID or name of the cost accountant or system user who last modified this cost estimate. Used for audit trail and change tracking.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Modified Timestamp' ;
    rdfs:comment 'The date and time when this standard cost record was last modified in the source system. Critical for audit trail and SOX compliance.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costEstimateNumber rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Number' ;
    rdfs:comment 'The unique business identifier for the cost estimate document in the source ERP system. Used for audit trail and traceability.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Amount' ;
    rdfs:comment 'The absolute difference between the current standard cost and the previous standard cost. Positive indicates cost increase, negative indicates cost decrease.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Percentage' ;
    rdfs:comment 'The percentage change in standard cost compared to the previous period. Calculated as (current - previous) / previous * 100.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVersion rdf:type rdf:Property ;
    rdfs:label 'Cost Version' ;
    rdfs:comment 'The cost version of the standard cost record' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingLotSize rdf:type rdf:Property ;
    rdfs:label 'Costing Lot Size' ;
    rdfs:comment 'The production lot size (quantity) used as the basis for calculating the standard cost. Fixed costs are spread over this quantity.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costingLotSizeUom rdf:type rdf:Property ;
    rdfs:label 'Costing Lot Size Uom' ;
    rdfs:comment 'The unit of measure for the costing lot size (e.g., EA, KG, L, CS). Must align with the materials base unit of measure.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingSheet rdf:type rdf:Property ;
    rdfs:label 'Costing Sheet' ;
    rdfs:comment 'The costing sheet identifier that defines the overhead calculation rules and surcharge rates applied in this cost estimate.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingType rdf:type rdf:Property ;
    rdfs:label 'Costing Type' ;
    rdfs:comment 'The type of cost estimate: standard (for inventory valuation), planned (for budgeting), actual (for variance analysis), or simulated (for what-if scenarios).' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costingVersion rdf:type rdf:Property ;
    rdfs:label 'Costing Version' ;
    rdfs:comment 'The costing version identifier that groups standard cost estimates for a specific planning or valuation scenario (e.g., current year, budget, simulation). Enables parallel costing scenarios.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directLaborCost rdf:type rdf:Property ;
    rdfs:label 'Direct Labor Cost' ;
    rdfs:comment 'The cost component for direct production labor (machine operators, line workers) allocated to one unit based on standard labor hours and rates.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedOverheadCost rdf:type rdf:Property ;
    rdfs:label 'Fixed Overhead Cost' ;
    rdfs:comment 'The cost component for fixed manufacturing overhead (plant management, utilities, rent) allocated to one unit based on the costing lot size.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightInCost rdf:type rdf:Property ;
    rdfs:label 'Freight In Cost' ;
    rdfs:comment 'The cost component for inbound freight and logistics to bring raw materials and packaging to the plant, allocated to one unit.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCost rdf:type rdf:Property ;
    rdfs:label 'Labor Cost' ;
    rdfs:comment 'The labor cost of the standard cost record' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineOverheadCost rdf:type rdf:Property ;
    rdfs:label 'Machine Overhead Cost' ;
    rdfs:comment 'The cost component for machine and equipment overhead (depreciation, maintenance, energy) allocated to one unit based on machine hours.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialCost rdf:type rdf:Property ;
    rdfs:label 'Material Cost' ;
    rdfs:comment 'The material cost of the standard cost record' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overheadCost rdf:type rdf:Property ;
    rdfs:label 'Overhead Cost' ;
    rdfs:comment 'The overhead cost of the standard cost record' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Cost' ;
    rdfs:comment 'The cost component for packaging materials (primary, secondary, tertiary) used for one unit. Critical for CPG cost structure analysis.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousStandardCost rdf:type rdf:Property ;
    rdfs:label 'Previous Standard Cost' ;
    rdfs:comment 'The total standard cost from the prior costing period or version. Used for variance analysis and cost trend reporting.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rawMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Raw Material Cost' ;
    rdfs:comment 'The cost component for raw materials consumed in the production of one unit. Key input for COGS and margin analysis.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingUsage rdf:type rdf:Property ;
    rdfs:label 'Routing Usage' ;
    rdfs:comment 'The routing usage type (e.g., production, costing) that was used as the basis for labor and machine cost calculation in this estimate.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostStatus rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Status' ;
    rdfs:comment 'The standard cost status of the standard cost record' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStandardCost rdf:type rdf:Property ;
    rdfs:label 'Total Standard Cost' ;
    rdfs:comment 'The total standard cost per unit of the material, summing all cost components (raw material, packaging, labor, overhead, freight). This is the authoritative cost for inventory valuation and COGS.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationVariant rdf:type rdf:Property ;
    rdfs:label 'Valuation Variant' ;
    rdfs:comment 'The valuation variant that defines the costing methodology and cost component structure used for this estimate (e.g., full costing, marginal costing).' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variableOverheadCost rdf:type rdf:Property ;
    rdfs:label 'Variable Overhead Cost' ;
    rdfs:comment 'The cost component for variable manufacturing overhead (indirect materials, supplies, variable utilities) allocated to one unit.' ;
    rdfs:domain ind:StandardCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentCompanyCodeId rdf:type rdf:Property ;
    rdfs:label 'Parent Company Code Id' ;
    rdfs:comment 'Self-referencing FK on company_code (parent_company_code_id)' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:companyCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Company Code Status' ;
    rdfs:comment 'The company code status of the company code record' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'The company name of the company code record' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Internal cost-center identifier associated with the entity for budgeting.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveTo rdf:type rdf:Property ;
    rdfs:label 'Effective To' ;
    rdfs:comment 'Date when the legal entity ceased to be active (null if still active).' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industryCode rdf:type rdf:Property ;
    rdfs:label 'Industry Code' ;
    rdfs:comment 'Standard industry classification (e.g., NAICS) for the entity.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConsolidatedEntity rdf:type rdf:Property ;
    rdfs:label 'Is Consolidated Entity' ;
    rdfs:comment 'True if the entity is included in group financial consolidation.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublicCompany rdf:type rdf:Property ;
    rdfs:label 'Is Public Company' ;
    rdfs:comment 'True if the entity is publicly listed; otherwise false.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityType rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Type' ;
    rdfs:comment 'The legal entity type of the company code record' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrency rdf:type rdf:Property ;
    rdfs:label 'Local Currency' ;
    rdfs:comment 'The local currency of the company code record' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactMethod rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Method' ;
    rdfs:comment 'Preferred channel for official communications with the entity.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordAuditCreated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Created' ;
    rdfs:comment 'Timestamp when the company code record was first created in the system.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordAuditUpdated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Updated' ;
    rdfs:comment 'Timestamp of the most recent modification to the company code record.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:value rdf:type rdf:Property ;
    rdfs:label 'Value' ;
    rdfs:comment 'The value of the company code record' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiTrackingCapable rdf:type rdf:Property ;
    rdfs:label 'Api Tracking Capable' ;
    rdfs:comment 'Indicates whether the carrier provides a real-time shipment tracking API for track-and-trace integration. Enables automated shipment status updates in the TMS without manual EDI 214 processing. Used in carrier technology capability assessment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carbonIntensityGPerTkm rdf:type rdf:Property ;
    rdfs:label 'Carbon Intensity G Per Tkm' ;
    rdfs:comment 'The carbon intensity g per tkm of the carrier record' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Status' ;
    rdfs:comment 'Current lifecycle status of the carrier in the Consumer Goods approved carrier program. Active carriers are eligible for shipment tendering. Suspended carriers are temporarily blocked pending compliance review. Blacklisted carriers are permanently disqualified. Drives carrier selection eligibility in TMS routing.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Primary transportation mode classification of the carrier. Drives rate card selection, shipment planning rules, and EDI transaction sets. TL (Truckload), LTL (Less-Than-Truckload), parcel, rail, ocean, air, intermodal, and courier are the standard classifications in consumer goods logistics. [ENUM-REF-CANDIDATE: truckload|less_than_truckload|parcel|rail|ocean|air|intermodal|courier — promote to reference product]' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2EmissionRating rdf:type rdf:Property ;
    rdfs:label 'Co2 Emission Rating' ;
    rdfs:comment 'The co2 emission rating of the carrier record' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainCapable rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Capable' ;
    rdfs:comment 'Indicates whether the carrier has certified temperature-controlled transportation capability (refrigerated or frozen) for cold-chain compliant shipments of health, hygiene, and personal care products requiring temperature management. Critical for product safety and regulatory compliance.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'The contact phone of the carrier record' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfRegistration rdf:type rdf:Property ;
    rdfs:label 'Country Of Registration' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the carrier is legally registered and incorporated. Used for cross-border compliance checks, customs documentation, and carrier eligibility for specific trade lanes.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Number' ;
    rdfs:comment 'Unique identifier assigned by the U.S. Federal Motor Carrier Safety Administration (FMCSA) to commercial motor carriers operating in interstate commerce. Required for regulatory compliance verification and safety rating lookup. Mandatory for US-based trucking carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCode rdf:type rdf:Property ;
    rdfs:label 'Edi Code' ;
    rdfs:comment 'Carrier\'s EDI interchange identifier used in the ISA segment of X12 EDI transactions. Combined with the EDI qualifier, this uniquely identifies the carrier as an EDI trading partner. Required for automated tender and status message routing.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediQualifier rdf:type rdf:Property ;
    rdfs:label 'Edi Qualifier' ;
    rdfs:comment 'Two-digit qualifier code identifying the type of EDI sender/receiver identifier used in ISA segment of X12 EDI transactions (e.g., 02 = DUNS, 08 = UCC/EAN, ZZ = Mutually Defined). Required for EDI trading partner setup and message routing.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmcsaRatingDate rdf:type rdf:Property ;
    rdfs:label 'Fmcsa Rating Date' ;
    rdfs:comment 'Date on which the current FMCSA safety rating was issued or last updated. Used to assess rating currency and trigger re-evaluation workflows when ratings are older than the compliance review threshold.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fmcsaSafetyRating rdf:type rdf:Property ;
    rdfs:label 'Fmcsa Safety Rating' ;
    rdfs:comment 'Official safety fitness rating assigned by the FMCSA to motor carriers based on compliance reviews and safety audits. Satisfactory rating is required for carrier approval in Consumer Goods\' carrier program. Conditional or Unsatisfactory ratings trigger carrier review or suspension. Mandatory compliance field for US trucking carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Description of the carrier\'s operational geographic coverage scope, including regions, countries, or trade lanes served. Used in TMS routing logic to filter eligible carriers by origin-destination pair. Examples: \'Continental US\', \'US-Canada cross-border\', \'Trans-Pacific\', \'EU domestic\'.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Hazmat Cert Expiry Date' ;
    rdfs:comment 'Expiry date of the carrier\'s hazardous materials transportation certification. Triggers compliance alerts and blocks HAZMAT shipment tendering to the carrier if certification has lapsed.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified' ;
    rdfs:comment 'Indicates whether the carrier holds valid certification to transport hazardous materials (HAZMAT) as defined by DOT 49 CFR. Required for shipments of aerosols, flammable products, and chemical-based consumer goods. Validated against DOT HAZMAT registration database.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Full street address of the carrier\'s principal place of business or corporate headquarters. Used for legal correspondence, contract execution, and regulatory filings. Includes street, city, state/province, postal code, and country.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCode rdf:type rdf:Property ;
    rdfs:label 'Iata Code' ;
    rdfs:comment '2-3 character alphanumeric code assigned by IATA to identify air freight carriers. Used for air waybill generation, air freight booking, and international air cargo tracking. Applicable only to air freight carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCargoAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Cargo Amount' ;
    rdfs:comment 'Maximum coverage amount (in USD) of the carrier\'s cargo insurance policy covering loss or damage to goods in transit. Consumer Goods mandates minimum cargo insurance thresholds based on shipment value profiles. Critical for high-value CPG product shipments.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Reference number of the carrier\'s current certificate of insurance (COI) on file with Consumer Goods. Used for insurance verification, claims processing, and audit trail of carrier compliance documentation.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'Date on which the carrier\'s insurance certificate expires. Triggers automated renewal reminder workflows and carrier status suspension if insurance lapses. Critical compliance field for carrier program management.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Liability Amount' ;
    rdfs:comment 'Maximum coverage amount (in USD) of the carrier\'s general liability insurance policy. Consumer Goods requires minimum liability coverage thresholds as a condition of carrier approval. Validated during carrier onboarding and annual renewal.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Insurance Provider' ;
    rdfs:comment 'The insurance provider of the carrier record' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isColdChainCapable rdf:type rdf:Property ;
    rdfs:label 'Is Cold Chain Capable' ;
    rdfs:comment 'The is cold chain capable of the carrier record' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Certified' ;
    rdfs:comment 'The is hazmat certified of the carrier record' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreferredCarrier rdf:type rdf:Property ;
    rdfs:label 'Is Preferred Carrier' ;
    rdfs:comment 'The is preferred carrier of the carrier record' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'Date of the most recent compliance review conducted for this carrier, covering safety ratings, insurance certificates, HAZMAT certifications, and contractual obligations. Used to schedule periodic re-evaluations and flag overdue reviews.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Coverage Amount' ;
    rdfs:comment 'The liability coverage amount of the carrier record' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPayloadKg rdf:type rdf:Property ;
    rdfs:label 'Max Payload Kg' ;
    rdfs:comment 'Maximum weight capacity in kilograms that the carrier\'s standard equipment can transport per shipment. Used in load planning, shipment consolidation, and carrier eligibility checks to prevent overweight violations.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mcNumber rdf:type rdf:Property ;
    rdfs:label 'Mc Number' ;
    rdfs:comment 'Operating authority number issued by the FMCSA to for-hire motor carriers transporting regulated commodities in interstate commerce. Distinct from DOT number — MC number grants operating authority while DOT number is for safety registration. Used in carrier compliance validation.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modeOfTransport rdf:type rdf:Property ;
    rdfs:label 'Mode Of Transport' ;
    rdfs:comment 'The mode of transport of the carrier record' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeDeliveryPct rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Pct' ;
    rdfs:comment 'The on time delivery pct of the carrier record' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredCarrier rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier' ;
    rdfs:comment 'Indicates whether the carrier has been designated as a preferred carrier in Consumer Goods\' carrier program, typically based on negotiated rates, service performance, and strategic partnership status. Preferred carriers receive priority in TMS automated tendering sequences.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionCoverage rdf:type rdf:Property ;
    rdfs:label 'Region Coverage' ;
    rdfs:comment 'The region coverage of the carrier record' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Unique 2-4 character alpha code assigned by the National Motor Freight Traffic Association (NMFTA) to identify transportation carriers in North America. Used in EDI transactions (204, 214, 990) and freight billing. Mandatory for motor carriers operating in the US.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaCountries rdf:type rdf:Property ;
    rdfs:label 'Service Area Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing the countries in which the carrier provides transportation services. Used for international shipment routing, customs compliance validation, and carrier eligibility filtering in cross-border logistics.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelOffered rdf:type rdf:Property ;
    rdfs:label 'Service Level Offered' ;
    rdfs:comment 'The service level offered of the carrier record' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceMode rdf:type rdf:Property ;
    rdfs:label 'Service Mode' ;
    rdfs:comment 'Service level classification offered by the carrier indicating transit speed and handling commitment. Drives SLA assignment, freight cost tier selection, and shipment routing logic in the TMS. Used in OTIF (On Time In Full) performance measurement.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max C' ;
    rdfs:comment 'Maximum temperature (in degrees Celsius) that the carrier\'s cold-chain equipment can maintain during transit. Combined with the minimum temperature range, defines the carrier\'s certified temperature corridor for cold-chain shipments.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min C' ;
    rdfs:comment 'Minimum temperature (in degrees Celsius) that the carrier\'s cold-chain equipment can maintain during transit. Used to validate carrier eligibility for temperature-sensitive product shipments and cold-chain compliance verification.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingUrlTemplate rdf:type rdf:Property ;
    rdfs:label 'Tracking Url Template' ;
    rdfs:comment 'URL template for the carrier\'s web-based shipment tracking portal, with a placeholder (e.g., {tracking_number}) for dynamic substitution. Used to generate direct tracking links in shipment notifications, customer portals, and internal TMS dashboards.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Doing-business-as (DBA) or trade name used by the carrier in commercial operations, which may differ from the legal registered name. Used in operational communications, carrier portals, and reporting where the trade name is more recognizable.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessorialScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Accessorial Schedule Code' ;
    rdfs:comment 'Reference code identifying the accessorial charge schedule applicable to this contract. Accessorial charges include liftgate, residential delivery, inside delivery, detention, layover, hazmat handling, and temperature-controlled surcharges. Links to the accessorial rate table for freight audit and cost estimation.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessorialTerms rdf:type rdf:Property ;
    rdfs:label 'Accessorial Terms' ;
    rdfs:comment 'The accessorial terms of the carrier contract record' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewal rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal' ;
    rdfs:comment 'Indicates whether this carrier contract automatically renews at expiry unless terminated with advance notice. When true, the renewal_notice_days field defines the required notice period. Supports contract lifecycle management and procurement planning.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRate rdf:type rdf:Property ;
    rdfs:label 'Base Rate' ;
    rdfs:comment 'The primary negotiated freight rate under this contract before surcharges and accessorial charges are applied. The unit of measure for this rate is defined by the rate_type field (e.g., per mile, per CWT, per pallet, flat). Used as the foundation for freight cost estimation and freight audit rate lookup.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierContractStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Contract Status' ;
    rdfs:comment 'The carrier contract status of the carrier contract record' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainRequired rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required' ;
    rdfs:comment 'Indicates whether this contract covers temperature-controlled (cold chain) shipments requiring refrigerated or frozen transport. When true, cold chain compliance monitoring, temperature logging, and FEFO inventory management protocols apply. Relevant for health, hygiene, and perishable consumer goods.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the destination country covered by this contract. Used for cross-border freight classification, customs compliance, and international rate applicability.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRegion rdf:type rdf:Property ;
    rdfs:label 'Destination Region' ;
    rdfs:comment 'Geographic destination zone or region covered by this contract for lane-level rate applicability. May represent a state, ZIP zone, city cluster, or carrier-defined zone code. Used in freight cost estimation and tender evaluation.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detentionFreeTimeHours rdf:type rdf:Property ;
    rdfs:label 'Detention Free Time Hours' ;
    rdfs:comment 'Number of hours the carrier\'s equipment (trailer/container) may remain at a Consumer Goods facility for loading or unloading without incurring detention charges. Exceeding this threshold triggers accessorial detention fees per the contract rate schedule.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelSurchargeBasis rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Basis' ;
    rdfs:comment 'Defines how the fuel surcharge is calculated and applied: as a percentage of the base freight rate, a flat amount per mile, a flat amount per shipment, or dynamically linked to the DOE diesel fuel price index. Determines the fuel surcharge computation method in freight audit.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargePct rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Pct' ;
    rdfs:comment 'The fuel surcharge pct of the carrier contract record' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Rate' ;
    rdfs:comment 'Contracted fuel surcharge rate expressed as a percentage of the base rate or as a fixed amount per unit, applied on top of the base freight rate to account for fuel cost variability. Linked to a fuel index table or DOE diesel price index. Critical for freight cost estimation and audit.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'Maximum cargo insurance coverage amount provided by the carrier under this contract, expressed in the contract currency. Defines the financial liability limit for cargo loss or damage claims. Used in risk management and claims processing.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Amount' ;
    rdfs:comment 'The liability limit amount of the carrier contract record' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityLimitPerKg rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Per Kg' ;
    rdfs:comment 'Contractual carrier liability limit per kilogram of cargo for loss or damage claims, expressed in the contract currency. Used in freight claims management to calculate maximum recoverable amounts for damaged or lost shipments.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minWeightKg rdf:type rdf:Property ;
    rdfs:label 'Min Weight Kg' ;
    rdfs:comment 'Minimum shipment weight in kilograms at which this contract rate applies. Defines the lower bound of the weight break tier for rate applicability. Used in freight cost estimation and audit to validate correct rate application.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumVolumeCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Commitment' ;
    rdfs:comment 'The minimum volume commitment of the carrier contract record' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the origin country covered by this contract. Used for cross-border freight classification, customs compliance, and international rate applicability.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originRegion rdf:type rdf:Property ;
    rdfs:label 'Origin Region' ;
    rdfs:comment 'Geographic origin zone or region covered by this contract for lane-level rate applicability. May represent a state, ZIP zone, city cluster, or carrier-defined zone code. Used in freight cost estimation and tender evaluation.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Otif Penalty Rate' ;
    rdfs:comment 'Contractual penalty rate applied to the carrier for OTIF (On Time In Full) failures, expressed as a percentage of the invoice value or a fixed amount per incident. OTIF is a key KPI in consumer goods supply chain performance management. Supports carrier performance management and deduction processing.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Otif Threshold Pct' ;
    rdfs:comment 'Minimum OTIF performance percentage the carrier must achieve to avoid penalty charges under this contract. Expressed as a percentage (e.g., 98.5 means 98.5% OTIF compliance required). Below this threshold, the otif_penalty_rate is triggered.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Pickup Lead Time Hours' ;
    rdfs:comment 'Contracted lead time in hours from tender acceptance to carrier pickup at the origin facility. Used in shipment planning, load scheduling, and Blue Yonder WMS labor planning for dock door assignment.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateBasis rdf:type rdf:Property ;
    rdfs:label 'Rate Basis' ;
    rdfs:comment 'The rate basis of the carrier contract record' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Defines the unit basis on which the base_rate is charged. Per-mile rates apply to distance-based pricing; per-CWT (hundredweight) applies to weight-based LTL pricing; per-pallet applies to unit-load pricing; flat rate is a fixed charge per shipment regardless of weight or distance; per-kg and per-lb are weight-based variants used in air and parcel freight. [ENUM-REF-CANDIDATE: per_mile|per_cwt|per_pallet|per_shipment|flat|per_kg|per_lb — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The renewal date of the carrier contract record' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'The service level agreement of the carrier contract record' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedBy rdf:type rdf:Property ;
    rdfs:label 'Signed By' ;
    rdfs:comment 'The signed by of the carrier contract record' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'The signed date of the carrier contract record' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum temperature in degrees Celsius that must be maintained throughout transit for cold chain shipments under this contract. Applicable only when cold_chain_required is true. Exceedance triggers non-conformance reporting and potential product rejection.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum temperature in degrees Celsius that must be maintained throughout transit for cold chain shipments under this contract. Applicable only when cold_chain_required is true. Used for cold chain compliance monitoring and carrier performance audits.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackTraceMethod rdf:type rdf:Property ;
    rdfs:label 'Track Trace Method' ;
    rdfs:comment 'Method by which shipment tracking and status updates are provided by the carrier under this contract. EDI 214 is the standard electronic shipment status transaction; API enables real-time integration; portal requires manual check-in; email is manual notification. Drives track-and-trace capability in logistics operations.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentUnits rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Units' ;
    rdfs:comment 'Contracted minimum volume commitment by Consumer Goods to the carrier over the contract term, expressed in the unit defined by volume_commitment_uom (e.g., shipments, pallets, CWT, revenue miles). Failure to meet this commitment may trigger shortfall penalties or rate renegotiation.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCommitmentUom rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Uom' ;
    rdfs:comment 'Unit of measure for the volume_commitment_units field. Defines whether the volume commitment is expressed in number of shipments, pallets, hundredweight (CWT), revenue miles, kilograms, or truckloads.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneOperatingCarrierId rdf:type rdf:Property ;
    rdfs:label 'Lane Operating Carrier Id' ;
    rdfs:comment 'The lane operating carrier id of the lane record' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:primaryLaneBackupCarrierId rdf:type rdf:Property ;
    rdfs:label 'Primary Lane Backup Carrier Id' ;
    rdfs:comment 'Reference to the secondary/backup carrier for this lane, used when the preferred carrier declines the tender or is unavailable. Represents the second position in the routing guide.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:primaryLaneSupplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lane Supply Network Node Id' ;
    rdfs:comment 'Reference to the origin facility, distribution center, plant, or supplier location from which freight departs on this lane. Links to the location master in the logistics domain.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:annualVolumeLoads rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Loads' ;
    rdfs:comment 'Historical or planned annual shipment volume on this lane expressed in number of loads (truckloads, containers, or equivalent units). Used for carrier contract negotiations, network design, and freight spend forecasting.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualVolumeWeightKg rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Weight Kg' ;
    rdfs:comment 'Historical or planned annual freight weight moved on this lane in kilograms. Used for carrier contract negotiations, modal optimization, and carbon emissions intensity calculations per ISO 14001.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgTransitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Avg Transit Time Hours' ;
    rdfs:comment 'The avg transit time hours of the lane record' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkRateFlat rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Flat' ;
    rdfs:comment 'Lane-level flat cost benchmark (all-in rate per load/shipment) in the operating currency. Used for truckload lanes where per-km pricing is not applicable. Supports freight audit and carrier contract negotiation.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkRatePerKm rdf:type rdf:Property ;
    rdfs:label 'Benchmark Rate Per Km' ;
    rdfs:comment 'Lane-level cost benchmark expressed as rate per kilometer in the operating currency. Used for freight audit, carrier performance benchmarking, and transportation cost variance analysis. Confidential as it reflects negotiated contract intelligence.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonEmissionFactor rdf:type rdf:Property ;
    rdfs:label 'Carbon Emission Factor' ;
    rdfs:comment 'Lane-level carbon emission intensity factor expressed as kilograms of CO2 equivalent per kilometer, based on transport mode and equipment type. Used for Scope 3 emissions reporting, sustainability KPIs, and ESG disclosures per ISO 14001 and EPA Greenhouse Gas Reporting Program.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2PerShipmentKg rdf:type rdf:Property ;
    rdfs:label 'Co2 Per Shipment Kg' ;
    rdfs:comment 'The co2 per shipment kg of the lane record' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossBorder rdf:type rdf:Property ;
    rdfs:label 'Cross Border' ;
    rdfs:comment 'Indicates whether this lane crosses an international border, requiring customs documentation, import/export compliance, and potentially additional transit time for border clearance. Drives customs broker assignment and trade compliance workflows.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsTradeZone rdf:type rdf:Property ;
    rdfs:label 'Customs Trade Zone' ;
    rdfs:comment 'Trade zone or customs agreement applicable to this cross-border lane (e.g., USMCA, EU Single Market, ASEAN). Determines duty rates, documentation requirements, and customs clearance procedures. Populated only for cross-border lanes.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCity rdf:type rdf:Property ;
    rdfs:label 'Destination City' ;
    rdfs:comment 'City name of the lane destination point. Used for geographic lane analysis, carrier rate zone determination, and network design reporting.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Location' ;
    rdfs:comment 'The destination location of the lane record' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'Business-facing code for the destination location (e.g., customer DC code, store code, or GS1 Global Location Number). Used in EDI transactions, carrier communications, and freight audit matching.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStateProvince rdf:type rdf:Property ;
    rdfs:label 'Destination State Province' ;
    rdfs:comment 'ISO 3166-2 state or province code for the lane destination. Used in carrier rate zone mapping and freight cost benchmarking.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdEligible rdf:type rdf:Property ;
    rdfs:label 'Dsd Eligible' ;
    rdfs:comment 'Indicates whether this lane supports Direct Store Delivery (DSD), where product is delivered directly from the manufacturer or distributor to the retail store, bypassing the retailer\'s distribution center. Relevant for high-velocity CPG categories.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatRequired rdf:type rdf:Property ;
    rdfs:label 'Hazmat Required' ;
    rdfs:comment 'Indicates whether this lane requires carriers certified for hazardous materials (HAZMAT) transport. Applicable for lanes carrying chemical, aerosol, or regulated consumer goods. Triggers carrier qualification checks and regulatory documentation requirements per DOT/EPA/OSHA.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneStatus rdf:type rdf:Property ;
    rdfs:label 'Lane Status' ;
    rdfs:comment 'Current lifecycle status of the transportation lane. Active lanes are available for freight tendering and route optimization. Inactive or suspended lanes are excluded from planning runs.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkRegion rdf:type rdf:Property ;
    rdfs:label 'Network Region' ;
    rdfs:comment 'Geographic or operational network region to which this lane belongs (e.g., Northeast, Southeast, Midwest, West Coast, EMEA, APAC). Used for network design segmentation, regional freight cost analysis, and carrier portfolio management.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCity rdf:type rdf:Property ;
    rdfs:label 'Origin City' ;
    rdfs:comment 'City name of the lane origin point. Used for geographic lane analysis, carrier rate zone determination, and network design reporting.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocation rdf:type rdf:Property ;
    rdfs:label 'Origin Location' ;
    rdfs:comment 'The origin location of the lane record' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Location Code' ;
    rdfs:comment 'Business-facing code for the origin location (e.g., plant code, DC code, or GS1 Global Location Number). Used in EDI transactions, carrier communications, and freight audit matching.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originStateProvince rdf:type rdf:Property ;
    rdfs:label 'Origin State Province' ;
    rdfs:comment 'ISO 3166-2 state or province code for the lane origin. Used in carrier rate zone mapping, regulatory compliance (e.g., CARB emissions zones), and freight cost benchmarking.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredMode rdf:type rdf:Property ;
    rdfs:label 'Preferred Mode' ;
    rdfs:comment 'The preferred mode of the lane record' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingGuideRank rdf:type rdf:Property ;
    rdfs:label 'Routing Guide Rank' ;
    rdfs:comment 'Numeric rank of the preferred carrier in the lane routing guide sequence. Rank 1 is the primary carrier; higher ranks are fallback options. Used in automated freight tendering workflows to determine tender sequence.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardTransitDays rdf:type rdf:Property ;
    rdfs:label 'Standard Transit Days' ;
    rdfs:comment 'Contractually agreed or operationally standard number of calendar days for freight to travel from origin to destination on this lane. Used as the baseline for OTIF (On Time In Full) measurement, delivery promise, and ATP/CTP calculations in SAP IBP.' ;
    rdfs:domain ind:Lane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationFacilityDistributionCenterDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Distribution Center Distribution Facility Id' ;
    rdfs:comment 'Reference to the facility (distribution center, retail store, customer location, or 3PL node) to which the shipment is consigned.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:originDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Origin Distribution Facility Id' ;
    rdfs:comment 'The origin distribution facility id of the logistics shipment record' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:originTradeAccountId rdf:type rdf:Property ;
    rdfs:label 'Origin Trade Account Id' ;
    rdfs:comment 'Foreign key linking to sales.trade_account. Business justification: Shipment origin account is needed for cost attribution, SLA reporting, and regulatory shipment origin documentation.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAccount .

ind:primaryLogisticsDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Logistics Distribution Facility Id' ;
    rdfs:comment 'Reference to the facility (plant, distribution center, warehouse, or supplier location) from which the shipment departs.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Precise date and time the shipment was delivered and signed for at the destination, as captured by the carrier\'s POD (Proof of Delivery) system or electronic signature device. Enables time-window compliance measurement.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualPickupDate rdf:type rdf:Property ;
    rdfs:label 'Actual Pickup Date' ;
    rdfs:comment 'The actual pickup date of the logistics shipment record' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bolNumber rdf:type rdf:Property ;
    rdfs:label 'Bol Number' ;
    rdfs:comment 'Bill of Lading number issued by the carrier as the legal contract of carriage and receipt of goods. Required for freight audit, customs clearance, and proof of delivery. Key document in SAP S/4HANA SD and Blue Yonder WMS.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAddress rdf:type rdf:Property ;
    rdfs:label 'Destination Address' ;
    rdfs:comment 'The destination address of the logistics shipment record' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates the direction of the shipment relative to the enterprise network: inbound (from supplier), outbound (to customer/retailer), interplant (between internal facilities), or return (reverse logistics).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCostAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Amount' ;
    rdfs:comment 'Total contracted or invoiced freight cost for this shipment in the transaction currency. Used for freight cost allocation to COGS (Cost of Goods Sold), carrier spend analytics, and freight audit reconciliation.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the freight cost amount (e.g., USD, EUR, GBP). Required for multi-currency freight spend reporting and financial consolidation.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Freight payment terms indicating who bears the freight cost: prepaid (shipper pays), collect (consignee pays), or third_party (a designated third party pays). Drives freight invoice routing and cost allocation.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Amount' ;
    rdfs:comment 'Carrier-applied fuel surcharge amount for this shipment, separate from the base freight rate. Used for freight audit, cost variance analysis, and carrier contract compliance.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms) code defining the transfer of risk, cost responsibility, and delivery obligations between shipper and consignee. Governs freight cost allocation and insurance requirements. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — promote to reference product]' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isColdChain rdf:type rdf:Property ;
    rdfs:label 'Is Cold Chain' ;
    rdfs:comment 'The is cold chain of the logistics shipment record' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmat rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat' ;
    rdfs:comment 'The is hazmat of the logistics shipment record' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logisticsShipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Logistics Shipment Status' ;
    rdfs:comment 'The logistics shipment status of the logistics shipment record' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originAddress rdf:type rdf:Property ;
    rdfs:label 'Origin Address' ;
    rdfs:comment 'The origin address of the logistics shipment record' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifInFull rdf:type rdf:Property ;
    rdfs:label 'Otif In Full' ;
    rdfs:comment 'Indicates whether the shipment was delivered with the complete ordered quantity, contributing to the OTIF (On Time In Full) KPI. Supports retailer compliance scorecarding and deduction management.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifOnTime rdf:type rdf:Property ;
    rdfs:label 'Otif On Time' ;
    rdfs:comment 'Indicates whether the shipment was delivered on or before the planned delivery date, contributing to the OTIF (On Time In Full) KPI. Derived from planned vs. actual delivery date comparison and stored for reporting efficiency.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'The date on which the shipment is expected to arrive at the destination facility, based on contracted transit time and lane performance.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Planned Pickup Date' ;
    rdfs:comment 'The planned pickup date of the logistics shipment record' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:podReceived rdf:type rdf:Property ;
    rdfs:label 'Pod Received' ;
    rdfs:comment 'Indicates whether a signed Proof of Delivery (POD) document has been received and validated for this shipment. Required for freight invoice payment release and dispute resolution.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:podTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pod Timestamp' ;
    rdfs:comment 'Date and time the Proof of Delivery (POD) was electronically captured or received, as recorded by the carrier\'s mobile device or ePOD system. Used for freight audit and dispute resolution timelines.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Carrier-assigned Progressive (PRO) number used to track LTL (Less-Than-Truckload) shipments through the carrier\'s network. Essential for freight audit and claims management.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'The shipment type of the logistics shipment record' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRange rdf:type rdf:Property ;
    rdfs:label 'Temperature Range' ;
    rdfs:comment 'The temperature range of the logistics shipment record' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threePlReference rdf:type rdf:Property ;
    rdfs:label 'Three Pl Reference' ;
    rdfs:comment 'Reference number assigned by the 3PL (Third-Party Logistics) provider for this shipment in their WMS or TMS. Enables cross-system reconciliation and 3PL billing validation.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCases rdf:type rdf:Property ;
    rdfs:label 'Total Cases' ;
    rdfs:comment 'Total number of cases (cartons) included in the shipment. Used for pick/pack verification, receiving reconciliation, and OTIF (On Time In Full) quantity compliance.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFreightCost rdf:type rdf:Property ;
    rdfs:label 'Total Freight Cost' ;
    rdfs:comment 'The total freight cost of the logistics shipment record' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPallets rdf:type rdf:Property ;
    rdfs:label 'Total Pallets' ;
    rdfs:comment 'Total number of pallets included in the shipment. Used for dock scheduling, trailer loading planning, and carrier billing for LTL shipments.' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPieces rdf:type rdf:Property ;
    rdfs:label 'Total Pieces' ;
    rdfs:comment 'The total pieces of the logistics shipment record' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cbm' ;
    rdfs:comment 'The total volume cbm of the logistics shipment record' ;
    rdfs:domain ind:LogisticsShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'Total cubic volume of the shipment in cubic meters. Used for dimensional weight calculation, trailer utilization, and freight cost optimization.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentLegId rdf:type rdf:Property ;
    rdfs:label 'Shipment Leg Id' ;
    rdfs:comment 'Unique system-generated identifier for each individual shipment leg record within the logistics network. Serves as the primary key for the shipment_leg entity.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryShipmentNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Shipment Network Node Id' ;
    rdfs:comment 'Reference to the logistics node (warehouse, plant, port, cross-dock, or distribution center) from which this leg departs. Used for route optimization and network analysis.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:accessorialChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charges Amount' ;
    rdfs:comment 'Additional carrier charges beyond the base freight rate for this leg, including fuel surcharges, detention, liftgate, residential delivery, or hazmat fees. Used in freight audit and total landed cost analysis.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDeparture rdf:type rdf:Property ;
    rdfs:label 'Actual Departure' ;
    rdfs:comment 'The actual departure of the shipment leg record' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual date and time at which the shipment leg departed from the origin node as recorded by the carrier or warehouse management system. Used for OTIF performance measurement and delay root-cause analysis.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualTransitHours rdf:type rdf:Property ;
    rdfs:label 'Actual Transit Hours' ;
    rdfs:comment 'Actual elapsed transit time in hours for this leg, calculated from actual departure to actual arrival timestamps. Used for carrier performance benchmarking and OTIF analysis.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonEmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Carbon Emissions Kg' ;
    rdfs:comment 'Estimated carbon dioxide equivalent (CO₂e) emissions in kilograms for this shipment leg, calculated based on transport mode, distance, and cargo weight. Supports sustainability reporting under ISO 14001 and ESG commitments.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierProNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Pro Number' ;
    rdfs:comment 'Carrier-assigned Progressive (PRO) number or tracking number for this leg. Used for carrier track-and-trace, freight bill matching, and proof of delivery retrieval.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Required' ;
    rdfs:comment 'Indicates whether this leg crosses an international border and requires customs clearance (True). Triggers customs documentation workflows and compliance checks under applicable trade regulations.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Entry Number' ;
    rdfs:comment 'Official customs entry or declaration number assigned by the customs authority for this leg. Required for cross-border shipments and regulatory compliance documentation.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Code' ;
    rdfs:comment 'Standardized code identifying the root cause of any departure or arrival delay on this leg (e.g., weather, customs hold, carrier capacity, traffic, mechanical failure). Used for OTIF root-cause analysis and carrier performance management. [ENUM-REF-CANDIDATE: weather|customs_hold|carrier_capacity|traffic|mechanical_failure|port_congestion|documentation — promote to reference product]' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Timestamp' ;
    rdfs:comment 'Most recent carrier-provided or system-calculated Estimated Time of Arrival (ETA) for this leg. Updated dynamically during transit to reflect real-time conditions. Distinct from planned arrival (static) and actual arrival (confirmed).' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freightAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Freight Audit Status' ;
    rdfs:comment 'Current status of the freight invoice audit process for this leg. Tracks whether the carrier invoice has been validated, approved for payment, or is under dispute. Supports freight audit and payment workflows.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTransshipmentPoint rdf:type rdf:Property ;
    rdfs:label 'Is Transshipment Point' ;
    rdfs:comment 'Indicates whether the destination node of this leg is an intermediate transshipment point (True) rather than the final delivery destination (False). Used to identify relay legs in intermodal routing and cost allocation.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legCostAmount rdf:type rdf:Property ;
    rdfs:label 'Leg Cost Amount' ;
    rdfs:comment 'The leg cost amount of the shipment leg record' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Leg Distance Km' ;
    rdfs:comment 'Total distance in kilometers for this shipment leg from origin node to destination node. Used for freight cost calculation, carbon emissions estimation, and route optimization analytics.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legNumber rdf:type rdf:Property ;
    rdfs:label 'Leg Number' ;
    rdfs:comment 'Sequential integer indicating the order of this leg within the parent shipment (e.g., 1 = first leg, 2 = second leg). Enables reconstruction of the full shipment route in correct order.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Leg Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this shipment leg, often assigned by the carrier or freight forwarder (e.g., waybill number, booking reference). Used for carrier communication and freight audit.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legSequence rdf:type rdf:Property ;
    rdfs:label 'Leg Sequence' ;
    rdfs:comment 'The leg sequence of the shipment leg record' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legStatus rdf:type rdf:Property ;
    rdfs:label 'Leg Status' ;
    rdfs:comment 'Current lifecycle status of the shipment leg reflecting its operational state. Drives track-and-trace visibility and exception management workflows. [ENUM-REF-CANDIDATE: planned|in_transit|arrived|completed|cancelled|delayed — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legType rdf:type rdf:Property ;
    rdfs:label 'Leg Type' ;
    rdfs:comment 'The leg type of the shipment leg record' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedArrival rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival' ;
    rdfs:comment 'The planned arrival of the shipment leg record' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Timestamp' ;
    rdfs:comment 'Scheduled date and time at which the shipment leg is expected to arrive at the destination node. Used for receiving planning, dock scheduling, and OTIF target setting.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDeparture rdf:type rdf:Property ;
    rdfs:label 'Planned Departure' ;
    rdfs:comment 'The planned departure of the shipment leg record' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Timestamp' ;
    rdfs:comment 'Scheduled date and time at which the shipment leg is planned to depart from the origin node. Used for transportation planning, carrier booking, and On Time In Full (OTIF) baseline measurement.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedTransitHours rdf:type rdf:Property ;
    rdfs:label 'Planned Transit Hours' ;
    rdfs:comment 'Expected transit duration in hours for this leg as defined in the carrier contract or transportation plan. Used as the baseline for on-time performance measurement and SLA compliance.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proofOfDeliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Status' ;
    rdfs:comment 'Status of the Proof of Delivery (POD) document for this leg. Tracks whether POD has been received, is pending, or is under dispute. Required for freight audit, accounts payable, and customer dispute resolution.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentLegStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Leg Status' ;
    rdfs:comment 'The shipment leg status of the shipment leg record' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum allowable temperature in degrees Celsius for cold chain compliance during this leg. Applicable to temperature-sensitive consumer goods. Used for cold chain monitoring and regulatory compliance reporting.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum allowable temperature in degrees Celsius for cold chain compliance during this leg. Applicable to temperature-sensitive consumer goods. Used for cold chain monitoring and regulatory compliance reporting.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Transit Time Hours' ;
    rdfs:comment 'The transit time hours of the shipment leg record' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportServiceType rdf:type rdf:Property ;
    rdfs:label 'Transport Service Type' ;
    rdfs:comment 'Service level classification for this leg (e.g., Full Truckload (FTL), Less-than-Truckload (LTL), parcel, express, standard, bulk). Impacts freight cost calculation and carrier selection logic.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Code' ;
    rdfs:comment 'Identifier of the vehicle, vessel, aircraft, or rail car assigned to execute this leg (e.g., truck license plate, vessel IMO number, flight number, rail car ID). Used for asset tracking and carrier compliance.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Cbm' ;
    rdfs:comment 'Total cargo volume in cubic meters (CBM) for this leg. Used for volumetric freight rate calculation, container utilization analysis, and load planning optimization.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentItemId rdf:type rdf:Property ;
    rdfs:label 'Shipment Item Id' ;
    rdfs:comment 'Unique surrogate identifier for each shipment line item record in the logistics data platform. Primary key for the shipment_item entity.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:declaredValue rdf:type rdf:Property ;
    rdfs:label 'Declared Value' ;
    rdfs:comment 'The declared value of the shipment item record' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Document Number' ;
    rdfs:comment 'ERP delivery document number (e.g., SAP outbound delivery number) associated with this shipment line. Serves as the primary cross-reference between the logistics execution system and the financial/order management system.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:harmonizedTariffCode rdf:type rdf:Property ;
    rdfs:label 'Harmonized Tariff Code' ;
    rdfs:comment 'Harmonized System (HS) tariff classification code for the product, used for customs clearance, import duty calculation, and international trade compliance. Typically 6-10 digits per WCO HS nomenclature.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isControlledSubstance rdf:type rdf:Property ;
    rdfs:label 'Is Controlled Substance' ;
    rdfs:comment 'Indicates whether this item contains a controlled substance subject to DEA scheduling, FDA drug regulations, or equivalent international narcotics controls. Triggers enhanced chain-of-custody documentation requirements.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDsd rdf:type rdf:Property ;
    rdfs:label 'Is Dsd' ;
    rdfs:comment 'Indicates whether this item is fulfilled via Direct Store Delivery (DSD) channel, bypassing the retailer\'s distribution center and delivering directly to the store. Impacts route planning, SFA integration, and trade promotion settlement.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemperatureSensitive rdf:type rdf:Property ;
    rdfs:label 'Is Temperature Sensitive' ;
    rdfs:comment 'Indicates whether this item requires temperature-controlled handling and transport (cold chain). When true, temperature range requirements and cold-chain compliance monitoring are enforced throughout the shipment lifecycle.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Human-readable description of the product being shipped, including product name, variant, and pack size. Used on shipping documents, proof of delivery, and freight audit records.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current lifecycle status of this shipment line item. Tracks progression from warehouse picking through delivery confirmation. [ENUM-REF-CANDIDATE: planned|picked|loaded|in_transit|delivered|short_shipped|cancelled — promote to reference product]' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineValue rdf:type rdf:Property ;
    rdfs:label 'Line Value' ;
    rdfs:comment 'Total declared value of this shipment line item (shipped_quantity × unit_cost), used for customs valuation, cargo insurance, and financial reporting. Expressed in the shipment currency.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Temperature C' ;
    rdfs:comment 'Maximum allowable temperature in degrees Celsius for storage and transport of this item. Applicable when is_temperature_sensitive is true. Exceedances trigger quality holds and non-conformance reporting.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'Minimum allowable temperature in degrees Celsius for storage and transport of this item. Applicable when is_temperature_sensitive is true. Used to configure cold-chain monitoring alerts and carrier SLA requirements.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'The package count of the shipment item record' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Uom' ;
    rdfs:comment 'The quantity uom of the shipment item record' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Number' ;
    rdfs:comment 'Product registration or regulatory approval number required for cross-border shipments of regulated consumer goods (e.g., FDA registration, EPA registration, EU REACH authorization). Stored for customs and import compliance documentation.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrderLine rdf:type rdf:Property ;
    rdfs:label 'Sales Order Line' ;
    rdfs:comment 'Line item number within the originating sales order corresponding to this shipment item. Used for precise order-to-shipment reconciliation and partial fulfillment tracking.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentItemStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Item Status' ;
    rdfs:comment 'The shipment item status of the shipment item record' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeM3 rdf:type rdf:Property ;
    rdfs:label 'Volume M3' ;
    rdfs:comment 'Cubic volume of this shipment line item in cubic metres, used for truck load planning, container utilization optimization, and freight rate calculation based on dimensional weight.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryId rdf:type rdf:Property ;
    rdfs:label 'Delivery Id' ;
    rdfs:comment 'Unique surrogate identifier for each delivery execution record in the Silver layer lakehouse. Primary key for the delivery data product.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Delivery .

ind:finalShipmentLegId rdf:type rdf:Property ;
    rdfs:label 'Final Shipment Leg Id' ;
    rdfs:comment 'Foreign key linking to logistics.shipment_leg. Business justification: A delivery is the execution result of the final shipment leg in a multi-leg movement. shipment_leg captures leg sequence, origin/destination, actual arrival/departure timestamps, and leg-level freight' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentLeg .

ind:actualTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Actual Temperature C' ;
    rdfs:comment 'Actual temperature in degrees Celsius recorded during delivery, captured by IoT sensor or driver log. Used to verify cold-chain compliance and support FDA/EU GDP regulatory reporting for temperature-sensitive goods.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:address rdf:type rdf:Property ;
    rdfs:label 'Address' ;
    rdfs:comment 'The address of the delivery record' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Tracking Number' ;
    rdfs:comment 'External tracking number assigned by the carrier for track-and-trace visibility. Enables real-time shipment monitoring and customer-facing delivery status updates.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeName rdf:type rdf:Property ;
    rdfs:label 'Consignee Name' ;
    rdfs:comment 'Legal or trading name of the receiving party (store, warehouse, or customer) at the delivery destination. Used for POD (Proof of Delivery) documentation and dispute resolution.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'Actual quantity of goods physically delivered and accepted at the consignee location. Core metric for OTIF (On Time In Full) in-full measurement, fill rate KPI, and invoice reconciliation.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Externally-known business identifier for the delivery, typically sourced from SAP S/4HANA SD outbound delivery document (e.g., 80XXXXXXXX). Used in EDI communications, carrier coordination, and customer-facing tracking.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the delivery execution. \'full\' = all ordered quantities delivered; \'partial\' = some quantities delivered; \'failed\' = delivery attempt unsuccessful; \'refused\' = consignee rejected delivery; \'pending\' = delivery not yet attempted. Core field for OTIF (On Time In Full) calculation.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryType rdf:type rdf:Property ;
    rdfs:label 'Delivery Type' ;
    rdfs:comment 'Classification of the delivery method. DSD (Direct Store Delivery) = manufacturer delivers directly to retail shelf; warehouse = delivery to distribution center; cross_dock = transit without storage; drop_ship = vendor ships directly to consignee; returns = reverse logistics delivery. [ENUM-REF-CANDIDATE: DSD|warehouse|cross_dock|drop_ship|returns — promote to reference product]' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignatureFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Flag' ;
    rdfs:comment 'Indicates whether the POD (Proof of Delivery) signature was captured electronically (True) via e-POD app or DSD handheld, or obtained on paper (False). Determines evidentiary strength for dispute resolution.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstAttemptTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Attempt Timestamp' ;
    rdfs:comment 'Date and time of the first delivery attempt at the consignee location. Relevant when the delivery required multiple attempts (e.g., failed first attempt followed by successful re-delivery). Supports carrier performance analytics.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:goodsConditionCode rdf:type rdf:Property ;
    rdfs:label 'Goods Condition Code' ;
    rdfs:comment 'Condition of goods as assessed at point of delivery receipt. \'good\' = acceptable; \'damaged\' = physical damage observed; \'partial_damage\' = some units damaged; \'temperature_breach\' = cold-chain violation detected; \'contaminated\' = product integrity compromised. Triggers quality investigation and regulatory reporting. [ENUM-REF-CANDIDATE: good|damaged|partial_damage|temperature_breach|contaminated — promote to reference product]' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inFullFlag rdf:type rdf:Property ;
    rdfs:label 'In Full Flag' ;
    rdfs:comment 'Indicates whether the full ordered quantity was delivered (True). Component of the OTIF (On Time In Full) KPI, enabling separate on-time vs. in-full root cause analysis and fill rate reporting.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isComplete rdf:type rdf:Property ;
    rdfs:label 'Is Complete' ;
    rdfs:comment 'The is complete of the delivery record' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInFull rdf:type rdf:Property ;
    rdfs:label 'Is In Full' ;
    rdfs:comment 'The is in full of the delivery record' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOnTime rdf:type rdf:Property ;
    rdfs:label 'Is On Time' ;
    rdfs:comment 'The is on time of the delivery record' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onTimeFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Flag' ;
    rdfs:comment 'Indicates whether the delivery was completed on or before the scheduled delivery date/time (True). Component of the OTIF (On Time In Full) KPI, enabling separate on-time vs. in-full root cause analysis.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Flag' ;
    rdfs:comment 'Indicates whether this delivery met the OTIF (On Time In Full) KPI criteria — True if delivered on or before the scheduled date AND at 100% of ordered quantity. Core retail compliance metric for major retailers (e.g., Walmart OTIF penalty program).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoAttachmentReference rdf:type rdf:Property ;
    rdfs:label 'Photo Attachment Reference' ;
    rdfs:comment 'Storage reference or URL to photo evidence captured at delivery (e.g., goods condition, placement, damaged packaging). Supports POD (Proof of Delivery) documentation and insurance claims.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSource rdf:type rdf:Property ;
    rdfs:label 'Pod Source' ;
    rdfs:comment 'System or method used to capture the POD (Proof of Delivery). DSD_handheld = Direct Store Delivery device; epod_app = electronic POD mobile application; paper_scan = digitized paper document; EDI = Electronic Data Interchange confirmation; manual = manually entered. Determines data quality and evidentiary weight.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'Full name of the individual who physically received and signed for the delivery at the consignee location. Core POD (Proof of Delivery) field for dispute resolution and legal evidence.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refusedQuantity rdf:type rdf:Property ;
    rdfs:label 'Refused Quantity' ;
    rdfs:comment 'Quantity of goods refused or rejected by the consignee at point of delivery. Triggers reverse logistics, credit memo processing, and quality investigation workflows.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejection Quantity' ;
    rdfs:comment 'The rejection quantity of the delivery record' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'The planned calendar date on which the delivery was scheduled to arrive at the consignee location. Used as the baseline for OTIF (On Time In Full) on-time measurement and SLA compliance.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Timestamp' ;
    rdfs:comment 'The precise planned date and time window start for delivery at the consignee location. Supports time-window compliance measurement and carrier SLA (Service Level Agreement) tracking.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Signature Captured' ;
    rdfs:comment 'The signature captured of the delivery record' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureReference rdf:type rdf:Property ;
    rdfs:label 'Signature Reference' ;
    rdfs:comment 'Storage reference or URL pointing to the captured electronic or scanned signature image for this delivery. Used as legal evidence in POD (Proof of Delivery) dispute resolution.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowEnd rdf:type rdf:Property ;
    rdfs:label 'Window End' ;
    rdfs:comment 'The window end of the delivery record' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:windowStart rdf:type rdf:Property ;
    rdfs:label 'Window Start' ;
    rdfs:comment 'The window start of the delivery record' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proofOfDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Id' ;
    rdfs:comment 'Unique system-generated identifier for the proof of delivery record. Primary key for this entity.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capturedBy rdf:type rdf:Property ;
    rdfs:label 'Captured By' ;
    rdfs:comment 'The captured by of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capturedDevice rdf:type rdf:Property ;
    rdfs:label 'Captured Device' ;
    rdfs:comment 'The captured device of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierScanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Carrier Scan Timestamp' ;
    rdfs:comment 'Timestamp of the carrier\'s own barcode or RFID scan event at the point of delivery, as transmitted via EDI or carrier portal. May differ from receipt_timestamp if there is a lag between physical delivery and system capture.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coldChainCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Compliant Flag' ;
    rdfs:comment 'Indicates whether the delivery maintained required cold-chain temperature conditions throughout transit (True = compliant). Critical for temperature-sensitive consumer goods (e.g., dairy, frozen, pharmaceutical). Supports FDA and ISO 22716 compliance.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Reference Number' ;
    rdfs:comment 'The consignee\'s own purchase order or reference number for this delivery. Enables cross-referencing between the supplier\'s POD and the customer\'s receiving records for EDI reconciliation and dispute resolution.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageNoted rdf:type rdf:Property ;
    rdfs:label 'Damage Noted' ;
    rdfs:comment 'The damage noted of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:damageNotes rdf:type rdf:Property ;
    rdfs:label 'Damage Notes' ;
    rdfs:comment 'The damage notes of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageReported rdf:type rdf:Property ;
    rdfs:label 'Damage Reported' ;
    rdfs:comment 'The damage reported of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryCondition rdf:type rdf:Property ;
    rdfs:label 'Delivery Condition' ;
    rdfs:comment 'The delivery condition of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocationGln rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Gln' ;
    rdfs:comment 'GS1 Global Location Number (GLN) of the delivery destination. Provides a globally unique, standardized identifier for the consignee location, enabling interoperability with trading partners and EDI systems.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocationName rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Name' ;
    rdfs:comment 'Name of the physical delivery location (e.g., store name, distribution center name, warehouse name). Provides human-readable identification of the delivery destination for reporting and operations.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Delivery Temperature C' ;
    rdfs:comment 'Recorded temperature in degrees Celsius at the point of delivery for temperature-sensitive goods. Used to verify cold-chain compliance and support FDA regulatory reporting for perishable or pharmaceutical consumer goods.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The delivery timestamp of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Categorical classification of the type of discrepancy identified at delivery. Enables structured reporting and root cause analysis across the logistics network. [ENUM-REF-CANDIDATE: quantity_shortage|overage|damaged_goods|wrong_item|temperature_breach|missing_documentation — promote to reference product]' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'The date on which a delivery dispute was formally resolved. Used to measure dispute resolution cycle time and SLA compliance for freight audit and carrier management.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current status of any freight or delivery dispute associated with this POD. Tracks the lifecycle of dispute resolution from identification through closure. Supports freight audit and carrier claims management.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdRouteStopSequence rdf:type rdf:Property ;
    rdfs:label 'Dsd Route Stop Sequence' ;
    rdfs:comment 'The sequential stop number of this delivery within the DSD route. Used for route optimization analysis, driver performance measurement, and DSD compliance reporting in Salesforce Consumer Goods Cloud.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'The exception flag of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freightBillNumber rdf:type rdf:Property ;
    rdfs:label 'Freight Bill Number' ;
    rdfs:comment 'The carrier-issued freight bill or bill of lading (BOL) number associated with this delivery. Used to match POD records to freight invoices during freight audit and payment processes.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geofenceValidatedFlag rdf:type rdf:Property ;
    rdfs:label 'Geofence Validated Flag' ;
    rdfs:comment 'Indicates whether the GPS coordinates captured at delivery were within the expected geofence boundary of the consignee location (True = within geofence). Used to detect fraudulent or erroneous POD captures in DSD operations.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'GPS latitude coordinate captured at the time of delivery confirmation. Used for geofencing validation, proof of delivery location verification, and DSD compliance auditing.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'GPS longitude coordinate captured at the time of delivery confirmation. Used alongside latitude for geofencing validation, delivery location verification, and DSD compliance auditing.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsCondition rdf:type rdf:Property ;
    rdfs:label 'Goods Condition' ;
    rdfs:comment 'Condition of the goods as assessed at the point of delivery by the recipient. Drives claims processing, carrier liability assessment, and quality incident reporting. [ENUM-REF-CANDIDATE: intact|damaged|partial_damage|refused|short_delivered — promote to reference product if additional conditions are required]' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'The gps latitude of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'The gps longitude of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:photoAttachmentCount rdf:type rdf:Property ;
    rdfs:label 'Photo Attachment Count' ;
    rdfs:comment 'Number of photo attachments captured and associated with this POD record. Indicates the volume of photographic evidence available for dispute resolution and claims processing.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:photoAttachmentUrls rdf:type rdf:Property ;
    rdfs:label 'Photo Attachment Urls' ;
    rdfs:comment 'Comma-separated list of URL or file path references to photo images captured at delivery (e.g., photos of damaged goods, delivery location, pallet condition). Stored in secure document repository and referenced for dispute resolution.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoReference rdf:type rdf:Property ;
    rdfs:label 'Photo Reference' ;
    rdfs:comment 'The photo reference of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podConfirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Pod Confirmation Method' ;
    rdfs:comment 'The method used to confirm delivery receipt (e.g., signature, PIN code, photo-only, verbal confirmation, unattended drop). Supports compliance with carrier SLA requirements and DSD operational standards.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podImageReference rdf:type rdf:Property ;
    rdfs:label 'Pod Image Reference' ;
    rdfs:comment 'The pod image reference of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podNumber rdf:type rdf:Property ;
    rdfs:label 'Pod Number' ;
    rdfs:comment 'Externally-known business reference number for this POD document. Used in freight audit, dispute resolution, and EDI acknowledgement exchanges with carriers and customers.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podReference rdf:type rdf:Property ;
    rdfs:label 'Pod Reference' ;
    rdfs:comment 'The pod reference of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podStatus rdf:type rdf:Property ;
    rdfs:label 'Pod Status' ;
    rdfs:comment 'The pod status of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podType rdf:type rdf:Property ;
    rdfs:label 'Pod Type' ;
    rdfs:comment 'The pod type of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'The exact date and time at which the consignee acknowledged receipt of the goods. This is the principal business event timestamp for the POD and is the authoritative time used for OTIF measurement and freight audit.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recipientSignatureRef rdf:type rdf:Property ;
    rdfs:label 'Recipient Signature Ref' ;
    rdfs:comment 'The recipient signature ref of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientTitle rdf:type rdf:Property ;
    rdfs:label 'Recipient Title' ;
    rdfs:comment 'Job title or role of the individual who received the goods (e.g., Receiving Manager, Store Associate, Warehouse Clerk). Provides context for authorization level of the signatory.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureImageUrl rdf:type rdf:Property ;
    rdfs:label 'Signature Image Url' ;
    rdfs:comment 'URL or file path reference to the stored digital image of the recipient\'s signature. Used as legal evidence in freight disputes and customer claims. Stored in secure document repository.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signature Timestamp' ;
    rdfs:comment 'The signature timestamp of the proof of delivery record' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryFreightNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Freight Network Node Id' ;
    rdfs:comment 'Reference to the delivery/destination location (retailer DC, customer warehouse, store, or end-consumer address) to which the freight order is directed.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:actualPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Pickup Timestamp' ;
    rdfs:comment 'The actual date and time the carrier picked up the freight at the origin location. Compared against the pickup window to determine on-time pickup performance for OTIF reporting.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:agreedFreightRate rdf:type rdf:Property ;
    rdfs:label 'Agreed Freight Rate' ;
    rdfs:comment 'The negotiated or spot-quoted rate agreed with the carrier for executing this freight order, expressed in the transaction currency. Used for freight cost accrual, freight audit, and carrier rate benchmarking.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Invoice Number' ;
    rdfs:comment 'Invoice number issued by the carrier for this freight order. Used for freight audit and payment matching in accounts payable. Populated upon receipt of carrier invoice.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End' ;
    rdfs:comment 'End of the agreed delivery time window at the destination location. Defines the latest acceptable delivery time per retailer or customer SLA.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start' ;
    rdfs:comment 'Start of the agreed delivery time window at the destination location. Defines the earliest acceptable delivery time per retailer or customer SLA.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Amount' ;
    rdfs:comment 'The estimated cost amount of the freight order record' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Freight Order Number' ;
    rdfs:comment 'Externally-visible, human-readable business identifier for the freight order as issued by the Transportation Management System (TMS). Used in carrier communications, EDI transactions, and proof-of-delivery documents.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Freight Order Status' ;
    rdfs:comment 'The freight order status of the freight order record' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadType rdf:type rdf:Property ;
    rdfs:label 'Load Type' ;
    rdfs:comment 'Classification of the shipment load mode. FTL (Full Truckload) indicates the carrier\'s entire trailer is dedicated to this shipment; LTL (Less-than-Truckload) indicates shared trailer space; parcel indicates small-package carrier service; intermodal indicates multi-modal container movement; rail indicates rail freight.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Pickup Window End' ;
    rdfs:comment 'End of the agreed pickup time window at the origin location. Defines the latest time the carrier may arrive for loading without incurring a late pickup penalty.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickupWindowStart rdf:type rdf:Property ;
    rdfs:label 'Pickup Window Start' ;
    rdfs:comment 'Start of the agreed pickup time window at the origin location. Defines the earliest time the carrier may arrive for loading. Used for dock scheduling and carrier compliance measurement.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Requested Pickup Date' ;
    rdfs:comment 'The date on which the shipper requests the carrier to pick up the freight at the origin location. Used for OTIF (On Time In Full) measurement and carrier performance tracking.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Reference Number' ;
    rdfs:comment 'External reference number used by the carrier or 3PL to identify this shipment in their system. Enables cross-system track-and-trace and carrier invoice reconciliation via EDI (Electronic Data Interchange).' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderDate rdf:type rdf:Property ;
    rdfs:label 'Tender Date' ;
    rdfs:comment 'The tender date of the freight order record' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tenderStatus rdf:type rdf:Property ;
    rdfs:label 'Tender Status' ;
    rdfs:comment 'The tender status of the freight order record' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderingMethod rdf:type rdf:Property ;
    rdfs:label 'Tendering Method' ;
    rdfs:comment 'Method used to tender the freight order to a carrier. Contract indicates a pre-negotiated rate agreement; spot indicates a one-time market rate; load_board indicates posting to a freight exchange; dedicated indicates a committed fleet arrangement; auction indicates a competitive bidding process.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmsSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Tms Source System' ;
    rdfs:comment 'Identifies the source Transportation Management System (TMS) from which this freight order record was ingested into the lakehouse. Supports data lineage, reconciliation, and multi-system integration auditing.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'The total cost of the freight order record' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Freight Invoice Id' ;
    rdfs:comment 'Unique surrogate identifier for the freight invoice record in the Consumer Goods lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessorialAmount rdf:type rdf:Property ;
    rdfs:label 'Accessorial Amount' ;
    rdfs:comment 'Total amount of accessorial charges on the invoice, including but not limited to liftgate, residential delivery, inside delivery, detention, redelivery, and hazmat fees. Audited against contracted accessorial schedules.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Amount approved for payment to the carrier after freight audit review and any adjustments. May differ from invoiced total if disputes or corrections were applied. This is the amount that flows to accounts payable for payment.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Completed Timestamp' ;
    rdfs:comment 'Date and time the freight audit review was completed for this invoice. Marks the transition from \'under_audit\' to \'approved\' or \'disputed\' status in the freight audit and pay (FAP) workflow.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'The audit status of the freight invoice record' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseFreightAmount rdf:type rdf:Property ;
    rdfs:label 'Base Freight Amount' ;
    rdfs:comment 'The base freight amount of the freight invoice record' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedAmount rdf:type rdf:Property ;
    rdfs:label 'Contracted Amount' ;
    rdfs:comment 'Expected freight charge calculated from the applicable carrier contract rate for this lane, mode, and service level. Used as the benchmark in freight audit to identify billing variances.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeNotes rdf:type rdf:Property ;
    rdfs:label 'Dispute Notes' ;
    rdfs:comment 'Free-text notes describing the reason for disputing the freight invoice, including specific discrepancies identified during freight audit. Supports carrier communication and dispute resolution.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Code' ;
    rdfs:comment 'EDI (Electronic Data Interchange) transaction set identifier for invoices received electronically via EDI 210 (Motor Carrier Freight Invoice) or equivalent. Enables traceability of electronic invoice transmission.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightClass rdf:type rdf:Property ;
    rdfs:label 'Freight Class' ;
    rdfs:comment 'National Motor Freight Classification (NMFC) freight class assigned to the shipment (e.g., 50, 70, 100, 150). Determines LTL (Less-Than-Truckload) base rates and is a key audit point for freight invoice validation.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightInvoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Freight Invoice Status' ;
    rdfs:comment 'The freight invoice status of the freight invoice record' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Invoice Currency Code' ;
    rdfs:comment 'The invoice currency code of the freight invoice record' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceSource rdf:type rdf:Property ;
    rdfs:label 'Invoice Source' ;
    rdfs:comment 'Channel through which the freight invoice was received by Consumer Goods. Used to track EDI adoption rates and identify manual processing inefficiencies.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'The invoiced amount of the freight invoice record' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicedTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Total Amount' ;
    rdfs:comment 'Total gross amount invoiced by the carrier, inclusive of line-haul, fuel surcharge, accessorials, and taxes. This is the amount the carrier is requesting for payment before audit adjustments.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineHaulAmount rdf:type rdf:Property ;
    rdfs:label 'Line Haul Amount' ;
    rdfs:comment 'Base transportation charge for moving freight from origin to destination, excluding surcharges and accessorials. Core component of the freight invoice monetary triplet.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidDate rdf:type rdf:Property ;
    rdfs:label 'Paid Date' ;
    rdfs:comment 'Date the payment was issued to the carrier for this freight invoice. Used to calculate Days Sales Outstanding (DSO), confirm on-time payment, and support carrier relationship management.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceDate rdf:type rdf:Property ;
    rdfs:label 'Service Date' ;
    rdfs:comment 'Date the transportation service was rendered (pickup or delivery date). Used to match the invoice to the correct accounting period and validate service delivery.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Shipment Weight Kg' ;
    rdfs:comment 'Actual or billed shipment weight in kilograms as stated on the freight invoice. Used to validate weight-based freight charges against contracted rates and detect weight discrepancies.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Monetary difference between the invoiced total amount and the contracted rate amount (invoiced_total_amount minus contracted_amount). Positive value indicates overbilling by carrier; negative indicates underbilling. Central metric in the freight audit and pay (FAP) process.' ;
    rdfs:domain ind:FreightInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Carrier Performance Id' ;
    rdfs:comment 'Unique surrogate identifier for each carrier performance scorecard record in the Silver Layer lakehouse.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageCostPerShipment rdf:type rdf:Property ;
    rdfs:label 'Average Cost Per Shipment' ;
    rdfs:comment 'The average cost per shipment of the carrier performance record' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgTransitDays rdf:type rdf:Property ;
    rdfs:label 'Avg Transit Days' ;
    rdfs:comment 'Average number of calendar days from actual pickup to actual delivery across all shipments in the measurement period. Compared against standard transit days to assess transit time performance.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierContactName rdf:type rdf:Property ;
    rdfs:label 'Carrier Contact Name' ;
    rdfs:comment 'Name of the carrier\'s primary account representative or performance manager who receives and acknowledges this scorecard.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierPerformanceStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Performance Status' ;
    rdfs:comment 'The carrier performance status of the carrier performance record' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimCount rdf:type rdf:Property ;
    rdfs:label 'Claim Count' ;
    rdfs:comment 'The claim count of the carrier performance record' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimRatePct rdf:type rdf:Property ;
    rdfs:label 'Claim Rate Pct' ;
    rdfs:comment 'The claim rate pct of the carrier performance record' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Claims Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the total_claims_amount field (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsRatePct rdf:type rdf:Property ;
    rdfs:label 'Claims Rate Pct' ;
    rdfs:comment 'Percentage of shipments resulting in a freight claim (loss, damage, or shortage) during the measurement period. Key indicator of cargo handling quality.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compositeScore rdf:type rdf:Property ;
    rdfs:label 'Composite Score' ;
    rdfs:comment 'Weighted composite score (0–100) summarizing the carrier\'s overall performance across all measured KPIs for the period. Drives performance tier assignment and contract renewal decisions.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerShipment rdf:type rdf:Property ;
    rdfs:label 'Cost Per Shipment' ;
    rdfs:comment 'The cost per shipment of the carrier performance record' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageRatePct rdf:type rdf:Property ;
    rdfs:label 'Damage Rate Pct' ;
    rdfs:comment 'Percentage of shipments with reported product damage upon delivery during the measurement period. Distinct from claims rate as it isolates physical damage from loss/shortage events.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediComplianceRatePct rdf:type rdf:Property ;
    rdfs:label 'Edi Compliance Rate Pct' ;
    rdfs:comment 'Percentage of shipments for which the carrier transmitted all required EDI transaction sets (e.g., 214 shipment status, 210 freight invoice) accurately and on time during the measurement period.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End' ;
    rdfs:comment 'The evaluation period end of the carrier performance record' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start' ;
    rdfs:comment 'The evaluation period start of the carrier performance record' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightSpendCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Spend Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the total_freight_spend field (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:improvementPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Improvement Plan Flag' ;
    rdfs:comment 'Indicates whether a formal Carrier Improvement Plan (CIP) is active for this carrier as of this measurement period. True = improvement plan in effect; False = no active plan.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inFullDeliveryPct rdf:type rdf:Property ;
    rdfs:label 'In Full Delivery Pct' ;
    rdfs:comment 'The in full delivery pct of the carrier performance record' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inFullRatePct rdf:type rdf:Property ;
    rdfs:label 'In Full Rate Pct' ;
    rdfs:comment 'Percentage of shipments delivered with the complete ordered quantity, without short-shipment or partial delivery, during the measurement period.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceAccuracyPct rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Pct' ;
    rdfs:comment 'The invoice accuracy pct of the carrier performance record' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceAccuracyRatePct rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Rate Pct' ;
    rdfs:comment 'Percentage of carrier freight invoices that matched the contracted rate without requiring correction or dispute during the measurement period. Supports freight audit and pay processes.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPeriod rdf:type rdf:Property ;
    rdfs:label 'Measurement Period' ;
    rdfs:comment 'The measurement period of the carrier performance record' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodType rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Type' ;
    rdfs:comment 'Granularity of the performance measurement window — weekly, monthly, quarterly, or annual. Determines the cadence at which KPIs are aggregated and reviewed.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeDeliveryRatePct rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate Pct' ;
    rdfs:comment 'Percentage of shipments delivered to the destination within the committed delivery window during the measurement period. Distinct from OTIF as it excludes the in-full dimension.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimePickupRatePct rdf:type rdf:Property ;
    rdfs:label 'On Time Pickup Rate Pct' ;
    rdfs:comment 'Percentage of shipments where the carrier arrived at the origin facility within the scheduled pickup window during the measurement period.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifPct rdf:type rdf:Property ;
    rdfs:label 'Otif Pct' ;
    rdfs:comment 'The otif pct of the carrier performance record' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifRatePct rdf:type rdf:Property ;
    rdfs:label 'Otif Rate Pct' ;
    rdfs:comment 'Percentage of shipments delivered both on time and in full during the measurement period. Core OTIF KPI used in carrier scorecards and contract compliance reviews. Calculated as (OTIF shipments / total shipments) × 100.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Overall performance classification assigned to the carrier for this measurement period based on composite KPI scoring. Preferred = top-tier; Approved = meets standards; Probation = below threshold with improvement plan; Suspended = removed from routing guide pending review.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'Last calendar date of the measurement period covered by this scorecard record.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'First calendar date of the measurement period covered by this scorecard record.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'The period type of the carrier performance record' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podComplianceRatePct rdf:type rdf:Property ;
    rdfs:label 'Pod Compliance Rate Pct' ;
    rdfs:comment 'Percentage of shipments for which a valid Proof of Delivery (POD) document was received within the contractually required timeframe during the measurement period.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodCompositeScore rdf:type rdf:Property ;
    rdfs:label 'Prior Period Composite Score' ;
    rdfs:comment 'Composite performance score from the immediately preceding measurement period. Enables trend analysis and period-over-period performance comparison without requiring a self-join.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scorecardFinalizedDate rdf:type rdf:Property ;
    rdfs:label 'Scorecard Finalized Date' ;
    rdfs:comment 'Calendar date on which the scorecard was locked as final after the dispute resolution window closed. Null if scorecard is not yet finalized.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scorecardNotes rdf:type rdf:Property ;
    rdfs:label 'Scorecard Notes' ;
    rdfs:comment 'Free-text field for logistics team commentary on the scorecard, including context for performance anomalies, weather events, or force majeure conditions that impacted KPIs.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardNumber rdf:type rdf:Property ;
    rdfs:label 'Scorecard Number' ;
    rdfs:comment 'Externally-known business identifier for this scorecard record, used in carrier communications and contract review meetings. Format: CPSC-YYYY-MM-XXXXXX.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardPublishedDate rdf:type rdf:Property ;
    rdfs:label 'Scorecard Published Date' ;
    rdfs:comment 'Calendar date on which the scorecard was formally published and shared with the carrier for review. Marks the start of the carrier\'s dispute window.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scorecardRating rdf:type rdf:Property ;
    rdfs:label 'Scorecard Rating' ;
    rdfs:comment 'The scorecard rating of the carrier performance record' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardReference rdf:type rdf:Property ;
    rdfs:label 'Scorecard Reference' ;
    rdfs:comment 'The scorecard reference of the carrier performance record' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardStatus rdf:type rdf:Property ;
    rdfs:label 'Scorecard Status' ;
    rdfs:comment 'Current lifecycle state of the scorecard record. Draft = under calculation; Published = shared with carrier; Disputed = carrier has raised a challenge; Finalized = agreed and locked; Archived = historical.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderAcceptancePct rdf:type rdf:Property ;
    rdfs:label 'Tender Acceptance Pct' ;
    rdfs:comment 'The tender acceptance pct of the carrier performance record' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderAcceptanceRatePct rdf:type rdf:Property ;
    rdfs:label 'Tender Acceptance Rate Pct' ;
    rdfs:comment 'Percentage of load tenders accepted by the carrier on first offer during the measurement period. Low acceptance rates indicate capacity reliability issues and routing guide compliance failures.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderAcceptanceTargetPct rdf:type rdf:Property ;
    rdfs:label 'Tender Acceptance Target Pct' ;
    rdfs:comment 'Contracted minimum tender acceptance rate for this carrier during the measurement period. Compared against actual tender acceptance rate to assess routing guide compliance.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalClaimsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Claims Amount' ;
    rdfs:comment 'Total monetary value of freight claims filed against the carrier during the measurement period, expressed in the reporting currency. Used for financial recovery tracking and carrier liability assessment.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFreightSpend rdf:type rdf:Property ;
    rdfs:label 'Total Freight Spend' ;
    rdfs:comment 'Total freight cost paid to the carrier during the measurement period, including base freight, fuel surcharges, and accessorial charges. Used for spend analytics and contract benchmarking.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalShipments rdf:type rdf:Property ;
    rdfs:label 'Total Shipments' ;
    rdfs:comment 'Total number of shipments tendered to the carrier during the measurement period. Serves as the denominator for rate-based KPI calculations.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTenders rdf:type rdf:Property ;
    rdfs:label 'Total Tenders' ;
    rdfs:comment 'Total number of load tenders issued to the carrier during the measurement period, including both accepted and rejected tenders.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentMembershipId rdf:type rdf:Property ;
    rdfs:label 'Segment Membership Id' ;
    rdfs:comment 'Primary key for the segment_membership association' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'The ML model confidence score (0.0000–1.0000) for this specific shopper-segment assignment. Distinct from the segment-level min_confidence_score threshold — this is the actual score achieved by this shopper at the time of assignment. Only meaningful in the context of this individual membership record.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exitReason rdf:type rdf:Property ;
    rdfs:label 'Exit Reason' ;
    rdfs:comment 'The reason this shopper\'s membership in this segment ended. Populated when effective_until is set. Supports segment lifecycle analysis and suppression management.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
