ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Foreign key linking to consumer.address. Business justification: Product registration captures a consumer\'s address for warranty service dispatch, product recall notifications, and regulatory compliance (CPSC recall traceability). Linking to consumer.address enable' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:batchReleaseId rdf:type rdf:Property ;
    rdfs:label 'Batch Release Id' ;
    rdfs:comment 'Foreign key linking to quality.batch_release. Business justification: Product recall management requires tracing registered consumer products to their batch release record to identify affected consumers for targeted recall notifications. Regulatory recall processes (FDA' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRelease .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: CPG product registrations are attributed to acquisition campaigns (e.g., \'registered via summer loyalty campaign\') for campaign ROI measurement and CRM attribution reporting. registration_source and r' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:loyaltyAccountId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Account Id' ;
    rdfs:comment 'Foreign key linking to consumer.loyalty_account. Business justification: Product registration is a primary loyalty enrollment touchpoint in consumer goods (e.g., Dyson, Philips). Linking registration to loyalty_account enables warranty-loyalty integration, post-purchase lo' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyAccount .

ind:registrationProductRegisteredShopperId rdf:type rdf:Property ;
    rdfs:label 'Registration Product Registered Shopper Id' ;
    rdfs:comment 'add column registered_shopper_id (BIGINT) with FK to consumer.shopper.shopper_id - product registration is a consumer warranty/registration record' ;
    rdfs:domain ind:Registration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shopper .

ind:registrationProductShopperId rdf:type rdf:Property ;
