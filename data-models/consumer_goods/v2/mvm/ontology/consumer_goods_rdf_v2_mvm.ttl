ind:manufacturingFacilityStatus rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Facility Status' ;
    rdfs:comment 'The manufacturing facility status of the manufacturing facility record' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesSystemIntegrated rdf:type rdf:Property ;
    rdfs:label 'Mes System Integrated' ;
    rdfs:comment 'Indicates whether the facility is integrated with Siemens Opcenter MES for real-time production tracking and shop floor data collection.' ;
    rdfs:domain ind:ManufacturingFacility ;
