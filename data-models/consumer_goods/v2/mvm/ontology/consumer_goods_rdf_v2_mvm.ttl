ind:waterConsumptionCubicMetersPerYear rdf:type rdf:Property ;
    rdfs:label 'Water Consumption Cubic Meters Per Year' ;
    rdfs:comment 'Annual water consumption of the facility measured in cubic meters, tracked for environmental compliance and sustainability reporting.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workforceHeadcount rdf:type rdf:Property ;
    rdfs:label 'Workforce Headcount' ;
    rdfs:comment 'Total number of employees (full-time equivalent) assigned to the manufacturing facility.' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionLineId rdf:type rdf:Property ;
    rdfs:label 'Production Line Id' ;
    rdfs:comment 'Unique identifier for the production line. Primary key for the production line master record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionLine .

ind:productCategoryId rdf:type rdf:Property ;
    rdfs:label 'Product Category Id' ;
    rdfs:comment 'Foreign key linking to product.category. Business justification: Production lines are qualified for specific product categories (allergen handling, GMP classification, fill type). product_category is a denormalized text field; FK to product.category enables categor' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:allergenHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Handling Flag' ;
    rdfs:comment 'Indicates whether this production line handles products containing allergens. Critical for cross-contamination prevention and regulatory compliance.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenTypes rdf:type rdf:Property ;
    rdfs:label 'Allergen Types' ;
    rdfs:comment 'Comma-separated list of allergen types handled on this line (e.g., nuts, dairy, gluten). Used for allergen management and cleaning validation protocols.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Physical asset tag number assigned to the production line for asset management and tracking purposes. Links to the fixed asset register in the ERP system.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of automation on the production line. Indicates the level of human intervention required and impacts labor planning and quality consistency.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverTimeStandardMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Standard Minutes' ;
    rdfs:comment 'Standard time in minutes required to change over the production line from one product or batch to another. Used for production scheduling and OEE loss calculation.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cleaningValidationProtocol rdf:type rdf:Property ;
    rdfs:label 'Cleaning Validation Protocol' ;
    rdfs:comment 'Reference to the cleaning validation protocol document applicable to this production line. Ensures GMP compliance and prevents cross-contamination.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewSizeStandard rdf:type rdf:Property ;
    rdfs:label 'Crew Size Standard' ;
    rdfs:comment 'Standard number of operators required to run the production line at full capacity. Used for labor planning and cost allocation.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting depreciation method applied to this production line asset. Used for financial reporting and asset valuation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCapacity rdf:type rdf:Property ;
    rdfs:label 'Design Capacity' ;
    rdfs:comment 'The design capacity of the production line record' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designCapacityUnitsPerHour rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Units Per Hour' ;
    rdfs:comment 'The design capacity units per hour of the production line record' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designSpeedUnitsPerHour rdf:type rdf:Property ;
    rdfs:label 'Design Speed Units Per Hour' ;
    rdfs:comment 'Theoretical maximum production capacity of the line measured in units per hour under ideal conditions. Used for capacity planning and scheduling.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyConsumptionKwhPerUnit rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Unit' ;
    rdfs:comment 'Average energy consumption per unit produced on this line, measured in kilowatt-hours. Key metric for sustainability reporting and cost analysis.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalControlRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Control Required' ;
    rdfs:comment 'Indicates whether the production line requires controlled environmental conditions such as temperature, humidity, or air quality. Critical for GMP compliance and product quality.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpClassification rdf:type rdf:Property ;
    rdfs:label 'Gmp Classification' ;
    rdfs:comment 'GMP classification level of the production line indicating the quality and cleanliness standards required for products manufactured on this line. Critical for regulatory compliance and product safety.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityRangePercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Range Percent' ;
    rdfs:comment 'Acceptable relative humidity range for the production line as a percentage. Format: min-max (e.g., 40-60). Used for environmental monitoring and compliance.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installedPowerKw rdf:type rdf:Property ;
    rdfs:label 'Installed Power Kw' ;
    rdfs:comment 'Total installed electrical power capacity of the production line in kilowatts. Used for energy consumption tracking and sustainability reporting.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMajorOverhaulDate rdf:type rdf:Property ;
    rdfs:label 'Last Major Overhaul Date' ;
    rdfs:comment 'Date of the most recent major overhaul or refurbishment of the production line. Used for maintenance planning and asset condition assessment.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Business identifier code for the production line. Unique within the facility and used for operational reference in MES systems and production scheduling.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineLengthMeters rdf:type rdf:Property ;
    rdfs:label 'Line Length Meters' ;
    rdfs:comment 'Physical length of the production line in meters. Used for facility layout planning and material flow analysis.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'Human-readable name of the production line. Used for display in dashboards, reports, and operator interfaces.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the production line based on its primary manufacturing function. Determines the type of operations and products that can be processed on this line.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeBetweenFailuresHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures Hours' ;
    rdfs:comment 'Average time in hours between equipment failures on this production line. Key reliability metric used for maintenance optimization and capacity planning.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanTimeToRepairHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair Hours' ;
    rdfs:comment 'Average time in hours required to repair and restore the production line to operational status after a failure. Used for downtime analysis and maintenance resource planning.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesAssetTag rdf:type rdf:Property ;
    rdfs:label 'Mes Asset Tag' ;
    rdfs:comment 'Unique asset identifier for this production line in the Siemens Opcenter MES system. Used for real-time data collection, production tracking, and integration with shop floor systems.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User identifier of the person who last modified this production line record. Used for audit trail and accountability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date of the next planned preventive maintenance activity for this production line. Used for maintenance scheduling and production planning coordination.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nominalOeeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Nominal Oee Target Percent' ;
    rdfs:comment 'Target OEE percentage for this production line. OEE is calculated as Availability × Performance × Quality and represents the benchmark for line performance evaluation.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plcSystemType rdf:type rdf:Property ;
    rdfs:label 'Plc System Type' ;
    rdfs:comment 'Type and model of the PLC system controlling the production line. Used for technical support, integration planning, and system upgrade management.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryCapability rdf:type rdf:Property ;
    rdfs:label 'Product Category Capability' ;
    rdfs:comment 'Comma-separated list of product categories that can be manufactured on this line. Used for production planning and product-line matching in scheduling systems.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLineStatus rdf:type rdf:Property ;
    rdfs:label 'Production Line Status' ;
    rdfs:comment 'The production line status of the production line record' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Frequency' ;
    rdfs:comment 'Standard frequency for quality control inspections on this production line. Defines the QC sampling plan and compliance with GMP requirements.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratedSpeedUph rdf:type rdf:Property ;
    rdfs:label 'Rated Speed Uph' ;
    rdfs:comment 'The rated speed uph of the production line record' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Source system from which this production line record originated (e.g., SAP S/4HANA PP, Siemens Opcenter MES). Used for data lineage and integration troubleshooting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Scada Integration Enabled' ;
    rdfs:comment 'Indicates whether the production line is integrated with the SCADA system for real-time monitoring and control. Enables remote visibility and data collection.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scrapRateTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Scrap Rate Target Percent' ;
    rdfs:comment 'Target scrap rate percentage for this production line. Used for quality performance benchmarking and waste reduction initiatives.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Celsius' ;
    rdfs:comment 'Acceptable operating temperature range for the production line in Celsius. Format: min-max (e.g., 18-25). Used for environmental monitoring and compliance.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected useful life of the production line in years for depreciation and asset lifecycle planning purposes.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workCenterId rdf:type rdf:Property ;
    rdfs:label 'Work Center Id' ;
    rdfs:comment 'Unique identifier for the work center. Primary key.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:availableCapacityHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Hours Per Day' ;
    rdfs:comment 'Total available production hours per day for this work center after accounting for planned downtime, breaks, and maintenance windows.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Due Date' ;
    rdfs:comment 'Next scheduled calibration date for measurement and control instruments on this work center, ensuring accuracy and compliance with quality standards.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityCategory rdf:type rdf:Property ;
    rdfs:label 'Capacity Category' ;
    rdfs:comment 'The capacity category of the work center record' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPerHour rdf:type rdf:Property ;
    rdfs:label 'Capacity Per Hour' ;
    rdfs:comment 'The capacity per hour of the work center record' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'Unit of measure for the rated capacity indicating how production output is quantified for this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:category rdf:type rdf:Property ;
    rdfs:label 'Category' ;
    rdfs:comment 'High-level category grouping work centers by operational domain for capacity planning and resource allocation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanRoomClass rdf:type rdf:Property ;
    rdfs:label 'Clean Room Class' ;
    rdfs:comment 'ISO 14644 clean room classification for work centers in controlled environments, critical for cosmetics and personal care product manufacturing per GMP requirements. [ENUM-REF-CANDIDATE: iso_3|iso_4|iso_5|iso_6|iso_7|iso_8|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewSize rdf:type rdf:Property ;
    rdfs:label 'Crew Size' ;
    rdfs:comment 'Standard number of operators required to run this work center during normal production operations, used for labor planning and scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date when the work center was retired from production service, supporting asset lifecycle tracking and capacity planning.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:energyConsumptionKwhPerHour rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Hour' ;
    rdfs:comment 'Average energy consumption in kilowatt-hours per operating hour, supporting sustainability reporting and cost allocation per ISO 14001 environmental management.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Qualification Status' ;
    rdfs:comment 'Current qualification status of the work center per GMP requirements. IQ (Installation Qualification), OQ (Operational Qualification), PQ (Performance Qualification) track equipment validation stages per ISO 22716.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousAreaClassification rdf:type rdf:Property ;
    rdfs:label 'Hazardous Area Classification' ;
    rdfs:comment 'Electrical area classification for work centers handling flammable or explosive materials, ensuring compliance with Occupational Safety and Health Administration (OSHA) and ATEX directives. [ENUM-REF-CANDIDATE: non_hazardous|class_1_div_1|class_1_div_2|class_2_div_1|class_2_div_2|atex_zone_0|atex_zone_1|atex_zone_2 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Humidity Controlled Flag' ;
    rdfs:comment 'Indicates whether this work center operates in a humidity-controlled environment requiring environmental monitoring per GMP standards.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date of the most recent calibration performed on this work center, supporting traceability and compliance documentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceClass rdf:type rdf:Property ;
    rdfs:label 'Maintenance Class' ;
    rdfs:comment 'Classification of the work center by maintenance priority and frequency requirements, driving preventive maintenance scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceStrategy rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy' ;
    rdfs:comment 'Maintenance approach applied to this work center defining how maintenance activities are planned and executed.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesEquipmentCode rdf:type rdf:Property ;
    rdfs:label 'Mes Equipment Code' ;
    rdfs:comment 'Unique equipment identifier in the Siemens Opcenter MES system enabling real-time production tracking and shop floor data collection.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer model number of the work center equipment, enabling precise identification for maintenance, parts ordering, and technical documentation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this work center record was last modified, supporting change tracking and audit compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operatorSkillLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Operator Skill Level Required' ;
    rdfs:comment 'Minimum operator skill level required to operate this work center safely and effectively, supporting workforce planning and training requirements.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date when the work center achieved its current GMP qualification status, establishing the baseline for requalification scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratedCapacity rdf:type rdf:Property ;
    rdfs:label 'Rated Capacity' ;
    rdfs:comment 'Maximum production capacity of the work center expressed in units per time period, used for Material Requirements Planning (MRP) capacity calculations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requalificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Requalification Due Date' ;
    rdfs:comment 'Date by which the work center must undergo requalification to maintain GMP compliance and production authorization.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyCertification rdf:type rdf:Property ;
    rdfs:label 'Safety Certification' ;
    rdfs:comment 'Safety certifications held by this work center such as CE marking, UL listing, or other regulatory approvals required for operation.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Setup Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to prepare the work center for production, including changeover and configuration activities.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Cycle Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to complete one production cycle or unit at this work center, used for scheduling and costing.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardRate rdf:type rdf:Property ;
    rdfs:label 'Standard Rate' ;
    rdfs:comment 'The standard rate of the work center record' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardRatePerHour rdf:type rdf:Property ;
    rdfs:label 'Standard Rate Per Hour' ;
    rdfs:comment 'The standard rate per hour of the work center record' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teardownTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to clean, sanitize, and reset the work center after production completion per Good Manufacturing Practice (GMP) requirements.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether this work center operates in a temperature-controlled environment requiring environmental monitoring per GMP standards.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utilizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Percent' ;
    rdfs:comment 'Target utilization rate as a percentage of available capacity, used for capacity planning and Overall Equipment Effectiveness (OEE) benchmarking.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Work Center Status' ;
    rdfs:comment 'Current operational status of the work center indicating availability for production scheduling and capacity planning.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterType rdf:type rdf:Property ;
    rdfs:label 'Work Center Type' ;
    rdfs:comment 'Classification of the work center by its primary function in the manufacturing process. Categorizes equipment by operational role.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingBomId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Bom Id' ;
    rdfs:comment 'Unique identifier for the bill of materials record. Primary key for the manufacturing BOM entity.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufacturingBom .

ind:primaryManufacturingSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Manufacturing Sku Id' ;
    rdfs:comment 'Reference to the finished good or semi-finished SKU that this BOM defines. Links to the product master for which this material structure applies.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:allergenFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Flag' ;
    rdfs:comment 'Indicates whether this component contains or may contain allergens as defined by FDA and EU REACH regulations. True if allergen present. Used for product labeling, consumer safety warnings, and regulatory compliance.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternativeItemPriority rdf:type rdf:Property ;
    rdfs:label 'Alternative Item Priority' ;
    rdfs:comment 'The selection priority for this component within its alternative item group. Lower numbers indicate higher priority. Used by MRP to determine preferred material selection when multiple alternatives are available.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'The name or identifier of the person who approved this BOM version for production use. Required for GMP compliance and quality assurance. Typically a product development manager, quality manager, or regulatory affairs specialist.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Indicates whether this component is automatically consumed (backflushed) when the finished good is confirmed in the MES system, rather than requiring explicit material issue transactions. True if backflushed. Common for high-volume, low-value components.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the base quantity (e.g., EA for each, KG for kilogram, L for liter, BOX for box). Must align with the SKU primary UOM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM. Active BOMs are used for production planning and MRP runs. Inactive or obsolete BOMs are retained for historical reference and regulatory traceability.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentEffectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Component Effective End Date' ;
    rdfs:comment 'The date after which this specific component is no longer valid within the BOM structure. Nullable for open-ended components. Used for material phase-out and supplier transition management.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:componentEffectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Component Effective Start Date' ;
    rdfs:comment 'The date from which this specific component becomes valid within the BOM structure. Supports phased material transitions, supplier changes, and cost optimization initiatives.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:componentItemCategory rdf:type rdf:Property ;
    rdfs:label 'Component Item Category' ;
    rdfs:comment 'Classification of the component type. Stock items are inventory-managed materials, non-stock are direct procurement items, phantom are intermediate assemblies not physically stocked, text items are instructions, and variable size items have flexible dimensions.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentQuantity rdf:type rdf:Property ;
    rdfs:label 'Component Quantity' ;
    rdfs:comment 'The quantity of this component required to produce the base quantity of the finished good. Used for MRP explosion, production order material requirements, and COGS calculation.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Component Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the component quantity (e.g., KG for raw materials, EA for packaging units, L for liquids). Must align with the component material master UOM.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Percentage' ;
    rdfs:comment 'The percentage of total product cost attributed to this component. Used for COGS calculation, profitability analysis, and cost optimization initiatives. Sum of all component cost allocations should equal 100% for the BOM.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalComponentFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Component Flag' ;
    rdfs:comment 'Indicates whether this component is critical for product quality, safety, or regulatory compliance. True if critical. Triggers enhanced quality control, supplier qualification requirements, and inventory safety stock policies.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The date after which this BOM version is no longer valid for new production orders. Nullable for open-ended BOMs. Used for phase-out management and regulatory compliance transitions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The date from which this BOM version becomes valid for production planning and MRP explosion. Supports planned material transitions and new product launches.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotSizeRequirement rdf:type rdf:Property ;
    rdfs:label 'Lot Size Requirement' ;
    rdfs:comment 'Defines the lot sizing rule for this component in production orders. Exact requires precise quantity, minimum allows overages, multiple requires quantities in specific increments, none has no restriction. Impacts material planning and waste management.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingBomStatus rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Bom Status' ;
    rdfs:comment 'The manufacturing bom status of the manufacturing bom record' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumLotSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Lot Size' ;
    rdfs:comment 'The minimum quantity that must be procured or produced for this component. Driven by supplier MOQ, production batch constraints, or economic order quantity calculations. Nullable if no minimum applies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plmSystemReference rdf:type rdf:Property ;
    rdfs:label 'Plm System Reference' ;
    rdfs:comment 'External reference identifier linking this BOM to the source PLM system record. Enables traceability to engineering change orders, formulation documents, and R&D specifications.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text field capturing regulatory compliance requirements, restrictions, or special handling instructions for this component. Includes FDA registration numbers, EU REACH compliance status, GMP requirements, and safety data sheet references.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapFactorPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Percentage' ;
    rdfs:comment 'The expected waste or loss percentage for this component during production. Used to adjust gross material requirements in MRP runs. Typical values range from 0% to 10% depending on material type and process complexity.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Unique identifier for the production routing master record. Primary key.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when this routing was approved for production use. Supports audit trail and compliance requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeoverTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Minutes' ;
    rdfs:comment 'Time required to transition production lines from the previous product to this routing. Critical for production scheduling and minimizing downtime.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the standard cost amount.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedScrapPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Scrap Percentage' ;
    rdfs:comment 'Overall expected scrap percentage for the routing, representing anticipated waste or defects. Used for material planning and cost estimation.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Yield Percentage' ;
    rdfs:comment 'Overall expected yield percentage for the routing, representing the ratio of good output to total input. Used for production planning and variance analysis.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Critical Flag' ;
    rdfs:comment 'Indicates whether this routing includes GMP-critical operations requiring enhanced documentation, validation, and compliance controls per ISO 22716 and FDA regulations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipcCheckpointCount rdf:type rdf:Property ;
    rdfs:label 'Ipc Checkpoint Count' ;
    rdfs:comment 'Number of in-process control checkpoints defined in this routing. IPC checkpoints are quality inspection points during production per ISO 22716 and GMP requirements.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotSizeRestriction rdf:type rdf:Property ;
    rdfs:label 'Lot Size Restriction' ;
    rdfs:comment 'Constraint on production lot sizes for this routing. Fixed requires exact base quantity; minimum/maximum define bounds; multiple requires lot sizes to be multiples of base quantity; none allows any lot size.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumLotSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Lot Size' ;
    rdfs:comment 'Maximum production lot size allowed for this routing. Nullable if no maximum constraint exists.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationCount rdf:type rdf:Property ;
    rdfs:label 'Operation Count' ;
    rdfs:comment 'The operation count of the routing record' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationDescription rdf:type rdf:Property ;
    rdfs:label 'Operation Description' ;
    rdfs:comment 'The operation description of the routing record' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationSequence rdf:type rdf:Property ;
    rdfs:label 'Operation Sequence' ;
    rdfs:comment 'JSON array or delimited string capturing the complete sequence of operation steps. Each operation includes: operation_number, work_center_code, operation_description, control_key (internal_processing|external_processing|milestone), setup_time_minutes, machine_time_minutes, labor_time_minutes, yield_quantity, scrap_percentage, gmp_critical_step_flag, ipc_checkpoint_flag. This is the single authoritative source for all routing operation data — no separate operation entity exists.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionSchedulerCode rdf:type rdf:Property ;
    rdfs:label 'Production Scheduler Code' ;
    rdfs:comment 'Code identifying the production scheduling strategy or algorithm used for this routing (e.g., forward scheduling, backward scheduling, finite capacity).' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Business identifier for the routing. Externally-known unique code used in production planning and scheduling systems.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Status' ;
    rdfs:comment 'Current lifecycle status of the routing. Active routings are available for production scheduling; draft routings are under development; inactive routings are temporarily disabled; obsolete routings are retired; under_review routings are pending approval.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingType rdf:type rdf:Property ;
    rdfs:label 'Routing Type' ;
    rdfs:comment 'Classification of the routing defining its usage pattern. Standard routings are default production paths; reference routings are templates; rate routings define production rates; alternative routings provide backup paths; special routings are for one-time or custom production runs.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runTimePerUnitMinutes rdf:type rdf:Property ;
    rdfs:label 'Run Time Per Unit Minutes' ;
    rdfs:comment 'The run time per unit minutes of the routing record' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCostAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Amount' ;
    rdfs:comment 'Standard production cost per base quantity for this routing, including labor, machine, and overhead costs. Used for cost accounting and variance analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLaborTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Labor Time Minutes' ;
    rdfs:comment 'Cumulative labor time across all operations in the routing, used for workforce planning and standard cost calculation.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMachineTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Machine Time Minutes' ;
    rdfs:comment 'Cumulative machine processing time across all operations in the routing, used for capacity planning and Overall Equipment Effectiveness (OEE) calculations.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSetupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Setup Time Minutes' ;
    rdfs:comment 'Cumulative setup time across all operations in the routing, used for capacity planning and scheduling.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStandardLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Standard Lead Time Hours' ;
    rdfs:comment 'Total cumulative lead time in hours required to complete all operations in this routing, including setup, processing, and queue times. Used for Material Requirements Planning (MRP) and capacity planning.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStandardTimeMin rdf:type rdf:Property ;
    rdfs:label 'Total Standard Time Min' ;
    rdfs:comment 'The total standard time min of the routing record' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Order Id' ;
    rdfs:comment 'Unique identifier for the production order. Primary key for the production order entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:demandPlanId rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Id' ;
    rdfs:comment 'Foreign key linking to supply.demand_plan. Business justification: S&OP/IBP demand fulfillment traceability: production orders are created to fulfill demand plans. Planners require this link for demand-supply variance analysis and S&OP cycle supply review reporting. ' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandPlan .

ind:marketingBrandId rdf:type rdf:Property ;
    rdfs:label 'Marketing Brand Id' ;
    rdfs:comment 'Foreign key linking to marketing.brand. Business justification: Production Planning Dashboard ties orders to brands to enable demand forecasting and coordinated marketing launch planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingBrand .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Foreign key linking to sales.order. Business justification: Order fulfillment process requires linking each production order to the originating sales order to track manufacturing against sales commitments.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:sopCycleId rdf:type rdf:Property ;
    rdfs:label 'Sop Cycle Id' ;
    rdfs:comment 'Foreign key linking to supply.sop_cycle. Business justification: S&OP cycle production performance reporting: production orders are released within a specific S&OP cycle. This link enables actual vs planned production volume reconciliation at cycle level — a standa' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SopCycle .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual cost incurred for the production order. Includes material, labor, and overhead costs. Used for variance analysis.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEnd rdf:type rdf:Property ;
    rdfs:label 'Actual End' ;
    rdfs:comment 'The actual end of the production order record' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'The actual end date of the production order record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Timestamp' ;
    rdfs:comment 'Actual date and time when production execution completed. Used for OEE calculation and performance analysis.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStart rdf:type rdf:Property ;
    rdfs:label 'Actual Start' ;
    rdfs:comment 'The actual start of the production order record' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'The actual start date of the production order record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when production execution began on the shop floor. Captured from MES system.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Unique batch or lot number assigned to the production run. Critical for traceability and recall management per GMP requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'Actual quantity produced and confirmed as good output. Represents yield after quality inspection.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costObject rdf:type rdf:Property ;
    rdfs:label 'Cost Object' ;
    rdfs:comment 'Cost object (production order number or process order) used for collecting actual costs. Links to CO-PC product costing.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Minutes' ;
    rdfs:comment 'Total unplanned downtime in minutes during production execution. Impacts OEE availability component.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'Inspection lot number created for quality control of the production output. Links to QM inspection results.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpController rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller' ;
    rdfs:comment 'Three-character code identifying the MRP controller responsible for planning this material. Links to planner master data.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeePercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Percentage' ;
    rdfs:comment 'Overall Equipment Effectiveness percentage for this production run. Calculated as Availability × Performance × Quality. Industry standard KPI.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business identifier for the production order. Externally-known unique order number assigned by SAP S/4HANA PP system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Quantity' ;
    rdfs:comment 'Planned quantity to be produced in base unit of measure. Target output for the production order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the production order. CRTD=Created, REL=Released, PCNF=Partially Confirmed, TECO=Technically Complete, CNF=Confirmed, DLV=Delivered, CLSD=Closed. [ENUM-REF-CANDIDATE: CRTD|REL|PCNF|TECO|CNF|DLV|CLSD — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of production order. PP01=Standard Production, PP03=Rework, PP05=Co-Product, PP10=Process Order, PP20=Batch Order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCost rdf:type rdf:Property ;
    rdfs:label 'Planned Cost' ;
    rdfs:comment 'Standard or planned cost for producing the order quantity. Calculated from BOM and routing costs.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'The planned quantity of the production order record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level for production scheduling. 1=Highest priority (rush/expedite), 5=Lowest priority (standard). Used for sequencing and resource allocation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionSupervisor rdf:type rdf:Property ;
    rdfs:label 'Production Supervisor' ;
    rdfs:comment 'Name of the production supervisor responsible for overseeing execution of this order on the shop floor.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Indicates whether quality inspection is mandatory before goods receipt. Drives QM integration and inspection lot creation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releasedBy rdf:type rdf:Property ;
    rdfs:label 'Released By' ;
    rdfs:comment 'User ID of the person who released the production order for execution. Audit trail for production authorization.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'Date and time when the production order was released for shop floor execution. Triggers material availability check and capacity reservation.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledEnd rdf:type rdf:Property ;
    rdfs:label 'Scheduled End' ;
    rdfs:comment 'The scheduled end of the production order record' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'The scheduled end date of the production order record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledFinishDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Date' ;
    rdfs:comment 'Planned date when production is scheduled to complete. Used for capacity planning and delivery commitments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStart rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start' ;
    rdfs:comment 'The scheduled start of the production order record' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date when production is scheduled to begin. Set during production planning and MRP run.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'Quantity of material scrapped or rejected during production. Used for yield analysis and cost accounting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementRule rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule' ;
    rdfs:comment 'Rule for settling production order costs. FUL=Full settlement, PAR=Partial settlement, PER=Periodic settlement.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'Actual yield percentage calculated as (confirmed_quantity / order_quantity) * 100. Key performance metric for production efficiency.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchRecordId rdf:type rdf:Property ;
    rdfs:label 'Batch Record Id' ;
    rdfs:comment 'Unique identifier for the electronic batch manufacturing record (eBMR). Primary key for GMP-compliant batch traceability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to procurement.goods_receipt. Business justification: GMP regulations in consumer goods require batch records to document the specific goods receipt (and supplier lot) of each raw material consumed. This lot genealogy link is mandatory for recall managem' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Actual cost per unit incurred for this batch. Includes material, labor, and overhead variances.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeActual rdf:type rdf:Property ;
    rdfs:label 'Batch Size Actual' ;
    rdfs:comment 'Actual production quantity achieved for this batch. Used for yield calculation and inventory reconciliation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizePlanned rdf:type rdf:Property ;
    rdfs:label 'Batch Size Planned' ;
    rdfs:comment 'Planned production quantity for this batch as specified in the production order. Measured in base unit of measure.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the batch. Controls inventory availability and distribution eligibility per GMP workflow.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Minutes' ;
    rdfs:comment 'Time in minutes required for line changeover before this batch. Key metric for SMED and lean manufacturing initiatives.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:electronicSignatureCount rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Count' ;
    rdfs:comment 'Number of electronic signatures captured during batch record lifecycle. Required for FDA 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Gmp Deviation Count' ;
    rdfs:comment 'Number of GMP deviations recorded for this batch. Used for quality trend analysis and CAPA tracking.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Deviation Flag' ;
    rdfs:comment 'Indicates whether any GMP deviations were recorded during batch production. Triggers quality review workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpReviewed rdf:type rdf:Property ;
    rdfs:label 'Gmp Reviewed' ;
    rdfs:comment 'The gmp reviewed of the batch record record' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotGenealogyCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Lot Genealogy Complete Flag' ;
    rdfs:comment 'Indicates whether complete raw material lot traceability has been captured for this batch. Required for recall readiness.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'The manufacture date of the batch record record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturedQuantity rdf:type rdf:Property ;
    rdfs:label 'Manufactured Quantity' ;
    rdfs:comment 'The manufactured quantity of the batch record record' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'Calendar date of batch production. Printed on product packaging for consumer information and regulatory compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing End Timestamp' ;
    rdfs:comment 'Date and time when batch production was completed and final packaging finished. Used for cycle time analysis.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manufacturingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Start Timestamp' ;
    rdfs:comment 'Date and time when batch production was initiated on the shop floor. Captured from MES system.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Release Flag' ;
    rdfs:comment 'Indicates whether the batch has been released by Quality Assurance for distribution. Required before inventory availability.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Quality Release Timestamp' ;
    rdfs:comment 'Date and time when Quality Assurance approved the batch for release. Marks transition from quarantine to available inventory.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityProduced rdf:type rdf:Property ;
    rdfs:label 'Quantity Produced' ;
    rdfs:comment 'The quantity produced of the batch record record' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether this batch is subject to a product recall. Triggers supply chain hold and customer notification.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Recall Initiated Date' ;
    rdfs:comment 'Date when recall was initiated for this batch. Used for regulatory reporting and recall effectiveness tracking.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordLockedFlag rdf:type rdf:Property ;
    rdfs:label 'Record Locked Flag' ;
    rdfs:comment 'Indicates whether this batch record is locked from further edits. Required for GMP record integrity after quality release.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether batch is on regulatory hold pending investigation or approval. Prevents distribution until cleared.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'The release date of the batch record record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:released rdf:type rdf:Property ;
    rdfs:label 'Released' ;
    rdfs:comment 'The released of the batch record record' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewByException rdf:type rdf:Property ;
    rdfs:label 'Review By Exception' ;
    rdfs:comment 'The review by exception of the batch record record' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reworkQuantity rdf:type rdf:Property ;
    rdfs:label 'Rework Quantity' ;
    rdfs:comment 'Quantity of product requiring rework during batch production. Indicator of process capability and quality issues.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:veevaVaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Reference' ;
    rdfs:comment 'Reference to the master batch record document stored in Veeva Vault. Links to regulatory document management system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Production Confirmation Id' ;
    rdfs:comment 'Unique identifier for the production confirmation record. Primary key for shop floor execution tracking.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'SAP CO activity type code representing the type of work performed (e.g., machine hours, labor hours, setup hours) for cost allocation purposes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual date and time when the operation was completed and confirmed by the operator. Used for OEE calculation and production order settlement.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLaborTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Time Minutes' ;
    rdfs:comment 'Actual operator labor time spent on this operation including manual work, monitoring, and quality checks. Measured in minutes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMachineTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Machine Time Minutes' ;
    rdfs:comment 'Actual time the machine or equipment was actively running during this operation. Excludes setup and downtime. Measured in minutes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSetupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Setup Time Minutes' ;
    rdfs:comment 'Actual time spent on machine setup, changeover, and preparation activities before production began. Measured in minutes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual date and time when the operator began executing this operation on the shop floor. Captured from MES or manual confirmation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationNotes rdf:type rdf:Property ;
    rdfs:label 'Confirmation Notes' ;
    rdfs:comment 'Free-text notes or comments entered by the operator or supervisor regarding this operation execution, including any issues or observations.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'The confirmation number of the production confirmation record' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'System timestamp when this confirmation record was created and submitted to the ERP or MES system.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationType rdf:type rdf:Property ;
    rdfs:label 'Confirmation Type' ;
    rdfs:comment 'Classification of the confirmation event indicating whether this is a partial progress update, final completion, milestone checkpoint, rework confirmation, or cancellation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedScrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Scrap Quantity' ;
    rdfs:comment 'Actual quantity of defective or waste material generated during this operation. Used for yield variance analysis and quality tracking.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedYieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Yield Quantity' ;
    rdfs:comment 'Actual quantity of good output produced and confirmed for this operation. Measured in the base unit of measure for the material.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborHours rdf:type rdf:Property ;
    rdfs:label 'Labor Hours' ;
    rdfs:comment 'The labor hours of the production confirmation record' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineHours rdf:type rdf:Property ;
    rdfs:label 'Machine Hours' ;
    rdfs:comment 'The machine hours of the production confirmation record' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Mes Transaction Reference' ;
    rdfs:comment 'Unique transaction reference from the Siemens Opcenter MES system that originated this confirmation. Used for traceability and system reconciliation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeAvailabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Availability Percent' ;
    rdfs:comment 'Calculated availability component of OEE for this operation, representing the percentage of scheduled time that equipment was available for production.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeePerformancePercent rdf:type rdf:Property ;
    rdfs:label 'Oee Performance Percent' ;
    rdfs:comment 'Calculated performance component of OEE for this operation, representing actual production speed versus ideal speed.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeQualityPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Quality Percent' ;
    rdfs:comment 'Calculated quality component of OEE for this operation, representing the percentage of good output versus total output produced.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationStatus rdf:type rdf:Property ;
    rdfs:label 'Operation Status' ;
    rdfs:comment 'Current lifecycle status of the manufacturing operation indicating its execution state in the production workflow.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'Financial posting date when this confirmation was recorded in the ERP system for inventory and cost accounting purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether this operation output requires quality inspection before release to inventory or next operation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this confirmation has been reversed or cancelled due to error correction or process adjustment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Standardized code explaining why this confirmation was reversed, if applicable. Used for process improvement and error tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Flag' ;
    rdfs:comment 'Indicates whether this confirmation represents a rework operation to correct defects from a previous production run.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'Planned completion date and time for this operation as determined by production scheduling or MES system.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'Planned start date and time for this operation as determined by production scheduling or MES system.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Production shift identifier during which this operation was executed (e.g., SHIFT_1, DAY, NIGHT). Used for shift performance analysis.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Standardized code explaining any significant variance between planned and actual quantities or times. Used for root cause analysis.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Business identifier for the work order assigned to this manufacturing operation. Externally visible reference used across shop floor systems.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Yield Quantity' ;
    rdfs:comment 'The yield quantity of the production confirmation record' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedOrderId rdf:type rdf:Property ;
    rdfs:label 'Planned Order Id' ;
    rdfs:comment 'Unique system-generated identifier for the planned order record. Primary key for the planned order entity.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:convertedProductionOrderId rdf:type rdf:Property ;
    rdfs:label 'Converted Production Order Id' ;
    rdfs:comment 'Reference to the production order that was created from this planned order upon conversion. Null if not yet converted.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:destinationNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Network Node Id' ;
    rdfs:comment 'Foreign key linking to supply.network_node. Business justification: Supply network destination planning: planned orders specify which supply network node will receive the produced goods. Role-prefixed \'destination_\' distinguishes from the source manufacturing facility' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:distributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Distribution Facility Id' ;
    rdfs:comment 'Foreign key linking to distribution.distribution_facility. Business justification: MRP/IBP planned orders in consumer goods are generated to replenish specific distribution centers. DC replenishment planning, OTIF reporting, and supply network optimization all require knowing which ' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:dtcOrderId rdf:type rdf:Property ;
    rdfs:label 'Dtc Order Id' ;
    rdfs:comment 'Foreign key linking to consumer.dtc_order. Business justification: Make-to-Order DTC Demand Traceability: In DTC consumer goods, individual DTC orders trigger make-to-order MRP planned production runs. Linking planned_order to dtc_order enables operations teams to tr' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DtcOrder .

ind:availabilityDate rdf:type rdf:Property ;
    rdfs:label 'Availability Date' ;
    rdfs:comment 'The date when the produced or procured material from this planned order is expected to be available for consumption or shipment.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'The date when this planned order was converted to a production order. Null if not yet converted.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'Indicates whether this planned order has been converted to a production order: NOT_CONVERTED (still in planning), PARTIALLY_CONVERTED (split conversion), FULLY_CONVERTED (completely converted).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User ID or system identifier of the person or automated process that created this planned order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSourceType rdf:type rdf:Property ;
    rdfs:label 'Demand Source Type' ;
    rdfs:comment 'Classification of the demand signal that triggered this planned order: FORECAST (demand planning), CUSTOMER_ORDER (firm sales order), STOCK_TRANSFER (inter-plant), SAFETY_STOCK (replenishment), PROMOTION (trade promotion demand).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionMessageCode rdf:type rdf:Property ;
    rdfs:label 'Exception Message Code' ;
    rdfs:comment 'Code representing MRP exception conditions (e.g., EX01 = reschedule in, EX02 = reschedule out, EX03 = cancel, EX10 = expedite). Empty if no exception.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionMessageText rdf:type rdf:Property ;
    rdfs:label 'Exception Message Text' ;
    rdfs:comment 'Human-readable description of the MRP exception condition requiring planner attention.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmedFlag rdf:type rdf:Property ;
    rdfs:label 'Firmed Flag' ;
    rdfs:comment 'The firmed flag of the planned order record' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firmingDate rdf:type rdf:Property ;
    rdfs:label 'Firming Date' ;
    rdfs:comment 'The date when this planned order was firmed by a planner. Null if not yet firmed.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firmingIndicator rdf:type rdf:Property ;
    rdfs:label 'Firming Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this planned order is firmed (locked from automatic MRP changes). True = firmed, False = subject to MRP rescheduling.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ibpPlanVersion rdf:type rdf:Property ;
    rdfs:label 'Ibp Plan Version' ;
    rdfs:comment 'Version identifier from SAP IBP system that generated the demand signal driving this planned order. Format: IBP-YYYYMM.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User ID or system identifier of the person or automated process that last modified this planned order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeKey rdf:type rdf:Property ;
    rdfs:label 'Lot Size Key' ;
    rdfs:comment 'Code indicating the lot-sizing procedure used: EX (exact lot size), HB (lot-for-lot), FX (fixed lot size), PD (periodic lot size), WM (weekly lot size).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpRunCode rdf:type rdf:Property ;
    rdfs:label 'Mrp Run Code' ;
    rdfs:comment 'Reference to the specific MRP run that generated or last modified this planned order. Links to MRP execution history.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrpRunDate rdf:type rdf:Property ;
    rdfs:label 'Mrp Run Date' ;
    rdfs:comment 'The mrp run date of the planned order record' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'The planned end date of the planned order record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Planned Order Number' ;
    rdfs:comment 'The planned order number of the planned order record' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'The planned start date of the planned order record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriod rdf:type rdf:Property ;
    rdfs:label 'Planning Period' ;
    rdfs:comment 'The planning time bucket this order belongs to, expressed as YYYY-Wnn (week), YYYY-Mnn (month), or YYYY-Qn (quarter). Used for MPS and S&OP alignment.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningStrategyGroup rdf:type rdf:Property ;
    rdfs:label 'Planning Strategy Group' ;
    rdfs:comment 'Two-digit code defining the planning strategy (e.g., 10 = make-to-stock, 20 = make-to-order, 40 = planning with final assembly, 50 = planning without final assembly).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Priority level assigned to this planned order for scheduling and resource allocation: LOW, NORMAL, HIGH, URGENT.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'The inventory level that triggers generation of a planned order for replenishment.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'The safety stock level maintained for this SKU at this plant, influencing planned order generation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version identifier for the MPS schedule that generated or governs this planned order. Enables tracking of schedule changes over time.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentId rdf:type rdf:Property ;
    rdfs:label 'Equipment Id' ;
    rdfs:comment 'Primary key for equipment' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:parentEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Equipment Id' ;
    rdfs:comment 'Self-referencing FK on equipment (parent_equipment_id)' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Purchase price paid for the equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetTag rdf:type rdf:Property ;
    rdfs:label 'Asset Tag' ;
    rdfs:comment 'Internal tag or barcode used to physically label the equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Units' ;
    rdfs:comment 'Unit of measure for the equipment\'s capacity.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityValue rdf:type rdf:Property ;
    rdfs:label 'Capacity Value' ;
    rdfs:comment 'Numeric capacity of the equipment expressed in the specified units.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceGmp rdf:type rdf:Property ;
    rdfs:label 'Compliance Gmp' ;
    rdfs:comment 'Indicates whether the equipment complies with GMP standards.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'Currency in which the acquisition cost is expressed.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organizational department responsible for the equipment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationEndDate rdf:type rdf:Property ;
    rdfs:label 'Depreciation End Date' ;
    rdfs:comment 'Date when the equipment is fully depreciated.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationStartDate rdf:type rdf:Property ;
    rdfs:label 'Depreciation Start Date' ;
    rdfs:comment 'Date when depreciation of the equipment begins.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:energyConsumptionKwh rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh' ;
    rdfs:comment 'Total energy consumed by the equipment in kilowatt-hours.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Status' ;
    rdfs:comment 'Current operational state of the equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Category of equipment based on function or form factor.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installDate rdf:type rdf:Property ;
    rdfs:label 'Install Date' ;
    rdfs:comment 'The install date of the equipment record' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date the equipment was installed and became operational.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent scheduled maintenance.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Code identifying the plant or facility where the equipment resides.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceCost rdf:type rdf:Property ;
    rdfs:label 'Maintenance Cost' ;
    rdfs:comment 'Cost incurred for the most recent maintenance activity.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Maintenance Frequency Days' ;
    rdfs:comment 'Number of days between routine maintenance events.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Company that produced the equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtbfHours rdf:type rdf:Property ;
    rdfs:label 'Mtbf Hours' ;
    rdfs:comment 'Average operating hours between equipment failures.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mttrHours rdf:type rdf:Property ;
    rdfs:label 'Mttr Hours' ;
    rdfs:comment 'Average time required to repair equipment after a failure.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Date' ;
    rdfs:comment 'The next calibration date of the equipment record' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'The next maintenance date of the equipment record' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextMaintenanceDue rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due' ;
    rdfs:comment 'Planned date for the next maintenance activity.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oeeActual rdf:type rdf:Property ;
    rdfs:label 'Oee Actual' ;
    rdfs:comment 'Measured Overall Equipment Effectiveness percentage.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeTarget rdf:type rdf:Property ;
    rdfs:label 'Oee Target' ;
    rdfs:comment 'Target Overall Equipment Effectiveness percentage.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerRatingKw rdf:type rdf:Property ;
    rdfs:label 'Power Rating Kw' ;
    rdfs:comment 'Maximum power consumption of the equipment in kilowatts.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyRating rdf:type rdf:Property ;
    rdfs:label 'Safety Rating' ;
    rdfs:comment 'Safety classification of the equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUsageHours rdf:type rdf:Property ;
    rdfs:label 'Total Usage Hours' ;
    rdfs:comment 'Cumulative operating hours since installation.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voltage rdf:type rdf:Property ;
    rdfs:label 'Voltage' ;
    rdfs:comment 'Nominal operating voltage of the equipment.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shopperId rdf:type rdf:Property ;
    rdfs:label 'Shopper Id' ;
    rdfs:comment 'Unique surrogate identifier for every end consumer and shopper record in the Consumer Goods golden master. This is the anchor primary key for the entire consumer domain — all other consumer entities reference this record. Role: MASTER_PARTY.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shopper .

ind:consumerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Consumer Segment Id' ;
    rdfs:comment 'Foreign key linking to marketing.consumer_segment. Business justification: Shopper-to-segment assignment drives personalization, campaign targeting, and CLTV modeling. Marketing teams must know which consumer segment each shopper belongs to for 1:1 campaign execution and seg' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsumerSegment .

ind:preferredRetailStoreId rdf:type rdf:Property ;
    rdfs:label 'Preferred Retail Store Id' ;
    rdfs:comment 'Foreign key linking to sales.retail_store. Business justification: CPG consumer profiles track a shopper\'s preferred/home store for personalization, store-level marketing, and loyalty program management. `preferred_store_banner` is a denormalized text field; replacin' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailStore .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'The channel through which the consumer was first acquired or registered. Supports marketing attribution, channel ROI analysis, and consumer journey analytics. Aligns with DTC, POS, and loyalty enrollment touchpoints. [ENUM-REF-CANDIDATE: dtc_web|dtc_mobile|retail_pos|loyalty_enrollment|social_media|event|referral|wholesale — promote to reference product]' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'The date on which the consumer was first acquired or registered in the system (yyyy-MM-dd). Used for cohort analysis, consumer tenure calculations, and lifecycle marketing programs.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ageVerified rdf:type rdf:Property ;
    rdfs:label 'Age Verified' ;
    rdfs:comment 'Indicates whether the consumer has passed age verification for access to age-restricted products (e.g., alcohol, tobacco, certain health products). TRUE = age verified; FALSE = not verified. Required for regulatory compliance with FDA and CPSC age-restriction mandates.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:birthDate rdf:type rdf:Property ;
    rdfs:label 'Birth Date' ;
    rdfs:comment 'The consumer\'s date of birth in ISO 8601 format (yyyy-MM-dd). Used for age verification (e.g., age-restricted products), lifecycle segmentation, birthday loyalty rewards, and regulatory compliance.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ccpaSubject rdf:type rdf:Property ;
    rdfs:label 'Ccpa Subject' ;
    rdfs:comment 'Indicates whether this consumer is a California resident subject to CCPA protections. TRUE = CCPA applies; FALSE = not a CCPA subject. Drives opt-out of sale workflows, data deletion requests, and disclosure obligations.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'The exact date and time (ISO 8601 with timezone) when the consumer last provided or updated their privacy consent. Provides the auditable consent record required by GDPR Article 7 and CCPA. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'The version identifier of the privacy policy and consent notice that the consumer accepted (e.g., \'v2.3\', \'2024-01\'). Used to track consent currency and trigger re-consent workflows when policy versions are updated.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerType rdf:type rdf:Property ;
    rdfs:label 'Consumer Type' ;
    rdfs:comment 'Categorical classification of the shopper record distinguishing individual consumers, household accounts, small business buyers, enrolled loyalty program members, and guest/anonymous shoppers. Drives CRM segmentation and personalization strategy.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the consumer has consented to sharing their personal data with third-party partners (e.g., retail partners, market research firms such as Nielsen IQ). TRUE = consented; FALSE = not consented. Critical for GDPR Article 6 lawful basis and CCPA opt-out compliance.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'The date of birth of the shopper record' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:displayName rdf:type rdf:Property ;
    rdfs:label 'Display Name' ;
    rdfs:comment 'The consumer\'s preferred display name or alias used in digital channels, loyalty portals, and personalized marketing communications. May differ from legal name.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'The email of the shopper record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptIn rdf:type rdf:Property ;
    rdfs:label 'Email Opt In' ;
    rdfs:comment 'Indicates whether the consumer has provided explicit opt-in consent to receive email marketing communications. TRUE = consented; FALSE = not consented or withdrawn. Mandatory suppression flag for GDPR/CCPA compliance in all outbound email campaigns.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'The consumer\'s legal family name (surname) as captured at registration or identity verification. Combined with given_name to form the full legal identity for CRM, personalization, and regulatory compliance.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'The first name of the shopper record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'First Purchase Date' ;
    rdfs:comment 'The first purchase date of the shopper record' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprSubject rdf:type rdf:Property ;
    rdfs:label 'Gdpr Subject' ;
    rdfs:comment 'Indicates whether this consumer is a GDPR data subject (i.e., located in the EU/EEA and subject to GDPR protections). TRUE = GDPR applies; FALSE = not a GDPR subject. Drives data processing lawful basis checks, right-to-erasure workflows, and data portability requests.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'The consumer\'s self-reported gender identity. Used for consumer segmentation, personalized product recommendations, and inclusive marketing. Collected with explicit consent per GDPR/CCPA.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:givenName rdf:type rdf:Property ;
    rdfs:label 'Given Name' ;
    rdfs:comment 'The consumer\'s legal given name (first name) as captured at registration or identity verification. Used for personalized communications, CRM, and regulatory subject identification under GDPR/CCPA.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Date' ;
    rdfs:comment 'The date on which the consumer\'s identity was most recently verified (yyyy-MM-dd). Used to assess verification recency and trigger re-verification workflows for high-risk transactions or regulatory audits.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identityVerified rdf:type rdf:Property ;
    rdfs:label 'Identity Verified' ;
    rdfs:comment 'Indicates whether the consumer\'s identity has been formally verified through an identity verification process (e.g., email confirmation, document verification, phone OTP). TRUE = verified; FALSE = unverified. Affects eligibility for high-value loyalty redemptions and DTC account features.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'The language preference of the shopper record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Activity Timestamp' ;
    rdfs:comment 'The last activity timestamp of the shopper record' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'The last name of the shopper record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'The date of the consumer\'s most recent confirmed purchase transaction across any channel (DTC, retail POS, e-commerce). Used for recency scoring in RFM (Recency, Frequency, Monetary) analysis, churn prediction, and re-engagement campaign triggers.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimeValue rdf:type rdf:Property ;
    rdfs:label 'Lifetime Value' ;
    rdfs:comment 'The lifetime value of the shopper record' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Loyalty Enrollment Date' ;
    rdfs:comment 'The date the consumer formally enrolled in the loyalty program (yyyy-MM-dd). Used to calculate loyalty tenure, anniversary rewards, and cohort-based loyalty analytics.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Balance' ;
    rdfs:comment 'The current redeemable loyalty points balance held by the consumer. This is the raw operational balance as recorded in the loyalty system — not a calculated aggregate. Used for redemption eligibility checks and consumer-facing balance display.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyStatus rdf:type rdf:Property ;
    rdfs:label 'Loyalty Status' ;
    rdfs:comment 'The loyalty status of the shopper record' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyTier rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier' ;
    rdfs:comment 'The consumer\'s current tier within the loyalty program (e.g., Bronze, Silver, Gold, Platinum). Determines benefit entitlements, promotional eligibility, and personalized offer thresholds. Recalculated periodically based on purchase activity.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'The most recently recorded Net Promoter Score (NPS) for this consumer, on a scale of 0–10. NPS is the industry-standard metric for measuring consumer loyalty and likelihood to recommend. Supports consumer satisfaction analytics and brand health reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Date' ;
    rdfs:comment 'The date on which the most recent NPS survey response was recorded for this consumer. Used to assess recency of satisfaction data and trigger re-survey workflows.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'The phone of the shopper record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'The consumer\'s preferred transaction currency in ISO 4217 three-letter code (e.g., \'USD\', \'EUR\', \'GBP\'). Used for DTC pricing display, loyalty point valuation, and cross-border e-commerce personalization.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'The consumer\'s preferred communication language in IETF BCP 47 format (e.g., \'en-US\', \'fr-FR\', \'es-MX\'). Drives localization of marketing communications, product labels, and digital experience personalization.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressCode rdf:type rdf:Property ;
    rdfs:label 'Primary Address Code' ;
    rdfs:comment 'The primary address id of the shopper record' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'The primary email address used for all consumer communications, loyalty program enrollment, DTC order confirmations, and digital marketing. Serves as the principal digital identity key in CRM and Salesforce Consumer Goods Cloud.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'The consumer\'s primary contact phone number in E.164 international format. Used for SMS marketing, two-factor authentication, consumer care, and DTC order notifications.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationOptIn rdf:type rdf:Property ;
    rdfs:label 'Push Notification Opt In' ;
    rdfs:comment 'Indicates whether the consumer has opted in to receive push notifications via the brand\'s mobile application. TRUE = opted in; FALSE = opted out or not set. Drives mobile engagement campaign eligibility.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Registration Source Url' ;
    rdfs:comment 'The URL or digital touchpoint from which the consumer completed their registration (e.g., brand website landing page, DTC checkout, loyalty sign-up page). Supports digital marketing attribution and campaign source tracking.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shopperStatus rdf:type rdf:Property ;
    rdfs:label 'Shopper Status' ;
    rdfs:comment 'The shopper status of the shopper record' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsOptIn rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In' ;
    rdfs:comment 'Indicates whether the consumer has provided explicit opt-in consent to receive SMS/text marketing communications. TRUE = consented; FALSE = not consented or withdrawn. Required for TCPA compliance in the US and equivalent regulations globally.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemConsumerRef rdf:type rdf:Property ;
    rdfs:label 'Source System Consumer Ref' ;
    rdfs:comment 'The consumer\'s unique identifier as recorded in the originating source system (e.g., SAP Business Partner ID, Salesforce Contact ID, DTC platform user ID). Enables cross-system reconciliation, MDM golden record matching, and audit traceability back to the system of record.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdId rdf:type rdf:Property ;
    rdfs:label 'Household Id' ;
    rdfs:comment 'Unique surrogate identifier for the household record in the Consumer Goods lakehouse. Primary key for all household-level analytics, loyalty pooling, and basket analysis.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:mergedFromHouseholdId rdf:type rdf:Property ;
    rdfs:label 'Merged From Household Id' ;
    rdfs:comment 'Reference to the source household record that was merged into this household during deduplication or household consolidation. Null if no merge has occurred. Supports data lineage and audit trails.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:addressSummary rdf:type rdf:Property ;
    rdfs:label 'Address Summary' ;
    rdfs:comment 'The address summary of the household record' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandAffinityFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Affinity Flag' ;
    rdfs:comment 'Indicates whether the household has demonstrated strong brand loyalty to the company\'s portfolio based on repeat purchase patterns and SOV (Share of Voice) analysis. Used for brand marketing investment decisions.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccpaOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Flag' ;
    rdfs:comment 'Indicates whether the household has exercised the right to opt out of the sale of personal information under CCPA (California Consumer Privacy Act). Mandatory compliance field for California-resident households.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:childrenPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Children Present Flag' ;
    rdfs:comment 'Indicates whether children under 18 are present in the household. Key trigger for cross-sell targeting of baby, child health, and family-oriented CPG/FMCG product categories.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cltvBand rdf:type rdf:Property ;
    rdfs:label 'Cltv Band' ;
    rdfs:comment 'Categorical CLTV (Customer Lifetime Value) band assigned to the household based on historical purchase behavior and predictive modeling. Used for investment prioritization in trade promotion and personalization.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to any consent or privacy preference for the household. Critical for GDPR/CCPA audit trails and demonstrating lawful basis for data processing.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Originating system or channel from which the household record was first created or last enriched. Used for data lineage, quality scoring, and source system reconciliation in the lakehouse. [ENUM-REF-CANDIDATE: crm|loyalty_program|ecommerce|panel|pos|dtc|manual — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalEngagementFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Engagement Flag' ;
    rdfs:comment 'Indicates whether the household actively engages with the brand through digital channels (e-commerce, mobile app, social media). Used for DTC (Direct to Consumer) channel strategy and omnichannel personalization.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'Date on which the household was dissolved, merged, or deactivated. Null for active households. Used for lifecycle reporting and GDPR/CCPA data retention compliance.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dwellingType rdf:type rdf:Property ;
    rdfs:label 'Dwelling Type' ;
    rdfs:comment 'Type of residential dwelling occupied by the household. Used for product category targeting (e.g., home care, cleaning products) and basket size normalization in CPG analytics.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedSize rdf:type rdf:Property ;
    rdfs:label 'Estimated Size' ;
    rdfs:comment 'Estimated number of individuals residing in the household. Used for basket size normalization, per-capita consumption analysis, and product volume forecasting in S&OP (Sales and Operations Planning).' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formationDate rdf:type rdf:Property ;
    rdfs:label 'Formation Date' ;
    rdfs:comment 'Date on which the household record was first established in the system, representing when the household unit was recognized as a distinct entity for loyalty and analytics purposes.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the household has provided valid consent for data processing under GDPR (General Data Protection Regulation). Mandatory for EU-resident households before any marketing or analytics processing.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Broad geographic region of the household\'s residence (e.g., Northeast, Southeast, Midwest, West, Southwest). Used for regional demand planning and distribution channel management.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasChildren rdf:type rdf:Property ;
    rdfs:label 'Has Children' ;
    rdfs:comment 'The has children of the household record' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:householdStatus rdf:type rdf:Property ;
    rdfs:label 'Household Status' ;
    rdfs:comment 'Current lifecycle state of the household record. \'merged\' indicates consolidation with another household; \'dissolved\' indicates the household no longer exists as a unit.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdType rdf:type rdf:Property ;
    rdfs:label 'Household Type' ;
    rdfs:comment 'Categorical classification of the household composition used for segmentation and cross-sell targeting in CPG/FMCG analytics. [ENUM-REF-CANDIDATE: single|couple|family|multi_generational|shared_living|other — promote to reference product if values expand]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeBand rdf:type rdf:Property ;
    rdfs:label 'Income Band' ;
    rdfs:comment 'Estimated annual household income bracket used for consumer segmentation, RSP (Recommended Selling Price) sensitivity analysis, and premium product targeting. Derived from third-party panel data or self-reported.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeBracket rdf:type rdf:Property ;
    rdfs:label 'Income Bracket' ;
    rdfs:comment 'The income bracket of the household record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifeStage rdf:type rdf:Property ;
    rdfs:label 'Life Stage' ;
    rdfs:comment 'Life stage classification of the household used for targeted marketing and NPD (New Product Development) insights (e.g., young_single, young_couple_no_children, family_with_young_children, family_with_teens, empty_nester, retired). Enables cross-sell triggers such as recommending baby products when life stage transitions. [ENUM-REF-CANDIDATE: young_single|young_couple_no_children|family_with_young_children|family_with_teens|empty_nester|retired|other — promote to reference product]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfChildren rdf:type rdf:Property ;
    rdfs:label 'Number Of Children' ;
    rdfs:comment 'The number of children of the household record' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:panelMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Panel Member Flag' ;
    rdfs:comment 'Indicates whether the household is an active member of a consumer research panel (e.g., Nielsen IQ Consumer Panel). Panel households provide purchase diary data used for market intelligence and SOM (Share of Market) analysis.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:petOwnerFlag rdf:type rdf:Property ;
    rdfs:label 'Pet Owner Flag' ;
    rdfs:comment 'Indicates whether the household owns pets. Used for targeted marketing of pet care product categories and cross-sell recommendations within the CPG/FMCG portfolio.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryChannel rdf:type rdf:Property ;
    rdfs:label 'Primary Channel' ;
    rdfs:comment 'The dominant channel through which the household makes purchases. Used for DTC (Direct to Consumer) strategy, channel mix analysis, and trade promotion targeting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRetailerBanner rdf:type rdf:Property ;
    rdfs:label 'Primary Retailer Banner' ;
    rdfs:comment 'The retail banner or chain where the household conducts the majority of its grocery or consumer goods shopping (e.g., Walmart, Target, Kroger). Used for OSA (On Shelf Availability) and POG (Planogram) analytics.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelBuyerFlag rdf:type rdf:Property ;
    rdfs:label 'Private Label Buyer Flag' ;
    rdfs:comment 'Indicates whether the household regularly purchases private label or store-brand products in addition to or instead of branded CPG products. Used for competitive analysis and brand switching risk assessment.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchaseFrequencyBand rdf:type rdf:Property ;
    rdfs:label 'Purchase Frequency Band' ;
    rdfs:comment 'Categorical band representing how frequently the household makes purchases across CPG/FMCG categories. Derived from POS (Point of Sale) transaction history and used for demand sensing and replenishment planning.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'The region of the household record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'The size of the household record' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tenureType rdf:type rdf:Property ;
    rdfs:label 'Tenure Type' ;
    rdfs:comment 'Indicates whether the household owns or rents their residence. Used for home improvement and home care product category targeting and consumer segmentation.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active addresses are eligible for order fulfillment and marketing. Inactive addresses are retained for historical reporting. Deleted status supports GDPR right-to-erasure soft-delete workflows.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the address by its business purpose. Billing addresses are used for invoicing and financial compliance; shipping addresses drive DTC order fulfillment and last-mile logistics; home and work addresses support personalized marketing and consumer segmentation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:censusTract rdf:type rdf:Property ;
    rdfs:label 'Census Tract' ;
    rdfs:comment 'U.S. Census Bureau census tract code for the address location. Enables demographic overlay analysis, market penetration reporting by socioeconomic segment, and trade area planning for consumer goods distribution.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentCaptured rdf:type rdf:Property ;
    rdfs:label 'Consent Captured' ;
    rdfs:comment 'Indicates whether explicit consumer consent was obtained for storing and processing this address record under applicable privacy regulations (GDPR/CCPA). True indicates consent is on file; False requires consent collection before marketing use.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date on which the consumer provided consent for storage and processing of this address record. Required for GDPR Article 7 compliance documentation and CCPA opt-in audit trails.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataResidencyRegion rdf:type rdf:Property ;
    rdfs:label 'Data Residency Region' ;
    rdfs:comment 'Geographic data residency classification for this address record, indicating the regulatory jurisdiction governing data storage and processing. Drives GDPR (EU), CCPA (US/CA), and other regional privacy law compliance for data localization requirements.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverabilityScore rdf:type rdf:Property ;
    rdfs:label 'Deliverability Score' ;
    rdfs:comment 'Numeric score (0.00–100.00) representing the likelihood that a physical shipment or direct mail piece will be successfully delivered to this address. Derived from address validation provider output. Supports carrier selection and DTC fulfillment risk management.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmaCode rdf:type rdf:Property ;
    rdfs:label 'Dma Code' ;
    rdfs:comment 'Nielsen Designated Market Area (DMA) code for the address location. Used for media planning, Share of Voice (SOV) analysis, and regional brand marketing investment allocation in consumer goods trade promotion programs.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotMail rdf:type rdf:Property ;
    rdfs:label 'Do Not Mail' ;
    rdfs:comment 'Indicates whether the consumer has opted out of physical direct mail marketing to this address. When True, this address must be suppressed from direct mail campaign execution lists. Supports GDPR right-to-object and CCPA opt-out compliance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dpvConfirmation rdf:type rdf:Property ;
    rdfs:label 'Dpv Confirmation' ;
    rdfs:comment 'USPS Delivery Point Validation confirmation code indicating the deliverability of the address. Y=Confirmed deliverable, S=Confirmed deliverable (secondary info missing), D=Confirmed deliverable (secondary info present but unneeded), N=Not confirmed. Critical for DTC fulfillment and direct mail campaigns.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'Classification of the address format to guide formatting, validation, and carrier routing logic. PO Box addresses may not be eligible for certain DTC carriers; military addresses (APO/FPO/DPO) require specific handling; rural route addresses may have extended delivery windows.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodingAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocoding Accuracy' ;
    rdfs:comment 'Precision level of the geocoded latitude/longitude coordinates for this address. Rooftop indicates exact parcel-level geocoding; range_interpolated indicates interpolation between street numbers; geometric_center indicates centroid of a polygon. Impacts reliability of proximity-based analytics.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultBilling rdf:type rdf:Property ;
    rdfs:label 'Is Default Billing' ;
    rdfs:comment 'Indicates whether this address is the consumer\'s default billing address for payment processing and invoice generation. Used in DTC checkout flows and financial compliance reporting.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultShipping rdf:type rdf:Property ;
    rdfs:label 'Is Default Shipping' ;
    rdfs:comment 'Indicates whether this address is the consumer\'s default shipping destination for DTC orders. Distinct from is_primary as a consumer may have a primary home address but a different default shipping address (e.g., workplace).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this is the consumer\'s primary address record for the given address type. When True, this address is used as the default for order fulfillment, marketing communications, and regulatory correspondence.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isValidated rdf:type rdf:Property ;
    rdfs:label 'Is Validated' ;
    rdfs:comment 'The is validated of the address record' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including house/building number and street name. Core component of the consumer\'s physical location used for DTC order fulfillment, direct mail marketing, and GDPR/CCPA data residency compliance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for apartment, suite, unit, floor, or building designations. Supplements address_line_1 to ensure complete and accurate delivery routing for DTC shipments.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line 3' ;
    rdfs:comment 'Tertiary address line for additional location details such as neighborhood, district, or care-of designations. Used in international address formats where three address lines are required.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plus4Code rdf:type rdf:Property ;
    rdfs:label 'Plus4 Code' ;
    rdfs:comment 'The four-digit USPS ZIP+4 extension code that narrows delivery to a specific block face or building. Enables postal presort discounts for direct mail campaigns and improves delivery precision for DTC shipments within the United States.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialIndicator rdf:type rdf:Property ;
    rdfs:label 'Residential Indicator' ;
    rdfs:comment 'Classification of the address as residential or commercial. Impacts carrier surcharge calculations (UPS/FedEx residential delivery fees), marketing segmentation, and DTC fulfillment cost modeling.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source Record Code' ;
    rdfs:comment 'Conformed governance attribute source_record_id.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardizedAddress rdf:type rdf:Property ;
    rdfs:label 'Standardized Address' ;
    rdfs:comment 'The full address formatted as a single standardized string per USPS/UPU postal standards after address validation and normalization (e.g., \'123 MAIN ST APT 4B, CHICAGO IL 60601-1234\'). Used as the canonical address for carrier label generation and deduplication.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA time zone identifier for the address location (e.g., America/New_York, Europe/London). Used for scheduling personalized marketing communications at optimal local times and for regulatory compliance with time-sensitive consumer notifications.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromTimestamp rdf:type rdf:Property ;
    rdfs:label 'Valid From Timestamp' ;
    rdfs:comment 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validToTimestamp rdf:type rdf:Property ;
    rdfs:label 'Valid To Timestamp' ;
    rdfs:comment 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validationProvider rdf:type rdf:Property ;
    rdfs:label 'Validation Provider' ;
    rdfs:comment 'Name of the third-party address validation service used to verify this address (e.g., USPS CASS, SmartyStreets, Loqate, Google Maps API). Supports audit trails for data quality governance and vendor performance tracking.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current validation state of the address record as determined by address verification services (e.g., USPS CASS, SmartyStreets, Loqate). Validated addresses reduce failed DTC deliveries and return-to-sender costs. Failed addresses require consumer outreach before order fulfillment.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when the address was last validated by the address verification service. Used to determine if re-validation is needed based on data freshness policies and to support data quality SLA reporting.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:enrollmentCampaignId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Loyalty accounts are created or tier-upgraded via specific enrollment campaigns. Tracking which campaign drove loyalty enrollment is required for loyalty program growth reporting, campaign ROI, and ac' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally visible, human-readable membership number assigned to the consumer at enrollment. Printed on loyalty cards, referenced in consumer communications, and used for in-store identification. Serves as the BUSINESS_IDENTIFIER for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle state of the loyalty account. \'active\' = fully operational; \'suspended\' = temporarily restricted (e.g., fraud review); \'closed\' = permanently deactivated; \'pending\' = enrollment not yet confirmed; \'frozen\' = points locked pending investigation. Serves as the LIFECYCLE_STATUS for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the loyalty account indicating whether it belongs to an individual consumer, a household unit, a small business buyer, or a coalition partner program. Drives eligibility rules and benefit structures.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cltvSegment rdf:type rdf:Property ;
    rdfs:label 'Cltv Segment' ;
    rdfs:comment 'Consumer\'s current Customer Lifetime Value (CLTV) segment classification derived from purchase history, points activity, and predictive modeling. Used for personalized promotion targeting, retention investment prioritization, and Trade Promotion Optimization (TPO). Not a calculated metric — this is a segment label assigned by the analytics/ML pipeline.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'Consumer\'s preferred channel for receiving loyalty program communications (e.g., points balance updates, tier change notifications, promotional offers). Drives outbound communication channel selection in CRM and marketing automation.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDataSharing rdf:type rdf:Property ;
    rdfs:label 'Consent Data Sharing' ;
    rdfs:comment 'Indicates whether the consumer has consented to sharing their loyalty data with third-party partners (e.g., retail partners, coalition program members). Required for GDPR and CCPA compliance. True = consented; False = not consented.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentMarketing rdf:type rdf:Property ;
    rdfs:label 'Consent Marketing' ;
    rdfs:comment 'Indicates whether the consumer has provided explicit opt-in consent to receive marketing communications related to the loyalty program. Required for GDPR Article 6 lawful basis and CCPA compliance. True = consented; False = not consented.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Channel through which the consumer enrolled in the loyalty program (e.g., web, mobile app, in-store, call center, partner, Direct-to-Consumer (DTC) platform). Used for channel attribution and acquisition cost analysis.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Calendar date on which the consumer formally enrolled in the loyalty program. Used to calculate membership tenure, anniversary rewards, and cohort-based retention analytics. Serves as EFFECTIVE_FROM for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentSourceCode rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source Code' ;
    rdfs:comment 'Campaign or promotion source code associated with the consumer\'s enrollment event (e.g., a Trade Promotion Management (TPM) campaign code, QR code identifier, or referral code). Used for acquisition attribution and Trade Promotion Optimization (TPO) ROI analysis.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Indicates whether this loyalty account has been flagged for suspected fraudulent activity (e.g., points manipulation, account takeover, synthetic identity). True = flagged for review; False = no fraud concern. Triggers account suspension workflow.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudReviewDate rdf:type rdf:Property ;
    rdfs:label 'Fraud Review Date' ;
    rdfs:comment 'Date on which the most recent fraud review was conducted or scheduled for this account. Nullable if no fraud review has occurred. Used by the fraud operations team to track investigation timelines.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent qualifying activity (purchase, redemption, or engagement event) on this loyalty account. Used to determine account dormancy, trigger re-engagement campaigns, and apply activity-based points expiry policies.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastEarnDate rdf:type rdf:Property ;
    rdfs:label 'Last Earn Date' ;
    rdfs:comment 'Date of the most recent points earn event on this account. Used to assess earn recency for RFM (Recency, Frequency, Monetary) segmentation and to trigger earn-reminder communications.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRedemptionDate rdf:type rdf:Property ;
    rdfs:label 'Last Redemption Date' ;
    rdfs:comment 'Date of the most recent points redemption event on this account. Used to assess redemption engagement, identify high-value redeemers, and support personalized redemption offer targeting.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimePointsEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Earned' ;
    rdfs:comment 'Cumulative total of all points ever earned on this account since enrollment, including base earn, bonus earn, and promotional earn events. Never decremented by redemptions or expirations. Used for Customer Lifetime Value (CLTV) calculation and tier qualification history.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsExpired rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Expired' ;
    rdfs:comment 'Cumulative total of all points that have expired on this account due to inactivity or program rules. Used for points liability release reporting in finance and consumer re-engagement analysis.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Redeemed' ;
    rdfs:comment 'Cumulative total of all points ever redeemed on this account since enrollment. Used for redemption rate analysis, points liability reconciliation, and CLTV modeling.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Loyalty Account Status' ;
    rdfs:comment 'The loyalty account status of the loyalty account record' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipTier rdf:type rdf:Property ;
    rdfs:label 'Membership Tier' ;
    rdfs:comment 'Current loyalty tier of the account reflecting the consumer\'s engagement and spend level (e.g., Standard, Silver, Gold, Platinum, Elite). Determines benefit multipliers, exclusive offers, and service levels. Reviewed periodically against tier_qualification_spend.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Date' ;
    rdfs:comment 'Date on which the consumer formally opted out of the loyalty program or withdrew consent for data processing. Nullable if the consumer has not opted out. Required for GDPR right-to-erasure and CCPA opt-out compliance tracking.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pointsBalance rdf:type rdf:Property ;
    rdfs:label 'Points Balance' ;
    rdfs:comment 'Current redeemable points balance on the loyalty account as of the last transaction processing. Represents the net of all earned, redeemed, adjusted, and expired points. Used for consumer-facing balance display and finance points liability reporting.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Points Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the monetary currency in which tier_qualification_spend and redemption values are denominated (e.g., USD, EUR, GBP). Supports multi-currency global loyalty programs.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsExpiryPolicy rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Policy' ;
    rdfs:comment 'Policy governing when unredeemed points on this account expire. Options include rolling 12-month inactivity, annual calendar expiry, never-expire, program-end expiry, or activity-based reset. Drives points liability forecasting and consumer communication triggers.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsLifetimeEarned rdf:type rdf:Property ;
    rdfs:label 'Points Lifetime Earned' ;
    rdfs:comment 'The points lifetime earned of the loyalty account record' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredRedemptionType rdf:type rdf:Property ;
    rdfs:label 'Preferred Redemption Type' ;
    rdfs:comment 'Consumer\'s stated or inferred preferred method of redeeming loyalty points. Used for personalized redemption offer targeting and program design optimization. [ENUM-REF-CANDIDATE: discount|free_product|gift_card|charity|cashback|experience|travel|merchandise — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousTier rdf:type rdf:Property ;
    rdfs:label 'Previous Tier' ;
    rdfs:comment 'The membership tier held by the consumer immediately before the most recent tier change. Used for tier transition analysis, win-back campaigns, and understanding tier migration patterns.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Tier Effective Date' ;
    rdfs:comment 'Date on which the current membership tier became effective. Used to calculate tier tenure, assess tier stability, and trigger tier-anniversary benefits.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualificationSpend rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Spend' ;
    rdfs:comment 'Cumulative qualifying purchase spend (in program currency) accumulated within the current tier review period. Compared against tier thresholds to determine tier upgrade, maintenance, or downgrade at the next tier review date.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierReviewDate rdf:type rdf:Property ;
    rdfs:label 'Tier Review Date' ;
    rdfs:comment 'Scheduled date on which the consumer\'s membership tier will be evaluated against tier_qualification_spend thresholds for potential upgrade, maintenance, or downgrade. Drives proactive consumer engagement campaigns before review.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Transaction Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for each loyalty points movement event. Serves as the primary key for the loyalty_transaction data product and enables precise audit trail reconciliation of all points currency activity.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Loyalty points liability accounting: under IFRS 15/ASC 606, loyalty points are deferred revenue requiring journal entries at earn and redemption. Consumer goods auditors and finance teams require dire' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Reference to the originating sales order or DTC purchase that triggered an earn or redemption event. Null for non-purchase-triggered transactions such as birthday bonuses, referral awards, or manual adjustments.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:reversalReferenceLoyaltyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference Loyalty Transaction Id' ;
    rdfs:comment 'For reversal-type transactions, the loyalty_transaction_id of the original transaction being reversed. Enables bidirectional audit trail linking between original and reversal entries for points reconciliation.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyTransaction .

ind:adjustmentNotes rdf:type rdf:Property ;
    rdfs:label 'Adjustment Notes' ;
    rdfs:comment 'Free-text narrative entered by a customer service agent or system process explaining the rationale for a manual points adjustment or reversal. Supports audit review and consumer dispute resolution.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Standardized code identifying the business reason for manual point adjustments or reversals (e.g., GOODWILL, DATA_CORRECTION, FRAUD_REVERSAL, SYSTEM_ERROR, PROMOTION_CORRECTION). Populated only for adjust and reversal transaction types. [ENUM-REF-CANDIDATE: GOODWILL|DATA_CORRECTION|FRAUD_REVERSAL|SYSTEM_ERROR|PROMOTION_CORRECTION|COMPLAINT_RESOLUTION — promote to reference product]' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusMultiplier rdf:type rdf:Property ;
    rdfs:label 'Bonus Multiplier' ;
    rdfs:comment 'The multiplier applied to the base earn rate for bonus transactions (e.g., 2.0 for double points, 1.5 for 50% bonus). Null for non-bonus transactions. Used to decompose total points awarded into base and bonus components for TPM ROI analysis.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentVerified rdf:type rdf:Property ;
    rdfs:label 'Consent Verified' ;
    rdfs:comment 'Indicates whether the consumer\'s active consent for loyalty program participation and data processing was verified at the time of this transaction. Supports GDPR Article 7 and CCPA consent audit requirements.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataRetentionFlag rdf:type rdf:Property ;
    rdfs:label 'Data Retention Flag' ;
    rdfs:comment 'Indicates whether this transaction record is subject to a data retention hold, preventing deletion or anonymization beyond the standard retention period. Set to True for records under legal hold, active fraud investigation, or regulatory audit. Supports GDPR right-to-erasure compliance.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earnRate rdf:type rdf:Property ;
    rdfs:label 'Earn Rate' ;
    rdfs:comment 'The points-per-currency-unit rate applied to calculate the points_amount for earn transactions (e.g., 1.5 points per USD spent). Captures the rate in effect at the time of the transaction for historical accuracy and program performance analysis.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Review Status' ;
    rdfs:comment 'The outcome of the fraud review process for transactions flagged by the fraud detection system: not_reviewed (default), under_review (investigation in progress), cleared (confirmed legitimate), or confirmed_fraud (fraudulent transaction confirmed and reversed).' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBonusTransaction rdf:type rdf:Property ;
    rdfs:label 'Is Bonus Transaction' ;
    rdfs:comment 'Indicates whether this earn transaction includes a bonus points multiplier applied on top of the base earn rate (e.g., double-points promotion, birthday bonus, new member bonus). Enables separation of base earn from promotional bonus in program cost analysis.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyTransactionStatus rdf:type rdf:Property ;
    rdfs:label 'Loyalty Transaction Status' ;
    rdfs:comment 'The loyalty transaction status of the loyalty transaction record' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monetaryValue rdf:type rdf:Property ;
    rdfs:label 'Monetary Value' ;
    rdfs:comment 'The monetary equivalent value of the points moved in this transaction, expressed in the program\'s base currency. Used for points liability valuation on the balance sheet and for calculating the cost of loyalty rewards in COGS reporting.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsAmount rdf:type rdf:Property ;
    rdfs:label 'Points Amount' ;
    rdfs:comment 'The absolute number of loyalty points moved in this transaction. Always stored as a positive value regardless of direction; the transaction_type field determines whether points are added or subtracted from the account balance. Supports fractional points for precision in tiered earn-rate calculations.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Points Balance After' ;
    rdfs:comment 'Snapshot of the loyalty account\'s total available points balance immediately after this transaction was applied. Together with points_balance_before, provides the complete before/after audit trail for each points movement event.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Points Balance Before' ;
    rdfs:comment 'Snapshot of the loyalty account\'s total available points balance immediately before this transaction was applied. Critical for audit trail completeness and points liability reconciliation required by finance.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsDirection rdf:type rdf:Property ;
    rdfs:label 'Points Direction' ;
    rdfs:comment 'Indicates whether the points_amount increases (credit) or decreases (debit) the loyalty account balance. Enables double-entry-style reconciliation of the points ledger for finance liability reporting.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Date' ;
    rdfs:comment 'The date on which the points awarded in this earn transaction are scheduled to expire per the loyalty program\'s currency expiration policy. Null for non-earn transactions. Drives the points liability aging schedule reported to finance.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pointsLiabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Points Liability Flag' ;
    rdfs:comment 'Indicates whether this transaction contributes to the outstanding points liability on the company\'s balance sheet (True for unspent earned points, False for redeemed or expired points). Supports finance\'s points liability reserve calculation under GAAP/IFRS.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Timestamp' ;
    rdfs:comment 'The date and time at which the loyalty transaction was processed and posted to the account balance by the loyalty engine. May differ from transaction_timestamp due to batch processing windows or pending verification holds.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:programYear rdf:type rdf:Property ;
    rdfs:label 'Program Year' ;
    rdfs:comment 'The fiscal or calendar year of the loyalty program in which this transaction occurred. Used for annual points balance resets, year-over-year program performance reporting, and points expiration policy enforcement.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Amount' ;
    rdfs:comment 'The net purchase amount (after discounts, excluding taxes) on the triggering order that qualified for points earning. Used to verify earn rate calculations and supports COGS and loyalty cost-per-transaction reporting.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionValue rdf:type rdf:Property ;
    rdfs:label 'Redemption Value' ;
    rdfs:comment 'The monetary discount or reward value applied to the consumer\'s order when points are redeemed. Populated only for redeem-type transactions. Used to calculate the effective discount rate and redemption liability release in financial reporting.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'The reference number of the loyalty transaction record' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTransactionRef rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Ref' ;
    rdfs:comment 'The native transaction identifier from the originating source system (e.g., Salesforce record ID, SAP document number, POS receipt number). Enables cross-system reconciliation and traceability back to the system of record.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The transaction date of the loyalty transaction record' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Human-readable, externally referenceable business identifier for the loyalty transaction, formatted as LT-{YYYY}-{sequence}. Used in consumer-facing communications, call-centre lookups, and points dispute resolution.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current workflow state of the loyalty transaction reflecting its processing lifecycle: pending (awaiting confirmation), processed (successfully posted to account), reversed (cancelled after posting), failed (processing error), or cancelled (voided before posting).' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) at which the loyalty points movement event occurred in the real world — i.e., when the triggering business event (purchase, referral, etc.) was confirmed and points were posted. This is the principal business event timestamp, distinct from system audit timestamps.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Categorical discriminator identifying the nature of the points movement: earn (points awarded), redeem (points consumed), adjust (manual correction), expire (points lapsed per program rules), transfer (inter-account movement), or reversal (cancellation of a prior transaction). [ENUM-REF-CANDIDATE: earn|redeem|adjust|expire|transfer|reversal — promote to reference product]' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerEvent rdf:type rdf:Property ;
    rdfs:label 'Trigger Event' ;
    rdfs:comment 'The specific business event that initiated this points movement, such as purchase, referral, product_review, birthday_bonus, promotion_bonus, account_registration, social_share, or survey_completion. Drives attribution analysis and program ROI reporting. [ENUM-REF-CANDIDATE: purchase|referral|product_review|birthday_bonus|promotion_bonus|account_registration|social_share|survey_completion — promote to reference product]' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Unique surrogate identifier for each consumer segment definition record in the Consumer Goods lakehouse silver layer. Serves as the primary key for all segment definition and membership records.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:parentSegmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Segment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent segment when this segment is a sub-segment or child in a hierarchical segmentation structure (e.g., \'High-Value Loyalists\' as a child of \'Loyalty Program Members\'). Null for top-level segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:activationChannel rdf:type rdf:Property ;
    rdfs:label 'Activation Channel' ;
    rdfs:comment 'The primary marketing activation channel for which this segment is designed (e.g., email campaigns, SMS, push notifications, paid media audiences, in-store promotions). Drives channel-specific audience export configurations in Salesforce Consumer Goods Cloud and CRM platforms.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageRangeMax rdf:type rdf:Property ;
    rdfs:label 'Age Range Max' ;
    rdfs:comment 'For demographic segments, the maximum consumer age (in years) defining the upper bound for segment inclusion. Used alongside age_range_min to define age-banded demographic segments (e.g., Millennials: 28–43).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeMin rdf:type rdf:Property ;
    rdfs:label 'Age Range Min' ;
    rdfs:comment 'For demographic segments, the minimum consumer age (in years) required for segment inclusion. Used in age-gated product targeting (e.g., health supplements, alcohol-adjacent personal care) and regulatory compliance with COPPA for under-13 restrictions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'Method by which consumers are assigned to this segment. \'rule_based\' uses deterministic business rules (e.g., purchase frequency thresholds); \'ml_model\' uses a trained machine learning classifier; \'manual\' indicates analyst-driven assignment; \'hybrid\' combines rule-based and ML approaches.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelScope rdf:type rdf:Property ;
    rdfs:label 'Channel Scope' ;
    rdfs:comment 'The distribution or engagement channel(s) for which this segment is applicable. \'dtc\' (Direct to Consumer) segments target consumers via owned digital channels; \'retail\' targets in-store shoppers; \'ecommerce\' targets online platform shoppers; \'omnichannel\' applies across all channels.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cltvMaxValue rdf:type rdf:Property ;
    rdfs:label 'Cltv Max Value' ;
    rdfs:comment 'For CLTV (Customer Lifetime Value)-based segments, the maximum predicted CLTV value defining the upper bound of this segment tier. Used to create banded CLTV segments (e.g., mid-value tier: CLTV between $500 and $2000). Null if no upper bound applies.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cltvMinValue rdf:type rdf:Property ;
    rdfs:label 'Cltv Min Value' ;
    rdfs:comment 'For CLTV (Customer Lifetime Value)-based segments, the minimum predicted CLTV score or monetary value required for a consumer to qualify for segment membership. Enables tiered loyalty and high-value consumer targeting strategies. Null for non-CLTV segment types.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentBasis rdf:type rdf:Property ;
    rdfs:label 'Consent Basis' ;
    rdfs:comment 'The legal basis under GDPR Article 6 or CCPA for processing consumer data within this segment. \'consent\' requires explicit opt-in; \'legitimate_interest\' applies where the business has a justified interest; \'contract\' applies for contractual necessity; \'not_required\' for non-personal aggregate segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRequired rdf:type rdf:Property ;
    rdfs:label 'Consent Required' ;
    rdfs:comment 'Indicates whether explicit consumer consent is required before a consumer can be assigned to or activated within this segment. True for segments used in direct marketing, personalization, or profiling activities subject to GDPR Article 6 or CCPA opt-in requirements.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'The created date of the segment record' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:criteriaDefinition rdf:type rdf:Property ;
    rdfs:label 'Criteria Definition' ;
    rdfs:comment 'The criteria definition of the segment record' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionLogic rdf:type rdf:Property ;
    rdfs:label 'Definition Logic' ;
    rdfs:comment 'The definition logic of the segment record' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSuppressionSegment rdf:type rdf:Property ;
    rdfs:label 'Is Suppression Segment' ;
    rdfs:comment 'Indicates whether this segment is a suppression list used to exclude consumers from campaigns (e.g., opted-out consumers, recent purchasers, regulatory exclusions). True means consumers in this segment are excluded from targeted marketing activations.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'The date and time when the segment membership was last recalculated and updated. Used to assess data freshness for CRM targeting and to trigger refresh workflows when the segment is stale relative to its defined refresh frequency.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loyaltyTierScope rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Scope' ;
    rdfs:comment 'The loyalty program tier(s) targeted by this segment. Enables differentiated engagement strategies for loyalty program members (e.g., exclusive offers for Platinum tier, win-back campaigns for Bronze tier). \'all\' indicates the segment applies across all loyalty tiers.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Min Confidence Score' ;
    rdfs:comment 'The minimum ML model confidence score (0.0000 to 1.0000) required for a consumer to be assigned to this segment when using ML-based assignment. Consumers with scores below this threshold are excluded. Null for rule-based or manual segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mlModelCode rdf:type rdf:Property ;
    rdfs:label 'Ml Model Code' ;
    rdfs:comment 'Identifier of the machine learning model used to generate or score this segment, when assignment_method is \'ml_model\' or \'hybrid\'. Enables traceability to the model registry for audit, retraining, and explainability purposes. Null for rule_based or manual segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Version identifier of the segmentation model or rule set that produced this segment definition (e.g., \'v1.0\', \'v2.3\'). Enables traceability of segment membership changes across model iterations and supports A/B testing of segmentation approaches.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScoreMax rdf:type rdf:Property ;
    rdfs:label 'Nps Score Max' ;
    rdfs:comment 'For NPS (Net Promoter Score)-based segments, the maximum NPS score (0–10 scale) defining the upper bound for segment inclusion. Used in conjunction with nps_score_min to define NPS-banded segments (e.g., detractors: 0–6).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsScoreMin rdf:type rdf:Property ;
    rdfs:label 'Nps Score Min' ;
    rdfs:comment 'For NPS (Net Promoter Score)-based segments, the minimum NPS score (0–10 scale) required for segment inclusion. Enables targeting of promoters (9–10), passives (7–8), or detractors (0–6) for tailored consumer engagement programs.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:owningBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Owning Business Unit' ;
    rdfs:comment 'The business unit (BU) within Consumer Goods responsible for this segment\'s definition, governance, and activation (e.g., \'Personal Care\', \'Home Care\', \'Health & Wellness\'). Used for segment ownership reporting and cross-BU deduplication governance.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationEligible rdf:type rdf:Property ;
    rdfs:label 'Personalization Eligible' ;
    rdfs:comment 'Indicates whether consumers in this segment are eligible for personalized content, product recommendations, or pricing in DTC (Direct to Consumer) and e-commerce channels. Requires valid consent_basis when consent_required is True.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'How frequently the segment membership is recalculated and updated. Determines the cadence at which consumer assignments are re-evaluated against the segment\'s rules or ML model. Impacts CRM campaign freshness and personalization accuracy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfmFrequencyMin rdf:type rdf:Property ;
    rdfs:label 'Rfm Frequency Min' ;
    rdfs:comment 'For RFM (Recency, Frequency, Monetary)-based segments, the minimum number of purchase transactions required within the recency window for a consumer to qualify for the frequency criterion. Null for non-RFM segment types.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfmMonetaryMin rdf:type rdf:Property ;
    rdfs:label 'Rfm Monetary Min' ;
    rdfs:comment 'For RFM (Recency, Frequency, Monetary)-based segments, the minimum cumulative spend amount (in the segment\'s currency) required within the recency window for a consumer to qualify for the monetary criterion. Null for non-RFM segment types.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfmRecencyDays rdf:type rdf:Property ;
    rdfs:label 'Rfm Recency Days' ;
    rdfs:comment 'For RFM (Recency, Frequency, Monetary)-based segments, the number of days used to define the recency window (e.g., last 90 days). Consumers with a purchase within this window qualify for the recency criterion. Null for non-RFM segment types.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle state of the segment definition. \'active\' segments are available for CRM targeting and trade promotion activation; \'draft\' segments are under construction; \'archived\' segments are retained for historical analysis but no longer used in campaigns.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segmentation methodology applied to define this segment. Behavioral segments are based on purchase patterns; demographic on age/gender/income; psychographic on lifestyle/values; RFM (Recency, Frequency, Monetary) on transactional scoring; CLTV (Customer Lifetime Value)-based on predicted long-term value; geographic on location.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Source Segment Code' ;
    rdfs:comment 'The native identifier of this segment in the originating operational system (e.g., Salesforce Consumer Goods Cloud segment ID, Nielsen IQ panel group code). Enables cross-system reconciliation and data lineage tracing back to the system of record.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceSize rdf:type rdf:Property ;
    rdfs:label 'Target Audience Size' ;
    rdfs:comment 'The estimated or actual count of unique consumers assigned to this segment at the time of last refresh. Used for campaign planning, media budget allocation, and share of voice (SOV) estimation. Not a real-time count — reflects the last segment refresh cycle.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each consent record in the Consumer Goods consumer privacy system. Primary key for the consent_record data product, serving as the SSOT for GDPR Article 7 and CCPA compliance audits.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:captureMethod rdf:type rdf:Property ;
    rdfs:label 'Capture Method' ;
    rdfs:comment 'Channel or mechanism through which the consumer\'s consent was captured. Identifies whether consent was obtained via a web form, mobile app, in-store interaction, call center agent, paper form, or email link. Required for GDPR proof-of-consent obligations.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Capture Timestamp' ;
    rdfs:comment 'Exact date and time (with timezone offset) when the consumer\'s consent action was recorded in the system. This is the principal business event timestamp for the consent record and is immutable once set. Required for GDPR Article 7 audit trail.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeTrigger rdf:type rdf:Property ;
    rdfs:label 'Change Trigger' ;
    rdfs:comment 'The business reason or event that triggered the most recent change to the consent status. Distinguishes consumer-initiated changes from system-driven expirations, administrative overrides, legal requests (e.g., right to erasure), or re-consent campaigns.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentGiven rdf:type rdf:Property ;
    rdfs:label 'Consent Given' ;
    rdfs:comment 'The consent given of the consent record record' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Consent Language Code' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 country subtag) of the language in which the consent notice was presented to the consumer (e.g., \'en\', \'fr\', \'de\', \'es-MX\'). Required to confirm consent was given in an intelligible form per GDPR Article 7.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentProofReference rdf:type rdf:Property ;
    rdfs:label 'Consent Proof Reference' ;
    rdfs:comment 'Reference identifier or URL pointing to the stored proof-of-consent artifact (e.g., screenshot, signed form scan, call recording reference, Veeva Vault document ID). Supports GDPR Article 7(1) obligation to demonstrate that consent was given.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Record Status' ;
    rdfs:comment 'The consent record status of the consent record record' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Defines the breadth of the consent grant — whether it applies globally across all Consumer Goods brands and products, is restricted to a specific brand, product category, or a single campaign. Enables granular consent management across the product portfolio.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle status of the consent record indicating whether the consumer has actively granted, withdrawn, or is pending confirmation of consent, or whether the consent has expired past its validity period.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTextSnapshot rdf:type rdf:Property ;
    rdfs:label 'Consent Text Snapshot' ;
    rdfs:comment 'Verbatim text or reference hash of the consent notice, privacy policy excerpt, or opt-in language presented to the consumer at the time of consent capture. Immutable record of what the consumer agreed to, required for GDPR Article 7 proof-of-consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Category of consent being captured, defining the specific processing activity for which the consumer has provided or withheld consent. Covers marketing email, SMS, push notification, data sharing, profiling, and cookies as required by GDPR and CCPA.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cookieConsentCategories rdf:type rdf:Property ;
    rdfs:label 'Cookie Consent Categories' ;
    rdfs:comment 'Comma-separated list of cookie categories for which the consumer has granted consent (e.g., \'functional,analytics,marketing\'). Captures granular cookie preferences as required by the ePrivacy Directive and GDPR for digital channels. [ENUM-REF-CANDIDATE: necessary|functional|analytics|marketing|social_media|personalization|advertising — promote to reference product]' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Type of device used by the consumer when providing consent in digital channels. Supports forensic audit trails and UX analysis of consent capture flows.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Flag' ;
    rdfs:comment 'Indicates whether the consumer completed a double opt-in confirmation process (e.g., clicked a confirmation link in a verification email) in addition to the initial consent action. Double opt-in provides stronger proof of consent for marketing communications under GDPR.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Timestamp' ;
    rdfs:comment 'Exact date and time when the consumer completed the double opt-in confirmation step. Null if double opt-in was not required or not yet completed. Provides the definitive timestamp for consent activation in double opt-in workflows.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address of the device from which the consumer submitted their consent. Captured for digital consent channels (web form, mobile app, email link) as evidence of consent origin. May be considered PII under GDPR in some EU jurisdictions.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentRecord rdf:type rdf:Property ;
    rdfs:label 'Is Current Record' ;
    rdfs:comment 'Indicates whether this row represents the current active consent record for the consumer-consent_type combination. Supports Slowly Changing Dimension (SCD Type 2) pattern in the Silver Layer, where historical consent versions are retained for audit purposes and this flag identifies the latest version.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The lawful basis under GDPR Article 6 or equivalent regulation for processing the consumer\'s personal data. Consent is one of six legal bases; this field distinguishes consent-based processing from other lawful bases to support compliance reporting.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorAgeThreshold rdf:type rdf:Property ;
    rdfs:label 'Minor Age Threshold' ;
    rdfs:comment 'Age threshold (in years) used to determine whether parental consent was required for this consent record, based on the applicable jurisdiction\'s rules (e.g., 16 for GDPR default, 13 for COPPA, 13-16 for EU member state variations). Null if consumer is not a minor.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentalConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Flag' ;
    rdfs:comment 'Indicates whether parental or guardian consent was obtained for a minor consumer. Required under GDPR Article 8 for children under 16 (or lower age threshold set by member state) and COPPA for US consumers under 13.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Consent Status' ;
    rdfs:comment 'The consent status immediately before the most recent status change. Enables point-in-time audit reconstruction and supports the immutable event log requirement for GDPR Article 7 compliance audits without requiring a separate history table join.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingAgent rdf:type rdf:Property ;
    rdfs:label 'Processing Agent' ;
    rdfs:comment 'Identifier of the system, application, or human agent (call center representative ID or system name) that processed and recorded the consent event. Supports accountability requirements under GDPR Article 5(2) and provides an audit trail of who or what captured the consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profilingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Profiling Consent Flag' ;
    rdfs:comment 'Indicates whether the consumer has consented to automated profiling and decision-making activities, including personalization algorithms, NPS scoring, CLTV modeling, and segmentation. Required under GDPR Article 22 for automated decision-making with significant effects.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reConsentDeadline rdf:type rdf:Property ;
    rdfs:label 'Re Consent Deadline' ;
    rdfs:comment 'Date by which the consumer must re-confirm their consent before the current consent record is automatically withdrawn or expired. Null if re-consent is not required. Used to drive automated consent renewal campaigns.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Re Consent Required Flag' ;
    rdfs:comment 'Indicates whether this consent record requires re-confirmation from the consumer due to a material change in the privacy policy, consent notice, or processing purpose. Triggers re-consent outreach workflows in the CRM system.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Sequential version number of this consent record for the consumer-consent_type combination. Increments with each status change or update, enabling full audit history reconstruction. Version 1 is the initial consent capture; subsequent versions reflect changes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'The applicable privacy regulation or jurisdiction framework under which this consent record was created and must be managed. Determines the legal basis, retention rules, and consumer rights applicable to this record (e.g., GDPR for EU consumers, CCPA for California residents).' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'Number of days this consent record must be retained for compliance purposes after the consent is withdrawn or expires. Determined by applicable regulatory requirements (e.g., GDPR Article 5(1)(e) storage limitation, CCPA). Drives automated data lifecycle management.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'The source channel of the consent record record' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharingFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Flag' ;
    rdfs:comment 'Indicates whether the consumer has explicitly consented to their personal data being shared with third-party partners (e.g., retail partners, data brokers, analytics providers). Distinct from general data sharing consent; specifically governs external data transfers.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withdrawalMethod rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Method' ;
    rdfs:comment 'Channel or mechanism through which the consumer withdrew their consent. Null if consent has not been withdrawn. Required to demonstrate that withdrawal was as easy as giving consent per GDPR Article 7(3).' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Timestamp' ;
    rdfs:comment 'Exact date and time when the consumer withdrew their consent. Null if consent has not been withdrawn. GDPR Article 7(3) requires that withdrawal be as easy as giving consent; this timestamp documents the withdrawal event for audit purposes.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ar_invoice. Business justification: DTC order-to-cash cycle: each DTC order generates an AR invoice for collections, dispute management, and revenue recognition under IFRS 15/ASC 606. Consumer goods DTC finance teams require this link f' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:distributionShipmentId rdf:type rdf:Property ;
    rdfs:label 'Distribution Shipment Id' ;
    rdfs:comment 'Foreign key linking to distribution.distribution_shipment. Business justification: DTC last-mile delivery tracking: links a consumer DTC order to its distribution shipment for delivery performance reporting, customer shipment notifications, and carrier OTIF compliance. Distinct from' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionShipment .

ind:fulfillmentNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Network Node Id' ;
    rdfs:comment 'Foreign key linking to supply.network_node. Business justification: DTC orders are fulfilled from a specific supply network node (DC/fulfillment center). Supply network allocation reporting and node-level capacity planning require knowing which network node fulfilled ' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:fulfillmentSupplierId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: Drop-ship DTC fulfillment requires tracking which supplier fulfilled each order for supplier OTIF performance reporting, cost allocation, and compliance audits. A consumer goods domain expert expects ' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:outboundOrderId rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Id' ;
    rdfs:comment 'Foreign key linking to distribution.outbound_order. Business justification: DTC order fulfillment process: each consumer DTC order generates a distribution outbound_order for warehouse execution. Operations and customer service teams track which outbound_order fulfills which ' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundOrder .

ind:priceListId rdf:type rdf:Property ;
    rdfs:label 'Price List Id' ;
    rdfs:comment 'Foreign key linking to sales.price_list. Business justification: DTC orders in CPG are priced against a specific consumer price list (DTC channel price list, promotional price list, loyalty tier price list). This FK enables DTC pricing audit, margin analysis by pri' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:shippingAddressId rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Id' ;
    rdfs:comment 'The shipping address id of the dtc order record' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:subscriptionId rdf:type rdf:Property ;
    rdfs:label 'Subscription Id' ;
    rdfs:comment 'Reference to the consumer subscription plan that generated this DTC order, when subscription_order_flag is True. Links to the subscription master for recurring order management, churn analysis, and subscription revenue reporting.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscription .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The date the shipment was confirmed as delivered to the consumer. Compared against promised_delivery_date to calculate OTIF performance and identify late delivery patterns for carrier SLA management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingAddressSameFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Address Same Flag' ;
    rdfs:comment 'Indicates whether the billing address is identical to the shipping address for this order. When False, a separate billing address record is maintained. Used for payment processing and fraud risk scoring.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'Code identifying the shipping carrier assigned to deliver this DTC order (e.g., UPS, FedEx, USPS, DHL). Used for carrier performance analysis, SLA tracking, and logistics cost allocation.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'The specific owned DTC channel through which the order was placed (e.g., brand website, mobile app, social commerce). Enables channel-level performance analysis, attribution modeling, and Share of Voice (SOV) reporting across DTC touchpoints.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total monetary discount applied at the order header level, including promotional codes, loyalty redemptions, and trade promotion discounts. Used for Trade Promotion Management (TPM) ROI analysis and net revenue reporting. Part of TRANSACTION_HEADER MONETARY_TRIPLET adjustment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dtcOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Dtc Order Status' ;
    rdfs:comment 'The dtc order status of the dtc order record' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentRef rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Ref' ;
    rdfs:comment 'External reference number linking this DTC order to the fulfillment system (e.g., Blue Yonder WMS warehouse order, 3PL fulfillment reference, or SAP WM transfer order). Enables end-to-end order-to-delivery traceability and OTIF measurement.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current fulfillment state of the DTC order at the header level, indicating whether all line items have been picked, packed, and shipped. Used for OTIF (On Time In Full) KPI reporting and supply chain performance dashboards.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Order Flag' ;
    rdfs:comment 'Indicates whether this DTC order was placed as a gift, triggering gift wrapping, suppression of price information on packing slips, and gift message inclusion. Used for seasonal demand analysis and consumer gifting behavior modeling.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ip Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code derived from the consumer\'s IP address at the time of order placement. Used for fraud detection, geo-restriction compliance, and cross-border commerce analytics. Classified as potentially PII under GDPR.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsEarned rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Earned' ;
    rdfs:comment 'Number of loyalty program points earned by the consumer for this DTC order, based on the order total and applicable loyalty tier multipliers. Feeds into CLTV calculations and loyalty program engagement analytics.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyPointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Redeemed' ;
    rdfs:comment 'Number of loyalty program points redeemed by the consumer as a discount on this DTC order. Used for loyalty liability accounting, redemption rate analysis, and consumer engagement reporting.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The exact date and time (UTC) when the consumer submitted the order through the DTC e-commerce or brand website channel. This is the principal business event timestamp used for demand planning, daily sales reporting, and S&OP inputs. Satisfies TRANSACTION_HEADER BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Timestamp' ;
    rdfs:comment 'The order timestamp of the dtc order record' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Order Total Amount' ;
    rdfs:comment 'The final net amount charged to the consumer, calculated as subtotal minus discounts plus shipping plus tax. This is the authoritative revenue figure for DTC channel financial reporting and EBITDA contribution analysis. Satisfies TRANSACTION_HEADER MONETARY_TRIPLET net total.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The payment instrument type used by the consumer to complete this DTC order (e.g., credit card, PayPal, digital wallet). Used for payment analytics, fraud detection, and consumer payment preference reporting. Note: No raw card data is stored; only the instrument type.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of the payment transaction associated with this DTC order, tracking authorization through capture or refund. Critical for revenue recognition, accounts receivable (DSO), and consumer dispute resolution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTransactionRef rdf:type rdf:Property ;
    rdfs:label 'Payment Transaction Ref' ;
    rdfs:comment 'External payment gateway transaction reference or authorization code for this order. Used for payment reconciliation, chargeback management, and financial audit trails. Does not contain sensitive card data (PCI DSS compliant tokenized reference only).' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'The delivery date committed to the consumer at the time of order placement, based on Available to Promise (ATP) or Capable to Promise (CTP) logic. Used for SLA compliance measurement and consumer expectation management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Promotional or coupon code entered by the consumer at checkout, linking this order to a specific Trade Promotion Management (TPM) campaign. Enables TPM ROI measurement, promotional lift analysis, and Trade Promotion Optimization (TPO) modeling.' ;
    rdfs:domain ind:Consumer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnFlag rdf:type rdf:Property ;
    rdfs:label 'Return Flag' ;
    rdfs:comment 'Indicates whether any item in this DTC order has been returned or a return has been initiated. Used for return rate analysis, product quality monitoring, and consumer satisfaction (NPS) correlation studies.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for the order return (e.g., defective product, wrong item, consumer changed mind). Populated when return_flag is True. Used for quality defect analysis, product improvement, and COGS impact reporting. [ENUM-REF-CANDIDATE: defective|wrong_item|not_as_described|changed_mind|damaged_in_transit|late_delivery|other — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Ship To Address Line1' ;
    rdfs:comment 'Primary street address line for the shipping destination of this DTC order. Used for carrier routing, last-mile delivery, and geographic sales analysis. Classified as PII under GDPR and CCPA.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCity rdf:type rdf:Property ;
    rdfs:label 'Ship To City' ;
    rdfs:comment 'City of the shipping destination for this DTC order. Used for geographic demand analysis, Distribution Requirements Planning (DRP), and regional marketing segmentation.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the shipping destination. Drives international shipping compliance, customs documentation, import/export regulatory requirements, and multi-country revenue reporting.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToName rdf:type rdf:Property ;
    rdfs:label 'Ship To Name' ;
    rdfs:comment 'Full name of the recipient at the shipping address for this DTC order. May differ from the ordering consumer (e.g., gift orders). Required for carrier label generation and last-mile delivery. Classified as PII under GDPR and CCPA.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToPostalCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the shipping destination. Used for carrier rate calculation, geographic clustering, and micro-market demand analysis.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToStateProvince rdf:type rdf:Property ;
    rdfs:label 'Ship To State Province' ;
    rdfs:comment 'State or province of the shipping destination. Used for tax jurisdiction determination, regional sales reporting, and regulatory compliance (e.g., state-level FDA or EPA requirements).' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedDate rdf:type rdf:Property ;
    rdfs:label 'Shipped Date' ;
    rdfs:comment 'The date the order was physically dispatched from the fulfillment center or warehouse. Used for lead time analysis, carrier handoff tracking, and revenue recognition timing under ASC 606.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Amount' ;
    rdfs:comment 'Shipping and handling charges billed to the consumer for this DTC order. Used for logistics cost analysis, free-shipping threshold reporting, and net revenue calculations.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemOrderRef rdf:type rdf:Property ;
    rdfs:label 'Source System Order Ref' ;
    rdfs:comment 'The native order identifier from the originating e-commerce platform or ERP system (e.g., Salesforce Commerce Cloud order ID, SAP SD sales order number). Used for cross-system reconciliation, EDI integration, and data lineage tracing back to the system of record.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Subscription Order Flag' ;
    rdfs:comment 'Indicates whether this DTC order was generated as part of a recurring subscription (subscribe-and-save) program. Used to distinguish subscription revenue from one-time purchase revenue for CLTV modeling and replenishment trigger analysis.' ;
    rdfs:domain ind:DtcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'The gross merchandise value of all line items before discounts, shipping charges, and taxes are applied. Used as the base for promotional discount calculations, COGS analysis, and gross margin reporting. Part of TRANSACTION_HEADER MONETARY_TRIPLET.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total sales tax or VAT charged on this DTC order, calculated based on the shipping destination jurisdiction. Required for financial reporting, tax compliance, and SOX audit trails. Part of TRANSACTION_HEADER MONETARY_TRIPLET adjustment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'The total amount of the dtc order record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-assigned tracking number for the shipment associated with this DTC order. Provided to the consumer for last-mile visibility and used internally for delivery confirmation and OTIF measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtcOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Dtc Order Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual line item within a DTC order. Primary key for this entity. Role: TRANSACTION_LINE.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DtcOrderLine .

ind:priceListItemId rdf:type rdf:Property ;
    rdfs:label 'Price List Item Id' ;
    rdfs:comment 'Foreign key linking to sales.price_list_item. Business justification: Each DTC order line is priced against a specific price list item (SKU-level price). This FK supports DTC line-level pricing audit, promotional price validation, margin-per-SKU reporting, and price com' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceListItem .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'Date on which the order line was physically dispatched from the fulfillment warehouse. Used to calculate On Time In Full (OTIF) performance and carrier SLA adherence.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costOfGoodsSold rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold' ;
    rdfs:comment 'Standard cost of goods for the units on this order line at time of sale. Used for gross margin calculation, DTC channel profitability analysis, and EBITDA reporting. Classified confidential as it reveals internal cost structure.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dtcOrderLineStatus rdf:type rdf:Property ;
    rdfs:label 'Dtc Order Line Status' ;
    rdfs:comment 'The dtc order line status of the dtc order line record' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReturned rdf:type rdf:Property ;
    rdfs:label 'Is Returned' ;
    rdfs:comment 'Indicates whether this order line has been subject to a consumer return. True when a return has been initiated or completed. Enables return rate analysis by SKU, category, and consumer segment for product quality and consumer experience programs.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Line Discount Amount' ;
    rdfs:comment 'Total monetary discount applied to this order line, including promotional discounts, coupon redemptions, and loyalty rewards. Used for Trade Promotion Management (TPM) analysis and margin reporting.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Line Discount Pct' ;
    rdfs:comment 'Discount rate applied to this order line expressed as a percentage of the gross unit price. Enables promotional effectiveness analysis and margin impact assessment without requiring price recalculation.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNetAmount rdf:type rdf:Property ;
    rdfs:label 'Line Net Amount' ;
    rdfs:comment 'Net monetary value of this order line after all discounts have been applied but before tax. Core revenue recognition field for DTC channel P&L reporting and COGS analysis. Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT monetary component.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineSubtotal rdf:type rdf:Property ;
    rdfs:label 'Line Subtotal' ;
    rdfs:comment 'Gross line value before tax, calculated as unit_price multiplied by quantity_ordered. Represents the pre-discount, pre-tax revenue contribution of this line item.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTotal rdf:type rdf:Property ;
    rdfs:label 'Line Total' ;
    rdfs:comment 'The line total of the dtc order line record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Final total amount for this order line inclusive of all discounts and taxes. Represents the actual amount charged to the consumer for this line item. Used for revenue reporting and consumer billing reconciliation.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promisedShipDate rdf:type rdf:Property ;
    rdfs:label 'Promised Ship Date' ;
    rdfs:comment 'Date on which the order line was committed to ship to the consumer at time of order placement. Basis for Available to Promise (ATP) and Service Level Agreement (SLA) compliance measurement.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityCancelled rdf:type rdf:Property ;
    rdfs:label 'Quantity Cancelled' ;
    rdfs:comment 'Number of units cancelled on this order line, either by the consumer or due to inventory unavailability. Supports cancellation rate analysis and demand signal correction.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'Number of units of the SKU ordered by the consumer on this line. Basis for demand planning, inventory reservation, and fulfillment processing. Satisfies TRANSACTION_LINE LINE_QUANTITY category.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityShipped rdf:type rdf:Property ;
    rdfs:label 'Quantity Shipped' ;
    rdfs:comment 'Actual number of units of the SKU dispatched to the consumer for this line. May differ from quantity_ordered due to partial fulfillment, Out of Stock (OOS) situations, or split shipments. Key metric for On Time In Full (OTIF) measurement.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriptionFlag rdf:type rdf:Property ;
    rdfs:label 'Subscription Flag' ;
    rdfs:comment 'Indicates whether this order line was generated as part of a recurring subscription program (e.g., Subscribe & Save). True for subscription-triggered lines. Enables subscription revenue tracking and replenishment program analysis.' ;
    rdfs:domain ind:DtcOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Gross selling price per unit of the SKU at the time of order placement, before any discounts or promotions. Represents the consumer-facing price (RSP/MSRP or DTC-specific price). Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT category.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAddressId rdf:type rdf:Property ;
    rdfs:label 'Billing Address Id' ;
    rdfs:comment 'The billing address id of the subscription record' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:subscriptionDeliveryAddressId rdf:type rdf:Property ;
    rdfs:label 'Subscription Delivery Address Id' ;
    rdfs:comment 'Reference to the consumer\'s preferred delivery address for subscription fulfillment. Links to the address master for DSD (Direct Store Delivery) routing and last-mile logistics planning via Blue Yonder WMS.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:acquisitionSource rdf:type rdf:Property ;
    rdfs:label 'Acquisition Source' ;
    rdfs:comment 'Marketing source or campaign that drove the consumer to subscribe (e.g., email campaign code, paid search, influencer referral, loyalty program). Used for marketing ROI (Return on Investment) attribution and SOV (Share of Voice) analysis.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether the subscription is configured to automatically renew at the end of each billing cycle (True) or requires explicit consumer action to continue (False). Governs recurring revenue recognition and consumer notification obligations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCycleDay rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Day' ;
    rdfs:comment 'Day of the month (1–31) on which the subscription billing charge is processed. Governs the recurring payment schedule and aligns with the consumer\'s preferred billing date. Used in accounts receivable and DSO (Days Sales Outstanding) reporting.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'The billing frequency of the subscription record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Calendar date on which the consumer formally cancelled the subscription. Distinct from end_date (which may be a future scheduled end). Used in churn cohort analysis and subscription tenure reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Consumer-stated or system-derived reason for cancelling the subscription. Populated when subscription_status transitions to \'cancelled\'. Critical input for churn analysis, NPS (Net Promoter Score) correlation, and consumer retention strategy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFrequency rdf:type rdf:Property ;
    rdfs:label 'Delivery Frequency' ;
    rdfs:comment 'The delivery frequency of the subscription record' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPct rdf:type rdf:Property ;
    rdfs:label 'Discount Pct' ;
    rdfs:comment 'The discount pct of the subscription record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'Percentage discount applied to the subscription price per billing cycle, expressed as a decimal (e.g., 0.1500 = 15%). Reflects subscriber loyalty pricing, promotional offers, or TPM (Trade Promotion Management) funded discounts.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Calendar date on which the subscription is scheduled to end or was terminated. Null for open-ended subscriptions. Represents EFFECTIVE_UNTIL for this agreement. Populated on cancellation or plan expiry.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:failedPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Failed Payment Count' ;
    rdfs:comment 'Cumulative number of failed payment attempts on this subscription since inception. Used to trigger dunning workflows, payment retry logic, and subscription suspension rules. Key indicator for revenue leakage management.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Cadence at which the subscription order is automatically triggered and fulfilled. Drives the replenishment schedule and next order date calculation. Key input for demand planning and S&OP forecasting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'Calendar date of the most recently fulfilled subscription order. Used to validate subscription activity, detect stalled subscriptions, and support FEFO (First Expired First Out) inventory allocation for replenishment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Actual amount charged to the consumer per billing cycle after applying the discount rate. Equals subscription_price × (1 - discount_rate). Used in revenue recognition, COGS (Cost of Goods Sold) analysis, and financial reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextBillingDate rdf:type rdf:Property ;
    rdfs:label 'Next Billing Date' ;
    rdfs:comment 'The next billing date of the subscription record' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Next Delivery Date' ;
    rdfs:comment 'The next delivery date of the subscription record' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextOrderDate rdf:type rdf:Property ;
    rdfs:label 'Next Order Date' ;
    rdfs:comment 'Scheduled calendar date for the next automatic order generation under this subscription. Used by fulfillment systems for ATP (Available to Promise) checks and demand sensing. Updated after each successful order cycle.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Date' ;
    rdfs:comment 'The next renewal date of the subscription record' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pauseEndDate rdf:type rdf:Property ;
    rdfs:label 'Pause End Date' ;
    rdfs:comment 'Calendar date on which the subscription pause is scheduled to end and auto-replenishment is set to resume. Null if the pause is indefinite. Used in demand forecasting to anticipate reactivation volumes.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pauseFlag rdf:type rdf:Property ;
    rdfs:label 'Pause Flag' ;
    rdfs:comment 'The pause flag of the subscription record' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pauseReason rdf:type rdf:Property ;
    rdfs:label 'Pause Reason' ;
    rdfs:comment 'Consumer-stated reason for pausing the subscription. Populated when subscription_status transitions to \'paused\'. Used in consumer retention analysis and proactive re-engagement campaign targeting.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pauseStartDate rdf:type rdf:Property ;
    rdfs:label 'Pause Start Date' ;
    rdfs:comment 'Calendar date on which the consumer-initiated subscription pause became effective. Used to calculate pause duration and adjust next_order_date upon resumption. Supports consumer retention lifecycle tracking.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Payment Method Type' ;
    rdfs:comment 'Category of payment instrument used for recurring subscription billing (e.g., credit_card, digital_wallet). Stored as a type reference only — no raw card or account data is stored here per PCI DSS compliance. Supports payment failure analysis and retry logic.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTokenReference rdf:type rdf:Property ;
    rdfs:label 'Payment Token Reference' ;
    rdfs:comment 'Tokenized reference identifier for the consumer\'s stored payment method, issued by the payment processor vault. Never contains raw card or bank account data. Used to initiate recurring charges without storing PCI-sensitive data. Compliant with PCI DSS tokenization requirements.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'The plan name of the subscription record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:price rdf:type rdf:Property ;
    rdfs:label 'Price' ;
    rdfs:comment 'Gross price charged to the consumer per billing cycle before any discounts are applied. Expressed in the subscription\'s billing currency. Used in subscription revenue forecasting and CLTV (Customer Lifetime Value) calculations.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerCycle rdf:type rdf:Property ;
    rdfs:label 'Price Per Cycle' ;
    rdfs:comment 'The price per cycle of the subscription record' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recurringAmount rdf:type rdf:Property ;
    rdfs:label 'Recurring Amount' ;
    rdfs:comment 'The recurring amount of the subscription record' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Calendar date on which the subscription became effective and the first order cycle was initiated. Represents EFFECTIVE_FROM for this agreement. Used in cohort analysis and subscription tenure calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Subscription Number' ;
    rdfs:comment 'Externally visible, human-readable subscription reference number communicated to the consumer in confirmation emails, invoices, and customer service interactions. Serves as the BUSINESS_IDENTIFIER for this agreement.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Status' ;
    rdfs:comment 'Current lifecycle state of the subscription. \'active\' = fulfilling orders; \'paused\' = consumer-initiated hold; \'cancelled\' = permanently terminated; \'pending\' = awaiting first payment confirmation; \'expired\' = plan term ended without renewal. Drives LIFECYCLE_STATUS for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionType rdf:type rdf:Property ;
    rdfs:label 'Subscription Type' ;
    rdfs:comment 'Classification of the subscription program type. \'auto_replenishment\' covers single-SKU DTC replenishment; \'subscription_box\' covers curated multi-product boxes; \'bundle\' covers fixed product bundles; \'trial\' covers introductory trial subscriptions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrdersFulfilled rdf:type rdf:Property ;
    rdfs:label 'Total Orders Fulfilled' ;
    rdfs:comment 'Cumulative count of successfully fulfilled subscription orders since the subscription start date. Non-derived operational counter maintained by the fulfillment system. Used in subscription tenure analysis and OTIF (On Time In Full) performance tracking.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trialEndDate rdf:type rdf:Property ;
    rdfs:label 'Trial End Date' ;
    rdfs:comment 'Calendar date on which the trial period ends and standard subscription billing commences. Null for non-trial subscriptions. Used to trigger trial-to-paid conversion communications and revenue recognition timing.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialFlag rdf:type rdf:Property ;
    rdfs:label 'Trial Flag' ;
    rdfs:comment 'Indicates whether this subscription was initiated as a trial or introductory offer (True) or as a standard paid subscription (False). Used to segment trial-to-paid conversion analytics and NPD (New Product Development) launch performance.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Origin Network Node Id' ;
    rdfs:comment 'The origin network node id of the demand plan record' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:primaryDemandSupplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Demand Supply Network Node Id' ;
    rdfs:comment 'Reference to the distribution location, warehouse, or market geography for which demand is planned.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:commercialOverlayQuantity rdf:type rdf:Property ;
    rdfs:label 'Commercial Overlay Quantity' ;
    rdfs:comment 'Demand adjustment quantity applied by field sales teams based on customer intelligence, market conditions, and sales pipeline visibility.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Planner-assigned confidence rating in the demand forecast based on data quality, market visibility, and forecast stability.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consensusQuantity rdf:type rdf:Property ;
    rdfs:label 'Consensus Quantity' ;
    rdfs:comment 'Agreed demand forecast quantity representing the single demand signal passed to supply planning after S&OP consensus process. This is the authoritative demand plan.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByPersona rdf:type rdf:Property ;
    rdfs:label 'Created By Persona' ;
    rdfs:comment 'Role or persona of the user who created this demand plan version, used for accountability and collaboration tracking.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandPatternType rdf:type rdf:Property ;
    rdfs:label 'Demand Pattern Type' ;
    rdfs:comment 'Classification of historical demand behavior pattern used to select appropriate statistical forecasting algorithm.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Status' ;
    rdfs:comment 'The demand plan status of the demand plan record' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSensingSignal rdf:type rdf:Property ;
    rdfs:label 'Demand Sensing Signal' ;
    rdfs:comment 'Short-term demand trend indicator derived from real-time POS data, shipment data, and market signals to enable rapid forecast adjustments.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandType rdf:type rdf:Property ;
    rdfs:label 'Demand Type' ;
    rdfs:comment 'The demand type of the demand plan record' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this demand plan version becomes active and is used for supply planning and ATP calculations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date until which this demand plan version remains active. Null indicates the version is currently active with no planned expiration.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastAccuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Percentage' ;
    rdfs:comment 'Historical forecast accuracy metric for this SKU/location/channel combination, used for forecast quality benchmarking and continuous improvement.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastBiasPercentage rdf:type rdf:Property ;
    rdfs:label 'Forecast Bias Percentage' ;
    rdfs:comment 'Systematic tendency to over-forecast or under-forecast, calculated as average percentage deviation from actual demand.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isConsensusVersion rdf:type rdf:Property ;
    rdfs:label 'Is Consensus Version' ;
    rdfs:comment 'Flag indicating whether this version represents the official consensus demand plan approved through the S&OP process and used for supply planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingEventUpliftQuantity rdf:type rdf:Property ;
    rdfs:label 'Marketing Event Uplift Quantity' ;
    rdfs:comment 'Incremental demand quantity expected from planned marketing campaigns, promotions, and brand activation events.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npdLaunchVolumeQuantity rdf:type rdf:Property ;
    rdfs:label 'Npd Launch Volume Quantity' ;
    rdfs:comment 'Forecasted demand quantity for new product launches or product line extensions during the planning period.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planHorizonEnd rdf:type rdf:Property ;
    rdfs:label 'Plan Horizon End' ;
    rdfs:comment 'The plan horizon end of the demand plan record' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planHorizonStart rdf:type rdf:Property ;
    rdfs:label 'Plan Horizon Start' ;
    rdfs:comment 'The plan horizon start of the demand plan record' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'The plan version of the demand plan record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerNotes rdf:type rdf:Property ;
    rdfs:label 'Planner Notes' ;
    rdfs:comment 'Free-text comments and annotations from demand planners explaining assumptions, adjustments, risks, or special considerations for this forecast.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningBucket rdf:type rdf:Property ;
    rdfs:label 'Planning Bucket' ;
    rdfs:comment 'Time granularity of the demand plan (daily, weekly, monthly, quarterly) used for aggregation and reporting.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the planning period (week or month) for which demand is forecasted.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the planning period (week or month) for which demand is forecasted.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalOverlayQuantity rdf:type rdf:Property ;
    rdfs:label 'Promotional Overlay Quantity' ;
    rdfs:comment 'Demand uplift quantity attributed to trade promotions, price discounts, and retail execution activities.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Classification of the primary risk factor affecting demand plan reliability and supply fulfillment capability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Flag' ;
    rdfs:comment 'Indicator that this demand plan carries elevated supply risk due to capacity constraints, material shortages, or demand volatility.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'Original unique identifier of this demand plan record in the source system, used for data lineage and reconciliation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalBaselineQuantity rdf:type rdf:Property ;
    rdfs:label 'Statistical Baseline Quantity' ;
    rdfs:comment 'Unconstrained demand forecast quantity generated by statistical forecasting algorithms before any commercial overlays or adjustments.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToBaselineQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance To Baseline Quantity' ;
    rdfs:comment 'Difference between consensus quantity and statistical baseline quantity, indicating the net impact of all commercial adjustments and overlays.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionName rdf:type rdf:Property ;
    rdfs:label 'Version Name' ;
    rdfs:comment 'Human-readable name of the demand plan version (e.g., \'Statistical Baseline Q1 2024\', \'Consensus Final March 2024\').' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Version Sequence Number' ;
    rdfs:comment 'Sequential version number within the planning cycle, used to track iteration history and version progression.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionType rdf:type rdf:Property ;
    rdfs:label 'Version Type' ;
    rdfs:comment 'Classification of the demand plan version indicating its stage in the S&OP process. Statistical baseline represents unconstrained forecast; consensus represents agreed demand signal passed to supply planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastVersionId rdf:type rdf:Property ;
    rdfs:label 'Forecast Version Id' ;
    rdfs:comment 'Reference to the parent or baseline forecast version from which this version was derived (e.g., statistical baseline that was then adjusted). Nullable for original baseline versions.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ForecastVersion .

ind:forecastSopCycleId rdf:type rdf:Property ;
    rdfs:label 'Forecast Sop Cycle Id' ;
    rdfs:comment 'Reference to the Sales and Operations Planning (S&OP) or Integrated Business Planning (IBP) cycle to which this forecast version belongs.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SopCycle .

ind:primaryForecastSopCycleId rdf:type rdf:Property ;
    rdfs:label 'Primary Forecast Sop Cycle Id' ;
    rdfs:comment 'Foreign key linking to supply.sop_cycle. Business justification: forecast_version needs to be linked to its planning cycle; added new FK sop_cycle_id referencing sop_cycle.sop_cycle_id. Existing planning_cycle_id column renamed to sop_cycle_id, so removed planning_' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SopCycle .

ind:aggregationLevel rdf:type rdf:Property ;
    rdfs:label 'Aggregation Level' ;
    rdfs:comment 'The level of aggregation at which this forecast version is maintained: Stock Keeping Unit (SKU) level, product family, brand, category, sales channel, customer account, geographic region, or global total. [ENUM-REF-CANDIDATE: sku|product_family|brand|category|channel|customer|region|global — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:algorithmUsed rdf:type rdf:Property ;
    rdfs:label 'Algorithm Used' ;
    rdfs:comment 'The algorithm used of the forecast version record' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Comments or notes provided by the approver during the approval process, documenting any conditions, concerns, or guidance related to this forecast version. Nullable if not yet approved or no notes provided.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'The date and time when this forecast version was archived and moved out of active planning use. Nullable if not yet archived.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:biasPercentage rdf:type rdf:Property ;
    rdfs:label 'Bias Percentage' ;
    rdfs:comment 'Forecast bias percentage indicating systematic over-forecasting (positive bias) or under-forecasting (negative bias). A value near zero indicates an unbiased forecast. Nullable if not yet calculated.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandSensingApplied rdf:type rdf:Property ;
    rdfs:label 'Demand Sensing Applied' ;
    rdfs:comment 'Boolean flag indicating whether demand sensing algorithms (short-term forecast adjustments based on real-time Point of Sale (POS) data, shipment data, or other leading indicators) were applied to this forecast version.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Forecast Horizon Days' ;
    rdfs:comment 'The forecast horizon days of the forecast version record' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastMethod rdf:type rdf:Property ;
    rdfs:label 'Forecast Method' ;
    rdfs:comment 'The forecast method of the forecast version record' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastQuantity rdf:type rdf:Property ;
    rdfs:label 'Forecast Quantity' ;
    rdfs:comment 'The forecast quantity of the forecast version record' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Forecast Source System' ;
    rdfs:comment 'Name or identifier of the source system or application that generated or contributed to this forecast version (e.g., \'SAP IBP\', \'TradeEdge\', \'Excel Upload\', \'Salesforce CG Cloud\').' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastVersionStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Version Status' ;
    rdfs:comment 'The forecast version status of the forecast version record' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActiveVersion rdf:type rdf:Property ;
    rdfs:label 'Is Active Version' ;
    rdfs:comment 'Boolean flag indicating whether this forecast version is currently active and being used for planning and execution. Only one version per planning cycle should typically be active at a time.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBaseline rdf:type rdf:Property ;
    rdfs:label 'Is Baseline' ;
    rdfs:comment 'The is baseline of the forecast version record' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFinal rdf:type rdf:Property ;
    rdfs:label 'Is Final' ;
    rdfs:comment 'The is final of the forecast version record' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFinalApprovedVersion rdf:type rdf:Property ;
    rdfs:label 'Is Final Approved Version' ;
    rdfs:comment 'Boolean flag indicating whether this version is the final approved forecast that will be used for operational execution, Material Requirements Planning (MRP), and Distribution Requirements Planning (DRP).' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meanAbsolutePercentageError rdf:type rdf:Property ;
    rdfs:label 'Mean Absolute Percentage Error' ;
    rdfs:comment 'Mean Absolute Percentage Error (MAPE) metric for this forecast version, measuring the average magnitude of forecast errors as a percentage. Lower values indicate better forecast accuracy. Nullable if not yet calculated.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelParameters rdf:type rdf:Property ;
    rdfs:label 'Model Parameters' ;
    rdfs:comment 'The model parameters of the forecast version record' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newProductIntroductionIncluded rdf:type rdf:Property ;
    rdfs:label 'New Product Introduction Included' ;
    rdfs:comment 'Boolean flag indicating whether New Product Development (NPD) or New Product Introduction (NPI) launches were incorporated into this forecast version.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End Date' ;
    rdfs:comment 'The last date of the planning period covered by this forecast version (e.g., end of the fiscal quarter or rolling 18-month horizon).' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start Date' ;
    rdfs:comment 'The first date of the planning period covered by this forecast version (e.g., start of the fiscal quarter or month).' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalEventsIncluded rdf:type rdf:Property ;
    rdfs:label 'Promotional Events Included' ;
    rdfs:comment 'Boolean flag indicating whether trade promotions, marketing campaigns, and promotional events were factored into this forecast version.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation or reason provided when this forecast version was rejected during the approval process. Nullable if version was not rejected.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'The snapshot date of the forecast version record' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'The snapshot timestamp of the forecast version record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:statisticalModelApplied rdf:type rdf:Property ;
    rdfs:label 'Statistical Model Applied' ;
    rdfs:comment 'Name or identifier of the statistical forecasting model or algorithm applied to generate or adjust this forecast version (e.g., \'Exponential Smoothing\', \'ARIMA\', \'Machine Learning Ensemble\', \'Holt-Winters\'). Nullable if no statistical model was used.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeBucket rdf:type rdf:Property ;
    rdfs:label 'Time Bucket' ;
    rdfs:comment 'The time granularity or bucket size used for this forecast version: daily, weekly, monthly, quarterly, or annual periods.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionCode rdf:type rdf:Property ;
    rdfs:label 'Version Code' ;
    rdfs:comment 'Short alphanumeric code or identifier for the forecast version used in system integrations and reporting (e.g., \'STAT_BASE\', \'CONS_V1\', \'FINAL_APR\').' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionDescription rdf:type rdf:Property ;
    rdfs:label 'Version Description' ;
    rdfs:comment 'Detailed textual description or notes about this forecast version, including assumptions, adjustments made, special considerations, or rationale for key changes.' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionLabel rdf:type rdf:Property ;
    rdfs:label 'Version Label' ;
    rdfs:comment 'The version label of the forecast version record' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of the forecast version: draft (under construction), in review (submitted for approval), approved (validated and accepted), rejected (not accepted), archived (historical record), or active (currently in use for planning).' ;
    rdfs:domain ind:ForecastVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryPolicyId rdf:type rdf:Property ;
    rdfs:label 'Inventory Policy Id' ;
    rdfs:comment 'Unique identifier for the inventory policy record. Primary key for this entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryPolicy .

ind:primaryInventorySupplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Supply Network Node Id' ;
    rdfs:comment 'Reference to the distribution facility, warehouse, or storage location node in the supply network where this policy applies.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the supply planning manager or director who approved this inventory policy for operational use.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerOtifCommitmentPercent rdf:type rdf:Property ;
    rdfs:label 'Customer Otif Commitment Percent' ;
    rdfs:comment 'Specific OTIF performance level committed to a customer or channel, which may differ from internal targets and may be contractually binding.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleStockTargetUnits rdf:type rdf:Property ;
    rdfs:label 'Cycle Stock Target Units' ;
    rdfs:comment 'Target cycle stock quantity representing the average inventory held to meet expected demand between replenishments, excluding safety stock.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandVariabilityCoefficient rdf:type rdf:Property ;
    rdfs:label 'Demand Variability Coefficient' ;
    rdfs:comment 'Statistical measure of demand variability (coefficient of variation or standard deviation) used in safety stock calculations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fillRateTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Target Percent' ;
    rdfs:comment 'Target percentage of customer demand that should be fulfilled from available inventory without backorders or stockouts.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryPolicyStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Policy Status' ;
    rdfs:comment 'The inventory policy status of the inventory policy record' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date when this inventory policy was last reviewed and validated by the supply planning team.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeVariabilityDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Variability Days' ;
    rdfs:comment 'Standard deviation or variance of replenishment lead time in days, used to account for supply uncertainty in safety stock calculations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSize rdf:type rdf:Property ;
    rdfs:label 'Lot Size' ;
    rdfs:comment 'The lot size of the inventory policy record' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStockLevel rdf:type rdf:Property ;
    rdfs:label 'Max Stock Level' ;
    rdfs:comment 'The max stock level of the inventory policy record' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumStockLevelUnits rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level Units' ;
    rdfs:comment 'Maximum inventory level allowed at this location for this SKU, used to prevent overstocking and manage warehouse capacity constraints.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementWindowDays rdf:type rdf:Property ;
    rdfs:label 'Measurement Window Days' ;
    rdfs:comment 'Time period in days over which service level performance is measured and evaluated against targets (e.g., rolling 30 days, 90 days, quarterly).' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minStockLevel rdf:type rdf:Property ;
    rdfs:label 'Min Stock Level' ;
    rdfs:comment 'The min stock level of the inventory policy record' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumStockLevelUnits rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Level Units' ;
    rdfs:comment 'Minimum inventory level that should be maintained at this location for this SKU, typically aligned with safety stock or regulatory requirements.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next review and update of this inventory policy, ensuring policies remain aligned with business conditions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onTimeDeliveryTargetPercent rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Target Percent' ;
    rdfs:comment 'Target percentage of orders that should be delivered by the customer-requested or committed delivery date.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderUpToLevel rdf:type rdf:Property ;
    rdfs:label 'Order Up To Level' ;
    rdfs:comment 'The order up to level of the inventory policy record' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifCompositeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Otif Composite Target Percent' ;
    rdfs:comment 'Composite OTIF (On Time In Full) target percentage representing orders delivered both on time and in full quantity, a critical customer service metric.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseIndicator rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Indicator' ;
    rdfs:comment 'Indicates whether failure to meet the defined service level targets will result in financial penalties, chargebacks, or other contractual consequences.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Business identifier code for the inventory policy, used for external reference and reporting.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNotes rdf:type rdf:Property ;
    rdfs:label 'Policy Notes' ;
    rdfs:comment 'Free-text notes capturing special considerations, exceptions, seasonal adjustments, or business context relevant to this inventory policy.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the inventory policy indicating its approval and operational state. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|expired|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'The policy type of the inventory policy record' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'The reorder point of the inventory policy record' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPointUnits rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Units' ;
    rdfs:comment 'Inventory level at which a replenishment order should be triggered, calculated as lead time demand plus safety stock.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentMethod rdf:type rdf:Property ;
    rdfs:label 'Replenishment Method' ;
    rdfs:comment 'The inventory replenishment strategy applied: MRP (Material Requirements Planning), DRP (Distribution Requirements Planning), VMI (Vendor Managed Inventory), JIT (Just In Time), Kanban, or Fixed Order Quantity.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerMandatedTargetFlag rdf:type rdf:Property ;
    rdfs:label 'Retailer Mandated Target Flag' ;
    rdfs:comment 'Indicates whether the service level targets are mandated by a retail customer as part of their supplier requirements or vendor compliance program.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCycleDays rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Days' ;
    rdfs:comment 'Frequency in days at which inventory levels are reviewed and replenishment decisions are made for this SKU-location combination.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Review Period Days' ;
    rdfs:comment 'The review period days of the inventory policy record' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockCalculatedUnits rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Calculated Units' ;
    rdfs:comment 'System-calculated safety stock quantity based on demand variability, lead time variability, and service level inputs before manual approval or adjustment.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Calculation Method' ;
    rdfs:comment 'The methodology used to calculate safety stock: fixed value, forecast error-based, demand variability, lead time variability, combined variability, or service level-driven calculation.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockDaysOfSupply rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Days Of Supply' ;
    rdfs:comment 'Safety stock expressed as the number of days of average demand coverage, providing a time-based view of inventory buffer.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockTargetUnits rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Target Units' ;
    rdfs:comment 'Target safety stock quantity in base units of measure, representing the buffer inventory to protect against demand and supply variability.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockUnits rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Units' ;
    rdfs:comment 'The safety stock units of the inventory policy record' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelTargetPct rdf:type rdf:Property ;
    rdfs:label 'Service Level Target Pct' ;
    rdfs:comment 'The service level target pct of the inventory policy record' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Service Level Target Percent' ;
    rdfs:comment 'Target service level percentage (e.g., 95%, 98%, 99.5%) representing the desired probability of not stocking out during the replenishment lead time.' ;
    rdfs:domain ind:InventoryPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockId rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Id' ;
    rdfs:comment 'Unique identifier for the safety stock calculation record. Primary key for the safety stock entity.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySafetySupplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Safety Supply Network Node Id' ;
    rdfs:comment 'Reference to the storage location, distribution center, or facility where the safety stock applies. Links to distribution facility master data.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:standardCostId rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Id' ;
    rdfs:comment 'Foreign key linking to finance.standard_cost. Business justification: Safety stock financial valuation for working capital reporting uses standard cost per unit. The safety_stock table already carries holding_cost_per_unit and stockout_cost_per_unit, which are derived f' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StandardCost .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'The ABC classification of the SKU based on revenue contribution or volume. A items are high-value requiring tight control; B items are moderate; C items are low-value. Influences service level targets and safety stock investment decisions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'The date and time when the safety stock calculation was approved by the planner. Marks the transition from calculated to approved state in the workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedSafetyStockUnits rdf:type rdf:Property ;
    rdfs:label 'Approved Safety Stock Units' ;
    rdfs:comment 'The final approved safety stock quantity in base units of measure after planner review and adjustment. This is the target value used for inventory policy execution and Available to Promise (ATP) calculations.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyDemandUnits rdf:type rdf:Property ;
    rdfs:label 'Average Daily Demand Units' ;
    rdfs:comment 'The mean daily demand quantity in base units of measure. Used as input to safety stock calculations and represents expected consumption rate.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Average Lead Time Days' ;
    rdfs:comment 'The mean replenishment lead time in days from order placement to receipt. Used in safety stock calculations to determine the exposure period for demand and supply variability.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedSafetyStockUnits rdf:type rdf:Property ;
    rdfs:label 'Calculated Safety Stock Units' ;
    rdfs:comment 'The system-calculated safety stock quantity in base units of measure. This is the raw output from the calculation engine before any manual adjustments or approvals.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The methodology used to calculate the safety stock quantity. Statistical methods use demand and lead time variability; days-of-supply uses fixed coverage targets; manual override represents planner judgment; service level and lead time methods focus on specific risk factors; hybrid combines multiple approaches.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'The date and time when the safety stock calculation was executed by the planning system. Provides audit trail for calculation runs and version control.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:days rdf:type rdf:Property ;
    rdfs:label 'Days' ;
    rdfs:comment 'The days of the safety stock record' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOfSupplyTarget rdf:type rdf:Property ;
    rdfs:label 'Days Of Supply Target' ;
    rdfs:comment 'The target safety stock coverage expressed in days of average demand. Used when calculation method is days-of-supply based. Represents the buffer duration to protect against stockouts.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandClassification rdf:type rdf:Property ;
    rdfs:label 'Demand Classification' ;
    rdfs:comment 'The demand pattern category for this SKU-location. Steady indicates consistent demand; seasonal shows periodic peaks; erratic has high variability; lumpy has infrequent large orders; intermittent has sporadic demand; obsolete indicates phase-out. Influences calculation method selection.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandVariability rdf:type rdf:Property ;
    rdfs:label 'Demand Variability' ;
    rdfs:comment 'The demand variability of the safety stock record' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date when this safety stock target expires and is replaced by a new calculation. Used to manage the lifecycle of safety stock policies and trigger recalculation cycles.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastAccuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Percent' ;
    rdfs:comment 'The historical forecast accuracy for this SKU-location combination expressed as a percentage. Used to adjust safety stock calculations based on forecasting reliability. Lower accuracy typically requires higher safety stock.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Holding Cost Per Unit' ;
    rdfs:comment 'The annual cost to hold one unit of inventory including warehousing, insurance, obsolescence, and capital cost. Used in inventory optimization to balance service level against carrying cost. Expressed in local currency.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Review Timestamp' ;
    rdfs:comment 'The date and time when the safety stock record was last reviewed by a planner, regardless of whether changes were made. Used to track planner engagement and ensure regular review cycles.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leadTimeVariability rdf:type rdf:Property ;
    rdfs:label 'Lead Time Variability' ;
    rdfs:comment 'The lead time variability of the safety stock record' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderMultiple rdf:type rdf:Property ;
    rdfs:label 'Order Multiple' ;
    rdfs:comment 'The order quantity increment or lot size multiple required by supplier or production constraints. Safety stock and reorder quantities must align with this multiple.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideNotes rdf:type rdf:Property ;
    rdfs:label 'Override Notes' ;
    rdfs:comment 'Free-text explanation provided by the planner when manually overriding the calculated safety stock. Documents the business context and rationale for the adjustment.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'The business reason code when approved safety stock differs from calculated safety stock. Captures planner judgment factors such as promotional events, seasonal peaks, supply chain risks, new product introductions, product phase-outs, or quality concerns.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'The approval workflow status of the safety stock calculation. Pending review indicates awaiting planner action; approved means active for execution; rejected requires recalculation; under revision is being adjusted; expired indicates the planning period has passed.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Status' ;
    rdfs:comment 'The safety stock status of the safety stock record' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelPct rdf:type rdf:Property ;
    rdfs:label 'Service Level Pct' ;
    rdfs:comment 'The service level pct of the safety stock record' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockoutCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Stockout Cost Per Unit' ;
    rdfs:comment 'The estimated cost of a stockout per unit including lost sales, expediting costs, customer dissatisfaction, and brand impact. Used in service level optimization to quantify the cost of Out of Stock (OOS) events. Expressed in local currency.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyRiskScore rdf:type rdf:Property ;
    rdfs:label 'Supply Risk Score' ;
    rdfs:comment 'A quantitative risk score assessing supply chain vulnerability for this SKU-location. Higher scores indicate greater risk from supplier reliability, geopolitical factors, transportation disruptions, or single-source dependencies. Used to adjust safety stock buffers.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetServiceLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Target Service Level Percent' ;
    rdfs:comment 'The desired in-stock probability or fill rate target expressed as a percentage (e.g., 95.00, 98.50). Drives the safety stock buffer size to achieve the specified On Shelf Availability (OSA) or Service Level Agreement (SLA).' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:units rdf:type rdf:Property ;
    rdfs:label 'Units' ;
    rdfs:comment 'The units of the safety stock record' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:xyzClassification rdf:type rdf:Property ;
    rdfs:label 'Xyz Classification' ;
    rdfs:comment 'The XYZ classification based on demand variability. X items have low variability (predictable); Y items have moderate variability; Z items have high variability (unpredictable). Used alongside ABC to determine safety stock strategy.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zScore rdf:type rdf:Property ;
    rdfs:label 'Z Score' ;
    rdfs:comment 'The standard normal distribution value corresponding to the target service level. Used in statistical safety stock formulas to translate service level percentage into buffer quantity.' ;
    rdfs:domain ind:SafetyStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Id' ;
    rdfs:comment 'Unique identifier for the supply replenishment order record. Primary key for this entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplenishmentOrder .

ind:carrierContractId rdf:type rdf:Property ;
    rdfs:label 'Carrier Contract Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier_contract. Business justification: CONTRACT_COMPLIANCE: Each replenishment order is governed by a carrier contract; needed for rate and penalty enforcement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierContract .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Identifier of the logistics carrier or transportation provider assigned to execute this replenishment shipment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:consensusDemandId rdf:type rdf:Property ;
    rdfs:label 'Consensus Demand Id' ;
    rdfs:comment 'Foreign key linking to supply.consensus_demand. Business justification: Replenishment orders are generated to fulfill consensus demand volumes agreed upon in the S&OP process. Linking supply_replenishment_order to the specific consensus_demand record it fulfills enables d' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsensusDemand .

ind:destinationLocationSupplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Supply Network Node Id' ;
    rdfs:comment 'Identifier of the supply network node to which inventory will be delivered (distribution center, warehouse, or retail location).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:laneId rdf:type rdf:Property ;
    rdfs:label 'Lane Id' ;
    rdfs:comment 'Foreign key linking to logistics.lane. Business justification: ORDER_EXECUTION: Replenishment order execution follows a specific lane; lane_id links order to transportation routing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:logisticsShipmentId rdf:type rdf:Property ;
    rdfs:label 'Logistics Shipment Id' ;
    rdfs:comment 'Identifier of the physical shipment record associated with this replenishment order once released for execution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LogisticsShipment .

ind:networkLaneId rdf:type rdf:Property ;
    rdfs:label 'Network Lane Id' ;
    rdfs:comment 'Foreign key linking to supply.network_lane. Business justification: A replenishment order travels along a specific supply network lane (source-destination pair). The network_lane is the supply domain\'s lane entity defining lead times, costs, and capacity for the route' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkLane .

ind:primarySupplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Supply Network Node Id' ;
    rdfs:comment 'Identifier of the supply network node from which inventory will be shipped (plant, distribution center, or warehouse).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:sourceNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Source Network Node Id' ;
    rdfs:comment 'The source network node id of the supply replenishment order record' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:supplierSiteId rdf:type rdf:Property ;
    rdfs:label 'Supplier Site Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_site. Business justification: Replenishment orders ship from a specific supplier site (factory or distribution point). This link supports site-level OTIF tracking, capacity constraint analysis, and compliance auditing — essential ' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierSite .

ind:triggeredSafetyStockId rdf:type rdf:Property ;
    rdfs:label 'Triggered Safety Stock Id' ;
    rdfs:comment 'Foreign key linking to supply.safety_stock. Business justification: When a replenishment order is triggered by a safety stock breach (safety_stock_trigger_flag = true), linking to the specific safety_stock record that triggered it enables precise demand-supply pegging' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyStock .

ind:triggeringOrderId rdf:type rdf:Property ;
    rdfs:label 'Triggering Order Id' ;
    rdfs:comment 'Foreign key linking to sales.order. Business justification: Demand-driven replenishment (DRP) in consumer goods traces replenishment orders back to the customer sales order that triggered them. This link enables end-to-end order fulfillment traceability, backo' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'Actual date the goods were received at the destination location.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availableToPromiseQuantity rdf:type rdf:Property ;
    rdfs:label 'Available To Promise Quantity' ;
    rdfs:comment 'ATP quantity at the source location at the time the replenishment order was created, used to validate supply availability.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drpRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Drp Run Timestamp' ;
    rdfs:comment 'Date and time when the DRP execution run that generated this order was executed.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The due date of the supply replenishment order record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastDemandQuantity rdf:type rdf:Property ;
    rdfs:label 'Forecast Demand Quantity' ;
    rdfs:comment 'Forecasted demand quantity at the destination location that drove the replenishment calculation.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderCostAmount rdf:type rdf:Property ;
    rdfs:label 'Order Cost Amount' ;
    rdfs:comment 'Total cost associated with this replenishment order, including product cost, transportation cost, and handling fees.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Free-text notes or special instructions related to this replenishment order, such as handling requirements or routing constraints.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Date' ;
    rdfs:comment 'Target date for goods receipt at the destination location, accounting for transit lead time.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedShipDate rdf:type rdf:Property ;
    rdfs:label 'Planned Ship Date' ;
    rdfs:comment 'Target date for shipment departure from the source location as calculated by the DRP engine.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promisedDate rdf:type rdf:Property ;
    rdfs:label 'Promised Date' ;
    rdfs:comment 'The promised date of the supply replenishment order record' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Actual quantity of the SKU received at the destination location, captured at goods receipt.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Number' ;
    rdfs:comment 'Business-facing unique order number for the replenishment order, used for tracking and reference across systems and communications.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'The requested date of the supply replenishment order record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity' ;
    rdfs:comment 'Quantity of the SKU requested for replenishment as calculated by the DRP engine or demand planner.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Trigger Flag' ;
    rdfs:comment 'Indicates whether this replenishment order was triggered by inventory falling below safety stock threshold at the destination location.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'The ship date of the supply replenishment order record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'Actual quantity of the SKU shipped from the source location, captured at dispatch.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyReplenishmentOrderCode rdf:type rdf:Property ;
    rdfs:label 'Supply Replenishment Order Code' ;
    rdfs:comment 'The supply replenishment order code of the supply replenishment order record' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyReplenishmentOrderDescription rdf:type rdf:Property ;
    rdfs:label 'Supply Replenishment Order Description' ;
    rdfs:comment 'The supply replenishment order description of the supply replenishment order record' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyReplenishmentOrderName rdf:type rdf:Property ;
    rdfs:label 'Supply Replenishment Order Name' ;
    rdfs:comment 'The supply replenishment order name of the supply replenishment order record' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyReplenishmentOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Supply Replenishment Order Status' ;
    rdfs:comment 'The supply replenishment order status of the supply replenishment order record' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transit Lead Time Days' ;
    rdfs:comment 'Planned number of days for goods to travel from source to destination location.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportationMode rdf:type rdf:Property ;
    rdfs:label 'Transportation Mode' ;
    rdfs:comment 'Primary mode of transportation planned or used for this replenishment shipment.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkNodeId rdf:type rdf:Property ;
    rdfs:label 'Network Node Id' ;
    rdfs:comment 'Primary key for network_node' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Parent Network Node Id' ;
    rdfs:comment 'The parent network node id of the network node record' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:capacityClass rdf:type rdf:Property ;
    rdfs:label 'Capacity Class' ;
    rdfs:comment 'Classification of the supply network node storage and throughput capacity used in IBP supply planning for capacity-constrained optimization.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDockEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Enabled Flag' ;
    rdfs:comment 'Indicates whether this supply network node supports cross-docking operations (direct transfer without storage). Used in transportation and distribution planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dsdEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Enabled Flag' ;
    rdfs:comment 'Indicates whether this supply network node supports Direct Store Delivery operations. Used in distribution planning and route optimization.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:echelonLevel rdf:type rdf:Property ;
    rdfs:label 'Echelon Level' ;
    rdfs:comment 'The echelon level of the network node record' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gln rdf:type rdf:Property ;
    rdfs:label 'Gln' ;
    rdfs:comment 'GS1 Global Location Number uniquely identifying the physical location of the supply network node for EDI transactions and supply chain visibility.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether this supply network node is certified to handle and store hazardous materials. Used for product allocation and regulatory compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkNodeStatus rdf:type rdf:Property ;
    rdfs:label 'Network Node Status' ;
    rdfs:comment 'The network node status of the network node record' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classification of the supply network node indicating its role in the supply chain (manufacturing plant, regional distribution center, forward distribution center, co-manufacturer, third-party logistics warehouse, cross-dock facility, or supplier location). [ENUM-REF-CANDIDATE: manufacturing_plant|regional_dc|forward_dc|co_manufacturer|3pl_warehouse|cross_dock|supplier_location — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningGroup rdf:type rdf:Property ;
    rdfs:label 'Planning Group' ;
    rdfs:comment 'Planning group or cluster assignment for the supply network node used in IBP and S&OP processes to aggregate nodes for planning purposes.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Replenishment Frequency' ;
    rdfs:comment 'Standard replenishment frequency for inventory at this supply network node. Used in DRP planning and inventory policy definition.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockDays rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Days' ;
    rdfs:comment 'Target safety stock coverage in days of supply maintained at this network node. Used in inventory optimization and S&OP planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingPriority rdf:type rdf:Property ;
    rdfs:label 'Sourcing Priority' ;
    rdfs:comment 'Priority ranking of this supply network node in sourcing rules and allocation logic (lower number = higher priority). Used in IBP supply planning and ATP/CTP allocation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Units' ;
    rdfs:comment 'Maximum storage capacity of the supply network node measured in standard storage units (pallets, cases, or cubic meters). Used for inventory optimization and DRP planning.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCapacityUom rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Uom' ;
    rdfs:comment 'Unit of measure for the storage capacity (pallets, cases, cubic meters, square meters). Aligns with WMS and IBP planning units.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputCapacityDaily rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity Daily' ;
    rdfs:comment 'Maximum daily throughput capacity of the supply network node measured in standard units (cases, pallets, or production units per day). Used for production and distribution planning.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputCapacityUom rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity Uom' ;
    rdfs:comment 'Unit of measure for the daily throughput capacity. Used in production scheduling and distribution planning.' ;
    rdfs:domain ind:NetworkNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Enabled Flag' ;
    rdfs:comment 'Indicates whether this supply network node participates in Vendor Managed Inventory programs. Used in collaborative planning and replenishment processes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityQuantity rdf:type rdf:Property ;
    rdfs:label 'Capacity Quantity' ;
    rdfs:comment 'Maximum throughput capacity of this lane per planning period (day, week, month), representing the upper limit of goods that can be moved. Used by Supply Planning and Sales and Operations Planning (S&OP) for capacity-constrained optimization.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUom rdf:type rdf:Property ;
    rdfs:label 'Capacity Uom' ;
    rdfs:comment 'Unit of measure for the capacity quantity field, indicating how lane capacity is measured and constrained. [ENUM-REF-CANDIDATE: EA|CS|PL|TU|KG|LB|L|GAL — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Regulatory or business compliance requirements applicable to this lane, such as temperature control (Good Manufacturing Practice - GMP), hazardous materials handling (Environmental Protection Agency - EPA), or cross-border customs (Food and Drug Administration - FDA).' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'Standard transportation or transfer cost per unit of measure for moving goods along this lane. Used for supply chain cost modeling and total landed cost calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'The distance km of the network lane record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryLane rdf:type rdf:Property ;
    rdfs:label 'Is Primary Lane' ;
    rdfs:comment 'Boolean flag indicating whether this lane is the primary (preferred) sourcing route for the destination. True if this is the default lane used under normal conditions; false for backup or secondary lanes.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Lane Cost Per Unit' ;
    rdfs:comment 'The lane cost per unit of the network lane record' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laneMode rdf:type rdf:Property ;
    rdfs:label 'Lane Mode' ;
    rdfs:comment 'The lane mode of the network lane record' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneType rdf:type rdf:Property ;
    rdfs:label 'Lane Type' ;
    rdfs:comment 'Classification of the supply network lane based on the nature of the sourcing relationship: production (from manufacturing plant), transfer (between internal facilities), external procurement (from supplier), direct shipment (plant to customer), cross-dock (no storage), or drop-ship (supplier to customer).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'Identifier of the user or system process that last modified this supply network lane record, used for audit trail and data governance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Lot Size Quantity' ;
    rdfs:comment 'Standard batch or lot size for replenishment orders on this lane. Orders are typically rounded to multiples of this quantity for operational efficiency (e.g., full pallet, full truckload).' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Max Capacity Units' ;
    rdfs:comment 'The max capacity units of the network lane record' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum quantity that can be ordered or shipped on this lane in a single replenishment cycle, constrained by capacity, vehicle limits, or storage restrictions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Order Quantity' ;
    rdfs:comment 'The min order quantity of the network lane record' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minShipmentUnits rdf:type rdf:Property ;
    rdfs:label 'Min Shipment Units' ;
    rdfs:comment 'The min shipment units of the network lane record' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkLaneStatus rdf:type rdf:Property ;
    rdfs:label 'Network Lane Status' ;
    rdfs:comment 'Current lifecycle status of the supply network lane: active (operational), inactive (temporarily disabled), suspended (on hold), planned (future activation), or decommissioned (permanently closed).' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otif Target Pct' ;
    rdfs:comment 'Specific target percentage for On Time In Full delivery performance on this lane, a key supply chain Key Performance Indicator (KPI) measuring the percentage of orders delivered on time and complete.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Processing Lead Time Days' ;
    rdfs:comment 'Time in days required for order processing, picking, packing, and loading at the source location before shipment begins.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Standard Lead Time Days' ;
    rdfs:comment 'Total planned lead time in days from order placement to goods receipt at destination, including processing time, transportation time, and buffer. Used by Material Requirements Planning (MRP) and Distribution Requirements Planning (DRP) for replenishment calculations.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transit Time Days' ;
    rdfs:comment 'The transit time days of the network lane record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'The transport mode of the network lane record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportationLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Transportation Lead Time Days' ;
    rdfs:comment 'Transit time in days for goods to move from source to destination, excluding processing and handling time. Component of the total standard lead time.' ;
    rdfs:domain ind:NetworkLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atpRecordId rdf:type rdf:Property ;
    rdfs:label 'Atp Record Id' ;
    rdfs:comment 'Primary key for atp_record' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAtpSupplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Atp Supply Network Node Id' ;
    rdfs:comment 'Reference to the distribution facility or warehouse location where ATP is calculated.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'The quantity already committed or reserved for existing sales orders, reducing available ATP.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atpCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Atp Calculation Method' ;
    rdfs:comment 'The method used to calculate ATP. Simple ATP considers only on-hand inventory minus allocations. Cumulative ATP includes planned receipts over time. Multi-level ATP considers BOM components. Product allocation ATP applies allocation rules across customer segments.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpCheckHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Atp Check Horizon Days' ;
    rdfs:comment 'The number of days into the future that the ATP check considers for availability. Defines the planning horizon for promise calculations.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atpConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Atp Confirmation Number' ;
    rdfs:comment 'Unique confirmation number generated when ATP is reserved for a sales order, providing traceability between ATP records and order promising.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpDate rdf:type rdf:Property ;
    rdfs:label 'Atp Date' ;
    rdfs:comment 'The date for which ATP quantity is calculated. Represents the promise date for order fulfillment.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:atpQuantity rdf:type rdf:Property ;
    rdfs:label 'Atp Quantity' ;
    rdfs:comment 'The confirmed quantity available to promise to customers for the given SKU, location, and date. Represents uncommitted inventory available for new orders.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atpRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Atp Record Status' ;
    rdfs:comment 'The atp record status of the atp record record' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpStatus rdf:type rdf:Property ;
    rdfs:label 'Atp Status' ;
    rdfs:comment 'The current status of the ATP record. Available indicates positive ATP. Constrained indicates limited availability. Blocked indicates ATP is not available for promising. Expired indicates the ATP date has passed.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableDate rdf:type rdf:Property ;
    rdfs:label 'Available Date' ;
    rdfs:comment 'The available date of the atp record record' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'The available quantity of the atp record record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backorderQuantity rdf:type rdf:Property ;
    rdfs:label 'Backorder Quantity' ;
    rdfs:comment 'The quantity of unfulfilled demand from previous periods that impacts current ATP availability.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedQuantity rdf:type rdf:Property ;
    rdfs:label 'Committed Quantity' ;
    rdfs:comment 'The committed quantity of the atp record record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctpQuantity rdf:type rdf:Property ;
    rdfs:label 'Ctp Quantity' ;
    rdfs:comment 'The quantity that can be promised considering both current inventory and planned production or supply receipts. Extends ATP by including future supply.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeAtp rdf:type rdf:Property ;
    rdfs:label 'Cumulative Atp' ;
    rdfs:comment 'The cumulative atp of the atp record record' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeAtpQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Atp Quantity' ;
    rdfs:comment 'The cumulative ATP quantity calculated across multiple time periods, showing total available quantity from current date through the ATP date.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerPriorityTier rdf:type rdf:Property ;
    rdfs:label 'Customer Priority Tier' ;
    rdfs:comment 'The priority tier of the customer or channel for which ATP is being calculated, used in allocation scenarios where high-priority customers receive preferential ATP.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastConsumptionQuantity rdf:type rdf:Property ;
    rdfs:label 'Forecast Consumption Quantity' ;
    rdfs:comment 'The quantity of forecast demand consumed by actual sales orders, used in ATP calculations to avoid double-counting demand.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intransitQuantity rdf:type rdf:Property ;
    rdfs:label 'Intransit Quantity' ;
    rdfs:comment 'The quantity currently in transit to the location that will contribute to ATP upon arrival.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Shelf Life Days' ;
    rdfs:comment 'The minimum remaining shelf life in days required for the product to be available for promising, ensuring customers receive products with adequate shelf life.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onHandInventory rdf:type rdf:Property ;
    rdfs:label 'On Hand Inventory' ;
    rdfs:comment 'The physical inventory quantity available at the location at the time of ATP calculation.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQuantity rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity' ;
    rdfs:comment 'The on hand quantity of the atp record record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Quantity' ;
    rdfs:comment 'The quantity expected to be received from production orders, purchase orders, or transfers by the ATP date.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningVersion rdf:type rdf:Property ;
    rdfs:label 'Planning Version' ;
    rdfs:comment 'The planning scenario or version identifier in SAP IBP under which this ATP calculation was performed, enabling what-if analysis and scenario planning.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productAllocationGroup rdf:type rdf:Property ;
    rdfs:label 'Product Allocation Group' ;
    rdfs:comment 'The allocation group or priority segment assigned to this ATP calculation, used when ATP is allocated across customer tiers or channels.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Production Order Quantity' ;
    rdfs:comment 'The quantity scheduled for production that will be available by the ATP date.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Quantity' ;
    rdfs:comment 'The quantity on open purchase orders expected to be received by the ATP date.' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyQuantity rdf:type rdf:Property ;
    rdfs:label 'Supply Quantity' ;
    rdfs:comment 'The supply quantity of the atp record record' ;
    rdfs:domain ind:AtpRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineDemandVolume rdf:type rdf:Property ;
    rdfs:label 'Baseline Demand Volume' ;
    rdfs:comment 'The total baseline demand volume (in units) across all SKUs for the planning horizon at the start of this cycle.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consensusDemandVolume rdf:type rdf:Property ;
    rdfs:label 'Consensus Demand Volume' ;
    rdfs:comment 'The total consensus demand volume (in units) across all SKUs after demand review adjustments.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consensusMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Consensus Meeting Date' ;
    rdfs:comment 'The consensus meeting date of the sop cycle record' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constrainedSupplyVolume rdf:type rdf:Property ;
    rdfs:label 'Constrained Supply Volume' ;
    rdfs:comment 'The total constrained supply volume (in units) that can be delivered given capacity and material constraints.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the cycle for external reference and system integration (e.g., \'SOP-2024-01\', \'IBP-Q1-24\').' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleEndDate rdf:type rdf:Property ;
    rdfs:label 'Cycle End Date' ;
    rdfs:comment 'The date when this S&OP cycle is scheduled to complete and be locked (typically before the start of the planning month).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleLockedDate rdf:type rdf:Property ;
    rdfs:label 'Cycle Locked Date' ;
    rdfs:comment 'The date when this S&OP cycle was locked and finalized.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleLockedFlag rdf:type rdf:Property ;
    rdfs:label 'Cycle Locked Flag' ;
    rdfs:comment 'Indicates whether this S&OP cycle has been locked and no further changes are permitted (True if locked, False if still open for edits).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Business-friendly name or label for the S&OP cycle (e.g., \'January 2024 S&OP Cycle\', \'Q1 FY2024 IBP\').' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleNotes rdf:type rdf:Property ;
    rdfs:label 'Cycle Notes' ;
    rdfs:comment 'General free-text notes or comments about this S&OP cycle, including special circumstances, deviations from standard process, or other relevant context.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cyclePhase rdf:type rdf:Property ;
    rdfs:label 'Cycle Phase' ;
    rdfs:comment 'Current phase of the S&OP cycle: statistical_forecast (initial statistical forecast generation), demand_review (demand planning team review), supply_review (supply planning team review), pre_sop (pre-S&OP reconciliation meeting), executive_sop (executive S&OP decision meeting), closed (cycle completed and locked).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleStartDate rdf:type rdf:Property ;
    rdfs:label 'Cycle Start Date' ;
    rdfs:comment 'The date when this S&OP cycle officially begins (typically the first day of the cycle month).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Status' ;
    rdfs:comment 'The cycle status of the sop cycle record' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'The cadence or type of S&OP cycle: monthly (standard monthly cadence), quarterly (quarterly review), annual (annual planning), rolling (continuous rolling horizon), event_driven (triggered by specific business events).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandConsensusAchievedFlag rdf:type rdf:Property ;
    rdfs:label 'Demand Consensus Achieved Flag' ;
    rdfs:comment 'Indicates whether demand consensus was achieved during the demand review phase (True if consensus reached, False otherwise).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:demandReviewDate rdf:type rdf:Property ;
    rdfs:label 'Demand Review Date' ;
    rdfs:comment 'The demand review date of the sop cycle record' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:demandReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Demand Review Due Date' ;
    rdfs:comment 'Target date by which the demand review phase must be completed.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executiveApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Executive Approval Date' ;
    rdfs:comment 'The date when the executive sponsor formally approved the S&OP plan for this cycle.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executiveApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Executive Approval Flag' ;
    rdfs:comment 'Indicates whether the executive S&OP meeting approved the plan (True if approved, False if rejected or pending).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executiveApprovalNotes rdf:type rdf:Property ;
    rdfs:label 'Executive Approval Notes' ;
    rdfs:comment 'Free-text notes or comments from the executive sponsor regarding the approval decision, including any conditions or action items.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executiveReviewDate rdf:type rdf:Property ;
    rdfs:label 'Executive Review Date' ;
    rdfs:comment 'The executive review date of the sop cycle record' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executiveSopMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Executive Sop Meeting Date' ;
    rdfs:comment 'Scheduled date for the executive S&OP meeting where senior leadership reviews and approves the plan.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month number) within the fiscal year (e.g., 1 for January, 12 for December).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year to which this planning cycle belongs (e.g., 2024).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frozenPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Frozen Period Months' ;
    rdfs:comment 'The number of months at the start of the planning horizon that are frozen and not subject to change (typically 0-3 months).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:keyAssumptions rdf:type rdf:Property ;
    rdfs:label 'Key Assumptions' ;
    rdfs:comment 'Free-text field capturing the key business assumptions underlying this S&OP cycle (e.g., promotional plans, market trends, supply constraints, new product launches).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyRisks rdf:type rdf:Property ;
    rdfs:label 'Key Risks' ;
    rdfs:comment 'Free-text field documenting the key risks identified during this S&OP cycle (e.g., supplier reliability, demand volatility, capacity constraints).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationActions rdf:type rdf:Property ;
    rdfs:label 'Mitigation Actions' ;
    rdfs:comment 'Free-text field describing the mitigation actions agreed upon to address identified risks and supply gaps.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseStatus rdf:type rdf:Property ;
    rdfs:label 'Phase Status' ;
    rdfs:comment 'Status of the current cycle phase: not_started (phase has not begun), in_progress (phase is actively underway), completed (phase finished and approved), on_hold (phase temporarily paused), cancelled (phase or cycle cancelled).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonMonths rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Months' ;
    rdfs:comment 'The number of months into the future that this S&OP cycle plans (e.g., 18 months, 24 months).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningMonth rdf:type rdf:Property ;
    rdfs:label 'Planning Month' ;
    rdfs:comment 'The target month for which this S&OP cycle is planning demand and supply (typically the first day of the planning month).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preSopMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Pre Sop Meeting Date' ;
    rdfs:comment 'Scheduled date for the pre-S&OP reconciliation meeting where demand and supply teams align on recommendations.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preSopReviewDate rdf:type rdf:Property ;
    rdfs:label 'Pre Sop Review Date' ;
    rdfs:comment 'The pre sop review date of the sop cycle record' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sopCycleStatus rdf:type rdf:Property ;
    rdfs:label 'Sop Cycle Status' ;
    rdfs:comment 'The sop cycle status of the sop cycle record' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalForecastDueDate rdf:type rdf:Property ;
    rdfs:label 'Statistical Forecast Due Date' ;
    rdfs:comment 'Target date by which the statistical forecast phase must be completed.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplyConsensusAchievedFlag rdf:type rdf:Property ;
    rdfs:label 'Supply Consensus Achieved Flag' ;
    rdfs:comment 'Indicates whether supply consensus was achieved during the supply review phase (True if consensus reached, False otherwise).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyGapVolume rdf:type rdf:Property ;
    rdfs:label 'Supply Gap Volume' ;
    rdfs:comment 'The total supply gap (in units) representing the difference between consensus demand and constrained supply (positive indicates shortfall, negative indicates surplus).' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Supply Review Date' ;
    rdfs:comment 'The supply review date of the sop cycle record' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplyReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Supply Review Due Date' ;
    rdfs:comment 'Target date by which the supply review phase must be completed.' ;
    rdfs:domain ind:SopCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this consensus demand record is currently active and should be used by supply planning. False indicates the record has been superseded or deactivated.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agreedDate rdf:type rdf:Property ;
    rdfs:label 'Agreed Date' ;
    rdfs:comment 'The agreed date of the consensus demand record' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedQuantity rdf:type rdf:Property ;
    rdfs:label 'Approved Quantity' ;
    rdfs:comment 'The approved quantity of the consensus demand record' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biasIndicator rdf:type rdf:Property ;
    rdfs:label 'Bias Indicator' ;
    rdfs:comment 'Indicator of systematic forecasting bias based on historical performance. Over-forecast indicates consistent overestimation; under-forecast indicates consistent underestimation; neutral indicates balanced accuracy.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text field for demand planners to capture additional context, assumptions, risks, or special considerations related to this consensus demand record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialInputQuantity rdf:type rdf:Property ;
    rdfs:label 'Commercial Input Quantity' ;
    rdfs:comment 'The commercial input quantity of the consensus demand record' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consensusDemandStatus rdf:type rdf:Property ;
    rdfs:label 'Consensus Demand Status' ;
    rdfs:comment 'The consensus demand status of the consensus demand record' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constrainedFlag rdf:type rdf:Property ;
    rdfs:label 'Constrained Flag' ;
    rdfs:comment 'Indicates whether the consensus demand has been adjusted downward due to known supply constraints. True means demand was constrained; false means demand is unconstrained.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:constraintReason rdf:type rdf:Property ;
    rdfs:label 'Constraint Reason' ;
    rdfs:comment 'Explanation of the supply constraint that limited consensus demand (e.g., production capacity, raw material shortage, distribution capacity). Populated only when constrained_flag is true.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerCommitmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Customer Commitment Quantity' ;
    rdfs:comment 'Demand volume backed by firm customer orders, contracts, or commitments for this planning period. Represents the most reliable component of consensus demand.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandCategory rdf:type rdf:Property ;
    rdfs:label 'Demand Category' ;
    rdfs:comment 'Classification of the demand type to enable segmented planning and analysis. Base demand represents ongoing business; promotional and seasonal reflect event-driven spikes; new launch and phase-out support lifecycle transitions.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandDriverCode rdf:type rdf:Property ;
    rdfs:label 'Demand Driver Code' ;
    rdfs:comment 'Code identifying the primary business driver or causal factor influencing this demand (e.g., holiday season, weather pattern, competitive action, regulatory change). Supports root-cause analysis.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandDriverDescription rdf:type rdf:Property ;
    rdfs:label 'Demand Driver Description' ;
    rdfs:comment 'Detailed explanation of the demand driver or business rationale behind the consensus demand figure. Captures qualitative insights from demand planners and commercial teams.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandVolatilityIndex rdf:type rdf:Property ;
    rdfs:label 'Demand Volatility Index' ;
    rdfs:comment 'Statistical measure of demand variability for this SKU/location combination, typically expressed as coefficient of variation. Higher values indicate greater uncertainty and require higher safety stock.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financeInputQuantity rdf:type rdf:Property ;
    rdfs:label 'Finance Input Quantity' ;
    rdfs:comment 'The finance input quantity of the consensus demand record' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAccuracyPreviousPeriod rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Previous Period' ;
    rdfs:comment 'The forecast accuracy percentage achieved for this SKU/location combination in the previous planning period. Used to assess forecasting performance trends and adjust confidence levels.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastModelCode rdf:type rdf:Property ;
    rdfs:label 'Forecast Model Code' ;
    rdfs:comment 'Identifier of the statistical forecasting model or algorithm used to generate the baseline statistical forecast (e.g., exponential smoothing, ARIMA, machine learning model).' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newProductLaunchQuantity rdf:type rdf:Property ;
    rdfs:label 'New Product Launch Quantity' ;
    rdfs:comment 'Demand volume attributed to new product introductions or product launches scheduled for this planning period. Typically based on launch plans and market sizing.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizonType rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Type' ;
    rdfs:comment 'Classification of the planning time horizon for this demand record. Short-term (0-3 months) is firm; medium-term (3-12 months) is flexible; long-term (12+ months) is strategic.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Flag' ;
    rdfs:comment 'Indicates whether this consensus demand includes uplift from planned trade promotions or marketing events. True means promotional activity is planned; false means base demand only.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalityFactor rdf:type rdf:Property ;
    rdfs:label 'Seasonality Factor' ;
    rdfs:comment 'Multiplicative factor representing seasonal demand patterns for this planning period. Values above 1.0 indicate peak season; below 1.0 indicate off-season.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalForecastQuantity rdf:type rdf:Property ;
    rdfs:label 'Statistical Forecast Quantity' ;
    rdfs:comment 'The baseline demand forecast generated by statistical forecasting algorithms before any manual adjustments or commercial overlays. Serves as the starting point for consensus demand.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalQuantity rdf:type rdf:Property ;
    rdfs:label 'Statistical Quantity' ;
    rdfs:comment 'The statistical quantity of the consensus demand record' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unconstrainedDemandQuantity rdf:type rdf:Property ;
    rdfs:label 'Unconstrained Demand Quantity' ;
    rdfs:comment 'The theoretical demand volume if all supply constraints (capacity, materials, inventory) were removed. Used for capacity planning and investment decisions.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The percentage variance between consensus demand and statistical forecast, calculated as (variance_to_statistical / statistical_forecast_quantity) * 100. Used to monitor forecast override patterns.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToStatistical rdf:type rdf:Property ;
    rdfs:label 'Variance To Statistical' ;
    rdfs:comment 'The difference between consensus demand quantity and statistical forecast quantity. Positive values indicate upward adjustments; negative values indicate downward adjustments. Key metric for forecast bias analysis.' ;
    rdfs:domain ind:ConsensusDemand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentTradeAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Trade Account Id' ;
    rdfs:comment 'The parent trade account id of the trade account record' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAccount .

ind:accountCloseDate rdf:type rdf:Property ;
    rdfs:label 'Account Close Date' ;
    rdfs:comment 'The date when this trade account was permanently closed or terminated, if applicable.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The account name of the trade account record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountOpenDate rdf:type rdf:Property ;
    rdfs:label 'Account Open Date' ;
    rdfs:comment 'The date when this trade account was first established and approved for business transactions.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Strategic tier classification based on account size, coverage, and business importance: Tier 1 (national key accounts), Tier 2 (regional chains), Tier 3 (local/metro accounts), Tier 4 (independent operators).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acvTotal rdf:type rdf:Property ;
    rdfs:label 'Acv Total' ;
    rdfs:comment 'The total All Commodity Volume representing the annual dollar sales volume across all product categories for this retail account, used for market coverage analysis.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'The credit limit of the trade account record' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'The maximum outstanding accounts receivable balance allowed for this trade account before credit hold is applied.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'The credit risk rating assigned to this trade account by internal credit management or external credit bureau (e.g., AAA, AA, A, BBB, BB, B, CCC, D).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'The trade name or DBA name under which the account operates in the market, if different from legal entity name.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Delivery Flag' ;
    rdfs:comment 'Indicates whether this trade account receives direct store delivery (DSD) shipments bypassing the retailers distribution center.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunNumber rdf:type rdf:Property ;
    rdfs:label 'Dun Number' ;
    rdfs:comment 'The dun number of the trade account record' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'The 9-digit DUNS number assigned by Dun & Bradstreet for unique identification of the business entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Capable Flag' ;
    rdfs:comment 'Indicates whether this trade account has EDI connectivity enabled for electronic exchange of purchase orders, invoices, and advance ship notices.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'The first line of the street address for the trade account headquarters or primary business location.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line2' ;
    rdfs:comment 'The second line of the street address (suite, floor, building) for the trade account headquarters.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'The city name of the trade account headquarters location.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'The 3-letter ISO 3166-1 alpha-3 country code for the trade account headquarters location (e.g., USA, CAN, MEX, GBR, DEU).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'The postal code or ZIP code of the trade account headquarters location.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'The state, province, or administrative region of the trade account headquarters location.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'The official registered legal name of the trade partner organization as it appears on legal documents and contracts.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifSlaTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Otif Sla Target Percent' ;
    rdfs:comment 'The contractual OTIF service level agreement target percentage for order fulfillment performance (e.g., 95.00 represents 95% of orders delivered on time and in full).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'The payment terms of the trade account record' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'The standard payment terms code governing invoice payment due dates and early payment discounts (e.g., Net 30, Net 60, 2/10 Net 30).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The account status immediately prior to the most recent status change, maintained for audit trail and lifecycle analysis.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'The business email address of the primary contact for order management, invoicing, and account communications.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'The full name of the primary business contact or account manager at the trade partner organization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'The business phone number of the primary contact, including country code and extension if applicable.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Primary Language Code' ;
    rdfs:comment 'The 2-letter ISO 639-1 language code for the preferred communication language with this trade account (e.g., en, es, fr, de).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'The date and time when this trade account master record was first created in the system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The date and time when this trade account master record was most recently modified.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:statusChangeReason rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason' ;
    rdfs:comment 'The business reason or justification for the most recent account status change (e.g., payment default, business closure, credit improvement, contract renewal).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Status Change Timestamp' ;
    rdfs:comment 'The date and time when the most recent account status change occurred.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:statusChangedByUser rdf:type rdf:Property ;
    rdfs:label 'Status Changed By User' ;
    rdfs:comment 'The user ID or name of the person who executed the most recent account status change, for audit and accountability purposes.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Flag' ;
    rdfs:comment 'Indicates whether this trade account holds a valid tax exemption certificate for sales tax or VAT purposes.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'The government-issued tax identification number for this legal entity (e.g., EIN in USA, VAT number in EU, GST number in other jurisdictions).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdpCount rdf:type rdf:Property ;
    rdfs:label 'Tdp Count' ;
    rdfs:comment 'The total number of distribution points (store locations or outlets) operated by this trade account where products can be sold.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradeAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Trade Account Status' ;
    rdfs:comment 'The trade account status of the trade account record' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeChannel rdf:type rdf:Property ;
    rdfs:label 'Trade Channel' ;
    rdfs:comment 'The primary retail or distribution channel through which this trade account operates: grocery (supermarkets), mass (mass merchandisers), club (warehouse clubs), drug (pharmacy chains), convenience stores, foodservice (restaurants/institutions), or e-commerce (online retailers). [ENUM-REF-CANDIDATE: grocery|mass|club|drug|convenience|foodservice|e-commerce — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountContactId rdf:type rdf:Property ;
    rdfs:label 'Account Contact Id' ;
    rdfs:comment 'Reference to another account contact record representing this contact\'s direct manager or supervisor within the trade account organization. Enables organizational hierarchy mapping.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountContactStatus rdf:type rdf:Property ;
    rdfs:label 'Account Contact Status' ;
    rdfs:comment 'The account contact status of the account contact record' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistantName rdf:type rdf:Property ;
    rdfs:label 'Assistant Name' ;
    rdfs:comment 'The name of the contact\'s administrative assistant or executive assistant, if applicable. Used for scheduling and communication routing.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistantPhone rdf:type rdf:Property ;
    rdfs:label 'Assistant Phone' ;
    rdfs:comment 'The phone number of the contact\'s administrative assistant. Used for scheduling and communication routing.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactNotes rdf:type rdf:Property ;
    rdfs:label 'Contact Notes' ;
    rdfs:comment 'Free-form text field for capturing additional notes, preferences, or context about the contact. Used by sales representatives to document relationship insights.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'The contact\'s role in the buying decision process. Distinguishes between primary decision-makers, influencers, and administrative contacts. Critical for sales force automation and account planning.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. Active contacts are currently employed and engaged with the account. Inactive or terminated contacts are retained for historical reference.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact\'s primary functional role at the trade account. Determines which business processes and communications this contact participates in.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the contact, if applicable. Still used in some trade channels for purchase orders and formal documentation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'The complete formatted name of the contact, typically concatenated as first name and last name. Used for display and reporting purposes.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDecisionMaker rdf:type rdf:Property ;
    rdfs:label 'Is Decision Maker' ;
    rdfs:comment 'Boolean flag indicating whether this contact has purchasing authority and decision-making power for the account. True if decision maker, False otherwise.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Boolean flag indicating whether this contact is the primary point of contact for the trade account. True if primary, False otherwise.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'The official job title or position held by the contact at the trade account organization. Examples include Senior Buyer, Category Manager, Supply Chain Director.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'The date of the most recent interaction or communication with this contact. Used to track engagement frequency and identify dormant relationships.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'The URL of the contact\'s LinkedIn professional profile. Used for social selling and relationship intelligence.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile or cellular phone number for the contact. Used for urgent communications and field-based retail execution activities.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Next Follow Up Date' ;
    rdfs:comment 'The scheduled date for the next planned follow-up or interaction with this contact. Supports proactive account management and sales cadence planning.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInEmail rdf:type rdf:Property ;
    rdfs:label 'Opt In Email' ;
    rdfs:comment 'Boolean flag indicating whether the contact has opted in to receive commercial email communications. True if opted in, False if opted out. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInPhone rdf:type rdf:Property ;
    rdfs:label 'Opt In Phone' ;
    rdfs:comment 'Boolean flag indicating whether the contact has opted in to receive commercial phone communications. True if opted in, False if opted out. Required for telemarketing compliance.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInSms rdf:type rdf:Property ;
    rdfs:label 'Opt In Sms' ;
    rdfs:comment 'Boolean flag indicating whether the contact has opted in to receive commercial SMS or text message communications. True if opted in, False if opted out.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred method for receiving business communications. Supports personalized engagement strategies in SFA and retail execution workflows.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleTitle rdf:type rdf:Property ;
    rdfs:label 'Role Title' ;
    rdfs:comment 'The role title of the account contact record' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceUserCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce User Code' ;
    rdfs:comment 'The Salesforce user ID of the sales representative or account manager responsible for this contact. Links to the internal sales team member managing the relationship.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'The sales territory or region code to which this contact and their account are assigned. Used for sales force automation and territory management.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountAddressStatus rdf:type rdf:Property ;
    rdfs:label 'Account Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active addresses are available for transactions; inactive addresses are retained for historical reporting; pending addresses await validation; closed addresses are permanently retired.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine3 rdf:type rdf:Property ;
    rdfs:label 'Address Line 3' ;
    rdfs:comment 'Additional address line for complex addresses, building names, or delivery instructions. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressName rdf:type rdf:Property ;
    rdfs:label 'Address Name' ;
    rdfs:comment 'Business name or label for this address location (e.g., \'Main Distribution Center\', \'Regional Office - Northeast\', \'Store #1234\').' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressValidationDate rdf:type rdf:Property ;
    rdfs:label 'Address Validation Date' ;
    rdfs:comment 'Date when the address was last validated against postal authority databases. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Address Validation Status' ;
    rdfs:comment 'Status of address verification against postal authority databases. Validated addresses improve delivery success rates and reduce logistics costs.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Special instructions for delivery personnel including receiving hours, dock locations, access codes, contact requirements, and handling instructions. Critical for On Time In Full (OTIF) performance.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorNumber rdf:type rdf:Property ;
    rdfs:label 'Dock Door Number' ;
    rdfs:comment 'Specific dock door or bay number for deliveries at warehouse or distribution center locations. Used by carriers and Direct Store Delivery (DSD) drivers.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdRouteEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Route Eligible Flag' ;
    rdfs:comment 'Indicates whether this location is eligible for Direct Store Delivery (DSD) routing (True) or requires warehouse distribution (False). Critical for route planning and logistics optimization.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediLocationQualifier rdf:type rdf:Property ;
    rdfs:label 'Edi Location Qualifier' ;
    rdfs:comment 'EDI X12 location qualifier code used in Electronic Data Interchange (EDI) transactions to identify the address role (e.g., ST for ship-to, BT for bill-to, SF for ship-from). Supports automated order processing and Advanced Shipping Notice (ASN) generation.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inactivationReason rdf:type rdf:Property ;
    rdfs:label 'Inactivation Reason' ;
    rdfs:comment 'Business reason for address inactivation (e.g., location closed, address changed, account terminated, consolidation). Used for audit trails and business intelligence.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Address Flag' ;
    rdfs:comment 'Indicates whether this is the primary address for the account (True) or a secondary/alternate address (False). Used for default shipping and billing operations.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Receiving Hours End' ;
    rdfs:comment 'End time for receiving deliveries at this location in 24-hour format (HH:mm). Used for delivery scheduling and On Time In Full (OTIF) compliance.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Receiving Hours Start' ;
    rdfs:comment 'Start time for receiving deliveries at this location in 24-hour format (HH:mm). Used for delivery scheduling and On Time In Full (OTIF) compliance.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardizedAddressFlag rdf:type rdf:Property ;
    rdfs:label 'Standardized Address Flag' ;
    rdfs:comment 'Indicates whether the address has been standardized to postal authority format (True) or remains in original input format (False).' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction identifier for sales tax, value-added tax (VAT), or goods and services tax (GST) calculation. Used in invoice generation and financial reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acvWeight rdf:type rdf:Property ;
    rdfs:label 'Acv Weight' ;
    rdfs:comment 'All Commodity Volume (ACV) weighting factor representing this stores share of total market volume, used for distribution and market share calculations.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bannerName rdf:type rdf:Property ;
    rdfs:label 'Banner Name' ;
    rdfs:comment 'The retail banner or brand under which this store operates (e.g., Walmart Supercenter, Target, Kroger).' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Date when the store permanently closed or is scheduled to close. Null if store is active.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dsdRouteCode rdf:type rdf:Property ;
    rdfs:label 'Dsd Route Code' ;
    rdfs:comment 'Route code or identifier for Direct Store Delivery (DSD) logistics and delivery scheduling.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Visit Date' ;
    rdfs:comment 'Date of the most recent retail execution visit or sales call to this store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledVisitDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Visit Date' ;
    rdfs:comment 'Date of the next planned retail execution visit or sales call to this store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Date when the store first opened for business operations.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours for the store (e.g., Mon-Fri 8am-10pm, Sat-Sun 9am-9pm) used for retail execution visit planning.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osaTargetPct rdf:type rdf:Property ;
    rdfs:label 'Osa Target Pct' ;
    rdfs:comment 'Target On Shelf Availability (OSA) percentage for this store indicating expected in-stock performance for key Stock Keeping Units (SKUs).' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifSlaTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otif Sla Target Pct' ;
    rdfs:comment 'Target On Time In Full (OTIF) service level percentage agreed with this store for delivery performance measurement.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planogramZone rdf:type rdf:Property ;
    rdfs:label 'Planogram Zone' ;
    rdfs:comment 'Planogram zone or cluster assignment indicating which shelf layout and assortment plan applies to this store.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posSystemType rdf:type rdf:Property ;
    rdfs:label 'Pos System Type' ;
    rdfs:comment 'Type or vendor of the Point of Sale (POS) system used at this store for transaction processing and sales data capture.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailStoreStatus rdf:type rdf:Property ;
    rdfs:label 'Retail Store Status' ;
    rdfs:comment 'The retail store status of the retail store record' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeFormat rdf:type rdf:Property ;
    rdfs:label 'Store Format' ;
    rdfs:comment 'The retail format classification of the store indicating size, assortment, and operational model. [ENUM-REF-CANDIDATE: hypermarket|supermarket|convenience|club|drug|dollar|specialty|e-commerce_fulfillment_center — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeName rdf:type rdf:Property ;
    rdfs:label 'Store Name' ;
    rdfs:comment 'The official name or designation of the retail store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeNumber rdf:type rdf:Property ;
    rdfs:label 'Store Number' ;
    rdfs:comment 'The retailer-assigned unique store number or code used for operational identification and Direct Store Delivery (DSD) routing.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storePhone rdf:type rdf:Property ;
    rdfs:label 'Store Phone' ;
    rdfs:comment 'Primary contact phone number for the retail store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeSizeSqFt rdf:type rdf:Property ;
    rdfs:label 'Store Size Sq Ft' ;
    rdfs:comment 'Total retail selling space of the store measured in square feet, used for All Commodity Volume (ACV) and Total Distribution Points (TDP) calculations.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storeStatus rdf:type rdf:Property ;
    rdfs:label 'Store Status' ;
    rdfs:comment 'Current operational status of the retail store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeTier rdf:type rdf:Property ;
    rdfs:label 'Store Tier' ;
    rdfs:comment 'Strategic tier classification (e.g., Tier 1, Tier 2) indicating store importance based on volume, profitability, or strategic value for prioritized retail execution.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdpWeight rdf:type rdf:Property ;
    rdfs:label 'Tdp Weight' ;
    rdfs:comment 'Total Distribution Points (TDP) weighting factor representing this stores contribution to numeric distribution metrics.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingArea rdf:type rdf:Property ;
    rdfs:label 'Trading Area' ;
    rdfs:comment 'Geographic trading area or market designation (e.g., metro area, region) used for sales territory and distribution planning.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillingSupplierSiteId rdf:type rdf:Property ;
    rdfs:label 'Fulfilling Supplier Site Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_site. Business justification: Drop-ship order fulfillment in consumer goods requires identifying the specific supplier site shipping directly to the customer. This named process (direct-ship/drop-ship) links the sales order to the' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierSite .

ind:pricingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Id' ;
    rdfs:comment 'Foreign key linking to sales.pricing_agreement. Business justification: Orders are governed by a pricing agreement; linking captures contract context.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingAgreement .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'The commercial channel through which the order was received. Critical for channel-specific analytics and revenue attribution.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsAmount rdf:type rdf:Property ;
    rdfs:label 'Cogs Amount' ;
    rdfs:comment 'Total cost of goods sold for all items on this order. Used for gross margin calculation and profitability analysis.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by supply chain and logistics based on ATP/CTP availability. Committed date for OTIF tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'The product division or business unit for this order. Used for divisional P&L reporting and product line segmentation.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Freight and shipping charges applied to the order. May be customer-paid or supplier-absorbed depending on terms.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Amount' ;
    rdfs:comment 'Gross profit on the order calculated as total revenue less COGS. Key profitability metric for order-level margin analysis.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'Three-letter Incoterm code defining the transfer of risk and cost responsibility between buyer and seller. Examples: FOB, CIF, DDP.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifStatus rdf:type rdf:Property ;
    rdfs:label 'Otif Status' ;
    rdfs:comment 'Indicates whether the order was delivered on time and in full per customer commitment. Key supply chain KPI for customer service measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'The customers purchase order number provided at order placement. Required for EDI transactions and invoice matching.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The delivery date requested by the customer at the time of order placement. Used for OTIF performance measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesOffice rdf:type rdf:Property ;
    rdfs:label 'Sales Office' ;
    rdfs:comment 'The sales office or branch that originated this order. Used for territory management and sales force performance tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganization rdf:type rdf:Property ;
    rdfs:label 'Sales Organization' ;
    rdfs:comment 'The sales organization responsible for this order. Defines the selling entity and organizational hierarchy for reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Document Number' ;
    rdfs:comment 'The native SAP SD sales order document number. Used for system-to-system integration and ERP traceability.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'The transportation mode selected for order delivery. Impacts delivery time, cost, and carrier selection.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for customer-specific delivery instructions, packaging requirements, or handling notes for warehouse and logistics teams.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Unique system identifier for the invoice record. Primary key.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:invoiceSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Invoice Sales Order Id' ;
    rdfs:comment 'Reference to the originating sales order that this invoice fulfills. Links invoice to order for order-to-cash reconciliation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:sourceOrderId rdf:type rdf:Property ;
    rdfs:label 'Source Order Id' ;
    rdfs:comment 'The source order id of the invoice record' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the period covered by this invoice. Used for period-based billing and revenue allocation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this invoice. Relevant for subscription, service, or recurring billing scenarios.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingType rdf:type rdf:Property ;
    rdfs:label 'Billing Type' ;
    rdfs:comment 'Classification of the invoice document type: standard invoice for goods/services, credit memo for returns/adjustments, debit memo for additional charges, proforma for advance notice, intercompany for internal transfers, or consignment for stock-based billing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Timestamp when the invoice was cancelled or voided. Null for active invoices. Used for cancelled invoice reporting and audit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costOfGoodsSoldAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold Amount' ;
    rdfs:comment 'Total standard cost of all products billed on this invoice. Used for gross margin calculation and profitability analysis at invoice level.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysSalesOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Sales Outstanding' ;
    rdfs:comment 'Number of days between invoice date and payment date (or current date if unpaid). Key metric for working capital management and customer payment behavior analysis.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Boolean indicator that the customer has raised a dispute or deduction claim against this invoice. Triggers collections hold and dispute resolution workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'Standardized code categorizing the reason for invoice dispute. Enables root cause analysis of deductions and customer dissatisfaction. [ENUM-REF-CANDIDATE: pricing|quantity|quality|delivery|promotion|damaged_goods|not_received — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'Code representing the distribution channel through which the sale was made (e.g., retail, wholesale, DTC, e-commerce). Enables channel-specific revenue analysis.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Edi Document Number' ;
    rdfs:comment 'Unique EDI transaction control number assigned when invoice is transmitted via EDI 810. Used for EDI audit trail and error resolution.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Status' ;
    rdfs:comment 'Status of EDI 810 invoice transmission to customer\'s system. Tracks electronic invoice delivery for large retail and distributor accounts.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Amount' ;
    rdfs:comment 'Total freight, shipping, and logistics charges added to the invoice. May be separately itemized for customer transparency.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total invoice value before any deductions, including all line items, charges, and fees but before trade discounts and taxes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'Three-letter Incoterm code defining the division of costs and risks between buyer and seller (e.g., FOB, CIF, DDP). Critical for international trade invoicing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date the invoice was officially issued to the customer. This is the accounting date used for revenue recognition and aging calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally-visible unique invoice document number used for customer communication, payment reconciliation, and accounts receivable tracking. Typically follows company-specific numbering scheme.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current state of the invoice in the accounts receivable lifecycle. Tracks progression from draft through payment completion or dispute resolution. [ENUM-REF-CANDIDATE: draft|issued|sent|partially_paid|paid|overdue|cancelled|disputed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Final invoice total after all discounts, charges, and taxes. This is the amount due from the customer and recorded in accounts receivable.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'Remaining unpaid balance on the invoice. Calculated as net_amount minus paid_amount. Used for aging analysis and collections prioritization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Cumulative amount received against this invoice across all payment transactions. Used to calculate outstanding balance.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External payment reference number provided by the customer or payment processor for reconciliation. Links invoice to bank statement or remittance advice.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Category' ;
    rdfs:comment 'Classification determining how revenue from this invoice is recognized per accounting standards (ASC 606 / IFRS 15). Drives financial reporting and revenue allocation logic.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Code' ;
    rdfs:comment 'Code identifying the sales organization unit responsible for this invoice. Used for revenue attribution and sales performance reporting.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Trade Discount Amount' ;
    rdfs:comment 'Total trade promotion discounts, volume rebates, and negotiated price reductions applied at invoice level. Reduces gross amount to arrive at net taxable amount.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name or title of the pricing agreement for business reference and reporting.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the pricing agreement, used in contracts and SAP SD condition records.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the pricing agreement structure: standard pricing, volume-based tiered discounts, promotional allowances, rebate structures, long-term contract, or spot pricing.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the pricing agreement automatically renews upon expiration unless terminated by either party.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseListPrice rdf:type rdf:Property ;
    rdfs:label 'Base List Price' ;
    rdfs:comment 'Standard manufacturer list price before any discounts, allowances, or negotiated reductions are applied.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the legal contract document or master agreement associated with this pricing agreement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedNetPrice rdf:type rdf:Property ;
    rdfs:label 'Contracted Net Price' ;
    rdfs:comment 'Agreed net price per unit after applying all negotiated discounts and allowances as defined in the pricing agreement.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount off the base list price granted to the customer under this pricing agreement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'Minimum monetary value required per order to qualify for the contracted pricing terms.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User identifier or name of the person who last modified the pricing agreement record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpPrice rdf:type rdf:Property ;
    rdfs:label 'Msrp Price' ;
    rdfs:comment 'Manufacturer suggested retail price for consumer-facing pricing, used for price positioning and margin calculation.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Price Protection Flag' ;
    rdfs:comment 'Indicates whether the customer is protected from price increases during the agreement period.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the pricing agreement indicating its operational state and enforceability.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'Tiered pricing level assigned to the customer based on volume commitments, strategic importance, or negotiated terms.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productScope rdf:type rdf:Property ;
    rdfs:label 'Product Scope' ;
    rdfs:comment 'Defines the breadth of product coverage: all products, specific product category, individual SKUs, or brand-level pricing.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalAllowance rdf:type rdf:Property ;
    rdfs:label 'Promotional Allowance' ;
    rdfs:comment 'Additional allowance or discount provided to support trade promotions, in-store displays, or marketing activities.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount' ;
    rdfs:comment 'Fixed monetary rebate amount granted per unit or per transaction under the pricing agreement terms.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebatePercentage rdf:type rdf:Property ;
    rdfs:label 'Rebate Percentage' ;
    rdfs:comment 'Percentage rebate granted to the customer upon achieving volume thresholds or other performance criteria defined in the agreement.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rspPrice rdf:type rdf:Property ;
    rdfs:label 'Rsp Price' ;
    rdfs:comment 'Manufacturer recommended selling price to be used by the retailer or distributor at point of sale.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeThresholdQuantity rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Quantity' ;
    rdfs:comment 'Minimum order or cumulative purchase quantity required to qualify for the contracted pricing tier or volume-based discount.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeThresholdUom rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Uom' ;
    rdfs:comment 'Unit of measure for the volume threshold quantity (e.g., EA for each, CS for case, PAL for pallet).' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnOrderId rdf:type rdf:Property ;
    rdfs:label 'Return Order Id' ;
    rdfs:comment 'Unique identifier for the return order record. Primary key.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnOrder .

ind:originatingSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Originating Sales Order Id' ;
    rdfs:comment 'Reference to the original sales order that this return is associated with.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Additional adjustments applied to the return value (e.g., damage deductions, handling fees, promotional credits).' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the logistics carrier used for reverse shipment of the returned goods.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Issued Date' ;
    rdfs:comment 'Date when the credit memo was officially issued to the customer.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Unique credit memo document number issued for this return in the financial system.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoPostedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Posted Date' ;
    rdfs:comment 'Date when the credit memo was posted to the general ledger for financial settlement.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Status' ;
    rdfs:comment 'Current status of the credit memo in the accounts receivable settlement process. [ENUM-REF-CANDIDATE: not_requested|requested|approved|issued|posted|rejected|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerResponsibleFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Responsible Flag' ;
    rdfs:comment 'Indicates whether the customer is financially responsible for the return (True) or the business absorbs the cost (False).' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionInstruction rdf:type rdf:Property ;
    rdfs:label 'Disposition Instruction' ;
    rdfs:comment 'Instruction for handling the returned goods based on inspection results and business rules. [ENUM-REF-CANDIDATE: return_to_stock|destroy|rework|donate|quarantine|return_to_vendor|scrap — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Goods Received Date' ;
    rdfs:comment 'Date when the returned goods were physically received at the return processing facility or warehouse.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Completed Date' ;
    rdfs:comment 'Date when quality inspection of the returned goods was completed.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Name of the quality inspector who performed the inspection of returned goods.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Number' ;
    rdfs:comment 'Manufacturing lot or batch number of the returned product for traceability.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Original Unit Price' ;
    rdfs:comment 'Original unit price at which the product was sold in the originating sales order.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Result' ;
    rdfs:comment 'Result of the quality inspection performed on the returned goods.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Amount' ;
    rdfs:comment 'Fee charged to the customer for processing and restocking the returned goods, if applicable.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnAmount rdf:type rdf:Property ;
    rdfs:label 'Return Amount' ;
    rdfs:comment 'The return amount of the return order record' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Date' ;
    rdfs:comment 'Date when the return was officially authorized by the business for processing.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Number' ;
    rdfs:comment 'Externally-known unique authorization number issued for this return request. Format: RMA-XXXXXXXX.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'The return date of the return order record' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Return Order Status' ;
    rdfs:comment 'The return order status of the return order record' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnOrderType rdf:type rdf:Property ;
    rdfs:label 'Return Order Type' ;
    rdfs:comment 'Classification of the return based on the originating channel: retail account, distributor, direct-to-consumer, or wholesale.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReason rdf:type rdf:Property ;
    rdfs:label 'Return Reason' ;
    rdfs:comment 'The return reason of the return order record' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Return Reason Description' ;
    rdfs:comment 'Detailed free-text description providing additional context about the return reason.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnRequestDate rdf:type rdf:Property ;
    rdfs:label 'Return Request Date' ;
    rdfs:comment 'Date when the return request was initiated by the customer or account.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnShippingCost rdf:type rdf:Property ;
    rdfs:label 'Return Shipping Cost' ;
    rdfs:comment 'Cost incurred for shipping the returned goods back to the warehouse.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnStatus rdf:type rdf:Property ;
    rdfs:label 'Return Status' ;
    rdfs:comment 'Current lifecycle status of the return order in the reverse logistics and credit processing workflow. [ENUM-REF-CANDIDATE: requested|authorized|in_transit|received|inspected|approved|rejected|credit_issued|closed|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnValueGross rdf:type rdf:Property ;
    rdfs:label 'Return Value Gross' ;
    rdfs:comment 'Gross monetary value of the returned goods before any deductions (returned quantity × original unit price).' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnValueNet rdf:type rdf:Property ;
    rdfs:label 'Return Value Net' ;
    rdfs:comment 'Net monetary value to be credited to the customer after restocking fees and adjustments (gross - restocking fee - adjustments).' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Quantity of units being returned.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity Uom' ;
    rdfs:comment 'Unit of measure for the returned quantity (EA=Each, CS=Case, PL=Pallet, KG=Kilogram, LB=Pound, L=Liter, GAL=Gallon). [ENUM-REF-CANDIDATE: EA|CS|PL|KG|LB|L|GAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByPriceListId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Price List Id' ;
    rdfs:comment 'Reference to the newer price list that replaces this one when status is superseded. Enables price list succession tracking and historical pricing analysis.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:freightInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Freight Inclusion Flag' ;
    rdfs:comment 'Indicates whether freight costs are included in the prices in this list. True when prices are freight-inclusive (delivered pricing), false when prices are ex-works or FOB.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moqUom rdf:type rdf:Property ;
    rdfs:label 'Moq Uom' ;
    rdfs:comment 'Unit of measure for the minimum order quantity threshold. May differ from price UoM to support different ordering and pricing units.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpFlag rdf:type rdf:Property ;
    rdfs:label 'Msrp Flag' ;
    rdfs:comment 'Indicates whether this price list contains manufacturer suggested retail prices (MSRP). True when prices represent official MSRP for consumer-facing pricing and promotional compliance.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceBasis rdf:type rdf:Property ;
    rdfs:label 'Price Basis' ;
    rdfs:comment 'Pricing methodology or basis used to establish prices in this list. List price indicates standard published pricing, cost plus indicates markup over cost, market based indicates alignment with market rates, competitive indicates positioning relative to competitors, value based indicates pricing tied to customer value perception.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListStatus rdf:type rdf:Property ;
    rdfs:label 'Price List Status' ;
    rdfs:comment 'Current lifecycle status of the price list. Draft indicates under development, pending approval indicates awaiting authorization, active indicates currently in use, inactive indicates temporarily disabled, expired indicates past validity period, superseded indicates replaced by newer version.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListType rdf:type rdf:Property ;
    rdfs:label 'Price List Type' ;
    rdfs:comment 'Classification of the price list by its business purpose and application context. Standard lists provide baseline pricing, promotional lists support time-limited campaigns, contract lists support negotiated agreements, channel-specific lists apply to distribution channels, seasonal lists support seasonal pricing strategies, and clearance lists support inventory liquidation.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceProtectionDays rdf:type rdf:Property ;
    rdfs:label 'Price Protection Days' ;
    rdfs:comment 'Number of days of price protection coverage offered under this price list. Defines the lookback period for retroactive price adjustments when price protection is enabled.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceRoundingRule rdf:type rdf:Property ;
    rdfs:label 'Price Rounding Rule' ;
    rdfs:comment 'Rounding rule applied to calculated prices from this list. Supports psychological pricing strategies and currency denomination constraints.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUom rdf:type rdf:Property ;
    rdfs:label 'Price Uom' ;
    rdfs:comment 'Standard unit of measure in which prices are expressed in this list (e.g., EA for each, CS for case, PAL for pallet). Aligns with SAP MM material master UoM configuration.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingConditionType rdf:type rdf:Property ;
    rdfs:label 'Pricing Condition Type' ;
    rdfs:comment 'SAP SD condition type code that defines how prices from this list are applied in pricing procedures (e.g., PR00 for base price, K004 for material price). Links price list to SAP pricing schema configuration.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rspFlag rdf:type rdf:Property ;
    rdfs:label 'Rsp Flag' ;
    rdfs:comment 'Indicates whether this price list contains recommended selling prices (RSP) for retail partners. True when prices represent manufacturer-suggested retail pricing guidance.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Classification' ;
    rdfs:comment 'Tax category or classification code applicable to prices in this list. Determines tax treatment for products priced under this list in compliance with jurisdictional tax regulations.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeClass rdf:type rdf:Property ;
    rdfs:label 'Trade Class' ;
    rdfs:comment 'Customer trade class or customer pricing group to which this price list applies. Used to segment pricing by customer type such as mass merchandisers, drug stores, grocery chains, convenience stores, or specialty retailers.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'The SAP SD condition type code that defines the pricing logic for this item (e.g., PR00 for base price, K004 for customer discount). Maps to SAP pricing procedure.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPrice rdf:type rdf:Property ;
    rdfs:label 'Cost Price' ;
    rdfs:comment 'The standard cost or COGS for this SKU in the specified currency. Used for margin analysis and profitability calculations. Business-confidential data.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'The customer segment or pricing group for which this price applies (e.g., national accounts, regional chains, independent retailers). Supports segment-based pricing.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemSequence rdf:type rdf:Property ;
    rdfs:label 'Item Sequence' ;
    rdfs:comment 'Sequential line number of this item within the parent price list. Used for ordering and display purposes.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'The base list price for this SKU in the specified currency and unit of measure. Represents the standard selling price before any discounts or promotions.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginPercentage rdf:type rdf:Property ;
    rdfs:label 'Margin Percentage' ;
    rdfs:comment 'The target gross margin percentage for this price list item, calculated as (list_price - cost_price) / list_price * 100. Business-confidential data.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this price list item represents a manual override of standard pricing logic. True if this is an exception price.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceListItemStatus rdf:type rdf:Property ;
    rdfs:label 'Price List Item Status' ;
    rdfs:comment 'Current lifecycle status of this price list item. Controls whether the item can be used in pricing calculations.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Pricing Unit Quantity' ;
    rdfs:comment 'The quantity of base units represented by one pricing unit. For example, if price is per case and a case contains 12 units, this value is 12.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this price is part of a promotional campaign. True if this is a temporary promotional price rather than standard list price.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapConditionRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Condition Record Number' ;
    rdfs:comment 'The unique SAP SD condition record number for this price list item. Enables traceability back to the source ERP system.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleBasis rdf:type rdf:Property ;
    rdfs:label 'Scale Basis' ;
    rdfs:comment 'The basis for volume-based pricing scales (e.g., quantity, order value, weight, volume). Defines how tiered pricing thresholds are measured.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleQuantityFrom rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity From' ;
    rdfs:comment 'The lower bound of the quantity range for which this price applies in a tiered pricing structure. Used for volume discount calculations.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleQuantityTo rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity To' ;
    rdfs:comment 'The upper bound of the quantity range for which this price applies in a tiered pricing structure. Null indicates no upper limit for the highest tier.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether inspection results under this plan require formal approval by a quality manager or authorized person before batch release. Typically true for GMP-critical inspections.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aqlLevel rdf:type rdf:Property ;
    rdfs:label 'Aql Level' ;
    rdfs:comment 'Acceptable Quality Level expressed as a percentage. Maximum percent defective that is considered acceptable for the inspection plan. Used in acceptance sampling decisions.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateOfAnalysisRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Required Flag' ;
    rdfs:comment 'Indicates whether a formal Certificate of Analysis document must be generated upon successful completion of inspections under this plan. Typically required for finished goods and customer-facing materials.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Change Control Number' ;
    rdfs:comment 'Reference to the change control request or document that authorized the creation or last modification of this inspection plan. Required for GMP compliance and audit trail.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicCount rdf:type rdf:Property ;
    rdfs:label 'Characteristic Count' ;
    rdfs:comment 'Number of quality characteristics (test parameters) defined in this inspection plan. Each characteristic has its own specification limits.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dynamicModificationRule rdf:type rdf:Property ;
    rdfs:label 'Dynamic Modification Rule' ;
    rdfs:comment 'Attribute dynamic_modification_rule of quality.inspection_plan.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpRelevant rdf:type rdf:Property ;
    rdfs:label 'Gmp Relevant' ;
    rdfs:comment 'Attribute gmp_relevant of quality.inspection_plan.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency' ;
    rdfs:comment 'Attribute inspection_frequency of quality.inspection_plan.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Lead Time Days' ;
    rdfs:comment 'Expected number of calendar days required to complete all inspections and testing defined in this plan. Used for production scheduling and inventory planning.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'Primary method used to perform the inspection: manual measurement, automated testing, laboratory analysis, visual examination, destructive testing, or non-destructive testing.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Plan Status' ;
    rdfs:comment 'Attribute status of quality.inspection_plan.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionSeverity rdf:type rdf:Property ;
    rdfs:label 'Inspection Severity' ;
    rdfs:comment 'Severity level of inspection based on supplier quality history and risk assessment. Tightened inspection applies stricter acceptance criteria.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStage rdf:type rdf:Property ;
    rdfs:label 'Inspection Stage' ;
    rdfs:comment 'Production or supply chain stage at which this inspection is triggered. Aligns with GMP critical control points.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Type of quality inspection this plan governs: incoming (supplier materials), in-process (production intermediates), final (finished goods), stability (shelf-life studies), release (batch release), or periodic (routine surveillance).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Business identifier for the inspection plan, used across quality management systems and documentation. Externally visible code for referencing the plan in quality specifications and batch records.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the inspection plan including scope, objectives, and special instructions for quality control personnel.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the inspection plan. Only active plans are used for inspection lot creation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Attribute plan_type of quality.inspection_plan.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Reference to the regulatory requirement, standard, or guideline that mandates this inspection (e.g., FDA 21 CFR Part 211, EU GMP Annex 1, ISO 22716). Critical for compliance audits.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleInspectorRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Inspector Role' ;
    rdfs:comment 'Job role or qualification level required for personnel authorized to perform inspections under this plan (e.g., QC Technician, QC Analyst, QC Manager). Ensures competency requirements are met.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision number of this inspection plan. Incremented each time the plan is updated. Part of change control and audit trail.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of sample units to be drawn per inspection lot. Determined by statistical sampling plan and AQL requirements.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleUnit rdf:type rdf:Property ;
    rdfs:label 'Sample Unit' ;
    rdfs:comment 'Unit of measure for the sample (e.g., pieces, kg, liters, containers). Defines what constitutes one sample unit.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingProcedure rdf:type rdf:Property ;
    rdfs:label 'Sampling Procedure' ;
    rdfs:comment 'Attribute sampling_procedure of quality.inspection_plan.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Sampling Procedure Code' ;
    rdfs:comment 'Code identifying the sampling procedure to be followed: sample size, sampling frequency, sampling method (random, systematic, stratified). References approved sampling SOP.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skipLotAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Skip Lot Allowed Flag' ;
    rdfs:comment 'Indicates whether skip-lot inspection (reduced frequency based on consistent quality history) is permitted for this plan. Not allowed for GMP-critical inspections.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationVersion rdf:type rdf:Property ;
    rdfs:label 'Specification Version' ;
    rdfs:comment 'Version number of the quality specification document that this inspection plan implements. Ensures traceability to approved specifications.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageIndicator rdf:type rdf:Property ;
    rdfs:label 'Usage Indicator' ;
    rdfs:comment 'Attribute usage_indicator of quality.inspection_plan.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Unique identifier for the inspection lot. Primary key for the inspection lot entity representing a discrete QC inspection event triggered by production batch, goods receipt, or periodic review.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Foreign key linking to procurement.po_line. Business justification: Incoming inspection is triggered at PO line level (specific material/quantity). Linking inspection_lot to po_line enables line-level quality traceability, accepted/rejected quantity reconciliation aga' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Foreign key linking to distribution.distribution_storage_location. Business justification: Inspection lots are physically held in quarantine storage locations during inspection. WMS quarantine management and FEFO/FIFO compliance require a proper FK to the storage location, replacing the den' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:certificateOfAnalysisNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Number' ;
    rdfs:comment 'Document number of the Certificate of Analysis issued for this inspection lot. Links to formal quality documentation in Veeva Vault.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaIssueDate rdf:type rdf:Property ;
    rdfs:label 'Coa Issue Date' ;
    rdfs:comment 'Date when the Certificate of Analysis was formally issued for this inspection lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date when the formal usage decision was made and recorded in the quality management system.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Precise date and time when the usage decision was recorded. Used for audit trail and compliance reporting.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of defects or non-conformances identified during inspection. Used for quality metrics and trend analysis.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionOutcome rdf:type rdf:Property ;
    rdfs:label 'Disposition Outcome' ;
    rdfs:comment 'Final outcome status of the lot after disposition decision and stock posting. Confirms the actual inventory movement executed.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionEndDate rdf:type rdf:Property ;
    rdfs:label 'Inspection End Date' ;
    rdfs:comment 'Date when all inspection and testing activities were completed for this lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionLocation rdf:type rdf:Property ;
    rdfs:label 'Inspection Location' ;
    rdfs:comment 'Physical location or quality lab where the inspection was performed. May be different from the plant code for centralized testing facilities.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Status' ;
    rdfs:comment 'Inspection Lot Status value for the Inspection Lot record.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Free-text field for inspector comments, observations, or special conditions noted during the inspection process.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPriority rdf:type rdf:Property ;
    rdfs:label 'Inspection Priority' ;
    rdfs:comment 'Priority level assigned to the inspection lot. Determines the sequence and urgency of inspection execution in the quality lab.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Date' ;
    rdfs:comment 'Date when the physical inspection and testing activities began for this lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle status of the inspection lot. Tracks progression from creation through inspection execution to final disposition decision.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotOriginNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Origin Number' ;
    rdfs:comment 'Document number of the originating transaction (production order number, purchase order number, delivery number, etc.) that triggered this inspection lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotOriginType rdf:type rdf:Property ;
    rdfs:label 'Lot Origin Type' ;
    rdfs:comment 'Source document type that triggered the creation of this inspection lot. Links the quality inspection to the originating business transaction.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotQuantity rdf:type rdf:Property ;
    rdfs:label 'Lot Quantity' ;
    rdfs:comment 'Total quantity of material in the inspection lot. Represents the population from which samples are drawn for inspection.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Lot Quantity Uom' ;
    rdfs:comment 'Unit of measure for the lot quantity (each, kilogram, liter, meter, etc.). Aligns with material master UOM. [ENUM-REF-CANDIDATE: EA|KG|L|M|M2|M3|BOX|CASE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:origin rdf:type rdf:Property ;
    rdfs:label 'Origin' ;
    rdfs:comment 'Attribute inspection_lot_origin of quality.inspection_lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldReason rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Reason' ;
    rdfs:comment 'Detailed explanation of why the lot is under regulatory hold. Documents the specific compliance or quality concern requiring additional review.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'Date when the material must be re-inspected to confirm continued compliance with quality specifications. Applicable for raw materials and intermediates.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleQuantity rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity' ;
    rdfs:comment 'Quantity of material drawn as a sample for inspection testing. Determined by the inspection plan sampling procedure.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity Uom' ;
    rdfs:comment 'Unit of measure for the sample quantity drawn for testing. [ENUM-REF-CANDIDATE: EA|KG|L|M|M2|M3|BOX|CASE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockPostingInstruction rdf:type rdf:Property ;
    rdfs:label 'Stock Posting Instruction' ;
    rdfs:comment 'Instruction for inventory movement based on the usage decision. Determines the target stock type for material posting in warehouse management.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemStatus rdf:type rdf:Property ;
    rdfs:label 'System Status' ;
    rdfs:comment 'Attribute system_status of quality.inspection_lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDecision rdf:type rdf:Property ;
    rdfs:label 'Usage Decision' ;
    rdfs:comment 'Final disposition decision for the inspected lot. Determines whether material can be released for use, must be reworked, or should be rejected.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDecisionCode rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Code' ;
    rdfs:comment 'Standardized code representing the usage decision. Used for automated stock posting and reporting in SAP QM.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResultId rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Id' ;
    rdfs:comment 'Unique identifier for the inspection result record. Primary key for granular QC (Quality Control) measurement and test result records captured at the characteristic level within an inspection lot.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nonconformanceId rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Id' ;
    rdfs:comment 'Foreign key linking to quality.nonconformance. Business justification: An out-of-specification inspection result is the direct trigger for raising a nonconformance record. This FK links the specific measurement result (with its deviation_code, defect_classification, defe' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Nonconformance .

ind:testEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Test Equipment Id' ;
    rdfs:comment 'Surrogate identifier: Test Equipment Id.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:characteristicCode rdf:type rdf:Property ;
    rdfs:label 'Characteristic Code' ;
    rdfs:comment 'Characteristic Code value for the Inspection Result record.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicName rdf:type rdf:Property ;
    rdfs:label 'Characteristic Name' ;
    rdfs:comment 'Characteristic Name value for the Inspection Result record.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Inclusion Flag' ;
    rdfs:comment 'Flag indicating whether this result should be included in the Certificate of Analysis (COA) document for the batch. True indicates inclusion; false indicates internal-only result.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlChartRuleViolated rdf:type rdf:Property ;
    rdfs:label 'Control Chart Rule Violated' ;
    rdfs:comment 'Description of the specific SPC control chart rule that was violated (e.g., point beyond control limit, 7 consecutive points above centerline, 2 of 3 points beyond 2-sigma). Populated when control_chart_violation_flag is true.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlChartViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Control Chart Violation Flag' ;
    rdfs:comment 'Flag indicating whether this measurement violates SPC (Statistical Process Control) control chart rules (e.g., out of control limits, run rules, trend rules). True indicates a violation requiring investigation.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifier of the source system from which this inspection result was captured (e.g., SAP QM, LIMS, Veeva Vault, manual entry). Used for data lineage and audit purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectClassification rdf:type rdf:Property ;
    rdfs:label 'Defect Classification' ;
    rdfs:comment 'Defect Classification value for the Inspection Result record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'Standardized code classifying the type of defect or non-conformance observed when result_status is fail. Used for defect trending and root cause analysis.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectSeverity rdf:type rdf:Property ;
    rdfs:label 'Defect Severity' ;
    rdfs:comment 'Classification of the severity of the non-conformance. Critical defects pose safety or regulatory risk; major defects affect functionality; minor defects are cosmetic or non-functional.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationCode rdf:type rdf:Property ;
    rdfs:label 'Deviation Code' ;
    rdfs:comment 'Reference to an approved deviation or waiver document that authorizes acceptance of a non-conforming result. Populated when result_status is waived.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalConditionHumidity rdf:type rdf:Property ;
    rdfs:label 'Environmental Condition Humidity' ;
    rdfs:comment 'Relative humidity (percentage) at the time of measurement. Critical for tests sensitive to moisture levels.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalConditionTemperature rdf:type rdf:Property ;
    rdfs:label 'Environmental Condition Temperature' ;
    rdfs:comment 'Ambient temperature (in degrees Celsius) at the time of measurement. Critical for tests sensitive to environmental conditions.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationResult rdf:type rdf:Property ;
    rdfs:label 'Evaluation Result' ;
    rdfs:comment 'Evaluation Result value for the Inspection Result record.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCharacteristicCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Code' ;
    rdfs:comment 'Unique code identifying the specific quality characteristic being measured (e.g., pH level, viscosity, weight, color, microbial count). Corresponds to the master inspection characteristic definition.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCharacteristicName rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Name' ;
    rdfs:comment 'Human-readable name of the quality characteristic being tested (e.g., Product pH, Net Weight, Microbial Load, Color Consistency).' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionMethodCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Method Code' ;
    rdfs:comment 'Code identifying the standardized test method or procedure used to perform this measurement (e.g., ASTM method, USP method, internal SOP number).' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResultStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Status' ;
    rdfs:comment 'Attribute status of quality.inspection_result.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when this specific characteristic measurement was performed. Critical for time-sensitive tests and GMP audit trails.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:instrumentCode rdf:type rdf:Property ;
    rdfs:label 'Instrument Code' ;
    rdfs:comment 'Unique identifier of the measurement instrument or equipment used to capture this result (e.g., balance ID, pH meter ID, spectrophotometer ID). Required for GMP (Good Manufacturing Practice) audit trails and instrument calibration traceability.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isWithinSpec rdf:type rdf:Property ;
    rdfs:label 'Is Within Spec' ;
    rdfs:comment 'Boolean indicator for Is Within Spec.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laboratoryCode rdf:type rdf:Property ;
    rdfs:label 'Laboratory Code' ;
    rdfs:comment 'Identifier of the laboratory or testing facility where this measurement was performed. May be an internal QC lab or an external contract lab.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Spec Limit' ;
    rdfs:comment 'Lower Spec Limit value for the Inspection Result record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Specification Limit' ;
    rdfs:comment 'The minimum acceptable value for this characteristic as defined in the product specification or quality standard. Values below this threshold indicate non-conformance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'The actual quantitative measurement or test result value recorded during inspection. For qualitative characteristics, this may be encoded numerically or stored as a code.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'Date/time of Measurement Timestamp.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementUncertainty rdf:type rdf:Property ;
    rdfs:label 'Measurement Uncertainty' ;
    rdfs:comment 'Quantified estimate of the uncertainty or error margin associated with the measured value. Required for ISO 17025 compliance and advanced SPC (Statistical Process Control) analysis.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recorded Timestamp' ;
    rdfs:comment 'Attribute recorded_timestamp of quality.inspection_result.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Flag indicating whether this result must be reported to regulatory authorities (e.g., FDA, EPA) due to non-conformance or safety concerns. True indicates reportable event.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text comments or observations recorded by the inspector regarding this measurement. May include notes on sample condition, procedural deviations, or contextual information.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Pass/fail status of this individual characteristic measurement. Pass indicates the measured value is within specification limits; fail indicates non-conformance; conditional indicates acceptance with restrictions; pending indicates awaiting review; waived indicates non-conformance accepted by authorized deviation.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultUom rdf:type rdf:Property ;
    rdfs:label 'Result Uom' ;
    rdfs:comment 'Result Uom value for the Inspection Result record.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValuation rdf:type rdf:Property ;
    rdfs:label 'Result Valuation' ;
    rdfs:comment 'Attribute result_valuation of quality.inspection_result.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValue rdf:type rdf:Property ;
    rdfs:label 'Result Value' ;
    rdfs:comment 'Result Value value for the Inspection Result record.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultValueText rdf:type rdf:Property ;
    rdfs:label 'Result Value Text' ;
    rdfs:comment 'Result Value Text value for the Inspection Result record.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestIndicator rdf:type rdf:Property ;
    rdfs:label 'Retest Indicator' ;
    rdfs:comment 'Flag indicating whether this result is a retest of a previously failed or inconclusive measurement. True indicates this is a retest; false indicates initial test.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestReasonCode rdf:type rdf:Property ;
    rdfs:label 'Retest Reason Code' ;
    rdfs:comment 'Code indicating the reason for retesting this characteristic. Applicable only when retest_indicator is true.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Sequence Number' ;
    rdfs:comment 'Sequential number of this sample within the inspection lot (e.g., 1, 2, 3). Used to track sampling order and support statistical sampling plans.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The ideal or nominal value for this characteristic. Used for process capability analysis and SPC (Statistical Process Control) charting.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Test Batch Number' ;
    rdfs:comment 'Batch or run number of the test reagents or consumables used during this measurement. Required for traceability in regulated environments.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'Test Method value for the Inspection Result record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Spec Limit' ;
    rdfs:comment 'Upper Spec Limit value for the Inspection Result record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Specification Limit' ;
    rdfs:comment 'The maximum acceptable value for this characteristic as defined in the product specification or quality standard. Values above this threshold indicate non-conformance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageDecisionId rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Id' ;
    rdfs:comment 'Unique identifier for the quality control usage decision record. Primary key.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UsageDecision .

ind:capaId rdf:type rdf:Property ;
    rdfs:label 'Capa Id' ;
    rdfs:comment 'Reference to the CAPA record initiated as a result of this usage decision, if applicable. Null if no CAPA was required.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capa .

ind:inboundReceiptLineId rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Line Id' ;
    rdfs:comment 'Foreign key linking to distribution.inbound_receipt_line. Business justification: Usage decisions (accept/reject/rework) directly govern disposition of inbound receipt lines — stock posting, quarantine, or supplier return. QA and logistics teams jointly use this link for GMP dispos' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundReceiptLine .

ind:acceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Accepted Quantity' ;
    rdfs:comment 'Accepted Quantity value for the Usage Decision record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Required Flag' ;
    rdfs:comment 'Indicates whether this usage decision triggers a CAPA process due to significant non-conformance. True=CAPA required, False=No CAPA needed. Links to continuous improvement.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionCode rdf:type rdf:Property ;
    rdfs:label 'Decision Code' ;
    rdfs:comment 'The formal quality control usage decision code. A=Accept (Unrestricted Use), R=Reject, Q=Quality Hold, S=Restricted Use (Sample/Scrap), X=Rework Required. Drives downstream inventory disposition.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDescription rdf:type rdf:Property ;
    rdfs:label 'Decision Description' ;
    rdfs:comment 'Decision Description value for the Usage Decision record.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionMakerName rdf:type rdf:Property ;
    rdfs:label 'Decision Maker Name' ;
    rdfs:comment 'Full name of the quality control inspector or authorized personnel who made the usage decision. Captured for audit and traceability purposes.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionText rdf:type rdf:Property ;
    rdfs:label 'Decision Text' ;
    rdfs:comment 'Detailed textual description or rationale for the usage decision. Captures the quality assessor\'s reasoning and any special conditions or instructions.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionType rdf:type rdf:Property ;
    rdfs:label 'Decision Type' ;
    rdfs:comment 'Decision Type value for the Usage Decision record.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Detailed description of the defect, non-conformance, or quality issue identified during inspection. Supports CAPA and continuous improvement processes.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Disposition value for the Usage Decision record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'The date when the material disposition action was completed (e.g., stock posted to unrestricted, blocked, or scrapped). Null if disposition is still pending.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Current status of the material disposition action following the usage decision. pending=Decision made but stock not yet moved, completed=Stock posting completed, cancelled=Decision reversed or voided.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAction rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action' ;
    rdfs:comment 'Attribute follow_up_action of quality.usage_decision.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Quality Score value for the Usage Decision record.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityAccepted rdf:type rdf:Property ;
    rdfs:label 'Quantity Accepted' ;
    rdfs:comment 'The quantity of material accepted for unrestricted use based on the usage decision. Measured in the material\'s base unit of measure.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRejected rdf:type rdf:Property ;
    rdfs:label 'Quantity Rejected' ;
    rdfs:comment 'The quantity of material rejected and not suitable for use. Measured in the material\'s base unit of measure. May trigger disposal or return to supplier.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRework rdf:type rdf:Property ;
    rdfs:label 'Quantity Rework' ;
    rdfs:comment 'The quantity of material designated for rework or reprocessing to meet quality standards. Measured in the material\'s base unit of measure.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Reason Code value for the Usage Decision record.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:comment 'Rejected Quantity value for the Usage Decision record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockPostingType rdf:type rdf:Property ;
    rdfs:label 'Stock Posting Type' ;
    rdfs:comment 'Attribute stock_posting_type of quality.usage_decision.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:udCode rdf:type rdf:Property ;
    rdfs:label 'Ud Code' ;
    rdfs:comment 'Attribute ud_code of quality.usage_decision.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDecisionStatus rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Status' ;
    rdfs:comment 'Attribute status of quality.usage_decision.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Id' ;
    rdfs:comment 'Foreign key linking to quality.certificate_of_analysis. Business justification: A nonconformance raised during batch review or incoming goods inspection may reference the Certificate of Analysis for the implicated batch. This FK enables QA to directly access the CoA from the nonc' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificateOfAnalysis .

ind:productComplaintId rdf:type rdf:Property ;
    rdfs:label 'Product Complaint Id' ;
    rdfs:comment 'Foreign key reference to the customer complaint record that triggered this nonconformance, when applicable. Links to consumer complaint tracking system.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductComplaint .

ind:affectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity' ;
    rdfs:comment 'Quantity of product units or material affected by the nonconformance. Used for containment scope and financial impact assessment.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity Uom' ;
    rdfs:comment 'Unit of measure for the affected quantity: EA (each/units), KG (kilograms), L (liters), M (meters), BOX (boxes), PALLET (pallets).' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date/time of Closed Date.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the nonconformance was formally closed after verification of corrective actions and effectiveness checks. Null if still open.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containmentAction rdf:type rdf:Property ;
    rdfs:label 'Containment Action' ;
    rdfs:comment 'Immediate containment actions taken to prevent further occurrence or distribution of nonconforming product. Describes short-term corrective measures implemented before root cause analysis.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Containment Timestamp' ;
    rdfs:comment 'Date and time when containment actions were completed and verified effective. Critical for regulatory reporting and OTIF compliance.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:defectCategory rdf:type rdf:Property ;
    rdfs:label 'Defect Category' ;
    rdfs:comment 'Attribute defect_category of quality.nonconformance.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedDate rdf:type rdf:Property ;
    rdfs:label 'Detected Date' ;
    rdfs:comment 'Date/time of Detected Date.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'Date and time when the nonconformance was first detected or observed. Represents the real-world event time of quality issue identification.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionPoint rdf:type rdf:Property ;
    rdfs:label 'Detection Point' ;
    rdfs:comment 'Attribute detection_point of quality.nonconformance.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'Origin point where the nonconformance was first identified: QC inspection (quality control laboratory testing), manufacturing line (in-process detection), supplier receipt (incoming material inspection), customer complaint (consumer-reported issue), regulatory audit (FDA or regulatory body inspection), internal audit (GMP self-audit), or stability study (long-term product stability testing). [ENUM-REF-CANDIDATE: qc_inspection|manufacturing_line|supplier_receipt|customer_complaint|regulatory_audit|internal_audit|stability_study — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Disposition Approved By' ;
    rdfs:comment 'User identifier of the quality authority who approved the disposition decision. Links to workforce/employee master data for audit trail and GMP compliance.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Approved Timestamp' ;
    rdfs:comment 'Date and time when the disposition decision was formally approved by quality authority. Critical for GMP audit trail and batch release decisions.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final disposition decision for the nonconforming product or material: use_as_is (approved for use despite nonconformance), rework (reprocess to meet specifications), scrap (destroy), return_to_supplier (send back to vendor), downgrade (sell as lower grade), or quarantine (hold pending further investigation).' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the quality event: complaint (customer-reported issue), defect (internal manufacturing defect), deviation (process deviation from standard), improvement request (continuous improvement opportunity), supplier issue (supplier quality problem), or audit finding (GMP audit observation).' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated or actual financial impact of the nonconformance, including costs of rework, scrap, containment, investigation, customer credits, and potential recall costs. Expressed in base currency.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial impact amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGmpRelated rdf:type rdf:Property ;
    rdfs:label 'Is Gmp Related' ;
    rdfs:comment 'Boolean indicator for Is Gmp Related.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ncNumber rdf:type rdf:Property ;
    rdfs:label 'Nc Number' ;
    rdfs:comment 'Nc Number value for the Nonconformance record.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncStatus rdf:type rdf:Property ;
    rdfs:label 'Nc Status' ;
    rdfs:comment 'Nc Status value for the Nonconformance record.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncType rdf:type rdf:Property ;
    rdfs:label 'Nc Type' ;
    rdfs:comment 'Nc Type value for the Nonconformance record.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonconformanceStatus rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Status' ;
    rdfs:comment 'Current lifecycle status of the nonconformance record: open (newly created), in_investigation (root cause analysis underway), containment_active (immediate containment actions in progress), capa_assigned (corrective and preventive action assigned), closed (resolved and verified), or cancelled (invalidated).' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'External business identifier for the quality notification or nonconformance event. Corresponds to SAP QM notification number or Veeva Vault quality event identifier.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date when the nonconformance was reported to regulatory authorities, if applicable. Null if not reportable or not yet reported.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable' ;
    rdfs:comment 'Boolean indicator for Regulatory Reportable.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Attribute reported_date of quality.nonconformance.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time when the nonconformance was formally logged into the quality management system (SAP QM or Veeva Vault). May differ from detection timestamp due to reporting lag.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Functional department responsible for investigating and resolving the nonconformance (e.g., Quality Assurance, Manufacturing, Supply Chain, R&D).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Root Cause value for the Nonconformance record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Detailed findings from root cause investigation, including methodology used (5-Why, Fishbone, Fault Tree Analysis) and identified root causes. Supports CAPA development.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity classification of the quality event based on impact to product safety, efficacy, and regulatory compliance. Critical: immediate risk to consumer safety or regulatory violation; Major: significant quality impact requiring containment; Minor: low impact quality issue.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify effectiveness of corrective actions and confirm the nonconformance has been resolved (e.g., re-inspection, re-testing, process validation, trend analysis).' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'The actual date when all CAPA actions were completed and verified, prior to formal closure.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Business-facing unique identifier for the CAPA record, typically formatted as CAPA-NNNNNN. Used for external communication and audit trails.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:comment 'Current lifecycle status of the CAPA record, tracking progression from initiation through closure. [ENUM-REF-CANDIDATE: open|investigation|action_plan|implementation|verification|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Classification of the CAPA as corrective (addressing existing nonconformance), preventive (preventing potential nonconformance), or combined (both corrective and preventive actions).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureComments rdf:type rdf:Property ;
    rdfs:label 'Closure Comments' ;
    rdfs:comment 'Final comments or notes recorded at the time of CAPA closure, summarizing outcomes and lessons learned.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'The date when the CAPA was formally closed after successful completion and verification of all actions.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Attribute completion_date of quality.capa.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Corrective Action value for the Capa record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective action(s) taken to address the existing nonconformance and eliminate its cause.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Amount' ;
    rdfs:comment 'Estimated or actual financial cost impact of the CAPA issue, including costs of investigation, rework, scrap, recall, or other remediation activities.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cost impact amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Flag' ;
    rdfs:comment 'Indicates whether the CAPA issue had a direct impact on customers, such as product quality defects, delivery delays, or safety concerns.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectivenessCheckDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Date' ;
    rdfs:comment 'Date/time of Effectiveness Check Date.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessResult rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Result' ;
    rdfs:comment 'Effectiveness Result value for the Capa record.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Method' ;
    rdfs:comment 'The method or approach used to verify that the corrective and preventive actions were effective in resolving the issue and preventing recurrence (e.g., follow-up audit, process monitoring, trend analysis).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerificationResult rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Result' ;
    rdfs:comment 'The outcome of the effectiveness verification, indicating whether the CAPA actions successfully resolved the issue and prevented recurrence.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerified rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verified' ;
    rdfs:comment 'Attribute effectiveness_verified of quality.capa.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'The date when the CAPA record was formally initiated and opened in the quality management system.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date/time of Opened Date.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Preventive Action value for the Capa record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Description' ;
    rdfs:comment 'Detailed description of the preventive action(s) implemented to prevent recurrence of the issue or occurrence of similar issues.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemStatement rdf:type rdf:Property ;
    rdfs:label 'Problem Statement' ;
    rdfs:comment 'Attribute problem_statement of quality.capa.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Flag' ;
    rdfs:comment 'Boolean indicator for Regulatory Impact Flag.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Method' ;
    rdfs:comment 'The methodology used to identify the root cause of the issue, such as 5 Whys, Fishbone Diagram, Fault Tree Analysis, Pareto Analysis, or Failure Mode and Effects Analysis (FMEA).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed description of the identified root cause(s) of the nonconformance or issue.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Reference Number' ;
    rdfs:comment 'Reference identifier of the originating event (e.g., nonconformance ID, audit finding ID, complaint ID) that triggered this CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'The origin or trigger event that initiated the CAPA, such as nonconformance, audit finding, customer complaint, supplier quality issue, stability study failure, or regulatory inspection finding.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'The planned or target date by which all CAPA actions should be completed and verified.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Brief descriptive title summarizing the CAPA issue or focus area.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date when the effectiveness verification was completed.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchCertificateOfAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Batch Certificate Of Analysis Id' ;
    rdfs:comment 'Attribute certificate_of_analysis_id of quality.batch_release.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificateOfAnalysis .

ind:primaryBatchReleaseCertificateOfAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Primary Batch Release Certificate Of Analysis Id' ;
    rdfs:comment 'Foreign key linking to quality.certificate_of_analysis. Business justification: Link batch_release to the Certificate of Analysis that documents the released batch, removing redundant reference number.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificateOfAnalysis .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference to the complete audit trail log for all actions and approvals related to this batch release. Required for 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchReleaseStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Release Status' ;
    rdfs:comment 'Attribute status of quality.batch_release.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Batch Size Quantity' ;
    rdfs:comment 'Total quantity of finished goods produced in this batch. Used for yield calculation and inventory planning.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeUom rdf:type rdf:Property ;
    rdfs:label 'Batch Size Uom' ;
    rdfs:comment 'Unit of measure for the batch size quantity (e.g., kilograms, liters, units). Aligns with GS1 standards for trade item measurement. [ENUM-REF-CANDIDATE: kg|lbs|liters|gallons|units|cases|pallets — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationCount rdf:type rdf:Property ;
    rdfs:label 'Deviation Count' ;
    rdfs:comment 'Number of manufacturing or quality deviations recorded during the production and testing of this batch. Used for quality trend analysis.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Hold Initiated Date' ;
    rdfs:comment 'Date when the regulatory or business hold was placed on the batch. Nullable if no hold exists.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Detailed explanation of why the batch is on hold, if applicable. Includes regulatory citation, investigation reference, or customer complaint number.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingSiteCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Code' ;
    rdfs:comment 'Code identifying the manufacturing facility or plant where the batch was produced. Used for site-level quality tracking and regulatory reporting.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Product Registration Number' ;
    rdfs:comment 'Regulatory registration or approval number for the product in the target market. Required for FDA NDC, EU product registration, or equivalent.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionDate rdf:type rdf:Property ;
    rdfs:label 'Production Date' ;
    rdfs:comment 'Date when the batch manufacturing was completed. Critical for shelf-life calculation and FEFO inventory management.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaSignoffFlag rdf:type rdf:Property ;
    rdfs:label 'Qa Signoff Flag' ;
    rdfs:comment 'Boolean indicator for Qa Signoff Flag.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Inspection Status' ;
    rdfs:comment 'Overall status of QC inspection and testing for this batch. Summarizes results from multiple QC test records.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qpCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Qp Certification Flag' ;
    rdfs:comment 'Boolean indicator for Qp Certification Flag.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qpSignature rdf:type rdf:Property ;
    rdfs:label 'Qp Signature' ;
    rdfs:comment 'Attribute qp_signature of quality.batch_release.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qpSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qp Signature Timestamp' ;
    rdfs:comment 'Timestamp when the Qualified Person electronically signed the batch release decision. Part of 21 CFR Part 11 electronic signature compliance.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualifiedPersonName rdf:type rdf:Property ;
    rdfs:label 'Qualified Person Name' ;
    rdfs:comment 'Full name of the Qualified Person who signed off on the batch release. Required for regulatory audit trail.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Status' ;
    rdfs:comment 'Indicates if the batch is under any regulatory or business hold that prevents distribution. Holds may be imposed by FDA, EPA, internal quality, customer complaint, or recall investigation.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMarket rdf:type rdf:Property ;
    rdfs:label 'Regulatory Market' ;
    rdfs:comment 'Primary regulatory market or jurisdiction for which this batch was released. Different markets may have different release requirements and QP sign-off rules. [ENUM-REF-CANDIDATE: USA|CAN|MEX|GBR|DEU|FRA|ITA|ESP|CHN|JPN|AUS|BRA|IND — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDecision rdf:type rdf:Property ;
    rdfs:label 'Release Decision' ;
    rdfs:comment 'Final disposition decision for the batch: released for distribution, rejected for destruction, quarantine for further testing, conditional release with restrictions, pending review, or on hold pending investigation. Critical GMP control point.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseNotes rdf:type rdf:Property ;
    rdfs:label 'Release Notes' ;
    rdfs:comment 'Free-text notes and comments from the Qualified Person regarding the release decision. May include justification for conditional release or special handling instructions.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseNumber rdf:type rdf:Property ;
    rdfs:label 'Release Number' ;
    rdfs:comment 'Release Number value for the Batch Release record.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Release Quantity' ;
    rdfs:comment 'Attribute release_quantity of quality.batch_release.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Release Status value for the Batch Release record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Precise timestamp when the batch release decision was recorded in the system. Used for audit trail and regulatory compliance.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Released Quantity' ;
    rdfs:comment 'Quantity of the batch that was approved for release and distribution. May be less than batch size if partial rejection occurred.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapQmInspectionLot rdf:type rdf:Property ;
    rdfs:label 'Sap Qm Inspection Lot' ;
    rdfs:comment 'SAP QM inspection lot number associated with this batch release. Links to SAP S/4HANA QM module for detailed inspection results and usage decisions.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityStudyReference rdf:type rdf:Property ;
    rdfs:label 'Stability Study Reference' ;
    rdfs:comment 'Reference number linking to the stability study protocol and results that support the assigned shelf life and expiry date for this batch.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedFlag rdf:type rdf:Property ;
    rdfs:label 'Approved Flag' ;
    rdfs:comment 'Boolean indicator for Approved Flag.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Name' ;
    rdfs:comment 'Full name of the quality assurance professional authorized to approve and sign this certificate. Must have appropriate delegation of authority.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Title' ;
    rdfs:comment 'Job title or role of the authorized signatory (e.g., QA Manager, Quality Director, Laboratory Supervisor).' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSize rdf:type rdf:Property ;
    rdfs:label 'Batch Size' ;
    rdfs:comment 'Total quantity produced in the manufacturing batch. Used to assess sample representativeness and for statistical quality control.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Externally-known unique certificate number assigned to this CoA document. Used for customer communication and regulatory submissions.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfAnalysisStatus rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Status' ;
    rdfs:comment 'Attribute status of quality.certificate_of_analysis.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Classification of the certificate based on the material type being certified. Determines applicable test parameters and regulatory requirements.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Number' ;
    rdfs:comment 'Coa Number value for the Certificate Of Analysis record.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaStatus rdf:type rdf:Property ;
    rdfs:label 'Coa Status' ;
    rdfs:comment 'Coa Status value for the Certificate Of Analysis record.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatement rdf:type rdf:Property ;
    rdfs:label 'Compliance Statement' ;
    rdfs:comment 'Attribute compliance_statement of quality.certificate_of_analysis.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Facing Flag' ;
    rdfs:comment 'Indicates whether this certificate is intended for external distribution to trade customers or is for internal use only. True if customer-facing.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerName rdf:type rdf:Property ;
    rdfs:label 'Customer Name' ;
    rdfs:comment 'Customer Name value for the Certificate Of Analysis record.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Document Reference value for the Certificate Of Analysis record.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL or file path to the digitally signed PDF or scanned image of the certificate stored in Veeva Vault or document management system.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant Flag' ;
    rdfs:comment 'Indicates whether the batch and testing process were conducted under GMP conditions. True if GMP-compliant.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date on which this certificate of analysis was officially issued and authorized for distribution to customers or regulatory bodies.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Overall Result value for the Certificate Of Analysis record.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallResultStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Result Status' ;
    rdfs:comment 'Aggregate pass/fail status for all test parameters on this certificate. Determines batch release decision and customer distribution eligibility.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityTested rdf:type rdf:Property ;
    rdfs:label 'Quantity Tested' ;
    rdfs:comment 'The quantity of material sampled and tested for this certificate. Expressed in the material\'s base unit of measure.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityTestedUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Tested Uom' ;
    rdfs:comment 'Unit of measure for the quantity tested (e.g., kilograms, liters, units). Aligns with material master UOM.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Flag' ;
    rdfs:comment 'Indicates whether this certificate is required for regulatory submissions or compliance filings with FDA, EPA, or other governing bodies. True if required for submission.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierLotNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Lot Number' ;
    rdfs:comment 'The lot or batch number assigned by the supplier for raw materials or packaging materials. Used for supplier quality traceability.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'The date on which quality control testing was performed for this certificate. May differ from manufacturing date for retained samples.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testMethodReference rdf:type rdf:Property ;
    rdfs:label 'Test Method Reference' ;
    rdfs:comment 'Reference to the analytical test methods used (e.g., USP, ASTM, internal method codes). May be a comma-separated list for multiple methods.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Line Id' ;
    rdfs:comment 'Foreign key linking to distribution.outbound_order_line. Business justification: Required for complaint traceability: product complaint must reference the outbound order line that delivered the product, allowing root cause analysis and customer service reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundOrderLine .

ind:complainantAddress rdf:type rdf:Property ;
    rdfs:label 'Complainant Address' ;
    rdfs:comment 'Mailing address of the complainant for correspondence and product sample return.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complainantContact rdf:type rdf:Property ;
    rdfs:label 'Complainant Contact' ;
    rdfs:comment 'Attribute complainant_contact of quality.product_complaint.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complainantCountryCode rdf:type rdf:Property ;
    rdfs:label 'Complainant Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the complainant location.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complainantEmail rdf:type rdf:Property ;
    rdfs:label 'Complainant Email' ;
    rdfs:comment 'Email address of the complainant for follow-up communication.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complainantName rdf:type rdf:Property ;
    rdfs:label 'Complainant Name' ;
    rdfs:comment 'Full name of the individual or organization filing the complaint.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complainantPhone rdf:type rdf:Property ;
    rdfs:label 'Complainant Phone' ;
    rdfs:comment 'Contact phone number of the complainant.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintCategory rdf:type rdf:Property ;
    rdfs:label 'Complaint Category' ;
    rdfs:comment 'Primary classification of the complaint type based on the nature of the quality issue reported.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintDescription rdf:type rdf:Property ;
    rdfs:label 'Complaint Description' ;
    rdfs:comment 'Detailed narrative description of the complaint as reported by the complainant, including symptoms, observations, and circumstances.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Number' ;
    rdfs:comment 'Externally-visible unique complaint reference number used for tracking and communication with consumers and regulatory bodies.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Complaint Received Timestamp' ;
    rdfs:comment 'Date and time when the complaint was first received by the organization.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complaintSource rdf:type rdf:Property ;
    rdfs:label 'Complaint Source' ;
    rdfs:comment 'Origin channel through which the complaint was received.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintStatus rdf:type rdf:Property ;
    rdfs:label 'Complaint Status' ;
    rdfs:comment 'Current lifecycle state of the complaint investigation and resolution process.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintSubcategory rdf:type rdf:Property ;
    rdfs:label 'Complaint Subcategory' ;
    rdfs:comment 'Detailed sub-classification providing additional granularity to the complaint category.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintType rdf:type rdf:Property ;
    rdfs:label 'Complaint Type' ;
    rdfs:comment 'Complaint Type value for the Product Complaint record.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Date when the consumer or customer experienced the quality issue or adverse event.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completion Date' ;
    rdfs:comment 'Date when the investigation was concluded and findings documented.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationOutcome rdf:type rdf:Property ;
    rdfs:label 'Investigation Outcome' ;
    rdfs:comment 'Attribute investigation_outcome of quality.product_complaint.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date when the formal investigation of the complaint was initiated.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current state of the internal quality investigation process.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationSummary rdf:type rdf:Property ;
    rdfs:label 'Investigation Summary' ;
    rdfs:comment 'Attribute investigation_summary of quality.product_complaint.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdverseEvent rdf:type rdf:Property ;
    rdfs:label 'Is Adverse Event' ;
    rdfs:comment 'Boolean indicator for Is Adverse Event.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReportable rdf:type rdf:Property ;
    rdfs:label 'Is Reportable' ;
    rdfs:comment 'Attribute is_reportable of quality.product_complaint.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labAnalysisResult rdf:type rdf:Property ;
    rdfs:label 'Lab Analysis Result' ;
    rdfs:comment 'Summary of laboratory test results conducted on the returned product sample.' ;
    rdfs:domain ind:ProductComplaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productComplaintStatus rdf:type rdf:Property ;
    rdfs:label 'Product Complaint Status' ;
    rdfs:comment 'Attribute status of quality.product_complaint.' ;
    rdfs:domain ind:ProductComplaint ;
