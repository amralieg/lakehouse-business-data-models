    rdfs:range xsd:string .

ind:usageRightsExpiry rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Expiry' ;
    rdfs:comment 'The usage rights expiry of the creative asset record' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:widthPixels rdf:type rdf:Property ;
    rdfs:label 'Width Pixels' ;
    rdfs:comment 'Width dimension of the creative asset in pixels (applicable to images, videos, and display ads).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeLower rdf:type rdf:Property ;
    rdfs:label 'Age Range Lower' ;
    rdfs:comment 'Lower bound of the age range for consumers in this segment (in years). Null if age is not a defining characteristic.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeUpper rdf:type rdf:Property ;
    rdfs:label 'Age Range Upper' ;
    rdfs:comment 'Upper bound of the age range for consumers in this segment (in years). Null if age is not a defining characteristic.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageBasketSizeUsd rdf:type rdf:Property ;
    rdfs:label 'Average Basket Size Usd' ;
    rdfs:comment 'Average transaction or basket size in USD for consumers in this segment, used for campaign ROI modeling.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandAffinity rdf:type rdf:Property ;
    rdfs:label 'Brand Affinity' ;
    rdfs:comment 'Brands or brand categories that this segment shows strong preference or loyalty toward. Used for brand-specific campaign targeting.' ;
    rdfs:domain ind:ConsumerSegment ;
