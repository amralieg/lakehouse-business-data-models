    rdfs:comment 'The iso certification of the manufacturing facility record' ;
    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
