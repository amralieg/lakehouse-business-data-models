    rdfs:domain ind:ManufacturingFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaSiteNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Site Number' ;
