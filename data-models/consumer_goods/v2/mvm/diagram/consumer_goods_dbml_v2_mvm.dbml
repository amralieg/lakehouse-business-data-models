// DBML Schema for Business: Consumer_Goods
// Version: 2
// Generated on: 2026-06-27 07:48:03

Project {
  database_type: 'Databricks Unity Catalog'
  Note: 'Lakehouse data model for Consumer_Goods - Version 2'
}

Table product.sku {
  sku_id varchar [pk, note: 'Unique surrogate identifier for each SKU record in the product master. Primary key for the sku data product, referenced by all downstream domains as the authoritative product identifier.']
  approved_supplier_list_id varchar [note: 'Foreign key linking to procurement.approved_supplier_list. Business justification: ASL-to-SKU linkage is a core consumer goods procurement control: production and procurement cannot proceed without ASL qualification. Quality and regulatory teams query \'which ASL governs this SKU\' fo']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Cost allocation report requires each SKU to be assigned a cost_center for expense tracking and product profitability analysis.']
  default_supply_network_node_id varchar [note: 'Foreign key linking to supply.network_node. Business justification: Required for assigning each SKU to its primary distribution node used in supply planning, ATP calculations, and network optimization.']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: AR invoice posting uses a default sales GL account per SKU; linking enables automated revenue posting and audit trails.']
  hierarchy_id varchar [note: 'Foreign key linking to product.product_hierarchy. Business justification: sku should be linked to its product hierarchy for classification; no existing column, so new FK added.']
  manufacturing_facility_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_facility. Business justification: CAPACITY PLANNING: Assign each SKU to its primary manufacturing facility for production capacity allocation, cost per facility, and regulatory reporting.']
  owning_marketing_brand_id varchar [note: 'Foreign key linking to marketing.brand. Business justification: Brand performance reports require each SKU to be linked to its marketing brand for equity and spend analysis.']
  primary_supplier_id varchar [note: 'Foreign key linking to procurement.supplier. Business justification: Primary Supplier Assignment for each SKU is required for sourcing strategy, cost analysis, and regulatory compliance reports.']
  primary_supplier_site_id varchar [note: 'Foreign key linking to procurement.supplier_site. Business justification: Designating a primary supplier site per SKU supports logistics planning, VMI inventory control, and OTIF performance tracking.']
  product_brand_id varchar [note: 'Foreign key linking to product.product_brand. Business justification: sku needs to reference its brand master; brand string is redundant once product_brand_id FK is added.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Profitability statements map each SKU to a profit_center, enabling SKU‑level P&L reporting and margin analysis.']
  sku_category_id varchar [note: 'Foreign key linking to product.category. Business justification: SKU belongs to a product category; linking SKU to category eliminates silo and consolidates category data.']
  sku_product_category_id varchar [note: 'Foreign key linking to product.product_category. Business justification: SKU may belong to multiple product categories; linking SKU to product_category adds needed inbound relationship.']
  amount decimal(18,4) [note: 'Amount value for the sku record.']
  code varchar [note: 'Internal alphanumeric code assigned to the SKU within the ERP system (SAP S/4HANA Material Number). Serves as the primary business identifier used in procurement, manufacturing, and sales transactions. Maps to SAP MM material number.']
  color varchar [note: 'Consumer-facing color descriptor for the SKU (e.g., \'Blue\', \'Clear\', \'White\'). Applicable to products where color is a differentiating attribute (e.g., hair color, cosmetics, cleaning products). Used in planogram execution and consumer-facing content.']
  country_of_origin varchar [note: 'ISO 3166-1 alpha-3 country code indicating the country where the product is manufactured or substantially transformed. Required for customs declarations, trade compliance, and consumer labeling in many markets.']
  created_timestamp timestamp [note: 'Timestamp when the SKU master record was first created in the system of record (SAP S/4HANA). Used for data lineage, audit trail, and compliance with SOX record-keeping requirements.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the MSRP and standard cost fields (e.g., USD, EUR, GBP). Ensures consistent financial reporting across multi-currency operations.']
  description varchar [note: 'The sku description of the sku record']
  discontinuation_date date [note: 'Date on which the SKU was or is planned to be permanently discontinued from the portfolio. Triggers end-of-life processes in supply chain, manufacturing, and trade. Null if the SKU is still active.']
  ean varchar [note: '13-digit European Article Number (EAN-13) used in international retail markets outside North America for barcode scanning and product identification. Registered with GS1.']
  effective_from date [note: 'The effective from of the sku.']
  effective_until date [note: 'The effective until of the sku record']
  fefo_threshold_pct decimal(5,2) [note: 'Minimum remaining shelf life percentage (of total shelf life) required at the time of shipment to a customer or retailer. Below this threshold, the product is considered non-shippable. Used in Blue Yonder WMS and SAP IBP inventory optimization.']
  gross_weight_kg decimal(18,4) [note: 'Total gross weight of the consumer unit including packaging in kilograms. Used in logistics freight calculation, transportation planning, and customs documentation. Maps to SAP MM material master gross weight field.']
  gtin varchar [note: 'GS1-standard Global Trade Item Number uniquely identifying the product in global trade. Encompasses UPC-A (12-digit), EAN-13 (13-digit), and ITF-14 (14-digit) formats. Used for barcode scanning, EDI transactions, and retailer product listings.']
  inci_declaration varchar [note: 'Full INCI (International Nomenclature of Cosmetic Ingredients) ingredient list as declared on product packaging, listed in descending order of concentration. Mandatory for cosmetic and personal care products under FDA and EU regulations. Stored in Veeva Vault.']
  is_hazardous boolean [note: 'Indicates whether the SKU is classified as a hazardous material requiring special handling, storage, or transportation documentation (e.g., Safety Data Sheet / SDS). Triggers compliance workflows in logistics and warehouse management.']
  is_recyclable_packaging boolean [note: 'Indicates whether the primary packaging of the SKU is designed to be recyclable. Used in sustainability reporting, ESG disclosures, and consumer-facing labeling claims per FTC Green Guides.']
  is_regulated_product boolean [note: 'Indicates whether the SKU is subject to regulatory approval or registration requirements (e.g., FDA OTC drug, EPA-registered disinfectant, CPSC-regulated product). Triggers regulatory submission workflows in Veeva Vault.']
  is_sustainable boolean [note: 'Indicates whether the SKU meets the company\'s sustainability criteria, such as FSC-certified packaging, RSPO-certified palm oil, or ISO 14001-aligned manufacturing. Used in sustainability reporting and ESG disclosures.']
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent update to the SKU master record. Used for change data capture (CDC) in the Databricks Silver Layer pipeline, audit trail, and data quality monitoring.']
  launch_date date [note: 'Date on which the SKU was first commercially available for sale in any market. Used in new product development (NPD) tracking, demand planning baseline establishment, and trade promotion planning.']
  lifecycle_stage varchar [note: 'Current stage of the SKU in the Product Lifecycle Management (PLM) framework (e.g., concept, development, launch, growth, mature, decline, discontinued). Governs which business processes are active for the SKU. Managed in Veeva Vault PLM. [ENUM-REF-CANDIDATE: concept|development|launch|growth|mature|decline|discontinued — 7 candidates stripped; promote to reference product]']
  msrp decimal(18,4) [note: 'Manufacturer Suggested Retail Price (MSRP) in the base currency. Represents the recommended consumer selling price (RSP) set by the manufacturer. Used in trade promotion planning (TPM), pricing strategy, and retailer negotiations. Confidential commercial data.']
  name varchar [note: 'The sku name of the sku record']
  net_content decimal(18,4) [note: 'Numeric net content quantity of the product as declared on packaging (e.g., 500, 1.5, 200). Must be paired with net_content_uom. Regulated by FDA and FTC for accurate labeling. Used in COGS calculation and logistics weight/volume planning.']
  net_content_uom varchar [note: 'Unit of measure for the net content quantity (e.g., ml, L, g, kg, oz, fl oz, ct). Aligned with GS1 UN/CEFACT unit codes. Required for regulatory labeling compliance and logistics planning. [ENUM-REF-CANDIDATE: ml|L|g|kg|oz|fl oz|ct|units — 8 candidates stripped; promote to reference product]']
  net_weight_kg decimal(18,4) [note: 'Net weight of the product content excluding packaging in kilograms. Used in COGS calculation, regulatory labeling, and customs declarations. Maps to SAP MM material master net weight field.']
  notes varchar [note: 'The notes of the sku record']
  pack_size varchar [note: 'Number of individual consumer units contained within a single sellable pack (e.g., 1 for single unit, 2 for twin pack, 6 for multipack). Used in trade promotion planning (TPM), pricing, and distribution requirements planning (DRP).']
  packaging_material_type varchar [note: 'Material type of the primary consumer packaging (e.g., plastic, glass, aluminum, paper, cardboard). Used in sustainability reporting, EU REACH compliance, and packaging specification management in Veeva Vault. [ENUM-REF-CANDIDATE: plastic|glass|aluminum|paper|cardboard|composite|biodegradable — 7 candidates stripped; promote to reference product]']
  portfolio_classification varchar [note: 'Strategic classification of the SKU within the brand portfolio (e.g., core, strategic, tail, innovation, seasonal, limited_edition). Used in S&OP (Sales and Operations Planning) prioritization, resource allocation, and SKU rationalization decisions.']
  product_form varchar [note: 'Physical or chemical form of the product (e.g., liquid, powder, gel, cream, spray). Critical for manufacturing process routing in Siemens Opcenter MES, packaging specification, and regulatory classification. [ENUM-REF-CANDIDATE: liquid|powder|gel|cream|foam|spray|bar|tablet|capsule|wipe|stick|sheet — promote to reference product]']
  product_name varchar [note: 'Full consumer-facing product name as it appears on packaging and in retail listings. Includes brand, variant, and size descriptors (e.g., \'Brand X Moisturizing Body Wash Fresh Scent 500ml\'). Used in marketing, trade, and regulatory submissions.']
  quantity decimal(18,4) [note: 'The quantity of the sku record']
  regulatory_category varchar [note: 'Regulatory classification of the SKU determining the applicable regulatory framework and labeling requirements (e.g., cosmetic, OTC drug, household chemical, food). Drives compliance workflows in Veeva Vault and regulatory reporting. [ENUM-REF-CANDIDATE: cosmetic|otc_drug|household_chemical|food|dietary_supplement|medical_device|general_merchandise — 7 candidates stripped; promote to reference product]']
  scent varchar [note: 'Consumer-facing scent or fragrance descriptor for the SKU (e.g., \'Fresh\', \'Lavender\', \'Unscented\'). Relevant for personal care and household products. Used in consumer engagement, marketing, and IFRA fragrance compliance tracking.']
  short_description varchar [note: 'Abbreviated product description (typically 40–80 characters) used in ERP transactions, warehouse management systems, and EDI communications where full product names are truncated. Maps to SAP MM short text field.']
  sku_status varchar [note: 'Current operational status of the SKU in the ERP system (SAP S/4HANA material status). Controls whether the SKU can be procured, manufactured, sold, or shipped. \'blocked\' prevents all transactions; \'pending_launch\' indicates pre-commercialization.']
  source_system_code varchar [note: 'The source system code of the sku record']
  standard_cost decimal(18,4) [note: 'Standard cost per consumer unit used for Cost of Goods Sold (COGS) calculation, financial reporting, and profitability analysis. Set annually during standard cost roll in SAP S/4HANA CO. Confidential financial data.']
  storage_conditions varchar [note: 'Required storage conditions for the SKU throughout the supply chain (e.g., ambient, refrigerated, frozen, controlled_temperature). Drives warehouse slotting in Blue Yonder WMS, transportation lane requirements, and regulatory compliance.']
  sub_brand varchar [note: 'Sub-brand or product line within the parent brand (e.g., \'Dove Men+Care\', \'Tide PODS\'). Enables granular brand portfolio analysis and targeted trade promotion management (TPM).']
  subcategory varchar [note: 'Second-level product classification within the category (e.g., \'Shampoo\', \'Conditioner\', \'Detergent Pods\'). Supports granular category management, demand planning in SAP IBP, and retail execution reporting.']
  target_demographic varchar [note: 'Primary consumer demographic segment this SKU is designed and marketed for (e.g., adult, baby, male, female, professional). Drives consumer segmentation, marketing investment allocation, and shelf placement strategy. [ENUM-REF-CANDIDATE: adult|baby|child|teen|senior|unisex|male|female|professional|family — promote to reference product]']
  total_shelf_life_days varchar [note: 'Total shelf life of the SKU in days from the date of manufacture to the expiry date as declared on packaging. Used in FEFO (First Expired First Out) inventory management, Blue Yonder WMS configuration, and regulatory compliance.']
  uom varchar [note: 'The uom of the sku record']
  upc varchar [note: '12-digit Universal Product Code (UPC-A) used primarily in North American retail for point-of-sale scanning and inventory management. Subset of GTIN. Registered with GS1 US.']
  updated_timestamp timestamp [note: 'The updated timestamp of the sku record']
  variant varchar [note: 'Specific variant descriptor distinguishing this SKU from others within the same product line (e.g., \'Original\', \'Sensitive Skin\', \'Extra Strength\', \'2-in-1\'). Used in PLM lifecycle management and consumer segmentation.']
  volume_ml decimal(18,4) [note: 'Volume of the consumer unit in millilitres, used for liquid and semi-liquid products. Supports logistics cube utilization calculations, warehouse slotting, and transportation planning.']

  Note: 'Core master record for every Stock Keeping Unit (SKU) in the CPG/FMCG portfolio. Single source of truth for SKU identity including internal code, description, brand assignment, sub-brand, product form, variant, net content, unit of measure, pack size, launch date, discontinuation date, PLM lifecycle stage, portfolio classification, shelf life attributes (total shelf life, FEFO threshold, storage conditions), and key consumer-facing attributes (scent, color, target demographic). Referenced by all other domains as the authoritative product identifier.'
}

Table product.gtin_registry {
  gtin_registry_id varchar [pk, note: 'Unique surrogate primary key for each GTIN registry record in the Databricks Silver layer. Assigned by the platform upon ingestion from SAP S/4HANA MM or GS1 registration source.']
  account_address_id varchar [note: 'Carried-over connect_table FK addition P5 (BIGINT).']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: GTIN legal entity ownership for intercompany reconciliation and regulatory filings. In multi-entity CPG companies, GTINs are registered and owned by specific legal entities (company codes). Required f']
  packaging_spec_id varchar [note: 'Foreign key linking to product.product_packaging_spec. Business justification: A GTIN is assigned at a specific packaging level (consumer unit, inner pack, case, pallet) and corresponds to a specific packaging specification. The gtin_registry already links to sku via sku_id, but']
  sku_id varchar [note: 'Reference to the internal SKU master record to which this GTIN is assigned. A single SKU may have multiple GTINs across packaging hierarchy levels (each, inner pack, case, pallet).']
  activation_date date [note: 'The date on which the GTIN was activated and made available for commercial use, EDI transactions, and retailer catalog publication. May differ from assignment_date when a GTIN is pre-assigned during NPD but activated at product launch.']
  amount decimal(18,4) [note: 'The amount of the gtin registry record']
  assignment_date date [note: 'The calendar date on which this GTIN was formally assigned to the SKU by the brand owner. Used for GS1 GTIN Management Standard compliance, audit trails, and PLM lifecycle tracking in SAP S/4HANA MM.']
  barcode_symbology varchar [note: 'The barcode symbology used to encode this GTIN on the physical product or packaging (e.g., UPC-A for consumer units, ITF-14 for cases, GS1-128 for logistic labels). Determines scanner compatibility at POS, warehouse, and DSD delivery points. [ENUM-REF-CANDIDATE: UPC-A|EAN-13|EAN-8|ITF-14|GS1-128|GS1_DataBar|QR_Code — promote to reference product]']
  brand_name varchar [note: 'The registered brand or trademark name under which the product is marketed to consumers. Used for retailer catalog syndication, Nielsen IQ market measurement reporting, and trade promotion management in Salesforce Consumer Goods Cloud.']
  brand_owner_gln varchar [note: 'The 13-digit GS1 Global Location Number (GLN) identifying the legal entity that owns the brand and is responsible for the GTIN assignment. Required for GS1 Data Source (1WorldSync/Salsify) product data syndication and retailer onboarding.']
  cases_per_pallet varchar [note: 'The standard number of cases stacked on one pallet (logistic unit). Used for transportation planning, warehouse slotting in Blue Yonder WMS, and pallet-level GTIN-14 assignment. Drives DRP and S&OP capacity calculations in SAP IBP.']
  check_digit varchar [note: 'The single trailing check digit of the GTIN, calculated using the GS1 modulo-10 algorithm. Used to validate GTIN integrity during barcode scanning, EDI processing, and retailer catalog ingestion. Stored explicitly to support validation workflows.']
  code varchar [note: 'The gtin registry code for the gtin registry record.']
  country_of_origin varchar [note: 'ISO 3166-1 alpha-3 country code indicating the country where the product was manufactured or substantially transformed. Required for customs declarations, FDA import labeling, FTC country-of-origin rules, and retailer catalog submissions.']
  created_timestamp timestamp [note: 'The timestamp when this GTIN registry record was first created in the system of record. Follows ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for audit trail, SOX compliance, and data lineage tracking.']
  currency_code varchar [note: 'Currency code for gtin_registry (currency_code).']
  data_pool_publication_date date [note: 'The date on which the product data for this GTIN was first published to the GS1 data pool (GDSN). Used to track compliance with retailer new item setup timelines and GS1 sunrise date requirements.']
  data_pool_published boolean [note: 'Indicates whether the full product data record for this GTIN has been published to a GS1-certified data pool (e.g., 1WorldSync, Salsify) for retailer catalog synchronization. True = published and available to subscribers; False = not yet published.']
  description varchar [note: 'The gtin registry description of the gtin registry record']
  ean_value decimal(18,2) [note: 'The 13-digit EAN-13 barcode value used for international retail scanning and cross-border trade. Populated when gtin_format is GTIN-13. Required for EU, APAC, and LATAM retailer catalog submissions and EDI transactions.']
  edi_eligible boolean [note: 'Indicates whether this GTIN is set up and approved for EDI transactions (850 Purchase Order, 856 ASN, 832 Price/Sales Catalog) with trading partners. False when the GTIN is pending retailer item setup or has failed EDI validation. Managed in SAP S/4HANA SD and Oracle Cloud EDI.']
  effective_from date [note: 'The effective from of the gtin registry record']
  effective_until date [note: 'The effective until of the gtin registry record']
  gpc_brick_code varchar [note: 'The 8-digit GS1 Global Product Classification (GPC) Brick Code that categorizes the product into a standardized product segment, family, class, and brick. Required for GS1 data pool submissions and used by retailers for category management and planogram (POG) optimization.']
  gs1_company_prefix varchar [note: 'The GS1-assigned company prefix (6–12 digits) that identifies the brand owner within the GTIN structure. Issued by GS1 US or a GS1 Member Organization. Determines the number of GTINs available to the company and is embedded in every GTIN assigned by the company.']
  gs1_member_org varchar [note: 'The name of the GS1 Member Organization (e.g., GS1 US, GS1 UK, GS1 Germany) through which the company prefix was licensed. Relevant for multi-national CPG companies that hold prefixes from multiple GS1 member organizations across different markets.']
  gs1_registration_reference varchar [note: 'The reference number or confirmation identifier issued by GS1 (or a GS1 Member Organization) upon formal registration of this GTIN in the GS1 registry. Used for audit, dispute resolution, and regulatory submissions requiring proof of GS1 registration.']
  gs1_registry_published boolean [note: 'Indicates whether this GTIN has been published to the GS1 Registry Platform (formerly GEPIR) and is visible to trading partners and retailers for catalog synchronization. True = published; False = not yet published or withheld.']
  gtin_format varchar [note: 'Identifies the GTIN format variant: GTIN-8 (EAN-8 short barcode), GTIN-12 (UPC-A, North American standard), GTIN-13 (EAN-13, international standard), or GTIN-14 (ITF-14, used for cases and pallets). Determines barcode symbology and EDI transaction set usage.']
  gtin_registry_status varchar [note: 'The gtin registry status of the gtin registry record']
  gtin_value decimal(18,2) [note: 'The full numeric GTIN string including the check digit. Supports GTIN-8, GTIN-12 (UPC-A), GTIN-13 (EAN-13), and GTIN-14 (shipping container/case) formats as defined by GS1 General Specifications. Used in barcode scanning, EDI transactions, and retailer catalog synchronization.']
  indicator_digit varchar [note: 'Single leading digit (0–9) used in GTIN-14 to indicate the packaging level of a trade item. A value of 0 indicates a consumer unit; values 1–8 indicate inner packs or cases; value 9 is reserved for variable-measure trade items. Applicable only when gtin_format is GTIN-14.']
  inner_packs_per_case varchar [note: 'The number of inner packs (display shippers or multi-packs) contained within one case. Populated only when an intermediate inner-pack packaging level exists in the hierarchy. Used in SAP S/4HANA MM BOM and GS1 packaging hierarchy declarations.']
  is_consumer_unit boolean [note: 'Indicates whether this GTIN represents the consumer-facing sellable unit (each/each pack) as opposed to an inner pack, case, or pallet. True = consumer unit eligible for POS scanning; False = logistic/trade unit. Drives OSA monitoring and POS data matching in Nielsen IQ and TradeEdge.']
  is_orderable boolean [note: 'Indicates whether this GTIN is currently eligible to be ordered by retail customers via EDI or Salesforce Consumer Goods Cloud order management. False when the GTIN is retired, pending, or restricted to specific channels.']
  is_scannable boolean [note: 'Indicates whether a valid, scannable barcode (UPC/EAN/ITF-14) has been verified and approved for this GTIN. False when the barcode artwork is pending verification or has failed GS1 barcode quality verification. Used in retail execution and DSD workflows in Salesforce Consumer Goods Cloud.']
  is_variable_measure boolean [note: 'Indicates whether this GTIN represents a variable-measure trade item (e.g., catch-weight products sold by weight). True = variable measure; False = fixed measure. Variable-measure GTINs use indicator digit 9 in GTIN-14 and require special POS and EDI handling per GS1 specifications.']
  item_reference_number varchar [note: 'The item reference portion of the GTIN, assigned by the brand owner to uniquely identify the product within the company prefix. Together with the company prefix and check digit, it forms the complete GTIN. Sourced from SAP S/4HANA MM material master EAN/UPC segment.']
  last_updated_timestamp timestamp [note: 'The timestamp of the most recent modification to this GTIN registry record in the system of record. Used for incremental data loads, change detection, and audit compliance in the Databricks Silver layer.']
  name varchar [note: 'The gtin registry name of the gtin registry record']
  net_content_uom varchar [note: 'The unit of measure for the net content value (e.g., ml, L, g, kg, oz, fl_oz, ct, ea). Required for FDA label compliance, GS1 data pool submissions, and retailer catalog item setup. Follows GS1 Recommendation on Unit of Measure codes. [ENUM-REF-CANDIDATE: ml|L|g|kg|oz|fl_oz|ct|ea — 8 candidates stripped; promote to reference product]']
  net_content_value decimal(18,4) [note: 'The numeric net content quantity of the consumer unit (e.g., 400 for a 400ml shampoo bottle). Combined with net_content_uom to express the full net content declaration required on product labels per FDA and FTC labeling regulations.']
  notes varchar [note: 'The notes of the gtin registry record']
  packaging_level varchar [note: 'Identifies the packaging hierarchy level to which this GTIN is assigned: each (consumer unit), inner pack (multi-pack or display shipper), case (master carton), or pallet (logistic unit). Drives EDI order management, warehouse scanning, and DRP/MRP planning in SAP S/4HANA and Blue Yonder WMS.']
  plm_lifecycle_stage varchar [note: 'The current PLM lifecycle stage of the product associated with this GTIN: concept, development, commercialization, active (in market), end_of_life (phase-out initiated), or discontinued. Sourced from the PLM system and used to govern GTIN activation, EDI eligibility, and retailer catalog status.']
  product_category varchar [note: 'The internal product category classification (e.g., Hair Care, Skin Care, Oral Care, Home Care) to which the SKU belongs. Aligns with the company\'s PLM product hierarchy and Nielsen IQ category definitions for market share reporting.']
  product_description varchar [note: 'Short consumer-facing product description associated with this GTIN, as published to retailer catalogs and GS1 data pools. Typically includes brand name, product name, variant, and net content (e.g., \'Brand X Moisturizing Shampoo 400ml\'). Sourced from SAP S/4HANA MM material description.']
  quantity decimal(18,4) [note: 'The quantity of the gtin registry record']
  registration_status varchar [note: 'Current lifecycle status of the GTIN registration: active (in use and published to trading partners), pending (assigned but not yet published), inactive (temporarily suspended), retired (permanently discontinued), or cancelled (assigned in error and voided). Governs EDI eligibility and retailer catalog synchronization.']
  retirement_date date [note: 'The date on which the GTIN was retired or discontinued from active commercial use. Per GS1 GTIN Management Standard, a retired GTIN must not be reassigned for a minimum of 48 months. Null when the GTIN is still active.']
  source_system_code varchar [note: 'The source system code of the gtin registry record']
  source_system_key varchar [note: 'The natural key or internal identifier of this GTIN record in the originating source system (e.g., SAP material number + EAN category combination). Used for delta-load reconciliation, deduplication, and lineage tracing in the Databricks Silver layer ingestion pipeline.']
  target_market_country varchar [note: 'ISO 3166-1 alpha-3 country code of the primary market for which this GTIN is intended. A single SKU may have different GTINs for different target markets due to regulatory labeling, language, or formulation differences. Used in GS1 data pool syndication and Veeva Vault regulatory submissions.']
  units_per_case varchar [note: 'The number of consumer units (eaches) contained within one case (master carton). Used in SAP S/4HANA MM for BOM/packaging hierarchy, DRP/MRP planning, and EDI order quantity validation. Also referenced in Blue Yonder WMS for receiving and putaway.']
  uom varchar [note: 'The uom of the gtin registry record']
  upc_value decimal(18,2) [note: 'The 12-digit UPC-A barcode value assigned to the consumer unit (each). Derived from the GTIN-12 and used primarily for North American retail POS scanning and retailer item setup. Populated only when gtin_format is GTIN-12.']
  updated_timestamp timestamp [note: 'The updated timestamp of the gtin registry record']

  Note: 'Authoritative registry of all GS1-compliant global trade item numbers (GTIN-8, GTIN-12/UPC, GTIN-13/EAN, GTIN-14) assigned to each SKU and its packaging hierarchy levels (each, inner pack, case, pallet). Stores GTIN value, GS1 company prefix, indicator digit, check digit, packaging level, assignment date, status, and GS1 registration reference. Enables barcode scanning, EDI transactions, and retailer catalog synchronization.'
}

Table product.hierarchy {
  hierarchy_id varchar [pk, note: 'Unique surrogate identifier for each node in the product classification hierarchy. Serves as the primary key for this record in the Silver Layer lakehouse.']
  parent_hierarchy_id varchar [note: 'Reference to the immediate parent node in the product hierarchy tree. NULL for root-level nodes (e.g., Division). Enables recursive traversal of the Division → Category → Sub-Category → Brand → Sub-Brand → Product Form → SKU hierarchy.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Hierarchical P&L and segment reporting. CPG product hierarchy nodes (division, category, subcategory) map to profit center hierarchy for management P&L, IBP planning, and IFRS 8 segment reporting. The']
  amount decimal(18,4) [note: 'The amount of the hierarchy record']
  approved_date date [note: 'Date on which this hierarchy node was formally approved by the data steward or product management team. Supports PLM lifecycle governance and audit trail for regulatory submissions.']
  brand_code varchar [note: 'Code of the Brand-level ancestor node for this hierarchy node. Denormalized to enable brand-level P&L reporting, brand equity tracking, SOV (Share of Voice) analysis, and trade promotion planning at the brand level.']
  category_code varchar [note: 'Code of the Category-level ancestor node for this hierarchy node. Denormalized to support category management, trade promotion planning (TPM), and demand forecasting without recursive hierarchy joins.']
  channel_applicability varchar [note: 'Distribution channels through which products in this hierarchy node are sold (e.g., \'Retail\', \'E-Commerce\', \'DTC\', \'Wholesale\', \'DSD\'). Supports channel management, trade promotion planning, and distribution requirements planning (DRP). [ENUM-REF-CANDIDATE: Retail|E-Commerce|DTC|Wholesale|DSD|Club|Drug — promote to reference product]']
  code varchar [note: 'The hierarchy code of the hierarchy record']
  cpsc_regulated boolean [note: 'Indicates whether products in this hierarchy node are subject to CPSC (Consumer Product Safety Commission) regulations. True = product safety testing, labeling, and reporting requirements under CPSA apply.']
  created_timestamp timestamp [note: 'Timestamp when this hierarchy node record was first created in the Silver Layer lakehouse. Supports audit trail, data lineage, and compliance with SOX financial data governance requirements.']
  currency_code varchar [note: 'The currency code of the hierarchy record']
  description varchar [note: 'The hierarchy description of the hierarchy record']
  division_code varchar [note: 'Code of the top-level Division node to which this hierarchy node belongs (e.g., \'HPC\' for Home & Personal Care, \'FOOD\' for Food & Beverage). Denormalized for fast filtering in OLAP queries and S&OP (Sales and Operations Planning) reporting without full hierarchy traversal.']
  effective_from date [note: 'Date from which this hierarchy node became effective and available for use in planning, trade promotion, and reporting systems. Supports temporal validity management and historical hierarchy reconstruction for trend analysis.']
  effective_until date [note: 'Date after which this hierarchy node is no longer active. NULL indicates an open-ended validity. Used for hierarchy versioning, portfolio rationalization, and ensuring discontinued nodes are excluded from forward-looking demand plans.']
  external_reference_code varchar [note: 'External partner or retailer-specific category code mapped to this hierarchy node (e.g., Walmart category code, Amazon browse node ID). Supports EDI (Electronic Data Interchange) transactions, retailer data synchronization, and VMI (Vendor Managed Inventory) programs.']
  gmp_standard varchar [note: 'Applicable GMP (Good Manufacturing Practice) standard for manufacturing products in this hierarchy node. Drives quality management requirements in Siemens Opcenter MES and Veeva Vault QMS. ISO 22716 applies to cosmetics; 21 CFR 111 to dietary supplements; 21 CFR 210/211 to pharmaceuticals.']
  gpc_brick_code varchar [note: 'GS1 Global Product Classification (GPC) brick-level code (8-digit numeric) aligned to this hierarchy node. Enables cross-industry product classification interoperability, EDI transactions, and retailer data synchronization via GS1 standards.']
  gpc_brick_name varchar [note: 'Descriptive name of the GS1 GPC brick code associated with this hierarchy node (e.g., \'Shampoo/Conditioner - Non-Medicated\'). Supports regulatory submissions, retailer onboarding, and GS1 data pool synchronization.']
  hierarchy_status varchar [note: 'The hierarchy status of the hierarchy record']
  ibp_planning_level boolean [note: 'Indicates whether this hierarchy node is a designated planning level in SAP IBP (Integrated Business Planning) for demand forecasting and S&OP (Sales and Operations Planning). True = this node is an active planning aggregation point.']
  inci_applicable boolean [note: 'Indicates whether products in this hierarchy node require INCI (International Nomenclature of Cosmetic Ingredients) ingredient declaration on labeling. True = cosmetic/personal care products subject to EU Cosmetics Regulation and FDA cosmetic labeling requirements.']
  iri_category_code varchar [note: 'IRI (now Circana) proprietary category code mapped to this hierarchy node. Supports market share reporting, TDP (Total Distribution Points) analysis, and SOM (Share of Market) calculations using IRI syndicated data.']
  is_leaf_node boolean [note: 'Indicates whether this node is a terminal leaf in the hierarchy (True = no children exist, typically the SKU level). Used to filter for assignable product nodes in demand forecasting, inventory management, and trade promotion planning.']
  language_code varchar [note: 'ISO 639-1 language code for the node_name and node_description fields (e.g., \'en\', \'fr\', \'de\', \'es\'). Supports multi-language product hierarchy management for global CPG/FMCG operations and localized reporting.']
  level varchar [note: 'Numeric depth of this node within the product classification hierarchy. Level 1 = Division, Level 2 = Category, Level 3 = Sub-Category, Level 4 = Brand, Level 5 = Sub-Brand, Level 6 = Product Form, Level 7 = SKU (Stock Keeping Unit). Used for OLAP drill-down and aggregation logic.']
  level_name varchar [note: 'Business label for the hierarchy depth of this node. Enumerated values correspond to the CPG/FMCG standard classification spine: Division, Category, Sub-Category, Brand, Sub-Brand, Product Form, SKU (Stock Keeping Unit). Drives display logic in reporting tools and S&OP dashboards. [ENUM-REF-CANDIDATE: Division|Category|Sub-Category|Brand|Sub-Brand|Product Form|SKU — 7 candidates stripped; promote to reference product]']
  market_share_reportable boolean [note: 'Indicates whether this hierarchy node is included in external market share reporting via Nielsen IQ or IRI/Circana syndicated data. True = node is mapped to a syndicated data category for SOM (Share of Market) and ACV (All Commodity Volume) reporting.']
  name varchar [note: 'The hierarchy name of the hierarchy record']
  nielsen_category_code varchar [note: 'Nielsen IQ proprietary category code mapped to this hierarchy node. Enables direct linkage between internal product classification and Nielsen IQ retail measurement data for market share reporting, ACV (All Commodity Volume) analysis, and competitive benchmarking.']
  node_code varchar [note: 'Externally-known alphanumeric code uniquely identifying this hierarchy node within its level. Used as the business key in SAP S/4HANA MM product group structures and referenced in EDI transactions and trade promotion planning systems.']
  node_description varchar [note: 'Extended business description of the hierarchy node providing additional context about the product grouping, its scope, and intended use in classification. Supports regulatory categorization and PLM documentation.']
  node_name varchar [note: 'Human-readable business name of this hierarchy node (e.g., \'Personal Care\', \'Shampoo\', \'Head & Shoulders\', \'Classic Clean\'). Used in OLAP drill-down reports, trade promotion planning, and market share dashboards.']
  node_status varchar [note: 'Current lifecycle status of this hierarchy node. \'active\' nodes are available for use in planning, trade promotion, and reporting. \'discontinued\' nodes are retained for historical analysis. \'pending\' nodes are awaiting approval in the PLM (Product Lifecycle Management) workflow.']
  notes varchar [note: 'The notes of the hierarchy record']
  path varchar [note: 'Materialized full path string from root to this node using a delimiter (e.g., \'Consumer Goods / Personal Care / Hair Care / Shampoo / Head & Shoulders / Classic Clean\'). Enables fast string-based filtering and display in BI tools without recursive joins.']
  plm_lifecycle_stage varchar [note: 'Current stage of the product node in the PLM (Product Lifecycle Management) lifecycle. Drives NPD (New Product Development) workflows, portfolio rationalization decisions, and demand planning assumptions in SAP IBP. [ENUM-REF-CANDIDATE: concept|development|launch|growth|mature|decline|discontinued — 7 candidates stripped; promote to reference product]']
  quantity decimal(18,4) [note: 'The quantity of the hierarchy record']
  reach_regulated boolean [note: 'Indicates whether products in this hierarchy node are subject to EU REACH Regulation (Registration, Evaluation, Authorisation and Restriction of Chemicals). True = chemical substance registration and SDS (Safety Data Sheet) requirements apply.']
  regulatory_framework varchar [note: 'Identifies the primary regulatory framework governing products classified under this hierarchy node (e.g., \'FDA OTC Drug\', \'FDA Cosmetic\', \'EPA Pesticide\', \'CPSC Consumer Product\', \'EU Cosmetics Regulation\'). Drives compliance workflows in Veeva Vault and regulatory labeling requirements. [ENUM-REF-CANDIDATE: FDA OTC Drug|FDA Cosmetic|EPA Pesticide|CPSC Consumer Product|EU Cosmetics Regulation|REACH|ISO 22716|IFRA — promote to reference product]']
  sort_order varchar [note: 'Numeric sequence controlling the display order of sibling nodes within the same parent. Used to enforce business-defined ordering in planograms (POG), category management reports, and trade promotion planning interfaces.']
  source_system_code varchar [note: 'Identifies the operational system of record from which this hierarchy node was sourced (e.g., SAP S/4HANA MM, Veeva Vault PLM, Salesforce Consumer Goods Cloud). Supports data lineage tracking and Silver Layer reconciliation in the Databricks Lakehouse. [ENUM-REF-CANDIDATE: SAP_S4|ORACLE_ERP|VEEVA|SALESFORCE_CGC|SAP_IBP|NIELSEN|MANUAL — 7 candidates stripped; promote to reference product]']
  source_system_node_code varchar [note: 'Native identifier of this hierarchy node in the originating operational system (e.g., SAP product hierarchy node ID, Veeva Vault record ID). Enables reverse traceability from the Silver Layer back to the system of record for reconciliation and audit.']
  sustainability_flag boolean [note: 'Indicates whether products in this hierarchy node carry a sustainability certification (e.g., FSC, RSPO, ISO 14001). Supports ESG reporting, sustainable sourcing procurement decisions, and consumer-facing sustainability claims.']
  tax_category_code varchar [note: 'Tax classification code assigned to this hierarchy node for VAT/GST determination in SAP S/4HANA FI/CO. Drives correct tax treatment in sales orders, invoicing, and financial reporting across jurisdictions.']
  trade_promotion_eligible boolean [note: 'Indicates whether products under this hierarchy node are eligible for trade promotion activities (TPM/TPO). Drives eligibility rules in Salesforce Consumer Goods Cloud Trade Promotion Management and ROI (Return on Investment) reporting.']
  uom varchar [note: 'The uom of the hierarchy record']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to this hierarchy node record in the Silver Layer. Used for incremental data pipeline processing, change data capture, and audit trail maintenance.']
  version_number varchar [note: 'Monotonically incrementing version counter for this hierarchy node record. Incremented each time the node definition is materially changed (e.g., reclassification, rename, regulatory framework update). Supports SCD Type 2 history management and audit compliance.']

  Note: 'Defines the multi-level product classification hierarchy used across the CPG portfolio: Division → Category → Sub-Category → Brand → Sub-Brand → Product Form → SKU. Each node carries hierarchy level code, node name, parent node reference, sort order, active flag, GPC brick code alignment, Nielsen/IRI category code mapping, and applicable regulatory framework. Serves as the single authoritative classification backbone for OLAP drill-down, trade promotion planning, demand forecasting, market share reporting, and regulatory categorization.'
}

Table product.product_bom {
  product_bom_id varchar [pk, note: 'Unique surrogate identifier for the Bill of Materials (BOM) header record in the Databricks Silver Layer. Primary key for this entity.']
  account_address_id varchar [note: 'Carried-over connect_table FK addition P7 (BIGINT).']
  formulation_id varchar [note: 'Foreign key linking to product.product_formulation. Business justification: A Bill of Materials is built to manufacture a specific approved formulation. product_bom currently carries formulation_code as a plain STRING reference to the formulation — this is a denormalized poin']
  inspection_plan_id varchar [note: 'Foreign key linking to quality.inspection_plan. Business justification: BOM change control requires linking each BOM version to the active inspection plan so that BOM revisions automatically trigger inspection plan review. Standard SAP QM/PLM integration for GMP manufactu']
  manufacturing_facility_id varchar [note: 'Reference to the manufacturing plant or production site that owns this BOM. BOMs in SAP are plant-specific; the same material may have different BOMs per plant reflecting local sourcing or production capabilities.']
  sku_id varchar [note: 'Reference to the finished good or semi-finished SKU for which this BOM is defined. Links to the product master (material master in SAP). A single SKU may have multiple BOMs of different types.']
  specification_id varchar [note: 'Foreign key linking to quality.specification. Business justification: BOM change control in consumer goods GMP manufacturing requires linking each BOM version to its governing quality specification. When a BOM changes, the linked specification triggers mandatory QA revi']
  alternative_bom varchar [note: 'Alternative BOM identifier (SAP STLAL) allowing multiple BOM variants for the same material and plant combination. Used to manage seasonal formulations, regional variants, or cost-optimized alternatives within the same SKU.']
  amount decimal(18,4) [note: 'The amount of the product bom record']
  approved_date date [note: 'Date on which this BOM was formally approved for production use. Part of the GMP and PLM audit trail. Required for regulatory submissions and quality management documentation.']
  base_quantity decimal(18,6) [note: 'The reference quantity of the finished or semi-finished material for which the BOM component quantities are specified. All component quantities in BOM line items are expressed relative to this base quantity. Typically 1 or 100 in CPG manufacturing.']
  base_uom varchar [note: 'Unit of measure for the BOM base quantity (e.g., KG, L, EA, G). Defines the unit in which the finished good is expressed for component ratio calculations. Aligns with SAP base unit of measure (MARA-MEINS) and GS1 unit codes.']
  bom_category varchar [note: 'SAP BOM category indicating the object type the BOM is assigned to. \'material\' is the standard category for product BOMs in CPG/FMCG. \'equipment\' and \'functional_location\' apply to plant maintenance BOMs. Aligns with SAP STKO-STLTY.']
  bom_description varchar [note: 'Human-readable description of the BOM, typically including the product name, formulation variant, and intended use. Used in PLM, engineering change orders, and regulatory documentation.']
  bom_level varchar [note: 'Indicates the level of the BOM in a multi-level product structure. Level 0 is the finished good, level 1 represents direct components, level 2 represents sub-components, etc. Used for multi-level BOM explosion in MRP and costing roll-ups.']
  bom_number varchar [note: 'Externally-known BOM document number as assigned in SAP S/4HANA PP/MM (e.g., SAP BOM header number). This is the business-facing identifier used in PLM, procurement, and manufacturing communications.']
  bom_type varchar [note: 'Classifies the purpose of the BOM. \'production\' is used for manufacturing execution (MRP/MES), \'costing\' for COGS and standard cost roll-up, \'engineering\' for R&D and NPD design, \'sales\' for variant configuration, \'configurable\' for multi-variant BOMs. Aligns with SAP BOM usage (STLAL).']
  change_number varchar [note: 'Engineering Change Number (ECN) or Engineering Change Order (ECO) reference that authorized the creation or modification of this BOM version. Provides traceability from BOM changes back to the formal change management process in PLM.']
  code varchar [note: 'The product bom code of the product bom record']
  component_count varchar [note: 'Total number of active component line items in this BOM. Provides a quick indicator of BOM complexity and is used in BOM completeness validation checks during PLM review and quality audits.']
  costing_relevance varchar [note: 'Indicates whether this BOM is relevant for product costing (COGS calculation and standard cost roll-up). \'relevant\' means the BOM is included in cost estimates, \'not_relevant\' excludes it, \'conditional\' applies under specific costing scenarios. Critical for financial reporting and EBITDA analysis.']
  created_timestamp timestamp [note: 'Timestamp when this BOM record was first created in the source system (SAP S/4HANA). Provides the audit trail creation marker required for GMP, SOX, and ISO 9001 compliance.']
  currency_code varchar [note: 'The currency code of the product bom record']
  deletion_flag boolean [note: 'Indicates whether this BOM has been flagged for deletion in SAP. A deletion flag marks the BOM as logically deleted without physically removing the record, preserving audit history. Aligns with SAP STKO-LOEKZ.']
  description varchar [note: 'The product bom description of the product bom record']
  effective_from date [note: 'The date from which this BOM version is valid and can be used for production planning, MRP, and costing. Supports time-phased BOM management for seasonal reformulations, ingredient substitutions, or regulatory-driven changes.']
  effective_until date [note: 'The date until which this BOM version is valid. Null indicates an open-ended validity. Used to manage BOM version transitions during reformulations, regulatory updates, or product discontinuations.']
  gmp_compliant boolean [note: 'Indicates whether this BOM has been validated as compliant with Good Manufacturing Practice (GMP) standards. Required for health, hygiene, and personal care products. Compliance is verified during quality review before BOM activation.']
  is_configurable boolean [note: 'Indicates whether this BOM supports variant configuration, allowing different component selections based on product characteristics (e.g., fragrance variant, pack size). Used for configurable products in CPG where a single BOM covers multiple SKU variants.']
  is_phantom boolean [note: 'Indicates whether this BOM represents a phantom assembly — a logical grouping of components that does not physically exist as a stocked item but is used to simplify BOM structures. Phantom assemblies are exploded through in MRP without generating production orders.']
  last_changed_by varchar [note: 'User ID or name of the person who last modified this BOM record. Part of the change audit trail required for GMP, engineering change management, and SOX compliance.']
  last_changed_timestamp timestamp [note: 'Timestamp of the most recent modification to this BOM record in the source system. Used for incremental data loading, change detection, and audit trail maintenance.']
  lot_size_from decimal(18,3) [note: 'Minimum lot size for which this BOM is valid. BOMs can be lot-size dependent in process manufacturing, where component quantities vary based on batch size. Used in conjunction with lot_size_to to define the valid production quantity range.']
  lot_size_to decimal(18,3) [note: 'Maximum lot size for which this BOM is valid. Defines the upper bound of the production quantity range for lot-size-dependent BOMs. Null indicates no upper limit.']
  lot_size_uom varchar [note: 'Unit of measure for the lot size range (lot_size_from and lot_size_to). Typically matches the base UOM of the finished good (e.g., KG, L, EA).']
  material_number varchar [note: 'SAP material number (MATNR) of the finished good or semi-finished product for which this BOM is defined. This is the externally-known product code used across SAP modules (MM, PP, SD, CO) and in EDI transactions with trading partners.']
  mrp_relevance boolean [note: 'Indicates whether this BOM is used in Material Requirements Planning (MRP) runs for procurement and production scheduling. When true, MRP will explode this BOM to generate dependent requirements for components and raw materials.']
  name varchar [note: 'The product bom name of the product bom record']
  notes varchar [note: 'Free-text notes or comments associated with this BOM header, capturing manufacturing instructions, formulation rationale, regulatory notes, or change justifications that do not fit structured fields. Sourced from SAP BOM header long text.']
  plant_code varchar [note: 'Four-character SAP plant code identifying the manufacturing facility or production site where this BOM is applicable. Used in MRP, production orders, and supply chain planning (SAP IBP).']
  plm_status varchar [note: 'Current lifecycle state of the BOM as managed in the PLM process. \'draft\' indicates initial creation, \'in_review\' is under engineering/regulatory review, \'approved\' is signed off but not yet released to production, \'active\' is in use for manufacturing, \'obsolete\' is retired, \'superseded\' has been replaced by a newer BOM version.']
  product_bom_status varchar [note: 'The product bom status of the product bom record']
  production_version varchar [note: 'SAP production version identifier (MKAL-VERID) that links this BOM to a specific routing/recipe and production line. A material may have multiple production versions representing different manufacturing processes or lines at the same plant.']
  quantity decimal(18,4) [note: 'The quantity of the product bom record']
  reach_compliant boolean [note: 'Indicates whether all chemical substances in this BOM are compliant with EU REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) regulation. Mandatory for products sold in the European Union.']
  regulatory_approval_status varchar [note: 'Status of regulatory approval for this BOM/formulation. Indicates whether the ingredient composition has been reviewed and approved by relevant regulatory bodies (FDA, EU REACH, CPSC). Required before a BOM can be released to active production status.']
  rspo_certified boolean [note: 'Indicates whether palm oil or palm-derived ingredients in this BOM are sourced from RSPO-certified sustainable sources. Relevant for personal care and household products containing palm oil derivatives. Supports sustainability reporting.']
  source_system_bom_code varchar [note: 'The native primary key or document number of this BOM record in the originating source system (e.g., SAP internal BOM header key combining MATNR+WERKS+STLAL+STLAN). Enables traceability back to the system of record.']
  source_system_code varchar [note: 'The source system code of the product bom record']
  uom varchar [note: 'The uom of the product bom record']
  updated_timestamp timestamp [note: 'The updated timestamp of the product bom record']
  version varchar [note: 'Version or revision identifier for the BOM document, enabling traceability of formulation changes over time. Incremented when ingredient quantities, component substitutions, or structural changes are made. Critical for regulatory submissions and GMP compliance.']
  created_by varchar [note: 'User ID or name of the person who created this BOM record in SAP S/4HANA or the PLM system. Part of the mandatory audit trail for GMP and SOX compliance.']

  Note: 'Bill of Materials (BOM) header record defining the complete ingredient and component structure for a finished good or semi-finished SKU. Captures BOM number, BOM type (production, costing, engineering), base quantity, unit of measure, effective date range, PLM status, and the owning plant or production site. Links to BOM line items for individual component details. Sourced from SAP S/4HANA PP/MM modules.'
}

Table product.bom_line {
  bom_line_id varchar [pk, note: 'Unique surrogate identifier for each individual component line within a Bill of Materials. Primary key for this entity. Role: TRANSACTION_LINE.']
  approved_supplier_list_id varchar [note: 'Foreign key linking to procurement.approved_supplier_list. Business justification: MRP and procurement planning systems check the ASL for each BOM component to determine valid sources before generating purchase requisitions. In consumer goods, each BOM line component must have an AS']
  manufacturing_facility_id varchar [note: 'Reference to the manufacturing plant or production facility for which this BOM line is defined. BOM structures can vary by plant due to local sourcing, equipment capabilities, or regulatory requirements.']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: Each BOM line specifies a raw material or packaging component. The material table is the authoritative master for all materials in the CPG portfolio. bom_line currently stores component_description as']
  product_bom_id varchar [note: 'Reference to the parent Bill of Materials header that this line belongs to. Satisfies TRANSACTION_LINE HEADER_REFERENCE category.']
  sku_id varchar [note: 'Reference to the master product/material record for the component (raw material, packaging component, or sub-assembly) required on this BOM line. Satisfies TRANSACTION_LINE RESOURCE_REFERENCE category.']
  specification_id varchar [note: 'Foreign key linking to quality.specification. Business justification: Each BOM line item (ingredient/component) in GMP consumer goods manufacturing references its governing quality specification for incoming inspection and CoA validation. Component-level spec linkage is']
  supplier_id varchar [note: 'Reference to the preferred or approved supplier for this component. Used in procurement planning and source list determination during MRP runs. Supports VMI (Vendor Managed Inventory) and MOQ (Minimum Order Quantity) management.']
  alternative_item_group varchar [note: 'Groups multiple BOM lines that are interchangeable alternatives for the same component requirement. All lines sharing the same group code can substitute for one another, enabling flexible sourcing and production planning.']
  alternative_priority varchar [note: 'Numeric priority rank within an alternative item group, determining the preferred order of substitution when multiple alternatives exist. Lower numbers indicate higher preference (e.g., 1 = first choice).']
  amount decimal(18,4) [note: 'The amount of the bom line record']
  bom_item_category varchar [note: 'SAP BOM item category code that controls how the component is procured and managed. Determines whether the item is stocked, non-stocked, variable-size, or a document/text item. [ENUM-REF-CANDIDATE: stock|non_stock|variable_size|document|text|class — promote to reference product]']
  bom_line_status varchar [note: 'The bom line status of the bom line record']
  bulk_material_flag boolean [note: 'Indicates whether this component is a bulk material that is not individually picked or issued but is consumed from a bulk supply point on the shop floor. Bulk materials are typically excluded from individual goods issue postings.']
  change_number varchar [note: 'The Engineering Change Number (ECN) or Engineering Change Order (ECO) that authorized the creation or modification of this BOM line. Provides traceability to the formal change management process in PLM.']
  co_product_flag boolean [note: 'Indicates whether this BOM line represents a co-product or by-product that is produced alongside the primary output. Co-products have positive quantities and receive a portion of the production cost allocation.']
  code varchar [note: 'The bom line code of the bom line record']
  component_cost_usd decimal(18,4) [note: 'The standard cost per unit of measure for this component in USD, used for COGS (Cost of Goods Sold) calculation and product costing. Sourced from the material master standard price or moving average price.']
  component_item_number varchar [note: 'The externally-known material or item number for the component as defined in the ERP system (e.g., SAP material number). Used for cross-system referencing and procurement planning.']
  component_type varchar [note: 'Classification of the component indicating its role in the manufacturing process. Drives MRP planning logic and COGS categorization. [ENUM-REF-CANDIDATE: raw_material|packaging|semi_finished|finished_good|co_product|by_product — promote to reference product]']
  created_timestamp timestamp [note: 'The timestamp when this BOM line record was first created in the system. Used for audit trail, data lineage, and change management tracking.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the component cost value (e.g., USD, EUR, GBP). Enables multi-currency COGS reporting for global manufacturing operations.']
  description varchar [note: 'The bom line description of the bom line record']
  effective_from date [note: 'The effective from of the bom line record']
  effective_until date [note: 'The effective until of the bom line record']
  fixed_quantity_flag boolean [note: 'Indicates whether the component quantity is fixed regardless of the parent order quantity (True) or scales proportionally with the production order size (False). Fixed quantities are common for setup materials, catalysts, or tooling items.']
  hazardous_material_flag boolean [note: 'Indicates whether this component is classified as a hazardous material under applicable regulations (e.g., OSHA HazCom, EU CLP, DOT). Triggers special handling, storage, and transportation requirements and SDS documentation.']
  inci_name varchar [note: 'The standardized INCI (International Nomenclature of Cosmetic Ingredients) name for this component when used in personal care or cosmetic formulations. Required for regulatory ingredient labeling compliance on finished product packaging.']
  is_alternative_item boolean [note: 'Indicates whether this BOM line represents an alternative or substitute component that can be used in place of the primary component. Alternative items are used when the primary component is unavailable, supporting supply continuity.']
  is_critical_component boolean [note: 'Indicates whether this component is designated as critical to the production of the parent SKU. Critical components trigger priority procurement actions and are subject to enhanced supply chain monitoring and safety stock policies.']
  issue_method varchar [note: 'The method by which this component is issued from inventory to the production order. Backflush automatically posts consumption upon order confirmation; manual requires explicit goods issue; pick list generates a picking document; kanban uses replenishment signals.']
  last_modified_timestamp timestamp [note: 'The timestamp when this BOM line record was most recently updated. Used for change detection, data synchronization, and audit trail purposes in the Silver Layer lakehouse.']
  lead_time_offset_days varchar [note: 'The number of days before or after the parent order start date that this component must be available. Positive values indicate the component is needed before production start; negative values indicate it is needed after. Used in MRP scheduling.']
  line_number varchar [note: 'Sequential position number of this component line within the parent BOM, used for ordering and referencing individual line items. Satisfies TRANSACTION_LINE LINE_SEQUENCE category. Corresponds to SAP BOM item number (POSNR).']
  line_status varchar [note: 'Current lifecycle status of this BOM line item. Controls whether the component is included in active MRP runs and procurement planning. Inactive or obsolete lines are retained for historical traceability.']
  minimum_order_quantity decimal(18,4) [note: 'The minimum quantity of this component that must be ordered from the supplier in a single purchase order. Used in procurement planning to ensure order quantities meet supplier MOQ (Minimum Order Quantity) requirements.']
  name varchar [note: 'The bom line name of the bom line record']
  notes varchar [note: 'The notes of the bom line record']
  operation_number varchar [note: 'Reference to the specific production routing operation or work center step at which this component is consumed. Enables precise material staging and backflushing in the MES and MRP systems.']
  phantom_item_flag boolean [note: 'Indicates whether this BOM line represents a phantom assembly — a logical grouping of components that is not physically stocked or produced as a discrete item but is exploded through in MRP planning.']
  quantity decimal(18,4) [note: 'The quantity of the bom line record']
  reach_registration_number varchar [note: 'The EU REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals) registration number for this chemical component. Required for substances manufactured or imported into the EU above threshold quantities.']
  recursive_bom_flag boolean [note: 'Indicates whether this component itself has a subordinate BOM (i.e., it is a sub-assembly or semi-finished good with its own BOM structure). Used to identify multi-level BOM explosion requirements in MRP planning.']
  required_quantity decimal(18,6) [note: 'The quantity of the component required to produce one unit of the parent SKU at the base quantity defined in the BOM header. Satisfies TRANSACTION_LINE LINE_QUANTITY category. Supports MRP and COGS calculation.']
  scrap_percentage decimal(7,4) [note: 'The expected percentage of this component that will be lost or wasted during the manufacturing process. Used to inflate the planned component quantity in MRP runs and COGS calculations. Expressed as a percentage (e.g., 2.5 = 2.5%).']
  sds_document_number varchar [note: 'The document number or reference identifier for the Safety Data Sheet (SDS) associated with this hazardous component. Links to the SDS stored in Veeva Vault or the document management system for regulatory compliance.']
  source_system_code varchar [note: 'Identifier for the operational system of record from which this BOM line was sourced (e.g., SAP_S4HANA, ORACLE_ERP). Supports data lineage tracking and multi-system reconciliation in the Databricks Silver Layer.']
  storage_location varchar [note: 'The designated warehouse storage location or bin where this component is staged for production consumption. Used by WMS and MES for material staging, goods issue, and FEFO/FIFO inventory management.']
  unit_of_measure varchar [note: 'The unit of measure for the required quantity of the component (e.g., KG, L, EA, M, G). Must align with the component material master UOM. Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT category (measurement dimension).']
  uom varchar [note: 'The uom of the bom line record']
  updated_timestamp timestamp [note: 'The updated timestamp of the bom line record']
  usage_probability_pct decimal(7,4) [note: 'The probability (expressed as a percentage, 0–100) that this alternative component will actually be used in production. Used by MRP to calculate weighted component requirements across alternative item groups.']
  valid_from_date date [note: 'The date from which this BOM line is effective and should be included in production and MRP planning. Supports date-effective BOM management for product reformulations and packaging changes.']
  valid_to_date date [note: 'The date after which this BOM line is no longer effective and should be excluded from production and MRP planning. Null indicates the line is open-ended with no planned expiry.']

  Note: 'Individual component line within a Bill of Materials, specifying each raw material, packaging component, or sub-assembly required to produce the parent SKU. Attributes include component item number, component description, component type (raw material, packaging, semi-finished), required quantity, unit of measure, scrap percentage, lead time offset, and whether the component is a critical or alternative item. Supports MRP, COGS calculation, and procurement planning.'
}

Table product.formulation {
  formulation_id varchar [pk, note: 'Unique surrogate identifier for the formulation master record in the Databricks Silver Layer. Primary key for all downstream joins and lineage tracking.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: R&D cost tracking and project accounting. Formulations are developed in R&D labs; lab costs, stability testing, and regulatory approval expenses are charged to specific R&D cost centers. CPG finance t']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: A product formulation is created for a specific SKU — this is the foundational parent-child relationship. product_formulation currently has no in-domain FK, making it a silo. Adding sku_id normalizes ']
  supplier_id varchar [note: 'Foreign key linking to procurement.supplier. Business justification: Contract/toll manufacturing in consumer goods requires tracking which supplier produces each formulation. Quality audits, regulatory submissions, and COGS calculations depend on knowing the formulatio']
  active_ingredient_name varchar [note: 'The active ingredient name of the product formulation record']
  active_ingredient_pct decimal(6,3) [note: 'The active ingredient pct of the product formulation record']
  allergen_declaration varchar [note: 'The allergen declaration of the product formulation record']
  amount decimal(18,4) [note: 'The amount of the product formulation record']
  approval_date date [note: 'The approval date of the product formulation record']
  bom_reference_code varchar [note: 'The bom reference code of the product formulation record']
  code varchar [note: 'The formulation code of the product formulation record']
  color_description varchar [note: 'The color description of the product formulation record']
  created_timestamp timestamp [note: 'The created timestamp of the product formulation record']
  currency_code varchar [note: 'The currency code of the product formulation record']
  effective_date date [note: 'The effective date of the product formulation record']
  effective_from date [note: 'The effective from of the product formulation record']
  effective_until date [note: 'The effective until of the product formulation record']
  formulation_type varchar [note: 'The formulation type of the product formulation record']
  fragrance_code varchar [note: 'The fragrance code of the product formulation record']
  gmp_compliance_flag boolean [note: 'The gmp compliance flag of the product formulation record']
  inci_declaration varchar [note: 'The inci declaration of the product formulation record']
  intended_use varchar [note: 'The intended use of the product formulation record']
  is_cruelty_free boolean [note: 'The is cruelty free of the product formulation record']
  is_fragrance_free boolean [note: 'The is fragrance free of the product formulation record']
  is_vegan boolean [note: 'The is vegan of the product formulation record']
  lab_notebook_reference varchar [note: 'The lab notebook reference of the product formulation record']
  last_modified_timestamp timestamp [note: 'The last modified timestamp of the product formulation record']
  lifecycle_stage varchar [note: 'The lifecycle stage of the product formulation record']
  name varchar [note: 'The formulation name of the product formulation record']
  notes varchar [note: 'The notes of the product formulation record']
  obsolescence_date date [note: 'The obsolescence date of the product formulation record']
  ph_max decimal(5,2) [note: 'The ph max of the product formulation record']
  ph_min decimal(5,2) [note: 'The ph min of the product formulation record']
  preservative_system varchar [note: 'The preservative system of the product formulation record']
  product_category varchar [note: 'The product category of the product formulation record']
  product_formulation_code varchar [note: 'The product formulation code of the product formulation record']
  product_formulation_description varchar [note: 'The product formulation description of the product formulation record']
  product_formulation_name varchar [note: 'The product formulation name of the product formulation record']
  product_formulation_status varchar [note: 'The product formulation status of the product formulation record']
  quantity decimal(18,4) [note: 'The quantity of the product formulation record']
  rd_project_code varchar [note: 'The rd project code of the product formulation record']
  reach_registration_number varchar [note: 'The reach registration number of the product formulation record']
  regulatory_approval_status varchar [note: 'The regulatory approval status of the product formulation record']
  regulatory_classification varchar [note: 'The regulatory classification of the product formulation record']
  rspo_certified boolean [note: 'The rspo certified of the product formulation record']
  source_system_code varchar [note: 'The source system code of the product formulation record']
  stability_period_months varchar [note: 'The stability period months of the product formulation record']
  storage_condition varchar [note: 'The storage condition of the product formulation record']
  total_solid_content_pct decimal(6,3) [note: 'The total solid content pct of the product formulation record']
  uom varchar [note: 'The uom of the product formulation record']
  updated_timestamp timestamp [note: 'The updated timestamp of the product formulation record']
  version_number varchar [note: 'The version number of the product formulation record']
  viscosity_max_cps decimal(10,2) [note: 'The viscosity max cps of the product formulation record']
  viscosity_min_cps decimal(10,2) [note: 'The viscosity min cps of the product formulation record']

  Note: 'Formulation master record capturing the approved chemical or ingredient recipe for a consumer goods product (household, personal care, health, or hygiene). Stores formulation code, version number, formulation name, product category, regulatory approval status, pH range, viscosity, color, fragrance code, preservative system, and the R&D project reference. Tracks the full formulation lifecycle from lab development through commercial approval. Sourced from Veeva Vault PLM. [SSOT: authoritative table is research.research_formulation; this table is a deprecated duplicate.] [Non-authoritative; defers to SSOT research.research_formulation for concept \'formulation\'.]'
}

Table product.packaging_spec {
  packaging_spec_id varchar [pk, note: 'Unique surrogate identifier for each packaging specification record. One record represents one packaging level for one SKU. MASTER_RESOURCE role — primary key.']
  approved_manufacturing_facility_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_facility. Business justification: Packaging component specs require GMP site qualification per manufacturing facility — a spec approved at one plant may not be valid at another. Regulatory audits (FDA, EU GMP) require traceability of ']
  approved_supplier_list_id varchar [note: 'Foreign key linking to procurement.approved_supplier_list. Business justification: Packaging component qualification requires ASL approval beyond just knowing the supplier identity. Quality teams need ASL status (qualification level, audit score, expiry) for packaging supplier audit']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: A packaging specification is defined for a specific primary packaging material (e.g., HDPE bottle, aluminum can, paperboard carton). The material table is the master reference for all packaging materi']
  sku_id varchar [note: 'Reference to the parent SKU for which this packaging specification is defined. Links the packaging record to the product master.']
  supplier_contract_id varchar [note: 'Foreign key linking to procurement.supplier_contract. Business justification: Packaging procurement in consumer goods is governed by specific supplier contracts defining tooling ownership, pricing, and quality standards. Packaging teams need to reference the active contract for']
  supplier_id varchar [note: 'Reference to the approved supplier responsible for manufacturing or supplying this packaging component. Links to the supplier master for procurement, quality, and compliance management.']
  trade_account_id varchar [note: 'Foreign key linking to sales.trade_account. Business justification: Customer-specific packaging specifications (retailer-exclusive pack sizes, private label packaging, club-store formats) are standard in consumer goods. Linking product_packaging_spec to trade_account ']
  amount decimal(18,4) [note: 'The amount of the product packaging spec record']
  approval_status varchar [note: 'The approval status of the product packaging spec record']
  artwork_ref varchar [note: 'The artwork ref of the product packaging spec record']
  color varchar [note: 'The color of the product packaging spec record']
  component_type varchar [note: 'The component type of the product packaging spec record']
  country_of_origin varchar [note: 'The country of origin of the product packaging spec record']
  created_timestamp timestamp [note: 'The created timestamp of the product packaging spec record']
  currency_code varchar [note: 'The currency code of the product packaging spec record']
  ean varchar [note: 'The ean of the product packaging spec record']
  effective_date date [note: 'The effective date of the product packaging spec record']
  effective_from date [note: 'The effective from of the product packaging spec record']
  effective_until date [note: 'The effective until of the product packaging spec record']
  expiry_date date [note: 'The expiry date of the product packaging spec record']
  finish varchar [note: 'The finish of the product packaging spec record']
  gross_weight_g decimal(12,3) [note: 'The gross weight g of the product packaging spec record']
  gtin varchar [note: 'The gtin of the product packaging spec record']
  hazmat_flag boolean [note: 'The hazmat flag of the product packaging spec record']
  height_mm decimal(10,3) [note: 'The height mm of the product packaging spec record']
  hi varchar [note: 'The hi of the product packaging spec record']
  is_fsc_certified boolean [note: 'The is fsc certified of the product packaging spec record']
  is_rspo_certified boolean [note: 'The is rspo certified of the product packaging spec record']
  last_modified_timestamp timestamp [note: 'The last modified timestamp of the product packaging spec record']
  lead_time_days varchar [note: 'The lead time days of the product packaging spec record']
  length_mm decimal(10,3) [note: 'The length mm of the product packaging spec record']
  lifecycle_status varchar [note: 'The lifecycle status of the product packaging spec record']
  material_composition varchar [note: 'The material composition of the product packaging spec record']
  moq varchar [note: 'The moq of the product packaging spec record']
  notes varchar [note: 'The notes of the product packaging spec record']
  packaging_level varchar [note: 'The packaging level of the product packaging spec record']
  pcr_content_pct decimal(5,2) [note: 'The pcr content pct of the product packaging spec record']
  print_method varchar [note: 'The print method of the product packaging spec record']
  product_packaging_spec_code varchar [note: 'The product packaging spec code of the product packaging spec record']
  product_packaging_spec_description varchar [note: 'The product packaging spec description of the product packaging spec record']
  product_packaging_spec_name varchar [note: 'The product packaging spec name of the product packaging spec record']
  product_packaging_spec_status varchar [note: 'The product packaging spec status of the product packaging spec record']
  qty_per_parent varchar [note: 'The qty per parent of the product packaging spec record']
  quantity decimal(18,4) [note: 'The quantity of the product packaging spec record']
  recyclability_code varchar [note: 'The recyclability code of the product packaging spec record']
  regulatory_compliance_flag boolean [note: 'The regulatory compliance flag of the product packaging spec record']
  source_system_code varchar [note: 'The source system code of the product packaging spec record']
  spec_code varchar [note: 'The spec code of the product packaging spec record']
  spec_name varchar [note: 'The spec name of the product packaging spec record']
  supplier_tooling_ref varchar [note: 'The supplier tooling ref of the product packaging spec record']
  tare_weight_g decimal(12,3) [note: 'The tare weight g of the product packaging spec record']
  ti varchar [note: 'The ti of the product packaging spec record']
  unit_cost decimal(18,6) [note: 'The unit cost of the product packaging spec record']
  uom varchar [note: 'The uom of the product packaging spec record']
  upc varchar [note: 'The upc of the product packaging spec record']
  updated_timestamp timestamp [note: 'The updated timestamp of the product packaging spec record']
  version_number varchar [note: 'The version number of the product packaging spec record']
  width_mm decimal(10,3) [note: 'The width mm of the product packaging spec record']

  Note: 'Packaging specification master defining the complete physical, material, structural, and hierarchy attributes of all packaging levels for each SKU — primary (bottle, tube, sachet, pouch), secondary (carton, sleeve, shrink-wrap), tertiary (case, shipper), display unit, and pallet. Each record represents one packaging level for one SKU and captures: component type, material composition (HDPE, PET, glass, paperboard, aluminum, PCR content %), dimensions (L×W×H), gross/tare weight, color, finish, print method, recyclability code (How2Recycle label), FSC/RSPO certification flag, supplier tooling reference, quantity per hierarchy level (e.g., 12 eaches per case, 48 cases per pallet), Ti-Hi pallet configuration, and GTIN assigned at that level. Supports sustainability reporting (EPR, plastic tax), planogram compliance, DRP/MRP calculations, warehouse slotting, transportation cube optimization, and retailer EDI order processing. [SSOT: authoritative table is research.research_packaging_spec; this table is a deprecated duplicate.] [Non-authoritative; defers to SSOT research.research_packaging_spec for concept \'packaging_spec\'.]'
}

Table product.label_spec {
  label_spec_id varchar [pk, note: 'Unique surrogate identifier for each label specification record. Primary key for the label_spec data product in the product domain.']
  formulation_id varchar [note: 'Foreign key linking to product.product_formulation. Business justification: A regulatory label specification is derived from the approved product formulation — the ingredient_declaration_text, INCI names, allergen declarations, and regulatory statements on the label must alig']
  label_supplier_id varchar [note: 'Foreign key linking to procurement.supplier. Business justification: Label printing is a distinct procurement category in consumer goods managed by packaging procurement teams. Each label spec must reference the approved print supplier for sourcing, quality control, an']
  packaging_spec_id varchar [note: 'Foreign key linking to product.product_packaging_spec. Business justification: A label specification is physically applied to a specific packaging component — the label dimensions, substrate material, print process, and barcode placement are all defined in relation to the packag']
  sku_id varchar [note: 'Reference to the SKU (Stock Keeping Unit) for which this label specification applies. Links the label spec to the product master.']
  specification_id varchar [note: 'Foreign key linking to quality.specification. Business justification: Label approval process in consumer goods requires QA sign-off against the governing quality specification for regulatory compliance (allergen declarations, mandatory warnings). This FK enables label c']
  trade_account_id varchar [note: 'Foreign key linking to sales.trade_account. Business justification: Retailer-specific label requirements (private label, export compliance labels, retailer-mandated warning statements) are a standard consumer goods operational need. Linking label_spec to trade_account']
  allergen_declaration varchar [note: 'Allergen declaration text as printed on the label (e.g., \'Contains: Milk, Soy\', \'May contain traces of nuts\'). Mandatory for food and personal care products under FDA FALCPA and EU Regulation 1169/2011.']
  amount decimal(18,4) [note: 'The amount of the label spec record']
  approval_status varchar [note: 'Current workflow status of the label specification in the regulatory and artwork approval process. Drives gating of production print runs and market release.']
  artwork_file_reference varchar [note: 'Document management system reference or file path to the approved artwork file for this label specification (e.g., Veeva Vault document ID or DAM asset reference). Links label spec to the physical artwork asset.']
  barcode_placement varchar [note: 'Specification of the physical placement zone for the barcode on the label or packaging (e.g., \'bottom-right back panel\', \'base of container\'). Ensures retail scanner readability and planogram compliance.']
  barcode_type varchar [note: 'Type of barcode symbology specified for placement on the label (e.g., UPC-A, EAN-13, ITF-14, GS1-128, QR Code, DataMatrix). Governs scanner compatibility at retail POS and logistics. [ENUM-REF-CANDIDATE: UPC-A|EAN-13|EAN-8|ITF-14|GS1-128|QR_Code|DataMatrix — 7 candidates stripped; promote to reference product]']
  certification_marks varchar [note: 'Third-party certification marks and logos authorized for display on this label (e.g., \'USDA Organic\', \'NSF Certified\', \'Leaping Bunny\', \'RSPO\', \'FSC\', \'CE Mark\'). Subject to certification body licensing requirements.']
  claim_text varchar [note: 'Marketing and regulatory claims printed on the label (e.g., \'Dermatologist Tested\', \'Cruelty-Free\', \'Hypoallergenic\', \'Organic\', \'Clinically Proven\'). Subject to FTC advertising substantiation requirements.']
  code varchar [note: 'The label spec code of the label spec record']
  color_profile varchar [note: 'Color management profile and ink specification for the label (e.g., \'CMYK + 2 Pantone\', \'Pantone 485C + Black\'). Ensures brand color consistency across print runs and suppliers.']
  country_of_origin varchar [note: 'ISO 3166-1 alpha-3 country code for the country of manufacture as declared on the label. Mandatory for customs, trade compliance, and consumer disclosure in most markets.']
  created_timestamp timestamp [note: 'Timestamp when this label specification record was first created in the system. Supports audit trail, data lineage, and regulatory record-keeping requirements.']
  currency_code varchar [note: 'The currency code of the label spec record']
  description varchar [note: 'The label spec description of the label spec record']
  digital_watermark_enabled boolean [note: 'Indicates whether a digital watermark (e.g., GS1 Digital Link, Digimarc) is embedded in the label artwork to support connected packaging, consumer engagement, and supply chain traceability.']
  distributor_name varchar [note: 'Legal name of the distributor or importer as printed on the label, where different from the manufacturer. Required in markets where the responsible party is the local distributor.']
  effective_date date [note: 'Date from which this label specification version is valid and authorized for use in production and distribution. Supports regulatory compliance date tracking.']
  effective_from date [note: 'The effective from of the label spec record']
  effective_until date [note: 'The effective until of the label spec record']
  expiry_date date [note: 'Date after which this label specification version is no longer valid and must be superseded. Nullable for open-ended specifications. Supports artwork lifecycle management.']
  gtin varchar [note: '14-digit Global Trade Item Number (GTIN) as encoded in the barcode on this label. Uniquely identifies the trade item at the specified packaging level per GS1 standards.']
  ingredient_declaration_text varchar [note: 'Full ingredient declaration text as it appears on the label, including INCI (International Nomenclature of Cosmetic Ingredients) names for cosmetics or common/scientific names for food and household products. Mandatory for regulatory compliance.']
  is_primary_label boolean [note: 'Indicates whether this label specification is the primary (master) label for the SKU-market-language combination, as opposed to a supplementary or promotional label variant.']
  label_approval_date date [note: 'Date on which the label specification received final regulatory and quality approval, authorizing use in production. Key milestone in the PLM artwork approval workflow.']
  label_dimensions varchar [note: 'Physical dimensions of the label (width x height in mm, e.g., \'120x80mm\'). Required for print production specifications and packaging line setup.']
  label_spec_status varchar [note: 'The label spec status of the label spec record']
  label_type varchar [note: 'Categorizes the physical placement and function of the label on the product packaging (e.g., front_of_pack, back_of_pack, inner_label, neck_label, hang_tag, insert). Drives artwork management and regulatory review workflows.']
  label_version varchar [note: 'Version number of the label specification (e.g., 1.0, 2.1, 3.0). Used to track label revisions and manage artwork lifecycle in PLM and Veeva Vault.']
  language_code varchar [note: 'ISO 639-1 language code (optionally with ISO 3166-1 region subtag) for the label text (e.g., en, fr, de, es, zh-CN). Supports multilingual labeling requirements.']
  last_modified_timestamp timestamp [note: 'Timestamp when this label specification record was most recently updated. Supports change tracking, audit trail, and downstream data synchronization.']
  lot_code_format varchar [note: 'Format specification for the lot/batch code printed on the label (e.g., \'YYYYMMDD-XXXX\', \'Julian date + shift code\'). Enables product traceability and recall management.']
  mandatory_regulatory_statements varchar [note: 'Concatenated text of all mandatory regulatory statements required by the applicable regulatory framework (e.g., FDA required statements, EU mandatory disclosures, CPSC safety notices). Stored as structured text for label artwork population.']
  manufacturer_address varchar [note: 'Full address of the manufacturer or responsible party as printed on the label. Mandatory for consumer contact and regulatory traceability in most jurisdictions.']
  manufacturer_name varchar [note: 'Legal name of the manufacturer or responsible party as printed on the label. Required by FDA, EU, and most national regulatory frameworks for product traceability.']
  market_country_code varchar [note: 'ISO 3166-1 alpha-3 country code identifying the market or country for which this label specification is valid (e.g., USA, GBR, DEU, FRA). Supports multi-market regulatory compliance.']
  name varchar [note: 'The label spec name of the label spec record']
  net_content_declaration varchar [note: 'Net content statement as printed on the label, including quantity and unit of measure (e.g., \'500 mL\', \'16 fl oz (473 mL)\', \'250 g\'). Mandatory per weights and measures regulations.']
  notes varchar [note: 'The notes of the label spec record']
  nutrition_facts_required boolean [note: 'Indicates whether a Nutrition Facts panel or equivalent nutritional information table is required on this label per applicable regulatory framework. Applies to food, beverage, and dietary supplement categories.']
  plm_change_order_number varchar [note: 'Change order or engineering change notice (ECN) number from the PLM system that authorized this label specification version. Provides traceability to the formal change management process.']
  print_process varchar [note: 'Printing technology specified for producing this label (e.g., flexographic, digital, offset, gravure, screen). Determines supplier qualification and color reproduction requirements.']
  quantity decimal(18,4) [note: 'The quantity of the label spec record']
  recycling_symbol_code varchar [note: 'Recycling and environmental symbol codes required on the label (e.g., Mobius loop resin identification code, Green Dot, Tidyman, FSC logo). Supports sustainability compliance and consumer communication.']
  regulatory_framework varchar [note: 'Primary regulatory framework governing this label specification (e.g., FDA 21 CFR, EU Regulation 1169/2011, CPSC 16 CFR, Health Canada). Determines mandatory statement requirements. [ENUM-REF-CANDIDATE: FDA_21_CFR|EU_1169_2011|CPSC_16_CFR|Health_Canada|ANVISA|TGA|SFDA — promote to reference product]']
  regulatory_registration_number varchar [note: 'Product registration or notification number assigned by the regulatory authority for the target market (e.g., FDA Facility Registration, EU Cosmetic Product Notification Portal reference, CPNP number). Required on label in certain markets.']
  shelf_life_statement varchar [note: 'Shelf life or best-before/expiry date format statement as printed on the label (e.g., \'Best Before: see base\', \'Use By: MM/YYYY\', \'PAO 12M\'). Supports FEFO inventory management and consumer safety.']
  source_system_code varchar [note: 'The source system code of the label spec record']
  substrate_material varchar [note: 'Material specification for the label substrate (e.g., \'White BOPP\', \'Kraft Paper\', \'Clear PET\', \'Foil\'). Drives procurement of label stock and sustainability reporting.']
  uom varchar [note: 'The uom of the label spec record']
  updated_timestamp timestamp [note: 'The updated timestamp of the label spec record']
  usage_instructions varchar [note: 'Directions for use as printed on the label (e.g., application method, dosage, frequency, preparation instructions). Required for regulated product categories and consumer safety.']
  veeva_document_reference varchar [note: 'Document identifier in Veeva Vault for the controlled label specification document. Provides direct traceability to the system of record for regulatory submissions and quality documents.']
  warning_statements varchar [note: 'All warning and precautionary statements required on the label (e.g., \'Keep out of reach of children\', \'Flammable\', allergen warnings, GHS hazard statements). Mandatory for consumer safety compliance.']

  Note: 'Regulatory labeling specification for each SKU and market/country combination. Captures label version, language, market/country code, label type (front-of-pack, back-of-pack, inner label), mandatory regulatory statements (FDA, EU, CPSC), ingredient declaration text, net content declaration, warning statements, usage instructions, claim text (e.g., \'dermatologist tested\', \'cruelty-free\'), barcode placement, and label approval status. Supports multi-market regulatory compliance and artwork management.'
}

Table product.product_brand {
  product_brand_id varchar [pk, note: 'Unique surrogate identifier for each brand master record in the Consumer Goods portfolio. Primary key for the product_brand dimension, referenced by all downstream domains including marketing, trade promotion, and financial reporting.']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: Brand legal entity ownership for trademark amortization, royalty accounting, and intercompany licensing. In multi-entity CPG companies, brands are owned by specific legal entities. The plain \'owner_en']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Brand-level spend tracking and marketing budget allocation. In CPG, each product brand is assigned a cost center for brand overhead, A&P spend, and brand profitability reporting. Finance controllers e']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Brand-level P&L reporting. CPG companies run profit center accounting at the brand level — brand revenue, COGS, and gross margin are tracked per profit center. Standard SAP CO-PA setup; brand managers']
  amount decimal(18,4) [note: 'The amount of the product brand record']
  architecture_type varchar [note: 'The architecture type of the product brand record']
  brand_name varchar [note: 'The brand name of the product brand record']
  brand_status varchar [note: 'The brand status of the product brand record']
  brand_tier varchar [note: 'The brand tier of the product brand record']
  code varchar [note: 'The product brand code of the product brand record']
  created_timestamp timestamp [note: 'The created timestamp of the product brand record']
  currency_code varchar [note: 'The currency code of the product brand record']
  description varchar [note: 'The product brand description of the product brand record']
  distribution_channel varchar [note: 'The distribution channel of the product brand record']
  divestiture_date date [note: 'The divestiture date of the product brand record']
  ean_prefix varchar [note: 'The ean prefix of the product brand record']
  effective_from date [note: 'The effective from of the product brand record']
  effective_until date [note: 'The effective until of the product brand record']
  equity_methodology varchar [note: 'The equity methodology of the product brand record']
  geographic_scope varchar [note: 'The geographic scope of the product brand record']
  gmp_certification_ref varchar [note: 'The gmp certification ref of the product brand record']
  is_licensed_brand boolean [note: 'The is licensed brand of the product brand record']
  last_updated_timestamp timestamp [note: 'The last updated timestamp of the product brand record']
  launch_date date [note: 'The launch date of the product brand record']
  launch_year varchar [note: 'The launch year of the product brand record']
  license_expiry_date date [note: 'The license expiry date of the product brand record']
  msrp_currency_code varchar [note: 'The msrp currency code of the product brand record']
  name varchar [note: 'The product brand name of the product brand record']
  notes varchar [note: 'The notes of the product brand record']
  nps_tracking_enabled boolean [note: 'The nps tracking enabled of the product brand record']
  owner_division varchar [note: 'The owner division of the product brand record']
  parent_brand_code varchar [note: 'The parent brand code of the product brand record']
  plm_stage varchar [note: 'The plm stage of the product brand record']
  positioning_statement varchar [note: 'The positioning statement of the product brand record']
  primary_country_code varchar [note: 'The primary country code of the product brand record']
  product_brand_status varchar [note: 'The product brand status of the product brand record']
  quantity decimal(18,4) [note: 'The quantity of the product brand record']
  regulatory_classification varchar [note: 'The regulatory classification of the product brand record']
  short_name varchar [note: 'The short name of the product brand record']
  social_media_handle varchar [note: 'The social media handle of the product brand record']
  source_system_brand_code varchar [note: 'The source system brand code of the product brand record']
  source_system_code varchar [note: 'The source system code of the product brand record']
  sustainability_certification varchar [note: 'The sustainability certification of the product brand record']
  trade_promotion_eligible boolean [note: 'The trade promotion eligible of the product brand record']
  trademark_jurisdiction varchar [note: 'The trademark jurisdiction of the product brand record']
  trademark_registration_ref varchar [note: 'The trademark registration ref of the product brand record']
  uom varchar [note: 'The uom of the product brand record']
  updated_timestamp timestamp [note: 'The updated timestamp of the product brand record']
  website_url varchar [note: 'The website url of the product brand record']

  Note: 'Brand master record defining each consumer goods brand in the portfolio. Captures brand code, brand name, brand tier (premium, mass, value), parent brand (for sub-brands), brand owner entity, brand launch year, brand positioning statement, target consumer segment, primary category, brand trademark registration reference, brand status (active, dormant, divested), and the brand equity tracking methodology. Serves as the authoritative brand dimension for marketing, trade promotion, and financial reporting. [SSOT] Superseded by authoritative table marketing.marketing_brand for concept \'brand\'. SSOT: canonical table is marketing.marketing_brand. [SSOT for concept \'brand\'.]'
}

Table product.registration {
  registration_id varchar [pk, note: 'Primary key for the registration association']
  address_id varchar [note: 'Foreign key linking to consumer.address. Business justification: Product registration captures a consumer\'s address for warranty service dispatch, product recall notifications, and regulatory compliance (CPSC recall traceability). Linking to consumer.address enable']
  batch_release_id varchar [note: 'Foreign key linking to quality.batch_release. Business justification: Product recall management requires tracing registered consumer products to their batch release record to identify affected consumers for targeted recall notifications. Regulatory recall processes (FDA']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: CPG product registrations are attributed to acquisition campaigns (e.g., \'registered via summer loyalty campaign\') for campaign ROI measurement and CRM attribution reporting. registration_source and r']
  loyalty_account_id varchar [note: 'Foreign key linking to consumer.loyalty_account. Business justification: Product registration is a primary loyalty enrollment touchpoint in consumer goods (e.g., Dyson, Philips). Linking registration to loyalty_account enables warranty-loyalty integration, post-purchase lo']
  registration_product_registered_shopper_id varchar [note: 'add column registered_shopper_id (BIGINT) with FK to consumer.shopper.shopper_id - product registration is a consumer warranty/registration record']
  registration_product_shopper_id varchar [note: 'Foreign key linking to the shopper who registers the SKU']
  retail_store_id varchar [note: 'Foreign key linking to sales.retail_store. Business justification: Warranty/product registration analytics by retail store: consumer goods brands track registrations by point-of-sale store for recall targeting, warranty claim validation, and retail performance report']
  sku_id varchar [note: 'Foreign key linking to the SKU being registered']
  amount decimal(18,4) [note: 'The amount of the product registration record']
  channel varchar [note: 'The registration channel of the product registration record']
  consent_marketing_flag boolean [note: 'The consent marketing flag of the product registration record']
  consent_to_marketing boolean [note: 'The consent to marketing of the product registration record']
  created_timestamp timestamp [note: 'The created timestamp of the product registration record']
  currency_code varchar [note: 'The currency code of the product registration record']
  effective_from date [note: 'The effective from of the product registration record']
  effective_until date [note: 'The effective until of the product registration record']
  extended_warranty_flag boolean [note: 'The extended warranty flag of the product registration record']
  extended_warranty_purchased boolean [note: 'The extended warranty purchased of the product registration record']
  gift_flag boolean [note: 'The gift flag of the product registration record']
  last_updated_timestamp timestamp [note: 'The last updated timestamp of the product registration record']
  lot_number varchar [note: 'The lot number of the product registration record']
  marketing_consent_flag boolean [note: 'The marketing consent flag of the product registration record']
  marketing_opt_in boolean [note: 'The marketing opt in of the product registration record']
  marketing_opt_in_flag boolean [note: 'The marketing opt in flag of the product registration record']
  notes varchar [note: 'The notes of the product registration record']
  opt_in_marketing_flag boolean [note: 'The opt in marketing flag of the product registration record']
  product_condition varchar [note: 'The product condition of the product registration record']
  product_registration_code varchar [note: 'The product registration code of the product registration record']
  product_registration_description varchar [note: 'The product registration description of the product registration record']
  product_registration_name varchar [note: 'The product registration name of the product registration record']
  product_registration_status varchar [note: 'The product registration status of the product registration record']
  proof_of_purchase_ref varchar [note: 'The proof of purchase ref of the product registration record']
  proof_of_purchase_reference varchar [note: 'The proof of purchase reference of the product registration record']
  purchase_channel varchar [note: 'The purchase channel of the product registration record']
  purchase_date date [note: 'The purchase date of the product registration record']
  purchase_price decimal(18,4) [note: 'The purchase price of the product registration record']
  quantity decimal(18,4) [note: 'The quantity of the product registration record']
  recall_notification_opt_in boolean [note: 'The recall notification opt in of the product registration record']
  reference varchar [note: 'The registration reference of the product registration record']
  registered_email varchar [note: 'The registered email of the product registration record']
  registration_date date [note: 'The registration date of the product registration record']
  registration_number varchar [note: 'The registration number of the product registration record']
  registration_status varchar [note: 'The registration status of the product registration record']
  retailer_name varchar [note: 'The retailer name of the product registration record']
  serial_number varchar [note: 'The serial number of the product registration record']
  source varchar [note: 'The registration source of the product registration record']
  source_system_code varchar [note: 'The source system code of the product registration record']
  uom varchar [note: 'The uom of the product registration record']
  updated_timestamp timestamp [note: 'The updated timestamp of the product registration record']
  verification_status varchar [note: 'The verification status of the product registration record']
  verified_flag boolean [note: 'The verified flag of the product registration record']
  warranty_duration_months varchar [note: 'The warranty duration months of the product registration record']
  warranty_end_date date [note: 'The warranty end date of the product registration record']
  warranty_expiry_date date [note: 'The warranty expiry date of the product registration record']
  warranty_period_months varchar [note: 'The warranty period months of the product registration record']
  warranty_start_date date [note: 'The warranty start date of the product registration record']
  warranty_status varchar [note: 'The warranty status of the product registration record']
  warranty_term_months varchar [note: 'The warranty term months of the product registration record']
  warranty_type varchar [note: 'The warranty type of the product registration record']

  Note: 'Represents the warranty/recall registration linking a SKU to a shopper. Each record captures when and how a shopper registered a product and the current warranty status.. Existence Justification: Consumers actively register each purchased SKU for warranty and recall purposes. A single SKU can be registered by many shoppers, and a shopper can register many different SKUs. The registration itself carries attributes such as registration date, source, and warranty status, making it an operational M:N relationship. [SSOT: authoritative table is regulatory.regulatory_registration; this table is a deprecated duplicate.] [SSOT: authoritative table is regulatory.regulatory_registration; this is a deprecated duplicate for concept \'registration\'.] [Non-authoritative; defers to SSOT regulatory.regulatory_registration for concept \'registration\'.]'
}

Table product.category {
  category_id varchar [pk, note: 'Primary key for category']
  hierarchy_id varchar [note: 'The hierarchy id of the category record']
  parent_category_id varchar [note: 'Identifier of the immediate parent category in the hierarchy (null for top‑level).']
  parent_product_category_id varchar [note: 'Self-referencing FK on product_category (parent_product_category_id)']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Category-level P&L management. CPG category managers report revenue, trade spend, and margin by product category mapped to profit centers. Standard in SAP CO-PA for category management reporting, trad']
  amount decimal(18,4) [note: 'The amount of the category record']
  business_unit varchar [note: 'Business unit responsible for the category (e.g., global, regional, local).']
  category_status varchar [note: 'Current lifecycle status of the category.']
  category_type varchar [note: 'The category type of the category record']
  classification varchar [note: 'High‑level business classification of the category for reporting and analytics.']
  classification_type varchar [note: 'Business classification indicating the nature of the category.']
  code varchar [note: 'Standardized alphanumeric code identifying the category (e.g., GS1 segment).']
  created_timestamp timestamp [note: 'Timestamp when the category record was first created in the system.']
  currency_code varchar [note: 'The currency code of the category record']
  description varchar [note: 'Detailed textual description of the category, its purpose and typical product types.']
  display_order varchar [note: 'Ordinal value used to order categories in UI listings.']
  effective_from date [note: 'Date when the category becomes active for product assignment.']
  effective_until date [note: 'Date when the category is retired or no longer usable (null if open‑ended).']
  gpc_brick_code varchar [note: 'The gpc brick code of the category record']
  hierarchy_level varchar [note: 'Numeric depth of the category within the hierarchy (1 = top level).']
  hierarchy_path varchar [note: 'Slash‑delimited path of ancestor category IDs (e.g., "/1/5/9").']
  image_url varchar [note: 'Link to the representative image for the category.']
  is_active boolean [note: 'The is active of the category record']
  is_leaf boolean [note: 'Flag indicating whether the category has no child categories.']
  is_leaf_node boolean [note: 'The is leaf node of the category record']
  level varchar [note: 'The category level of the category record']
  marketing_tag varchar [note: 'Marketing label applied to the category for promotional purposes.']
  merchandising_segment varchar [note: 'The merchandising segment of the category record']
  name varchar [note: 'Human‑readable name of the product category.']
  nielsen_category_code varchar [note: 'The nielsen category code of the category record']
  notes varchar [note: 'The notes of the category record']
  path varchar [note: 'The category path of the category record']
  product_category_code varchar [note: 'The product category code of the category record']
  product_category_description varchar [note: 'The product category description of the category record']
  product_category_name varchar [note: 'The product category name of the category record']
  product_category_status varchar [note: 'Current lifecycle status of the category (e.g., active for use, deprecated for retirement).']
  quantity decimal(18,4) [note: 'The quantity of the category record']
  sort_order varchar [note: 'The sort order of the category record']
  source_system_code varchar [note: 'The source system code of the category record']
  uom varchar [note: 'The uom of the category record']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the category record.']

  Note: 'Master reference table for category. Referenced by category_id.'
}

Table product.material {
  material_id varchar [pk, note: 'Primary key for material']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Material valuation and inventory accounting. In CPG/SAP MM-FI integration, each material (raw material, packaging) is assigned a GL account via valuation class for inventory posting, COGS recognition,']
  manufacturing_facility_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_facility. Business justification: Plant-specific material master is a core ERP concept (SAP MM): raw/packaging materials are qualified per manufacturing facility for GMP compliance, MRP planning, and procurement. A manufacturing domai']
  parent_material_id varchar [note: 'Self-referencing FK on material (parent_material_id)']
  supplier_id varchar [note: 'Identifier of the primary supplier for the material.']
  allergen_info varchar [note: 'Allergen declarations associated with the material, if applicable.']
  amount decimal(18,4) [note: 'The amount of the material record']
  base_uom varchar [note: 'Standard unit of measure used for inventory and transactions.']
  brand_name varchar [note: 'Brand under which the material is marketed.']
  cas_number varchar [note: 'The cas number of the material record']
  code varchar [note: 'Internal stock‑keeping unit or catalogue code that uniquely identifies the material within the enterprise.']
  country_of_origin varchar [note: 'Three‑letter ISO code of the country where the material is produced.']
  created_timestamp timestamp [note: 'Date and time when the material record was first created in the system.']
  currency_code varchar [note: 'Three‑letter ISO currency code for the standard cost.']
  description varchar [note: 'Free‑form textual description of the material, including usage notes.']
  ean varchar [note: '13‑digit European article number for the material.']
  effective_from date [note: 'Date when the material becomes effective for business use.']
  effective_until date [note: 'Date when the material is retired or no longer valid (null if open‑ended).']
  group varchar [note: 'Higher‑level grouping used for reporting and analytics.']
  gtin varchar [note: '14‑digit global identifier assigned to the material for trade and retail purposes.']
  hazard_classification varchar [note: 'The hazard classification of the material record']
  hazardous_flag boolean [note: 'Indicates whether the material is classified as hazardous under safety regulations.']
  inci_name varchar [note: 'The inci name of the material record']
  is_hazardous boolean [note: 'The is hazardous of the material record']
  last_updated_timestamp timestamp [note: 'Date and time of the most recent update to the material record.']
  lead_time_days varchar [note: 'The lead time days of the material record']
  lifecycle_stage varchar [note: 'Current stage of the material within its product lifecycle.']
  material_status varchar [note: 'Current lifecycle state of the material.']
  material_type varchar [note: 'Category describing the nature of the material within the product hierarchy.']
  name varchar [note: 'Human‑readable name of the material used in catalogs and reports.']
  notes varchar [note: 'The notes of the material record']
  number varchar [note: 'The number of the material record']
  packaging_type varchar [note: 'Primary packaging format for the material.']
  procurement_type varchar [note: 'The procurement type of the material record']
  quantity decimal(18,4) [note: 'The quantity of the material record']
  regulatory_status varchar [note: 'Current compliance status of the material with relevant regulations.']
  shelf_life_days varchar [note: 'Maximum number of days the material can be stored before expiration.']
  source_system_code varchar [note: 'The source system code of the material record']
  standard_cost decimal(12,4) [note: 'Default cost price of the material used for costing and pricing calculations.']
  storage_conditions varchar [note: 'The storage conditions of the material record']
  storage_temperature_c decimal(5,2) [note: 'Optimal storage temperature for the material in degrees Celsius.']
  unit_conversion_factor decimal(12,6) [note: 'Factor to convert from the material\'s base UOM to alternative units.']
  uom varchar [note: 'The uom of the material record']
  upc varchar [note: '12‑digit UPC code used primarily in North America.']
  updated_timestamp timestamp [note: 'The updated timestamp of the material record']
  volume_l decimal(10,3) [note: 'Typical volume of the material per unit, expressed in liters.']
  weight_kg decimal(10,3) [note: 'Net weight of a single unit of material expressed in kilograms.']

  Note: 'Master reference table for material. Referenced by material_id.'
}

Table manufacturing.manufacturing_facility {
  manufacturing_facility_id varchar [pk, note: 'Unique identifier for the manufacturing facility. Primary key. Role: MASTER_RESOURCE.']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: Every manufacturing facility operates under a legal entity (company code) for statutory reporting, intercompany transfers, and P&L consolidation. In consumer goods ERP, plant-to-company-code assignmen']
  primary_category_id varchar [note: 'Foreign key linking to product.category. Business justification: Manufacturing facilities specialize by product category (e.g., hair care, skin care), driving capacity planning, regulatory classification, and GMP requirements. primary_product_category is a denormal']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Manufacturing facilities are mapped to profit centers for management accounting and segment reporting in consumer goods. Drives facility-level P&L by brand/region. Required for contribution margin rep']
  supply_network_node_id varchar [note: 'Foreign key linking to supply.network_node. Business justification: Required for Supply Network Planning report to map each plant to its network node, enabling ATP, capacity, and logistics calculations; domain experts expect this mapping.']
  address_line_1 varchar [note: 'Primary street address line for the manufacturing facility location. Organizational contact data classified as confidential.']
  address_line_2 varchar [note: 'Secondary address line for suite, building, or additional location details. Organizational contact data classified as confidential.']
  capacity_units_per_year decimal(18,2) [note: 'The capacity units per year of the manufacturing facility record']
  city varchar [note: 'City or municipality where the manufacturing facility is located.']
  commissioning_date date [note: 'Date when the facility was officially commissioned and began production operations.']
  country_code varchar [note: 'Three-letter ISO country code where the manufacturing facility is located (e.g., USA, DEU, CHN).']
  created_timestamp timestamp [note: 'Timestamp when the manufacturing facility record was first created in the system.']
  email_address varchar [note: 'Primary email contact for the manufacturing facility operations team. Organizational contact data classified as confidential.']
  energy_consumption_kwh_per_year decimal(15,2) [note: 'Annual energy consumption of the facility measured in kilowatt-hours, used for sustainability reporting and cost management.']
  epa_site_number varchar [note: 'EPA facility identifier for environmental compliance tracking and reporting under EPA regulations.']
  erp_plant_code varchar [note: 'Plant identifier in the SAP S/4HANA ERP system used for integration with MM, PP, SD, and WM modules.']
  facility_code varchar [note: 'The facility code of the manufacturing facility record']
  facility_name varchar [note: 'Official business name of the manufacturing facility or plant site.']
  facility_type varchar [note: 'Classification of the manufacturing facility based on primary production function: mixing (formulation), filling (liquid/semi-solid), packaging (secondary), co-manufacturing (third-party), integrated (end-to-end), or contract (toll manufacturing).']
  fda_establishment_number varchar [note: 'FDA-issued establishment identifier for facilities manufacturing FDA-regulated products (cosmetics, OTC drugs, food). Required for US market distribution.']
  gmp_certification_date date [note: 'Date when the facility received its current GMP certification.']
  gmp_certified boolean [note: 'Indicates whether the facility holds current Good Manufacturing Practice certification required for consumer goods production.']
  gmp_expiration_date date [note: 'Date when the current GMP certification expires and requires renewal.']
  iso_14001_certified boolean [note: 'Indicates whether the facility holds ISO 14001 Environmental Management System certification.']
  iso_22716_compliance_tier varchar [note: 'Internal classification of the facility\'s compliance level with ISO 22716 cosmetics GMP standards: tier_1 (full compliance), tier_2 (partial compliance), tier_3 (basic compliance), non_compliant.']
  iso_9001_certified boolean [note: 'Indicates whether the facility holds ISO 9001 Quality Management System certification.']
  iso_certification varchar [note: 'The iso certification of the manufacturing facility record']
  last_audit_date date [note: 'Date of the most recent quality or compliance audit conducted at the facility.']
  last_modified_timestamp timestamp [note: 'Timestamp when the manufacturing facility record was last updated in the system.']
  latitude decimal(10,7) [note: 'Geographic latitude coordinate of the facility location in decimal degrees for mapping and logistics optimization.']
  longitude decimal(10,7) [note: 'Geographic longitude coordinate of the facility location in decimal degrees for mapping and logistics optimization.']
  manufacturing_facility_status varchar [note: 'The manufacturing facility status of the manufacturing facility record']
  mes_system_integrated boolean [note: 'Indicates whether the facility is integrated with Siemens Opcenter MES for real-time production tracking and shop floor data collection.']
  next_audit_date date [note: 'Scheduled date for the next quality or compliance audit at the facility.']
  number_of_production_lines varchar [note: 'Total count of active production lines within the facility available for manufacturing operations.']
  operational_status varchar [note: 'Current operational state of the manufacturing facility in its lifecycle.']
  osha_establishment_number varchar [note: 'OSHA establishment identifier for workplace safety reporting and compliance tracking.']
  ownership_type varchar [note: 'Legal ownership structure of the facility: owned (company-owned), leased (long-term lease), contract (third-party operated), joint_venture (shared ownership).']
  phone_number varchar [note: 'Primary contact phone number for the manufacturing facility. Organizational contact data classified as confidential.']
  plant_code varchar [note: 'Unique business identifier for the manufacturing plant used across SAP S/4HANA PP module and operational systems. Typically 4-10 alphanumeric characters.']
  postal_code varchar [note: 'Postal or ZIP code for the facility address. Organizational contact data classified as confidential.']
  production_capacity_units_per_day decimal(18,2) [note: 'Maximum daily production capacity of the facility measured in finished goods units per day under normal operating conditions.']
  shift_pattern varchar [note: 'Standard operating shift pattern for the facility: single (8 hours), two_shift (16 hours), three_shift (24 hours), continuous (24/7), flexible (variable).']
  source_system_code varchar [note: 'The source system code of the manufacturing facility record']
  square_footage decimal(12,2) [note: 'Total floor area of the manufacturing facility in square feet, including production, warehouse, and administrative spaces.']
  state_province varchar [note: 'State, province, or regional administrative division where the facility is located.']
  sustainability_rating varchar [note: 'Internal sustainability performance rating for the facility based on environmental impact, energy efficiency, waste reduction, and sustainable sourcing practices.']
  time_zone varchar [note: 'IANA time zone identifier for the facility location (e.g., America/New_York, Europe/Berlin) used for production scheduling and shift planning.']
  updated_timestamp timestamp [note: 'The updated timestamp of the manufacturing facility record']
  water_consumption_cubic_meters_per_year decimal(15,2) [note: 'Annual water consumption of the facility measured in cubic meters, tracked for environmental compliance and sustainability reporting.']
  workforce_headcount varchar [note: 'Total number of employees (full-time equivalent) assigned to the manufacturing facility.']

  Note: 'Master record for each manufacturing facility (plant/site) in the Consumer Goods network. Captures plant code, site name, address, GMP certification status, ISO 22716 compliance tier, production capacity (units/day), facility type (mixing, filling, packaging, co-manufacturing), regulatory registration numbers (FDA establishment ID, EPA site ID), and operational status. SSOT for all plant-level master data referenced by production orders, batch records, and OEE metrics. [SSOT] Superseded by authoritative table distribution.distribution_facility for concept \'facility\'. SSOT: canonical table is distribution.distribution_facility. [SSOT for concept \'facility\'.]'
}

Table manufacturing.production_line {
  production_line_id varchar [pk, note: 'Unique identifier for the production line. Primary key for the production line master record.']
  cost_center_id varchar [note: 'FK to finance.cost_center']
  manufacturing_facility_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_facility. Business justification: Production line belongs to a specific manufacturing facility; replace generic facility reference with direct link to manufacturing_facility.']
  product_category_id varchar [note: 'Foreign key linking to product.category. Business justification: Production lines are qualified for specific product categories (allergen handling, GMP classification, fill type). product_category is a denormalized text field; FK to product.category enables categor']
  allergen_handling_flag boolean [note: 'Indicates whether this production line handles products containing allergens. Critical for cross-contamination prevention and regulatory compliance.']
  allergen_types varchar [note: 'Comma-separated list of allergen types handled on this line (e.g., nuts, dairy, gluten). Used for allergen management and cleaning validation protocols.']
  asset_tag_number varchar [note: 'Physical asset tag number assigned to the production line for asset management and tracking purposes. Links to the fixed asset register in the ERP system.']
  automation_level varchar [note: 'Degree of automation on the production line. Indicates the level of human intervention required and impacts labor planning and quality consistency.']
  changeover_time_standard_minutes decimal(8,2) [note: 'Standard time in minutes required to change over the production line from one product or batch to another. Used for production scheduling and OEE loss calculation.']
  cleaning_validation_protocol varchar [note: 'Reference to the cleaning validation protocol document applicable to this production line. Ensures GMP compliance and prevents cross-contamination.']
  commissioning_date date [note: 'Date when the production line was commissioned and became operational. Used for asset lifecycle tracking and depreciation calculations.']
  created_timestamp timestamp [note: 'Timestamp when this production line record was first created in the system. Used for data lineage and audit trail purposes.']
  crew_size_standard varchar [note: 'Standard number of operators required to run the production line at full capacity. Used for labor planning and cost allocation.']
  depreciation_method varchar [note: 'Accounting depreciation method applied to this production line asset. Used for financial reporting and asset valuation.']
  design_capacity decimal(18,2) [note: 'The design capacity of the production line record']
  design_capacity_units_per_hour decimal(18,2) [note: 'The design capacity units per hour of the production line record']
  design_speed_units_per_hour decimal(12,2) [note: 'Theoretical maximum production capacity of the line measured in units per hour under ideal conditions. Used for capacity planning and scheduling.']
  energy_consumption_kwh_per_unit decimal(10,4) [note: 'Average energy consumption per unit produced on this line, measured in kilowatt-hours. Key metric for sustainability reporting and cost analysis.']
  environmental_control_required boolean [note: 'Indicates whether the production line requires controlled environmental conditions such as temperature, humidity, or air quality. Critical for GMP compliance and product quality.']
  gmp_classification varchar [note: 'GMP classification level of the production line indicating the quality and cleanliness standards required for products manufactured on this line. Critical for regulatory compliance and product safety.']
  humidity_range_percent varchar [note: 'Acceptable relative humidity range for the production line as a percentage. Format: min-max (e.g., 40-60). Used for environmental monitoring and compliance.']
  installed_power_kw decimal(10,2) [note: 'Total installed electrical power capacity of the production line in kilowatts. Used for energy consumption tracking and sustainability reporting.']
  last_major_overhaul_date date [note: 'Date of the most recent major overhaul or refurbishment of the production line. Used for maintenance planning and asset condition assessment.']
  last_modified_timestamp timestamp [note: 'Timestamp when this production line record was last updated. Used for change tracking and data quality monitoring.']
  line_code varchar [note: 'Business identifier code for the production line. Unique within the facility and used for operational reference in MES systems and production scheduling.']
  line_length_meters decimal(8,2) [note: 'Physical length of the production line in meters. Used for facility layout planning and material flow analysis.']
  line_name varchar [note: 'Human-readable name of the production line. Used for display in dashboards, reports, and operator interfaces.']
  line_status varchar [note: 'The line status of the production line record']
  line_type varchar [note: 'Classification of the production line based on its primary manufacturing function. Determines the type of operations and products that can be processed on this line.']
  mean_time_between_failures_hours decimal(10,2) [note: 'Average time in hours between equipment failures on this production line. Key reliability metric used for maintenance optimization and capacity planning.']
  mean_time_to_repair_hours decimal(8,2) [note: 'Average time in hours required to repair and restore the production line to operational status after a failure. Used for downtime analysis and maintenance resource planning.']
  mes_asset_tag varchar [note: 'Unique asset identifier for this production line in the Siemens Opcenter MES system. Used for real-time data collection, production tracking, and integration with shop floor systems.']
  modified_by_user varchar [note: 'User identifier of the person who last modified this production line record. Used for audit trail and accountability.']
  next_scheduled_maintenance_date date [note: 'Date of the next planned preventive maintenance activity for this production line. Used for maintenance scheduling and production planning coordination.']
  nominal_oee_target_percent decimal(5,2) [note: 'Target OEE percentage for this production line. OEE is calculated as Availability × Performance × Quality and represents the benchmark for line performance evaluation.']
  notes varchar [note: 'Free-text field for additional notes, special instructions, or operational considerations specific to this production line.']
  operational_status varchar [note: 'Current operational status of the production line. Indicates whether the line is available for production scheduling and execution.']
  plc_system_type varchar [note: 'Type and model of the PLC system controlling the production line. Used for technical support, integration planning, and system upgrade management.']
  product_category_capability varchar [note: 'Comma-separated list of product categories that can be manufactured on this line. Used for production planning and product-line matching in scheduling systems.']
  production_line_status varchar [note: 'The production line status of the production line record']
  quality_inspection_frequency varchar [note: 'Standard frequency for quality control inspections on this production line. Defines the QC sampling plan and compliance with GMP requirements.']
  rated_speed_uph decimal(18,2) [note: 'The rated speed uph of the production line record']
  record_source_system varchar [note: 'Source system from which this production line record originated (e.g., SAP S/4HANA PP, Siemens Opcenter MES). Used for data lineage and integration troubleshooting.']
  scada_integration_enabled boolean [note: 'Indicates whether the production line is integrated with the SCADA system for real-time monitoring and control. Enables remote visibility and data collection.']
  scrap_rate_target_percent decimal(5,2) [note: 'Target scrap rate percentage for this production line. Used for quality performance benchmarking and waste reduction initiatives.']
  shift_pattern varchar [note: 'Standard operating shift pattern for this production line. Defines the daily operating schedule and impacts capacity calculations.']
  source_system_code varchar [note: 'The source system code of the production line record']
  temperature_range_celsius varchar [note: 'Acceptable operating temperature range for the production line in Celsius. Format: min-max (e.g., 18-25). Used for environmental monitoring and compliance.']
  updated_timestamp timestamp [note: 'The updated timestamp of the production line record']
  useful_life_years varchar [note: 'Expected useful life of the production line in years for depreciation and asset lifecycle planning purposes.']

  Note: 'Master record for each physical production line within a manufacturing facility. Captures line code, line name, facility reference, line type (filling, blending, packaging, assembly), design speed (units/hour), nominal OEE target, GMP classification, MES asset tag (Siemens Opcenter), changeover time standard (minutes), and current operational status. Enables OEE benchmarking, scheduling capacity allocation, and MES integration at the line level.'
}

Table manufacturing.work_center {
  work_center_id varchar [pk, note: 'Unique identifier for the work center. Primary key.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Labor and overhead budgeting links each work center to a finance cost center for expense tracking.']
  manufacturing_facility_id varchar [note: 'Reference to the manufacturing plant where this work center is physically located.']
  production_line_id varchar [note: 'Reference to the production line to which this work center belongs, enabling line-level capacity and performance analysis.']
  available_capacity_hours_per_day decimal(6,2) [note: 'Total available production hours per day for this work center after accounting for planned downtime, breaks, and maintenance windows.']
  calibration_due_date date [note: 'Next scheduled calibration date for measurement and control instruments on this work center, ensuring accuracy and compliance with quality standards.']
  capacity_category varchar [note: 'The capacity category of the work center record']
  capacity_per_hour decimal(18,4) [note: 'The capacity per hour of the work center record']
  capacity_unit varchar [note: 'Unit of measure for the rated capacity indicating how production output is quantified for this work center.']
  category varchar [note: 'High-level category grouping work centers by operational domain for capacity planning and resource allocation.']
  clean_room_class varchar [note: 'ISO 14644 clean room classification for work centers in controlled environments, critical for cosmetics and personal care product manufacturing per GMP requirements. [ENUM-REF-CANDIDATE: iso_3|iso_4|iso_5|iso_6|iso_7|iso_8|not_applicable — 7 candidates stripped; promote to reference product]']
  code varchar [note: 'Business identifier code for the work center used in production planning and scheduling systems. Externally known unique code.']
  commissioning_date date [note: 'Date when the work center was first commissioned and put into production service, establishing the asset lifecycle baseline.']
  created_timestamp timestamp [note: 'Timestamp when this work center record was first created in the system, supporting audit trail and data lineage.']
  crew_size varchar [note: 'Standard number of operators required to run this work center during normal production operations, used for labor planning and scheduling.']
  decommissioning_date date [note: 'Date when the work center was retired from production service, supporting asset lifecycle tracking and capacity planning.']
  description varchar [note: 'Detailed description of the work center including its purpose, capabilities, and operational characteristics.']
  energy_consumption_kwh_per_hour decimal(12,4) [note: 'Average energy consumption in kilowatt-hours per operating hour, supporting sustainability reporting and cost allocation per ISO 14001 environmental management.']
  gmp_qualification_status varchar [note: 'Current qualification status of the work center per GMP requirements. IQ (Installation Qualification), OQ (Operational Qualification), PQ (Performance Qualification) track equipment validation stages per ISO 22716.']
  hazardous_area_classification varchar [note: 'Electrical area classification for work centers handling flammable or explosive materials, ensuring compliance with Occupational Safety and Health Administration (OSHA) and ATEX directives. [ENUM-REF-CANDIDATE: non_hazardous|class_1_div_1|class_1_div_2|class_2_div_1|class_2_div_2|atex_zone_0|atex_zone_1|atex_zone_2 — 8 candidates stripped; promote to reference product]']
  humidity_controlled_flag boolean [note: 'Indicates whether this work center operates in a humidity-controlled environment requiring environmental monitoring per GMP standards.']
  last_calibration_date date [note: 'Date of the most recent calibration performed on this work center, supporting traceability and compliance documentation.']
  maintenance_class varchar [note: 'Classification of the work center by maintenance priority and frequency requirements, driving preventive maintenance scheduling.']
  maintenance_strategy varchar [note: 'Maintenance approach applied to this work center defining how maintenance activities are planned and executed.']
  manufacturer_name varchar [note: 'Name of the equipment manufacturer, supporting warranty management, spare parts procurement, and technical support.']
  mes_equipment_code varchar [note: 'Unique equipment identifier in the Siemens Opcenter MES system enabling real-time production tracking and shop floor data collection.']
  model_number varchar [note: 'Manufacturer model number of the work center equipment, enabling precise identification for maintenance, parts ordering, and technical documentation.']
  modified_timestamp timestamp [note: 'Timestamp when this work center record was last modified, supporting change tracking and audit compliance.']
  name varchar [note: 'Human-readable name of the work center for identification and reporting purposes.']
  operator_skill_level_required varchar [note: 'Minimum operator skill level required to operate this work center safely and effectively, supporting workforce planning and training requirements.']
  qualification_date date [note: 'Date when the work center achieved its current GMP qualification status, establishing the baseline for requalification scheduling.']
  rated_capacity decimal(18,4) [note: 'Maximum production capacity of the work center expressed in units per time period, used for Material Requirements Planning (MRP) capacity calculations.']
  requalification_due_date date [note: 'Date by which the work center must undergo requalification to maintain GMP compliance and production authorization.']
  safety_certification varchar [note: 'Safety certifications held by this work center such as CE marking, UL listing, or other regulatory approvals required for operation.']
  serial_number varchar [note: 'Unique serial number assigned by the manufacturer to this specific equipment unit, supporting warranty tracking and asset identification.']
  setup_time_minutes decimal(10,2) [note: 'Standard time in minutes required to prepare the work center for production, including changeover and configuration activities.']
  shift_pattern varchar [note: 'Standard shift pattern for this work center defining operational hours and crew rotation schedules.']
  source_system_code varchar [note: 'The source system code of the work center record']
  standard_cycle_time_minutes decimal(10,2) [note: 'Standard time in minutes required to complete one production cycle or unit at this work center, used for scheduling and costing.']
  standard_rate decimal(18,4) [note: 'The standard rate of the work center record']
  standard_rate_per_hour decimal(18,4) [note: 'The standard rate per hour of the work center record']
  teardown_time_minutes decimal(10,2) [note: 'Standard time in minutes required to clean, sanitize, and reset the work center after production completion per Good Manufacturing Practice (GMP) requirements.']
  temperature_controlled_flag boolean [note: 'Indicates whether this work center operates in a temperature-controlled environment requiring environmental monitoring per GMP standards.']
  updated_timestamp timestamp [note: 'The updated timestamp of the work center record']
  utilization_rate_percent decimal(5,2) [note: 'Target utilization rate as a percentage of available capacity, used for capacity planning and Overall Equipment Effectiveness (OEE) benchmarking.']
  work_center_status varchar [note: 'Current operational status of the work center indicating availability for production scheduling and capacity planning.']
  work_center_type varchar [note: 'Classification of the work center by its primary function in the manufacturing process. Categorizes equipment by operational role.']

  Note: 'Master record for individual work centers (machines, stations, cells) within a production line. Captures work center code, description, work center type (mixing vessel, filling machine, labeler, capper, palletizer), rated capacity, standard cycle time, maintenance class, MES equipment ID (Siemens Opcenter), GMP equipment qualification status (IQ/OQ/PQ), and calibration due date. Supports MRP capacity planning, scheduling, and equipment qualification tracking per ISO 22716.'
}

Table manufacturing.manufacturing_bom {
  manufacturing_bom_id varchar [pk, note: 'Unique identifier for the bill of materials record. Primary key for the manufacturing BOM entity.']
  manufacturing_facility_id varchar [note: 'The manufacturing facility id of the manufacturing bom record']
  primary_manufacturing_sku_id varchar [note: 'Reference to the finished good or semi-finished SKU that this BOM defines. Links to the product master for which this material structure applies.']
  product_bom_id varchar [note: 'The product bom id of the manufacturing bom record']
  specification_id varchar [note: 'Foreign key linking to quality.specification. Business justification: Manufacturing BOM components must conform to quality specifications that drive incoming inspection and supplier qualification. Linking BOM to specification enables automated inspection plan generation']
  supplier_id varchar [note: 'Reference to the preferred or sole-source supplier for this component. Used for procurement planning, supplier performance tracking, and supply chain risk management. Nullable if multiple suppliers are available.']
  trade_account_id varchar [note: 'Foreign key linking to sales.trade_account. Business justification: In consumer goods, retailer-specific (private label) BOMs are a standard practice — a BOM may be formulated exclusively for one trade account with unique specifications. Linking manufacturing_bom to t']
  allergen_flag boolean [note: 'Indicates whether this component contains or may contain allergens as defined by FDA and EU REACH regulations. True if allergen present. Used for product labeling, consumer safety warnings, and regulatory compliance.']
  alternative_item_group varchar [note: 'Identifier for a group of interchangeable components that can substitute for each other in production. Used for supply chain flexibility, multi-sourcing strategies, and material availability optimization.']
  alternative_item_priority varchar [note: 'The selection priority for this component within its alternative item group. Lower numbers indicate higher priority. Used by MRP to determine preferred material selection when multiple alternatives are available.']
  approval_date date [note: 'The date when this BOM version was formally approved for production use. Establishes the official release date for regulatory compliance and change control purposes.']
  approved_by varchar [note: 'The name or identifier of the person who approved this BOM version for production use. Required for GMP compliance and quality assurance. Typically a product development manager, quality manager, or regulatory affairs specialist.']
  backflush_indicator boolean [note: 'Indicates whether this component is automatically consumed (backflushed) when the finished good is confirmed in the MES system, rather than requiring explicit material issue transactions. True if backflushed. Common for high-volume, low-value components.']
  base_quantity decimal(18,6) [note: 'The reference quantity of the finished good for which the component quantities are defined. Typically 1 unit, 100 units, or 1 batch. All component quantities are expressed per this base quantity.']
  base_unit_of_measure varchar [note: 'The unit of measure for the base quantity (e.g., EA for each, KG for kilogram, L for liter, BOX for box). Must align with the SKU primary UOM.']
  base_uom varchar [note: 'The base uom of the manufacturing bom record']
  bom_number varchar [note: 'The externally-known unique business identifier for this BOM, typically assigned by the PLM or ERP system. Used for cross-system reference and production order material requirements.']
  bom_status varchar [note: 'Current lifecycle status of the BOM. Active BOMs are used for production planning and MRP runs. Inactive or obsolete BOMs are retained for historical reference and regulatory traceability.']
  bom_type varchar [note: 'Classification of the BOM structure. Production BOM is used for standard manufacturing, co-product for joint production scenarios, phantom for intermediate assemblies not stocked, engineering for R&D prototypes, and planning for demand forecasting.']
  component_effective_end_date date [note: 'The date after which this specific component is no longer valid within the BOM structure. Nullable for open-ended components. Used for material phase-out and supplier transition management.']
  component_effective_start_date date [note: 'The date from which this specific component becomes valid within the BOM structure. Supports phased material transitions, supplier changes, and cost optimization initiatives.']
  component_item_category varchar [note: 'Classification of the component type. Stock items are inventory-managed materials, non-stock are direct procurement items, phantom are intermediate assemblies not physically stocked, text items are instructions, and variable size items have flexible dimensions.']
  component_item_number varchar [note: 'Sequential line number for each component within the BOM structure. Defines the order of components for display, reporting, and regulatory ingredient listing (descending order by weight for INCI compliance).']
  component_quantity decimal(18,6) [note: 'The quantity of this component required to produce the base quantity of the finished good. Used for MRP explosion, production order material requirements, and COGS calculation.']
  component_unit_of_measure varchar [note: 'The unit of measure for the component quantity (e.g., KG for raw materials, EA for packaging units, L for liquids). Must align with the component material master UOM.']
  cost_allocation_percentage decimal(5,2) [note: 'The percentage of total product cost attributed to this component. Used for COGS calculation, profitability analysis, and cost optimization initiatives. Sum of all component cost allocations should equal 100% for the BOM.']
  created_timestamp timestamp [note: 'The date and time when this BOM record was first created in the system. Used for audit trail, change tracking, and regulatory compliance documentation per ISO 9001 requirements.']
  critical_component_flag boolean [note: 'Indicates whether this component is critical for product quality, safety, or regulatory compliance. True if critical. Triggers enhanced quality control, supplier qualification requirements, and inventory safety stock policies.']
  effective_end_date date [note: 'The date after which this BOM version is no longer valid for new production orders. Nullable for open-ended BOMs. Used for phase-out management and regulatory compliance transitions.']
  effective_from date [note: 'The effective from of the manufacturing bom record']
  effective_start_date date [note: 'The date from which this BOM version becomes valid for production planning and MRP explosion. Supports planned material transitions and new product launches.']
  effective_until date [note: 'The effective until of the manufacturing bom record']
  hazardous_material_flag boolean [note: 'Indicates whether this component is classified as a hazardous material requiring special handling, storage, and disposal per OSHA and EPA regulations. True if hazardous. Triggers safety data sheet requirements and GMP compliance protocols.']
  inci_name varchar [note: 'The standardized INCI name for cosmetic ingredients as required by FDA and EU regulations. Used for product labeling, regulatory submissions, and consumer transparency. Mandatory for personal care and cosmetic products.']
  last_modified_timestamp timestamp [note: 'The date and time when this BOM record was last updated. Tracks formulation changes, component substitutions, and regulatory updates. Critical for change control and GMP compliance.']
  lead_time_days varchar [note: 'The procurement or production lead time for this component in days. Used for MRP scheduling, production order release timing, and inventory planning. Includes supplier lead time plus internal processing time.']
  lot_size_requirement varchar [note: 'Defines the lot sizing rule for this component in production orders. Exact requires precise quantity, minimum allows overages, multiple requires quantities in specific increments, none has no restriction. Impacts material planning and waste management.']
  manufacturing_bom_status varchar [note: 'The manufacturing bom status of the manufacturing bom record']
  minimum_lot_size decimal(18,6) [note: 'The minimum quantity that must be procured or produced for this component. Driven by supplier MOQ, production batch constraints, or economic order quantity calculations. Nullable if no minimum applies.']
  plm_system_reference varchar [note: 'External reference identifier linking this BOM to the source PLM system record. Enables traceability to engineering change orders, formulation documents, and R&D specifications.']
  regulatory_compliance_notes varchar [note: 'Free-text field capturing regulatory compliance requirements, restrictions, or special handling instructions for this component. Includes FDA registration numbers, EU REACH compliance status, GMP requirements, and safety data sheet references.']
  scrap_factor_percentage decimal(5,2) [note: 'The expected waste or loss percentage for this component during production. Used to adjust gross material requirements in MRP runs. Typical values range from 0% to 10% depending on material type and process complexity.']
  source_system_code varchar [note: 'The source system code of the manufacturing bom record']
  sustainability_certification varchar [note: 'Certification or standard that this component meets for sustainable sourcing (e.g., FSC for paper, RSPO for palm oil, Fair Trade, Organic). Used for corporate sustainability reporting and consumer transparency initiatives.']
  updated_timestamp timestamp [note: 'The updated timestamp of the manufacturing bom record']
  version varchar [note: 'Version identifier for the BOM structure. Incremented when material composition changes due to reformulation, cost optimization, or regulatory compliance updates. Supports change control and audit trail.']

  Note: 'Bill of Materials master record (header + component lines) defining the complete material structure for each finished good or semi-finished SKU. Header captures BOM number, BOM type (production, co-product, phantom), base quantity, unit of measure, validity dates, PLM system reference, and BOM status. Component lines capture item number, material reference (raw material, packaging, semi-finished), component quantity per base quantity, scrap factor percentage, item category (stock, non-stock, phantom), INCI name for cosmetic ingredients, allergen flag, hazardous material flag, and component validity dates. SSOT for MRP explosion, production order material requirements, COGS calculation, and regulatory ingredient disclosure per FDA/EU REACH. This is the single authoritative source for all BOM component data — no separate component entity exists.'
}

Table manufacturing.routing {
  routing_id varchar [pk, note: 'Unique identifier for the production routing master record. Primary key.']
  inspection_plan_id varchar [note: 'Foreign key linking to quality.inspection_plan. Business justification: In consumer goods GMP manufacturing, inspection plans are assigned to routing task lists to define quality gates at specific operations. This master data relationship (SAP QM task list assignment) ens']
  manufacturing_facility_id varchar [note: 'The manufacturing facility id of the routing record']
  product_bom_id varchar [note: 'Reference to the Bill of Materials (BOM) that defines the raw materials and components consumed by this routing. Links routing to material requirements.']
  sku_id varchar [note: 'Reference to the finished or semi-finished SKU that this routing defines the manufacturing process for.']
  specification_id varchar [note: 'Foreign key linking to quality.specification. Business justification: Routing operations in GMP consumer goods manufacturing have associated process specifications (temperature limits, mixing time, pressure ranges) that define critical process parameters. Linking routin']
  work_center_id varchar [note: 'The work center id of the routing record']
  approval_status varchar [note: 'Approval status of the routing for production use. Approved routings are validated and authorized; pending routings await review; rejected routings require rework.']
  approved_timestamp timestamp [note: 'Date and time when this routing was approved for production use. Supports audit trail and compliance requirements.']
  base_quantity decimal(15,3) [note: 'Standard production lot size for which the routing operation times and resource requirements are defined. Used as the basis for scaling production schedules.']
  base_unit_of_measure varchar [note: 'Unit of measure for the base quantity (e.g., KG, L, EA, M). Aligns with GS1 unit codes.']
  changeover_time_minutes decimal(10,2) [note: 'Time required to transition production lines from the previous product to this routing. Critical for production scheduling and minimizing downtime.']
  cost_currency_code varchar [note: 'ISO 4217 three-letter currency code for the standard cost amount.']
  created_timestamp timestamp [note: 'Date and time when this routing record was first created in the system. Supports audit trail and data lineage.']
  description varchar [note: 'Detailed textual description of the routing, including its purpose, scope, and any special instructions for production planners and shop floor operators.']
  effective_from date [note: 'The effective from of the routing record']
  effective_until date [note: 'The effective until of the routing record']
  expected_scrap_percentage decimal(5,2) [note: 'Overall expected scrap percentage for the routing, representing anticipated waste or defects. Used for material planning and cost estimation.']
  expected_yield_percentage decimal(5,2) [note: 'Overall expected yield percentage for the routing, representing the ratio of good output to total input. Used for production planning and variance analysis.']
  gmp_critical_flag boolean [note: 'Indicates whether this routing includes GMP-critical operations requiring enhanced documentation, validation, and compliance controls per ISO 22716 and FDA regulations.']
  ipc_checkpoint_count varchar [note: 'Number of in-process control checkpoints defined in this routing. IPC checkpoints are quality inspection points during production per ISO 22716 and GMP requirements.']
  last_modified_timestamp timestamp [note: 'Date and time when this routing record was last modified. Supports audit trail and change tracking.']
  lot_size_restriction varchar [note: 'Constraint on production lot sizes for this routing. Fixed requires exact base quantity; minimum/maximum define bounds; multiple requires lot sizes to be multiples of base quantity; none allows any lot size.']
  maximum_lot_size decimal(15,3) [note: 'Maximum production lot size allowed for this routing. Nullable if no maximum constraint exists.']
  minimum_lot_size decimal(15,3) [note: 'Minimum production lot size allowed for this routing. Nullable if no minimum constraint exists.']
  operation_count varchar [note: 'The operation count of the routing record']
  operation_description varchar [note: 'The operation description of the routing record']
  operation_number varchar [note: 'The operation number of the routing record']
  operation_sequence varchar [note: 'JSON array or delimited string capturing the complete sequence of operation steps. Each operation includes: operation_number, work_center_code, operation_description, control_key (internal_processing|external_processing|milestone), setup_time_minutes, machine_time_minutes, labor_time_minutes, yield_quantity, scrap_percentage, gmp_critical_step_flag, ipc_checkpoint_flag. This is the single authoritative source for all routing operation data — no separate operation entity exists.']
  plant_code varchar [note: 'Manufacturing plant or facility where this routing is executed. Aligns with organizational plant master data.']
  production_scheduler_code varchar [note: 'Code identifying the production scheduling strategy or algorithm used for this routing (e.g., forward scheduling, backward scheduling, finite capacity).']
  routing_number varchar [note: 'Business identifier for the routing. Externally-known unique code used in production planning and scheduling systems.']
  routing_status varchar [note: 'Current lifecycle status of the routing. Active routings are available for production scheduling; draft routings are under development; inactive routings are temporarily disabled; obsolete routings are retired; under_review routings are pending approval.']
  routing_type varchar [note: 'Classification of the routing defining its usage pattern. Standard routings are default production paths; reference routings are templates; rate routings define production rates; alternative routings provide backup paths; special routings are for one-time or custom production runs.']
  run_time_per_unit_minutes decimal(10,4) [note: 'The run time per unit minutes of the routing record']
  setup_time_minutes decimal(10,2) [note: 'The setup time minutes of the routing record']
  source_system_code varchar [note: 'The source system code of the routing record']
  standard_cost_amount decimal(15,2) [note: 'Standard production cost per base quantity for this routing, including labor, machine, and overhead costs. Used for cost accounting and variance analysis.']
  total_labor_time_minutes decimal(10,2) [note: 'Cumulative labor time across all operations in the routing, used for workforce planning and standard cost calculation.']
  total_machine_time_minutes decimal(10,2) [note: 'Cumulative machine processing time across all operations in the routing, used for capacity planning and Overall Equipment Effectiveness (OEE) calculations.']
  total_setup_time_minutes decimal(10,2) [note: 'Cumulative setup time across all operations in the routing, used for capacity planning and scheduling.']
  total_standard_lead_time_hours decimal(10,2) [note: 'Total cumulative lead time in hours required to complete all operations in this routing, including setup, processing, and queue times. Used for Material Requirements Planning (MRP) and capacity planning.']
  total_standard_time_min decimal(18,4) [note: 'The total standard time min of the routing record']
  updated_timestamp timestamp [note: 'The updated timestamp of the routing record']
  valid_from_date date [note: 'Date from which this routing becomes effective and available for production scheduling.']
  valid_to_date date [note: 'Date until which this routing remains effective. Nullable for open-ended routings.']
  version varchar [note: 'Version identifier for the routing, enabling tracking of routing changes over time. Supports engineering change management and audit trails.']

  Note: 'Production routing master (header + operation steps) defining the complete manufacturing process sequence for a finished or semi-finished SKU. Header captures routing number, routing type (standard, reference, rate), base quantity, plant, validity dates, and total standard lead time. Operation steps capture operation number, work center assignment, standard values (setup time, machine time, labor time), control key (internal processing, external processing, milestone), yield quantity, scrap percentage, GMP critical step flag, and IPC checkpoint flag. SSOT for production scheduling, capacity planning, standard cost calculation, and GMP batch record generation per ISO 22716. This is the single authoritative source for all routing operation data — no separate operation entity exists. Aligned with SAP PP Routing master.'
}

Table manufacturing.production_order {
  production_order_id varchar [pk, note: 'Unique identifier for the production order. Primary key for the production order entity.']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: Consumer goods companies create campaign-specific production orders for promotional packs and limited-edition SKUs. Linking production_order to campaign enables campaign COGS calculation, marketing RO']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: Production orders are created within a company code for legal entity financial reporting. In multi-entity consumer goods companies with contract or intercompany manufacturing, company code on producti']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Cost accounting report requires each production order to be charged to a finance cost center for OPEX allocation.']
  demand_plan_id varchar [note: 'Foreign key linking to supply.demand_plan. Business justification: S&OP/IBP demand fulfillment traceability: production orders are created to fulfill demand plans. Planners require this link for demand-supply variance analysis and S&OP cycle supply review reporting. ']
  inspection_plan_id varchar [note: 'Foreign key linking to quality.inspection_plan. Business justification: Production orders trigger an inspection plan; linking allows the order execution system to retrieve the exact inspection plan governing sampling and testing for that batch.']
  manufacturing_bom_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_bom. Business justification: Production order consumes a specific manufacturing BOM; adding manufacturing_bom_id FK connects BOM to order and eliminates isolation of manufacturing_bom.']
  manufacturing_facility_id varchar [note: 'The manufacturing facility id of the production order record']
  marketing_brand_id varchar [note: 'Foreign key linking to marketing.brand. Business justification: Production Planning Dashboard ties orders to brands to enable demand forecasting and coordinated marketing launch planning.']
  production_line_id varchar [note: 'FK to manufacturing.production_line']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Production orders settle actual manufacturing costs and variances to profit centers for brand/segment P&L reporting. In consumer goods SAP CO, production order settlement to profit center is a standar']
  routing_id varchar [note: 'Foreign key linking to manufacturing.routing. Business justification: Each production order follows a routing; adding routing_id FK links routing to order and eliminates isolation of routing.']
  sales_order_id varchar [note: 'Foreign key linking to sales.order. Business justification: Order fulfillment process requires linking each production order to the originating sales order to track manufacturing against sales commitments.']
  sku_id varchar [note: 'Reference to the SKU being produced in this production order. Links to the product master data.']
  sop_cycle_id varchar [note: 'Foreign key linking to supply.sop_cycle. Business justification: S&OP cycle production performance reporting: production orders are released within a specific S&OP cycle. This link enables actual vs planned production volume reconciliation at cycle level — a standa']
  trade_account_id varchar [note: 'Foreign key linking to sales.trade_account. Business justification: Required for Production Order to Customer Account linkage for OTIF SLA reporting and order fulfillment traceability.']
  actual_cost decimal(15,2) [note: 'Actual cost incurred for the production order. Includes material, labor, and overhead costs. Used for variance analysis.']
  actual_end timestamp [note: 'The actual end of the production order record']
  actual_end_date date [note: 'The actual end date of the production order record']
  actual_finish_timestamp timestamp [note: 'Actual date and time when production execution completed. Used for OEE calculation and performance analysis.']
  actual_start timestamp [note: 'The actual start of the production order record']
  actual_start_date date [note: 'The actual start date of the production order record']
  actual_start_timestamp timestamp [note: 'Actual date and time when production execution began on the shop floor. Captured from MES system.']
  batch_number varchar [note: 'Unique batch or lot number assigned to the production run. Critical for traceability and recall management per GMP requirements.']
  changeover_time_minutes varchar [note: 'Time in minutes required for line changeover before starting this production order. Used for scheduling and efficiency analysis.']
  confirmed_quantity decimal(15,3) [note: 'Actual quantity produced and confirmed as good output. Represents yield after quality inspection.']
  cost_object varchar [note: 'Cost object (production order number or process order) used for collecting actual costs. Links to CO-PC product costing.']
  created_timestamp timestamp [note: 'Date and time when the production order was created in the system. First event in order lifecycle.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for cost amounts. Typically company code currency.']
  downtime_minutes varchar [note: 'Total unplanned downtime in minutes during production execution. Impacts OEE availability component.']
  gmp_compliance_flag boolean [note: 'Indicates whether this production order is subject to GMP compliance requirements per ISO 22716 standards. True for regulated products.']
  inspection_lot_number varchar [note: 'Inspection lot number created for quality control of the production output. Links to QM inspection results.']
  last_modified_timestamp timestamp [note: 'Date and time of the most recent update to the production order record. Used for change tracking and audit compliance.']
  material_number varchar [note: 'SAP material number for the finished good being produced. Business identifier for the product in ERP system.']
  mrp_controller varchar [note: 'Three-character code identifying the MRP controller responsible for planning this material. Links to planner master data.']
  notes varchar [note: 'Free-text notes or comments related to the production order. Captures special instructions, issues, or observations from shop floor.']
  oee_percentage decimal(5,2) [note: 'Overall Equipment Effectiveness percentage for this production run. Calculated as Availability × Performance × Quality. Industry standard KPI.']
  order_number varchar [note: 'Business identifier for the production order. Externally-known unique order number assigned by SAP S/4HANA PP system.']
  order_quantity decimal(15,3) [note: 'Planned quantity to be produced in base unit of measure. Target output for the production order.']
  order_status varchar [note: 'Current lifecycle status of the production order. CRTD=Created, REL=Released, PCNF=Partially Confirmed, TECO=Technically Complete, CNF=Confirmed, DLV=Delivered, CLSD=Closed. [ENUM-REF-CANDIDATE: CRTD|REL|PCNF|TECO|CNF|DLV|CLSD — 7 candidates stripped; promote to reference product]']
  order_type varchar [note: 'Classification of production order. PP01=Standard Production, PP03=Rework, PP05=Co-Product, PP10=Process Order, PP20=Batch Order.']
  planned_cost decimal(15,2) [note: 'Standard or planned cost for producing the order quantity. Calculated from BOM and routing costs.']
  planned_quantity decimal(18,4) [note: 'The planned quantity of the production order record']
  plant_code varchar [note: 'Four-character code identifying the manufacturing facility where production occurs. Maps to SAP plant master.']
  priority varchar [note: 'Priority level for production scheduling. 1=Highest priority (rush/expedite), 5=Lowest priority (standard). Used for sequencing and resource allocation.']
  production_supervisor varchar [note: 'Name of the production supervisor responsible for overseeing execution of this order on the shop floor.']
  production_version varchar [note: 'Production version defining the specific BOM and routing combination used. Enables multiple production methods for same material.']
  quality_inspection_required boolean [note: 'Indicates whether quality inspection is mandatory before goods receipt. Drives QM integration and inspection lot creation.']
  released_by varchar [note: 'User ID of the person who released the production order for execution. Audit trail for production authorization.']
  released_timestamp timestamp [note: 'Date and time when the production order was released for shop floor execution. Triggers material availability check and capacity reservation.']
  scheduled_end timestamp [note: 'The scheduled end of the production order record']
  scheduled_end_date date [note: 'The scheduled end date of the production order record']
  scheduled_finish_date date [note: 'Planned date when production is scheduled to complete. Used for capacity planning and delivery commitments.']
  scheduled_start timestamp [note: 'The scheduled start of the production order record']
  scheduled_start_date date [note: 'Planned date when production is scheduled to begin. Set during production planning and MRP run.']
  scrap_quantity decimal(15,3) [note: 'Quantity of material scrapped or rejected during production. Used for yield analysis and cost accounting.']
  settlement_rule varchar [note: 'Rule for settling production order costs. FUL=Full settlement, PAR=Partial settlement, PER=Periodic settlement.']
  source_system_code varchar [note: 'The source system code of the production order record']
  unit_of_measure varchar [note: 'Base unit of measure for quantities. Standard ISO codes such as EA (each), KG (kilogram), L (liter), M (meter).']
  uom varchar [note: 'The uom of the production order record']
  updated_timestamp timestamp [note: 'The updated timestamp of the production order record']
  yield_percentage decimal(5,2) [note: 'Actual yield percentage calculated as (confirmed_quantity / order_quantity) * 100. Key performance metric for production efficiency.']
  created_by varchar [note: 'User ID of the person who created the production order in the system. Audit trail for order origination.']

  Note: 'Core transactional record representing a manufacturing production order issued to produce a specific SKU quantity at a facility. Captures order number, order type (PP01 standard, PP03 rework), SKU reference, plant, production line, scheduled start/finish dates, actual start/finish dates, order quantity, confirmed quantity, scrap quantity, order status (created, released, partially confirmed, technically complete, closed), MRP controller, and cost object. SSOT for production execution tracking in SAP S/4HANA PP.'
}

Table manufacturing.batch_record {
  batch_record_id varchar [pk, note: 'Unique identifier for the electronic batch manufacturing record (eBMR). Primary key for GMP-compliant batch traceability.']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: Campaign-specific batch traceability is required in consumer goods for promotional product recalls, quality holds scoped to a campaign run, and post-campaign quality audits. Regulators and brand quali']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Batch cost roll‑up uses finance cost center to allocate raw material and labor expenses per batch.']
  formulation_id varchar [note: 'Foreign key linking to product.product_formulation. Business justification: FDA 21 CFR Part 211 and EU GMP Annex 11 require batch records to reference the approved formulation version used in production — essential for regulatory audit, product recall traceability, and deviat']
  goods_receipt_id varchar [note: 'Foreign key linking to procurement.goods_receipt. Business justification: GMP regulations in consumer goods require batch records to document the specific goods receipt (and supplier lot) of each raw material consumed. This lot genealogy link is mandatory for recall managem']
  manufacturing_bom_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_bom. Business justification: The batch_record currently stores bom_version as a denormalized STRING. This should be replaced with a proper FK to manufacturing_bom, which contains the authoritative BOM version, component structure']
  manufacturing_facility_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_facility. Business justification: Batch record should reference the specific manufacturing facility for traceability.']
  marketing_brand_id varchar [note: 'Foreign key linking to marketing.brand. Business justification: Brand Batch Traceability Report requires linking each batch to its brand for recall, quality and marketing performance analysis.']
  production_line_id varchar [note: 'Reference to the specific production line used for this batch. Links to equipment master data.']
  production_order_id varchar [note: 'Reference to the production order that authorized this batch manufacturing run. Links to SAP PP production order master.']
  routing_id varchar [note: 'Foreign key linking to manufacturing.routing. Business justification: The batch_record currently stores routing_version as a denormalized STRING. This should be replaced with a proper FK to routing, which contains the authoritative routing version, operation sequence, a']
  sku_id varchar [note: 'Reference to the finished goods SKU produced in this batch. Links to product master data.']
  actual_cost_amount decimal(18,2) [note: 'Actual cost per unit incurred for this batch. Includes material, labor, and overhead variances.']
  batch_number varchar [note: 'Unique manufacturing batch identifier assigned at production initiation. Used for product traceability and recall management per GMP requirements.']
  batch_size_actual decimal(18,3) [note: 'Actual production quantity achieved for this batch. Used for yield calculation and inventory reconciliation.']
  batch_size_planned decimal(18,3) [note: 'Planned production quantity for this batch as specified in the production order. Measured in base unit of measure.']
  batch_status varchar [note: 'Current lifecycle status of the batch. Controls inventory availability and distribution eligibility per GMP workflow.']
  changeover_minutes varchar [note: 'Time in minutes required for line changeover before this batch. Key metric for SMED and lean manufacturing initiatives.']
  created_timestamp timestamp [note: 'Date and time when this batch record was first created in the system. Audit trail for record lifecycle.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for cost amounts. Supports multi-currency manufacturing operations.']
  downtime_minutes varchar [note: 'Total unplanned downtime in minutes during batch production. Used for OEE calculation and maintenance planning.']
  electronic_signature_count varchar [note: 'Number of electronic signatures captured during batch record lifecycle. Required for FDA 21 CFR Part 11 compliance.']
  expiry_date date [note: 'Date after which the product should not be used or sold. Critical for FEFO inventory management and consumer safety.']
  gmp_compliant boolean [note: 'The gmp compliant of the batch record record']
  gmp_deviation_count varchar [note: 'Number of GMP deviations recorded for this batch. Used for quality trend analysis and CAPA tracking.']
  gmp_deviation_flag boolean [note: 'Indicates whether any GMP deviations were recorded during batch production. Triggers quality review workflow.']
  gmp_reviewed boolean [note: 'The gmp reviewed of the batch record record']
  last_modified_timestamp timestamp [note: 'Date and time when this batch record was last updated. Audit trail for GMP compliance and data integrity.']
  lot_genealogy_complete_flag boolean [note: 'Indicates whether complete raw material lot traceability has been captured for this batch. Required for recall readiness.']
  lot_number varchar [note: 'The lot number of the batch record record']
  manufacture_date date [note: 'The manufacture date of the batch record record']
  manufactured_quantity decimal(18,4) [note: 'The manufactured quantity of the batch record record']
  manufacturing_date date [note: 'Calendar date of batch production. Printed on product packaging for consumer information and regulatory compliance.']
  manufacturing_end_timestamp timestamp [note: 'Date and time when batch production was completed and final packaging finished. Used for cycle time analysis.']
  manufacturing_start_timestamp timestamp [note: 'Date and time when batch production was initiated on the shop floor. Captured from MES system.']
  oee_percentage decimal(5,2) [note: 'Overall equipment effectiveness achieved during batch production. Composite metric of availability, performance, and quality.']
  quality_release_flag boolean [note: 'Indicates whether the batch has been released by Quality Assurance for distribution. Required before inventory availability.']
  quality_release_timestamp timestamp [note: 'Date and time when Quality Assurance approved the batch for release. Marks transition from quarantine to available inventory.']
  quantity_produced decimal(18,4) [note: 'The quantity produced of the batch record record']
  recall_flag boolean [note: 'Indicates whether this batch is subject to a product recall. Triggers supply chain hold and customer notification.']
  recall_initiated_date date [note: 'Date when recall was initiated for this batch. Used for regulatory reporting and recall effectiveness tracking.']
  record_locked_flag boolean [note: 'Indicates whether this batch record is locked from further edits. Required for GMP record integrity after quality release.']
  regulatory_hold_flag boolean [note: 'Indicates whether batch is on regulatory hold pending investigation or approval. Prevents distribution until cleared.']
  release_date date [note: 'The release date of the batch record record']
  released boolean [note: 'The released of the batch record record']
  review_by_exception boolean [note: 'The review by exception of the batch record record']
  rework_quantity decimal(18,3) [note: 'Quantity of product requiring rework during batch production. Indicator of process capability and quality issues.']
  scrap_quantity decimal(18,3) [note: 'Quantity of product scrapped during batch production. Used for yield calculation and waste reduction analysis.']
  shelf_life_days varchar [note: 'Number of days between manufacturing date and expiry date. Derived from product stability testing.']
  source_system_code varchar [note: 'The source system code of the batch record record']
  standard_cost_amount decimal(18,2) [note: 'Standard cost per unit for this batch based on BOM and routing. Used for cost variance analysis.']
  unit_of_measure varchar [note: 'Unit of measure for batch size quantities (e.g., KG, LTR, EA, CS). Aligns with GS1 standards.']
  uom varchar [note: 'The uom of the batch record record']
  updated_timestamp timestamp [note: 'The updated timestamp of the batch record record']
  veeva_vault_document_reference varchar [note: 'Reference to the master batch record document stored in Veeva Vault. Links to regulatory document management system.']
  yield_percentage decimal(5,2) [note: 'Ratio of actual batch size to planned batch size expressed as percentage. Key performance indicator for manufacturing efficiency.']

  Note: 'Electronic batch manufacturing record (eBMR) capturing the complete GMP-compliant execution history for a production batch. Captures batch number, production order reference, SKU, batch size, manufacturing date, expiry date (FEFO), facility, production line, batch status (in-process, released, rejected, quarantine, recalled), GMP deviation flag, electronic signature records, yield percentage, and Veeva Vault document reference. SSOT for GMP batch traceability per ISO 22716 and FDA 21 CFR Part 211.'
}

Table manufacturing.production_confirmation {
  production_confirmation_id varchar [pk, note: 'Unique identifier for the production confirmation record. Primary key for shop floor execution tracking.']
  batch_record_id varchar [note: 'Foreign key linking to manufacturing.batch_record. Business justification: A production confirmation is a shop floor execution event that contributes to the GMP batch record. Each confirmation (operation-level execution) rolls up into a batch_record (the complete eBMR for th']
  cost_center_id varchar [note: 'Reference to the cost center to which labor and overhead costs for this operation are allocated for financial accounting.']
  manufacturing_facility_id varchar [note: 'Reference to the manufacturing plant or facility where this operation was performed.']
  production_line_id varchar [note: 'Foreign key linking to manufacturing.production_line. Business justification: A production confirmation captures shop floor execution at a specific production line. While work_center_id provides granular equipment-level context, production_line_id is needed for line-level OEE r']
  production_order_id varchar [note: 'Reference to the parent production order under which this operation was executed.']
  routing_id varchar [note: 'The routing id of the production confirmation record']
  sales_order_id varchar [note: 'Foreign key linking to sales.order. Business justification: Production confirmation reports must reference the sales order they fulfill for accurate shipping and invoicing.']
  sku_id varchar [note: 'Reference to the finished or semi-finished material (SKU) produced by this operation.']
  sop_cycle_id varchar [note: 'Foreign key linking to supply.sop_cycle. Business justification: S&OP supply review actuals reconciliation: production confirmations represent actual output that must be reconciled against S&OP cycle supply targets during supply review meetings. This link enables a']
  work_center_id varchar [note: 'Reference to the work center (production line, machine, or station) where this operation was performed.']
  activity_type varchar [note: 'SAP CO activity type code representing the type of work performed (e.g., machine hours, labor hours, setup hours) for cost allocation purposes.']
  actual_end_datetime timestamp [note: 'Actual date and time when the operation was completed and confirmed by the operator. Used for OEE calculation and production order settlement.']
  actual_labor_time_minutes decimal(10,2) [note: 'Actual operator labor time spent on this operation including manual work, monitoring, and quality checks. Measured in minutes.']
  actual_machine_time_minutes decimal(10,2) [note: 'Actual time the machine or equipment was actively running during this operation. Excludes setup and downtime. Measured in minutes.']
  actual_setup_time_minutes decimal(10,2) [note: 'Actual time spent on machine setup, changeover, and preparation activities before production began. Measured in minutes.']
  actual_start_datetime timestamp [note: 'Actual date and time when the operator began executing this operation on the shop floor. Captured from MES or manual confirmation.']
  batch_number varchar [note: 'Manufacturing batch or lot number assigned to the output produced in this operation. Critical for traceability and recall management.']
  confirmation_notes varchar [note: 'Free-text notes or comments entered by the operator or supervisor regarding this operation execution, including any issues or observations.']
  confirmation_number varchar [note: 'The confirmation number of the production confirmation record']
  confirmation_timestamp timestamp [note: 'System timestamp when this confirmation record was created and submitted to the ERP or MES system.']
  confirmation_type varchar [note: 'Classification of the confirmation event indicating whether this is a partial progress update, final completion, milestone checkpoint, rework confirmation, or cancellation.']
  confirmed_quantity decimal(18,4) [note: 'The confirmed quantity of the production confirmation record']
  confirmed_scrap_quantity decimal(18,3) [note: 'Actual quantity of defective or waste material generated during this operation. Used for yield variance analysis and quality tracking.']
  confirmed_yield_quantity decimal(18,3) [note: 'Actual quantity of good output produced and confirmed for this operation. Measured in the base unit of measure for the material.']
  created_timestamp timestamp [note: 'The created timestamp of the production confirmation record']
  downtime_minutes decimal(10,2) [note: 'Total unplanned downtime during this operation due to equipment failure, material shortage, or other interruptions. Measured in minutes.']
  gmp_compliance_flag boolean [note: 'Indicates whether this operation was executed in compliance with GMP standards as required for regulated consumer goods products.']
  labor_hours decimal(10,2) [note: 'The labor hours of the production confirmation record']
  last_modified_timestamp timestamp [note: 'System timestamp when this confirmation record was last updated or modified. Used for change tracking and audit purposes.']
  machine_hours decimal(10,2) [note: 'The machine hours of the production confirmation record']
  mes_transaction_reference varchar [note: 'Unique transaction reference from the Siemens Opcenter MES system that originated this confirmation. Used for traceability and system reconciliation.']
  oee_availability_percent decimal(5,2) [note: 'Calculated availability component of OEE for this operation, representing the percentage of scheduled time that equipment was available for production.']
  oee_performance_percent decimal(5,2) [note: 'Calculated performance component of OEE for this operation, representing actual production speed versus ideal speed.']
  oee_quality_percent decimal(5,2) [note: 'Calculated quality component of OEE for this operation, representing the percentage of good output versus total output produced.']
  operation_number varchar [note: 'Sequential operation identifier within the production order routing. Typically a 4-digit numeric code representing the step in the manufacturing process.']
  operation_status varchar [note: 'Current lifecycle status of the manufacturing operation indicating its execution state in the production workflow.']
  posting_date date [note: 'Financial posting date when this confirmation was recorded in the ERP system for inventory and cost accounting purposes.']
  quality_inspection_required_flag boolean [note: 'Indicates whether this operation output requires quality inspection before release to inventory or next operation.']
  reversal_flag boolean [note: 'Indicates whether this confirmation has been reversed or cancelled due to error correction or process adjustment.']
  reversal_reason_code varchar [note: 'Standardized code explaining why this confirmation was reversed, if applicable. Used for process improvement and error tracking.']
  rework_flag boolean [note: 'Indicates whether this confirmation represents a rework operation to correct defects from a previous production run.']
  scheduled_end_datetime timestamp [note: 'Planned completion date and time for this operation as determined by production scheduling or MES system.']
  scheduled_start_datetime timestamp [note: 'Planned start date and time for this operation as determined by production scheduling or MES system.']
  scrap_quantity decimal(18,4) [note: 'The scrap quantity of the production confirmation record']
  shift_code varchar [note: 'Production shift identifier during which this operation was executed (e.g., SHIFT_1, DAY, NIGHT). Used for shift performance analysis.']
  source_system_code varchar [note: 'Identifier of the originating system that created this confirmation record (SAP PP, Siemens Opcenter MES, or manual entry).']
  unit_of_measure varchar [note: 'Standard unit of measure for the confirmed quantities (e.g., KG for kilograms, EA for each, LT for liters). Aligns with material master UOM.']
  uom varchar [note: 'The uom of the production confirmation record']
  updated_timestamp timestamp [note: 'The updated timestamp of the production confirmation record']
  variance_reason_code varchar [note: 'Standardized code explaining any significant variance between planned and actual quantities or times. Used for root cause analysis.']
  work_order_number varchar [note: 'Business identifier for the work order assigned to this manufacturing operation. Externally visible reference used across shop floor systems.']
  yield_quantity decimal(18,4) [note: 'The yield quantity of the production confirmation record']

  Note: 'Shop floor execution and confirmation record capturing the complete lifecycle of each manufacturing operation within a production order — from assignment and scheduling through actual execution and final confirmation. Captures work order number, parent production order reference, operation number, work center, assigned operator, scheduled start/end, actual start/end, confirmation type (partial, final), confirmed yield quantity, confirmed scrap quantity, actual setup/machine/labor time, operation status (open, in-progress, completed, cancelled), posting date, and MES transaction reference (Siemens Opcenter). SSOT for granular shop floor execution tracking, labor confirmation, production order settlement, and OEE calculation. Subsumes discrete work order assignment data.'
}

Table manufacturing.planned_order {
  planned_order_id varchar [pk, note: 'Unique system-generated identifier for the planned order record. Primary key for the planned order entity.']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: S&OP and MRP planning in consumer goods aligns production plans with campaign calendars. Campaign-driven demand spikes (e.g., promotional launches) generate planned orders; linking them enables brand ']
  converted_production_order_id varchar [note: 'Reference to the production order that was created from this planned order upon conversion. Null if not yet converted.']
  demand_plan_id varchar [note: 'Foreign key linking to supply.demand_plan. Business justification: MRP/DRP demand-supply traceability: planned orders are generated from demand plans. Planners need to trace which demand signal triggered each planned order for exception management and demand fulfillm']
  destination_network_node_id varchar [note: 'Foreign key linking to supply.network_node. Business justification: Supply network destination planning: planned orders specify which supply network node will receive the produced goods. Role-prefixed \'destination_\' distinguishes from the source manufacturing facility']
  distribution_facility_id varchar [note: 'Foreign key linking to distribution.distribution_facility. Business justification: MRP/IBP planned orders in consumer goods are generated to replenish specific distribution centers. DC replenishment planning, OTIF reporting, and supply network optimization all require knowing which ']
  dtc_order_id varchar [note: 'Foreign key linking to consumer.dtc_order. Business justification: Make-to-Order DTC Demand Traceability: In DTC consumer goods, individual DTC orders trigger make-to-order MRP planned production runs. Linking planned_order to dtc_order enables operations teams to tr']
  manufacturing_bom_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_bom. Business justification: MRP generates planned orders based on a specific Bill of Materials. The planned_order must reference the manufacturing_bom used to determine component requirements and quantities during planning. This']
  marketing_brand_id varchar [note: 'Foreign key linking to marketing.marketing_brand. Business justification: Brand-level S&OP capacity planning requires aggregating planned production orders by brand without joining through SKU-to-brand hierarchy. Brand managers review planned supply vs. brand-level demand t']
  production_line_id varchar [note: 'The production line id of the planned order record']
  routing_id varchar [note: 'Foreign key linking to manufacturing.routing. Business justification: MRP planning uses routing master data to calculate lead times, work center capacity requirements, and scheduling windows. The planned_order should reference the routing that defines the production pro']
  sales_order_id varchar [note: 'Foreign key linking to sales.order. Business justification: In make-to-order consumer goods operations, MRP/IBP planned orders are directly triggered by sales orders. Linking planned_order to the originating sales order enables demand-driven production plannin']
  sku_id varchar [note: 'Reference to the SKU (Stock Keeping Unit) that this planned order is for. Links to the product master data.']
  sop_cycle_id varchar [note: 'Foreign key linking to supply.sop_cycle. Business justification: S&OP cycle supply planning: planned_order has sop_cycle_reference (plain text denormalization) confirming this business relationship. Planned orders are generated within S&OP cycles; the FK formalizes']
  availability_date date [note: 'The date when the produced or procured material from this planned order is expected to be available for consumption or shipment.']
  conversion_date date [note: 'The date when this planned order was converted to a production order. Null if not yet converted.']
  conversion_status varchar [note: 'Indicates whether this planned order has been converted to a production order: NOT_CONVERTED (still in planning), PARTIALLY_CONVERTED (split conversion), FULLY_CONVERTED (completely converted).']
  created_by_user varchar [note: 'User ID or system identifier of the person or automated process that created this planned order.']
  created_timestamp timestamp [note: 'System timestamp when this planned order record was first created in the system.']
  demand_source_type varchar [note: 'Classification of the demand signal that triggered this planned order: FORECAST (demand planning), CUSTOMER_ORDER (firm sales order), STOCK_TRANSFER (inter-plant), SAFETY_STOCK (replenishment), PROMOTION (trade promotion demand).']
  exception_message_code varchar [note: 'Code representing MRP exception conditions (e.g., EX01 = reschedule in, EX02 = reschedule out, EX03 = cancel, EX10 = expedite). Empty if no exception.']
  exception_message_text varchar [note: 'Human-readable description of the MRP exception condition requiring planner attention.']
  firmed_flag boolean [note: 'The firmed flag of the planned order record']
  firming_date date [note: 'The date when this planned order was firmed by a planner. Null if not yet firmed.']
  firming_indicator boolean [note: 'Boolean flag indicating whether this planned order is firmed (locked from automatic MRP changes). True = firmed, False = subject to MRP rescheduling.']
  gmp_compliance_flag boolean [note: 'Indicates whether this planned order must comply with GMP regulations. True for pharmaceutical and cosmetic products requiring ISO 22716 compliance.']
  ibp_plan_version varchar [note: 'Version identifier from SAP IBP system that generated the demand signal driving this planned order. Format: IBP-YYYYMM.']
  last_modified_by_user varchar [note: 'User ID or system identifier of the person or automated process that last modified this planned order.']
  last_modified_timestamp timestamp [note: 'System timestamp when this planned order record was last updated or modified.']
  lot_size_key varchar [note: 'Code indicating the lot-sizing procedure used: EX (exact lot size), HB (lot-for-lot), FX (fixed lot size), PD (periodic lot size), WM (weekly lot size).']
  mrp_controller varchar [note: 'Code identifying the MRP controller or planning group responsible for this material and plant combination.']
  mrp_run_code varchar [note: 'Reference to the specific MRP run that generated or last modified this planned order. Links to MRP execution history.']
  mrp_run_date date [note: 'The mrp run date of the planned order record']
  notes varchar [note: 'Free-text field for planners to add comments, special instructions, or contextual information about this planned order.']
  order_number varchar [note: 'Business-readable unique identifier for the planned order, typically system-generated following organizational numbering conventions.']
  order_status varchar [note: 'Current lifecycle status of the planned order: DRAFT (initial creation), FIRMED (locked from MRP changes), RELEASED (approved for execution), CONVERTED (converted to production order), DELETED (marked for deletion), CANCELLED (cancelled before conversion).']
  order_type varchar [note: 'Classification of the planned order origin: MPS (Master Production Schedule), MRP (Material Requirements Planning generated), CBP (Consumption-Based Planning), MANUAL (manually created), FORECAST (forecast-driven), SAFETY (safety stock replenishment).']
  planned_end_date date [note: 'The planned end date of the planned order record']
  planned_order_number varchar [note: 'The planned order number of the planned order record']
  planned_quantity decimal(18,3) [note: 'The quantity of the SKU planned to be produced or procured in this order, expressed in the base unit of measure.']
  planned_start_date date [note: 'The planned start date of the planned order record']
  planning_period varchar [note: 'The planning time bucket this order belongs to, expressed as YYYY-Wnn (week), YYYY-Mnn (month), or YYYY-Qn (quarter). Used for MPS and S&OP alignment.']
  planning_strategy_group varchar [note: 'Two-digit code defining the planning strategy (e.g., 10 = make-to-stock, 20 = make-to-order, 40 = planning with final assembly, 50 = planning without final assembly).']
  priority_code varchar [note: 'Priority level assigned to this planned order for scheduling and resource allocation: LOW, NORMAL, HIGH, URGENT.']
  procurement_type varchar [note: 'Indicates whether this planned order is for in-house production (IN_HOUSE), external procurement (EXTERNAL), or can be either (BOTH).']
  production_version varchar [note: 'Identifies the specific combination of BOM (Bill of Materials) and routing to be used for production. Links to production master data.']
  reorder_point_quantity decimal(18,3) [note: 'The inventory level that triggers generation of a planned order for replenishment.']
  safety_stock_quantity decimal(18,3) [note: 'The safety stock level maintained for this SKU at this plant, influencing planned order generation.']
  schedule_version varchar [note: 'Version identifier for the MPS schedule that generated or governs this planned order. Enables tracking of schedule changes over time.']
  scheduled_finish_date date [note: 'The planned date when production or procurement activities for this order should be completed and goods available.']
  scheduled_start_date date [note: 'The planned date when production or procurement activities for this order should begin.']
  source_system_code varchar [note: 'The source system code of the planned order record']
  unit_of_measure varchar [note: 'The unit of measure for the planned quantity (e.g., EA for each, KG for kilogram, L for liter). Follows ISO standard unit codes.']
  uom varchar [note: 'The uom of the planned order record']
  updated_timestamp timestamp [note: 'The updated timestamp of the planned order record']

  Note: 'Production planning record representing the complete planning pipeline from S&OP/IBP through MRP execution to production order conversion. Encompasses both Master Production Schedule (MPS) entries (planned quantities by SKU/facility/period with schedule versioning) and MRP-generated planned orders (system-proposed production or procurement proposals). Captures planned order ID, order type (MPS, MRP planned, CBP), SKU, plant, MRP run reference, planned quantity, scheduled start/finish dates, planning period (week/month), schedule version, S&OP cycle reference, IBP plan version, firming indicator, schedule status (draft, firmed, released, converted, deleted), exception message code, planner ID, and conversion status. SSOT for MRP exception management, MPS governance, and the complete production planning pipeline from demand signal through to production order creation.'
}

Table manufacturing.equipment {
  equipment_id varchar [pk, note: 'Primary key for equipment']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Equipment assets are assigned to cost centers for depreciation posting, maintenance cost collection, and asset accounting in consumer goods ERP. SAP Asset Management requires cost center on every equi']
  manufacturing_facility_id varchar [note: 'Reference to the plant entity that houses the equipment.']
  parent_equipment_id varchar [note: 'Self-referencing FK on equipment (parent_equipment_id)']
  production_line_id varchar [note: 'Reference to the production line on which the equipment operates.']
  work_center_id varchar [note: 'The work center id of the equipment record']
  acquisition_cost decimal(12,2) [note: 'Purchase price paid for the equipment.']
  asset_tag varchar [note: 'Internal tag or barcode used to physically label the equipment.']
  calibration_due_date date [note: 'Scheduled date for the next calibration.']
  capacity_units varchar [note: 'Unit of measure for the equipment\'s capacity.']
  capacity_value decimal(12,2) [note: 'Numeric capacity of the equipment expressed in the specified units.']
  code varchar [note: 'The equipment code of the equipment record']
  compliance_gmp boolean [note: 'Indicates whether the equipment complies with GMP standards.']
  created_timestamp timestamp [note: 'The created timestamp of the equipment record']
  currency varchar [note: 'Currency in which the acquisition cost is expressed.']
  department varchar [note: 'Organizational department responsible for the equipment.']
  depreciation_end_date date [note: 'Date when the equipment is fully depreciated.']
  depreciation_method varchar [note: 'Accounting method used to depreciate the equipment.']
  depreciation_start_date date [note: 'Date when depreciation of the equipment begins.']
  description varchar [note: 'Free‑form text describing the equipment\'s purpose and characteristics.']
  energy_consumption_kwh decimal(12,2) [note: 'Total energy consumed by the equipment in kilowatt‑hours.']
  equipment_status varchar [note: 'Current operational state of the equipment.']
  equipment_type varchar [note: 'Category of equipment based on function or form factor.']
  hazard_classification varchar [note: 'Level of hazard associated with equipment operation.']
  install_date date [note: 'The install date of the equipment record']
  installation_date date [note: 'Date the equipment was installed and became operational.']
  last_calibration_date date [note: 'Date when the equipment was last calibrated.']
  last_maintenance_date date [note: 'Date of the most recent scheduled maintenance.']
  location_code varchar [note: 'Code identifying the plant or facility where the equipment resides.']
  maintenance_cost decimal(12,2) [note: 'Cost incurred for the most recent maintenance activity.']
  maintenance_frequency_days varchar [note: 'Number of days between routine maintenance events.']
  manufacturer varchar [note: 'Company that produced the equipment.']
  model_number varchar [note: 'Model identifier assigned by the manufacturer.']
  mtbf_hours decimal(10,2) [note: 'Average operating hours between equipment failures.']
  mttr_hours decimal(10,2) [note: 'Average time required to repair equipment after a failure.']
  name varchar [note: 'Human‑readable name or designation of the equipment.']
  next_calibration_date date [note: 'The next calibration date of the equipment record']
  next_maintenance_date date [note: 'The next maintenance date of the equipment record']
  next_maintenance_due date [note: 'Planned date for the next maintenance activity.']
  oee_actual decimal(5,2) [note: 'Measured Overall Equipment Effectiveness percentage.']
  oee_target decimal(5,2) [note: 'Target Overall Equipment Effectiveness percentage.']
  power_rating_kw decimal(10,2) [note: 'Maximum power consumption of the equipment in kilowatts.']
  purchase_date date [note: 'Date the equipment was purchased.']
  safety_rating varchar [note: 'Safety classification of the equipment.']
  serial_number varchar [note: 'Unique serial number stamped on the equipment.']
  source_system_code varchar [note: 'The source system code of the equipment record']
  total_usage_hours decimal(10,2) [note: 'Cumulative operating hours since installation.']
  updated_timestamp timestamp [note: 'The updated timestamp of the equipment record']
  voltage decimal(10,2) [note: 'Nominal operating voltage of the equipment.']
  warranty_end_date date [note: 'Date when the equipment warranty expires.']
  warranty_start_date date [note: 'Date when the equipment warranty period begins.']
  weight_kg decimal(10,2) [note: 'Weight of the equipment in kilograms.']

  Note: 'Master reference table for equipment. Referenced by equipment_id.'
}

Table consumer.shopper {
  shopper_id varchar [pk, note: 'Unique surrogate identifier for every end consumer and shopper record in the Consumer Goods golden master. This is the anchor primary key for the entire consumer domain — all other consumer entities reference this record. Role: MASTER_PARTY.']
  consumer_segment_id varchar [note: 'Foreign key linking to marketing.consumer_segment. Business justification: Shopper-to-segment assignment drives personalization, campaign targeting, and CLTV modeling. Marketing teams must know which consumer segment each shopper belongs to for 1:1 campaign execution and seg']
  preferred_retail_store_id varchar [note: 'Foreign key linking to sales.retail_store. Business justification: CPG consumer profiles track a shopper\'s preferred/home store for personalization, store-level marketing, and loyalty program management. `preferred_store_banner` is a denormalized text field; replacin']
  acquisition_channel varchar [note: 'The channel through which the consumer was first acquired or registered. Supports marketing attribution, channel ROI analysis, and consumer journey analytics. Aligns with DTC, POS, and loyalty enrollment touchpoints. [ENUM-REF-CANDIDATE: dtc_web|dtc_mobile|retail_pos|loyalty_enrollment|social_media|event|referral|wholesale — promote to reference product]']
  acquisition_date date [note: 'The date on which the consumer was first acquired or registered in the system (yyyy-MM-dd). Used for cohort analysis, consumer tenure calculations, and lifecycle marketing programs.']
  age_verified boolean [note: 'Indicates whether the consumer has passed age verification for access to age-restricted products (e.g., alcohol, tobacco, certain health products). TRUE = age verified; FALSE = not verified. Required for regulatory compliance with FDA and CPSC age-restriction mandates.']
  amount decimal(18,4) [note: 'The amount of the shopper record']
  birth_date date [note: 'The consumer\'s date of birth in ISO 8601 format (yyyy-MM-dd). Used for age verification (e.g., age-restricted products), lifecycle segmentation, birthday loyalty rewards, and regulatory compliance.']
  ccpa_subject boolean [note: 'Indicates whether this consumer is a California resident subject to CCPA protections. TRUE = CCPA applies; FALSE = not a CCPA subject. Drives opt-out of sale workflows, data deletion requests, and disclosure obligations.']
  code varchar [note: 'The shopper code of the shopper record']
  consent_timestamp timestamp [note: 'The exact date and time (ISO 8601 with timezone) when the consumer last provided or updated their privacy consent. Provides the auditable consent record required by GDPR Article 7 and CCPA. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  consent_version varchar [note: 'The version identifier of the privacy policy and consent notice that the consumer accepted (e.g., \'v2.3\', \'2024-01\'). Used to track consent currency and trigger re-consent workflows when policy versions are updated.']
  consumer_type varchar [note: 'Categorical classification of the shopper record distinguishing individual consumers, household accounts, small business buyers, enrolled loyalty program members, and guest/anonymous shoppers. Drives CRM segmentation and personalization strategy.']
  country_code varchar [note: 'The consumer\'s country of residence in ISO 3166-1 alpha-3 format (e.g., \'USA\', \'GBR\', \'DEU\'). Determines applicable regulatory framework (GDPR for EU, CCPA for California), tax jurisdiction, and localized product availability.']
  created_timestamp timestamp [note: 'The exact date and time (ISO 8601 with timezone) when this shopper record was first created in the Consumer Goods data platform. Serves as the authoritative audit trail for record creation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  currency_code varchar [note: 'The currency code of the shopper record']
  data_sharing_consent boolean [note: 'Indicates whether the consumer has consented to sharing their personal data with third-party partners (e.g., retail partners, market research firms such as Nielsen IQ). TRUE = consented; FALSE = not consented. Critical for GDPR Article 6 lawful basis and CCPA opt-out compliance.']
  date_of_birth date [note: 'The date of birth of the shopper record']
  description varchar [note: 'The shopper description of the shopper record']
  display_name varchar [note: 'The consumer\'s preferred display name or alias used in digital channels, loyalty portals, and personalized marketing communications. May differ from legal name.']
  effective_from date [note: 'The effective from of the shopper record']
  effective_until date [note: 'The effective until of the shopper record']
  email varchar [note: 'The email of the shopper record']
  email_opt_in boolean [note: 'Indicates whether the consumer has provided explicit opt-in consent to receive email marketing communications. TRUE = consented; FALSE = not consented or withdrawn. Mandatory suppression flag for GDPR/CCPA compliance in all outbound email campaigns.']
  family_name varchar [note: 'The consumer\'s legal family name (surname) as captured at registration or identity verification. Combined with given_name to form the full legal identity for CRM, personalization, and regulatory compliance.']
  first_name varchar [note: 'The first name of the shopper record']
  first_purchase_date date [note: 'The first purchase date of the shopper record']
  gdpr_subject boolean [note: 'Indicates whether this consumer is a GDPR data subject (i.e., located in the EU/EEA and subject to GDPR protections). TRUE = GDPR applies; FALSE = not a GDPR subject. Drives data processing lawful basis checks, right-to-erasure workflows, and data portability requests.']
  gender varchar [note: 'The consumer\'s self-reported gender identity. Used for consumer segmentation, personalized product recommendations, and inclusive marketing. Collected with explicit consent per GDPR/CCPA.']
  given_name varchar [note: 'The consumer\'s legal given name (first name) as captured at registration or identity verification. Used for personalized communications, CRM, and regulatory subject identification under GDPR/CCPA.']
  identity_verification_date date [note: 'The date on which the consumer\'s identity was most recently verified (yyyy-MM-dd). Used to assess verification recency and trigger re-verification workflows for high-risk transactions or regulatory audits.']
  identity_verified boolean [note: 'Indicates whether the consumer\'s identity has been formally verified through an identity verification process (e.g., email confirmation, document verification, phone OTP). TRUE = verified; FALSE = unverified. Affects eligibility for high-value loyalty redemptions and DTC account features.']
  is_active boolean [note: 'The is active of the shopper record']
  language_preference varchar [note: 'The language preference of the shopper record']
  last_activity_timestamp timestamp [note: 'The last activity timestamp of the shopper record']
  last_name varchar [note: 'The last name of the shopper record']
  last_purchase_date date [note: 'The date of the consumer\'s most recent confirmed purchase transaction across any channel (DTC, retail POS, e-commerce). Used for recency scoring in RFM (Recency, Frequency, Monetary) analysis, churn prediction, and re-engagement campaign triggers.']
  lifecycle_status varchar [note: 'Current state of the consumer record in the lifecycle. \'active\' = engaged consumer; \'inactive\' = no activity within defined period; \'opted_out\' = consumer has withdrawn consent and must not be contacted; \'suspended\' = account temporarily restricted; \'pending_verification\' = identity not yet confirmed. Drives GDPR/CCPA suppression logic.']
  lifetime_value decimal(18,4) [note: 'The lifetime value of the shopper record']
  loyalty_enrollment_date date [note: 'The date the consumer formally enrolled in the loyalty program (yyyy-MM-dd). Used to calculate loyalty tenure, anniversary rewards, and cohort-based loyalty analytics.']
  loyalty_points_balance decimal(18,4) [note: 'The current redeemable loyalty points balance held by the consumer. This is the raw operational balance as recorded in the loyalty system — not a calculated aggregate. Used for redemption eligibility checks and consumer-facing balance display.']
  loyalty_status varchar [note: 'The loyalty status of the shopper record']
  loyalty_tier varchar [note: 'The consumer\'s current tier within the loyalty program (e.g., Bronze, Silver, Gold, Platinum). Determines benefit entitlements, promotional eligibility, and personalized offer thresholds. Recalculated periodically based on purchase activity.']
  marketing_opt_in boolean [note: 'The marketing opt in of the shopper record']
  name varchar [note: 'The shopper name of the shopper record']
  notes varchar [note: 'The notes of the shopper record']
  nps_score varchar [note: 'The most recently recorded Net Promoter Score (NPS) for this consumer, on a scale of 0–10. NPS is the industry-standard metric for measuring consumer loyalty and likelihood to recommend. Supports consumer satisfaction analytics and brand health reporting.']
  nps_survey_date date [note: 'The date on which the most recent NPS survey response was recorded for this consumer. Used to assess recency of satisfaction data and trigger re-survey workflows.']
  phone varchar [note: 'The phone of the shopper record']
  postal_code varchar [note: 'The consumer\'s residential postal or ZIP code. Used for geographic segmentation, regional marketing campaigns, distribution territory assignment, and retail proximity analysis (OSA, planogram relevance).']
  preferred_currency varchar [note: 'The consumer\'s preferred transaction currency in ISO 4217 three-letter code (e.g., \'USD\', \'EUR\', \'GBP\'). Used for DTC pricing display, loyalty point valuation, and cross-border e-commerce personalization.']
  preferred_language varchar [note: 'The consumer\'s preferred communication language in IETF BCP 47 format (e.g., \'en-US\', \'fr-FR\', \'es-MX\'). Drives localization of marketing communications, product labels, and digital experience personalization.']
  primary_address_code varchar [note: 'The primary address id of the shopper record']
  primary_email varchar [note: 'The primary email address used for all consumer communications, loyalty program enrollment, DTC order confirmations, and digital marketing. Serves as the principal digital identity key in CRM and Salesforce Consumer Goods Cloud.']
  primary_phone varchar [note: 'The consumer\'s primary contact phone number in E.164 international format. Used for SMS marketing, two-factor authentication, consumer care, and DTC order notifications.']
  push_notification_opt_in boolean [note: 'Indicates whether the consumer has opted in to receive push notifications via the brand\'s mobile application. TRUE = opted in; FALSE = opted out or not set. Drives mobile engagement campaign eligibility.']
  quantity decimal(18,4) [note: 'The quantity of the shopper record']
  record_source_system varchar [note: 'The record source system of the shopper record']
  registration_source_url varchar [note: 'The URL or digital touchpoint from which the consumer completed their registration (e.g., brand website landing page, DTC checkout, loyalty sign-up page). Supports digital marketing attribution and campaign source tracking.']
  shopper_status varchar [note: 'The shopper status of the shopper record']
  sms_opt_in boolean [note: 'Indicates whether the consumer has provided explicit opt-in consent to receive SMS/text marketing communications. TRUE = consented; FALSE = not consented or withdrawn. Required for TCPA compliance in the US and equivalent regulations globally.']
  source_system_code varchar [note: 'The source system code of the shopper record']
  source_system_consumer_ref varchar [note: 'The consumer\'s unique identifier as recorded in the originating source system (e.g., SAP Business Partner ID, Salesforce Contact ID, DTC platform user ID). Enables cross-system reconciliation, MDM golden record matching, and audit traceability back to the system of record.']
  uom varchar [note: 'The uom of the shopper record']
  updated_timestamp timestamp [note: 'The exact date and time (ISO 8601 with timezone) when this shopper record was most recently modified. Used for change data capture (CDC), incremental ETL processing, and audit compliance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']

  Note: 'Golden master record for every end consumer and shopper across B2C and DTC channels. Stores consumer identity (full name, date of birth, gender), contact details (primary email, phone), language and currency preferences, acquisition metadata (channel, date), consumer lifecycle status (active/inactive/opted-out), identity verification status, and source system references. This is the single anchor entity for the consumer domain — all other consumer entities reference this record via shopper_id. Supports CRM, personalization, regulatory compliance (GDPR/CCPA subject identification), and consumer 360-degree view.'
}

Table consumer.household {
  household_id varchar [pk, note: 'Unique surrogate identifier for the household record in the Consumer Goods lakehouse. Primary key for all household-level analytics, loyalty pooling, and basket analysis.']
  consumer_segment_id varchar [note: 'Foreign key linking to marketing.consumer_segment. Business justification: Household-level segmentation is standard in consumer goods for trade promotion targeting, media planning, and panel analysis. The existing market_segment text field is a denormalized segment label; re']
  merged_from_household_id varchar [note: 'Reference to the source household record that was merged into this household during deduplication or household consolidation. Null if no merge has occurred. Supports data lineage and audit trails.']
  shopper_id varchar [note: 'Reference to the designated primary shopper or head-of-household consumer profile. Used to anchor loyalty program pooling and personalization targeting.']
  address_summary varchar [note: 'The address summary of the household record']
  amount decimal(18,4) [note: 'The amount of the household record']
  brand_affinity_flag boolean [note: 'Indicates whether the household has demonstrated strong brand loyalty to the company\'s portfolio based on repeat purchase patterns and SOV (Share of Voice) analysis. Used for brand marketing investment decisions.']
  ccpa_opt_out_flag boolean [note: 'Indicates whether the household has exercised the right to opt out of the sale of personal information under CCPA (California Consumer Privacy Act). Mandatory compliance field for California-resident households.']
  children_present_flag boolean [note: 'Indicates whether children under 18 are present in the household. Key trigger for cross-sell targeting of baby, child health, and family-oriented CPG/FMCG product categories.']
  cltv_band varchar [note: 'Categorical CLTV (Customer Lifetime Value) band assigned to the household based on historical purchase behavior and predictive modeling. Used for investment prioritization in trade promotion and personalization.']
  code varchar [note: 'Externally-known alphanumeric business identifier for the household, used in CRM, loyalty, and DTC channel communications. Distinct from the surrogate primary key.']
  consent_last_updated_timestamp timestamp [note: 'Timestamp of the most recent update to any consent or privacy preference for the household. Critical for GDPR/CCPA audit trails and demonstrating lawful basis for data processing.']
  country_code varchar [note: 'ISO 3166-1 alpha-3 country code representing the country of the household\'s primary residence. Used for regulatory compliance (GDPR, CCPA) and international market segmentation.']
  created_timestamp timestamp [note: 'Timestamp when the household record was first created in the system. Used for data lineage, audit trails, and GDPR/CCPA compliance reporting.']
  currency_code varchar [note: 'The currency code of the household record']
  data_source varchar [note: 'Originating system or channel from which the household record was first created or last enriched. Used for data lineage, quality scoring, and source system reconciliation in the lakehouse. [ENUM-REF-CANDIDATE: crm|loyalty_program|ecommerce|panel|pos|dtc|manual — 7 candidates stripped; promote to reference product]']
  description varchar [note: 'The household description of the household record']
  digital_engagement_flag boolean [note: 'Indicates whether the household actively engages with the brand through digital channels (e-commerce, mobile app, social media). Used for DTC (Direct to Consumer) channel strategy and omnichannel personalization.']
  dissolution_date date [note: 'Date on which the household was dissolved, merged, or deactivated. Null for active households. Used for lifecycle reporting and GDPR/CCPA data retention compliance.']
  dwelling_type varchar [note: 'Type of residential dwelling occupied by the household. Used for product category targeting (e.g., home care, cleaning products) and basket size normalization in CPG analytics.']
  effective_from date [note: 'The effective from of the household record']
  effective_until date [note: 'The effective until of the household record']
  estimated_size varchar [note: 'Estimated number of individuals residing in the household. Used for basket size normalization, per-capita consumption analysis, and product volume forecasting in S&OP (Sales and Operations Planning).']
  formation_date date [note: 'Date on which the household record was first established in the system, representing when the household unit was recognized as a distinct entity for loyalty and analytics purposes.']
  gdpr_consent_flag boolean [note: 'Indicates whether the household has provided valid consent for data processing under GDPR (General Data Protection Regulation). Mandatory for EU-resident households before any marketing or analytics processing.']
  geographic_region varchar [note: 'Broad geographic region of the household\'s residence (e.g., Northeast, Southeast, Midwest, West, Southwest). Used for regional demand planning and distribution channel management.']
  has_children boolean [note: 'The has children of the household record']
  household_status varchar [note: 'Current lifecycle state of the household record. \'merged\' indicates consolidation with another household; \'dissolved\' indicates the household no longer exists as a unit.']
  household_type varchar [note: 'Categorical classification of the household composition used for segmentation and cross-sell targeting in CPG/FMCG analytics. [ENUM-REF-CANDIDATE: single|couple|family|multi_generational|shared_living|other — promote to reference product if values expand]']
  income_band varchar [note: 'Estimated annual household income bracket used for consumer segmentation, RSP (Recommended Selling Price) sensitivity analysis, and premium product targeting. Derived from third-party panel data or self-reported.']
  income_bracket varchar [note: 'The income bracket of the household record']
  last_updated_timestamp timestamp [note: 'Timestamp of the most recent modification to the household record. Used for change data capture (CDC) in the Databricks lakehouse Silver layer and data freshness monitoring.']
  life_stage varchar [note: 'Life stage classification of the household used for targeted marketing and NPD (New Product Development) insights (e.g., young_single, young_couple_no_children, family_with_young_children, family_with_teens, empty_nester, retired). Enables cross-sell triggers such as recommending baby products when life stage transitions. [ENUM-REF-CANDIDATE: young_single|young_couple_no_children|family_with_young_children|family_with_teens|empty_nester|retired|other — promote to reference product]']
  lifecycle_stage varchar [note: 'The lifecycle stage of the household record']
  loyalty_enrollment_date date [note: 'Date on which the household was enrolled in the loyalty program. Used to calculate loyalty tenure, tier progression timelines, and CLTV (Customer Lifetime Value) cohort analysis.']
  loyalty_points_balance decimal(18,2) [note: 'Current unredeemed loyalty points balance accumulated at the household level across all member consumers. Supports household-level pooling for CPG/FMCG loyalty programs.']
  loyalty_tier varchar [note: 'Current loyalty program tier of the household based on cumulative purchase activity. Drives reward multipliers, exclusive offers, and CLTV (Customer Lifetime Value) segmentation.']
  marketing_opt_in_flag boolean [note: 'Indicates whether the household has opted in to receive marketing communications (email, SMS, push notifications) from the brand. Governs eligibility for trade promotion and consumer engagement campaigns.']
  name varchar [note: 'Human-readable label for the household, typically the primary shopper\'s surname or a family name used for display in CRM and loyalty program communications.']
  notes varchar [note: 'The notes of the household record']
  nps_score varchar [note: 'Most recent NPS (Net Promoter Score) recorded for the household, ranging from 0 to 10. Used to classify households as Promoters (9-10), Passives (7-8), or Detractors (0-6) for consumer engagement programs.']
  nps_survey_date date [note: 'Date on which the most recent NPS (Net Promoter Score) survey response was recorded for the household. Used to assess recency of satisfaction data for consumer engagement decisions.']
  number_of_children varchar [note: 'The number of children of the household record']
  panel_member_flag boolean [note: 'Indicates whether the household is an active member of a consumer research panel (e.g., Nielsen IQ Consumer Panel). Panel households provide purchase diary data used for market intelligence and SOM (Share of Market) analysis.']
  pet_owner_flag boolean [note: 'Indicates whether the household owns pets. Used for targeted marketing of pet care product categories and cross-sell recommendations within the CPG/FMCG portfolio.']
  postal_code varchar [note: 'Postal or ZIP code of the household\'s primary residence. Used for geographic clustering, DRP (Distribution Requirements Planning), and localized trade promotion targeting.']
  preferred_language varchar [note: 'BCP 47 language tag representing the household\'s preferred communication language (e.g., en-US, es-MX, fr-FR). Used for localized marketing content, product labeling compliance, and consumer engagement personalization.']
  primary_channel varchar [note: 'The dominant channel through which the household makes purchases. Used for DTC (Direct to Consumer) strategy, channel mix analysis, and trade promotion targeting.']
  primary_retailer_banner varchar [note: 'The retail banner or chain where the household conducts the majority of its grocery or consumer goods shopping (e.g., Walmart, Target, Kroger). Used for OSA (On Shelf Availability) and POG (Planogram) analytics.']
  private_label_buyer_flag boolean [note: 'Indicates whether the household regularly purchases private label or store-brand products in addition to or instead of branded CPG products. Used for competitive analysis and brand switching risk assessment.']
  purchase_frequency_band varchar [note: 'Categorical band representing how frequently the household makes purchases across CPG/FMCG categories. Derived from POS (Point of Sale) transaction history and used for demand sensing and replenishment planning.']
  quantity decimal(18,4) [note: 'The quantity of the household record']
  record_source_system varchar [note: 'The record source system of the household record']
  region varchar [note: 'The region of the household record']
  size varchar [note: 'The size of the household record']
  source_system_code varchar [note: 'The source system code of the household record']
  tenure_type varchar [note: 'Indicates whether the household owns or rents their residence. Used for home improvement and home care product category targeting and consumer segmentation.']
  uom varchar [note: 'The uom of the household record']
  updated_timestamp timestamp [note: 'The updated timestamp of the household record']

  Note: 'Household unit grouping multiple shoppers who share a residence and purchasing decisions. Captures household demographics (estimated size, income band, life stage), formation date, status, and primary shopper designation. Enables household-level basket analysis, cross-sell targeting (e.g., recommending baby products when life stage changes), and loyalty program household pooling for CPG/FMCG brands.'
}

Table consumer.address {
  address_id varchar [pk, note: 'Unique surrogate identifier for each consumer address record in the Consumer Goods DTC/B2C platform. Primary key for the consumer_address data product.']
  household_id varchar [note: 'The household id of the address record']
  shopper_id varchar [note: 'Reference to the consumer/shopper profile this address belongs to. Links the address record to the master consumer party in the CRM and DTC systems.']
  address_status varchar [note: 'Current lifecycle status of the address record. Active addresses are eligible for order fulfillment and marketing. Inactive addresses are retained for historical reporting. Deleted status supports GDPR right-to-erasure soft-delete workflows.']
  address_type varchar [note: 'Classification of the address by its business purpose. Billing addresses are used for invoicing and financial compliance; shipping addresses drive DTC order fulfillment and last-mile logistics; home and work addresses support personalized marketing and consumer segmentation.']
  amount decimal(18,4) [note: 'The amount of the address record']
  census_tract varchar [note: 'U.S. Census Bureau census tract code for the address location. Enables demographic overlay analysis, market penetration reporting by socioeconomic segment, and trade area planning for consumer goods distribution.']
  city varchar [note: 'City or municipality of the consumer\'s address. Used for geographic segmentation, regional marketing campaigns, distribution zone assignment, and regulatory data residency tracking.']
  code varchar [note: 'The address code of the address record']
  consent_captured boolean [note: 'Indicates whether explicit consumer consent was obtained for storing and processing this address record under applicable privacy regulations (GDPR/CCPA). True indicates consent is on file; False requires consent collection before marketing use.']
  consent_date date [note: 'Date on which the consumer provided consent for storage and processing of this address record. Required for GDPR Article 7 compliance documentation and CCPA opt-in audit trails.']
  country_code varchar [note: 'Three-letter ISO 3166-1 alpha-3 country code of the consumer\'s address (e.g., USA, GBR, DEU). Drives GDPR/CCPA data residency compliance, international shipping eligibility, tax jurisdiction, and regulatory reporting.']
  created_timestamp timestamp [note: 'Date and time when this address record was first created in the system. Supports GDPR Article 30 records of processing activities, data lineage tracking, and audit trail requirements for consumer data governance.']
  currency_code varchar [note: 'The currency code of the address record']
  data_quality_score decimal(5,2) [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  data_residency_region varchar [note: 'Geographic data residency classification for this address record, indicating the regulatory jurisdiction governing data storage and processing. Drives GDPR (EU), CCPA (US/CA), and other regional privacy law compliance for data localization requirements.']
  deliverability_score decimal(5,2) [note: 'Numeric score (0.00–100.00) representing the likelihood that a physical shipment or direct mail piece will be successfully delivered to this address. Derived from address validation provider output. Supports carrier selection and DTC fulfillment risk management.']
  description varchar [note: 'The address description of the address record']
  dma_code varchar [note: 'Nielsen Designated Market Area (DMA) code for the address location. Used for media planning, Share of Voice (SOV) analysis, and regional brand marketing investment allocation in consumer goods trade promotion programs.']
  do_not_mail boolean [note: 'Indicates whether the consumer has opted out of physical direct mail marketing to this address. When True, this address must be suppressed from direct mail campaign execution lists. Supports GDPR right-to-object and CCPA opt-out compliance.']
  dpv_confirmation varchar [note: 'USPS Delivery Point Validation confirmation code indicating the deliverability of the address. Y=Confirmed deliverable, S=Confirmed deliverable (secondary info missing), D=Confirmed deliverable (secondary info present but unneeded), N=Not confirmed. Critical for DTC fulfillment and direct mail campaigns.']
  effective_date date [note: 'The date from which this address record is considered valid and active for business use. Supports bi-temporal data modeling, address history tracking, and GDPR right-to-erasure compliance by enabling point-in-time address reconstruction.']
  effective_from date [note: 'The effective from of the address record']
  effective_until date [note: 'The effective until of the address record']
  expiry_date date [note: 'The date after which this address record is no longer valid for business use. Null indicates an open-ended active address. Used for address lifecycle management, historical reporting, and GDPR data minimization compliance.']
  format_type varchar [note: 'Classification of the address format to guide formatting, validation, and carrier routing logic. PO Box addresses may not be eligible for certain DTC carriers; military addresses (APO/FPO/DPO) require specific handling; rural route addresses may have extended delivery windows.']
  geocoding_accuracy varchar [note: 'Precision level of the geocoded latitude/longitude coordinates for this address. Rooftop indicates exact parcel-level geocoding; range_interpolated indicates interpolation between street numbers; geometric_center indicates centroid of a polygon. Impacts reliability of proximity-based analytics.']
  is_active boolean [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  is_default_billing boolean [note: 'Indicates whether this address is the consumer\'s default billing address for payment processing and invoice generation. Used in DTC checkout flows and financial compliance reporting.']
  is_default_shipping boolean [note: 'Indicates whether this address is the consumer\'s default shipping destination for DTC orders. Distinct from is_primary as a consumer may have a primary home address but a different default shipping address (e.g., workplace).']
  is_primary boolean [note: 'Indicates whether this is the consumer\'s primary address record for the given address type. When True, this address is used as the default for order fulfillment, marketing communications, and regulatory correspondence.']
  is_validated boolean [note: 'The is validated of the address record']
  latitude decimal(10,7) [note: 'Geographic latitude coordinate of the consumer\'s address in decimal degrees (WGS84 datum). Enables geocoded proximity analysis, delivery zone optimization, and location-based personalized marketing.']
  line_1 varchar [note: 'Primary street address line including house/building number and street name. Core component of the consumer\'s physical location used for DTC order fulfillment, direct mail marketing, and GDPR/CCPA data residency compliance.']
  line_2 varchar [note: 'Secondary address line for apartment, suite, unit, floor, or building designations. Supplements address_line_1 to ensure complete and accurate delivery routing for DTC shipments.']
  line_3 varchar [note: 'Tertiary address line for additional location details such as neighborhood, district, or care-of designations. Used in international address formats where three address lines are required.']
  longitude decimal(10,7) [note: 'Geographic longitude coordinate of the consumer\'s address in decimal degrees (WGS84 datum). Used alongside latitude for geocoded proximity analysis, store locator features, and last-mile delivery optimization.']
  name varchar [note: 'The address name of the address record']
  notes varchar [note: 'The notes of the address record']
  plus4_code varchar [note: 'The four-digit USPS ZIP+4 extension code that narrows delivery to a specific block face or building. Enables postal presort discounts for direct mail campaigns and improves delivery precision for DTC shipments within the United States.']
  postal_code varchar [note: 'ZIP or postal code of the consumer\'s address. Used for last-mile delivery routing, trade area analysis, demographic segmentation, and carrier rate determination in DTC fulfillment.']
  quantity decimal(18,4) [note: 'The quantity of the address record']
  record_source_system varchar [note: 'The record source system of the address record']
  residential_indicator varchar [note: 'Classification of the address as residential or commercial. Impacts carrier surcharge calculations (UPS/FedEx residential delivery fees), marketing segmentation, and DTC fulfillment cost modeling.']
  source varchar [note: 'The originating channel or system through which this address was captured. Supports data lineage, source quality scoring, and GDPR/CCPA consent audit trails. [ENUM-REF-CANDIDATE: crm|dtc_checkout|loyalty_enrollment|call_center|mobile_app|web_portal|third_party|manual_entry — promote to reference product]']
  source_record_code varchar [note: 'Conformed governance attribute source_record_id.']
  source_system_code varchar [note: 'The native record identifier from the originating operational system of record (e.g., Salesforce Consumer Goods Cloud Contact Address ID, SAP S/4HANA Business Partner Address GUID). Enables cross-system reconciliation and data lineage tracing in the Silver Layer.']
  standardized_address varchar [note: 'The full address formatted as a single standardized string per USPS/UPU postal standards after address validation and normalization (e.g., \'123 MAIN ST APT 4B, CHICAGO IL 60601-1234\'). Used as the canonical address for carrier label generation and deduplication.']
  state_province varchar [note: 'State, province, or administrative region of the consumer\'s address using ISO 3166-2 subdivision codes (e.g., US-CA, CA-ON). Supports tax jurisdiction determination, regional compliance, and territory-based sales reporting.']
  timezone varchar [note: 'IANA time zone identifier for the address location (e.g., America/New_York, Europe/London). Used for scheduling personalized marketing communications at optimal local times and for regulatory compliance with time-sensitive consumer notifications.']
  uom varchar [note: 'The uom of the address record']
  updated_timestamp timestamp [note: 'Date and time when this address record was last modified. Used for change data capture (CDC) in the Databricks Silver Layer pipeline, data freshness monitoring, and GDPR data accuracy compliance tracking.']
  valid_from_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  valid_to_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  validation_provider varchar [note: 'Name of the third-party address validation service used to verify this address (e.g., USPS CASS, SmartyStreets, Loqate, Google Maps API). Supports audit trails for data quality governance and vendor performance tracking.']
  validation_status varchar [note: 'Current validation state of the address record as determined by address verification services (e.g., USPS CASS, SmartyStreets, Loqate). Validated addresses reduce failed DTC deliveries and return-to-sender costs. Failed addresses require consumer outreach before order fulfillment.']
  validation_timestamp timestamp [note: 'Date and time when the address was last validated by the address verification service. Used to determine if re-validation is needed based on data freshness policies and to support data quality SLA reporting.']

  Note: 'Physical and digital address records associated with a consumer/shopper. Stores address type (billing, shipping, home, work), street lines, city, state/province, postal code, country, geocoordinates (latitude/longitude), address validation status, address source, effective date, and expiry date. Supports DTC order fulfillment, personalized marketing, and regulatory compliance for GDPR/CCPA data residency requirements.'
}

Table consumer.loyalty_account {
  loyalty_account_id varchar [pk, note: 'Loyalty account ID of the existing member who referred this consumer to the program. Used for referral reward attribution, viral growth tracking, and network-effect analysis in consumer retention programs.']
  enrollment_campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: Loyalty accounts are created or tier-upgraded via specific enrollment campaigns. Tracking which campaign drove loyalty enrollment is required for loyalty program growth reporting, campaign ROI, and ac']
  retail_store_id varchar [note: 'Reference to the consumer\'s preferred or most frequently visited retail store location. Used for store-level loyalty analytics, On Shelf Availability (OSA) correlation, and localized promotion targeting.']
  shopper_id varchar [note: 'Reference to the consumer profile who owns this loyalty account. Links to the consumer master record in the Consumer domain.']
  account_number varchar [note: 'Externally visible, human-readable membership number assigned to the consumer at enrollment. Printed on loyalty cards, referenced in consumer communications, and used for in-store identification. Serves as the BUSINESS_IDENTIFIER for this MASTER_AGREEMENT entity.']
  account_status varchar [note: 'Current lifecycle state of the loyalty account. \'active\' = fully operational; \'suspended\' = temporarily restricted (e.g., fraud review); \'closed\' = permanently deactivated; \'pending\' = enrollment not yet confirmed; \'frozen\' = points locked pending investigation. Serves as the LIFECYCLE_STATUS for this MASTER_AGREEMENT entity.']
  account_type varchar [note: 'Classification of the loyalty account indicating whether it belongs to an individual consumer, a household unit, a small business buyer, or a coalition partner program. Drives eligibility rules and benefit structures.']
  amount decimal(18,4) [note: 'The amount of the loyalty account record']
  cltv_segment varchar [note: 'Consumer\'s current Customer Lifetime Value (CLTV) segment classification derived from purchase history, points activity, and predictive modeling. Used for personalized promotion targeting, retention investment prioritization, and Trade Promotion Optimization (TPO). Not a calculated metric — this is a segment label assigned by the analytics/ML pipeline.']
  code varchar [note: 'The loyalty account code of the loyalty account record']
  communication_preference varchar [note: 'Consumer\'s preferred channel for receiving loyalty program communications (e.g., points balance updates, tier change notifications, promotional offers). Drives outbound communication channel selection in CRM and marketing automation.']
  consent_data_sharing boolean [note: 'Indicates whether the consumer has consented to sharing their loyalty data with third-party partners (e.g., retail partners, coalition program members). Required for GDPR and CCPA compliance. True = consented; False = not consented.']
  consent_marketing boolean [note: 'Indicates whether the consumer has provided explicit opt-in consent to receive marketing communications related to the loyalty program. Required for GDPR Article 6 lawful basis and CCPA compliance. True = consented; False = not consented.']
  consent_timestamp timestamp [note: 'Timestamp at which the consumer\'s most recent consent preferences were captured or last updated. Required for GDPR audit trail demonstrating when consent was obtained. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  country_code varchar [note: 'ISO 3166-1 alpha-3 three-letter country code representing the country in which the loyalty account is registered. Determines applicable regulatory framework (GDPR, CCPA, etc.), program rules, and currency.']
  created_timestamp timestamp [note: 'Timestamp at which this loyalty account record was first created in the system. Serves as the RECORD_AUDIT_CREATED field for this MASTER_AGREEMENT entity. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  currency_code varchar [note: 'The currency code of the loyalty account record']
  description varchar [note: 'The loyalty account description of the loyalty account record']
  effective_from date [note: 'The effective from of the loyalty account record']
  effective_until date [note: 'The effective until of the loyalty account record']
  enrollment_channel varchar [note: 'Channel through which the consumer enrolled in the loyalty program (e.g., web, mobile app, in-store, call center, partner, Direct-to-Consumer (DTC) platform). Used for channel attribution and acquisition cost analysis.']
  enrollment_date date [note: 'Calendar date on which the consumer formally enrolled in the loyalty program. Used to calculate membership tenure, anniversary rewards, and cohort-based retention analytics. Serves as EFFECTIVE_FROM for this MASTER_AGREEMENT entity.']
  enrollment_source_code varchar [note: 'Campaign or promotion source code associated with the consumer\'s enrollment event (e.g., a Trade Promotion Management (TPM) campaign code, QR code identifier, or referral code). Used for acquisition attribution and Trade Promotion Optimization (TPO) ROI analysis.']
  expiry_date date [note: 'Date on which the loyalty account is scheduled to expire or become inactive if no qualifying activity occurs. Nullable for open-ended programs. Serves as EFFECTIVE_UNTIL for this MASTER_AGREEMENT entity. Used for points liability forecasting and consumer re-engagement campaigns.']
  fraud_flag boolean [note: 'Indicates whether this loyalty account has been flagged for suspected fraudulent activity (e.g., points manipulation, account takeover, synthetic identity). True = flagged for review; False = no fraud concern. Triggers account suspension workflow.']
  fraud_review_date date [note: 'Date on which the most recent fraud review was conducted or scheduled for this account. Nullable if no fraud review has occurred. Used by the fraud operations team to track investigation timelines.']
  language_code varchar [note: 'ISO 639-1 two-letter language code (optionally with ISO 3166-1 country subtag) representing the consumer\'s preferred language for loyalty program communications (e.g., \'en\', \'fr\', \'es-MX\'). Supports multilingual global loyalty programs.']
  last_activity_date date [note: 'Date of the most recent qualifying activity (purchase, redemption, or engagement event) on this loyalty account. Used to determine account dormancy, trigger re-engagement campaigns, and apply activity-based points expiry policies.']
  last_earn_date date [note: 'Date of the most recent points earn event on this account. Used to assess earn recency for RFM (Recency, Frequency, Monetary) segmentation and to trigger earn-reminder communications.']
  last_redemption_date date [note: 'Date of the most recent points redemption event on this account. Used to assess redemption engagement, identify high-value redeemers, and support personalized redemption offer targeting.']
  lifetime_points_earned decimal(18,4) [note: 'Cumulative total of all points ever earned on this account since enrollment, including base earn, bonus earn, and promotional earn events. Never decremented by redemptions or expirations. Used for Customer Lifetime Value (CLTV) calculation and tier qualification history.']
  lifetime_points_expired decimal(18,4) [note: 'Cumulative total of all points that have expired on this account due to inactivity or program rules. Used for points liability release reporting in finance and consumer re-engagement analysis.']
  lifetime_points_redeemed decimal(18,4) [note: 'Cumulative total of all points ever redeemed on this account since enrollment. Used for redemption rate analysis, points liability reconciliation, and CLTV modeling.']
  loyalty_account_status varchar [note: 'The loyalty account status of the loyalty account record']
  membership_tier varchar [note: 'Current loyalty tier of the account reflecting the consumer\'s engagement and spend level (e.g., Standard, Silver, Gold, Platinum, Elite). Determines benefit multipliers, exclusive offers, and service levels. Reviewed periodically against tier_qualification_spend.']
  name varchar [note: 'The loyalty account name of the loyalty account record']
  notes varchar [note: 'The notes of the loyalty account record']
  nps_score varchar [note: 'Most recent Net Promoter Score (NPS) survey response from this consumer (0–10 scale). Used to segment consumers into Promoters (9–10), Passives (7–8), and Detractors (0–6) for loyalty program health monitoring and consumer engagement strategy.']
  nps_survey_date date [note: 'Date on which the most recent NPS survey response was captured for this consumer. Used to assess NPS data freshness and schedule next survey cadence.']
  opt_out_date date [note: 'Date on which the consumer formally opted out of the loyalty program or withdrew consent for data processing. Nullable if the consumer has not opted out. Required for GDPR right-to-erasure and CCPA opt-out compliance tracking.']
  points_balance decimal(18,4) [note: 'Current redeemable points balance on the loyalty account as of the last transaction processing. Represents the net of all earned, redeemed, adjusted, and expired points. Used for consumer-facing balance display and finance points liability reporting.']
  points_currency_code varchar [note: 'ISO 4217 three-letter currency code representing the monetary currency in which tier_qualification_spend and redemption values are denominated (e.g., USD, EUR, GBP). Supports multi-currency global loyalty programs.']
  points_expiry_policy varchar [note: 'Policy governing when unredeemed points on this account expire. Options include rolling 12-month inactivity, annual calendar expiry, never-expire, program-end expiry, or activity-based reset. Drives points liability forecasting and consumer communication triggers.']
  points_lifetime_earned varchar [note: 'The points lifetime earned of the loyalty account record']
  preferred_redemption_type varchar [note: 'Consumer\'s stated or inferred preferred method of redeeming loyalty points. Used for personalized redemption offer targeting and program design optimization. [ENUM-REF-CANDIDATE: discount|free_product|gift_card|charity|cashback|experience|travel|merchandise — promote to reference product if additional types are needed]']
  previous_tier varchar [note: 'The membership tier held by the consumer immediately before the most recent tier change. Used for tier transition analysis, win-back campaigns, and understanding tier migration patterns.']
  quantity decimal(18,4) [note: 'The quantity of the loyalty account record']
  record_source_system varchar [note: 'The record source system of the loyalty account record']
  source_system_code varchar [note: 'Code identifying the operational system of record from which this loyalty account record originated (e.g., Salesforce Consumer Goods Cloud (SFCGC), SAP S/4HANA). Used for data lineage tracking and Silver Layer reconciliation in the Databricks Lakehouse.']
  tier_effective_date date [note: 'Date on which the current membership tier became effective. Used to calculate tier tenure, assess tier stability, and trigger tier-anniversary benefits.']
  tier_qualification_spend decimal(18,2) [note: 'Cumulative qualifying purchase spend (in program currency) accumulated within the current tier review period. Compared against tier thresholds to determine tier upgrade, maintenance, or downgrade at the next tier review date.']
  tier_review_date date [note: 'Scheduled date on which the consumer\'s membership tier will be evaluated against tier_qualification_spend thresholds for potential upgrade, maintenance, or downgrade. Drives proactive consumer engagement campaigns before review.']
  uom varchar [note: 'The uom of the loyalty account record']
  updated_timestamp timestamp [note: 'Timestamp at which this loyalty account record was most recently modified. Used for incremental data pipeline processing, change data capture (CDC), and audit trail maintenance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']

  Note: 'Loyalty program membership account and transaction history for a consumer enrolled in a CPG brand loyalty or rewards program. Captures account master (program name, membership tier, enrollment date, points balance, lifetime points earned/redeemed, tier qualification spend, tier review date, status) and individual points movement events (earn, redeem, adjust, expire — with points amount, triggering event, associated order reference, balance snapshot, processing status, timestamp). Supports CLTV calculation, personalized promotions, consumer retention programs, and points liability reporting required by finance.'
}

Table consumer.loyalty_transaction {
  loyalty_transaction_id varchar [pk, note: 'Unique system-generated surrogate identifier for each loyalty points movement event. Serves as the primary key for the loyalty_transaction data product and enables precise audit trail reconciliation of all points currency activity.']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: Loyalty bonus-point events are triggered by specific marketing campaigns (double-points promotions, campaign earn events). Linking loyalty_transaction to campaign enables campaign ROI measurement via ']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Loyalty program cost attribution: earn and redemption transactions generate costs (points liability, redemption fulfillment) allocated to loyalty program cost centers. Consumer goods finance teams req']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Required for accounting loyalty point expense; loyalty_transaction must post expense to a GL account for financial statements.']
  journal_entry_id varchar [note: 'Foreign key linking to finance.journal_entry. Business justification: Loyalty points liability accounting: under IFRS 15/ASC 606, loyalty points are deferred revenue requiring journal entries at earn and redemption. Consumer goods auditors and finance teams require dire']
  loyalty_account_id varchar [note: 'Reference to the loyalty program account against which this points movement is recorded. Links the transaction to the member\'s running balance and tier status.']
  order_id varchar [note: 'Reference to the originating sales order or DTC purchase that triggered an earn or redemption event. Null for non-purchase-triggered transactions such as birthday bonuses, referral awards, or manual adjustments.']
  retail_store_id varchar [note: 'Foreign key linking to sales.retail_store. Business justification: Loyalty earn and redemption events occur at specific retail stores. Store-level loyalty analytics — which stores drive highest earn rates, redemption patterns by store — is a core CPG retail execution']
  reversal_reference_loyalty_transaction_id varchar [note: 'For reversal-type transactions, the loyalty_transaction_id of the original transaction being reversed. Enables bidirectional audit trail linking between original and reversal entries for points reconciliation.']
  shopper_id varchar [note: 'Reference to the end consumer or shopper who owns the loyalty account. Supports GDPR/CCPA data subject requests and consumer-level analytics across the CRM platform.']
  sku_id varchar [note: 'Reference to the specific SKU (Stock Keeping Unit) purchased or redeemed in this transaction. Populated for purchase-triggered earn events and product-reward redemptions. Enables product-level loyalty attribution and NPD performance analysis.']
  adjustment_notes varchar [note: 'Free-text narrative entered by a customer service agent or system process explaining the rationale for a manual points adjustment or reversal. Supports audit review and consumer dispute resolution.']
  adjustment_reason_code varchar [note: 'Standardized code identifying the business reason for manual point adjustments or reversals (e.g., GOODWILL, DATA_CORRECTION, FRAUD_REVERSAL, SYSTEM_ERROR, PROMOTION_CORRECTION). Populated only for adjust and reversal transaction types. [ENUM-REF-CANDIDATE: GOODWILL|DATA_CORRECTION|FRAUD_REVERSAL|SYSTEM_ERROR|PROMOTION_CORRECTION|COMPLAINT_RESOLUTION — promote to reference product]']
  amount decimal(18,4) [note: 'The amount of the loyalty transaction record']
  bonus_multiplier decimal(6,4) [note: 'The multiplier applied to the base earn rate for bonus transactions (e.g., 2.0 for double points, 1.5 for 50% bonus). Null for non-bonus transactions. Used to decompose total points awarded into base and bonus components for TPM ROI analysis.']
  channel varchar [note: 'The consumer engagement channel through which the triggering event occurred: ecommerce (third-party online), mobile_app (brand app), retail_store (physical POS), dtc_website (Direct-to-Consumer website), call_centre (agent-assisted), or kiosk (in-store self-service). Supports omnichannel loyalty analytics and channel attribution reporting.']
  code varchar [note: 'The loyalty transaction code of the loyalty transaction record']
  consent_verified boolean [note: 'Indicates whether the consumer\'s active consent for loyalty program participation and data processing was verified at the time of this transaction. Supports GDPR Article 7 and CCPA consent audit requirements.']
  country_code varchar [note: 'ISO 3166-1 alpha-3 country code of the market in which this loyalty transaction occurred (e.g., USA, GBR, DEU). Supports multi-market loyalty program reporting, regulatory compliance (GDPR for EU markets), and geographic performance analytics.']
  created_timestamp timestamp [note: 'The date and time at which this loyalty transaction record was first created in the source system. Serves as the system audit creation timestamp for data lineage, reconciliation, and SOX compliance.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the monetary_value field (e.g., USD, EUR, GBP). Supports multi-currency loyalty programs operating across international markets.']
  data_retention_flag boolean [note: 'Indicates whether this transaction record is subject to a data retention hold, preventing deletion or anonymization beyond the standard retention period. Set to True for records under legal hold, active fraud investigation, or regulatory audit. Supports GDPR right-to-erasure compliance.']
  description varchar [note: 'The loyalty transaction description of the loyalty transaction record']
  earn_rate decimal(10,6) [note: 'The points-per-currency-unit rate applied to calculate the points_amount for earn transactions (e.g., 1.5 points per USD spent). Captures the rate in effect at the time of the transaction for historical accuracy and program performance analysis.']
  effective_from date [note: 'The effective from of the loyalty transaction record']
  effective_until date [note: 'The effective until of the loyalty transaction record']
  expiry_date date [note: 'The expiry date of the loyalty transaction record']
  fraud_flag boolean [note: 'Indicates whether this transaction has been flagged by the fraud detection system as potentially fraudulent or suspicious. Flagged transactions are held for review before points are posted. Supports loyalty program integrity and financial controls.']
  fraud_review_status varchar [note: 'The outcome of the fraud review process for transactions flagged by the fraud detection system: not_reviewed (default), under_review (investigation in progress), cleared (confirmed legitimate), or confirmed_fraud (fraudulent transaction confirmed and reversed).']
  is_bonus_transaction boolean [note: 'Indicates whether this earn transaction includes a bonus points multiplier applied on top of the base earn rate (e.g., double-points promotion, birthday bonus, new member bonus). Enables separation of base earn from promotional bonus in program cost analysis.']
  loyalty_transaction_status varchar [note: 'The loyalty transaction status of the loyalty transaction record']
  monetary_value decimal(18,2) [note: 'The monetary equivalent value of the points moved in this transaction, expressed in the program\'s base currency. Used for points liability valuation on the balance sheet and for calculating the cost of loyalty rewards in COGS reporting.']
  name varchar [note: 'The loyalty transaction name of the loyalty transaction record']
  notes varchar [note: 'The notes of the loyalty transaction record']
  points_amount decimal(18,4) [note: 'The absolute number of loyalty points moved in this transaction. Always stored as a positive value regardless of direction; the transaction_type field determines whether points are added or subtracted from the account balance. Supports fractional points for precision in tiered earn-rate calculations.']
  points_balance_after decimal(18,4) [note: 'Snapshot of the loyalty account\'s total available points balance immediately after this transaction was applied. Together with points_balance_before, provides the complete before/after audit trail for each points movement event.']
  points_balance_before decimal(18,4) [note: 'Snapshot of the loyalty account\'s total available points balance immediately before this transaction was applied. Critical for audit trail completeness and points liability reconciliation required by finance.']
  points_direction varchar [note: 'Indicates whether the points_amount increases (credit) or decreases (debit) the loyalty account balance. Enables double-entry-style reconciliation of the points ledger for finance liability reporting.']
  points_expiry_date date [note: 'The date on which the points awarded in this earn transaction are scheduled to expire per the loyalty program\'s currency expiration policy. Null for non-earn transactions. Drives the points liability aging schedule reported to finance.']
  points_liability_flag boolean [note: 'Indicates whether this transaction contributes to the outstanding points liability on the company\'s balance sheet (True for unspent earned points, False for redeemed or expired points). Supports finance\'s points liability reserve calculation under GAAP/IFRS.']
  processing_timestamp timestamp [note: 'The date and time at which the loyalty transaction was processed and posted to the account balance by the loyalty engine. May differ from transaction_timestamp due to batch processing windows or pending verification holds.']
  program_year varchar [note: 'The fiscal or calendar year of the loyalty program in which this transaction occurred. Used for annual points balance resets, year-over-year program performance reporting, and points expiration policy enforcement.']
  qualifying_spend_amount decimal(18,2) [note: 'The net purchase amount (after discounts, excluding taxes) on the triggering order that qualified for points earning. Used to verify earn rate calculations and supports COGS and loyalty cost-per-transaction reporting.']
  quantity decimal(18,4) [note: 'The quantity of the loyalty transaction record']
  record_source_system varchar [note: 'The record source system of the loyalty transaction record']
  redemption_value decimal(18,2) [note: 'The monetary discount or reward value applied to the consumer\'s order when points are redeemed. Populated only for redeem-type transactions. Used to calculate the effective discount rate and redemption liability release in financial reporting.']
  reference_number varchar [note: 'The reference number of the loyalty transaction record']
  source_system_code varchar [note: 'The source system code of the loyalty transaction record']
  source_transaction_ref varchar [note: 'The native transaction identifier from the originating source system (e.g., Salesforce record ID, SAP document number, POS receipt number). Enables cross-system reconciliation and traceability back to the system of record.']
  transaction_date timestamp [note: 'The transaction date of the loyalty transaction record']
  transaction_number varchar [note: 'Human-readable, externally referenceable business identifier for the loyalty transaction, formatted as LT-{YYYY}-{sequence}. Used in consumer-facing communications, call-centre lookups, and points dispute resolution.']
  transaction_status varchar [note: 'Current workflow state of the loyalty transaction reflecting its processing lifecycle: pending (awaiting confirmation), processed (successfully posted to account), reversed (cancelled after posting), failed (processing error), or cancelled (voided before posting).']
  transaction_timestamp timestamp [note: 'The precise date and time (with timezone offset) at which the loyalty points movement event occurred in the real world — i.e., when the triggering business event (purchase, referral, etc.) was confirmed and points were posted. This is the principal business event timestamp, distinct from system audit timestamps.']
  transaction_type varchar [note: 'Categorical discriminator identifying the nature of the points movement: earn (points awarded), redeem (points consumed), adjust (manual correction), expire (points lapsed per program rules), transfer (inter-account movement), or reversal (cancellation of a prior transaction). [ENUM-REF-CANDIDATE: earn|redeem|adjust|expire|transfer|reversal — promote to reference product]']
  trigger_event varchar [note: 'The specific business event that initiated this points movement, such as purchase, referral, product_review, birthday_bonus, promotion_bonus, account_registration, social_share, or survey_completion. Drives attribution analysis and program ROI reporting. [ENUM-REF-CANDIDATE: purchase|referral|product_review|birthday_bonus|promotion_bonus|account_registration|social_share|survey_completion — promote to reference product]']
  uom varchar [note: 'The uom of the loyalty transaction record']
  updated_timestamp timestamp [note: 'The date and time at which this loyalty transaction record was last modified in the source system. Tracks reversals, status changes, and manual adjustments for audit and data quality monitoring.']

  Note: 'Individual points movement event within a loyalty account — earn, redeem, adjust, or expire. Records points amount, triggering event (purchase, referral, review, birthday bonus, promotion), associated order reference, balance snapshot (before/after), processing status, and transaction timestamp. Provides the complete audit trail for loyalty currency reconciliation and supports points liability reporting required by finance.'
}

Table consumer.segment {
  segment_id varchar [pk, note: 'Unique surrogate identifier for each consumer segment definition record in the Consumer Goods lakehouse silver layer. Serves as the primary key for all segment definition and membership records.']
  consumer_segment_id varchar [note: 'Foreign key linking to marketing.consumer_segment. Business justification: Operational consumer segments (loyalty/DTC targeting) must reconcile with marketing-defined consumer segments for campaign planning alignment. This cross-domain segment mapping is a data governance an']
  parent_segment_id varchar [note: 'Self-referencing identifier pointing to the parent segment when this segment is a sub-segment or child in a hierarchical segmentation structure (e.g., \'High-Value Loyalists\' as a child of \'Loyalty Program Members\'). Null for top-level segments.']
  activation_channel varchar [note: 'The primary marketing activation channel for which this segment is designed (e.g., email campaigns, SMS, push notifications, paid media audiences, in-store promotions). Drives channel-specific audience export configurations in Salesforce Consumer Goods Cloud and CRM platforms.']
  age_range_max varchar [note: 'For demographic segments, the maximum consumer age (in years) defining the upper bound for segment inclusion. Used alongside age_range_min to define age-banded demographic segments (e.g., Millennials: 28–43).']
  age_range_min varchar [note: 'For demographic segments, the minimum consumer age (in years) required for segment inclusion. Used in age-gated product targeting (e.g., health supplements, alcohol-adjacent personal care) and regulatory compliance with COPPA for under-13 restrictions.']
  amount decimal(18,4) [note: 'The amount of the segment record']
  assignment_method varchar [note: 'Method by which consumers are assigned to this segment. \'rule_based\' uses deterministic business rules (e.g., purchase frequency thresholds); \'ml_model\' uses a trained machine learning classifier; \'manual\' indicates analyst-driven assignment; \'hybrid\' combines rule-based and ML approaches.']
  channel_scope varchar [note: 'The distribution or engagement channel(s) for which this segment is applicable. \'dtc\' (Direct to Consumer) segments target consumers via owned digital channels; \'retail\' targets in-store shoppers; \'ecommerce\' targets online platform shoppers; \'omnichannel\' applies across all channels.']
  cltv_max_value decimal(18,2) [note: 'For CLTV (Customer Lifetime Value)-based segments, the maximum predicted CLTV value defining the upper bound of this segment tier. Used to create banded CLTV segments (e.g., mid-value tier: CLTV between $500 and $2000). Null if no upper bound applies.']
  cltv_min_value decimal(18,2) [note: 'For CLTV (Customer Lifetime Value)-based segments, the minimum predicted CLTV score or monetary value required for a consumer to qualify for segment membership. Enables tiered loyalty and high-value consumer targeting strategies. Null for non-CLTV segment types.']
  code varchar [note: 'Externally-known alphanumeric business identifier for the segment, used in CRM campaign targeting, trade promotion management (TPM) systems, and Salesforce Consumer Goods Cloud audience configurations. Unique per segment version.']
  consent_basis varchar [note: 'The legal basis under GDPR Article 6 or CCPA for processing consumer data within this segment. \'consent\' requires explicit opt-in; \'legitimate_interest\' applies where the business has a justified interest; \'contract\' applies for contractual necessity; \'not_required\' for non-personal aggregate segments.']
  consent_required boolean [note: 'Indicates whether explicit consumer consent is required before a consumer can be assigned to or activated within this segment. True for segments used in direct marketing, personalization, or profiling activities subject to GDPR Article 6 or CCPA opt-in requirements.']
  created_date date [note: 'The created date of the segment record']
  created_timestamp timestamp [note: 'The date and time when this segment definition record was first created in the Consumer Goods lakehouse silver layer. Serves as the audit trail creation marker for data governance and lineage tracking.']
  criteria_definition varchar [note: 'The criteria definition of the segment record']
  currency_code varchar [note: 'ISO 4217 three-letter currency code applicable to monetary thresholds defined in this segment (e.g., rfm_monetary_min, cltv_min_value). Ensures consistent monetary comparisons across geographies and DTC channels.']
  definition_logic varchar [note: 'The definition logic of the segment record']
  description varchar [note: 'Detailed narrative description of the segment\'s defining characteristics, inclusion criteria, and intended business use (e.g., targeting strategy, personalization approach, or trade promotion eligibility). Authored by the owning brand or business unit.']
  effective_end_date date [note: 'The date on which this segment definition expires and is no longer eligible for active targeting. Null indicates an open-ended segment with no planned expiry. Used for time-variant segment membership tracking and historical analysis.']
  effective_from date [note: 'The effective from of the segment record']
  effective_start_date date [note: 'The date from which this segment definition becomes valid and eligible for use in CRM targeting, personalization, and trade promotion activation. Supports time-variant segment tracking and bi-temporal data modeling in the silver layer.']
  effective_until date [note: 'The effective until of the segment record']
  geographic_scope varchar [note: 'ISO 3166-1 alpha-3 country code(s) or region identifiers defining the geographic boundary of this segment (e.g., \'USA\', \'GBR\', \'DEU\'). Supports multi-country CPG brand activation and ensures GDPR/CCPA-compliant targeting within applicable jurisdictions.']
  is_active boolean [note: 'The is active of the segment record']
  is_suppression_segment boolean [note: 'Indicates whether this segment is a suppression list used to exclude consumers from campaigns (e.g., opted-out consumers, recent purchasers, regulatory exclusions). True means consumers in this segment are excluded from targeted marketing activations.']
  last_refresh_timestamp timestamp [note: 'The date and time when the segment membership was last recalculated and updated. Used to assess data freshness for CRM targeting and to trigger refresh workflows when the segment is stale relative to its defined refresh frequency.']
  loyalty_tier_scope varchar [note: 'The loyalty program tier(s) targeted by this segment. Enables differentiated engagement strategies for loyalty program members (e.g., exclusive offers for Platinum tier, win-back campaigns for Bronze tier). \'all\' indicates the segment applies across all loyalty tiers.']
  min_confidence_score decimal(5,4) [note: 'The minimum ML model confidence score (0.0000 to 1.0000) required for a consumer to be assigned to this segment when using ML-based assignment. Consumers with scores below this threshold are excluded. Null for rule-based or manual segments.']
  ml_model_code varchar [note: 'Identifier of the machine learning model used to generate or score this segment, when assignment_method is \'ml_model\' or \'hybrid\'. Enables traceability to the model registry for audit, retraining, and explainability purposes. Null for rule_based or manual segments.']
  model_version varchar [note: 'Version identifier of the segmentation model or rule set that produced this segment definition (e.g., \'v1.0\', \'v2.3\'). Enables traceability of segment membership changes across model iterations and supports A/B testing of segmentation approaches.']
  name varchar [note: 'Human-readable business name of the consumer segment (e.g., \'High-Value Loyalists\', \'Lapsed Shoppers\', \'Health-Conscious Millennials\'). Used in marketing activation, CRM dashboards, and trade promotion targeting.']
  notes varchar [note: 'The notes of the segment record']
  nps_score_max varchar [note: 'For NPS (Net Promoter Score)-based segments, the maximum NPS score (0–10 scale) defining the upper bound for segment inclusion. Used in conjunction with nps_score_min to define NPS-banded segments (e.g., detractors: 0–6).']
  nps_score_min varchar [note: 'For NPS (Net Promoter Score)-based segments, the minimum NPS score (0–10 scale) required for segment inclusion. Enables targeting of promoters (9–10), passives (7–8), or detractors (0–6) for tailored consumer engagement programs.']
  owning_business_unit varchar [note: 'The business unit (BU) within Consumer Goods responsible for this segment\'s definition, governance, and activation (e.g., \'Personal Care\', \'Home Care\', \'Health & Wellness\'). Used for segment ownership reporting and cross-BU deduplication governance.']
  personalization_eligible boolean [note: 'Indicates whether consumers in this segment are eligible for personalized content, product recommendations, or pricing in DTC (Direct to Consumer) and e-commerce channels. Requires valid consent_basis when consent_required is True.']
  priority varchar [note: 'Numeric priority rank used to resolve conflicts when a consumer qualifies for multiple overlapping segments. Lower values indicate higher priority. Used by CRM and personalization engines to determine which segment\'s rules take precedence for offer assignment.']
  quantity decimal(18,4) [note: 'The quantity of the segment record']
  record_source_system varchar [note: 'The record source system of the segment record']
  refresh_frequency varchar [note: 'How frequently the segment membership is recalculated and updated. Determines the cadence at which consumer assignments are re-evaluated against the segment\'s rules or ML model. Impacts CRM campaign freshness and personalization accuracy.']
  rfm_frequency_min varchar [note: 'For RFM (Recency, Frequency, Monetary)-based segments, the minimum number of purchase transactions required within the recency window for a consumer to qualify for the frequency criterion. Null for non-RFM segment types.']
  rfm_monetary_min decimal(18,2) [note: 'For RFM (Recency, Frequency, Monetary)-based segments, the minimum cumulative spend amount (in the segment\'s currency) required within the recency window for a consumer to qualify for the monetary criterion. Null for non-RFM segment types.']
  rfm_recency_days varchar [note: 'For RFM (Recency, Frequency, Monetary)-based segments, the number of days used to define the recency window (e.g., last 90 days). Consumers with a purchase within this window qualify for the recency criterion. Null for non-RFM segment types.']
  segment_status varchar [note: 'Current lifecycle state of the segment definition. \'active\' segments are available for CRM targeting and trade promotion activation; \'draft\' segments are under construction; \'archived\' segments are retained for historical analysis but no longer used in campaigns.']
  segment_type varchar [note: 'Classification of the segmentation methodology applied to define this segment. Behavioral segments are based on purchase patterns; demographic on age/gender/income; psychographic on lifestyle/values; RFM (Recency, Frequency, Monetary) on transactional scoring; CLTV (Customer Lifetime Value)-based on predicted long-term value; geographic on location.']
  source_segment_code varchar [note: 'The native identifier of this segment in the originating operational system (e.g., Salesforce Consumer Goods Cloud segment ID, Nielsen IQ panel group code). Enables cross-system reconciliation and data lineage tracing back to the system of record.']
  source_system_code varchar [note: 'The source system code of the segment record']
  target_audience_size varchar [note: 'The estimated or actual count of unique consumers assigned to this segment at the time of last refresh. Used for campaign planning, media budget allocation, and share of voice (SOV) estimation. Not a real-time count — reflects the last segment refresh cycle.']
  trade_promotion_eligible boolean [note: 'Indicates whether this consumer segment is eligible for trade promotion targeting within the Trade Promotion Management (TPM) system. True enables the segment to be used in TPM/TPO campaign audience configurations in Salesforce Consumer Goods Cloud.']
  uom varchar [note: 'The uom of the segment record']
  updated_timestamp timestamp [note: 'The date and time when this segment definition record was most recently modified. Used for incremental data pipeline processing, change data capture (CDC), and audit trail compliance in the Databricks lakehouse silver layer.']
  version varchar [note: 'Integer version number of this segment definition record, incremented each time the segment\'s criteria, model, or metadata is materially updated. Supports bi-temporal tracking and enables comparison of segment membership across definition versions.']

  Note: 'Consumer segmentation classification and membership records used for targeting, personalization, and marketing activation. Stores segment definition (name, code, model version, type — behavioral/demographic/psychographic/RFM/CLTV-based, description, effective date range, owning brand/BU) and individual membership assignments (shopper reference, assignment date, expiry date, assignment method — rule-based/ML/manual, confidence score, segment version). Enables time-variant segment membership tracking, CRM-driven personalization, and trade promotion targeting across CPG brands.'
}

Table consumer.consent_record {
  consent_record_id varchar [pk, note: 'Unique surrogate identifier for each consent record in the Consumer Goods consumer privacy system. Primary key for the consent_record data product, serving as the SSOT for GDPR Article 7 and CCPA compliance audits.']
  campaign_id varchar [note: 'Reference to the marketing or re-consent campaign that prompted this consent record creation or update. Enables campaign-level consent conversion tracking and supports Trade Promotion Management (TPM) and consumer engagement analytics.']
  marketing_brand_id varchar [note: 'Reference to the Consumer Goods brand for which this consent was captured. Enables brand-level consent reporting and ensures that consent granted for one brand is not incorrectly applied to another brand within the same corporate portfolio.']
  shopper_id varchar [note: 'Reference to the consumer profile record for whom this consent record applies. Links the consent record to the consumer master in the CRM/DTC system (Salesforce Consumer Goods Cloud).']
  amount decimal(18,4) [note: 'The amount of the consent record record']
  capture_method varchar [note: 'Channel or mechanism through which the consumer\'s consent was captured. Identifies whether consent was obtained via a web form, mobile app, in-store interaction, call center agent, paper form, or email link. Required for GDPR proof-of-consent obligations.']
  capture_timestamp timestamp [note: 'Exact date and time (with timezone offset) when the consumer\'s consent action was recorded in the system. This is the principal business event timestamp for the consent record and is immutable once set. Required for GDPR Article 7 audit trail.']
  change_trigger varchar [note: 'The business reason or event that triggered the most recent change to the consent status. Distinguishes consumer-initiated changes from system-driven expirations, administrative overrides, legal requests (e.g., right to erasure), or re-consent campaigns.']
  channel varchar [note: 'The channel of the consent record record']
  code varchar [note: 'The consent record code of the consent record record']
  consent_date date [note: 'The consent date of the consent record record']
  consent_given boolean [note: 'The consent given of the consent record record']
  consent_language_code varchar [note: 'ISO 639-1 language code (optionally with ISO 3166-1 country subtag) of the language in which the consent notice was presented to the consumer (e.g., \'en\', \'fr\', \'de\', \'es-MX\'). Required to confirm consent was given in an intelligible form per GDPR Article 7.']
  consent_proof_reference varchar [note: 'Reference identifier or URL pointing to the stored proof-of-consent artifact (e.g., screenshot, signed form scan, call recording reference, Veeva Vault document ID). Supports GDPR Article 7(1) obligation to demonstrate that consent was given.']
  consent_record_status varchar [note: 'The consent record status of the consent record record']
  consent_scope varchar [note: 'Defines the breadth of the consent grant — whether it applies globally across all Consumer Goods brands and products, is restricted to a specific brand, product category, or a single campaign. Enables granular consent management across the product portfolio.']
  consent_status varchar [note: 'Current lifecycle status of the consent record indicating whether the consumer has actively granted, withdrawn, or is pending confirmation of consent, or whether the consent has expired past its validity period.']
  consent_text_snapshot varchar [note: 'Verbatim text or reference hash of the consent notice, privacy policy excerpt, or opt-in language presented to the consumer at the time of consent capture. Immutable record of what the consumer agreed to, required for GDPR Article 7 proof-of-consent.']
  consent_timestamp timestamp [note: 'The consent timestamp of the consent record record']
  consent_type varchar [note: 'Category of consent being captured, defining the specific processing activity for which the consumer has provided or withheld consent. Covers marketing email, SMS, push notification, data sharing, profiling, and cookies as required by GDPR and CCPA.']
  consent_version varchar [note: 'Version identifier of the consent notice, privacy policy, or terms document presented to the consumer at the time of consent capture. Enables tracking of which policy version was in effect when consent was given, critical for GDPR Article 7 compliance.']
  cookie_consent_categories varchar [note: 'Comma-separated list of cookie categories for which the consumer has granted consent (e.g., \'functional,analytics,marketing\'). Captures granular cookie preferences as required by the ePrivacy Directive and GDPR for digital channels. [ENUM-REF-CANDIDATE: necessary|functional|analytics|marketing|social_media|personalization|advertising — promote to reference product]']
  country_code varchar [note: 'ISO 3166-1 alpha-3 country code of the consumer\'s country of residence at the time of consent capture. Determines applicable privacy regulation (e.g., GDPR for EU countries, CCPA for USA/California). Critical for multi-jurisdiction compliance management.']
  created_timestamp timestamp [note: 'Timestamp when this consent record was first created in the Consumer Goods data platform (Silver Layer). Distinct from capture_timestamp which records the business event time. Supports data lineage and audit trail requirements.']
  currency_code varchar [note: 'The currency code of the consent record record']
  description varchar [note: 'The consent record description of the consent record record']
  device_type varchar [note: 'Type of device used by the consumer when providing consent in digital channels. Supports forensic audit trails and UX analysis of consent capture flows.']
  double_opt_in_flag boolean [note: 'Indicates whether the consumer completed a double opt-in confirmation process (e.g., clicked a confirmation link in a verification email) in addition to the initial consent action. Double opt-in provides stronger proof of consent for marketing communications under GDPR.']
  double_opt_in_timestamp timestamp [note: 'Exact date and time when the consumer completed the double opt-in confirmation step. Null if double opt-in was not required or not yet completed. Provides the definitive timestamp for consent activation in double opt-in workflows.']
  effective_from date [note: 'Date from which this consent record is considered active and binding. Typically aligns with the capture date but may differ for backdated or scheduled consent activations. Supports MASTER_AGREEMENT role effective-period tracking.']
  effective_until date [note: 'The effective until of the consent record record']
  expiry_date date [note: 'Date on which this consent record expires and must be renewed or re-confirmed by the consumer. Null indicates open-ended consent with no defined expiry. Used to trigger consent renewal workflows and ensure ongoing compliance with GDPR\'s requirement for time-limited consent.']
  ip_address varchar [note: 'IP address of the device from which the consumer submitted their consent. Captured for digital consent channels (web form, mobile app, email link) as evidence of consent origin. May be considered PII under GDPR in some EU jurisdictions.']
  is_current_record boolean [note: 'Indicates whether this row represents the current active consent record for the consumer-consent_type combination. Supports Slowly Changing Dimension (SCD Type 2) pattern in the Silver Layer, where historical consent versions are retained for audit purposes and this flag identifies the latest version.']
  legal_basis varchar [note: 'The lawful basis under GDPR Article 6 or equivalent regulation for processing the consumer\'s personal data. Consent is one of six legal bases; this field distinguishes consent-based processing from other lawful bases to support compliance reporting.']
  minor_age_threshold varchar [note: 'Age threshold (in years) used to determine whether parental consent was required for this consent record, based on the applicable jurisdiction\'s rules (e.g., 16 for GDPR default, 13 for COPPA, 13-16 for EU member state variations). Null if consumer is not a minor.']
  name varchar [note: 'The consent record name of the consent record record']
  notes varchar [note: 'The notes of the consent record record']
  parental_consent_flag boolean [note: 'Indicates whether parental or guardian consent was obtained for a minor consumer. Required under GDPR Article 8 for children under 16 (or lower age threshold set by member state) and COPPA for US consumers under 13.']
  prior_consent_status varchar [note: 'The consent status immediately before the most recent status change. Enables point-in-time audit reconstruction and supports the immutable event log requirement for GDPR Article 7 compliance audits without requiring a separate history table join.']
  processing_agent varchar [note: 'Identifier of the system, application, or human agent (call center representative ID or system name) that processed and recorded the consent event. Supports accountability requirements under GDPR Article 5(2) and provides an audit trail of who or what captured the consent.']
  profiling_consent_flag boolean [note: 'Indicates whether the consumer has consented to automated profiling and decision-making activities, including personalization algorithms, NPS scoring, CLTV modeling, and segmentation. Required under GDPR Article 22 for automated decision-making with significant effects.']
  quantity decimal(18,4) [note: 'The quantity of the consent record record']
  re_consent_deadline date [note: 'Date by which the consumer must re-confirm their consent before the current consent record is automatically withdrawn or expired. Null if re-consent is not required. Used to drive automated consent renewal campaigns.']
  re_consent_required_flag boolean [note: 'Indicates whether this consent record requires re-confirmation from the consumer due to a material change in the privacy policy, consent notice, or processing purpose. Triggers re-consent outreach workflows in the CRM system.']
  record_source_system varchar [note: 'The record source system of the consent record record']
  record_version varchar [note: 'Sequential version number of this consent record for the consumer-consent_type combination. Increments with each status change or update, enabling full audit history reconstruction. Version 1 is the initial consent capture; subsequent versions reflect changes.']
  regulatory_jurisdiction varchar [note: 'The applicable privacy regulation or jurisdiction framework under which this consent record was created and must be managed. Determines the legal basis, retention rules, and consumer rights applicable to this record (e.g., GDPR for EU consumers, CCPA for California residents).']
  retention_period_days varchar [note: 'Number of days this consent record must be retained for compliance purposes after the consent is withdrawn or expires. Determined by applicable regulatory requirements (e.g., GDPR Article 5(1)(e) storage limitation, CCPA). Drives automated data lifecycle management.']
  source_channel varchar [note: 'The source channel of the consent record record']
  source_system_code varchar [note: 'The source system code of the consent record record']
  third_party_sharing_flag boolean [note: 'Indicates whether the consumer has explicitly consented to their personal data being shared with third-party partners (e.g., retail partners, data brokers, analytics providers). Distinct from general data sharing consent; specifically governs external data transfers.']
  uom varchar [note: 'The uom of the consent record record']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to this consent record in the data platform. Used for incremental data processing, change data capture (CDC), and audit trail maintenance in the Databricks Lakehouse Silver Layer.']
  withdrawal_method varchar [note: 'Channel or mechanism through which the consumer withdrew their consent. Null if consent has not been withdrawn. Required to demonstrate that withdrawal was as easy as giving consent per GDPR Article 7(3).']
  withdrawal_timestamp timestamp [note: 'Exact date and time when the consumer withdrew their consent. Null if consent has not been withdrawn. GDPR Article 7(3) requires that withdrawal be as easy as giving consent; this timestamp documents the withdrawal event for audit purposes.']

  Note: 'Formal consent and privacy preference record for a consumer capturing GDPR, CCPA, and other regulatory consent obligations, including full audit history of all consent changes. Stores consent type (marketing email, SMS, push notification, data sharing, profiling, cookies), current consent status (granted, withdrawn, pending), consent version, capture method (web form, app, in-store, call center), capture timestamp, IP address, regulatory jurisdiction, expiry date, and immutable event log of every status change (prior status, new status, change trigger, channel, processing agent/system). This is the SSOT for consumer privacy compliance and provides the complete consent history required for GDPR Article 7 and CCPA compliance audits.'
}

Table consumer.dtc_order {
  dtc_order_id varchar [pk, note: 'Unique surrogate identifier for each Direct-to-Consumer (DTC) order record in the Silver layer lakehouse. Primary key for this entity. Role: TRANSACTION_HEADER.']
  ar_invoice_id varchar [note: 'Foreign key linking to finance.ar_invoice. Business justification: DTC order-to-cash cycle: each DTC order generates an AR invoice for collections, dispute management, and revenue recognition under IFRS 15/ASC 606. Consumer goods DTC finance teams require this link f']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: Order‑to‑Campaign linkage enables ROI analysis by attributing direct‑to‑consumer orders to the marketing campaign that generated the purchase.']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: Multi-entity DTC operations: consumer goods companies operating across legal entities require each DTC order attributed to a company code for statutory financial reporting, VAT/tax compliance, and int']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Order processing costs are allocated to internal cost centers for budgeting and variance analysis.']
  distribution_facility_id varchar [note: 'Foreign key linking to distribution.distribution_facility. Business justification: Order fulfillment report requires order-level DC assignment for shipping cost, OTIF metrics, and inventory allocation.']
  distribution_shipment_id varchar [note: 'Foreign key linking to distribution.distribution_shipment. Business justification: DTC last-mile delivery tracking: links a consumer DTC order to its distribution shipment for delivery performance reporting, customer shipment notifications, and carrier OTIF compliance. Distinct from']
  fulfillment_network_node_id varchar [note: 'Foreign key linking to supply.network_node. Business justification: DTC orders are fulfilled from a specific supply network node (DC/fulfillment center). Supply network allocation reporting and node-level capacity planning require knowing which network node fulfilled ']
  fulfillment_supplier_id varchar [note: 'Foreign key linking to procurement.supplier. Business justification: Drop-ship DTC fulfillment requires tracking which supplier fulfilled each order for supplier OTIF performance reporting, cost allocation, and compliance audits. A consumer goods domain expert expects ']
  loyalty_account_id varchar [note: 'Foreign key linking to consumer.loyalty_account. Business justification: A DTC order earns and redeems loyalty points (loyalty_points_earned, loyalty_points_redeemed columns exist on dtc_order). Linking dtc_order directly to loyalty_account enables direct reconciliation of']
  order_id varchar [note: 'Foreign key linking to sales.order. Business justification: Required for consolidated revenue reporting across channels; DTC orders must be reconciled with central sales order for finance.']
  outbound_order_id varchar [note: 'Foreign key linking to distribution.outbound_order. Business justification: DTC order fulfillment process: each consumer DTC order generates a distribution outbound_order for warehouse execution. Operations and customer service teams track which outbound_order fulfills which ']
  price_list_id varchar [note: 'Foreign key linking to sales.price_list. Business justification: DTC orders in CPG are priced against a specific consumer price list (DTC channel price list, promotional price list, loyalty tier price list). This FK enables DTC pricing audit, margin analysis by pri']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: DTC channel P&L reporting: consumer goods companies track DTC as a distinct profit center. Each DTC order must be attributed to a profit center for channel-level revenue and margin reporting, a standa']
  retail_store_id varchar [note: 'Foreign key linking to sales.retail_store. Business justification: Omnichannel CPG DTC orders are frequently initiated in-store (endless aisle, ship-from-store, click-and-collect). Linking DTC orders to the originating retail store enables omnichannel attribution rep']
  shipping_address_id varchar [note: 'The shipping address id of the dtc order record']
  shopper_id varchar [note: 'Reference to the consumer (shopper) who placed this DTC order. Links to the consumer master profile in the Consumer domain SSOT, enabling CLTV analysis, loyalty program attribution, and personalization. Satisfies TRANSACTION_HEADER PARTY_REFERENCE category.']
  subscription_id varchar [note: 'Reference to the consumer subscription plan that generated this DTC order, when subscription_order_flag is True. Links to the subscription master for recurring order management, churn analysis, and subscription revenue reporting.']
  actual_delivery_date date [note: 'The date the shipment was confirmed as delivered to the consumer. Compared against promised_delivery_date to calculate OTIF performance and identify late delivery patterns for carrier SLA management.']
  amount decimal(18,4) [note: 'The amount of the dtc order record']
  billing_address_same_flag boolean [note: 'Indicates whether the billing address is identical to the shipping address for this order. When False, a separate billing address record is maintained. Used for payment processing and fraud risk scoring.']
  carrier_code varchar [note: 'Code identifying the shipping carrier assigned to deliver this DTC order (e.g., UPS, FedEx, USPS, DHL). Used for carrier performance analysis, SLA tracking, and logistics cost allocation.']
  channel varchar [note: 'The channel of the dtc order record']
  channel_code varchar [note: 'The specific owned DTC channel through which the order was placed (e.g., brand website, mobile app, social commerce). Enables channel-level performance analysis, attribution modeling, and Share of Voice (SOV) reporting across DTC touchpoints.']
  code varchar [note: 'The dtc order code of the dtc order record']
  created_timestamp timestamp [note: 'Timestamp when this DTC order record was first ingested and created in the Silver layer lakehouse. Used for data lineage, audit trails, and ETL reconciliation. Satisfies TRANSACTION_HEADER RECORD_AUDIT_CREATED category.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts on this order (e.g., USD, EUR, GBP). Required for multi-currency financial consolidation, FX reporting, and EBITDA calculations. Part of TRANSACTION_HEADER MONETARY_TRIPLET.']
  description varchar [note: 'The dtc order description of the dtc order record']
  device_type varchar [note: 'Type of device used by the consumer to place this DTC order. Used for UX optimization, mobile commerce analytics, and channel attribution modeling to improve conversion rates across device types.']
  discount_amount decimal(18,4) [note: 'Total monetary discount applied at the order header level, including promotional codes, loyalty redemptions, and trade promotion discounts. Used for Trade Promotion Management (TPM) ROI analysis and net revenue reporting. Part of TRANSACTION_HEADER MONETARY_TRIPLET adjustment.']
  dtc_order_status varchar [note: 'The dtc order status of the dtc order record']
  effective_from date [note: 'The effective from of the dtc order record']
  effective_until date [note: 'The effective until of the dtc order record']
  fulfillment_ref varchar [note: 'External reference number linking this DTC order to the fulfillment system (e.g., Blue Yonder WMS warehouse order, 3PL fulfillment reference, or SAP WM transfer order). Enables end-to-end order-to-delivery traceability and OTIF measurement.']
  fulfillment_status varchar [note: 'Current fulfillment state of the DTC order at the header level, indicating whether all line items have been picked, packed, and shipped. Used for OTIF (On Time In Full) KPI reporting and supply chain performance dashboards.']
  gift_order_flag boolean [note: 'Indicates whether this DTC order was placed as a gift, triggering gift wrapping, suppression of price information on packing slips, and gift message inclusion. Used for seasonal demand analysis and consumer gifting behavior modeling.']
  ip_country_code varchar [note: 'Three-letter ISO 3166-1 alpha-3 country code derived from the consumer\'s IP address at the time of order placement. Used for fraud detection, geo-restriction compliance, and cross-border commerce analytics. Classified as potentially PII under GDPR.']
  loyalty_points_earned varchar [note: 'Number of loyalty program points earned by the consumer for this DTC order, based on the order total and applicable loyalty tier multipliers. Feeds into CLTV calculations and loyalty program engagement analytics.']
  loyalty_points_redeemed varchar [note: 'Number of loyalty program points redeemed by the consumer as a discount on this DTC order. Used for loyalty liability accounting, redemption rate analysis, and consumer engagement reporting.']
  name varchar [note: 'The dtc order name of the dtc order record']
  notes varchar [note: 'The notes of the dtc order record']
  order_date timestamp [note: 'The exact date and time (UTC) when the consumer submitted the order through the DTC e-commerce or brand website channel. This is the principal business event timestamp used for demand planning, daily sales reporting, and S&OP inputs. Satisfies TRANSACTION_HEADER BUSINESS_EVENT_TIMESTAMP category.']
  order_status varchar [note: 'Current lifecycle state of the DTC order, tracking progression from placement through fulfillment or cancellation. Used for order management dashboards, OTIF reporting, and consumer communication triggers. Satisfies TRANSACTION_HEADER LIFECYCLE_STATUS category. [ENUM-REF-CANDIDATE: pending|confirmed|processing|shipped|delivered|cancelled|returned — promote to reference product]']
  order_timestamp timestamp [note: 'The order timestamp of the dtc order record']
  order_total_amount decimal(18,4) [note: 'The final net amount charged to the consumer, calculated as subtotal minus discounts plus shipping plus tax. This is the authoritative revenue figure for DTC channel financial reporting and EBITDA contribution analysis. Satisfies TRANSACTION_HEADER MONETARY_TRIPLET net total.']
  payment_method varchar [note: 'The payment instrument type used by the consumer to complete this DTC order (e.g., credit card, PayPal, digital wallet). Used for payment analytics, fraud detection, and consumer payment preference reporting. Note: No raw card data is stored; only the instrument type.']
  payment_status varchar [note: 'Current status of the payment transaction associated with this DTC order, tracking authorization through capture or refund. Critical for revenue recognition, accounts receivable (DSO), and consumer dispute resolution.']
  payment_transaction_ref varchar [note: 'External payment gateway transaction reference or authorization code for this order. Used for payment reconciliation, chargeback management, and financial audit trails. Does not contain sensitive card data (PCI DSS compliant tokenized reference only).']
  promised_delivery_date date [note: 'The delivery date committed to the consumer at the time of order placement, based on Available to Promise (ATP) or Capable to Promise (CTP) logic. Used for SLA compliance measurement and consumer expectation management.']
  promotion_code varchar [note: 'Promotional or coupon code entered by the consumer at checkout, linking this order to a specific Trade Promotion Management (TPM) campaign. Enables TPM ROI measurement, promotional lift analysis, and Trade Promotion Optimization (TPO) modeling.']
  quantity decimal(18,4) [note: 'The quantity of the dtc order record']
  record_source_system varchar [note: 'The record source system of the dtc order record']
  return_flag boolean [note: 'Indicates whether any item in this DTC order has been returned or a return has been initiated. Used for return rate analysis, product quality monitoring, and consumer satisfaction (NPS) correlation studies.']
  return_reason_code varchar [note: 'Standardized code indicating the primary reason for the order return (e.g., defective product, wrong item, consumer changed mind). Populated when return_flag is True. Used for quality defect analysis, product improvement, and COGS impact reporting. [ENUM-REF-CANDIDATE: defective|wrong_item|not_as_described|changed_mind|damaged_in_transit|late_delivery|other — promote to reference product]']
  ship_to_address_line1 varchar [note: 'Primary street address line for the shipping destination of this DTC order. Used for carrier routing, last-mile delivery, and geographic sales analysis. Classified as PII under GDPR and CCPA.']
  ship_to_city varchar [note: 'City of the shipping destination for this DTC order. Used for geographic demand analysis, Distribution Requirements Planning (DRP), and regional marketing segmentation.']
  ship_to_country_code varchar [note: 'Three-letter ISO 3166-1 alpha-3 country code for the shipping destination. Drives international shipping compliance, customs documentation, import/export regulatory requirements, and multi-country revenue reporting.']
  ship_to_name varchar [note: 'Full name of the recipient at the shipping address for this DTC order. May differ from the ordering consumer (e.g., gift orders). Required for carrier label generation and last-mile delivery. Classified as PII under GDPR and CCPA.']
  ship_to_postal_code varchar [note: 'Postal or ZIP code of the shipping destination. Used for carrier rate calculation, geographic clustering, and micro-market demand analysis.']
  ship_to_state_province varchar [note: 'State or province of the shipping destination. Used for tax jurisdiction determination, regional sales reporting, and regulatory compliance (e.g., state-level FDA or EPA requirements).']
  shipped_date date [note: 'The date the order was physically dispatched from the fulfillment center or warehouse. Used for lead time analysis, carrier handoff tracking, and revenue recognition timing under ASC 606.']
  shipping_amount decimal(18,4) [note: 'Shipping and handling charges billed to the consumer for this DTC order. Used for logistics cost analysis, free-shipping threshold reporting, and net revenue calculations.']
  source_system_code varchar [note: 'The source system code of the dtc order record']
  source_system_order_ref varchar [note: 'The native order identifier from the originating e-commerce platform or ERP system (e.g., Salesforce Commerce Cloud order ID, SAP SD sales order number). Used for cross-system reconciliation, EDI integration, and data lineage tracing back to the system of record.']
  subscription_order_flag boolean [note: 'Indicates whether this DTC order was generated as part of a recurring subscription (subscribe-and-save) program. Used to distinguish subscription revenue from one-time purchase revenue for CLTV modeling and replenishment trigger analysis.']
  subtotal_amount decimal(18,4) [note: 'The gross merchandise value of all line items before discounts, shipping charges, and taxes are applied. Used as the base for promotional discount calculations, COGS analysis, and gross margin reporting. Part of TRANSACTION_HEADER MONETARY_TRIPLET.']
  tax_amount decimal(18,4) [note: 'Total sales tax or VAT charged on this DTC order, calculated based on the shipping destination jurisdiction. Required for financial reporting, tax compliance, and SOX audit trails. Part of TRANSACTION_HEADER MONETARY_TRIPLET adjustment.']
  total_amount decimal(18,4) [note: 'The total amount of the dtc order record']
  tracking_number varchar [note: 'Carrier-assigned tracking number for the shipment associated with this DTC order. Provided to the consumer for last-mile visibility and used internally for delivery confirmation and OTIF measurement.']
  uom varchar [note: 'The uom of the dtc order record']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to this DTC order record in the Silver layer, capturing status changes, address corrections, or payment updates. Supports change data capture and audit compliance. Satisfies TRANSACTION_HEADER RECORD_AUDIT_UPDATED category.']

  Note: 'Direct-to-Consumer (DTC) order with line-item detail placed by a shopper through owned e-commerce or brand website channels. Captures order header (order number, date, status, channel, shipping/billing address, payment method, subtotal, discount, shipping cost, tax, total, currency, fulfillment reference) and line items (SKU/GTIN, product name, quantity ordered/shipped, unit price, line discount, line total, promotion code, fulfillment status, return flag). This is the SSOT for DTC channel order transactions and enables SKU-level purchase analysis, replenishment triggers, and product affinity modeling.'
}

Table consumer.dtc_order_line {
  dtc_order_line_id varchar [pk, note: 'Unique surrogate identifier for each individual line item within a DTC order. Primary key for this entity. Role: TRANSACTION_LINE.']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: Line‑level attribution assigns each ordered SKU to the campaign that promoted it, supporting product‑level campaign performance reporting.']
  demand_plan_id varchar [note: 'Foreign key linking to supply.demand_plan. Business justification: DTC order line actuals are reconciled against demand plan buckets to measure forecast accuracy (MAPE/bias). Demand planners attribute actual DTC sales to specific plan versions for variance analysis. ']
  distribution_facility_id varchar [note: 'Reference to the fulfillment warehouse or distribution center from which this order line was or will be shipped. Supports Distribution Requirements Planning (DRP) and warehouse performance analytics.']
  dtc_order_id varchar [note: 'Foreign key reference to the parent DTC order header. Establishes the header/detail relationship for this line item. Satisfies TRANSACTION_LINE HEADER_REFERENCE category.']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Revenue recognition at line level: DTC order lines post to specific GL accounts by product category (e.g., food vs. personal care revenue accounts). Consumer goods finance requires line-level GL attri']
  price_list_item_id varchar [note: 'Foreign key linking to sales.price_list_item. Business justification: Each DTC order line is priced against a specific price list item (SKU-level price). This FK supports DTC line-level pricing audit, promotional price validation, margin-per-SKU reporting, and price com']
  shopper_id varchar [note: 'Reference to the end consumer or shopper who placed the DTC order. Enables consumer-level purchase history, CLTV analysis, and personalization. Satisfies TRANSACTION_LINE PARTY_REFERENCE category.']
  sku_id varchar [note: 'Reference to the product SKU purchased on this line. Enables SKU-level purchase analysis, product affinity modeling, and replenishment triggers. Satisfies TRANSACTION_LINE RESOURCE_REFERENCE category.']
  subscription_id varchar [note: 'Reference to the consumer subscription record that triggered this order line, when subscription_flag is True. Enables subscription lifecycle analysis and recurring revenue reporting.']
  actual_delivery_date date [note: 'Date on which the order line was confirmed as delivered to the consumer. Used for OTIF calculation, consumer satisfaction analysis, and carrier performance reporting.']
  actual_ship_date date [note: 'Date on which the order line was physically dispatched from the fulfillment warehouse. Used to calculate On Time In Full (OTIF) performance and carrier SLA adherence.']
  amount decimal(18,4) [note: 'The amount of the dtc order line record']
  brand_code varchar [note: 'Code identifying the brand under which the product on this order line is marketed. Supports brand-level revenue reporting, Share of Market (SOM) analysis, and brand portfolio performance tracking.']
  channel_code varchar [note: 'Identifies the specific DTC sub-channel through which this order line was placed (e.g., brand website, mobile app, subscription program, social commerce). Supports channel-level revenue attribution and consumer journey analytics.']
  code varchar [note: 'The dtc order line code of the dtc order line record']
  cost_of_goods_sold decimal(18,4) [note: 'Standard cost of goods for the units on this order line at time of sale. Used for gross margin calculation, DTC channel profitability analysis, and EBITDA reporting. Classified confidential as it reveals internal cost structure.']
  created_timestamp timestamp [note: 'Timestamp when this order line record was first created in the system, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Provides audit trail for data lineage and SOX compliance.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code in which all monetary amounts on this order line are denominated (e.g., USD, EUR, GBP). Supports multi-currency DTC operations and financial consolidation.']
  description varchar [note: 'The dtc order line description of the dtc order line record']
  dtc_order_line_status varchar [note: 'The dtc order line status of the dtc order line record']
  effective_from date [note: 'The effective from of the dtc order line record']
  effective_until date [note: 'The effective until of the dtc order line record']
  fulfillment_status varchar [note: 'Current fulfillment lifecycle state of this order line. Tracks progression from order confirmation through warehouse picking, packing, shipment, and delivery. Supports On Time In Full (OTIF) monitoring and consumer communication. [ENUM-REF-CANDIDATE: pending|confirmed|picking|packed|shipped|delivered|cancelled|backordered — promote to reference product]']
  gift_flag boolean [note: 'Indicates whether this order line was designated as a gift by the consumer. True when the consumer selected gift options (e.g., gift wrapping, gift message). Supports gifting program analytics and packaging operations.']
  gtin varchar [note: 'GS1-standard Global Trade Item Number for the product on this line. Enables cross-retailer product identification, barcode scanning, and regulatory traceability. Conforms to GS1 GTIN-8, GTIN-12 (UPC), GTIN-13 (EAN), or GTIN-14 formats.']
  hazmat_flag boolean [note: 'Indicates whether the product on this order line is classified as a hazardous material requiring special handling, packaging, or shipping restrictions. True for products subject to DOT, IATA, or EPA hazmat regulations. Critical for carrier compliance and Safety Data Sheet (SDS) requirements.']
  is_returned boolean [note: 'Indicates whether this order line has been subject to a consumer return. True when a return has been initiated or completed. Enables return rate analysis by SKU, category, and consumer segment for product quality and consumer experience programs.']
  line_discount_amount decimal(18,4) [note: 'Total monetary discount applied to this order line, including promotional discounts, coupon redemptions, and loyalty rewards. Used for Trade Promotion Management (TPM) analysis and margin reporting.']
  line_discount_pct decimal(7,4) [note: 'Discount rate applied to this order line expressed as a percentage of the gross unit price. Enables promotional effectiveness analysis and margin impact assessment without requiring price recalculation.']
  line_net_amount decimal(18,4) [note: 'Net monetary value of this order line after all discounts have been applied but before tax. Core revenue recognition field for DTC channel P&L reporting and COGS analysis. Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT monetary component.']
  line_number varchar [note: 'Sequential position of this line item within the parent DTC order. Used for ordering, display, and reconciliation of multi-line orders. Satisfies TRANSACTION_LINE LINE_SEQUENCE category.']
  line_subtotal decimal(18,4) [note: 'Gross line value before tax, calculated as unit_price multiplied by quantity_ordered. Represents the pre-discount, pre-tax revenue contribution of this line item.']
  line_total decimal(18,4) [note: 'The line total of the dtc order line record']
  line_total_amount decimal(18,4) [note: 'Final total amount for this order line inclusive of all discounts and taxes. Represents the actual amount charged to the consumer for this line item. Used for revenue reporting and consumer billing reconciliation.']
  loyalty_points_earned varchar [note: 'Number of loyalty program points earned by the consumer for purchasing this order line. Supports loyalty program accrual tracking, Consumer Lifetime Value (CLTV) modeling, and consumer engagement analytics.']
  loyalty_points_redeemed varchar [note: 'Number of loyalty program points redeemed by the consumer as a discount on this order line. Enables loyalty redemption rate analysis and program liability management.']
  name varchar [note: 'The dtc order line name of the dtc order line record']
  notes varchar [note: 'The notes of the dtc order line record']
  product_category_code varchar [note: 'Hierarchical product category classification code for the SKU on this line (e.g., Personal Care > Hair Care > Shampoo). Enables category-level sales analysis, assortment planning, and consumer purchase pattern segmentation.']
  product_name varchar [note: 'Commercial name of the product SKU as displayed to the consumer at time of purchase. Captured at order time to preserve historical accuracy independent of future product name changes.']
  promised_delivery_date date [note: 'Date communicated to the consumer as the expected delivery date for this order line. Drives consumer expectation management, NPS impact analysis, and carrier performance benchmarking.']
  promised_ship_date date [note: 'Date on which the order line was committed to ship to the consumer at time of order placement. Basis for Available to Promise (ATP) and Service Level Agreement (SLA) compliance measurement.']
  promotion_code varchar [note: 'Promotional or coupon code applied by the consumer at checkout that triggered a discount on this order line. Enables Trade Promotion Management (TPM) redemption tracking, campaign ROI analysis, and fraud detection.']
  quantity decimal(18,4) [note: 'The quantity of the dtc order line record']
  quantity_cancelled varchar [note: 'Number of units cancelled on this order line, either by the consumer or due to inventory unavailability. Supports cancellation rate analysis and demand signal correction.']
  quantity_ordered varchar [note: 'Number of units of the SKU ordered by the consumer on this line. Basis for demand planning, inventory reservation, and fulfillment processing. Satisfies TRANSACTION_LINE LINE_QUANTITY category.']
  quantity_shipped varchar [note: 'Actual number of units of the SKU dispatched to the consumer for this line. May differ from quantity_ordered due to partial fulfillment, Out of Stock (OOS) situations, or split shipments. Key metric for On Time In Full (OTIF) measurement.']
  record_source_system varchar [note: 'The record source system of the dtc order line record']
  regulatory_hold_flag boolean [note: 'Indicates whether this order line is subject to a regulatory hold preventing fulfillment (e.g., FDA product recall, CPSC safety alert, EU REACH restriction). True when a hold is active. Supports compliance-driven order management and consumer safety programs.']
  return_reason_code varchar [note: 'Standardized code indicating the reason for the consumer return of this order line. Supports product quality analysis, Quality Control (QC) escalation, and consumer experience improvement. [ENUM-REF-CANDIDATE: DEFECTIVE|WRONG_ITEM|NOT_AS_DESCRIBED|CHANGED_MIND|DAMAGED_IN_TRANSIT|LATE_DELIVERY|DUPLICATE_ORDER|OTHER — promote to reference product]']
  source_system_code varchar [note: 'The source system code of the dtc order line record']
  subscription_flag boolean [note: 'Indicates whether this order line was generated as part of a recurring subscription program (e.g., Subscribe & Save). True for subscription-triggered lines. Enables subscription revenue tracking and replenishment program analysis.']
  tax_amount decimal(18,4) [note: 'Total tax amount applied to this order line, including applicable sales tax, VAT, or GST based on consumer jurisdiction. Required for tax compliance reporting and financial reconciliation.']
  unit_of_measure varchar [note: 'Unit of measure in which the SKU quantity is expressed on this order line (e.g., EA=Each, CS=Case, PK=Pack). Aligns with GS1 and SAP UOM standards for consistent quantity interpretation. [ENUM-REF-CANDIDATE: EA|CS|PK|BX|KG|LB|OZ|L|ML — 9 candidates stripped; promote to reference product]']
  unit_price decimal(18,4) [note: 'Gross selling price per unit of the SKU at the time of order placement, before any discounts or promotions. Represents the consumer-facing price (RSP/MSRP or DTC-specific price). Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT category.']
  uom varchar [note: 'The uom of the dtc order line record']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to this order line record, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Supports change data capture (CDC), audit trails, and Silver layer incremental processing in the Databricks Lakehouse.']

  Note: 'Individual line item within a DTC order representing a single SKU purchased. Stores order reference, SKU/GTIN, product name, quantity ordered, quantity shipped, unit price, line discount, line total, promotion code applied, fulfillment status, and return flag. Enables SKU-level purchase analysis, replenishment triggers, and product affinity modeling for CPG DTC channels.'
}

Table consumer.subscription {
  subscription_id varchar [pk, note: 'Primary key for subscription']
  ar_invoice_id varchar [note: 'Foreign key linking to finance.ar_invoice. Business justification: Subscription billing generates recurring AR invoices independently of individual orders (annual/quarterly billing cycles). Consumer goods subscription finance requires direct subscription-to-AR-invoic']
  billing_address_id varchar [note: 'The billing address id of the subscription record']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: Subscriptions are acquired through specific marketing campaigns. Knowing which campaign drove subscription acquisition is essential for campaign ROI, customer acquisition cost reporting, and subscript']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Subscription program cost management: subscription fulfillment operations (pick/pack, customer service, churn management) are tracked to dedicated cost centers. Consumer goods finance teams require th']
  demand_plan_id varchar [note: 'Foreign key linking to supply.demand_plan. Business justification: Subscription recurring demand is a committed baseline input to demand planning. Supply planners use subscription cohort volumes as a known demand signal in statistical baseline forecasting and S&OP. A']
  distribution_facility_id varchar [note: 'Reference to the warehouse or distribution center assigned to fulfill this subscription\'s orders. Supports DRP (Distribution Requirements Planning) and inventory allocation across the supply chain network.']
  fulfillment_network_node_id varchar [note: 'Foreign key linking to supply.network_node. Business justification: Subscriptions are assigned to a designated supply network node for recurring fulfillment planning. Node-level capacity and replenishment planning for subscription volumes requires this assignment. Rol']
  marketing_brand_id varchar [note: 'Foreign key linking to marketing.marketing_brand. Business justification: Subscriptions in consumer goods are brand-specific (e.g., a brand\'s replenishment subscription program). Linking subscription to marketing_brand enables brand-level subscription analytics, renewal rat']
  price_list_id varchar [note: 'Foreign key linking to sales.price_list. Business justification: CPG subscription pricing is governed by a specific price list (subscriber discount tier, promotional rate, renewal price). Linking subscription to price_list enables subscription pricing governance, r']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Subscription channel revenue reporting: recurring subscription revenue is attributed to profit centers for channel P&L. Consumer goods companies with DTC subscription models (e.g., replenishment progr']
  shipping_address_id varchar [note: 'The shipping address id of the subscription record']
  shopper_id varchar [note: 'Reference to the consumer profile who owns this subscription. Links to the SSOT consumer master record for CRM and personalization.']
  sku_id varchar [note: 'Reference to the primary SKU enrolled in this subscription. Identifies the specific product variant (size, flavor, format) the consumer has subscribed to for auto-replenishment.']
  subscription_delivery_address_id varchar [note: 'Reference to the consumer\'s preferred delivery address for subscription fulfillment. Links to the address master for DSD (Direct Store Delivery) routing and last-mile logistics planning via Blue Yonder WMS.']
  acquisition_source varchar [note: 'Marketing source or campaign that drove the consumer to subscribe (e.g., email campaign code, paid search, influencer referral, loyalty program). Used for marketing ROI (Return on Investment) attribution and SOV (Share of Voice) analysis.']
  amount decimal(18,4) [note: 'The amount of the subscription record']
  auto_renew_flag boolean [note: 'Indicates whether the subscription is configured to automatically renew at the end of each billing cycle (True) or requires explicit consumer action to continue (False). Governs recurring revenue recognition and consumer notification obligations.']
  billing_cycle_day varchar [note: 'Day of the month (1–31) on which the subscription billing charge is processed. Governs the recurring payment schedule and aligns with the consumer\'s preferred billing date. Used in accounts receivable and DSO (Days Sales Outstanding) reporting.']
  billing_frequency varchar [note: 'The billing frequency of the subscription record']
  cancellation_date date [note: 'Calendar date on which the consumer formally cancelled the subscription. Distinct from end_date (which may be a future scheduled end). Used in churn cohort analysis and subscription tenure reporting.']
  cancellation_reason varchar [note: 'Consumer-stated or system-derived reason for cancelling the subscription. Populated when subscription_status transitions to \'cancelled\'. Critical input for churn analysis, NPS (Net Promoter Score) correlation, and consumer retention strategy.']
  ccpa_opt_out_flag boolean [note: 'Indicates whether the consumer has exercised their CCPA right to opt out of the sale or sharing of personal data associated with this subscription (True = opted out). Mandatory for California consumers. Drives data sharing restrictions downstream.']
  channel varchar [note: 'Sales channel through which the subscription was originally acquired (e.g., dtc_web, dtc_mobile). Supports DTC (Direct to Consumer) channel performance analysis, attribution reporting, and consumer acquisition cost tracking.']
  code varchar [note: 'The subscription code of the subscription record']
  created_timestamp timestamp [note: 'System timestamp recording when the subscription record was first created in the platform. Represents RECORD_AUDIT_CREATED. Used for data lineage, audit trails, and subscription cohort analysis.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the subscription billing currency (e.g., USD, EUR, GBP). Required for multi-currency DTC operations and financial consolidation reporting.']
  delivery_frequency varchar [note: 'The delivery frequency of the subscription record']
  description varchar [note: 'The subscription description of the subscription record']
  discount_pct decimal(7,4) [note: 'The discount pct of the subscription record']
  discount_rate decimal(5,4) [note: 'Percentage discount applied to the subscription price per billing cycle, expressed as a decimal (e.g., 0.1500 = 15%). Reflects subscriber loyalty pricing, promotional offers, or TPM (Trade Promotion Management) funded discounts.']
  effective_from date [note: 'The effective from of the subscription record']
  effective_until date [note: 'The effective until of the subscription record']
  end_date date [note: 'Calendar date on which the subscription is scheduled to end or was terminated. Null for open-ended subscriptions. Represents EFFECTIVE_UNTIL for this agreement. Populated on cancellation or plan expiry.']
  failed_payment_count varchar [note: 'Cumulative number of failed payment attempts on this subscription since inception. Used to trigger dunning workflows, payment retry logic, and subscription suspension rules. Key indicator for revenue leakage management.']
  frequency varchar [note: 'Cadence at which the subscription order is automatically triggered and fulfilled. Drives the replenishment schedule and next order date calculation. Key input for demand planning and S&OP forecasting.']
  gdpr_consent_flag boolean [note: 'Indicates whether the consumer has provided explicit GDPR-compliant consent for data processing associated with this subscription (True) or not (False). Mandatory for EU consumers. Supports regulatory compliance and data governance audits.']
  last_order_date date [note: 'Calendar date of the most recently fulfilled subscription order. Used to validate subscription activity, detect stalled subscriptions, and support FEFO (First Expired First Out) inventory allocation for replenishment.']
  name varchar [note: 'The subscription name of the subscription record']
  net_price decimal(18,4) [note: 'Actual amount charged to the consumer per billing cycle after applying the discount rate. Equals subscription_price × (1 - discount_rate). Used in revenue recognition, COGS (Cost of Goods Sold) analysis, and financial reporting.']
  next_billing_date date [note: 'The next billing date of the subscription record']
  next_delivery_date date [note: 'The next delivery date of the subscription record']
  next_order_date date [note: 'Scheduled calendar date for the next automatic order generation under this subscription. Used by fulfillment systems for ATP (Available to Promise) checks and demand sensing. Updated after each successful order cycle.']
  next_renewal_date date [note: 'The next renewal date of the subscription record']
  notes varchar [note: 'The notes of the subscription record']
  nps_score varchar [note: 'Most recent NPS (Net Promoter Score) survey response from the subscriber, on a scale of 0–10. Used to correlate subscription satisfaction with churn risk and to segment consumers for retention and advocacy programs.']
  pause_end_date date [note: 'Calendar date on which the subscription pause is scheduled to end and auto-replenishment is set to resume. Null if the pause is indefinite. Used in demand forecasting to anticipate reactivation volumes.']
  pause_flag boolean [note: 'The pause flag of the subscription record']
  pause_reason varchar [note: 'Consumer-stated reason for pausing the subscription. Populated when subscription_status transitions to \'paused\'. Used in consumer retention analysis and proactive re-engagement campaign targeting.']
  pause_start_date date [note: 'Calendar date on which the consumer-initiated subscription pause became effective. Used to calculate pause duration and adjust next_order_date upon resumption. Supports consumer retention lifecycle tracking.']
  payment_method varchar [note: 'The payment method of the subscription record']
  payment_method_type varchar [note: 'Category of payment instrument used for recurring subscription billing (e.g., credit_card, digital_wallet). Stored as a type reference only — no raw card or account data is stored here per PCI DSS compliance. Supports payment failure analysis and retry logic.']
  payment_token_reference varchar [note: 'Tokenized reference identifier for the consumer\'s stored payment method, issued by the payment processor vault. Never contains raw card or bank account data. Used to initiate recurring charges without storing PCI-sensitive data. Compliant with PCI DSS tokenization requirements.']
  plan_name varchar [note: 'The plan name of the subscription record']
  price decimal(18,4) [note: 'Gross price charged to the consumer per billing cycle before any discounts are applied. Expressed in the subscription\'s billing currency. Used in subscription revenue forecasting and CLTV (Customer Lifetime Value) calculations.']
  price_per_cycle decimal(18,4) [note: 'The price per cycle of the subscription record']
  promotion_code varchar [note: 'Trade promotion or marketing coupon code applied at subscription enrollment that governs the discount_rate or introductory pricing. Ties the subscription to a TPM (Trade Promotion Management) campaign for ROI measurement.']
  quantity varchar [note: 'Number of units of the subscribed SKU to be fulfilled per order cycle. Drives replenishment volume, inventory reservation, and demand planning inputs for S&OP (Sales and Operations Planning).']
  record_source_system varchar [note: 'The record source system of the subscription record']
  recurring_amount decimal(18,4) [note: 'The recurring amount of the subscription record']
  source_system_code varchar [note: 'The source system code of the subscription record']
  start_date date [note: 'Calendar date on which the subscription became effective and the first order cycle was initiated. Represents EFFECTIVE_FROM for this agreement. Used in cohort analysis and subscription tenure calculations.']
  subscription_number varchar [note: 'Externally visible, human-readable subscription reference number communicated to the consumer in confirmation emails, invoices, and customer service interactions. Serves as the BUSINESS_IDENTIFIER for this agreement.']
  subscription_status varchar [note: 'Current lifecycle state of the subscription. \'active\' = fulfilling orders; \'paused\' = consumer-initiated hold; \'cancelled\' = permanently terminated; \'pending\' = awaiting first payment confirmation; \'expired\' = plan term ended without renewal. Drives LIFECYCLE_STATUS for this MASTER_AGREEMENT entity.']
  subscription_type varchar [note: 'Classification of the subscription program type. \'auto_replenishment\' covers single-SKU DTC replenishment; \'subscription_box\' covers curated multi-product boxes; \'bundle\' covers fixed product bundles; \'trial\' covers introductory trial subscriptions.']
  total_orders_fulfilled varchar [note: 'Cumulative count of successfully fulfilled subscription orders since the subscription start date. Non-derived operational counter maintained by the fulfillment system. Used in subscription tenure analysis and OTIF (On Time In Full) performance tracking.']
  trial_end_date date [note: 'Calendar date on which the trial period ends and standard subscription billing commences. Null for non-trial subscriptions. Used to trigger trial-to-paid conversion communications and revenue recognition timing.']
  trial_flag boolean [note: 'Indicates whether this subscription was initiated as a trial or introductory offer (True) or as a standard paid subscription (False). Used to segment trial-to-paid conversion analytics and NPD (New Product Development) launch performance.']
  uom varchar [note: 'The uom of the subscription record']
  updated_timestamp timestamp [note: 'System timestamp recording the most recent modification to the subscription record. Represents RECORD_AUDIT_UPDATED. Used for change data capture (CDC) in the Databricks Silver Layer pipeline and audit compliance.']

  Note: 'Consumer subscription record for DTC auto-replenishment or subscription box programs. Stores subscription plan name, subscribed SKU(s), subscription frequency (weekly, monthly, bi-monthly), subscription status (active, paused, cancelled), start date, next order date, billing cycle, subscription price, discount rate, payment method reference, and cancellation reason if applicable. Enables subscription revenue forecasting and consumer retention management for CPG DTC channels.'
}

Table consumer.segment_membership {
  segment_membership_id varchar [pk, note: 'Primary key for the segment_membership association']
  segment_id varchar [note: 'Foreign key linking to the segment definition that this shopper is assigned to.']
  shopper_id varchar [note: 'Foreign key linking to the shopper (end consumer) who is a member of this segment.']
  assignment_date date [note: 'The calendar date on which this shopper was formally assigned to this segment. May differ from effective_from if assignments are pre-scheduled or back-dated.']
  assignment_method varchar [note: 'The method by which this specific shopper was assigned to this segment for this membership record. Values: rule_based (deterministic criteria), ml_model (probabilistic scoring), manual (human override), imported (external system feed). Belongs to the membership, not the segment definition or the shopper identity.']
  cltv_segment varchar [note: 'The consumer\'s current CLTV (Customer Lifetime Value) segment classification derived from purchase history and predictive modeling. Used for resource allocation in marketing, personalization prioritization, and retention investment decisions. Segment label, not a calculated metric. [Moved from shopper: This is a denormalized CLTV segment label on the shopper record. In the correct model, CLTV segment membership is represented as a segment_membership record linking the shopper to the appropriate CLTV-type segment. The label on shopper is redundant and creates a maintenance inconsistency — it should be removed in favor of querying the membership association.]']
  confidence_score decimal [note: 'The ML model confidence score (0.0000–1.0000) for this specific shopper-segment assignment. Distinct from the segment-level min_confidence_score threshold — this is the actual score achieved by this shopper at the time of assignment. Only meaningful in the context of this individual membership record.']
  effective_from date [note: 'The date on which this shopper\'s membership in this segment became active. Enables time-variant membership tracking and point-in-time segment reconstruction for campaign attribution.']
  effective_until date [note: 'The date on which this shopper\'s membership in this segment expires or was terminated. Null indicates an open-ended active membership. Supports segment churn analysis and re-entry tracking.']
  exit_reason varchar [note: 'The reason this shopper\'s membership in this segment ended. Populated when effective_until is set. Supports segment lifecycle analysis and suppression management.']
  is_active boolean [note: 'Indicates whether this specific shopper-segment membership is currently active. Derived from effective_from/effective_until but maintained as an explicit flag for query performance in CRM activation pipelines.']

  Note: 'This association product represents the Segment Membership between a shopper and a consumer segment. It captures the operational record of a specific shopper being assigned to a specific segment within a CPG CRM or CDP system, including the method of assignment, ML confidence score, effective date range, and exit reason. Each record links one shopper to one segment and carries attributes that exist only in the context of this individual membership — they cannot reside on the shopper record (which is identity-level) or the segment record (which is definition-level). Supports time-variant membership tracking, personalization activation, and campaign targeting across CPG brands.. Existence Justification: In CPG consumer data platforms, a single shopper is actively assigned to multiple segments simultaneously (e.g., a \'High-Value RFM\' segment AND a \'Millennial Demographic\' segment AND a \'Lapsed Buyer\' behavioral segment), and each segment contains thousands of shoppers. This is not an analytical correlation — CRM and CDP systems actively create, update, and expire individual membership records as part of campaign targeting and personalization workflows. The relationship is a recognized operational entity called \'segment membership\' with its own lifecycle data (assignment method, confidence score, effective dates, exit reason) that cannot reside on either the shopper or segment record alone.'
}

Table supply.demand_plan {
  demand_plan_id varchar [pk, note: 'Unique identifier for the demand plan record. Primary key representing a specific version-point in the S&OP/IBP cycle for a SKU/location/channel/planning period combination.']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: demand_plan carries \'marketing_event_uplift_quantity\' and \'promotional_overlay_quantity\' — both campaign-driven. Linking to the specific campaign enables IBP/S&OP traceability: which campaign drove wh']
  category_id varchar [note: 'Foreign key linking to product.category. Business justification: CPG demand plans are created at category level for category management, trade planning, and S&OP category reviews. Category-level demand plans (e.g., \'Hair Care\' total demand) are standard inputs to C']
  hierarchy_id varchar [note: 'Foreign key linking to product.hierarchy. Business justification: CPG S&OP demand plans are created at hierarchy levels (brand, division, category) in IBP/APO systems, not only at SKU level. Hierarchy-level demand planning drives top-down disaggregation. A CPG suppl']
  marketing_brand_id varchar [note: 'Foreign key linking to marketing.brand. Business justification: Integrated Demand Planning uses brand forecasts; brand_id links demand plan to specific brand for Brand Demand Forecast report.']
  origin_network_node_id varchar [note: 'The origin network node id of the demand plan record']
  primary_demand_supply_network_node_id varchar [note: 'Reference to the distribution location, warehouse, or market geography for which demand is planned.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: In consumer goods S&OP, demand plans are structured by profit center for financial P&L alignment and revenue planning. The financial demand review step of S&OP requires demand volumes mapped to profit']
  sku_id varchar [note: 'Reference to the product SKU for which demand is being planned.']
  sop_cycle_id varchar [note: 'Reference to the S&OP/IBP planning cycle during which this demand plan version was created.']
  trade_account_id varchar [note: 'Foreign key linking to sales.trade_account. Business justification: REQUIRED: Account‑level demand forecast used in S&OP planning; planners need trade_account context for each demand_plan.']
  amount decimal(18,4) [note: 'The amount of the demand plan record']
  approval_status varchar [note: 'Current approval state of the demand plan version within the S&OP governance workflow.']
  approved_timestamp timestamp [note: 'Date and time when this demand plan version was formally approved and locked for supply planning execution.']
  code varchar [note: 'The demand plan code of the demand plan record']
  commercial_overlay_quantity decimal(18,3) [note: 'Demand adjustment quantity applied by field sales teams based on customer intelligence, market conditions, and sales pipeline visibility.']
  confidence_level varchar [note: 'Planner-assigned confidence rating in the demand forecast based on data quality, market visibility, and forecast stability.']
  consensus_quantity decimal(18,3) [note: 'Agreed demand forecast quantity representing the single demand signal passed to supply planning after S&OP consensus process. This is the authoritative demand plan.']
  created_by_persona varchar [note: 'Role or persona of the user who created this demand plan version, used for accountability and collaboration tracking.']
  created_timestamp timestamp [note: 'Date and time when this demand plan version record was first created in the system.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code used for any monetary values associated with this demand plan (e.g., revenue forecasts).']
  demand_pattern_type varchar [note: 'Classification of historical demand behavior pattern used to select appropriate statistical forecasting algorithm.']
  demand_plan_status varchar [note: 'The demand plan status of the demand plan record']
  demand_sensing_signal varchar [note: 'Short-term demand trend indicator derived from real-time POS data, shipment data, and market signals to enable rapid forecast adjustments.']
  demand_type varchar [note: 'The demand type of the demand plan record']
  description varchar [note: 'The demand plan description of the demand plan record']
  effective_from date [note: 'The effective from of the demand plan record']
  effective_from_date date [note: 'Date from which this demand plan version becomes active and is used for supply planning and ATP calculations.']
  effective_to_date date [note: 'Date until which this demand plan version remains active. Null indicates the version is currently active with no planned expiration.']
  effective_until date [note: 'The effective until of the demand plan record']
  forecast_accuracy_percentage decimal(5,2) [note: 'Historical forecast accuracy metric for this SKU/location/channel combination, used for forecast quality benchmarking and continuous improvement.']
  forecast_bias_percentage decimal(5,2) [note: 'Systematic tendency to over-forecast or under-forecast, calculated as average percentage deviation from actual demand.']
  is_consensus_version boolean [note: 'Flag indicating whether this version represents the official consensus demand plan approved through the S&OP process and used for supply planning.']
  last_modified_timestamp timestamp [note: 'Date and time when this demand plan version was last updated or adjusted.']
  lifecycle_stage varchar [note: 'Product lifecycle stage classification used to apply appropriate forecasting models and demand shaping strategies.']
  marketing_event_uplift_quantity decimal(18,3) [note: 'Incremental demand quantity expected from planned marketing campaigns, promotions, and brand activation events.']
  name varchar [note: 'The demand plan name of the demand plan record']
  notes varchar [note: 'The notes of the demand plan record']
  npd_launch_volume_quantity decimal(18,3) [note: 'Forecasted demand quantity for new product launches or product line extensions during the planning period.']
  plan_horizon_end date [note: 'The plan horizon end of the demand plan record']
  plan_horizon_start date [note: 'The plan horizon start of the demand plan record']
  plan_version varchar [note: 'The plan version of the demand plan record']
  planned_quantity decimal(18,4) [note: 'The planned quantity of the demand plan record']
  planner_notes varchar [note: 'Free-text comments and annotations from demand planners explaining assumptions, adjustments, risks, or special considerations for this forecast.']
  planning_bucket varchar [note: 'Time granularity of the demand plan (daily, weekly, monthly, quarterly) used for aggregation and reporting.']
  planning_period_end_date date [note: 'End date of the planning period (week or month) for which demand is forecasted.']
  planning_period_start_date date [note: 'Start date of the planning period (week or month) for which demand is forecasted.']
  promotional_overlay_quantity decimal(18,3) [note: 'Demand uplift quantity attributed to trade promotions, price discounts, and retail execution activities.']
  quantity decimal(18,4) [note: 'The quantity of the demand plan record']
  risk_category varchar [note: 'Classification of the primary risk factor affecting demand plan reliability and supply fulfillment capability.']
  risk_flag boolean [note: 'Indicator that this demand plan carries elevated supply risk due to capacity constraints, material shortages, or demand volatility.']
  source_system_code varchar [note: 'The source system code of the demand plan record']
  source_system_record_code varchar [note: 'Original unique identifier of this demand plan record in the source system, used for data lineage and reconciliation.']
  statistical_baseline_quantity decimal(18,3) [note: 'Unconstrained demand forecast quantity generated by statistical forecasting algorithms before any commercial overlays or adjustments.']
  unit_of_measure varchar [note: 'Unit in which demand quantities are expressed (each, case, pallet, kilogram, liter, etc.). [ENUM-REF-CANDIDATE: EA|CS|PL|KG|LB|L|GAL — 7 candidates stripped; promote to reference product]']
  uom varchar [note: 'The uom of the demand plan record']
  updated_timestamp timestamp [note: 'The updated timestamp of the demand plan record']
  variance_to_baseline_quantity decimal(18,3) [note: 'Difference between consensus quantity and statistical baseline quantity, indicating the net impact of all commercial adjustments and overlays.']
  version_name varchar [note: 'Human-readable name of the demand plan version (e.g., \'Statistical Baseline Q1 2024\', \'Consensus Final March 2024\').']
  version_sequence_number varchar [note: 'Sequential version number within the planning cycle, used to track iteration history and version progression.']
  version_type varchar [note: 'Classification of the demand plan version indicating its stage in the S&OP process. Statistical baseline represents unconstrained forecast; consensus represents agreed demand signal passed to supply planning.']

  Note: 'Core master entity representing the demand plan across all versions, stages, and consensus outcomes within the S&OP/IBP cycle for each SKU/location/channel/planning period combination. Each record represents a specific version-point: captures version name, version type (statistical baseline/field sales overlay/marketing-adjusted/consensus/final approved), planning cycle reference, created-by persona, approval status, effective date range, planning bucket (weekly/monthly), statistical baseline quantity, commercial overlay, marketing event uplift, new product launch volume, consensus quantity, variance to statistical baseline, channel disaggregation, promotional overlays, and lifecycle stage. The consensus version represents the single agreed demand signal passed to supply planning. Enables forecast accuracy benchmarking across versions. Sourced from SAP IBP Demand Planning module.'
}

Table supply.forecast_version {
  forecast_version_id varchar [pk, note: 'Reference to the parent or baseline forecast version from which this version was derived (e.g., statistical baseline that was then adjusted). Nullable for original baseline versions.']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: In consumer goods S&OP, forecast versions capture promotional and campaign-driven demand uplifts. Planners must trace which marketing campaign drove a specific forecast version\'s uplift quantity — ess']
  demand_plan_id varchar [note: 'The demand plan id of the forecast version record']
  forecast_sop_cycle_id varchar [note: 'Reference to the Sales and Operations Planning (S&OP) or Integrated Business Planning (IBP) cycle to which this forecast version belongs.']
  hierarchy_id varchar [note: 'Foreign key linking to product.hierarchy. Business justification: In CPG IBP/APO, forecast versions are generated at multiple hierarchy levels (brand, category, division) for top-down planning. A forecast_version at hierarchy level is a standard S&OP artifact; CPG d']
  primary_forecast_sop_cycle_id varchar [note: 'Foreign key linking to supply.sop_cycle. Business justification: forecast_version needs to be linked to its planning cycle; added new FK sop_cycle_id referencing sop_cycle.sop_cycle_id. Existing planning_cycle_id column renamed to sop_cycle_id, so removed planning_']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Forecast versions in consumer goods S&OP are reviewed and approved by profit center owners during the financial review step. Revenue forecasting and margin gap analysis require forecast versions to be']
  sku_id varchar [note: 'The sku id of the forecast version record']
  aggregation_level varchar [note: 'The level of aggregation at which this forecast version is maintained: Stock Keeping Unit (SKU) level, product family, brand, category, sales channel, customer account, geographic region, or global total. [ENUM-REF-CANDIDATE: sku|product_family|brand|category|channel|customer|region|global — 8 candidates stripped; promote to reference product]']
  algorithm_used varchar [note: 'The algorithm used of the forecast version record']
  amount decimal(18,4) [note: 'The amount of the forecast version record']
  approval_notes varchar [note: 'Comments or notes provided by the approver during the approval process, documenting any conditions, concerns, or guidance related to this forecast version. Nullable if not yet approved or no notes provided.']
  approval_status varchar [note: 'The approval status of the forecast version record']
  approved_timestamp timestamp [note: 'The date and time when this forecast version was approved. Nullable if not yet approved.']
  archived_timestamp timestamp [note: 'The date and time when this forecast version was archived and moved out of active planning use. Nullable if not yet archived.']
  bias_percentage decimal(6,2) [note: 'Forecast bias percentage indicating systematic over-forecasting (positive bias) or under-forecasting (negative bias). A value near zero indicates an unbiased forecast. Nullable if not yet calculated.']
  code varchar [note: 'The forecast version code of the forecast version record']
  created_timestamp timestamp [note: 'The date and time when this forecast version record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for any monetary values associated with this forecast version (e.g., revenue forecasts). Nullable if forecast is purely volume-based.']
  demand_sensing_applied boolean [note: 'Boolean flag indicating whether demand sensing algorithms (short-term forecast adjustments based on real-time Point of Sale (POS) data, shipment data, or other leading indicators) were applied to this forecast version.']
  description varchar [note: 'The forecast version description of the forecast version record']
  effective_from date [note: 'The effective from of the forecast version record']
  effective_from_date date [note: 'The date from which this forecast version becomes effective and is used for operational planning, Distribution Requirements Planning (DRP), and Available to Promise (ATP) calculations.']
  effective_to_date date [note: 'The date until which this forecast version remains effective. Nullable for open-ended versions that remain active until superseded.']
  effective_until date [note: 'The effective until of the forecast version record']
  forecast_accuracy_percentage decimal(5,2) [note: 'Calculated forecast accuracy percentage for this version, measured as the percentage of forecasted demand that matched actual demand. Used for benchmarking version performance and continuous improvement. Nullable if accuracy has not yet been calculated.']
  forecast_horizon_days varchar [note: 'The forecast horizon days of the forecast version record']
  forecast_method varchar [note: 'The forecast method of the forecast version record']
  forecast_quantity decimal(18,3) [note: 'The forecast quantity of the forecast version record']
  forecast_source_system varchar [note: 'Name or identifier of the source system or application that generated or contributed to this forecast version (e.g., \'SAP IBP\', \'TradeEdge\', \'Excel Upload\', \'Salesforce CG Cloud\').']
  forecast_version_status varchar [note: 'The forecast version status of the forecast version record']
  is_active_version boolean [note: 'Boolean flag indicating whether this forecast version is currently active and being used for planning and execution. Only one version per planning cycle should typically be active at a time.']
  is_baseline boolean [note: 'The is baseline of the forecast version record']
  is_consensus_version boolean [note: 'Boolean flag indicating whether this version represents the consensus forecast agreed upon by cross-functional stakeholders (sales, marketing, supply chain, finance) during the S&OP process.']
  is_final boolean [note: 'The is final of the forecast version record']
  is_final_approved_version boolean [note: 'Boolean flag indicating whether this version is the final approved forecast that will be used for operational execution, Material Requirements Planning (MRP), and Distribution Requirements Planning (DRP).']
  last_modified_timestamp timestamp [note: 'The last modified timestamp of the forecast version record']
  mean_absolute_percentage_error decimal(5,2) [note: 'Mean Absolute Percentage Error (MAPE) metric for this forecast version, measuring the average magnitude of forecast errors as a percentage. Lower values indicate better forecast accuracy. Nullable if not yet calculated.']
  model_parameters varchar [note: 'The model parameters of the forecast version record']
  modified_timestamp timestamp [note: 'The date and time when this forecast version record was last modified.']
  name varchar [note: 'The forecast version name of the forecast version record']
  new_product_introduction_included boolean [note: 'Boolean flag indicating whether New Product Development (NPD) or New Product Introduction (NPI) launches were incorporated into this forecast version.']
  notes varchar [note: 'The notes of the forecast version record']
  planning_bucket varchar [note: 'The planning bucket of the forecast version record']
  planning_horizon_end_date date [note: 'The last date of the planning period covered by this forecast version (e.g., end of the fiscal quarter or rolling 18-month horizon).']
  planning_horizon_start_date date [note: 'The first date of the planning period covered by this forecast version (e.g., start of the fiscal quarter or month).']
  promotional_events_included boolean [note: 'Boolean flag indicating whether trade promotions, marketing campaigns, and promotional events were factored into this forecast version.']
  quantity decimal(18,4) [note: 'The quantity of the forecast version record']
  rejection_reason varchar [note: 'Explanation or reason provided when this forecast version was rejected during the approval process. Nullable if version was not rejected.']
  snapshot_date date [note: 'The snapshot date of the forecast version record']
  snapshot_timestamp timestamp [note: 'The snapshot timestamp of the forecast version record']
  source_system_code varchar [note: 'The source system code of the forecast version record']
  statistical_model_applied varchar [note: 'Name or identifier of the statistical forecasting model or algorithm applied to generate or adjust this forecast version (e.g., \'Exponential Smoothing\', \'ARIMA\', \'Machine Learning Ensemble\', \'Holt-Winters\'). Nullable if no statistical model was used.']
  time_bucket varchar [note: 'The time granularity or bucket size used for this forecast version: daily, weekly, monthly, quarterly, or annual periods.']
  unit_of_measure varchar [note: 'The unit of measure in which forecast quantities are expressed (e.g., \'EA\' for each, \'CS\' for case, \'KG\' for kilogram, \'L\' for liter). Aligns with GS1 standards.']
  uom varchar [note: 'The uom of the forecast version record']
  updated_timestamp timestamp [note: 'The updated timestamp of the forecast version record']
  version_code varchar [note: 'Short alphanumeric code or identifier for the forecast version used in system integrations and reporting (e.g., \'STAT_BASE\', \'CONS_V1\', \'FINAL_APR\').']
  version_description varchar [note: 'Detailed textual description or notes about this forecast version, including assumptions, adjustments made, special considerations, or rationale for key changes.']
  version_label varchar [note: 'The version label of the forecast version record']
  version_name varchar [note: 'Human-readable name assigned to this forecast version (e.g., \'Statistical Baseline Q1 2024\', \'Consensus Forecast March\', \'Final Approved Version\').']
  version_number varchar [note: 'The version number of the forecast version record']
  version_sequence_number varchar [note: 'Sequential number indicating the iteration or revision order of this forecast version within the planning cycle (e.g., 1 for first draft, 2 for first revision, 3 for consensus).']
  version_status varchar [note: 'Current lifecycle status of the forecast version: draft (under construction), in review (submitted for approval), approved (validated and accepted), rejected (not accepted), archived (historical record), or active (currently in use for planning).']
  version_type varchar [note: 'Classification of the forecast version indicating its role in the planning process: statistical baseline (system-generated), field sales overlay (sales team input), marketing adjusted (marketing promotions incorporated), consensus (collaborative agreement), final approved (executive sign-off), or simulation (what-if scenario).']

  Note: 'Tracks each named version or snapshot of the demand forecast within the IBP/S&OP cycle (e.g., statistical baseline, field sales overlay, marketing-adjusted, consensus, final approved). Captures version name, version type, planning cycle reference, created-by persona, approval status, and effective date range. Enables forecast accuracy benchmarking across versions.'
}

Table supply.inventory_policy {
  inventory_policy_id varchar [pk, note: 'Unique identifier for the inventory policy record. Primary key for this entity.']
  category_id varchar [note: 'Foreign key linking to product.category. Business justification: CPG inventory policies are frequently set at category level (e.g., all Skin Care SKUs maintain 28-day safety stock). Category-level inventory policy drives SKU-level parameter inheritance. Supply plan']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Inventory policies are owned by specific cost centers; linking enables policy‑related budgeting and compliance audits.']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: CPG procurement teams set inventory policies for critical raw materials and packaging components (min/max stock, reorder points for key ingredients). Material-level inventory policies are a standard S']
  origin_network_node_id varchar [note: 'The origin network node id of the inventory policy record']
  primary_inventory_supply_network_node_id varchar [note: 'Reference to the distribution facility, warehouse, or storage location node in the supply network where this policy applies.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Inventory policies carry service level and working capital targets owned by profit centers. Balance sheet management of safety stock investment and fill-rate commitments are tracked by profit center i']
  sku_id varchar [note: 'Reference to the SKU (Stock Keeping Unit) for which this inventory policy is defined.']
  sop_cycle_id varchar [note: 'Foreign key linking to supply.sop_cycle. Business justification: Inventory policies are reviewed, updated, and approved within S&OP/IBP planning cycles. The last_review_date, next_review_date, and review_cycle_days on inventory_policy indicate a cycle-driven review']
  trade_account_id varchar [note: 'Foreign key linking to sales.trade_account. Business justification: Retailer-mandated inventory policies are a core consumer goods reality — major retailers (e.g., Walmart, Tesco) contractually mandate service levels, OTIF targets, and safety stock minimums. inventory']
  amount decimal(18,4) [note: 'The amount of the inventory policy record']
  approval_date date [note: 'Date when this inventory policy was formally approved and authorized for use in supply planning and execution.']
  approval_status varchar [note: 'Current approval workflow status indicating whether the policy has been reviewed and approved by authorized supply planning personnel.']
  approved_by_name varchar [note: 'Name of the supply planning manager or director who approved this inventory policy for operational use.']
  code varchar [note: 'The inventory policy code of the inventory policy record']
  created_timestamp timestamp [note: 'Timestamp when this inventory policy record was first created in the system.']
  currency_code varchar [note: 'The currency code of the inventory policy record']
  customer_otif_commitment_percent decimal(5,2) [note: 'Specific OTIF performance level committed to a customer or channel, which may differ from internal targets and may be contractually binding.']
  cycle_stock_target_units decimal(18,3) [note: 'Target cycle stock quantity representing the average inventory held to meet expected demand between replenishments, excluding safety stock.']
  demand_variability_coefficient decimal(10,4) [note: 'Statistical measure of demand variability (coefficient of variation or standard deviation) used in safety stock calculations.']
  description varchar [note: 'The inventory policy description of the inventory policy record']
  effective_end_date date [note: 'Date on which this inventory policy expires or is superseded. Null indicates an open-ended policy.']
  effective_from date [note: 'The effective from of the inventory policy record']
  effective_start_date date [note: 'Date from which this inventory policy becomes active and applicable for planning and execution.']
  effective_until date [note: 'The effective until of the inventory policy record']
  fill_rate_target_percent decimal(5,2) [note: 'Target percentage of customer demand that should be fulfilled from available inventory without backorders or stockouts.']
  inventory_policy_status varchar [note: 'The inventory policy status of the inventory policy record']
  last_modified_timestamp timestamp [note: 'Timestamp when this inventory policy record was last updated or modified.']
  last_review_date date [note: 'Date when this inventory policy was last reviewed and validated by the supply planning team.']
  lead_time_variability_days decimal(10,2) [note: 'Standard deviation or variance of replenishment lead time in days, used to account for supply uncertainty in safety stock calculations.']
  lot_size decimal(18,3) [note: 'The lot size of the inventory policy record']
  max_stock_level decimal(18,3) [note: 'The max stock level of the inventory policy record']
  maximum_stock_level_units decimal(18,3) [note: 'Maximum inventory level allowed at this location for this SKU, used to prevent overstocking and manage warehouse capacity constraints.']
  measurement_window_days varchar [note: 'Time period in days over which service level performance is measured and evaluated against targets (e.g., rolling 30 days, 90 days, quarterly).']
  min_stock_level decimal(18,3) [note: 'The min stock level of the inventory policy record']
  minimum_stock_level_units decimal(18,3) [note: 'Minimum inventory level that should be maintained at this location for this SKU, typically aligned with safety stock or regulatory requirements.']
  name varchar [note: 'The inventory policy name of the inventory policy record']
  next_review_date date [note: 'Scheduled date for the next review and update of this inventory policy, ensuring policies remain aligned with business conditions.']
  notes varchar [note: 'The notes of the inventory policy record']
  on_time_delivery_target_percent decimal(5,2) [note: 'Target percentage of orders that should be delivered by the customer-requested or committed delivery date.']
  order_up_to_level decimal(18,3) [note: 'The order up to level of the inventory policy record']
  otif_composite_target_percent decimal(5,2) [note: 'Composite OTIF (On Time In Full) target percentage representing orders delivered both on time and in full quantity, a critical customer service metric.']
  penalty_clause_indicator boolean [note: 'Indicates whether failure to meet the defined service level targets will result in financial penalties, chargebacks, or other contractual consequences.']
  policy_code varchar [note: 'Business identifier code for the inventory policy, used for external reference and reporting.']
  policy_notes varchar [note: 'Free-text notes capturing special considerations, exceptions, seasonal adjustments, or business context relevant to this inventory policy.']
  policy_status varchar [note: 'Current lifecycle status of the inventory policy indicating its approval and operational state. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|expired|archived — 7 candidates stripped; promote to reference product]']
  policy_type varchar [note: 'The policy type of the inventory policy record']
  quantity decimal(18,4) [note: 'The quantity of the inventory policy record']
  reorder_point decimal(18,3) [note: 'The reorder point of the inventory policy record']
  reorder_point_units decimal(18,3) [note: 'Inventory level at which a replenishment order should be triggered, calculated as lead time demand plus safety stock.']
  replenishment_method varchar [note: 'The inventory replenishment strategy applied: MRP (Material Requirements Planning), DRP (Distribution Requirements Planning), VMI (Vendor Managed Inventory), JIT (Just In Time), Kanban, or Fixed Order Quantity.']
  retailer_mandated_target_flag boolean [note: 'Indicates whether the service level targets are mandated by a retail customer as part of their supplier requirements or vendor compliance program.']
  review_cycle_days varchar [note: 'Frequency in days at which inventory levels are reviewed and replenishment decisions are made for this SKU-location combination.']
  review_period_days varchar [note: 'The review period days of the inventory policy record']
  safety_stock_calculated_units decimal(18,3) [note: 'System-calculated safety stock quantity based on demand variability, lead time variability, and service level inputs before manual approval or adjustment.']
  safety_stock_calculation_method varchar [note: 'The methodology used to calculate safety stock: fixed value, forecast error-based, demand variability, lead time variability, combined variability, or service level-driven calculation.']
  safety_stock_days_of_supply decimal(10,2) [note: 'Safety stock expressed as the number of days of average demand coverage, providing a time-based view of inventory buffer.']
  safety_stock_target_units decimal(18,3) [note: 'Target safety stock quantity in base units of measure, representing the buffer inventory to protect against demand and supply variability.']
  safety_stock_units decimal(18,3) [note: 'The safety stock units of the inventory policy record']
  service_level_target_pct decimal(5,2) [note: 'The service level target pct of the inventory policy record']
  service_level_target_percent decimal(5,2) [note: 'Target service level percentage (e.g., 95%, 98%, 99.5%) representing the desired probability of not stocking out during the replenishment lead time.']
  source_system_code varchar [note: 'The source system code of the inventory policy record']
  unit_of_measure varchar [note: 'The unit of measure of the inventory policy record']
  uom varchar [note: 'The uom of the inventory policy record']
  updated_timestamp timestamp [note: 'The updated timestamp of the inventory policy record']

  Note: 'Master entity defining inventory policy parameters, safety stock calculations, service level commitments, and OTIF targets for each SKU/location node in the supply network. Captures safety stock target and calculated quantities (days of supply, units, calculation method, demand variability, lead time variability, service level input, calculated vs approved SS units, effective date, review status), reorder point, min/max levels, cycle stock target, replenishment method (MRP/DRP/VMI), review cycle, service level targets (fill rate %, on-time delivery %, OTIF composite %), customer/channel-level OTIF commitments, retailer-mandated target flags, penalty clause indicators, and measurement windows. Owned by supply planning; consumed by distribution and manufacturing execution.'
}

Table supply.safety_stock {
  safety_stock_id varchar [pk, note: 'Unique identifier for the safety stock calculation record. Primary key for the safety stock entity.']
  demand_plan_id varchar [note: 'Foreign key linking to supply.demand_plan. Business justification: Safety stock calculations are driven by demand plan data — specifically demand variability, forecast accuracy, and planned quantities. The demand_variability_coefficient and forecast_accuracy_percent ']
  inspection_plan_id varchar [note: 'Foreign key linking to quality.inspection_plan. Business justification: Safety stock calculation process: inspection lead time from the applicable inspection plan inflates effective replenishment lead time used in safety stock formulas. Consumer goods planners explicitly ']
  inventory_policy_id varchar [note: 'The inventory policy id of the safety stock record']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: CPG supply chains maintain safety stock for raw materials and packaging components, not only finished SKUs. Material-level safety stock (e.g., fragrance ingredient, bottle) is a distinct planning conc']
  origin_network_node_id varchar [note: 'The origin network node id of the safety stock record']
  primary_safety_supply_network_node_id varchar [note: 'Reference to the storage location, distribution center, or facility where the safety stock applies. Links to distribution facility master data.']
  sku_id varchar [note: 'Reference to the specific product SKU for which safety stock is calculated. Links to the product master data.']
  sop_cycle_id varchar [note: 'Foreign key linking to supply.sop_cycle. Business justification: Safety stock calculations are performed and approved within S&OP/IBP planning cycles. The planning_period_start_date and planning_period_end_date on safety_stock align with S&OP cycle horizons. Linkin']
  standard_cost_id varchar [note: 'Foreign key linking to finance.standard_cost. Business justification: Safety stock financial valuation for working capital reporting uses standard cost per unit. The safety_stock table already carries holding_cost_per_unit and stockout_cost_per_unit, which are derived f']
  abc_classification varchar [note: 'The ABC classification of the SKU based on revenue contribution or volume. A items are high-value requiring tight control; B items are moderate; C items are low-value. Influences service level targets and safety stock investment decisions.']
  amount decimal(18,4) [note: 'The amount of the safety stock record']
  approval_timestamp timestamp [note: 'The date and time when the safety stock calculation was approved by the planner. Marks the transition from calculated to approved state in the workflow.']
  approved_safety_stock_units decimal(15,3) [note: 'The final approved safety stock quantity in base units of measure after planner review and adjustment. This is the target value used for inventory policy execution and Available to Promise (ATP) calculations.']
  average_daily_demand_units decimal(15,3) [note: 'The mean daily demand quantity in base units of measure. Used as input to safety stock calculations and represents expected consumption rate.']
  average_lead_time_days decimal(8,2) [note: 'The mean replenishment lead time in days from order placement to receipt. Used in safety stock calculations to determine the exposure period for demand and supply variability.']
  calculated_safety_stock_units decimal(15,3) [note: 'The system-calculated safety stock quantity in base units of measure. This is the raw output from the calculation engine before any manual adjustments or approvals.']
  calculation_method varchar [note: 'The methodology used to calculate the safety stock quantity. Statistical methods use demand and lead time variability; days-of-supply uses fixed coverage targets; manual override represents planner judgment; service level and lead time methods focus on specific risk factors; hybrid combines multiple approaches.']
  calculation_timestamp timestamp [note: 'The date and time when the safety stock calculation was executed by the planning system. Provides audit trail for calculation runs and version control.']
  code varchar [note: 'The safety stock code of the safety stock record']
  created_timestamp timestamp [note: 'The date and time when this safety stock record was first created in the system. Provides audit trail for record lifecycle tracking.']
  currency_code varchar [note: 'The currency code of the safety stock record']
  days decimal(10,2) [note: 'The days of the safety stock record']
  days_of_supply_target decimal(6,2) [note: 'The target safety stock coverage expressed in days of average demand. Used when calculation method is days-of-supply based. Represents the buffer duration to protect against stockouts.']
  demand_classification varchar [note: 'The demand pattern category for this SKU-location. Steady indicates consistent demand; seasonal shows periodic peaks; erratic has high variability; lumpy has infrequent large orders; intermittent has sporadic demand; obsolete indicates phase-out. Influences calculation method selection.']
  demand_variability decimal(18,4) [note: 'The demand variability of the safety stock record']
  demand_variability_coefficient decimal(10,4) [note: 'Statistical measure of demand volatility expressed as coefficient of variation or standard deviation. Used in statistical safety stock calculations to quantify demand uncertainty.']
  description varchar [note: 'The safety stock description of the safety stock record']
  effective_date date [note: 'The date when this safety stock target becomes active and is used for inventory policy execution, Distribution Requirements Planning (DRP), and Available to Promise (ATP) calculations.']
  effective_from date [note: 'The effective from of the safety stock record']
  effective_until date [note: 'The effective until of the safety stock record']
  expiration_date date [note: 'The date when this safety stock target expires and is replaced by a new calculation. Used to manage the lifecycle of safety stock policies and trigger recalculation cycles.']
  forecast_accuracy_percent decimal(5,2) [note: 'The historical forecast accuracy for this SKU-location combination expressed as a percentage. Used to adjust safety stock calculations based on forecasting reliability. Lower accuracy typically requires higher safety stock.']
  holding_cost_per_unit decimal(15,4) [note: 'The annual cost to hold one unit of inventory including warehousing, insurance, obsolescence, and capital cost. Used in inventory optimization to balance service level against carrying cost. Expressed in local currency.']
  is_active boolean [note: 'Boolean flag indicating whether this safety stock record is currently active and being used for inventory policy execution. True means active; False means superseded or inactive.']
  last_review_timestamp timestamp [note: 'The date and time when the safety stock record was last reviewed by a planner, regardless of whether changes were made. Used to track planner engagement and ensure regular review cycles.']
  lead_time_days decimal(10,2) [note: 'The lead time days of the safety stock record']
  lead_time_variability decimal(10,4) [note: 'The lead time variability of the safety stock record']
  lead_time_variability_days decimal(8,2) [note: 'Measure of supply lead time uncertainty expressed in days. Represents the standard deviation or range of lead time fluctuation used in safety stock calculations.']
  minimum_order_quantity decimal(15,3) [note: 'The minimum order quantity constraint from the supplier or manufacturing process. Safety stock calculations must consider MOQ to ensure replenishment orders are feasible.']
  modified_timestamp timestamp [note: 'The date and time when this safety stock record was last modified. Updated whenever any field changes. Supports change tracking and audit requirements.']
  name varchar [note: 'The safety stock name of the safety stock record']
  next_review_date date [note: 'The scheduled date for the next safety stock review cycle. Used in Sales and Operations Planning (S&OP) and Integrated Business Planning (IBP) processes to ensure regular policy updates.']
  notes varchar [note: 'The notes of the safety stock record']
  order_multiple decimal(15,3) [note: 'The order quantity increment or lot size multiple required by supplier or production constraints. Safety stock and reorder quantities must align with this multiple.']
  override_notes varchar [note: 'Free-text explanation provided by the planner when manually overriding the calculated safety stock. Documents the business context and rationale for the adjustment.']
  override_reason_code varchar [note: 'The business reason code when approved safety stock differs from calculated safety stock. Captures planner judgment factors such as promotional events, seasonal peaks, supply chain risks, new product introductions, product phase-outs, or quality concerns.']
  planning_period_end_date date [note: 'The end date of the planning period for which this safety stock calculation is effective. Defines the validity window for the safety stock target.']
  planning_period_start_date date [note: 'The start date of the planning period for which this safety stock calculation is effective. Used in Sales and Operations Planning (S&OP) and Integrated Business Planning (IBP) cycles.']
  quantity decimal(18,4) [note: 'The quantity of the safety stock record']
  review_status varchar [note: 'The approval workflow status of the safety stock calculation. Pending review indicates awaiting planner action; approved means active for execution; rejected requires recalculation; under revision is being adjusted; expired indicates the planning period has passed.']
  safety_stock_status varchar [note: 'The safety stock status of the safety stock record']
  service_level_pct decimal(5,2) [note: 'The service level pct of the safety stock record']
  shelf_life_days varchar [note: 'The shelf life or expiration period of the product in days. Critical for Fast-Moving Consumer Goods (FMCG) and Consumer Packaged Goods (CPG) safety stock decisions to prevent obsolescence. Influences maximum safety stock levels and First Expired First Out (FEFO) policies.']
  source_system_code varchar [note: 'The source system code of the safety stock record']
  stockout_cost_per_unit decimal(15,4) [note: 'The estimated cost of a stockout per unit including lost sales, expediting costs, customer dissatisfaction, and brand impact. Used in service level optimization to quantify the cost of Out of Stock (OOS) events. Expressed in local currency.']
  supply_risk_score decimal(5,2) [note: 'A quantitative risk score assessing supply chain vulnerability for this SKU-location. Higher scores indicate greater risk from supplier reliability, geopolitical factors, transportation disruptions, or single-source dependencies. Used to adjust safety stock buffers.']
  target_service_level_percent decimal(5,2) [note: 'The desired in-stock probability or fill rate target expressed as a percentage (e.g., 95.00, 98.50). Drives the safety stock buffer size to achieve the specified On Shelf Availability (OSA) or Service Level Agreement (SLA).']
  unit_of_measure varchar [note: 'The unit of measure for safety stock quantities. EA=Each, CS=Case, PL=Pallet, KG=Kilogram, LB=Pound, L=Liter, GAL=Gallon. Must align with SKU base unit of measure. [ENUM-REF-CANDIDATE: EA|CS|PL|KG|LB|L|GAL — 7 candidates stripped; promote to reference product]']
  units decimal(18,3) [note: 'The units of the safety stock record']
  uom varchar [note: 'The uom of the safety stock record']
  updated_timestamp timestamp [note: 'The updated timestamp of the safety stock record']
  xyz_classification varchar [note: 'The XYZ classification based on demand variability. X items have low variability (predictable); Y items have moderate variability; Z items have high variability (unpredictable). Used alongside ABC to determine safety stock strategy.']
  z_score decimal(6,4) [note: 'The standard normal distribution value corresponding to the target service level. Used in statistical safety stock formulas to translate service level percentage into buffer quantity.']

  Note: 'Transactional record capturing the calculated and approved safety stock quantity for each SKU/location/time-period combination. Stores calculation method (statistical, days-of-supply, manual override), demand variability, lead time variability, service level input, calculated SS units, approved SS units, effective date, and review status. Distinct from inventory_policy (policy target) as this captures the actual calculated output.'
}

Table supply.replenishment_order {
  replenishment_order_id varchar [pk, note: 'Unique identifier for the supply replenishment order record. Primary key for this entity.']
  carrier_contract_id varchar [note: 'Foreign key linking to logistics.carrier_contract. Business justification: CONTRACT_COMPLIANCE: Each replenishment order is governed by a carrier contract; needed for rate and penalty enforcement.']
  carrier_id varchar [note: 'Identifier of the logistics carrier or transportation provider assigned to execute this replenishment shipment.']
  consensus_demand_id varchar [note: 'Foreign key linking to supply.consensus_demand. Business justification: Replenishment orders are generated to fulfill consensus demand volumes agreed upon in the S&OP process. Linking supply_replenishment_order to the specific consensus_demand record it fulfills enables d']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Replenishment orders incur expenses that must be tracked against the responsible cost center for expense reporting and internal charge‑backs.']
  demand_plan_id varchar [note: 'Foreign key linking to supply.demand_plan. Business justification: Replenishment orders are generated by DRP execution to fulfill demand plans. Linking supply_replenishment_order to the originating demand_plan enables demand-supply pegging, traceability from plan to ']
  destination_location_supply_network_node_id varchar [note: 'Identifier of the supply network node to which inventory will be delivered (distribution center, warehouse, or retail location).']
  destination_network_node_id varchar [note: 'The destination network node id of the supply replenishment order record']
  inventory_policy_id varchar [note: 'Foreign key linking to supply.inventory_policy. Business justification: Replenishment orders are generated based on inventory policy parameters (reorder point, order-up-to level, replenishment method). Linking to the governing inventory_policy record enables policy compli']
  lane_id varchar [note: 'Foreign key linking to logistics.lane. Business justification: ORDER_EXECUTION: Replenishment order execution follows a specific lane; lane_id links order to transportation routing.']
  logistics_shipment_id varchar [note: 'Identifier of the physical shipment record associated with this replenishment order once released for execution.']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: CPG replenishment orders cover raw material and packaging procurement, not only finished goods transfers. Purchase orders for ingredients and packaging components are core supply chain operations. A C']
  network_lane_id varchar [note: 'Foreign key linking to supply.network_lane. Business justification: A replenishment order travels along a specific supply network lane (source-destination pair). The network_lane is the supply domain\'s lane entity defining lead times, costs, and capacity for the route']
  primary_supply_network_node_id varchar [note: 'Identifier of the supply network node from which inventory will be shipped (plant, distribution center, or warehouse).']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Replenishment orders in consumer goods are assigned to profit centers for supply chain cost reporting, intercompany transfer pricing, and P&L allocation by business unit. This is a standard SAP/ERP or']
  sku_id varchar [note: 'Identifier of the product SKU being replenished through this order.']
  sop_cycle_id varchar [note: 'Foreign key linking to supply.sop_cycle. Business justification: Replenishment orders are generated within a specific S&OP/IBP planning cycle. The drp_run_timestamp on supply_replenishment_order indicates a planning run context tied to a cycle. Linking to sop_cycle']
  source_network_node_id varchar [note: 'The source network node id of the supply replenishment order record']
  standard_cost_id varchar [note: 'Foreign key linking to finance.standard_cost. Business justification: Replenishment orders are financially valued using standard cost for inventory accounting, purchase price variance (PPV) analysis, and working capital reporting. The order_cost_amount on supply_repleni']
  supplier_id varchar [note: 'Foreign key linking to procurement.supplier. Business justification: Replenishment orders are sourced from a specific supplier in consumer goods. This link enables supplier performance tracking (lead time adherence, OTIF), replenishment cost analysis by supplier, and s']
  supplier_site_id varchar [note: 'Foreign key linking to procurement.supplier_site. Business justification: Replenishment orders ship from a specific supplier site (factory or distribution point). This link supports site-level OTIF tracking, capacity constraint analysis, and compliance auditing — essential ']
  triggered_safety_stock_id varchar [note: 'Foreign key linking to supply.safety_stock. Business justification: When a replenishment order is triggered by a safety stock breach (safety_stock_trigger_flag = true), linking to the specific safety_stock record that triggered it enables precise demand-supply pegging']
  triggering_order_id varchar [note: 'Foreign key linking to sales.order. Business justification: Demand-driven replenishment (DRP) in consumer goods traces replenishment orders back to the customer sales order that triggered them. This link enables end-to-end order fulfillment traceability, backo']
  actual_receipt_date date [note: 'Actual date the goods were received at the destination location.']
  actual_ship_date date [note: 'Actual date the shipment departed from the source location.']
  amount decimal(18,4) [note: 'The amount of the supply replenishment order record']
  available_to_promise_quantity decimal(18,3) [note: 'ATP quantity at the source location at the time the replenishment order was created, used to validate supply availability.']
  cancellation_reason varchar [note: 'Reason code or description explaining why the replenishment order was cancelled, if applicable.']
  confirmed_quantity decimal(18,3) [note: 'Quantity of the SKU confirmed for shipment by the source location, may differ from requested quantity due to supply constraints.']
  created_timestamp timestamp [note: 'Date and time when this replenishment order record was first created in the system.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for all monetary amounts in this order.']
  drp_run_timestamp timestamp [note: 'Date and time when the DRP execution run that generated this order was executed.']
  due_date date [note: 'The due date of the supply replenishment order record']
  effective_from date [note: 'The effective from of the supply replenishment order record']
  effective_until date [note: 'The effective until of the supply replenishment order record']
  forecast_demand_quantity decimal(18,3) [note: 'Forecasted demand quantity at the destination location that drove the replenishment calculation.']
  last_modified_timestamp timestamp [note: 'Date and time when this replenishment order record was last modified in the system.']
  lead_time_days varchar [note: 'The lead time days of the supply replenishment order record']
  notes varchar [note: 'The notes of the supply replenishment order record']
  order_cost_amount decimal(18,2) [note: 'Total cost associated with this replenishment order, including product cost, transportation cost, and handling fees.']
  order_notes varchar [note: 'Free-text notes or special instructions related to this replenishment order, such as handling requirements or routing constraints.']
  order_quantity decimal(18,3) [note: 'The order quantity of the supply replenishment order record']
  order_status varchar [note: 'Current execution status of the replenishment order in the supply chain workflow.']
  order_type varchar [note: 'Classification of the replenishment order lifecycle stage: planned (system-generated recommendation), firmed (manually confirmed but not released), or released (committed for execution).']
  planned_receipt_date date [note: 'Target date for goods receipt at the destination location, accounting for transit lead time.']
  planned_ship_date date [note: 'Target date for shipment departure from the source location as calculated by the DRP engine.']
  priority varchar [note: 'The priority of the supply replenishment order record']
  priority_code varchar [note: 'Priority classification for order fulfillment, typically driven by stock-out risk, customer service level, or strategic importance.']
  promised_date date [note: 'The promised date of the supply replenishment order record']
  quantity decimal(18,4) [note: 'The quantity of the supply replenishment order record']
  received_quantity decimal(18,3) [note: 'Actual quantity of the SKU received at the destination location, captured at goods receipt.']
  replenishment_order_number varchar [note: 'Business-facing unique order number for the replenishment order, used for tracking and reference across systems and communications.']
  requested_date date [note: 'The requested date of the supply replenishment order record']
  requested_quantity decimal(18,3) [note: 'Quantity of the SKU requested for replenishment as calculated by the DRP engine or demand planner.']
  safety_stock_trigger_flag boolean [note: 'Indicates whether this replenishment order was triggered by inventory falling below safety stock threshold at the destination location.']
  ship_date date [note: 'The ship date of the supply replenishment order record']
  shipped_quantity decimal(18,3) [note: 'Actual quantity of the SKU shipped from the source location, captured at dispatch.']
  source_system_code varchar [note: 'The source system code of the supply replenishment order record']
  supply_replenishment_order_code varchar [note: 'The supply replenishment order code of the supply replenishment order record']
  supply_replenishment_order_description varchar [note: 'The supply replenishment order description of the supply replenishment order record']
  supply_replenishment_order_name varchar [note: 'The supply replenishment order name of the supply replenishment order record']
  supply_replenishment_order_status varchar [note: 'The supply replenishment order status of the supply replenishment order record']
  transit_lead_time_days varchar [note: 'Planned number of days for goods to travel from source to destination location.']
  transportation_mode varchar [note: 'Primary mode of transportation planned or used for this replenishment shipment.']
  unit_of_measure varchar [note: 'Unit of measure for all quantity fields in this order (EA=Each, CS=Case, PL=Pallet, KG=Kilogram, LB=Pound, L=Liter, GAL=Gallon). [ENUM-REF-CANDIDATE: EA|CS|PL|EA|KG|LB|L|GAL — 8 candidates stripped; promote to reference product]']
  uom varchar [note: 'The uom of the supply replenishment order record']
  updated_timestamp timestamp [note: 'The updated timestamp of the supply replenishment order record']

  Note: 'Transactional record representing a planned or released replenishment order generated by DRP execution for moving inventory between supply network nodes (plant-to-DC, DC-to-DC). Captures order type (planned/firmed/released), source location, destination location, SKU, requested quantity, confirmed quantity, planned ship date, planned receipt date, and DRP run reference. Distinct from purchase orders (owned by procurement) and production orders (owned by manufacturing). [SSOT] Superseded by authoritative table inventory.inventory_replenishment_order for concept \'replenishment_order\'. SSOT: canonical table is inventory.inventory_replenishment_order. [SSOT for concept \'replenishment_order\'.]'
}

Table supply.network_node {
  network_node_id varchar [pk, note: 'Primary key for network_node']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: Network nodes (plants, DCs) belong to a legal entity (company code) for statutory reporting, intercompany transactions, and tax compliance. In consumer goods with multi-country operations, this is a f']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Operating costs of each network node (warehouse, DC) are allocated to a cost center for overhead accounting and performance tracking.']
  parent_network_node_id varchar [note: 'The parent network node id of the network node record']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Distribution network nodes (DCs, warehouses, plants) are mapped to profit centers for cost allocation, P&L reporting by location, and transfer pricing in consumer goods. This is a fundamental organiza']
  address_line_1 varchar [note: 'Primary street address line for the supply network node location. Organizational contact data classified as confidential.']
  address_line_2 varchar [note: 'Secondary address line (suite, building, floor) for the supply network node location. Organizational contact data classified as confidential.']
  amount decimal(18,4) [note: 'The amount of the network node record']
  capacity_class varchar [note: 'Classification of the supply network node storage and throughput capacity used in IBP supply planning for capacity-constrained optimization.']
  city varchar [note: 'City where the supply network node is located. Used for geographic analysis and transportation planning. Organizational contact data classified as confidential.']
  code varchar [note: 'The network node code of the network node record']
  country_code varchar [note: 'The country code of the network node record']
  created_timestamp timestamp [note: 'Timestamp when this supply network node record was first created in the system. Used for audit trail and data lineage.']
  cross_dock_enabled_flag boolean [note: 'Indicates whether this supply network node supports cross-docking operations (direct transfer without storage). Used in transportation and distribution planning.']
  currency_code varchar [note: 'The currency code of the network node record']
  description varchar [note: 'The network node description of the network node record']
  dsd_enabled_flag boolean [note: 'Indicates whether this supply network node supports Direct Store Delivery operations. Used in distribution planning and route optimization.']
  echelon_level varchar [note: 'The echelon level of the network node record']
  effective_end_date date [note: 'Date when this supply network node was decommissioned or removed from the active supply network. Null for currently active nodes.']
  effective_from date [note: 'The effective from of the network node record']
  effective_start_date date [note: 'Date when this supply network node became operational and active in the supply network. Used for historical network analysis and planning.']
  effective_until date [note: 'The effective until of the network node record']
  gln varchar [note: 'GS1 Global Location Number uniquely identifying the physical location of the supply network node for EDI transactions and supply chain visibility.']
  hazmat_certified_flag boolean [note: 'Indicates whether this supply network node is certified to handle and store hazardous materials. Used for product allocation and regulatory compliance.']
  is_active boolean [note: 'The is active of the network node record']
  last_modified_timestamp timestamp [note: 'Timestamp when this supply network node record was last updated. Used for change tracking and data synchronization.']
  latitude decimal(10,7) [note: 'Geographic latitude coordinate of the supply network node in decimal degrees. Used for transportation optimization and network design analytics.']
  lead_time_days varchar [note: 'Standard lead time in days from this supply network node to downstream nodes or customers. Used in DRP execution and ATP/CTP calculations.']
  longitude decimal(10,7) [note: 'Geographic longitude coordinate of the supply network node in decimal degrees. Used for transportation optimization and network design analytics.']
  name varchar [note: 'The network node name of the network node record']
  network_node_status varchar [note: 'The network node status of the network node record']
  node_code varchar [note: 'Business identifier code for the supply network node used across planning and execution systems. Typically a short alphanumeric code used in SAP IBP and ERP systems.']
  node_name varchar [note: 'Human-readable name of the supply network node (e.g., \'Chicago Regional DC\', \'Memphis Manufacturing Plant\', \'Dallas Forward DC\').']
  node_status varchar [note: 'Current operational status of the supply network node in the supply planning system. Active nodes participate in DRP and IBP planning runs.']
  node_type varchar [note: 'Classification of the supply network node indicating its role in the supply chain (manufacturing plant, regional distribution center, forward distribution center, co-manufacturer, third-party logistics warehouse, cross-dock facility, or supplier location). [ENUM-REF-CANDIDATE: manufacturing_plant|regional_dc|forward_dc|co_manufacturer|3pl_warehouse|cross_dock|supplier_location — 7 candidates stripped; promote to reference product]']
  notes varchar [note: 'The notes of the network node record']
  ownership_type varchar [note: 'Ownership model of the supply network node (company-owned, leased, third-party logistics managed, co-manufacturer, or contract facility). Used for cost allocation and strategic network design.']
  planning_group varchar [note: 'Planning group or cluster assignment for the supply network node used in IBP and S&OP processes to aggregate nodes for planning purposes.']
  postal_code varchar [note: 'Postal or ZIP code for the supply network node location. Used for logistics routing and delivery planning. Organizational contact data classified as confidential.']
  quantity decimal(18,4) [note: 'The quantity of the network node record']
  region varchar [note: 'The region of the network node record']
  replenishment_frequency varchar [note: 'Standard replenishment frequency for inventory at this supply network node. Used in DRP planning and inventory policy definition.']
  safety_stock_days varchar [note: 'Target safety stock coverage in days of supply maintained at this network node. Used in inventory optimization and S&OP planning.']
  source_system_code varchar [note: 'The source system code of the network node record']
  sourcing_priority varchar [note: 'Priority ranking of this supply network node in sourcing rules and allocation logic (lower number = higher priority). Used in IBP supply planning and ATP/CTP allocation.']
  state_province varchar [note: 'State or province code where the supply network node is located. Used for tax jurisdiction and regulatory compliance. Organizational contact data classified as confidential.']
  storage_capacity_units decimal(15,2) [note: 'Maximum storage capacity of the supply network node measured in standard storage units (pallets, cases, or cubic meters). Used for inventory optimization and DRP planning.']
  storage_capacity_uom varchar [note: 'Unit of measure for the storage capacity (pallets, cases, cubic meters, square meters). Aligns with WMS and IBP planning units.']
  temperature_controlled_flag boolean [note: 'Indicates whether this supply network node has temperature-controlled storage capabilities for temperature-sensitive products. Used in product allocation and quality management.']
  throughput_capacity_daily decimal(15,2) [note: 'Maximum daily throughput capacity of the supply network node measured in standard units (cases, pallets, or production units per day). Used for production and distribution planning.']
  throughput_capacity_uom varchar [note: 'Unit of measure for the daily throughput capacity. Used in production scheduling and distribution planning.']
  time_zone varchar [note: 'IANA time zone identifier for the supply network node location (e.g., America/Chicago, America/New_York). Used for scheduling and ATP/CTP calculations.']
  uom varchar [note: 'The uom of the network node record']
  updated_timestamp timestamp [note: 'The updated timestamp of the network node record']
  vmi_enabled_flag boolean [note: 'Indicates whether this supply network node participates in Vendor Managed Inventory programs. Used in collaborative planning and replenishment processes.']

  Note: 'Master entity representing each node in the supply network (manufacturing plant, regional DC, forward DC, co-manufacturer, 3PL site). Captures node type, geographic location, capacity class, lead time to downstream nodes, sourcing rules, and active status. Forms the backbone of the supply network design used in IBP supply planning and DRP.'
}

Table supply.network_lane {
  network_lane_id varchar [pk, note: 'Primary key for network_lane']
  carrier_contract_id varchar [note: 'Foreign key linking to logistics.carrier_contract. Business justification: Lane Rate Governance process: each supply network lane is executed under a specific carrier contract defining rates, SLAs, and penalty clauses. Linking network_lane to carrier_contract enables contrac']
  carrier_id varchar [note: 'Identifier of the preferred or contracted transportation carrier servicing this lane. Used for freight planning and cost estimation.']
  destination_location_supply_network_node_id varchar [note: 'Identifier of the receiving supply network node (distribution center, warehouse, retail store, or customer location) to which goods are delivered.']
  destination_network_node_id varchar [note: 'The destination network node id of the network lane record']
  lane_id varchar [note: 'The lane id of the network lane record']
  origin_network_node_id varchar [note: 'The origin network node id of the network lane record']
  primary_supply_network_node_id varchar [note: 'Identifier of the originating supply network node (plant, distribution center, warehouse, or external supplier) from which goods are sourced.']
  amount decimal(18,4) [note: 'The amount of the network lane record']
  capacity_quantity decimal(18,3) [note: 'Maximum throughput capacity of this lane per planning period (day, week, month), representing the upper limit of goods that can be moved. Used by Supply Planning and Sales and Operations Planning (S&OP) for capacity-constrained optimization.']
  capacity_uom varchar [note: 'Unit of measure for the capacity quantity field, indicating how lane capacity is measured and constrained. [ENUM-REF-CANDIDATE: EA|CS|PL|TU|KG|LB|L|GAL — 8 candidates stripped; promote to reference product]']
  code varchar [note: 'The network lane code of the network lane record']
  compliance_requirements varchar [note: 'Regulatory or business compliance requirements applicable to this lane, such as temperature control (Good Manufacturing Practice - GMP), hazardous materials handling (Environmental Protection Agency - EPA), or cross-border customs (Food and Drug Administration - FDA).']
  cost_per_unit decimal(18,4) [note: 'Standard transportation or transfer cost per unit of measure for moving goods along this lane. Used for supply chain cost modeling and total landed cost calculations.']
  created_timestamp timestamp [note: 'Timestamp when this supply network lane record was first created in the system, following ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for cost and pricing on this lane (e.g., USD, EUR, GBP).']
  description varchar [note: 'The network lane description of the network lane record']
  distance_km decimal(12,2) [note: 'The distance km of the network lane record']
  effective_end_date date [note: 'Date when this supply network lane ceases or will cease to be effective. Null for lanes with no planned end date.']
  effective_from date [note: 'The effective from of the network lane record']
  effective_start_date date [note: 'Date when this supply network lane becomes or became effective and available for use in planning and execution systems.']
  effective_until date [note: 'The effective until of the network lane record']
  is_active boolean [note: 'Boolean flag indicating whether this lane is currently active and available for use in supply planning and replenishment. True if active; false if temporarily or permanently disabled.']
  is_primary_lane boolean [note: 'Boolean flag indicating whether this lane is the primary (preferred) sourcing route for the destination. True if this is the default lane used under normal conditions; false for backup or secondary lanes.']
  lane_cost_per_unit decimal(18,4) [note: 'The lane cost per unit of the network lane record']
  lane_mode varchar [note: 'The lane mode of the network lane record']
  lane_type varchar [note: 'Classification of the supply network lane based on the nature of the sourcing relationship: production (from manufacturing plant), transfer (between internal facilities), external procurement (from supplier), direct shipment (plant to customer), cross-dock (no storage), or drop-ship (supplier to customer).']
  last_modified_by varchar [note: 'Identifier of the user or system process that last modified this supply network lane record, used for audit trail and data governance.']
  last_modified_timestamp timestamp [note: 'Timestamp when this supply network lane record was most recently updated, following ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).']
  lead_time_days decimal(10,2) [note: 'The lead time days of the network lane record']
  lot_size_quantity decimal(18,3) [note: 'Standard batch or lot size for replenishment orders on this lane. Orders are typically rounded to multiples of this quantity for operational efficiency (e.g., full pallet, full truckload).']
  max_capacity_units decimal(18,3) [note: 'The max capacity units of the network lane record']
  maximum_order_quantity decimal(18,3) [note: 'Maximum quantity that can be ordered or shipped on this lane in a single replenishment cycle, constrained by capacity, vehicle limits, or storage restrictions.']
  min_order_quantity decimal(18,4) [note: 'The min order quantity of the network lane record']
  min_shipment_units decimal(18,3) [note: 'The min shipment units of the network lane record']
  minimum_order_quantity decimal(18,3) [note: 'Minimum quantity that must be ordered or shipped on this lane to meet operational or economic constraints. Used by DRP to ensure replenishment orders meet minimum thresholds.']
  name varchar [note: 'The network lane name of the network lane record']
  network_lane_status varchar [note: 'Current lifecycle status of the supply network lane: active (operational), inactive (temporarily disabled), suspended (on hold), planned (future activation), or decommissioned (permanently closed).']
  notes varchar [note: 'Free-text field for additional operational notes, special handling instructions, or contextual information about this supply network lane.']
  otif_target_pct decimal(5,2) [note: 'Specific target percentage for On Time In Full delivery performance on this lane, a key supply chain Key Performance Indicator (KPI) measuring the percentage of orders delivered on time and complete.']
  planning_group varchar [note: 'Organizational grouping or planning segment to which this lane belongs, used for segmented planning and reporting in Sales and Operations Planning (S&OP) and Integrated Business Planning (IBP).']
  processing_lead_time_days decimal(10,2) [note: 'Time in days required for order processing, picking, packing, and loading at the source location before shipment begins.']
  quantity decimal(18,4) [note: 'The quantity of the network lane record']
  risk_category varchar [note: 'Supply risk classification for this lane based on factors such as lead time variability, carrier reliability, geopolitical risk, and single-source dependency. Used for supply risk management and contingency planning.']
  safety_stock_days decimal(10,2) [note: 'Number of days of safety stock coverage recommended at the destination to buffer against variability in this lanes lead time and demand. Used by Inventory Optimization to calculate safety stock targets.']
  service_level_target_pct decimal(5,2) [note: 'Target service level percentage for on-time and in-full delivery performance on this lane, expressed as a percentage (e.g., 95.00 for 95%). Used to measure On Time In Full (OTIF) performance.']
  source_system_code varchar [note: 'The source system code of the network lane record']
  sourcing_priority varchar [note: 'Numeric ranking indicating the preference order for this lane when multiple sourcing options exist for the same destination. Lower numbers indicate higher priority (1 = primary, 2 = secondary, etc.). Used by Distribution Requirements Planning (DRP) and Integrated Business Planning (IBP) to determine replenishment routing.']
  standard_lead_time_days decimal(10,2) [note: 'Total planned lead time in days from order placement to goods receipt at destination, including processing time, transportation time, and buffer. Used by Material Requirements Planning (MRP) and Distribution Requirements Planning (DRP) for replenishment calculations.']
  transit_time_days varchar [note: 'The transit time days of the network lane record']
  transport_mode varchar [note: 'The transport mode of the network lane record']
  transportation_lead_time_days decimal(10,2) [note: 'Transit time in days for goods to move from source to destination, excluding processing and handling time. Component of the total standard lead time.']
  transportation_mode varchar [note: 'Primary method of transportation used for moving goods along this lane: truck (road freight), rail (train), ocean (sea freight), air (air cargo), intermodal (combination), or parcel (small package delivery).']
  unit_of_measure varchar [note: 'Unit of measure for quantities on this lane: EA (each), CS (case), PL (pallet), TU (truck unit), KG (kilogram), LB (pound), L (liter), GAL (gallon). Aligns with GS1 standards. [ENUM-REF-CANDIDATE: EA|CS|PL|TU|KG|LB|L|GAL — 8 candidates stripped; promote to reference product]']
  uom varchar [note: 'The uom of the network lane record']
  updated_timestamp timestamp [note: 'The updated timestamp of the network lane record']

  Note: 'Master entity defining the sourcing lane between two supply network nodes (source-destination pair). Captures lane type (production, transfer, external procurement), primary/secondary sourcing priority, standard lead time, transportation lead time, minimum order quantity (MOQ), lot size, and active status. Used by DRP and IBP to determine replenishment routing.'
}

Table supply.atp_record {
  atp_record_id varchar [pk, note: 'Primary key for atp_record']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: In consumer goods, marketing teams request ATP confirmation before committing to campaign launch dates and volume commitments. Linking atp_record directly to campaign enables campaign-specific availab']
  consensus_demand_id varchar [note: 'Foreign key linking to supply.consensus_demand. Business justification: ATP records are calculated against consensus demand volumes from the S&OP process. Linking atp_record to the specific consensus_demand record enables ATP availability measurement against committed con']
  demand_plan_id varchar [note: 'Foreign key linking to supply.demand_plan. Business justification: ATP/CTP calculations consume demand from demand plans. The demand_pegging_reference STRING column on atp_record is a free-text reference to the demand plan — replacing it with a proper FK demand_plan_']
  forecast_version_id varchar [note: 'Foreign key linking to supply.forecast_version. Business justification: ATP calculations consume forecast demand from a specific forecast version. The forecast_consumption_quantity on atp_record represents how much of the forecast has been consumed by committed orders. Li']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: CPG Capable-to-Promise (CTP) checks require component/material ATP alongside finished goods ATP. Material availability at a node determines whether a production order can be confirmed. CPG supply plan']
  order_id varchar [note: 'Foreign key linking to sales.order. Business justification: ATP checks are performed at sales order entry to confirm fulfillment promises. Linking atp_record to the sales order it was generated for enables OTIF tracking, customer promise management, and backor']
  origin_network_node_id varchar [note: 'The origin network node id of the atp record record']
  primary_atp_supply_network_node_id varchar [note: 'Reference to the distribution facility or warehouse location where ATP is calculated.']
  replenishment_order_id varchar [note: 'Foreign key linking to supply.supply_replenishment_order. Business justification: ATP records peg available supply to demand by referencing specific supply replenishment orders. The supply_pegging_reference STRING column on atp_record is a free-text reference to the supply order — ']
  sku_id varchar [note: 'Reference to the SKU for which ATP is calculated.']
  sop_cycle_id varchar [note: 'Foreign key linking to supply.sop_cycle. Business justification: ATP/CTP calculations are performed within a specific S&OP/IBP planning cycle. The planning_version STRING on atp_record references a planning cycle context. Linking to sop_cycle via a proper FK enable']
  allocated_quantity decimal(18,3) [note: 'The quantity already committed or reserved for existing sales orders, reducing available ATP.']
  amount decimal(18,4) [note: 'The amount of the atp record record']
  atp_calculation_method varchar [note: 'The method used to calculate ATP. Simple ATP considers only on-hand inventory minus allocations. Cumulative ATP includes planned receipts over time. Multi-level ATP considers BOM components. Product allocation ATP applies allocation rules across customer segments.']
  atp_check_horizon_days varchar [note: 'The number of days into the future that the ATP check considers for availability. Defines the planning horizon for promise calculations.']
  atp_confirmation_number varchar [note: 'Unique confirmation number generated when ATP is reserved for a sales order, providing traceability between ATP records and order promising.']
  atp_date date [note: 'The date for which ATP quantity is calculated. Represents the promise date for order fulfillment.']
  atp_quantity decimal(18,3) [note: 'The confirmed quantity available to promise to customers for the given SKU, location, and date. Represents uncommitted inventory available for new orders.']
  atp_record_status varchar [note: 'The atp record status of the atp record record']
  atp_status varchar [note: 'The current status of the ATP record. Available indicates positive ATP. Constrained indicates limited availability. Blocked indicates ATP is not available for promising. Expired indicates the ATP date has passed.']
  available_date date [note: 'The available date of the atp record record']
  available_quantity decimal(18,4) [note: 'The available quantity of the atp record record']
  backorder_quantity decimal(18,3) [note: 'The quantity of unfulfilled demand from previous periods that impacts current ATP availability.']
  calculation_timestamp timestamp [note: 'The exact date and time when this ATP record was calculated. Critical for understanding data freshness and order promising accuracy.']
  code varchar [note: 'The atp record code of the atp record record']
  committed_quantity decimal(18,3) [note: 'The committed quantity of the atp record record']
  created_timestamp timestamp [note: 'The timestamp when this ATP record was first created in the lakehouse silver layer.']
  ctp_quantity decimal(18,3) [note: 'The quantity that can be promised considering both current inventory and planned production or supply receipts. Extends ATP by including future supply.']
  cumulative_atp decimal(18,3) [note: 'The cumulative atp of the atp record record']
  cumulative_atp_quantity decimal(18,3) [note: 'The cumulative ATP quantity calculated across multiple time periods, showing total available quantity from current date through the ATP date.']
  currency_code varchar [note: 'The currency code of the atp record record']
  customer_priority_tier varchar [note: 'The priority tier of the customer or channel for which ATP is being calculated, used in allocation scenarios where high-priority customers receive preferential ATP.']
  description varchar [note: 'The atp record description of the atp record record']
  effective_from date [note: 'The effective from of the atp record record']
  effective_until date [note: 'The effective until of the atp record record']
  expiration_date date [note: 'The expiration date of the inventory lot or batch, relevant for FEFO (First Expired First Out) ATP logic in consumer goods with shelf life constraints.']
  forecast_consumption_quantity decimal(18,3) [note: 'The quantity of forecast demand consumed by actual sales orders, used in ATP calculations to avoid double-counting demand.']
  intransit_quantity decimal(18,3) [note: 'The quantity currently in transit to the location that will contribute to ATP upon arrival.']
  minimum_shelf_life_days varchar [note: 'The minimum remaining shelf life in days required for the product to be available for promising, ensuring customers receive products with adequate shelf life.']
  name varchar [note: 'The atp record name of the atp record record']
  notes varchar [note: 'The notes of the atp record record']
  on_hand_inventory decimal(18,3) [note: 'The physical inventory quantity available at the location at the time of ATP calculation.']
  on_hand_quantity decimal(18,3) [note: 'The on hand quantity of the atp record record']
  planned_receipt_quantity decimal(18,3) [note: 'The quantity expected to be received from production orders, purchase orders, or transfers by the ATP date.']
  planning_bucket varchar [note: 'The planning bucket of the atp record record']
  planning_version varchar [note: 'The planning scenario or version identifier in SAP IBP under which this ATP calculation was performed, enabling what-if analysis and scenario planning.']
  product_allocation_group varchar [note: 'The allocation group or priority segment assigned to this ATP calculation, used when ATP is allocated across customer tiers or channels.']
  production_order_quantity decimal(18,3) [note: 'The quantity scheduled for production that will be available by the ATP date.']
  purchase_order_quantity decimal(18,3) [note: 'The quantity on open purchase orders expected to be received by the ATP date.']
  quantity decimal(18,4) [note: 'The quantity of the atp record record']
  safety_stock_quantity decimal(18,3) [note: 'The minimum inventory buffer maintained to protect against demand variability and supply uncertainty. May reduce ATP if policy enforces safety stock protection.']
  source_system_code varchar [note: 'The source system code of the atp record record']
  source_system_record_code varchar [note: 'The unique identifier of this ATP record in the source operational system, enabling traceability and reconciliation.']
  supply_quantity decimal(18,3) [note: 'The supply quantity of the atp record record']
  unit_of_measure varchar [note: 'The unit of measure for all quantity fields in this record. Common values: EA (each), CS (case), PL (pallet), KG (kilogram), LB (pound), L (liter), GAL (gallon). [ENUM-REF-CANDIDATE: EA|CS|PL|KG|LB|L|GAL — 7 candidates stripped; promote to reference product]']
  uom varchar [note: 'The uom of the atp record record']
  updated_timestamp timestamp [note: 'The timestamp when this ATP record was last updated in the lakehouse silver layer.']

  Note: 'Transactional record capturing the Available-to-Promise (ATP) and Capable-to-Promise (CTP) calculation results for each SKU/location/date combination. Stores confirmed ATP quantity, CTP quantity, cumulative ATP, demand pegging reference, supply pegging reference, calculation timestamp, and ATP method (simple, cumulative, multi-level). Consumed by sales order management for order promising.'
}

Table supply.sop_cycle {
  sop_cycle_id varchar [pk, note: 'Unique identifier for the S&OP/IBP planning cycle instance. Primary key.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: S&OP cycles in consumer goods are explicitly scoped to profit centers for the financial review step — revenue, margin, and gap-to-target are reviewed by profit center during each cycle. This link enab']
  amount decimal(18,4) [note: 'The amount of the sop cycle record']
  baseline_demand_volume decimal(18,2) [note: 'The total baseline demand volume (in units) across all SKUs for the planning horizon at the start of this cycle.']
  code varchar [note: 'The sop cycle code of the sop cycle record']
  consensus_demand_volume decimal(18,2) [note: 'The total consensus demand volume (in units) across all SKUs after demand review adjustments.']
  consensus_meeting_date date [note: 'The consensus meeting date of the sop cycle record']
  constrained_supply_volume decimal(18,2) [note: 'The total constrained supply volume (in units) that can be delivered given capacity and material constraints.']
  created_timestamp timestamp [note: 'The timestamp when this S&OP cycle record was first created in the system.']
  currency_code varchar [note: 'The currency code of the sop cycle record']
  cycle_code varchar [note: 'Short alphanumeric code uniquely identifying the cycle for external reference and system integration (e.g., \'SOP-2024-01\', \'IBP-Q1-24\').']
  cycle_end_date date [note: 'The date when this S&OP cycle is scheduled to complete and be locked (typically before the start of the planning month).']
  cycle_locked_date date [note: 'The date when this S&OP cycle was locked and finalized.']
  cycle_locked_flag boolean [note: 'Indicates whether this S&OP cycle has been locked and no further changes are permitted (True if locked, False if still open for edits).']
  cycle_name varchar [note: 'Business-friendly name or label for the S&OP cycle (e.g., \'January 2024 S&OP Cycle\', \'Q1 FY2024 IBP\').']
  cycle_notes varchar [note: 'General free-text notes or comments about this S&OP cycle, including special circumstances, deviations from standard process, or other relevant context.']
  cycle_phase varchar [note: 'Current phase of the S&OP cycle: statistical_forecast (initial statistical forecast generation), demand_review (demand planning team review), supply_review (supply planning team review), pre_sop (pre-S&OP reconciliation meeting), executive_sop (executive S&OP decision meeting), closed (cycle completed and locked).']
  cycle_start_date date [note: 'The date when this S&OP cycle officially begins (typically the first day of the cycle month).']
  cycle_status varchar [note: 'The cycle status of the sop cycle record']
  cycle_type varchar [note: 'The cadence or type of S&OP cycle: monthly (standard monthly cadence), quarterly (quarterly review), annual (annual planning), rolling (continuous rolling horizon), event_driven (triggered by specific business events).']
  demand_consensus_achieved_flag boolean [note: 'Indicates whether demand consensus was achieved during the demand review phase (True if consensus reached, False otherwise).']
  demand_review_date date [note: 'The demand review date of the sop cycle record']
  demand_review_due_date date [note: 'Target date by which the demand review phase must be completed.']
  description varchar [note: 'The sop cycle description of the sop cycle record']
  effective_from date [note: 'The effective from of the sop cycle record']
  effective_until date [note: 'The effective until of the sop cycle record']
  end_date date [note: 'The end date of the sop cycle record']
  executive_approval_date date [note: 'The date when the executive sponsor formally approved the S&OP plan for this cycle.']
  executive_approval_flag boolean [note: 'Indicates whether the executive S&OP meeting approved the plan (True if approved, False if rejected or pending).']
  executive_approval_notes varchar [note: 'Free-text notes or comments from the executive sponsor regarding the approval decision, including any conditions or action items.']
  executive_review_date date [note: 'The executive review date of the sop cycle record']
  executive_sop_meeting_date date [note: 'Scheduled date for the executive S&OP meeting where senior leadership reviews and approves the plan.']
  fiscal_period varchar [note: 'The fiscal period (month number) within the fiscal year (e.g., 1 for January, 12 for December).']
  fiscal_year varchar [note: 'The fiscal year to which this planning cycle belongs (e.g., 2024).']
  frozen_period_months varchar [note: 'The number of months at the start of the planning horizon that are frozen and not subject to change (typically 0-3 months).']
  key_assumptions varchar [note: 'Free-text field capturing the key business assumptions underlying this S&OP cycle (e.g., promotional plans, market trends, supply constraints, new product launches).']
  key_risks varchar [note: 'Free-text field documenting the key risks identified during this S&OP cycle (e.g., supplier reliability, demand volatility, capacity constraints).']
  last_modified_timestamp timestamp [note: 'The timestamp when this S&OP cycle record was last updated.']
  mitigation_actions varchar [note: 'Free-text field describing the mitigation actions agreed upon to address identified risks and supply gaps.']
  name varchar [note: 'The sop cycle name of the sop cycle record']
  notes varchar [note: 'The notes of the sop cycle record']
  phase_status varchar [note: 'Status of the current cycle phase: not_started (phase has not begun), in_progress (phase is actively underway), completed (phase finished and approved), on_hold (phase temporarily paused), cancelled (phase or cycle cancelled).']
  planning_horizon_months varchar [note: 'The number of months into the future that this S&OP cycle plans (e.g., 18 months, 24 months).']
  planning_month date [note: 'The target month for which this S&OP cycle is planning demand and supply (typically the first day of the planning month).']
  pre_sop_meeting_date date [note: 'Scheduled date for the pre-S&OP reconciliation meeting where demand and supply teams align on recommendations.']
  pre_sop_review_date date [note: 'The pre sop review date of the sop cycle record']
  quantity decimal(18,4) [note: 'The quantity of the sop cycle record']
  sop_cycle_status varchar [note: 'The sop cycle status of the sop cycle record']
  source_system_code varchar [note: 'The source system code of the sop cycle record']
  start_date date [note: 'The start date of the sop cycle record']
  statistical_forecast_due_date date [note: 'Target date by which the statistical forecast phase must be completed.']
  supply_consensus_achieved_flag boolean [note: 'Indicates whether supply consensus was achieved during the supply review phase (True if consensus reached, False otherwise).']
  supply_gap_volume decimal(18,2) [note: 'The total supply gap (in units) representing the difference between consensus demand and constrained supply (positive indicates shortfall, negative indicates surplus).']
  supply_review_date date [note: 'The supply review date of the sop cycle record']
  supply_review_due_date date [note: 'Target date by which the supply review phase must be completed.']
  uom varchar [note: 'The uom of the sop cycle record']
  updated_timestamp timestamp [note: 'The updated timestamp of the sop cycle record']

  Note: 'Master entity representing each S&OP/IBP planning cycle instance (monthly cadence). Captures cycle name, planning month, cycle phase (statistical forecast, demand review, supply review, pre-S&OP, executive S&OP), phase status, cycle owner, key milestones, and sign-off records. Provides the governance framework for all demand and supply planning activities within the cycle.'
}

Table supply.consensus_demand {
  consensus_demand_id varchar [pk, note: 'Unique identifier for the consensus demand record. Primary key for this entity representing a single agreed demand signal from the S&OP demand review process.']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: consensus_demand holds \'marketing_event_uplift_quantity\', \'commercial_overlay_quantity\', and \'promotion_flag\' — all campaign-sourced inputs agreed in S&OP consensus meetings. Direct FK to campaign ena']
  demand_plan_id varchar [note: 'FK to supply.demand_plan.demand_plan_id — Links consensus demand records to demand plan header. Required for S&OP process tracking and forecast accuracy measurement.']
  forecast_version_id varchar [note: 'Foreign key linking to supply.forecast_version. Business justification: Consensus demand is derived from and compared against a specific forecast version during the S&OP demand review. The statistical_forecast_quantity and forecast_model_code on consensus_demand reference']
  hierarchy_id varchar [note: 'Foreign key linking to product.hierarchy. Business justification: CPG S&OP consensus demand is agreed at hierarchy levels (brand/category) before SKU disaggregation. Category managers and brand teams provide consensus inputs at hierarchy nodes. This link supports th']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Consensus demand in consumer goods S&OP is the agreed volume by profit center — finance inputs (finance_input_quantity already on consensus_demand) and approves figures by profit center for revenue pl']
  sku_id varchar [note: 'Reference to the product SKU for which consensus demand is being planned. Links to the product master data.']
  sop_cycle_id varchar [note: 'Reference to the specific S&OP or IBP cycle during which this consensus demand was agreed. Enables tracking of demand evolution across planning cycles.']
  supply_network_node_id varchar [note: 'Reference to the planning location (distribution center, plant, or market) for which this consensus demand applies.']
  active_flag boolean [note: 'Indicates whether this consensus demand record is currently active and should be used by supply planning. False indicates the record has been superseded or deactivated.']
  agreed_date date [note: 'The agreed date of the consensus demand record']
  amount decimal(18,4) [note: 'The amount of the consensus demand record']
  approval_status varchar [note: 'Current approval state of the consensus demand record within the S&OP workflow. Only approved records are released to supply planning.']
  approval_timestamp timestamp [note: 'Date and time when the consensus demand was formally approved and released to supply planning. Marks the transition from draft to official demand signal.']
  approved_quantity decimal(18,3) [note: 'The approved quantity of the consensus demand record']
  bias_indicator varchar [note: 'Indicator of systematic forecasting bias based on historical performance. Over-forecast indicates consistent overestimation; under-forecast indicates consistent underestimation; neutral indicates balanced accuracy.']
  code varchar [note: 'The consensus demand code of the consensus demand record']
  comments varchar [note: 'Free-text field for demand planners to capture additional context, assumptions, risks, or special considerations related to this consensus demand record.']
  commercial_input_quantity decimal(18,3) [note: 'The commercial input quantity of the consensus demand record']
  commercial_overlay_quantity decimal(18,3) [note: 'The demand adjustment applied by commercial teams based on market intelligence, customer commitments, and sales insights. Can be positive or negative.']
  confidence_level varchar [note: 'Qualitative assessment of confidence in the consensus demand figure based on data quality, market stability, and input reliability. Used for risk-based supply planning.']
  consensus_demand_status varchar [note: 'The consensus demand status of the consensus demand record']
  consensus_quantity decimal(18,3) [note: 'The final agreed demand volume for this SKU/location/period after all inputs and overlays have been applied. This is the single demand signal passed to supply planning and represents the official forecast.']
  constrained_flag boolean [note: 'Indicates whether the consensus demand has been adjusted downward due to known supply constraints. True means demand was constrained; false means demand is unconstrained.']
  constraint_reason varchar [note: 'Explanation of the supply constraint that limited consensus demand (e.g., production capacity, raw material shortage, distribution capacity). Populated only when constrained_flag is true.']
  created_timestamp timestamp [note: 'Date and time when this consensus demand record was first created in the system. Part of standard audit trail.']
  currency_code varchar [note: 'The currency code of the consensus demand record']
  customer_commitment_quantity decimal(18,3) [note: 'Demand volume backed by firm customer orders, contracts, or commitments for this planning period. Represents the most reliable component of consensus demand.']
  demand_category varchar [note: 'Classification of the demand type to enable segmented planning and analysis. Base demand represents ongoing business; promotional and seasonal reflect event-driven spikes; new launch and phase-out support lifecycle transitions.']
  demand_driver_code varchar [note: 'Code identifying the primary business driver or causal factor influencing this demand (e.g., holiday season, weather pattern, competitive action, regulatory change). Supports root-cause analysis.']
  demand_driver_description varchar [note: 'Detailed explanation of the demand driver or business rationale behind the consensus demand figure. Captures qualitative insights from demand planners and commercial teams.']
  demand_volatility_index decimal(5,2) [note: 'Statistical measure of demand variability for this SKU/location combination, typically expressed as coefficient of variation. Higher values indicate greater uncertainty and require higher safety stock.']
  description varchar [note: 'The consensus demand description of the consensus demand record']
  effective_from date [note: 'The effective from of the consensus demand record']
  effective_until date [note: 'The effective until of the consensus demand record']
  finance_input_quantity decimal(18,3) [note: 'The finance input quantity of the consensus demand record']
  forecast_accuracy_previous_period decimal(5,2) [note: 'The forecast accuracy percentage achieved for this SKU/location combination in the previous planning period. Used to assess forecasting performance trends and adjust confidence levels.']
  forecast_model_code varchar [note: 'Identifier of the statistical forecasting model or algorithm used to generate the baseline statistical forecast (e.g., exponential smoothing, ARIMA, machine learning model).']
  last_modified_timestamp timestamp [note: 'Date and time when this consensus demand record was last updated. Tracks the most recent change to any field in the record.']
  last_review_date date [note: 'Date when this consensus demand record was last reviewed and validated by the demand planning team during the S&OP demand review meeting.']
  marketing_event_uplift_quantity decimal(18,3) [note: 'Incremental demand volume expected from planned marketing campaigns, promotions, or trade events during this planning period.']
  name varchar [note: 'The consensus demand name of the consensus demand record']
  new_product_launch_quantity decimal(18,3) [note: 'Demand volume attributed to new product introductions or product launches scheduled for this planning period. Typically based on launch plans and market sizing.']
  next_review_date date [note: 'Scheduled date for the next S&OP demand review when this consensus demand will be re-evaluated and updated based on latest market intelligence.']
  notes varchar [note: 'The notes of the consensus demand record']
  planning_bucket varchar [note: 'The planning bucket of the consensus demand record']
  planning_horizon_type varchar [note: 'Classification of the planning time horizon for this demand record. Short-term (0-3 months) is firm; medium-term (3-12 months) is flexible; long-term (12+ months) is strategic.']
  promotion_flag boolean [note: 'Indicates whether this consensus demand includes uplift from planned trade promotions or marketing events. True means promotional activity is planned; false means base demand only.']
  quantity decimal(18,4) [note: 'The quantity of the consensus demand record']
  seasonality_factor decimal(5,2) [note: 'Multiplicative factor representing seasonal demand patterns for this planning period. Values above 1.0 indicate peak season; below 1.0 indicate off-season.']
  source_system_code varchar [note: 'The source system code of the consensus demand record']
  statistical_forecast_quantity decimal(18,3) [note: 'The baseline demand forecast generated by statistical forecasting algorithms before any manual adjustments or commercial overlays. Serves as the starting point for consensus demand.']
  statistical_quantity decimal(18,3) [note: 'The statistical quantity of the consensus demand record']
  unconstrained_demand_quantity decimal(18,3) [note: 'The theoretical demand volume if all supply constraints (capacity, materials, inventory) were removed. Used for capacity planning and investment decisions.']
  unit_of_measure varchar [note: 'The unit in which consensus demand quantity is expressed (each, case, pallet, kilogram, liter, etc.). Must align with product master UOM. [ENUM-REF-CANDIDATE: EA|CS|PAL|KG|LB|L|GAL — 7 candidates stripped; promote to reference product]']
  uom varchar [note: 'The uom of the consensus demand record']
  updated_timestamp timestamp [note: 'The updated timestamp of the consensus demand record']
  variance_percentage decimal(5,2) [note: 'The percentage variance between consensus demand and statistical forecast, calculated as (variance_to_statistical / statistical_forecast_quantity) * 100. Used to monitor forecast override patterns.']
  variance_to_statistical decimal(18,3) [note: 'The difference between consensus demand quantity and statistical forecast quantity. Positive values indicate upward adjustments; negative values indicate downward adjustments. Key metric for forecast bias analysis.']
  version_number varchar [note: 'Sequential version number tracking iterations of this consensus demand record within the same S&OP cycle. Increments with each revision to support change history.']

  Note: 'Transactional record capturing the final consensus demand volume agreed upon during the S&OP demand review for each SKU/location/planning period. Stores statistical forecast input, commercial overlay, marketing event uplift, new product launch volume, consensus quantity, variance to statistical baseline, approver, and S&OP cycle reference. Represents the single agreed demand signal passed to supply planning.'
}

Table sales.trade_account {
  trade_account_id varchar [pk, note: 'Unique identifier for the B2B trade account. Primary key for the trade account master record.']
  distribution_facility_id varchar [note: 'Foreign key linking to distribution.distribution_facility. Business justification: Logistics planning assigns each trade account a primary distribution center for order fulfillment and inventory allocation.']
  parent_trade_account_id varchar [note: 'The parent trade account id of the trade account record']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Profitability analysis assigns each customer to a profit center to aggregate revenue and margin in financial reporting.']
  account_close_date date [note: 'The date when this trade account was permanently closed or terminated, if applicable.']
  account_name varchar [note: 'The account name of the trade account record']
  account_number varchar [note: 'The account number of the trade account record']
  account_open_date date [note: 'The date when this trade account was first established and approved for business transactions.']
  account_status varchar [note: 'The current lifecycle status of the trade account: active (operational), inactive (dormant), suspended (temporarily blocked), pending approval (new account under review), credit hold (payment issues), or closed (permanently terminated).']
  account_tier varchar [note: 'Strategic tier classification based on account size, coverage, and business importance: Tier 1 (national key accounts), Tier 2 (regional chains), Tier 3 (local/metro accounts), Tier 4 (independent operators).']
  account_type varchar [note: 'The business model classification of the trade partner: retailer (sells to end consumers), distributor (logistics and fulfillment), wholesaler (bulk reseller), foodservice operator (restaurants/catering), or broker (sales intermediary).']
  acv_total decimal(18,2) [note: 'The total All Commodity Volume representing the annual dollar sales volume across all product categories for this retail account, used for market coverage analysis.']
  amount decimal(18,4) [note: 'The amount of the trade account record']
  code varchar [note: 'The trade account code of the trade account record']
  created_timestamp timestamp [note: 'The created timestamp of the trade account record']
  credit_limit decimal(18,4) [note: 'The credit limit of the trade account record']
  credit_limit_amount decimal(18,2) [note: 'The maximum outstanding accounts receivable balance allowed for this trade account before credit hold is applied.']
  credit_rating varchar [note: 'The credit risk rating assigned to this trade account by internal credit management or external credit bureau (e.g., AAA, AA, A, BBB, BB, B, CCC, D).']
  currency_code varchar [note: 'The 3-letter ISO 4217 currency code for all financial transactions with this trade account (e.g., USD, CAD, EUR, MXN).']
  dba_name varchar [note: 'The trade name or DBA name under which the account operates in the market, if different from legal entity name.']
  description varchar [note: 'The trade account description of the trade account record']
  dsd_delivery_flag boolean [note: 'Indicates whether this trade account receives direct store delivery (DSD) shipments bypassing the retailers distribution center.']
  dun_number varchar [note: 'The dun number of the trade account record']
  duns_number varchar [note: 'The 9-digit DUNS number assigned by Dun & Bradstreet for unique identification of the business entity.']
  edi_capable_flag boolean [note: 'Indicates whether this trade account has EDI connectivity enabled for electronic exchange of purchase orders, invoices, and advance ship notices.']
  effective_from date [note: 'The effective from of the trade account record']
  effective_until date [note: 'The effective until of the trade account record']
  gln varchar [note: 'The 13-digit GS1 Global Location Number uniquely identifying the legal entity and physical location of the trade partner.']
  headquarters_address_line1 varchar [note: 'The first line of the street address for the trade account headquarters or primary business location.']
  headquarters_address_line2 varchar [note: 'The second line of the street address (suite, floor, building) for the trade account headquarters.']
  headquarters_city varchar [note: 'The city name of the trade account headquarters location.']
  headquarters_country_code varchar [note: 'The 3-letter ISO 3166-1 alpha-3 country code for the trade account headquarters location (e.g., USA, CAN, MEX, GBR, DEU).']
  headquarters_postal_code varchar [note: 'The postal code or ZIP code of the trade account headquarters location.']
  headquarters_state_province varchar [note: 'The state, province, or administrative region of the trade account headquarters location.']
  last_order_date date [note: 'The date of the most recent purchase order received from this trade account.']
  legal_entity_name varchar [note: 'The official registered legal name of the trade partner organization as it appears on legal documents and contracts.']
  minimum_order_quantity varchar [note: 'The minimum order quantity (in units or cases) required for orders placed by this trade account.']
  name varchar [note: 'The trade account name of the trade account record']
  notes varchar [note: 'The notes of the trade account record']
  otif_sla_target_percent decimal(5,2) [note: 'The contractual OTIF service level agreement target percentage for order fulfillment performance (e.g., 95.00 represents 95% of orders delivered on time and in full).']
  payment_method varchar [note: 'The primary payment instrument used by this account: ACH (automated clearing house), wire transfer, check, EDI payment (electronic funds transfer via EDI 820), or credit card.']
  payment_terms varchar [note: 'The payment terms of the trade account record']
  payment_terms_code varchar [note: 'The standard payment terms code governing invoice payment due dates and early payment discounts (e.g., Net 30, Net 60, 2/10 Net 30).']
  previous_status varchar [note: 'The account status immediately prior to the most recent status change, maintained for audit trail and lifecycle analysis.']
  primary_contact_email varchar [note: 'The business email address of the primary contact for order management, invoicing, and account communications.']
  primary_contact_name varchar [note: 'The full name of the primary business contact or account manager at the trade partner organization.']
  primary_contact_phone varchar [note: 'The business phone number of the primary contact, including country code and extension if applicable.']
  primary_language_code varchar [note: 'The 2-letter ISO 639-1 language code for the preferred communication language with this trade account (e.g., en, es, fr, de).']
  quantity decimal(18,4) [note: 'The quantity of the trade account record']
  record_created_timestamp timestamp [note: 'The date and time when this trade account master record was first created in the system.']
  record_updated_timestamp timestamp [note: 'The date and time when this trade account master record was most recently modified.']
  source_system_code varchar [note: 'The source system code of the trade account record']
  status_change_reason varchar [note: 'The business reason or justification for the most recent account status change (e.g., payment default, business closure, credit improvement, contract renewal).']
  status_change_timestamp timestamp [note: 'The date and time when the most recent account status change occurred.']
  status_changed_by_user varchar [note: 'The user ID or name of the person who executed the most recent account status change, for audit and accountability purposes.']
  tax_exemption_flag boolean [note: 'Indicates whether this trade account holds a valid tax exemption certificate for sales tax or VAT purposes.']
  tax_number varchar [note: 'The government-issued tax identification number for this legal entity (e.g., EIN in USA, VAT number in EU, GST number in other jurisdictions).']
  tdp_count varchar [note: 'The total number of distribution points (store locations or outlets) operated by this trade account where products can be sold.']
  trade_account_status varchar [note: 'The trade account status of the trade account record']
  trade_channel varchar [note: 'The primary retail or distribution channel through which this trade account operates: grocery (supermarkets), mass (mass merchandisers), club (warehouse clubs), drug (pharmacy chains), convenience stores, foodservice (restaurants/institutions), or e-commerce (online retailers). [ENUM-REF-CANDIDATE: grocery|mass|club|drug|convenience|foodservice|e-commerce — 7 candidates stripped; promote to reference product]']
  uom varchar [note: 'The uom of the trade account record']
  updated_timestamp timestamp [note: 'The updated timestamp of the trade account record']
  vmi_enabled_flag boolean [note: 'Indicates whether this trade account participates in a VMI program where the supplier manages inventory replenishment based on POS or warehouse data.']

  Note: 'SSOT master record for all B2B trade customers including retailers, distributors, wholesalers, and foodservice operators. Captures authoritative account identity: legal entity name, trade channel classification (grocery, mass, club, drug, foodservice, e-commerce), account tier, credit rating, payment terms, currency, tax identifiers, DUNS number, GLN (GS1 Global Location Number), primary language, account status, lifecycle dates, and full status change audit history (previous status, new status, change reason, change timestamp, changed-by user). This is the golden record for all trade partner identity — every other customer domain entity references this product via FK.'
}

Table sales.account_contact {
  account_contact_id varchar [pk, note: 'Reference to another account contact record representing this contact\'s direct manager or supervisor within the trade account organization. Enables organizational hierarchy mapping.']
  trade_account_id varchar [note: 'Reference to the parent trade account (retailer, distributor, wholesaler, or foodservice operator) to which this contact belongs.']
  account_contact_status varchar [note: 'The account contact status of the account contact record']
  amount decimal(18,4) [note: 'The amount of the account contact record']
  assistant_name varchar [note: 'The name of the contact\'s administrative assistant or executive assistant, if applicable. Used for scheduling and communication routing.']
  assistant_phone varchar [note: 'The phone number of the contact\'s administrative assistant. Used for scheduling and communication routing.']
  code varchar [note: 'The account contact code of the account contact record']
  contact_notes varchar [note: 'Free-form text field for capturing additional notes, preferences, or context about the contact. Used by sales representatives to document relationship insights.']
  contact_role varchar [note: 'The contact\'s role in the buying decision process. Distinguishes between primary decision-makers, influencers, and administrative contacts. Critical for sales force automation and account planning.']
  contact_status varchar [note: 'Current lifecycle status of the contact record. Active contacts are currently employed and engaged with the account. Inactive or terminated contacts are retained for historical reference.']
  contact_type varchar [note: 'Classification of the contact\'s primary functional role at the trade account. Determines which business processes and communications this contact participates in.']
  created_timestamp timestamp [note: 'The timestamp when this contact record was first created in the system. Used for audit trail and data lineage tracking.']
  currency_code varchar [note: 'The currency code of the account contact record']
  department varchar [note: 'The organizational department or functional area within the trade account where this contact works. Examples include Procurement, Logistics, Finance, Marketing.']
  description varchar [note: 'The account contact description of the account contact record']
  effective_end_date date [note: 'The date when this contact\'s role at the trade account ended, if applicable. Null for currently active contacts. Used for historical tracking and relationship continuity.']
  effective_from date [note: 'The effective from of the account contact record']
  effective_start_date date [note: 'The date when this contact became active in their current role at the trade account. Used for tracking tenure and relationship history.']
  effective_until date [note: 'The effective until of the account contact record']
  email varchar [note: 'The email of the account contact record']
  email_address varchar [note: 'Primary business email address for the contact. Used for commercial communications, order confirmations, and business correspondence.']
  fax_number varchar [note: 'Fax number for the contact, if applicable. Still used in some trade channels for purchase orders and formal documentation.']
  first_name varchar [note: 'The given name of the individual contact at the trade account.']
  full_name varchar [note: 'The complete formatted name of the contact, typically concatenated as first name and last name. Used for display and reporting purposes.']
  is_decision_maker boolean [note: 'Boolean flag indicating whether this contact has purchasing authority and decision-making power for the account. True if decision maker, False otherwise.']
  is_primary boolean [note: 'The is primary of the account contact record']
  is_primary_contact boolean [note: 'Boolean flag indicating whether this contact is the primary point of contact for the trade account. True if primary, False otherwise.']
  job_title varchar [note: 'The official job title or position held by the contact at the trade account organization. Examples include Senior Buyer, Category Manager, Supply Chain Director.']
  language_preference varchar [note: 'The contact\'s preferred language for business communications, represented as a 3-letter ISO 639-2 language code. Examples: ENG (English), SPA (Spanish), FRA (French).']
  last_contact_date date [note: 'The date of the most recent interaction or communication with this contact. Used to track engagement frequency and identify dormant relationships.']
  last_modified_timestamp timestamp [note: 'The timestamp when this contact record was most recently updated. Used for audit trail and change tracking.']
  last_name varchar [note: 'The family name or surname of the individual contact at the trade account.']
  linkedin_profile_url varchar [note: 'The URL of the contact\'s LinkedIn professional profile. Used for social selling and relationship intelligence.']
  mobile_number varchar [note: 'Mobile or cellular phone number for the contact. Used for urgent communications and field-based retail execution activities.']
  name varchar [note: 'The account contact name of the account contact record']
  next_follow_up_date date [note: 'The scheduled date for the next planned follow-up or interaction with this contact. Supports proactive account management and sales cadence planning.']
  notes varchar [note: 'The notes of the account contact record']
  opt_in_email boolean [note: 'Boolean flag indicating whether the contact has opted in to receive commercial email communications. True if opted in, False if opted out. Required for GDPR and CCPA compliance.']
  opt_in_phone boolean [note: 'Boolean flag indicating whether the contact has opted in to receive commercial phone communications. True if opted in, False if opted out. Required for telemarketing compliance.']
  opt_in_sms boolean [note: 'Boolean flag indicating whether the contact has opted in to receive commercial SMS or text message communications. True if opted in, False if opted out.']
  phone varchar [note: 'The phone of the account contact record']
  phone_number varchar [note: 'Primary business telephone number for the contact. Includes country code, area code, and local number.']
  preferred_communication_channel varchar [note: 'The contact\'s preferred method for receiving business communications. Supports personalized engagement strategies in SFA and retail execution workflows.']
  quantity decimal(18,4) [note: 'The quantity of the account contact record']
  role_title varchar [note: 'The role title of the account contact record']
  salesforce_user_code varchar [note: 'The Salesforce user ID of the sales representative or account manager responsible for this contact. Links to the internal sales team member managing the relationship.']
  source_system_code varchar [note: 'The unique identifier for this contact in the source operational system. Used for data reconciliation and integration traceability.']
  territory_code varchar [note: 'The sales territory or region code to which this contact and their account are assigned. Used for sales force automation and territory management.']
  uom varchar [note: 'The uom of the account contact record']
  updated_timestamp timestamp [note: 'The updated timestamp of the account contact record']

  Note: 'Individual contacts associated with a trade account, including buyers, category managers, logistics coordinators, and finance contacts at the retailer or distributor. Captures full name, job title, department, contact role (primary buyer, logistics, finance, marketing), phone, email, preferred communication channel, active status, and opt-in/opt-out flags for commercial communications. Supports SFA and retail execution workflows in Salesforce Consumer Goods Cloud.'
}

Table sales.account_address {
  account_address_id varchar [pk, note: 'Unique identifier for the account address record. Primary key.']
  trade_account_id varchar [note: 'Reference to the trade account (retailer, distributor, wholesaler, or foodservice customer) that this address belongs to.']
  account_address_status varchar [note: 'Current lifecycle status of the address record. Active addresses are available for transactions; inactive addresses are retained for historical reporting; pending addresses await validation; closed addresses are permanently retired.']
  address_line_1 varchar [note: 'Primary street address line including street number, street name, and building identifier. Organizational contact data classified as confidential.']
  address_line_2 varchar [note: 'Secondary address line for suite, floor, apartment, or unit number. Organizational contact data classified as confidential.']
  address_line_3 varchar [note: 'Additional address line for complex addresses, building names, or delivery instructions. Organizational contact data classified as confidential.']
  address_name varchar [note: 'Business name or label for this address location (e.g., \'Main Distribution Center\', \'Regional Office - Northeast\', \'Store #1234\').']
  address_type varchar [note: 'Classification of the address purpose: headquarters (HQ), billing address, ship-to location, sold-to location, returns processing center, or warehouse/distribution center. Supports Electronic Data Interchange (EDI) ship-to/bill-to mapping and Direct Store Delivery (DSD) route planning.']
  address_validation_date date [note: 'Date when the address was last validated against postal authority databases. Format: yyyy-MM-dd.']
  address_validation_status varchar [note: 'Status of address verification against postal authority databases. Validated addresses improve delivery success rates and reduce logistics costs.']
  amount decimal(18,4) [note: 'The amount of the account address record']
  city varchar [note: 'City or municipality name for the address location. Organizational contact data classified as confidential.']
  code varchar [note: 'The account address code of the account address record']
  country_code varchar [note: 'Three-letter ISO 3166-1 alpha-3 country code (e.g., USA, CAN, MEX, GBR, DEU).']
  created_timestamp timestamp [note: 'Timestamp when this address record was first created in the system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Audit trail field for data governance and compliance.']
  currency_code varchar [note: 'The currency code of the account address record']
  delivery_instructions varchar [note: 'Special instructions for delivery personnel including receiving hours, dock locations, access codes, contact requirements, and handling instructions. Critical for On Time In Full (OTIF) performance.']
  description varchar [note: 'The account address description of the account address record']
  dock_door_number varchar [note: 'Specific dock door or bay number for deliveries at warehouse or distribution center locations. Used by carriers and Direct Store Delivery (DSD) drivers.']
  dsd_route_eligible_flag boolean [note: 'Indicates whether this location is eligible for Direct Store Delivery (DSD) routing (True) or requires warehouse distribution (False). Critical for route planning and logistics optimization.']
  edi_location_qualifier varchar [note: 'EDI X12 location qualifier code used in Electronic Data Interchange (EDI) transactions to identify the address role (e.g., ST for ship-to, BT for bill-to, SF for ship-from). Supports automated order processing and Advanced Shipping Notice (ASN) generation.']
  effective_end_date date [note: 'Date when this address was deactivated or replaced. Null indicates the address is currently active. Format: yyyy-MM-dd. Supports address history tracking and audit compliance.']
  effective_from date [note: 'The effective from of the account address record']
  effective_start_date date [note: 'Date when this address became active and valid for use in transactions. Format: yyyy-MM-dd. Supports address history tracking and audit compliance.']
  effective_until date [note: 'The effective until of the account address record']
  gln varchar [note: 'GS1 Global Location Number uniquely identifying this physical location in the global supply chain. 13-digit numeric identifier used for EDI transactions and supply chain visibility.']
  inactivation_reason varchar [note: 'Business reason for address inactivation (e.g., location closed, address changed, account terminated, consolidation). Used for audit trails and business intelligence.']
  last_modified_timestamp timestamp [note: 'Timestamp when this address record was last updated. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Audit trail field for data governance and compliance.']
  latitude decimal(10,7) [note: 'Geographic latitude coordinate in decimal degrees for geospatial analysis, route optimization, and Direct Store Delivery (DSD) planning. Range: -90.0000000 to +90.0000000.']
  longitude decimal(10,7) [note: 'Geographic longitude coordinate in decimal degrees for geospatial analysis, route optimization, and Direct Store Delivery (DSD) planning. Range: -180.0000000 to +180.0000000.']
  name varchar [note: 'The account address name of the account address record']
  notes varchar [note: 'The notes of the account address record']
  postal_code varchar [note: 'Postal code, ZIP code, or postcode for mail delivery routing. Format varies by country (e.g., 5-digit ZIP in USA, alphanumeric in Canada/UK). Organizational contact data classified as confidential.']
  primary_address_flag boolean [note: 'Indicates whether this is the primary address for the account (True) or a secondary/alternate address (False). Used for default shipping and billing operations.']
  quantity decimal(18,4) [note: 'The quantity of the account address record']
  receiving_hours_end varchar [note: 'End time for receiving deliveries at this location in 24-hour format (HH:mm). Used for delivery scheduling and On Time In Full (OTIF) compliance.']
  receiving_hours_start varchar [note: 'Start time for receiving deliveries at this location in 24-hour format (HH:mm). Used for delivery scheduling and On Time In Full (OTIF) compliance.']
  source_system_code varchar [note: 'Unique identifier for this address in the source system of record. Used for data reconciliation and bidirectional synchronization.']
  standardized_address_flag boolean [note: 'Indicates whether the address has been standardized to postal authority format (True) or remains in original input format (False).']
  state_province varchar [note: 'State, province, or administrative region code or name. Uses standard postal abbreviations (e.g., CA, NY, ON, QC). Organizational contact data classified as confidential.']
  tax_jurisdiction_code varchar [note: 'Tax jurisdiction identifier for sales tax, value-added tax (VAT), or goods and services tax (GST) calculation. Used in invoice generation and financial reporting.']
  time_zone varchar [note: 'IANA time zone identifier for this location (e.g., America/New_York, America/Chicago, Europe/London). Used for delivery scheduling, service level agreement (SLA) tracking, and On Time In Full (OTIF) calculations.']
  uom varchar [note: 'The uom of the account address record']
  updated_timestamp timestamp [note: 'The updated timestamp of the account address record']

  Note: 'Physical and mailing addresses associated with a trade account, including headquarters, billing address, ship-to locations, and sold-to locations. Captures address type (HQ, billing, ship-to, sold-to, returns), street, city, state/province, postal code, country, GS1 GLN for the location, geo-coordinates, time zone, and address validation status. Supports EDI ship-to/bill-to mapping and DSD route planning.'
}

Table sales.retail_store {
  retail_store_id varchar [pk, note: 'Unique identifier for the retail store location. Primary key.']
  account_address_id varchar [note: 'Foreign key linking to sales.account_address. Business justification: retail_store currently embeds a full physical address (address_line_1, address_line_2, city, state_province, postal_code, country_code, latitude, longitude) that duplicates the structure of account_ad']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: Retail stores are managed under a specific legal entity (company code) for multi-entity consumer goods operations, enabling store-level P&L statutory reporting, tax jurisdiction assignment, and interc']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Store‑level budgeting and expense tracking use a cost center per retail store for internal cost accounting.']
  distribution_facility_id varchar [note: 'Foreign key linking to distribution.distribution_facility. Business justification: Store replenishment process requires an assigned distribution center to schedule deliveries and calculate OTIF performance.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Store profitability reporting aggregates sales and costs by profit center, requiring a link from store to profit_center.']
  supplier_site_id varchar [note: 'Foreign key linking to procurement.supplier_site. Business justification: Store‑level VMI or direct replenishment ties a retail store to the exact supplier site that ships inventory, needed for logistics and OTIF tracking.']
  trade_account_id varchar [note: 'Reference to the parent trade account, banner, or retail chain that owns or operates this store.']
  acv_weight decimal(10,4) [note: 'All Commodity Volume (ACV) weighting factor representing this stores share of total market volume, used for distribution and market share calculations.']
  amount decimal(18,4) [note: 'The amount of the retail store record']
  banner_name varchar [note: 'The retail banner or brand under which this store operates (e.g., Walmart Supercenter, Target, Kroger).']
  close_date date [note: 'Date when the store permanently closed or is scheduled to close. Null if store is active.']
  code varchar [note: 'The retail store code of the retail store record']
  created_timestamp timestamp [note: 'Timestamp when this retail store record was first created in the system.']
  currency_code varchar [note: 'The currency code of the retail store record']
  description varchar [note: 'The retail store description of the retail store record']
  dsd_route_code varchar [note: 'Route code or identifier for Direct Store Delivery (DSD) logistics and delivery scheduling.']
  effective_from date [note: 'The effective from of the retail store record']
  effective_until date [note: 'The effective until of the retail store record']
  gln varchar [note: 'GS1 Global Location Number uniquely identifying this physical store location for Electronic Data Interchange (EDI) and supply chain transactions.']
  last_modified_timestamp timestamp [note: 'Timestamp when this retail store record was last updated or modified.']
  last_visit_date date [note: 'Date of the most recent retail execution visit or sales call to this store location.']
  name varchar [note: 'The retail store name of the retail store record']
  next_scheduled_visit_date date [note: 'Date of the next planned retail execution visit or sales call to this store location.']
  notes varchar [note: 'The notes of the retail store record']
  open_date date [note: 'Date when the store first opened for business operations.']
  operating_hours varchar [note: 'Standard operating hours for the store (e.g., Mon-Fri 8am-10pm, Sat-Sun 9am-9pm) used for retail execution visit planning.']
  osa_target_pct decimal(5,2) [note: 'Target On Shelf Availability (OSA) percentage for this store indicating expected in-stock performance for key Stock Keeping Units (SKUs).']
  otif_sla_target_pct decimal(5,2) [note: 'Target On Time In Full (OTIF) service level percentage agreed with this store for delivery performance measurement.']
  planogram_zone varchar [note: 'Planogram zone or cluster assignment indicating which shelf layout and assortment plan applies to this store.']
  pos_system_type varchar [note: 'Type or vendor of the Point of Sale (POS) system used at this store for transaction processing and sales data capture.']
  quantity decimal(18,4) [note: 'The quantity of the retail store record']
  retail_store_status varchar [note: 'The retail store status of the retail store record']
  source_system_code varchar [note: 'The source system code of the retail store record']
  store_format varchar [note: 'The retail format classification of the store indicating size, assortment, and operational model. [ENUM-REF-CANDIDATE: hypermarket|supermarket|convenience|club|drug|dollar|specialty|e-commerce_fulfillment_center — 8 candidates stripped; promote to reference product]']
  store_name varchar [note: 'The official name or designation of the retail store location.']
  store_number varchar [note: 'The retailer-assigned unique store number or code used for operational identification and Direct Store Delivery (DSD) routing.']
  store_phone varchar [note: 'Primary contact phone number for the retail store location.']
  store_size_sq_ft varchar [note: 'Total retail selling space of the store measured in square feet, used for All Commodity Volume (ACV) and Total Distribution Points (TDP) calculations.']
  store_status varchar [note: 'Current operational status of the retail store location.']
  store_tier varchar [note: 'Strategic tier classification (e.g., Tier 1, Tier 2) indicating store importance based on volume, profitability, or strategic value for prioritized retail execution.']
  tdp_weight decimal(10,4) [note: 'Total Distribution Points (TDP) weighting factor representing this stores contribution to numeric distribution metrics.']
  trading_area varchar [note: 'Geographic trading area or market designation (e.g., metro area, region) used for sales territory and distribution planning.']
  uom varchar [note: 'The uom of the retail store record']
  updated_timestamp timestamp [note: 'The updated timestamp of the retail store record']
  vmi_enabled_flag boolean [note: 'Indicates whether this store participates in a Vendor Managed Inventory (VMI) program where the manufacturer manages replenishment.']

  Note: 'Individual physical retail store or outlet location associated with a trade account banner or chain. Captures store number, store name, banner, format (hypermarket, supermarket, convenience, club, drug, dollar, e-commerce fulfillment center), store size (sq ft), trading area, store open/close dates, store manager, operating hours, and planogram zone assignment. Used for retail execution, OSA tracking, and DSD route management.'
}

Table sales.order {
  order_id varchar [pk, note: 'Unique system identifier for the sales order record. Primary key for the order entity.']
  account_address_id varchar [note: 'Reference to the customer location that receives the invoice and is responsible for payment. May differ from ship-to location.']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: Campaign-driven order attribution is a core consumer goods process: incremental orders generated by promotional campaigns must be linked to measure campaign ROI, trade promotion lift, and volume uplif']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: Sales orders are assigned to a company code for legal entity revenue recognition, statutory reporting, and intercompany sales processing. In SAP SD, company code derivation on sales orders is mandator']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Cost Center Allocation report requires each sales order to be charged to a cost center for internal expense tracking.']
  fulfilling_supplier_site_id varchar [note: 'Foreign key linking to procurement.supplier_site. Business justification: Drop-ship order fulfillment in consumer goods requires identifying the specific supplier site shipping directly to the customer. This named process (direct-ship/drop-ship) links the sales order to the']
  manufacturing_facility_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_facility. Business justification: In make-to-order and direct-ship consumer goods scenarios, a sales order is allocated to a specific manufacturing facility for fulfillment. This link enables facility-level order load balancing, capac']
  pricing_agreement_id varchar [note: 'Foreign key linking to sales.pricing_agreement. Business justification: Orders are governed by a pricing agreement; linking captures contract context.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Sales order margin planning and revenue allocation require profit center assignment. Consumer goods companies report order revenue and COGS by profit center for segment P&L. SAP SD standard: every sal']
  retail_store_id varchar [note: 'Reference to the customer location where goods should be delivered. May differ from bill-to location for multi-site customers.']
  supply_network_node_id varchar [note: 'Foreign key linking to supply.network_node. Business justification: Order Fulfillment Allocation report requires linking each order to the supply network node that will source inventory for accurate ATP/CTP calculations.']
  trade_account_id varchar [note: 'Reference to the customer or retail account that placed this order. Links to the customer master record.']
  actual_delivery_date date [note: 'The actual date when the order was delivered to the customer. Used to calculate OTIF performance and delivery variance.']
  amount decimal(18,4) [note: 'The amount of the order record']
  approved_timestamp timestamp [note: 'Timestamp when the order was approved for fulfillment. Marks transition from draft/pending to confirmed status in the order lifecycle.']
  cancellation_reason varchar [note: 'Free-text or coded reason for order cancellation if status is cancelled. Used for root cause analysis and process improvement.']
  channel_type varchar [note: 'The commercial channel through which the order was received. Critical for channel-specific analytics and revenue attribution.']
  code varchar [note: 'The order code of the order record']
  cogs_amount decimal(18,2) [note: 'Total cost of goods sold for all items on this order. Used for gross margin calculation and profitability analysis.']
  confirmed_delivery_date date [note: 'The delivery date confirmed by supply chain and logistics based on ATP/CTP availability. Committed date for OTIF tracking.']
  created_timestamp timestamp [note: 'System timestamp when this order record was first created in the database. Used for audit trail and data lineage tracking.']
  currency_code varchar [note: 'Three-letter ISO currency code for all monetary amounts on this order. Determines currency for pricing, tax, and totals.']
  description varchar [note: 'The order description of the order record']
  discount_amount decimal(18,2) [note: 'Total discount amount applied to the order including trade promotions, volume discounts, and negotiated price reductions.']
  distribution_channel varchar [note: 'The distribution channel through which products are sold. Defines the route-to-market and channel-specific pricing rules.']
  division varchar [note: 'The product division or business unit for this order. Used for divisional P&L reporting and product line segmentation.']
  effective_from date [note: 'The effective from of the order record']
  effective_until date [note: 'The effective until of the order record']
  freight_amount decimal(18,2) [note: 'Freight and shipping charges applied to the order. May be customer-paid or supplier-absorbed depending on terms.']
  gross_margin_amount decimal(18,2) [note: 'Gross profit on the order calculated as total revenue less COGS. Key profitability metric for order-level margin analysis.']
  incoterm varchar [note: 'Three-letter Incoterm code defining the transfer of risk and cost responsibility between buyer and seller. Examples: FOB, CIF, DDP.']
  modified_timestamp timestamp [note: 'System timestamp when this order record was last updated. Used for change tracking and data synchronization across systems.']
  name varchar [note: 'The order name of the order record']
  notes varchar [note: 'The notes of the order record']
  order_date date [note: 'The date when the sales order was placed or created by the customer. Primary business event timestamp for order lifecycle.']
  order_number varchar [note: 'Externally visible business identifier for the sales order. Used for customer communication and order tracking across systems.']
  order_status varchar [note: 'Current lifecycle status of the sales order indicating its position in the order-to-cash workflow. [ENUM-REF-CANDIDATE: draft|open|confirmed|in_fulfillment|shipped|delivered|cancelled — 7 candidates stripped; promote to reference product]']
  order_type varchar [note: 'Classification of the order based on fulfillment method and business process. Determines routing, pricing, and delivery rules.']
  otif_status varchar [note: 'Indicates whether the order was delivered on time and in full per customer commitment. Key supply chain KPI for customer service measurement.']
  payment_terms varchar [note: 'The payment terms code defining the credit period and discount conditions for this order. Examples: NET30, 2/10NET30.']
  priority varchar [note: 'Priority classification for order fulfillment. Determines sequencing in warehouse picking and expedited shipping eligibility.']
  purchase_order_number varchar [note: 'The customers purchase order number provided at order placement. Required for EDI transactions and invoice matching.']
  quantity decimal(18,4) [note: 'The quantity of the order record']
  requested_delivery_date date [note: 'The delivery date requested by the customer at the time of order placement. Used for OTIF performance measurement.']
  sales_office varchar [note: 'The sales office or branch that originated this order. Used for territory management and sales force performance tracking.']
  sales_organization varchar [note: 'The sales organization responsible for this order. Defines the selling entity and organizational hierarchy for reporting.']
  sap_sd_document_number varchar [note: 'The native SAP SD sales order document number. Used for system-to-system integration and ERP traceability.']
  shipping_method varchar [note: 'The transportation mode selected for order delivery. Impacts delivery time, cost, and carrier selection.']
  source varchar [note: 'The system or channel through which the order was originally captured. Used for channel attribution and system integration tracking.']
  source_system_code varchar [note: 'The source system code of the order record']
  special_instructions varchar [note: 'Free-text field for customer-specific delivery instructions, packaging requirements, or handling notes for warehouse and logistics teams.']
  subtotal_amount decimal(18,2) [note: 'Sum of all line item amounts before taxes, discounts, and freight charges. Base revenue amount for the order.']
  tax_amount decimal(18,2) [note: 'Total tax amount charged on the order including sales tax, VAT, GST, and other applicable taxes per jurisdiction.']
  total_amount decimal(18,2) [note: 'Final total amount for the order including subtotal, taxes, freight, less discounts. The invoiced amount for revenue recognition.']
  uom varchar [note: 'The uom of the order record']
  updated_timestamp timestamp [note: 'The updated timestamp of the order record']

  Note: 'Core sales order record capturing all commercial sales transactions across retail, wholesale, DTC, and e-commerce channels. Contains order header details (order number, date, channel type, status, delivery dates, OTIF status, payment terms, currency, totals, SAP SD document number) and line-level detail (SKU/GTIN, quantities ordered/confirmed/shipped, unit pricing, discounts, trade promotion references, line status, COGS, gross margin, delivery schedule). Serves as the primary transactional backbone of the sales domain enabling both order-level and SKU-level revenue and margin analysis.'
}

Table sales.invoice {
  invoice_id varchar [pk, note: 'Unique system identifier for the invoice record. Primary key.']
  account_address_id varchar [note: 'Reference to the billing address location for this invoice. The address where invoice is sent and payment is remitted from.']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: Sales invoices must be issued by a specific legal entity (company code) for VAT compliance, statutory financial reporting, and intercompany billing. Consumer goods companies operating across multiple ']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Financial consolidation needs each invoice posted to the responsible cost center for accurate profit analysis.']
  invoice_sales_order_id varchar [note: 'Reference to the originating sales order that this invoice fulfills. Links invoice to order for order-to-cash reconciliation.']
  pricing_agreement_id varchar [note: 'Foreign key linking to sales.pricing_agreement. Business justification: Invoice billing often follows a pricing agreement; linking provides traceability.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Revenue recognition and P&L reporting require invoices to be assigned to profit centers. In consumer goods ERP (SAP SD), every billing document carries a profit center for segment revenue reporting an']
  retail_store_id varchar [note: 'Reference to the physical delivery location where goods were shipped. May differ from bill-to account for multi-site customers.']
  source_order_id varchar [note: 'The source order id of the invoice record']
  trade_account_id varchar [note: 'Reference to the retail account, distributor, or DTC consumer who is billed on this invoice. The sold-to party in the order-to-cash process.']
  amount decimal(18,4) [note: 'The amount of the invoice record']
  billing_period_end_date date [note: 'End date of the period covered by this invoice. Used for period-based billing and revenue allocation.']
  billing_period_start_date date [note: 'Start date of the period covered by this invoice. Relevant for subscription, service, or recurring billing scenarios.']
  billing_type varchar [note: 'Classification of the invoice document type: standard invoice for goods/services, credit memo for returns/adjustments, debit memo for additional charges, proforma for advance notice, intercompany for internal transfers, or consignment for stock-based billing.']
  cancelled_timestamp timestamp [note: 'Timestamp when the invoice was cancelled or voided. Null for active invoices. Used for cancelled invoice reporting and audit.']
  code varchar [note: 'The invoice code of the invoice record']
  cost_of_goods_sold_amount decimal(18,2) [note: 'Total standard cost of all products billed on this invoice. Used for gross margin calculation and profitability analysis at invoice level.']
  created_timestamp timestamp [note: 'System timestamp when this invoice record was first created in the billing system. Used for audit trail and data lineage.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code in which the invoice is denominated (e.g., USD, EUR, GBP). All monetary amounts on this invoice are expressed in this currency.']
  days_sales_outstanding varchar [note: 'Number of days between invoice date and payment date (or current date if unpaid). Key metric for working capital management and customer payment behavior analysis.']
  description varchar [note: 'The invoice description of the invoice record']
  dispute_flag boolean [note: 'Boolean indicator that the customer has raised a dispute or deduction claim against this invoice. Triggers collections hold and dispute resolution workflow.']
  dispute_reason_code varchar [note: 'Standardized code categorizing the reason for invoice dispute. Enables root cause analysis of deductions and customer dissatisfaction. [ENUM-REF-CANDIDATE: pricing|quantity|quality|delivery|promotion|damaged_goods|not_received — 7 candidates stripped; promote to reference product]']
  distribution_channel_code varchar [note: 'Code representing the distribution channel through which the sale was made (e.g., retail, wholesale, DTC, e-commerce). Enables channel-specific revenue analysis.']
  division_code varchar [note: 'Code identifying the product division or business unit to which invoice revenue is attributed. Supports divisional P&L reporting.']
  due_date date [note: 'The date by which payment is expected per the agreed payment terms. Used for DSO tracking and collections management.']
  edi_document_number varchar [note: 'Unique EDI transaction control number assigned when invoice is transmitted via EDI 810. Used for EDI audit trail and error resolution.']
  edi_transmission_status varchar [note: 'Status of EDI 810 invoice transmission to customer\'s system. Tracks electronic invoice delivery for large retail and distributor accounts.']
  effective_from date [note: 'The effective from of the invoice record']
  effective_until date [note: 'The effective until of the invoice record']
  freight_charge_amount decimal(18,2) [note: 'Total freight, shipping, and logistics charges added to the invoice. May be separately itemized for customer transparency.']
  gross_amount decimal(18,2) [note: 'Total invoice value before any deductions, including all line items, charges, and fees but before trade discounts and taxes.']
  gross_margin_amount decimal(18,2) [note: 'Gross profit on this invoice, calculated as net_amount minus cost_of_goods_sold_amount. Key profitability metric for customer and product analysis.']
  incoterm_code varchar [note: 'Three-letter Incoterm code defining the division of costs and risks between buyer and seller (e.g., FOB, CIF, DDP). Critical for international trade invoicing.']
  invoice_date date [note: 'The date the invoice was officially issued to the customer. This is the accounting date used for revenue recognition and aging calculations.']
  invoice_number varchar [note: 'Externally-visible unique invoice document number used for customer communication, payment reconciliation, and accounts receivable tracking. Typically follows company-specific numbering scheme.']
  invoice_status varchar [note: 'Current state of the invoice in the accounts receivable lifecycle. Tracks progression from draft through payment completion or dispute resolution. [ENUM-REF-CANDIDATE: draft|issued|sent|partially_paid|paid|overdue|cancelled|disputed — 8 candidates stripped; promote to reference product]']
  last_modified_timestamp timestamp [note: 'System timestamp of the most recent update to this invoice record. Tracks changes for audit and data quality monitoring.']
  name varchar [note: 'The invoice name of the invoice record']
  net_amount decimal(18,2) [note: 'Final invoice total after all discounts, charges, and taxes. This is the amount due from the customer and recorded in accounts receivable.']
  notes varchar [note: 'Free-text field for special instructions, billing notes, dispute comments, or customer-specific messaging that appears on the invoice document.']
  outstanding_amount decimal(18,2) [note: 'Remaining unpaid balance on the invoice. Calculated as net_amount minus paid_amount. Used for aging analysis and collections prioritization.']
  paid_amount decimal(18,2) [note: 'Cumulative amount received against this invoice across all payment transactions. Used to calculate outstanding balance.']
  payment_method varchar [note: 'The payment instrument or mechanism used (or expected) for settling this invoice. Influences payment processing and reconciliation workflows. [ENUM-REF-CANDIDATE: wire_transfer|ach|check|credit_card|edi_payment|cash|direct_debit — 7 candidates stripped; promote to reference product]']
  payment_reference_number varchar [note: 'External payment reference number provided by the customer or payment processor for reconciliation. Links invoice to bank statement or remittance advice.']
  payment_status varchar [note: 'Current payment settlement status indicating whether the invoice has been paid in full, partially, or remains outstanding.']
  payment_terms_code varchar [note: 'Standard code representing the payment terms agreement (e.g., Net 30, Net 60, 2/10 Net 30). Determines due date calculation and early payment discount eligibility.']
  purchase_order_number varchar [note: 'Customer\'s purchase order number that authorized this invoice. Required for PO-based invoicing and three-way match reconciliation.']
  quantity decimal(18,4) [note: 'The quantity of the invoice record']
  revenue_recognition_category varchar [note: 'Classification determining how revenue from this invoice is recognized per accounting standards (ASC 606 / IFRS 15). Drives financial reporting and revenue allocation logic.']
  sales_organization_code varchar [note: 'Code identifying the sales organization unit responsible for this invoice. Used for revenue attribution and sales performance reporting.']
  source_system_code varchar [note: 'The source system code of the invoice record']
  tax_amount decimal(18,2) [note: 'Sum of all tax amounts (sales tax, VAT, GST, excise) applied to the invoice. Calculated based on tax jurisdiction and product tax classification.']
  total_amount decimal(18,4) [note: 'The total amount of the invoice record']
  trade_discount_amount decimal(18,2) [note: 'Total trade promotion discounts, volume rebates, and negotiated price reductions applied at invoice level. Reduces gross amount to arrive at net taxable amount.']
  uom varchar [note: 'The uom of the invoice record']
  updated_timestamp timestamp [note: 'The updated timestamp of the invoice record']

  Note: 'Commercial billing document issued to retail accounts, distributors, or DTC consumers upon order fulfillment. Contains invoice header (invoice number, date, billing type, payment terms, gross/net values, tax, currency, payment status, DSO tracking, EDI status) and line-level detail (SKU/GTIN, billed quantities, unit prices, trade discounts, net line values, tax codes, revenue recognition categories, COGS allocation). Links to the originating sales order and serves as the accounts receivable source record enabling SKU-level revenue and profitability reporting.'
}

Table sales.pricing_agreement {
  pricing_agreement_id varchar [pk, note: 'Unique identifier for the pricing agreement record. Primary key.']
  hierarchy_id varchar [note: 'Foreign key linking to product.product_hierarchy. Business justification: Pricing agreements are defined per product hierarchy to set prices for all SKUs within that hierarchy; essential for price‑setting reports.']
  price_list_id varchar [note: 'The price list id of the pricing agreement record']
  product_brand_id varchar [note: 'Foreign key linking to product.product_brand. Business justification: Key account pricing agreements in consumer goods are routinely scoped to a commercial brand portfolio (e.g., a Walmart agreement covering all Pantene SKUs). pricing_agreement has marketing_brand_id bu']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Trade pricing agreements (customer contracts, volume deals) are assigned to profit centers for trade spend P&L allocation and promotional ROI reporting. Consumer goods finance teams track contracted d']
  trade_account_id varchar [note: 'Reference to the retail account, distributor, or wholesale customer with whom this pricing agreement is established.']
  agreement_name varchar [note: 'Descriptive name or title of the pricing agreement for business reference and reporting.']
  agreement_number varchar [note: 'Externally-known unique business identifier for the pricing agreement, used in contracts and SAP SD condition records.']
  agreement_type varchar [note: 'Classification of the pricing agreement structure: standard pricing, volume-based tiered discounts, promotional allowances, rebate structures, long-term contract, or spot pricing.']
  amount decimal(18,4) [note: 'The amount of the pricing agreement record']
  approval_status varchar [note: 'Current approval workflow status indicating whether the pricing agreement has been reviewed and authorized by management.']
  approved_by varchar [note: 'Name or identifier of the manager or executive who approved the pricing agreement.']
  approved_date date [note: 'Date when the pricing agreement was formally approved by authorized personnel.']
  auto_renewal_flag boolean [note: 'Indicates whether the pricing agreement automatically renews upon expiration unless terminated by either party.']
  base_list_price decimal(18,4) [note: 'Standard manufacturer list price before any discounts, allowances, or negotiated reductions are applied.']
  code varchar [note: 'The pricing agreement code of the pricing agreement record']
  contract_document_reference varchar [note: 'Reference identifier or file path to the legal contract document or master agreement associated with this pricing agreement.']
  contracted_net_price decimal(18,4) [note: 'Agreed net price per unit after applying all negotiated discounts and allowances as defined in the pricing agreement.']
  created_timestamp timestamp [note: 'Timestamp when the pricing agreement record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code in which all pricing amounts in this agreement are denominated.']
  description varchar [note: 'The pricing agreement description of the pricing agreement record']
  discount_pct decimal(7,4) [note: 'The discount pct of the pricing agreement record']
  discount_percentage decimal(5,2) [note: 'Percentage discount off the base list price granted to the customer under this pricing agreement.']
  distribution_channel varchar [note: 'Distribution channel through which products under this pricing agreement are sold (e.g., retail, wholesale, DTC, e-commerce).']
  division varchar [note: 'Product division or business unit to which this pricing agreement applies.']
  effective_end_date date [note: 'Date when the pricing agreement expires or terminates. Nullable for open-ended agreements.']
  effective_from date [note: 'The effective from of the pricing agreement record']
  effective_start_date date [note: 'Date when the pricing agreement becomes active and enforceable for order pricing.']
  effective_until date [note: 'The effective until of the pricing agreement record']
  geographic_scope varchar [note: 'Geographic region or territory where this pricing agreement is valid and enforceable.']
  minimum_order_quantity decimal(15,3) [note: 'Minimum order quantity required per transaction to qualify for the contracted pricing under this agreement.']
  minimum_order_value decimal(18,2) [note: 'Minimum monetary value required per order to qualify for the contracted pricing terms.']
  modified_by varchar [note: 'User identifier or name of the person who last modified the pricing agreement record.']
  modified_timestamp timestamp [note: 'Timestamp when the pricing agreement record was last modified or updated.']
  msrp_price decimal(18,4) [note: 'Manufacturer suggested retail price for consumer-facing pricing, used for price positioning and margin calculation.']
  name varchar [note: 'The pricing agreement name of the pricing agreement record']
  notes varchar [note: 'Free-text field for additional comments, special terms, or clarifications related to the pricing agreement.']
  payment_terms varchar [note: 'Agreed payment terms defining the due date and discount conditions (e.g., Net 30, 2/10 Net 30).']
  price_protection_flag boolean [note: 'Indicates whether the customer is protected from price increases during the agreement period.']
  pricing_agreement_status varchar [note: 'Current lifecycle status of the pricing agreement indicating its operational state and enforceability.']
  pricing_tier varchar [note: 'Tiered pricing level assigned to the customer based on volume commitments, strategic importance, or negotiated terms.']
  product_scope varchar [note: 'Defines the breadth of product coverage: all products, specific product category, individual SKUs, or brand-level pricing.']
  promotional_allowance decimal(18,2) [note: 'Additional allowance or discount provided to support trade promotions, in-store displays, or marketing activities.']
  quantity decimal(18,4) [note: 'The quantity of the pricing agreement record']
  rebate_amount decimal(18,2) [note: 'Fixed monetary rebate amount granted per unit or per transaction under the pricing agreement terms.']
  rebate_percentage decimal(5,2) [note: 'Percentage rebate granted to the customer upon achieving volume thresholds or other performance criteria defined in the agreement.']
  rsp_price decimal(18,4) [note: 'Manufacturer recommended selling price to be used by the retailer or distributor at point of sale.']
  sales_organization varchar [note: 'SAP sales organization code responsible for managing and executing this pricing agreement.']
  source_system_code varchar [note: 'The source system code of the pricing agreement record']
  uom varchar [note: 'The uom of the pricing agreement record']
  updated_timestamp timestamp [note: 'The updated timestamp of the pricing agreement record']
  volume_threshold_quantity decimal(15,3) [note: 'Minimum order or cumulative purchase quantity required to qualify for the contracted pricing tier or volume-based discount.']
  volume_threshold_uom varchar [note: 'Unit of measure for the volume threshold quantity (e.g., EA for each, CS for case, PAL for pallet).']
  created_by varchar [note: 'User identifier or name of the person who created the pricing agreement record.']

  Note: 'Contractual pricing arrangement established with a retail account, distributor, or wholesale customer defining agreed RSP/MSRP, net pricing, volume-based tiered discounts, promotional allowances, and rebate structures. Captures agreement number, effective start/end dates, pricing tier, base list price, contracted net price, volume thresholds, rebate percentage, payment terms, currency, and approval status. Source of truth for customer-specific pricing in SAP SD condition records.'
}

Table sales.return_order {
  return_order_id varchar [pk, note: 'Unique identifier for the return order record. Primary key.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Return order processing costs (inspection, restocking, reverse logistics) are charged to cost centers for trade returns cost management reporting. Consumer goods companies track returns handling costs']
  distribution_facility_id varchar [note: 'Foreign key linking to distribution.distribution_facility. Business justification: Consumer goods reverse logistics: return orders are processed at a designated DC for physical receipt, quality inspection, and disposition. return_order.warehouse_location_code is a denormalized DC re']
  invoice_id varchar [note: 'Foreign key linking to sales.invoice. Business justification: A return order is typically processed against an original invoice to generate a credit memo. return_order already tracks credit_memo_number, credit_memo_status, and credit_memo_issued_date — these are']
  originating_sales_order_id varchar [note: 'Reference to the original sales order that this return is associated with.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Return orders reduce revenue and impact gross margin at the profit center level. Consumer goods P&L reporting requires returns and allowances to be allocated to the originating profit center for accur']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Return orders must reference the exact SKU being returned for warranty, credit, and compliance processing; used in return analytics.']
  source_order_id varchar [note: 'The source order id of the return order record']
  supplier_site_id varchar [note: 'Foreign key linking to procurement.supplier_site. Business justification: Consumer goods supplier returns (defective/recalled goods) require routing back to a specific supplier site for debit memo processing and quality disposition. The return_order.disposition_instruction ']
  trade_account_id varchar [note: 'Reference to the retail account, distributor, or DTC consumer initiating the return.']
  adjustment_amount decimal(15,2) [note: 'Additional adjustments applied to the return value (e.g., damage deductions, handling fees, promotional credits).']
  amount decimal(18,4) [note: 'The amount of the return order record']
  carrier_name varchar [note: 'Name of the logistics carrier used for reverse shipment of the returned goods.']
  code varchar [note: 'The return order code of the return order record']
  created_timestamp timestamp [note: 'Timestamp when this return order record was first created in the system.']
  credit_memo_issued_date date [note: 'Date when the credit memo was officially issued to the customer.']
  credit_memo_number varchar [note: 'Unique credit memo document number issued for this return in the financial system.']
  credit_memo_posted_date date [note: 'Date when the credit memo was posted to the general ledger for financial settlement.']
  credit_memo_status varchar [note: 'Current status of the credit memo in the accounts receivable settlement process. [ENUM-REF-CANDIDATE: not_requested|requested|approved|issued|posted|rejected|cancelled — 7 candidates stripped; promote to reference product]']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts in this return order.']
  customer_responsible_flag boolean [note: 'Indicates whether the customer is financially responsible for the return (True) or the business absorbs the cost (False).']
  description varchar [note: 'The return order description of the return order record']
  disposition_instruction varchar [note: 'Instruction for handling the returned goods based on inspection results and business rules. [ENUM-REF-CANDIDATE: return_to_stock|destroy|rework|donate|quarantine|return_to_vendor|scrap — 7 candidates stripped; promote to reference product]']
  distribution_channel varchar [note: 'SAP distribution channel code through which the original sale and return are processed.']
  division varchar [note: 'SAP division code representing the product line or business unit.']
  effective_from date [note: 'The effective from of the return order record']
  effective_until date [note: 'The effective until of the return order record']
  goods_received_date date [note: 'Date when the returned goods were physically received at the return processing facility or warehouse.']
  inspection_completed_date date [note: 'Date when quality inspection of the returned goods was completed.']
  inspector_name varchar [note: 'Name of the quality inspector who performed the inspection of returned goods.']
  lot_batch_number varchar [note: 'Manufacturing lot or batch number of the returned product for traceability.']
  modified_by varchar [note: 'User ID or system identifier of the person or process that last modified this return order record.']
  modified_timestamp timestamp [note: 'Timestamp when this return order record was last modified.']
  name varchar [note: 'The return order name of the return order record']
  notes varchar [note: 'Free-text field for additional comments, special instructions, or contextual information about the return.']
  original_unit_price decimal(15,2) [note: 'Original unit price at which the product was sold in the originating sales order.']
  quality_inspection_result varchar [note: 'Result of the quality inspection performed on the returned goods.']
  quantity decimal(18,4) [note: 'The quantity of the return order record']
  restocking_fee_amount decimal(15,2) [note: 'Fee charged to the customer for processing and restocking the returned goods, if applicable.']
  return_amount decimal(18,4) [note: 'The return amount of the return order record']
  return_authorization_date date [note: 'Date when the return was officially authorized by the business for processing.']
  return_authorization_number varchar [note: 'Externally-known unique authorization number issued for this return request. Format: RMA-XXXXXXXX.']
  return_date date [note: 'The return date of the return order record']
  return_order_status varchar [note: 'The return order status of the return order record']
  return_order_type varchar [note: 'Classification of the return based on the originating channel: retail account, distributor, direct-to-consumer, or wholesale.']
  return_reason varchar [note: 'The return reason of the return order record']
  return_reason_code varchar [note: 'Standardized code indicating the primary reason for the product return. [ENUM-REF-CANDIDATE: damaged_in_transit|expired|shelf_life_rejection|overstock|quality_defect|wrong_item_shipped|recall|customer_dissatisfaction|packaging_defect|promotional_return — 10 candidates stripped; promote to reference product]']
  return_reason_description varchar [note: 'Detailed free-text description providing additional context about the return reason.']
  return_request_date date [note: 'Date when the return request was initiated by the customer or account.']
  return_shipping_cost decimal(15,2) [note: 'Cost incurred for shipping the returned goods back to the warehouse.']
  return_status varchar [note: 'Current lifecycle status of the return order in the reverse logistics and credit processing workflow. [ENUM-REF-CANDIDATE: requested|authorized|in_transit|received|inspected|approved|rejected|credit_issued|closed|cancelled — 10 candidates stripped; promote to reference product]']
  return_value_gross decimal(15,2) [note: 'Gross monetary value of the returned goods before any deductions (returned quantity × original unit price).']
  return_value_net decimal(15,2) [note: 'Net monetary value to be credited to the customer after restocking fees and adjustments (gross - restocking fee - adjustments).']
  returned_quantity decimal(15,3) [note: 'Quantity of units being returned.']
  returned_quantity_uom varchar [note: 'Unit of measure for the returned quantity (EA=Each, CS=Case, PL=Pallet, KG=Kilogram, LB=Pound, L=Liter, GAL=Gallon). [ENUM-REF-CANDIDATE: EA|CS|PL|KG|LB|L|GAL — 7 candidates stripped; promote to reference product]']
  sales_organization varchar [note: 'SAP sales organization code responsible for processing this return.']
  source_system_code varchar [note: 'The source system code of the return order record']
  tracking_number varchar [note: 'Shipment tracking number provided by the carrier for the return shipment.']
  uom varchar [note: 'The uom of the return order record']
  updated_timestamp timestamp [note: 'The updated timestamp of the return order record']
  created_by varchar [note: 'User ID or system identifier of the person or process that created this return order record.']

  Note: 'Sales return authorization and credit memo request capturing product returns from retail accounts, distributors, or DTC consumers. Records return authorization number, return reason code (damaged in transit/expired/shelf-life rejection/overstock/quality defect/wrong item shipped/recall), return date, originating order reference, returned SKU/GTIN, returned quantity, return value, restocking fee if applicable, credit memo status (requested/approved/issued/posted), and disposition instruction (return to stock/destroy/rework/donate). Tracks reverse logistics triggers and financial credit processing for AR settlement.'
}

Table sales.price_list {
  price_list_id varchar [pk, note: 'Unique identifier for the price list record. Primary key.']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: Price lists are scoped to a legal entity (company code) for multi-entity consumer goods operations, intercompany pricing governance, and statutory compliance. A domain expert expects price lists to be']
  product_brand_id varchar [note: 'Foreign key linking to product.product_brand. Business justification: Brand-scoped price lists are a core consumer goods commercial construct (e.g., \'Dove Trade Price List Q1\'). product_brand is the trade-facing commercial brand entity; price_list already has marketing_']
  superseded_by_price_list_id varchar [note: 'Reference to the newer price list that replaces this one when status is superseded. Enables price list succession tracking and historical pricing analysis.']
  amount decimal(18,4) [note: 'The amount of the price list record']
  approval_status varchar [note: 'Current approval workflow status for the price list. Tracks progression through pricing governance approval process before activation.']
  approved_by varchar [note: 'User ID or name of the pricing manager or executive who approved this price list for activation. Required for audit trail and pricing governance compliance.']
  approved_timestamp timestamp [note: 'Date and time when the price list was approved for activation. Critical for audit trail and compliance with pricing governance policies.']
  code varchar [note: 'Unique business identifier code for the price list used in SAP SD pricing procedures and condition records. Externally-known identifier used in pricing agreements and sales documents.']
  created_timestamp timestamp [note: 'Date and time when this price list record was first created in the system. Supports audit trail and data lineage tracking.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code in which all prices in this list are denominated. Critical for multi-currency pricing operations and foreign exchange management.']
  description varchar [note: 'Detailed description of the price list purpose, scope, and applicability including target customer segments and product categories covered.']
  distribution_channel varchar [note: 'Distribution channel to which this price list applies. Enables channel-specific pricing strategies for retail stores, wholesale distributors, direct-to-consumer (DTC), e-commerce platforms, foodservice operators, and institutional buyers.']
  division varchar [note: 'SAP SD division code representing the product line or business unit to which this price list applies. Enables division-specific pricing strategies across product portfolios.']
  effective_end_date date [note: 'Date when the price list expires and is no longer valid for new pricing calculations. Nullable for open-ended price lists. Aligns with SAP SD condition record validity period.']
  effective_from date [note: 'The effective from of the price list record']
  effective_start_date date [note: 'Date when the price list becomes valid and active for pricing calculations in sales orders and quotations. Aligns with SAP SD condition record validity period.']
  effective_until date [note: 'The effective until of the price list record']
  external_reference_code varchar [note: 'External system identifier or reference number for this price list in the source system. Enables cross-system reconciliation and data lineage tracking.']
  freight_inclusion_flag boolean [note: 'Indicates whether freight costs are included in the prices in this list. True when prices are freight-inclusive (delivered pricing), false when prices are ex-works or FOB.']
  geographic_scope varchar [note: 'Geographic region, country, or territory to which this price list applies. Supports region-specific pricing strategies and regulatory compliance with local pricing regulations.']
  incoterm varchar [note: 'International Commercial Terms (Incoterms) code defining delivery and risk transfer terms associated with prices in this list (e.g., FOB, CIF, DDP). Clarifies freight and insurance responsibilities.']
  minimum_order_quantity decimal(15,3) [note: 'Minimum order quantity required for prices in this list to apply. Used to enforce volume thresholds and support tiered pricing strategies.']
  modified_by varchar [note: 'User ID or name of the person who last modified this price list record. Required for audit trail and accountability in pricing governance.']
  modified_timestamp timestamp [note: 'Date and time when this price list record was last modified. Supports change tracking and audit trail for pricing governance compliance.']
  moq_uom varchar [note: 'Unit of measure for the minimum order quantity threshold. May differ from price UoM to support different ordering and pricing units.']
  msrp_flag boolean [note: 'Indicates whether this price list contains manufacturer suggested retail prices (MSRP). True when prices represent official MSRP for consumer-facing pricing and promotional compliance.']
  name varchar [note: 'Descriptive business name of the price list for identification and reporting purposes.']
  notes varchar [note: 'Free-form notes and comments about the price list including special conditions, exceptions, or business context for pricing decisions.']
  payment_terms varchar [note: 'Standard payment terms associated with this price list (e.g., Net 30, 2/10 Net 30). Defines credit period and early payment discount eligibility for customers purchasing under this list.']
  price_basis varchar [note: 'Pricing methodology or basis used to establish prices in this list. List price indicates standard published pricing, cost plus indicates markup over cost, market based indicates alignment with market rates, competitive indicates positioning relative to competitors, value based indicates pricing tied to customer value perception.']
  price_list_status varchar [note: 'Current lifecycle status of the price list. Draft indicates under development, pending approval indicates awaiting authorization, active indicates currently in use, inactive indicates temporarily disabled, expired indicates past validity period, superseded indicates replaced by newer version.']
  price_list_type varchar [note: 'Classification of the price list by its business purpose and application context. Standard lists provide baseline pricing, promotional lists support time-limited campaigns, contract lists support negotiated agreements, channel-specific lists apply to distribution channels, seasonal lists support seasonal pricing strategies, and clearance lists support inventory liquidation.']
  price_protection_days varchar [note: 'Number of days of price protection coverage offered under this price list. Defines the lookback period for retroactive price adjustments when price protection is enabled.']
  price_protection_flag boolean [note: 'Indicates whether price protection provisions apply to this price list. When true, customers who purchased at higher prices may be eligible for retroactive credits if prices decrease during the protection period.']
  price_rounding_rule varchar [note: 'Rounding rule applied to calculated prices from this list. Supports psychological pricing strategies and currency denomination constraints.']
  price_uom varchar [note: 'Standard unit of measure in which prices are expressed in this list (e.g., EA for each, CS for case, PAL for pallet). Aligns with SAP MM material master UoM configuration.']
  pricing_condition_type varchar [note: 'SAP SD condition type code that defines how prices from this list are applied in pricing procedures (e.g., PR00 for base price, K004 for material price). Links price list to SAP pricing schema configuration.']
  quantity decimal(18,4) [note: 'The quantity of the price list record']
  rsp_flag boolean [note: 'Indicates whether this price list contains recommended selling prices (RSP) for retail partners. True when prices represent manufacturer-suggested retail pricing guidance.']
  sales_organization varchar [note: 'SAP SD sales organization code to which this price list applies. Defines the organizational scope for pricing applicability in the sales and distribution structure.']
  source_system_code varchar [note: 'The source system code of the price list record']
  tax_classification varchar [note: 'Tax category or classification code applicable to prices in this list. Determines tax treatment for products priced under this list in compliance with jurisdictional tax regulations.']
  trade_class varchar [note: 'Customer trade class or customer pricing group to which this price list applies. Used to segment pricing by customer type such as mass merchandisers, drug stores, grocery chains, convenience stores, or specialty retailers.']
  uom varchar [note: 'The uom of the price list record']
  updated_timestamp timestamp [note: 'The updated timestamp of the price list record']
  version_number varchar [note: 'Sequential version number of the price list. Increments with each revision to support version control and change tracking for pricing history and audit purposes.']
  created_by varchar [note: 'User ID or name of the person who created this price list record. Required for audit trail and accountability in pricing governance.']

  Note: 'Standard price list master defining list prices, RSP/MSRP, and channel-specific base prices for SKUs across different trade classes and geographies. Contains both header-level metadata (price list code, name, currency, effective dates, channel applicability, type, approval status) and SKU-level price entries (unit price, MOQ, price UoM, effective dates, override flags) for each product in the list. Serves as the pricing baseline from which customer-specific pricing agreements and trade discounts are derived in SAP SD condition records.'
}

Table sales.price_list_item {
  price_list_item_id varchar [pk, note: 'Unique identifier for the price list item record. Primary key for this entity.']
  price_list_id varchar [note: 'Reference to the parent price list that contains this item. Links this SKU-level price entry to its governing price list header.']
  sku_id varchar [note: 'Reference to the product (SKU) for which this price is defined. Identifies the specific finished good or SKU being priced.']
  amount decimal(18,4) [note: 'The amount of the price list item record']
  approval_status varchar [note: 'The approval workflow status for this price list item. Tracks whether the price has been reviewed and approved by pricing management.']
  approved_by varchar [note: 'The user ID or name of the person who approved this price list item. Supports audit trail and accountability for pricing decisions.']
  approved_timestamp timestamp [note: 'The date and time when this price list item was approved. Part of the pricing governance audit trail.']
  channel_type varchar [note: 'The sales channel or distribution channel for which this price applies (e.g., retail, wholesale, DTC, e-commerce). Enables channel-specific pricing strategies.']
  code varchar [note: 'The price list item code of the price list item record']
  condition_type varchar [note: 'The SAP SD condition type code that defines the pricing logic for this item (e.g., PR00 for base price, K004 for customer discount). Maps to SAP pricing procedure.']
  cost_price decimal(18,4) [note: 'The standard cost or COGS for this SKU in the specified currency. Used for margin analysis and profitability calculations. Business-confidential data.']
  created_timestamp timestamp [note: 'The date and time when this price list item record was first created in the system. Part of the audit trail.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all price amounts in this record (e.g., USD, EUR, GBP).']
  customer_segment varchar [note: 'The customer segment or pricing group for which this price applies (e.g., national accounts, regional chains, independent retailers). Supports segment-based pricing.']
  description varchar [note: 'The price list item description of the price list item record']
  distribution_channel varchar [note: 'The SAP distribution channel code for this price list item. Defines the route-to-market for which this price applies.']
  division varchar [note: 'The SAP division code for this price list item. Represents the product line or business unit responsible for this pricing.']
  effective_end_date date [note: 'The date on which this price list item expires and is no longer valid for new sales transactions. Null indicates open-ended validity.']
  effective_from date [note: 'The effective from of the price list item record']
  effective_start_date date [note: 'The date from which this price list item becomes active and can be used in sales transactions. Part of the item\'s validity period.']
  effective_until date [note: 'The effective until of the price list item record']
  geographic_scope varchar [note: 'The geographic region, country, or market for which this price is valid. Supports regional pricing strategies and multi-country operations.']
  gtin varchar [note: 'The globally unique GTIN (UPC, EAN, or GTIN-14) for the product. Supports EDI transactions and retail POS integration.']
  item_sequence varchar [note: 'Sequential line number of this item within the parent price list. Used for ordering and display purposes.']
  list_price decimal(18,4) [note: 'The base list price for this SKU in the specified currency and unit of measure. Represents the standard selling price before any discounts or promotions.']
  margin_percentage decimal(5,2) [note: 'The target gross margin percentage for this price list item, calculated as (list_price - cost_price) / list_price * 100. Business-confidential data.']
  minimum_order_quantity decimal(10,3) [note: 'The minimum quantity that must be ordered for this SKU at this price. Used to enforce order minimums and support volume-based pricing tiers.']
  modified_by varchar [note: 'The user ID or name of the person who last modified this price list item record. Supports audit trail and change tracking.']
  modified_timestamp timestamp [note: 'The date and time when this price list item record was last modified. Part of the audit trail for tracking changes.']
  moq_uom varchar [note: 'The unit of measure for the minimum order quantity (e.g., EA, CS, PAL).']
  msrp_price decimal(18,4) [note: 'The manufacturer\'s suggested retail price for this SKU. Used for retail channel pricing guidance and price protection calculations.']
  name varchar [note: 'The price list item name of the price list item record']
  notes varchar [note: 'Free-text notes or comments about this price list item. Used to document special pricing conditions, exceptions, or business rationale.']
  override_flag boolean [note: 'Indicates whether this price list item represents a manual override of standard pricing logic. True if this is an exception price.']
  price_list_item_status varchar [note: 'Current lifecycle status of this price list item. Controls whether the item can be used in pricing calculations.']
  price_uom varchar [note: 'The unit of measure for which the price is quoted (e.g., EA for each, CS for case, PAL for pallet). Aligns with product packaging hierarchy.']
  pricing_unit_quantity decimal(10,3) [note: 'The quantity of base units represented by one pricing unit. For example, if price is per case and a case contains 12 units, this value is 12.']
  promotional_flag boolean [note: 'Indicates whether this price is part of a promotional campaign. True if this is a temporary promotional price rather than standard list price.']
  quantity decimal(18,4) [note: 'The quantity of the price list item record']
  rsp_price decimal(18,4) [note: 'The recommended selling price for this SKU in the target market. May differ from MSRP based on regional pricing strategies.']
  sales_organization varchar [note: 'The SAP sales organization code responsible for this price list item. Aligns with organizational hierarchy and reporting structure.']
  sap_condition_record_number varchar [note: 'The unique SAP SD condition record number for this price list item. Enables traceability back to the source ERP system.']
  scale_basis varchar [note: 'The basis for volume-based pricing scales (e.g., quantity, order value, weight, volume). Defines how tiered pricing thresholds are measured.']
  scale_quantity_from decimal(10,3) [note: 'The lower bound of the quantity range for which this price applies in a tiered pricing structure. Used for volume discount calculations.']
  scale_quantity_to decimal(10,3) [note: 'The upper bound of the quantity range for which this price applies in a tiered pricing structure. Null indicates no upper limit for the highest tier.']
  source_system_code varchar [note: 'The source system code of the price list item record']
  unit_price decimal(18,4) [note: 'The unit price of the price list item record']
  uom varchar [note: 'The uom of the price list item record']
  updated_timestamp timestamp [note: 'The updated timestamp of the price list item record']
  created_by varchar [note: 'The user ID or name of the person who created this price list item record. Supports audit trail and accountability.']

  Note: 'Individual SKU-level price entry within a price list, capturing the specific list price or MSRP/RSP for a given product in a given channel and currency. Records SKU/GTIN reference, price list reference, unit price, minimum order quantity (MOQ), price unit of measure, effective dates, and override flag. Enables granular SKU-level pricing management and supports SAP SD condition record maintenance.'
}

Table quality.inspection_plan {
  inspection_plan_id varchar [pk, note: 'Unique identifier for the inspection plan. Primary key for the inspection plan master data entity.']
  approved_supplier_list_id varchar [note: 'Foreign key linking to procurement.approved_supplier_list. Business justification: Supplier qualification process: inspection plans are assigned based on ASL qualification level (e.g., AQL severity tied to supplier approval tier). QA teams need to know which ASL entry a plan was des']
  distribution_facility_id varchar [note: 'Foreign key linking to distribution.distribution_facility. Business justification: Inspection plans govern inbound receiving quality checks at distribution centers. Consumer goods DCs maintain facility-specific AQL levels and sampling procedures. This FK scopes inspection plans to d']
  equipment_id varchar [note: 'Foreign key linking to manufacturing.equipment. Business justification: Inspection plans specify which calibrated test equipment must be used, driving equipment scheduling and calibration compliance verification. inspection_plan has test_equipment_required as plain text (']
  formulation_id varchar [note: 'Foreign key linking to product.product_formulation. Business justification: GMP in-process and finished goods inspection plans reference the approved formulation to define test parameters (pH, viscosity, active ingredient content) and acceptance criteria. Standard consumer go']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: Goods receipt quality inspection for raw/packaging materials requires material-level inspection plans. inspection_plan has sku_id for finished goods but no material_id. Standard SAP QM MM integration:']
  packaging_spec_id varchar [note: 'Foreign key linking to product.product_packaging_spec. Business justification: Packaging incoming inspection requires linking the inspection plan to the packaging specification to define acceptance criteria (dimensions, material composition, print quality) for each packaging com']
  sku_id varchar [note: 'Reference to the material (raw material, packaging component, intermediate, or finished good) that this inspection plan applies to.']
  trade_account_id varchar [note: 'Foreign key linking to sales.trade_account. Business justification: Major retail accounts (Walmart, Costco, Kroger) in CPG mandate customer-specific quality inspection plans as a contractual requirement. QA teams must associate inspection plans with the trade account ']
  amount decimal(18,4) [note: 'Attribute amount of quality.inspection_plan.']
  approval_date date [note: 'Date on which this inspection plan was formally approved for use. Part of the plan\'s audit trail and regulatory documentation.']
  approval_required_flag boolean [note: 'Indicates whether inspection results under this plan require formal approval by a quality manager or authorized person before batch release. Typically true for GMP-critical inspections.']
  aql_level decimal(5,2) [note: 'Acceptable Quality Level expressed as a percentage. Maximum percent defective that is considered acceptable for the inspection plan. Used in acceptance sampling decisions.']
  certificate_of_analysis_required_flag boolean [note: 'Indicates whether a formal Certificate of Analysis document must be generated upon successful completion of inspections under this plan. Typically required for finished goods and customer-facing materials.']
  change_control_number varchar [note: 'Reference to the change control request or document that authorized the creation or last modification of this inspection plan. Required for GMP compliance and audit trail.']
  characteristic_count varchar [note: 'Number of quality characteristics (test parameters) defined in this inspection plan. Each characteristic has its own specification limits.']
  code varchar [note: 'Attribute code of quality.inspection_plan.']
  created_timestamp timestamp [note: 'Timestamp when this inspection plan record was first created in the source system. Part of the audit trail.']
  currency_code varchar [note: 'Attribute currency_code of quality.inspection_plan.']
  data_quality_score decimal(5,2) [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  description varchar [note: 'Attribute description of quality.inspection_plan.']
  dynamic_modification_rule varchar [note: 'Attribute dynamic_modification_rule of quality.inspection_plan.']
  effective_end_date date [note: 'Date after which this inspection plan is no longer valid. Nullable for open-ended plans. Used for version control and regulatory compliance.']
  effective_from date [note: 'Attribute effective_from of quality.inspection_plan.']
  effective_start_date date [note: 'Date from which this inspection plan becomes valid and applicable for quality inspections. Part of the plan\'s effective date range.']
  effective_until date [note: 'Attribute effective_until of quality.inspection_plan.']
  gmp_critical_flag boolean [note: 'Indicates whether this inspection plan covers GMP-critical quality attributes that directly impact product safety, efficacy, or regulatory compliance. GMP-critical inspections require enhanced documentation and cannot be skipped.']
  gmp_relevant boolean [note: 'Attribute gmp_relevant of quality.inspection_plan.']
  inspection_frequency varchar [note: 'Attribute inspection_frequency of quality.inspection_plan.']
  inspection_lead_time_days varchar [note: 'Expected number of calendar days required to complete all inspections and testing defined in this plan. Used for production scheduling and inventory planning.']
  inspection_method varchar [note: 'Primary method used to perform the inspection: manual measurement, automated testing, laboratory analysis, visual examination, destructive testing, or non-destructive testing.']
  inspection_plan_status varchar [note: 'Attribute status of quality.inspection_plan.']
  inspection_severity varchar [note: 'Severity level of inspection based on supplier quality history and risk assessment. Tightened inspection applies stricter acceptance criteria.']
  inspection_stage varchar [note: 'Production or supply chain stage at which this inspection is triggered. Aligns with GMP critical control points.']
  inspection_type varchar [note: 'Type of quality inspection this plan governs: incoming (supplier materials), in-process (production intermediates), final (finished goods), stability (shelf-life studies), release (batch release), or periodic (routine surveillance).']
  is_active boolean [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  last_modified_timestamp timestamp [note: 'Timestamp of the most recent modification to this inspection plan record. Used for change tracking and data synchronization.']
  material_type varchar [note: 'Classification of the material subject to inspection. Determines applicable GMP requirements and inspection rigor.']
  name varchar [note: 'Attribute name of quality.inspection_plan.']
  next_review_date date [note: 'Scheduled date for the next periodic review of this inspection plan. GMP requires regular review of quality procedures to ensure continued appropriateness.']
  notes varchar [note: 'Attribute notes of quality.inspection_plan.']
  plan_code varchar [note: 'Business identifier for the inspection plan, used across quality management systems and documentation. Externally visible code for referencing the plan in quality specifications and batch records.']
  plan_description varchar [note: 'Detailed description of the inspection plan including scope, objectives, and special instructions for quality control personnel.']
  plan_name varchar [note: 'Human-readable name of the inspection plan describing its purpose and scope.']
  plan_status varchar [note: 'Current lifecycle status of the inspection plan. Only active plans are used for inspection lot creation.']
  plan_type varchar [note: 'Attribute plan_type of quality.inspection_plan.']
  quantity decimal(18,4) [note: 'Attribute quantity of quality.inspection_plan.']
  record_source_system varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  regulatory_requirement varchar [note: 'Reference to the regulatory requirement, standard, or guideline that mandates this inspection (e.g., FDA 21 CFR Part 211, EU GMP Annex 1, ISO 22716). Critical for compliance audits.']
  responsible_inspector_role varchar [note: 'Job role or qualification level required for personnel authorized to perform inspections under this plan (e.g., QC Technician, QC Analyst, QC Manager). Ensures competency requirements are met.']
  revision_number varchar [note: 'Sequential revision number of this inspection plan. Incremented each time the plan is updated. Part of change control and audit trail.']
  sample_size varchar [note: 'Number of sample units to be drawn per inspection lot. Determined by statistical sampling plan and AQL requirements.']
  sample_unit varchar [note: 'Unit of measure for the sample (e.g., pieces, kg, liters, containers). Defines what constitutes one sample unit.']
  sampling_procedure varchar [note: 'Attribute sampling_procedure of quality.inspection_plan.']
  sampling_procedure_code varchar [note: 'Code identifying the sampling procedure to be followed: sample size, sampling frequency, sampling method (random, systematic, stratified). References approved sampling SOP.']
  skip_lot_allowed_flag boolean [note: 'Indicates whether skip-lot inspection (reduced frequency based on consistent quality history) is permitted for this plan. Not allowed for GMP-critical inspections.']
  source_record_code varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  source_system_code varchar [note: 'Unique identifier of this inspection plan in the source operational system. Enables traceability back to the system of record.']
  specification_version varchar [note: 'Version number of the quality specification document that this inspection plan implements. Ensures traceability to approved specifications.']
  uom varchar [note: 'Attribute uom of quality.inspection_plan.']
  updated_timestamp timestamp [note: 'Attribute updated_timestamp of quality.inspection_plan.']
  usage_indicator varchar [note: 'Attribute usage_indicator of quality.inspection_plan.']
  valid_from_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  valid_to_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  version_number varchar [note: 'Attribute version_number of quality.inspection_plan.']

  Note: 'Master inspection plan defining characteristics, sampling procedures, AQL levels, and methods applied to inspection lots.'
}

Table quality.inspection_lot {
  inspection_lot_id varchar [pk, note: 'Unique identifier for the inspection lot. Primary key for the inspection lot entity representing a discrete QC inspection event triggered by production batch, goods receipt, or periodic review.']
  approved_supplier_list_id varchar [note: 'Foreign key linking to procurement.approved_supplier_list. Business justification: Supplier qualification traceability: the ASL entry active at time of receipt determines inspection requirements. Regulatory audits require proof that the supplier was on the approved list when the lot']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: QC inspection costs (labor, consumables, equipment time) are charged to a cost center in SAP QM/CO integration. Consumer goods QC departments track inspection cost per lot against their cost center bu']
  distribution_facility_id varchar [note: 'Foreign key linking to distribution.distribution_facility. Business justification: Inspection lots created during inbound receiving at a DC must reference that distribution facility. The existing manufacturing_facility_id covers factory-origin lots; this FK covers DC-origin lots, en']
  goods_receipt_id varchar [note: 'Foreign key linking to procurement.goods_receipt. Business justification: Core QM process: in SAP QM and equivalent systems, a goods receipt event directly triggers creation of an inspection lot. Tracing inspection_lot back to the specific goods_receipt is fundamental for i']
  inspection_plan_id varchar [note: 'Identifier of the inspection plan template applied to this lot. Defines the characteristics to be inspected, sampling procedures, and acceptance criteria.']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: Goods receipt inspection for raw/packaging materials creates inspection lots against the material master. inspection_lot has sku_id for finished goods but no material_id for raw/packaging materials. E']
  po_line_id varchar [note: 'Foreign key linking to procurement.po_line. Business justification: Incoming inspection is triggered at PO line level (specific material/quantity). Linking inspection_lot to po_line enables line-level quality traceability, accepted/rejected quantity reconciliation aga']
  production_line_id varchar [note: 'Foreign key linking to manufacturing.production_line. Business justification: In-process inspection lots in consumer goods manufacturing are tied to the production line being monitored for IPC compliance. Line-level inspection lot tracking enables production line quality perfor']
  sku_id varchar [note: 'Identifier of the material (raw material, semi-finished good, or finished good) being inspected in this lot.']
  storage_location_id varchar [note: 'Foreign key linking to distribution.distribution_storage_location. Business justification: Inspection lots are physically held in quarantine storage locations during inspection. WMS quarantine management and FEFO/FIFO compliance require a proper FK to the storage location, replacing the den']
  supplier_id varchar [note: 'Identifier of the supplier or vendor for goods receipt inspection lots. Used for supplier quality performance tracking.']
  supplier_site_id varchar [note: 'Foreign key linking to procurement.supplier_site. Business justification: Supplier site-level quality performance reporting: consumer goods companies track inspection results by supplier site (not just supplier) to identify site-specific quality issues and schedule site aud']
  amount decimal(18,4) [note: 'Attribute amount of quality.inspection_lot.']
  batch_number varchar [note: 'Attribute batch_number of quality.inspection_lot.']
  certificate_of_analysis_number varchar [note: 'Document number of the Certificate of Analysis issued for this inspection lot. Links to formal quality documentation in Veeva Vault.']
  coa_issue_date date [note: 'Date when the Certificate of Analysis was formally issued for this inspection lot.']
  code varchar [note: 'Attribute code of quality.inspection_lot.']
  created_timestamp timestamp [note: 'Date and time when the inspection lot record was first created in the quality management system. Audit trail field.']
  currency_code varchar [note: 'Attribute currency_code of quality.inspection_lot.']
  data_quality_score decimal(5,2) [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  decision_date date [note: 'Date when the formal usage decision was made and recorded in the quality management system.']
  decision_timestamp timestamp [note: 'Precise date and time when the usage decision was recorded. Used for audit trail and compliance reporting.']
  defect_count varchar [note: 'Total number of defects or non-conformances identified during inspection. Used for quality metrics and trend analysis.']
  description varchar [note: 'Attribute description of quality.inspection_lot.']
  disposition_outcome varchar [note: 'Final outcome status of the lot after disposition decision and stock posting. Confirms the actual inventory movement executed.']
  effective_from date [note: 'Attribute effective_from of quality.inspection_lot.']
  effective_until date [note: 'Attribute effective_until of quality.inspection_lot.']
  expiration_date date [note: 'Expiration or best-before date assigned to the batch based on stability study results and shelf-life specifications.']
  gmp_compliance_flag boolean [note: 'Indicates whether the inspection lot was produced and inspected in compliance with Good Manufacturing Practice regulations.']
  inspection_end_date date [note: 'Date when all inspection and testing activities were completed for this lot.']
  inspection_location varchar [note: 'Physical location or quality lab where the inspection was performed. May be different from the plant code for centralized testing facilities.']
  inspection_lot_number varchar [note: 'Business identifier for the inspection lot. Externally visible alphanumeric code used in SAP QM and quality documentation for traceability and audit purposes.']
  inspection_lot_status varchar [note: 'Inspection Lot Status value for the Inspection Lot record.']
  inspection_notes varchar [note: 'Free-text field for inspector comments, observations, or special conditions noted during the inspection process.']
  inspection_priority varchar [note: 'Priority level assigned to the inspection lot. Determines the sequence and urgency of inspection execution in the quality lab.']
  inspection_start_date date [note: 'Date when the physical inspection and testing activities began for this lot.']
  inspection_status varchar [note: 'Current lifecycle status of the inspection lot. Tracks progression from creation through inspection execution to final disposition decision.']
  inspection_type varchar [note: 'Classification of the inspection lot based on the triggering event. Determines the inspection plan template and sampling strategy applied.']
  is_active boolean [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  last_modified_timestamp timestamp [note: 'Date and time when the inspection lot record was last updated. Tracks the most recent change for audit and compliance purposes.']
  lot_number varchar [note: 'Lot Number value for the Inspection Lot record.']
  lot_origin_number varchar [note: 'Document number of the originating transaction (production order number, purchase order number, delivery number, etc.) that triggered this inspection lot.']
  lot_origin_type varchar [note: 'Source document type that triggered the creation of this inspection lot. Links the quality inspection to the originating business transaction.']
  lot_quantity decimal(18,3) [note: 'Total quantity of material in the inspection lot. Represents the population from which samples are drawn for inspection.']
  lot_quantity_uom varchar [note: 'Unit of measure for the lot quantity (each, kilogram, liter, meter, etc.). Aligns with material master UOM. [ENUM-REF-CANDIDATE: EA|KG|L|M|M2|M3|BOX|CASE — 8 candidates stripped; promote to reference product]']
  name varchar [note: 'Attribute name of quality.inspection_lot.']
  notes varchar [note: 'Attribute notes of quality.inspection_lot.']
  origin varchar [note: 'Attribute inspection_lot_origin of quality.inspection_lot.']
  priority varchar [note: 'Attribute priority of quality.inspection_lot.']
  quantity decimal(18,4) [note: 'Attribute quantity of quality.inspection_lot.']
  record_source_system varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  regulatory_hold_flag boolean [note: 'Indicates whether the lot is under regulatory hold pending additional review or approval from regulatory affairs or quality assurance.']
  regulatory_hold_reason varchar [note: 'Detailed explanation of why the lot is under regulatory hold. Documents the specific compliance or quality concern requiring additional review.']
  retest_date date [note: 'Date when the material must be re-inspected to confirm continued compliance with quality specifications. Applicable for raw materials and intermediates.']
  sample_quantity decimal(18,3) [note: 'Quantity of material drawn as a sample for inspection testing. Determined by the inspection plan sampling procedure.']
  sample_quantity_uom varchar [note: 'Unit of measure for the sample quantity drawn for testing. [ENUM-REF-CANDIDATE: EA|KG|L|M|M2|M3|BOX|CASE — 8 candidates stripped; promote to reference product]']
  sample_size varchar [note: 'Sample Size value for the Inspection Lot record.']
  source_record_code varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  source_system_code varchar [note: 'Source System Code value for the Inspection Lot record.']
  stock_posting_instruction varchar [note: 'Instruction for inventory movement based on the usage decision. Determines the target stock type for material posting in warehouse management.']
  system_status varchar [note: 'Attribute system_status of quality.inspection_lot.']
  uom varchar [note: 'Attribute uom of quality.inspection_lot.']
  updated_timestamp timestamp [note: 'Attribute updated_timestamp of quality.inspection_lot.']
  usage_decision varchar [note: 'Final disposition decision for the inspected lot. Determines whether material can be released for use, must be reworked, or should be rejected.']
  usage_decision_code varchar [note: 'Standardized code representing the usage decision. Used for automated stock posting and reporting in SAP QM.']
  valid_from_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  valid_to_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']

  Note: 'Quality inspection lot representing a quantity of material under inspection, linked to inspection plan, results, and usage decision.'
}

Table quality.inspection_result {
  inspection_result_id varchar [pk, note: 'Unique identifier for the inspection result record. Primary key for granular QC (Quality Control) measurement and test result records captured at the characteristic level within an inspection lot.']
  inspection_lot_id varchar [note: 'Reference to the parent inspection lot under which this characteristic-level result was captured. Links to the inspection lot entity that groups multiple inspection results for a batch or production run.']
  nonconformance_id varchar [note: 'Foreign key linking to quality.nonconformance. Business justification: An out-of-specification inspection result is the direct trigger for raising a nonconformance record. This FK links the specific measurement result (with its deviation_code, defect_classification, defe']
  specification_id varchar [note: 'Foreign key linking to quality.specification. Business justification: Link inspection_result to its governing specification for easy access to spec limits and versioning.']
  test_equipment_id varchar [note: 'Surrogate identifier: Test Equipment Id.']
  amount decimal(18,4) [note: 'Attribute amount of quality.inspection_result.']
  approval_status varchar [note: 'Approval status of this inspection result by a quality supervisor or manager. Pending indicates awaiting review; approved indicates result accepted; rejected indicates result invalidated and retest required.']
  approval_timestamp timestamp [note: 'Date and time when this inspection result was approved. Required for GMP audit trails and batch release decision traceability.']
  characteristic_code varchar [note: 'Characteristic Code value for the Inspection Result record.']
  characteristic_name varchar [note: 'Characteristic Name value for the Inspection Result record.']
  coa_inclusion_flag boolean [note: 'Flag indicating whether this result should be included in the Certificate of Analysis (COA) document for the batch. True indicates inclusion; false indicates internal-only result.']
  code varchar [note: 'Attribute code of quality.inspection_result.']
  control_chart_rule_violated varchar [note: 'Description of the specific SPC control chart rule that was violated (e.g., point beyond control limit, 7 consecutive points above centerline, 2 of 3 points beyond 2-sigma). Populated when control_chart_violation_flag is true.']
  control_chart_violation_flag boolean [note: 'Flag indicating whether this measurement violates SPC (Statistical Process Control) control chart rules (e.g., out of control limits, run rules, trend rules). True indicates a violation requiring investigation.']
  created_timestamp timestamp [note: 'Date/time of Created Timestamp.']
  currency_code varchar [note: 'Attribute currency_code of quality.inspection_result.']
  data_quality_score decimal(5,2) [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  data_source_system varchar [note: 'Identifier of the source system from which this inspection result was captured (e.g., SAP QM, LIMS, Veeva Vault, manual entry). Used for data lineage and audit purposes.']
  defect_classification varchar [note: 'Defect Classification value for the Inspection Result record.']
  defect_code varchar [note: 'Standardized code classifying the type of defect or non-conformance observed when result_status is fail. Used for defect trending and root cause analysis.']
  defect_severity varchar [note: 'Classification of the severity of the non-conformance. Critical defects pose safety or regulatory risk; major defects affect functionality; minor defects are cosmetic or non-functional.']
  description varchar [note: 'Attribute description of quality.inspection_result.']
  deviation_code varchar [note: 'Reference to an approved deviation or waiver document that authorizes acceptance of a non-conforming result. Populated when result_status is waived.']
  effective_from date [note: 'Attribute effective_from of quality.inspection_result.']
  effective_until date [note: 'Attribute effective_until of quality.inspection_result.']
  environmental_condition_humidity decimal(5,2) [note: 'Relative humidity (percentage) at the time of measurement. Critical for tests sensitive to moisture levels.']
  environmental_condition_temperature decimal(5,2) [note: 'Ambient temperature (in degrees Celsius) at the time of measurement. Critical for tests sensitive to environmental conditions.']
  evaluation_result varchar [note: 'Evaluation Result value for the Inspection Result record.']
  inspection_characteristic_code varchar [note: 'Unique code identifying the specific quality characteristic being measured (e.g., pH level, viscosity, weight, color, microbial count). Corresponds to the master inspection characteristic definition.']
  inspection_characteristic_name varchar [note: 'Human-readable name of the quality characteristic being tested (e.g., Product pH, Net Weight, Microbial Load, Color Consistency).']
  inspection_method varchar [note: 'Attribute inspection_method of quality.inspection_result.']
  inspection_method_code varchar [note: 'Code identifying the standardized test method or procedure used to perform this measurement (e.g., ASTM method, USP method, internal SOP number).']
  inspection_result_status varchar [note: 'Attribute status of quality.inspection_result.']
  inspection_timestamp timestamp [note: 'Date and time when this specific characteristic measurement was performed. Critical for time-sensitive tests and GMP audit trails.']
  instrument_code varchar [note: 'Unique identifier of the measurement instrument or equipment used to capture this result (e.g., balance ID, pH meter ID, spectrophotometer ID). Required for GMP (Good Manufacturing Practice) audit trails and instrument calibration traceability.']
  is_active boolean [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  is_within_spec boolean [note: 'Boolean indicator for Is Within Spec.']
  laboratory_code varchar [note: 'Identifier of the laboratory or testing facility where this measurement was performed. May be an internal QC lab or an external contract lab.']
  last_modified_timestamp timestamp [note: 'Date/time of Last Modified Timestamp.']
  lower_spec_limit decimal(18,6) [note: 'Lower Spec Limit value for the Inspection Result record.']
  lower_specification_limit decimal(18,6) [note: 'The minimum acceptable value for this characteristic as defined in the product specification or quality standard. Values below this threshold indicate non-conformance.']
  measured_value decimal(18,6) [note: 'The actual quantitative measurement or test result value recorded during inspection. For qualitative characteristics, this may be encoded numerically or stored as a code.']
  measurement_timestamp timestamp [note: 'Date/time of Measurement Timestamp.']
  measurement_uncertainty decimal(18,6) [note: 'Quantified estimate of the uncertainty or error margin associated with the measured value. Required for ISO 17025 compliance and advanced SPC (Statistical Process Control) analysis.']
  name varchar [note: 'Attribute name of quality.inspection_result.']
  notes varchar [note: 'Notes value for the Inspection Result record.']
  quantity decimal(18,4) [note: 'Attribute quantity of quality.inspection_result.']
  record_created_timestamp timestamp [note: 'Date and time when this inspection result record was first created in the system. Audit trail field for data governance.']
  record_source_system varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  record_updated_timestamp timestamp [note: 'Date and time when this inspection result record was last modified. Audit trail field for data governance and change tracking.']
  recorded_timestamp timestamp [note: 'Attribute recorded_timestamp of quality.inspection_result.']
  regulatory_reportable_flag boolean [note: 'Flag indicating whether this result must be reported to regulatory authorities (e.g., FDA, EPA) due to non-conformance or safety concerns. True indicates reportable event.']
  remarks varchar [note: 'Free-text comments or observations recorded by the inspector regarding this measurement. May include notes on sample condition, procedural deviations, or contextual information.']
  result_status varchar [note: 'Pass/fail status of this individual characteristic measurement. Pass indicates the measured value is within specification limits; fail indicates non-conformance; conditional indicates acceptance with restrictions; pending indicates awaiting review; waived indicates non-conformance accepted by authorized deviation.']
  result_uom varchar [note: 'Result Uom value for the Inspection Result record.']
  result_valuation varchar [note: 'Attribute result_valuation of quality.inspection_result.']
  result_value decimal(18,6) [note: 'Result Value value for the Inspection Result record.']
  result_value_text varchar [note: 'Result Value Text value for the Inspection Result record.']
  retest_indicator boolean [note: 'Flag indicating whether this result is a retest of a previously failed or inconclusive measurement. True indicates this is a retest; false indicates initial test.']
  retest_reason_code varchar [note: 'Code indicating the reason for retesting this characteristic. Applicable only when retest_indicator is true.']
  sample_sequence_number varchar [note: 'Sequential number of this sample within the inspection lot (e.g., 1, 2, 3). Used to track sampling order and support statistical sampling plans.']
  source_record_code varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  source_system_code varchar [note: 'Source System Code value for the Inspection Result record.']
  target_value decimal(18,6) [note: 'The ideal or nominal value for this characteristic. Used for process capability analysis and SPC (Statistical Process Control) charting.']
  test_batch_number varchar [note: 'Batch or run number of the test reagents or consumables used during this measurement. Required for traceability in regulated environments.']
  test_method varchar [note: 'Test Method value for the Inspection Result record.']
  unit_of_measure varchar [note: 'The unit in which the measured value is expressed (e.g., grams, milliliters, pH units, CFU/g for colony forming units per gram, percentage).']
  uom varchar [note: 'Attribute uom of quality.inspection_result.']
  updated_timestamp timestamp [note: 'Attribute updated_timestamp of quality.inspection_result.']
  upper_spec_limit decimal(18,6) [note: 'Upper Spec Limit value for the Inspection Result record.']
  upper_specification_limit decimal(18,6) [note: 'The maximum acceptable value for this characteristic as defined in the product specification or quality standard. Values above this threshold indicate non-conformance.']
  valid_from_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  valid_to_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']

  Note: 'Recorded measurement result for an inspection characteristic, evaluated against specification limits with pass/fail valuation.'
}

Table quality.usage_decision {
  usage_decision_id varchar [pk, note: 'Unique identifier for the quality control usage decision record. Primary key.']
  capa_id varchar [note: 'Reference to the CAPA record initiated as a result of this usage decision, if applicable. Null if no CAPA was required.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Usage decisions triggering scrap, rework, or destruction post costs to a cost center (scrap account, rework cost center). Consumer goods operations track disposition costs by cost center for variance ']
  inbound_receipt_line_id varchar [note: 'Foreign key linking to distribution.inbound_receipt_line. Business justification: Usage decisions (accept/reject/rework) directly govern disposition of inbound receipt lines — stock posting, quarantine, or supplier return. QA and logistics teams jointly use this link for GMP dispos']
  inspection_lot_id varchar [note: 'Reference to the inspection lot for which this usage decision was made. Links to the QC inspection lot that was evaluated.']
  journal_entry_id varchar [note: 'Foreign key linking to finance.journal_entry. Business justification: Usage decisions in SAP QM trigger automatic goods movement postings (QI stock → unrestricted/scrap/rework) that generate journal entries. Linking usage_decision to journal_entry enables financial audi']
  logistics_shipment_id varchar [note: 'Foreign key linking to logistics.logistics_shipment. Business justification: Usage decisions (accept/reject/rework) on inspection lots directly trigger logistics actions: shipment holds, returns, or release for distribution. Linking usage_decision to logistics_shipment enables']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: Material disposition process (accept/reject/rework) for incoming raw/packaging materials requires linking usage decisions to the material master for inventory stock posting and supplier feedback. usag']
  nonconformance_id varchar [note: 'Foreign key linking to quality.nonconformance. Business justification: A usage decision resulting in rejection or rework disposition directly triggers a nonconformance record. This FK links the usage decision (with its disposition, rejected_quantity, rework_quantity) to ']
  sku_id varchar [note: 'Reference to the material or product that was inspected and for which the usage decision applies.']
  storage_location_id varchar [note: 'Foreign key linking to distribution.distribution_storage_location. Business justification: Usage decisions include stock_posting_instruction directing material to a specific storage location (quarantine, blocked, or available). Formalizing this FK replaces the denormalized storage_location_']
  supplier_id varchar [note: 'Reference to the supplier or vendor who provided the material, if applicable. Used for supplier quality management and vendor scorecarding.']
  accepted_quantity decimal(18,4) [note: 'Accepted Quantity value for the Usage Decision record.']
  amount decimal(18,4) [note: 'Attribute amount of quality.usage_decision.']
  approval_date date [note: 'The date when the usage decision was formally approved by authorized quality management personnel. Null if no approval was required.']
  approval_required_flag boolean [note: 'Indicates whether this usage decision requires additional management or quality assurance approval before batch release. True=Approval required, False=No additional approval needed.']
  batch_number varchar [note: 'The production batch or lot number to which this usage decision applies. Critical for traceability and recall management.']
  capa_required_flag boolean [note: 'Indicates whether this usage decision triggers a CAPA process due to significant non-conformance. True=CAPA required, False=No CAPA needed. Links to continuous improvement.']
  certificate_of_analysis_number varchar [note: 'Reference number of the Certificate of Analysis document that supports this usage decision. Links to detailed test results and specifications.']
  code varchar [note: 'Attribute code of quality.usage_decision.']
  comments varchar [note: 'Additional free-text comments or notes related to the usage decision. May include special handling instructions, escalation notes, or contextual information.']
  created_timestamp timestamp [note: 'Date/time of Created Timestamp.']
  currency_code varchar [note: 'Attribute currency_code of quality.usage_decision.']
  data_quality_score decimal(5,2) [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  decision_code varchar [note: 'The formal quality control usage decision code. A=Accept (Unrestricted Use), R=Reject, Q=Quality Hold, S=Restricted Use (Sample/Scrap), X=Rework Required. Drives downstream inventory disposition.']
  decision_date date [note: 'The calendar date on which the usage decision was formally made and recorded. Critical for compliance timelines and batch release tracking.']
  decision_description varchar [note: 'Decision Description value for the Usage Decision record.']
  decision_maker_name varchar [note: 'Full name of the quality control inspector or authorized personnel who made the usage decision. Captured for audit and traceability purposes.']
  decision_text varchar [note: 'Detailed textual description or rationale for the usage decision. Captures the quality assessor\'s reasoning and any special conditions or instructions.']
  decision_timestamp timestamp [note: 'The precise date and time when the usage decision was recorded in the system. Provides audit trail precision for regulatory compliance.']
  decision_type varchar [note: 'Decision Type value for the Usage Decision record.']
  defect_code varchar [note: 'Standardized code identifying the primary defect or non-conformance that led to rejection or restricted use decision. Used for root cause analysis and trend reporting.']
  defect_description varchar [note: 'Detailed description of the defect, non-conformance, or quality issue identified during inspection. Supports CAPA and continuous improvement processes.']
  description varchar [note: 'Attribute description of quality.usage_decision.']
  disposition varchar [note: 'Disposition value for the Usage Decision record.']
  disposition_date date [note: 'The date when the material disposition action was completed (e.g., stock posted to unrestricted, blocked, or scrapped). Null if disposition is still pending.']
  disposition_status varchar [note: 'Current status of the material disposition action following the usage decision. pending=Decision made but stock not yet moved, completed=Stock posting completed, cancelled=Decision reversed or voided.']
  effective_from date [note: 'Attribute effective_from of quality.usage_decision.']
  effective_until date [note: 'Attribute effective_until of quality.usage_decision.']
  follow_up_action varchar [note: 'Attribute follow_up_action of quality.usage_decision.']
  gmp_compliance_flag boolean [note: 'Indicates whether the batch meets Good Manufacturing Practice requirements. True=GMP compliant, False=Non-compliant. Required for pharmaceutical and cosmetic products.']
  inspection_type varchar [note: 'The type of quality inspection that led to this usage decision. goods_receipt=incoming material inspection, in_process=during production, final=finished goods, stability=shelf-life testing, complaint=customer complaint investigation.']
  is_active boolean [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  last_modified_timestamp timestamp [note: 'Date/time of Last Modified Timestamp.']
  name varchar [note: 'Attribute name of quality.usage_decision.']
  notes varchar [note: 'Attribute notes of quality.usage_decision.']
  plant_code varchar [note: 'The manufacturing plant or facility code where the inspection and usage decision were performed. Critical for multi-site quality management.']
  quality_score decimal(7,4) [note: 'Quality Score value for the Usage Decision record.']
  quantity decimal(18,4) [note: 'Attribute quantity of quality.usage_decision.']
  quantity_accepted decimal(18,3) [note: 'The quantity of material accepted for unrestricted use based on the usage decision. Measured in the material\'s base unit of measure.']
  quantity_rejected decimal(18,3) [note: 'The quantity of material rejected and not suitable for use. Measured in the material\'s base unit of measure. May trigger disposal or return to supplier.']
  quantity_rework decimal(18,3) [note: 'The quantity of material designated for rework or reprocessing to meet quality standards. Measured in the material\'s base unit of measure.']
  reason_code varchar [note: 'Reason Code value for the Usage Decision record.']
  record_created_timestamp timestamp [note: 'The timestamp when this usage decision record was first created in the lakehouse. Part of the audit trail for data governance.']
  record_source_system varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  record_updated_timestamp timestamp [note: 'The timestamp when this usage decision record was last updated in the lakehouse. Tracks data freshness and change history.']
  regulatory_hold_flag boolean [note: 'Indicates whether the material is under regulatory hold and cannot be released for distribution. True=Hold in effect, False=No regulatory hold. Critical for FDA and EPA compliance.']
  regulatory_hold_reason varchar [note: 'Detailed explanation of why the material is under regulatory hold. May reference specific test failures, compliance issues, or pending regulatory approvals.']
  rejected_quantity decimal(18,4) [note: 'Rejected Quantity value for the Usage Decision record.']
  rework_quantity decimal(18,4) [note: 'Rework Quantity value for the Usage Decision record.']
  sampling_procedure varchar [note: 'The sampling method or procedure used during the inspection (e.g., random sampling, statistical sampling, 100% inspection). Ensures inspection validity.']
  source_record_code varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  source_system_code varchar [note: 'The unique identifier of this usage decision record in the source operational system. Enables traceability back to the system of record.']
  stock_posting_instruction varchar [note: 'Instruction for how the inspected material should be posted to inventory. Determines the stock type and availability for use: unrestricted (available for sale/use), blocked (not available), quality_inspection (under evaluation), scrap (to be disposed), sample (for testing), rework (to be reprocessed).']
  stock_posting_type varchar [note: 'Attribute stock_posting_type of quality.usage_decision.']
  ud_code varchar [note: 'Attribute ud_code of quality.usage_decision.']
  unit_of_measure varchar [note: 'The unit of measure for the quantities in this usage decision (e.g., EA=Each, KG=Kilogram, L=Liter, CS=Case). Aligns with material master UOM.']
  uom varchar [note: 'Attribute uom of quality.usage_decision.']
  updated_timestamp timestamp [note: 'Attribute updated_timestamp of quality.usage_decision.']
  usage_decision_status varchar [note: 'Attribute status of quality.usage_decision.']
  valid_from_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  valid_to_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']

  Note: 'Usage decision recording acceptance, rejection, or rework disposition for an inspection lot and resulting stock posting.'
}

Table quality.nonconformance {
  nonconformance_id varchar [pk, note: 'Unique identifier for the nonconformance record. Primary key for the nonconformance data product.']
  certificate_of_analysis_id varchar [note: 'Foreign key linking to quality.certificate_of_analysis. Business justification: A nonconformance raised during batch review or incoming goods inspection may reference the Certificate of Analysis for the implicated batch. This FK enables QA to directly access the CoA from the nonc']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Cost of quality report allocates nonconformance financial impact to responsible cost center for internal cost tracking.']
  distribution_facility_id varchar [note: 'Foreign key linking to distribution.distribution_facility. Business justification: Nonconformances detected at distribution centers (e.g., storage failures, picking damage, temperature excursions) must reference the DC where detected. The existing manufacturing_facility_id covers fa']
  equipment_id varchar [note: 'Foreign key linking to manufacturing.equipment. Business justification: Equipment failures are a primary root cause category for nonconformances in consumer goods manufacturing. Linking NCs to specific equipment enables equipment reliability analysis, drives maintenance C']
  formulation_id varchar [note: 'Foreign key linking to product.product_formulation. Business justification: Formulation deviation management requires linking NCs to the specific product formulation version when in-process failures (out-of-spec pH, viscosity, active ingredient content) occur. Supports root c']
  inspection_lot_id varchar [note: 'Inspection Lot Id referencing quality.inspection_lot.inspection_lot_id.']
  journal_entry_id varchar [note: 'Foreign key linking to finance.journal_entry. Business justification: Nonconformances with financial impact (scrap write-offs, material destruction, rework costs) generate journal entries. nonconformance already has financial_impact_amount, confirming financial posting ']
  label_spec_id varchar [note: 'Foreign key linking to product.label_spec. Business justification: Label quality management requires raising NCs against specific label specifications when label defects (regulatory text errors, artwork deviations, missing allergen warnings) are detected during inspe']
  marketing_brand_id varchar [note: 'Foreign key linking to marketing.marketing_brand. Business justification: Brand protection and recall risk management require nonconformance events to be tracked by brand. Brand managers and QA teams use brand-level nonconformance reporting for regulatory submissions, brand']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: Supplier quality management requires raising nonconformances against specific raw/packaging materials when they fail incoming inspection. nonconformance has sku_id for finished goods but no material_i']
  packaging_spec_id varchar [note: 'Foreign key linking to product.product_packaging_spec. Business justification: Packaging quality management requires raising NCs against specific packaging specifications when components fail dimensional, material, or print quality requirements. Enables packaging supplier qualit']
  product_complaint_id varchar [note: 'Foreign key reference to the customer complaint record that triggered this nonconformance, when applicable. Links to consumer complaint tracking system.']
  production_line_id varchar [note: 'Foreign key linking to manufacturing.production_line. Business justification: Nonconformances in consumer goods manufacturing are attributed to specific production lines for root cause analysis, line performance KPIs, and OEE quality component reporting. Quality managers need N']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Non‑conformance events are tied to the SKU that caused the issue, enabling targeted CAPA and impact analysis.']
  specification_id varchar [note: 'Foreign key linking to quality.specification. Business justification: A nonconformance is raised when a material or process deviates from a defined quality specification. Linking nonconformance directly to specification enables QA to identify which specification was vio']
  supplier_id varchar [note: 'Foreign key reference to the supplier associated with this nonconformance, applicable when the issue originates from supplier-provided materials or components. Links to supplier master data.']
  supplier_site_id varchar [note: 'Foreign key linking to procurement.supplier_site. Business justification: Site-level nonconformance tracking is standard in consumer goods supplier quality management. Multi-site suppliers require site-specific NC metrics for audit scheduling and site performance scorecards']
  affected_quantity decimal(15,3) [note: 'Quantity of product units or material affected by the nonconformance. Used for containment scope and financial impact assessment.']
  affected_quantity_uom varchar [note: 'Unit of measure for the affected quantity: EA (each/units), KG (kilograms), L (liters), M (meters), BOX (boxes), PALLET (pallets).']
  amount decimal(18,4) [note: 'Attribute amount of quality.nonconformance.']
  closed_date date [note: 'Date/time of Closed Date.']
  closed_timestamp timestamp [note: 'Date and time when the nonconformance was formally closed after verification of corrective actions and effectiveness checks. Null if still open.']
  code varchar [note: 'Attribute code of quality.nonconformance.']
  containment_action varchar [note: 'Immediate containment actions taken to prevent further occurrence or distribution of nonconforming product. Describes short-term corrective measures implemented before root cause analysis.']
  containment_timestamp timestamp [note: 'Date and time when containment actions were completed and verified effective. Critical for regulatory reporting and OTIF compliance.']
  created_timestamp timestamp [note: 'Date and time when this nonconformance record was first created in the lakehouse silver layer. Audit trail for data governance.']
  currency_code varchar [note: 'Attribute currency_code of quality.nonconformance.']
  data_quality_score decimal(5,2) [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  defect_category varchar [note: 'Attribute defect_category of quality.nonconformance.']
  defect_classification varchar [note: 'Technical classification of the defect type: appearance (cosmetic defect), functionality (performance issue), safety (consumer safety risk), labeling (incorrect or missing label information), packaging (packaging integrity issue), contamination (foreign material or microbial contamination), specification_failure (out-of-specification test result), or process_deviation (manufacturing process non-conformance). [ENUM-REF-CANDIDATE: appearance|functionality|safety|labeling|packaging|contamination|specification_failure|process_deviation — 8 candidates stripped; promote to reference product]']
  defect_description varchar [note: 'Detailed narrative description of the nonconformance, including observed symptoms, affected characteristics, and initial assessment. Captures the what, where, and when of the quality event.']
  description varchar [note: 'Description value for the Nonconformance record.']
  detected_date date [note: 'Date/time of Detected Date.']
  detected_timestamp timestamp [note: 'Date and time when the nonconformance was first detected or observed. Represents the real-world event time of quality issue identification.']
  detection_point varchar [note: 'Attribute detection_point of quality.nonconformance.']
  detection_source varchar [note: 'Origin point where the nonconformance was first identified: QC inspection (quality control laboratory testing), manufacturing line (in-process detection), supplier receipt (incoming material inspection), customer complaint (consumer-reported issue), regulatory audit (FDA or regulatory body inspection), internal audit (GMP self-audit), or stability study (long-term product stability testing). [ENUM-REF-CANDIDATE: qc_inspection|manufacturing_line|supplier_receipt|customer_complaint|regulatory_audit|internal_audit|stability_study — 7 candidates stripped; promote to reference product]']
  disposition varchar [note: 'Disposition value for the Nonconformance record.']
  disposition_approved_by varchar [note: 'User identifier of the quality authority who approved the disposition decision. Links to workforce/employee master data for audit trail and GMP compliance.']
  disposition_approved_timestamp timestamp [note: 'Date and time when the disposition decision was formally approved by quality authority. Critical for GMP audit trail and batch release decisions.']
  disposition_decision varchar [note: 'Final disposition decision for the nonconforming product or material: use_as_is (approved for use despite nonconformance), rework (reprocess to meet specifications), scrap (destroy), return_to_supplier (send back to vendor), downgrade (sell as lower grade), or quarantine (hold pending further investigation).']
  effective_from date [note: 'Attribute effective_from of quality.nonconformance.']
  effective_until date [note: 'Attribute effective_until of quality.nonconformance.']
  event_type varchar [note: 'Classification of the quality event: complaint (customer-reported issue), defect (internal manufacturing defect), deviation (process deviation from standard), improvement request (continuous improvement opportunity), supplier issue (supplier quality problem), or audit finding (GMP audit observation).']
  financial_impact_amount decimal(15,2) [note: 'Estimated or actual financial impact of the nonconformance, including costs of rework, scrap, containment, investigation, customer credits, and potential recall costs. Expressed in base currency.']
  financial_impact_currency varchar [note: 'Three-letter ISO 4217 currency code for the financial impact amount (e.g., USD, EUR, GBP).']
  is_active boolean [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  is_gmp_related boolean [note: 'Boolean indicator for Is Gmp Related.']
  last_modified_timestamp timestamp [note: 'Date/time of Last Modified Timestamp.']
  name varchar [note: 'Attribute name of quality.nonconformance.']
  nc_number varchar [note: 'Nc Number value for the Nonconformance record.']
  nc_status varchar [note: 'Nc Status value for the Nonconformance record.']
  nc_type varchar [note: 'Nc Type value for the Nonconformance record.']
  nonconformance_status varchar [note: 'Current lifecycle status of the nonconformance record: open (newly created), in_investigation (root cause analysis underway), containment_active (immediate containment actions in progress), capa_assigned (corrective and preventive action assigned), closed (resolved and verified), or cancelled (invalidated).']
  notes varchar [note: 'Attribute notes of quality.nonconformance.']
  notification_number varchar [note: 'External business identifier for the quality notification or nonconformance event. Corresponds to SAP QM notification number or Veeva Vault quality event identifier.']
  priority varchar [note: 'Business priority for resolution based on operational impact, customer visibility, and regulatory risk. Urgent: immediate action required; High: expedited resolution needed; Medium: standard timeline; Low: routine handling.']
  quantity decimal(18,4) [note: 'Attribute quantity of quality.nonconformance.']
  record_source_system varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  regulatory_report_date date [note: 'Date when the nonconformance was reported to regulatory authorities, if applicable. Null if not reportable or not yet reported.']
  regulatory_reportable boolean [note: 'Boolean indicator for Regulatory Reportable.']
  regulatory_reportable_flag boolean [note: 'Boolean indicator whether this nonconformance requires reporting to regulatory authorities (FDA, EPA, CPSC) based on severity, product category, and regulatory requirements. True indicates mandatory regulatory notification.']
  reported_date date [note: 'Attribute reported_date of quality.nonconformance.']
  reported_timestamp timestamp [note: 'Date and time when the nonconformance was formally logged into the quality management system (SAP QM or Veeva Vault). May differ from detection timestamp due to reporting lag.']
  responsible_department varchar [note: 'Functional department responsible for investigating and resolving the nonconformance (e.g., Quality Assurance, Manufacturing, Supply Chain, R&D).']
  root_cause varchar [note: 'Root Cause value for the Nonconformance record.']
  root_cause_analysis varchar [note: 'Detailed findings from root cause investigation, including methodology used (5-Why, Fishbone, Fault Tree Analysis) and identified root causes. Supports CAPA development.']
  severity varchar [note: 'Severity classification of the quality event based on impact to product safety, efficacy, and regulatory compliance. Critical: immediate risk to consumer safety or regulatory violation; Major: significant quality impact requiring containment; Minor: low impact quality issue.']
  source_record_code varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  source_system_code varchar [note: 'Unique identifier of this nonconformance record in the source system (SAP QM notification number or Veeva Vault quality event ID). Enables traceability back to operational system.']
  uom varchar [note: 'Attribute uom of quality.nonconformance.']
  updated_timestamp timestamp [note: 'Date and time when this nonconformance record was last modified in the lakehouse silver layer. Audit trail for data governance and change tracking.']
  valid_from_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  valid_to_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  verification_method varchar [note: 'Method used to verify effectiveness of corrective actions and confirm the nonconformance has been resolved (e.g., re-inspection, re-testing, process validation, trend analysis).']

  Note: 'Nonconformance record documenting a quality deviation, its disposition, root cause, and linkage to CAPA.'
}

Table quality.capa {
  capa_id varchar [pk, note: 'Unique identifier for the CAPA record. Primary key.']
  approved_supplier_list_id varchar [note: 'Foreign key linking to procurement.approved_supplier_list. Business justification: Supplier re-qualification process: CAPAs issued to suppliers often require completion before ASL status is restored or upgraded. Linking CAPA to the specific ASL entry enables tracking of qualificatio']
  carrier_id varchar [note: 'Foreign key linking to logistics.carrier. Business justification: CAPAs are frequently initiated against carriers for recurring logistics quality failures (damage rates, temperature excursions, OTIF failures). capa already has supplier_id but carriers are distinct m']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: CAPA cost impact must be charged to a cost center for budgeting and expense analysis.']
  distribution_facility_id varchar [note: 'Foreign key linking to distribution.distribution_facility. Business justification: CAPAs initiated from distribution-related nonconformances (storage failures, mispicks, cold chain breaks) must reference the originating DC. The existing manufacturing_facility_id covers factory CAPAs']
  equipment_id varchar [note: 'Foreign key linking to manufacturing.equipment. Business justification: Equipment-related CAPAs (triggered by equipment failures causing quality events) must reference the specific equipment to drive preventive maintenance scheduling, requalification, and effectiveness ve']
  formulation_id varchar [note: 'Foreign key linking to product.product_formulation. Business justification: Formulation change control requires linking CAPAs to the specific formulation version that triggered the quality failure (stability failure, ingredient nonconformance). Enables root cause analysis and']
  journal_entry_id varchar [note: 'Foreign key linking to finance.journal_entry. Business justification: CAPA implementation costs (investigation, process changes, retraining, equipment upgrades) are posted as journal entries. capa already has cost_impact_amount and cost_impact_currency_code, confirming ']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: Supplier corrective action process for raw/packaging material quality failures requires linking CAPAs to the material master. capa has sku_id for finished goods but no material_id. Enables material-le']
  nonconformance_id varchar [note: 'Nonconformance Id referencing quality.nonconformance.nonconformance_id.']
  sku_id varchar [note: 'Identifier of the product affected by or related to this CAPA. Links to the product master data.']
  supplier_contract_id varchar [note: 'Foreign key linking to procurement.supplier_contract. Business justification: CAPA actions often stem from supplier contract obligations; linking ensures contract compliance tracking and auditability of corrective measures.']
  supplier_id varchar [note: 'Identifier of the supplier associated with the CAPA, if the issue originated from supplier-provided materials or services.']
  work_center_id varchar [note: 'Foreign key linking to manufacturing.work_center. Business justification: CAPAs in consumer goods GMP manufacturing are scoped to specific work centers for effectiveness verification and requalification. capa has process_area as plain text (denormalized work center referenc']
  actual_completion_date date [note: 'The actual date when all CAPA actions were completed and verified, prior to formal closure.']
  amount decimal(18,4) [note: 'Attribute amount of quality.capa.']
  batch_number varchar [note: 'Manufacturing batch or lot number associated with the CAPA, if applicable. Used to trace quality issues to specific production runs.']
  capa_number varchar [note: 'Business-facing unique identifier for the CAPA record, typically formatted as CAPA-NNNNNN. Used for external communication and audit trails.']
  capa_status varchar [note: 'Current lifecycle status of the CAPA record, tracking progression from initiation through closure. [ENUM-REF-CANDIDATE: open|investigation|action_plan|implementation|verification|closed|cancelled — 7 candidates stripped; promote to reference product]']
  capa_type varchar [note: 'Classification of the CAPA as corrective (addressing existing nonconformance), preventive (preventing potential nonconformance), or combined (both corrective and preventive actions).']
  closed_date date [note: 'Date/time of Closed Date.']
  closure_comments varchar [note: 'Final comments or notes recorded at the time of CAPA closure, summarizing outcomes and lessons learned.']
  closure_date date [note: 'The date when the CAPA was formally closed after successful completion and verification of all actions.']
  code varchar [note: 'Attribute code of quality.capa.']
  completion_date date [note: 'Attribute completion_date of quality.capa.']
  corrective_action varchar [note: 'Corrective Action value for the Capa record.']
  corrective_action_description varchar [note: 'Detailed description of the corrective action(s) taken to address the existing nonconformance and eliminate its cause.']
  cost_impact_amount decimal(18,2) [note: 'Estimated or actual financial cost impact of the CAPA issue, including costs of investigation, rework, scrap, recall, or other remediation activities.']
  cost_impact_currency_code varchar [note: 'Three-letter ISO 4217 currency code for the cost impact amount (e.g., USD, EUR, GBP).']
  created_timestamp timestamp [note: 'Timestamp when the CAPA record was first created in the quality management system.']
  currency_code varchar [note: 'Attribute currency_code of quality.capa.']
  customer_impact_flag boolean [note: 'Indicates whether the CAPA issue had a direct impact on customers, such as product quality defects, delivery delays, or safety concerns.']
  data_quality_score decimal(5,2) [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  description varchar [note: 'Detailed description of the nonconformance, audit finding, complaint, or stability failure that triggered the CAPA.']
  due_date date [note: 'Date/time of Due Date.']
  effective_from date [note: 'Attribute effective_from of quality.capa.']
  effective_until date [note: 'Attribute effective_until of quality.capa.']
  effectiveness_check_date date [note: 'Date/time of Effectiveness Check Date.']
  effectiveness_result varchar [note: 'Effectiveness Result value for the Capa record.']
  effectiveness_verification_method varchar [note: 'The method or approach used to verify that the corrective and preventive actions were effective in resolving the issue and preventing recurrence (e.g., follow-up audit, process monitoring, trend analysis).']
  effectiveness_verification_result varchar [note: 'The outcome of the effectiveness verification, indicating whether the CAPA actions successfully resolved the issue and prevented recurrence.']
  effectiveness_verified boolean [note: 'Attribute effectiveness_verified of quality.capa.']
  gmp_deviation_flag boolean [note: 'Indicates whether the CAPA issue involved a deviation from Good Manufacturing Practice (GMP) standards.']
  initiated_date date [note: 'The date when the CAPA record was formally initiated and opened in the quality management system.']
  is_active boolean [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  last_modified_timestamp timestamp [note: 'Timestamp when the CAPA record was last updated or modified.']
  name varchar [note: 'Attribute name of quality.capa.']
  notes varchar [note: 'Attribute notes of quality.capa.']
  opened_date date [note: 'Date/time of Opened Date.']
  preventive_action varchar [note: 'Preventive Action value for the Capa record.']
  preventive_action_description varchar [note: 'Detailed description of the preventive action(s) implemented to prevent recurrence of the issue or occurrence of similar issues.']
  priority varchar [note: 'Priority level assigned to the CAPA for resource allocation and scheduling purposes.']
  problem_statement varchar [note: 'Attribute problem_statement of quality.capa.']
  quantity decimal(18,4) [note: 'Attribute quantity of quality.capa.']
  record_source_system varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  regulatory_impact_flag boolean [note: 'Boolean indicator for Regulatory Impact Flag.']
  regulatory_report_date date [note: 'The date when the CAPA issue was reported to the relevant regulatory authority, if applicable.']
  regulatory_reportable_flag boolean [note: 'Indicates whether this CAPA issue is required to be reported to regulatory authorities such as FDA, EPA, or other governing bodies.']
  responsible_department varchar [note: 'The department or functional area responsible for implementing the CAPA actions.']
  root_cause_analysis varchar [note: 'Root Cause Analysis value for the Capa record.']
  root_cause_analysis_method varchar [note: 'The methodology used to identify the root cause of the issue, such as 5 Whys, Fishbone Diagram, Fault Tree Analysis, Pareto Analysis, or Failure Mode and Effects Analysis (FMEA).']
  root_cause_description varchar [note: 'Detailed description of the identified root cause(s) of the nonconformance or issue.']
  severity varchar [note: 'Severity classification of the CAPA issue based on impact to product quality, safety, regulatory compliance, or business operations.']
  source_record_code varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  source_reference_number varchar [note: 'Reference identifier of the originating event (e.g., nonconformance ID, audit finding ID, complaint ID) that triggered this CAPA.']
  source_system_code varchar [note: 'Source System Code value for the Capa record.']
  source_type varchar [note: 'The origin or trigger event that initiated the CAPA, such as nonconformance, audit finding, customer complaint, supplier quality issue, stability study failure, or regulatory inspection finding.']
  target_completion_date date [note: 'The planned or target date by which all CAPA actions should be completed and verified.']
  title varchar [note: 'Brief descriptive title summarizing the CAPA issue or focus area.']
  uom varchar [note: 'Attribute uom of quality.capa.']
  updated_timestamp timestamp [note: 'Attribute updated_timestamp of quality.capa.']
  valid_from_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  valid_to_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  verification_date date [note: 'The date when the effectiveness verification was completed.']

  Note: 'Corrective and preventive action record capturing root-cause analysis, corrective actions, preventive actions, and effectiveness verification.'
}

Table quality.batch_release {
  batch_release_id varchar [pk, note: 'Unique identifier for the batch release decision record. Primary key for the batch release entity.']
  batch_certificate_of_analysis_id varchar [note: 'Attribute certificate_of_analysis_id of quality.batch_release.']
  batch_record_id varchar [note: 'Foreign key linking to manufacturing.batch_record. Business justification: Batch release decisions are based on the manufacturing batch record; linking ensures release status reflects the underlying production data and supports regulatory audit trails.']
  capa_id varchar [note: 'Foreign key linking to quality.capa. Business justification: A batch release may be conditioned on or associated with a CAPA when deviations are found during batch review. batch_release.capa_required_flag (BOOLEAN) indicates a CAPA is needed, but the FK to capa']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Batch release activities (QP certification, lab testing, QA sign-off) incur costs charged to the QA/QC cost center. In regulated consumer goods (OTC, personal care), batch release cost tracking by cos']
  distribution_facility_id varchar [note: 'Foreign key linking to distribution.distribution_facility. Business justification: Batch release decisions are scoped to the distribution facility from which the batch will be dispatched. Regulatory market traceability and OTIF compliance reporting require linking each batch release']
  formulation_id varchar [note: 'Foreign key linking to product.product_formulation. Business justification: GMP batch release requires verifying the batch was produced against the approved formulation version. This FK enables batch record review to confirm formulation compliance, supporting QP certification']
  goods_receipt_id varchar [note: 'Foreign key linking to procurement.goods_receipt. Business justification: In consumer goods (food, personal care, OTC), batch release for incoming raw materials/packaging is triggered post-goods-receipt. Linking batch_release to goods_receipt enables end-to-end traceability']
  inspection_lot_id varchar [note: 'Attribute inspection_lot_id of quality.batch_release.']
  logistics_shipment_id varchar [note: 'Foreign key linking to logistics.logistics_shipment. Business justification: GMP batch release decisions govern whether an outbound shipment can proceed. QA and logistics teams use this link for batch-release-to-shipment traceability reports, regulatory audits, and shipment ho']
  marketing_brand_id varchar [note: 'Foreign key linking to marketing.marketing_brand. Business justification: Batch release decisions are brand-specific in consumer goods — QA releases product by brand for market launch timing, regulatory market clearance, and brand-level quality KPI reporting. Brand teams tr']
  packaging_spec_id varchar [note: 'Foreign key linking to product.product_packaging_spec. Business justification: GMP batch release requires confirming the packaging used matches the approved packaging specification. This FK enables batch record review to verify correct packaging was used, supporting GMP complian']
  primary_batch_release_certificate_of_analysis_id varchar [note: 'Foreign key linking to quality.certificate_of_analysis. Business justification: Link batch_release to the Certificate of Analysis that documents the released batch, removing redundant reference number.']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: Batch release is the quality disposition of a production order\'s output. Release reports in consumer goods directly reference production order numbers for regulatory submissions and customer COA reque']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Batch release reports require linking each release to the specific SKU for traceability, regulatory filing, and inventory reconciliation.']
  usage_decision_id varchar [note: 'Foreign key linking to quality.usage_decision. Business justification: A batch release decision is the formal QP-level authorization that follows the usage decision on the inspection lot. Linking batch_release directly to usage_decision enables traceability from the rele']
  amount decimal(18,4) [note: 'Attribute amount of quality.batch_release.']
  audit_trail_reference varchar [note: 'Reference to the complete audit trail log for all actions and approvals related to this batch release. Required for 21 CFR Part 11 compliance.']
  batch_number varchar [note: 'Attribute batch_number of quality.batch_release.']
  batch_release_status varchar [note: 'Attribute status of quality.batch_release.']
  batch_size_quantity decimal(18,3) [note: 'Total quantity of finished goods produced in this batch. Used for yield calculation and inventory planning.']
  batch_size_uom varchar [note: 'Unit of measure for the batch size quantity (e.g., kilograms, liters, units). Aligns with GS1 standards for trade item measurement. [ENUM-REF-CANDIDATE: kg|lbs|liters|gallons|units|cases|pallets — 7 candidates stripped; promote to reference product]']
  capa_required_flag boolean [note: 'Boolean flag indicating whether a CAPA investigation is required based on deviations or non-conformances identified during batch production or testing.']
  code varchar [note: 'Attribute code of quality.batch_release.']
  comments varchar [note: 'Comments value for the Batch Release record.']
  created_timestamp timestamp [note: 'Timestamp when the batch release record was first created in the system. Part of audit trail for regulatory compliance.']
  currency_code varchar [note: 'Attribute currency_code of quality.batch_release.']
  data_quality_score decimal(5,2) [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  description varchar [note: 'Attribute description of quality.batch_release.']
  deviation_count varchar [note: 'Number of manufacturing or quality deviations recorded during the production and testing of this batch. Used for quality trend analysis.']
  effective_from date [note: 'Attribute effective_from of quality.batch_release.']
  effective_until date [note: 'Attribute effective_until of quality.batch_release.']
  expiry_date date [note: 'Date after which the batch should not be sold or used. Calculated from production date plus shelf life. Critical for FEFO inventory management and regulatory compliance.']
  gmp_compliance_flag boolean [note: 'Boolean flag indicating whether the batch was manufactured in full compliance with GMP requirements. False indicates deviation or non-conformance.']
  gmp_compliant boolean [note: 'Attribute gmp_compliant of quality.batch_release.']
  hold_initiated_date date [note: 'Date when the regulatory or business hold was placed on the batch. Nullable if no hold exists.']
  hold_reason varchar [note: 'Detailed explanation of why the batch is on hold, if applicable. Includes regulatory citation, investigation reference, or customer complaint number.']
  is_active boolean [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  last_modified_timestamp timestamp [note: 'Timestamp when the batch release record was last updated. Tracks changes to release status, hold status, or other critical fields.']
  manufacture_date date [note: 'Attribute manufacture_date of quality.batch_release.']
  manufacturing_site_code varchar [note: 'Code identifying the manufacturing facility or plant where the batch was produced. Used for site-level quality tracking and regulatory reporting.']
  name varchar [note: 'Attribute name of quality.batch_release.']
  notes varchar [note: 'Attribute notes of quality.batch_release.']
  product_registration_number varchar [note: 'Regulatory registration or approval number for the product in the target market. Required for FDA NDC, EU product registration, or equivalent.']
  production_date date [note: 'Date when the batch manufacturing was completed. Critical for shelf-life calculation and FEFO inventory management.']
  qa_signoff_flag boolean [note: 'Boolean indicator for Qa Signoff Flag.']
  qc_inspection_status varchar [note: 'Overall status of QC inspection and testing for this batch. Summarizes results from multiple QC test records.']
  qp_certification_flag boolean [note: 'Boolean indicator for Qp Certification Flag.']
  qp_signature varchar [note: 'Attribute qp_signature of quality.batch_release.']
  qp_signature_timestamp timestamp [note: 'Timestamp when the Qualified Person electronically signed the batch release decision. Part of 21 CFR Part 11 electronic signature compliance.']
  qualified_person_name varchar [note: 'Full name of the Qualified Person who signed off on the batch release. Required for regulatory audit trail.']
  quantity decimal(18,4) [note: 'Attribute quantity of quality.batch_release.']
  record_source_system varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  regulatory_hold_status varchar [note: 'Indicates if the batch is under any regulatory or business hold that prevents distribution. Holds may be imposed by FDA, EPA, internal quality, customer complaint, or recall investigation.']
  regulatory_market varchar [note: 'Primary regulatory market or jurisdiction for which this batch was released. Different markets may have different release requirements and QP sign-off rules. [ENUM-REF-CANDIDATE: USA|CAN|MEX|GBR|DEU|FRA|ITA|ESP|CHN|JPN|AUS|BRA|IND — 13 candidates stripped; promote to reference product]']
  rejected_quantity decimal(18,3) [note: 'Quantity of the batch that was rejected and marked for destruction or rework. Part of quality yield tracking.']
  release_date date [note: 'Date when the batch was officially released for distribution and sale. Marks the point at which product becomes available to promise (ATP).']
  release_decision varchar [note: 'Final disposition decision for the batch: released for distribution, rejected for destruction, quarantine for further testing, conditional release with restrictions, pending review, or on hold pending investigation. Critical GMP control point.']
  release_notes varchar [note: 'Free-text notes and comments from the Qualified Person regarding the release decision. May include justification for conditional release or special handling instructions.']
  release_number varchar [note: 'Release Number value for the Batch Release record.']
  release_quantity decimal(18,4) [note: 'Attribute release_quantity of quality.batch_release.']
  release_status varchar [note: 'Release Status value for the Batch Release record.']
  release_timestamp timestamp [note: 'Precise timestamp when the batch release decision was recorded in the system. Used for audit trail and regulatory compliance.']
  released_quantity decimal(18,3) [note: 'Quantity of the batch that was approved for release and distribution. May be less than batch size if partial rejection occurred.']
  retest_date date [note: 'Date when the batch must be retested to confirm continued quality and stability. Common for raw materials and intermediates.']
  sap_qm_inspection_lot varchar [note: 'SAP QM inspection lot number associated with this batch release. Links to SAP S/4HANA QM module for detailed inspection results and usage decisions.']
  source_record_code varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  source_system_code varchar [note: 'Source System Code value for the Batch Release record.']
  stability_study_reference varchar [note: 'Reference number linking to the stability study protocol and results that support the assigned shelf life and expiry date for this batch.']
  uom varchar [note: 'Attribute uom of quality.batch_release.']
  updated_timestamp timestamp [note: 'Attribute updated_timestamp of quality.batch_release.']
  valid_from_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  valid_to_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  veeva_vault_document_reference varchar [note: 'Document identifier in Veeva Vault system linking to the official batch release record and supporting quality documents. Integrates with Veeva Vault QMS.']

  Note: 'Quality decision record authorizing the release, hold, or rejection of a manufactured batch, including QP certification and disposition.'
}

Table quality.certificate_of_analysis {
  certificate_of_analysis_id varchar [pk, note: 'Unique identifier for the certificate of analysis record. Primary key.']
  goods_receipt_id varchar [note: 'Foreign key linking to procurement.goods_receipt. Business justification: COAs accompany incoming shipments and are matched to goods receipts during incoming inspection. goods_receipt has certificate_of_analysis_received_flag (denormalized). Linking COA to goods_receipt ena']
  inspection_lot_id varchar [note: 'Attribute inspection_lot_id of quality.certificate_of_analysis.']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: Supplier CoA management for raw/packaging materials requires linking each CoA to the material master for incoming inspection validation and material release decisions. Standard SAP QM incoming goods p']
  sku_id varchar [note: 'Sku Id referencing product.sku.sku_id.']
  specification_id varchar [note: 'Foreign key linking to quality.specification. Business justification: A Certificate of Analysis documents test results evaluated against a specific quality specification. The FK to specification normalizes the relationship and enables direct retrieval of acceptance crit']
  supplier_id varchar [note: 'Foreign key linking to procurement.supplier. Business justification: COA must reference the supplier of the batch for traceability and regulatory compliance; supplier_name is replaced by FK.']
  supplier_site_id varchar [note: 'Foreign key linking to procurement.supplier_site. Business justification: COAs identify the supplier manufacturing/testing site that produced and tested the batch. certificate_of_analysis has denormalized manufacturing_site_code and manufacturing_site_name; replacing with s']
  amount decimal(18,4) [note: 'Attribute amount of quality.certificate_of_analysis.']
  approval_timestamp timestamp [note: 'Date and time when the certificate was officially approved by the authorized signatory. Represents the moment of quality release decision.']
  approved_flag boolean [note: 'Boolean indicator for Approved Flag.']
  authorized_signatory_name varchar [note: 'Full name of the quality assurance professional authorized to approve and sign this certificate. Must have appropriate delegation of authority.']
  authorized_signatory_title varchar [note: 'Job title or role of the authorized signatory (e.g., QA Manager, Quality Director, Laboratory Supervisor).']
  batch_number varchar [note: 'The manufacturing batch or lot number for the material being certified. Critical for traceability and recall management.']
  batch_size decimal(18,3) [note: 'Total quantity produced in the manufacturing batch. Used to assess sample representativeness and for statistical quality control.']
  batch_size_uom varchar [note: 'Unit of measure for the batch size. Typically matches the material\'s production UOM.']
  certificate_number varchar [note: 'Externally-known unique certificate number assigned to this CoA document. Used for customer communication and regulatory submissions.']
  certificate_of_analysis_status varchar [note: 'Attribute status of quality.certificate_of_analysis.']
  certificate_type varchar [note: 'Classification of the certificate based on the material type being certified. Determines applicable test parameters and regulatory requirements.']
  coa_number varchar [note: 'Coa Number value for the Certificate Of Analysis record.']
  coa_status varchar [note: 'Coa Status value for the Certificate Of Analysis record.']
  code varchar [note: 'Attribute code of quality.certificate_of_analysis.']
  compliance_statement varchar [note: 'Attribute compliance_statement of quality.certificate_of_analysis.']
  created_timestamp timestamp [note: 'Date and time when this certificate record was first created in the system. Audit trail for record lifecycle.']
  currency_code varchar [note: 'Attribute currency_code of quality.certificate_of_analysis.']
  customer_facing_flag boolean [note: 'Indicates whether this certificate is intended for external distribution to trade customers or is for internal use only. True if customer-facing.']
  customer_name varchar [note: 'Customer Name value for the Certificate Of Analysis record.']
  data_quality_score decimal(5,2) [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  description varchar [note: 'Attribute description of quality.certificate_of_analysis.']
  document_reference varchar [note: 'Document Reference value for the Certificate Of Analysis record.']
  document_url varchar [note: 'URL or file path to the digitally signed PDF or scanned image of the certificate stored in Veeva Vault or document management system.']
  effective_from date [note: 'Attribute effective_from of quality.certificate_of_analysis.']
  effective_until date [note: 'Attribute effective_until of quality.certificate_of_analysis.']
  expiry_date date [note: 'The date after which the material should not be used or sold. Based on stability studies and regulatory requirements.']
  gmp_compliant_flag boolean [note: 'Indicates whether the batch and testing process were conducted under GMP conditions. True if GMP-compliant.']
  is_active boolean [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  issue_date date [note: 'The date on which this certificate of analysis was officially issued and authorized for distribution to customers or regulatory bodies.']
  last_modified_timestamp timestamp [note: 'Date/time of Last Modified Timestamp.']
  lot_number varchar [note: 'Lot Number value for the Certificate Of Analysis record.']
  manufacture_date date [note: 'Date/time of Manufacture Date.']
  manufacturing_date date [note: 'The date on which the batch was manufactured or produced. Used for shelf-life calculations and FEFO inventory management.']
  modified_timestamp timestamp [note: 'Date and time when this certificate record was last modified. Supports change tracking and audit compliance.']
  name varchar [note: 'Attribute name of quality.certificate_of_analysis.']
  notes varchar [note: 'Attribute notes of quality.certificate_of_analysis.']
  overall_result varchar [note: 'Overall Result value for the Certificate Of Analysis record.']
  overall_result_status varchar [note: 'Aggregate pass/fail status for all test parameters on this certificate. Determines batch release decision and customer distribution eligibility.']
  quantity decimal(18,4) [note: 'Attribute quantity of quality.certificate_of_analysis.']
  quantity_tested decimal(18,3) [note: 'The quantity of material sampled and tested for this certificate. Expressed in the material\'s base unit of measure.']
  quantity_tested_uom varchar [note: 'Unit of measure for the quantity tested (e.g., kilograms, liters, units). Aligns with material master UOM.']
  record_source_system varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  regulatory_submission_flag boolean [note: 'Indicates whether this certificate is required for regulatory submissions or compliance filings with FDA, EPA, or other governing bodies. True if required for submission.']
  remarks varchar [note: 'Free-text field for additional notes, observations, or special conditions related to the testing or batch. May include deviations or special handling instructions.']
  retest_date date [note: 'The date by which the material should be retested to confirm continued conformance to specifications. Applicable primarily to raw materials.']
  source_record_code varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  source_system_code varchar [note: 'Source System Code value for the Certificate Of Analysis record.']
  storage_condition varchar [note: 'Recommended storage conditions for the material (e.g., store in cool dry place, refrigerate at 2-8°C, protect from light). Based on stability data.']
  supplier_lot_number varchar [note: 'The lot or batch number assigned by the supplier for raw materials or packaging materials. Used for supplier quality traceability.']
  test_date date [note: 'The date on which quality control testing was performed for this certificate. May differ from manufacturing date for retained samples.']
  test_method_reference varchar [note: 'Reference to the analytical test methods used (e.g., USP, ASTM, internal method codes). May be a comma-separated list for multiple methods.']
  uom varchar [note: 'Attribute uom of quality.certificate_of_analysis.']
  updated_timestamp timestamp [note: 'Attribute updated_timestamp of quality.certificate_of_analysis.']
  valid_from_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  valid_to_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  veeva_vault_document_reference varchar [note: 'Unique document identifier in Veeva Vault system where the certificate is stored. Enables integration with regulatory document management.']

  Note: 'Authoritative certificate documenting test results and specification conformance for a manufactured or supplied lot.'
}

Table quality.product_complaint {
  product_complaint_id varchar [pk, note: 'Unique identifier for the product complaint record. Primary key.']
  certificate_of_analysis_id varchar [note: 'Foreign key linking to quality.certificate_of_analysis. Business justification: During product complaint investigation, QA retrieves the Certificate of Analysis for the implicated batch to verify test results and specification conformance. This FK enables direct traceability from']
  label_spec_id varchar [note: 'Foreign key linking to product.label_spec. Business justification: Regulatory reporting for labeling complaints (missing allergen warnings, incorrect ingredient declarations) requires linking complaints to the specific label specification version. Supports label reca']
  marketing_brand_id varchar [note: 'Foreign key linking to marketing.brand. Business justification: Brand Complaint Dashboard requires linking complaints to the brand to monitor reputation and adjust campaigns.']
  order_id varchar [note: 'Foreign key linking to sales.order. Business justification: CPG complaint investigations require tracing the specific sales order that delivered the complained-about product to identify shipment date, lot, and distribution path. The \'complaint investigation\' p']
  outbound_order_line_id varchar [note: 'Foreign key linking to distribution.outbound_order_line. Business justification: Required for complaint traceability: product complaint must reference the outbound order line that delivered the product, allowing root cause analysis and customer service reporting.']
  retail_store_id varchar [note: 'Foreign key linking to sales.retail_store. Business justification: Store‑level complaint tracking required for quality investigations and performance dashboards; linking complaints to the retail store where purchase occurred is standard in consumer‑goods.']
  shopper_id varchar [note: 'Foreign key linking to consumer.shopper. Business justification: Complaint handling process requires linking each product complaint to the shopper who reported it for traceability and regulatory reporting.']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Complaints are investigated per SKU; linking enables root‑cause analysis, corrective actions, and compliance reporting.']
  supplier_id varchar [note: 'Foreign key linking to procurement.supplier. Business justification: Complaints must be tied to the responsible supplier for performance monitoring and regulatory reporting.']
  trade_account_id varchar [note: 'Identifier of the retail or trade account where the product was purchased, if applicable.']
  amount decimal(18,4) [note: 'Attribute amount of quality.product_complaint.']
  batch_number varchar [note: 'Attribute batch_number of quality.product_complaint.']
  closed_date date [note: 'Date/time of Closed Date.']
  closure_date date [note: 'Attribute closure_date of quality.product_complaint.']
  code varchar [note: 'Attribute code of quality.product_complaint.']
  complainant_address varchar [note: 'Mailing address of the complainant for correspondence and product sample return.']
  complainant_contact varchar [note: 'Attribute complainant_contact of quality.product_complaint.']
  complainant_country_code varchar [note: 'Three-letter ISO country code of the complainant location.']
  complainant_email varchar [note: 'Email address of the complainant for follow-up communication.']
  complainant_name varchar [note: 'Full name of the individual or organization filing the complaint.']
  complainant_phone varchar [note: 'Contact phone number of the complainant.']
  complaint_category varchar [note: 'Primary classification of the complaint type based on the nature of the quality issue reported.']
  complaint_description varchar [note: 'Detailed narrative description of the complaint as reported by the complainant, including symptoms, observations, and circumstances.']
  complaint_number varchar [note: 'Externally-visible unique complaint reference number used for tracking and communication with consumers and regulatory bodies.']
  complaint_received_timestamp timestamp [note: 'Date and time when the complaint was first received by the organization.']
  complaint_source varchar [note: 'Origin channel through which the complaint was received.']
  complaint_status varchar [note: 'Current lifecycle state of the complaint investigation and resolution process.']
  complaint_subcategory varchar [note: 'Detailed sub-classification providing additional granularity to the complaint category.']
  complaint_type varchar [note: 'Complaint Type value for the Product Complaint record.']
  corrective_action varchar [note: 'Description of corrective actions taken to address the immediate complaint.']
  created_timestamp timestamp [note: 'Timestamp when the complaint record was first created in the system.']
  currency_code varchar [note: 'Attribute currency_code of quality.product_complaint.']
  data_quality_score decimal(5,2) [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  description varchar [note: 'Description value for the Product Complaint record.']
  effective_from date [note: 'Attribute effective_from of quality.product_complaint.']
  effective_until date [note: 'Attribute effective_until of quality.product_complaint.']
  expiry_date date [note: 'Product expiration or best-before date printed on the package.']
  gtin varchar [note: 'Global Trade Item Number uniquely identifying the product in the supply chain.']
  incident_date date [note: 'Date when the consumer or customer experienced the quality issue or adverse event.']
  investigation_completion_date date [note: 'Date when the investigation was concluded and findings documented.']
  investigation_outcome varchar [note: 'Attribute investigation_outcome of quality.product_complaint.']
  investigation_start_date date [note: 'Date when the formal investigation of the complaint was initiated.']
  investigation_status varchar [note: 'Current state of the internal quality investigation process.']
  investigation_summary varchar [note: 'Attribute investigation_summary of quality.product_complaint.']
  is_active boolean [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  is_adverse_event boolean [note: 'Boolean indicator for Is Adverse Event.']
  is_reportable boolean [note: 'Attribute is_reportable of quality.product_complaint.']
  lab_analysis_result varchar [note: 'Summary of laboratory test results conducted on the returned product sample.']
  last_modified_timestamp timestamp [note: 'Timestamp when the complaint record was last updated.']
  lot_number varchar [note: 'Lot Number value for the Product Complaint record.']
  manufacturing_date date [note: 'Date when the product batch was manufactured.']
  name varchar [note: 'Attribute name of quality.product_complaint.']
  notes varchar [note: 'Attribute notes of quality.product_complaint.']
  preventive_action varchar [note: 'Description of preventive actions implemented to prevent recurrence of similar issues.']
  priority varchar [note: 'Attribute priority of quality.product_complaint.']
  product_complaint_status varchar [note: 'Attribute status of quality.product_complaint.']
  product_name varchar [note: 'Attribute product_name of quality.product_complaint.']
  purchase_date date [note: 'Date when the complainant purchased the product.']
  quantity decimal(18,4) [note: 'Attribute quantity of quality.product_complaint.']
  received_date date [note: 'Date/time of Received Date.']
  record_source_system varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  regulatory_agency varchar [note: 'Name of the regulatory agency to which the complaint was reported (e.g., FDA, EPA, CPSC).']
  regulatory_case_number varchar [note: 'Case or reference number assigned by the regulatory agency for tracking purposes.']
  regulatory_report_date date [note: 'Date when the complaint was reported to the relevant regulatory authority.']
  regulatory_reportable boolean [note: 'Boolean indicator for Regulatory Reportable.']
  regulatory_reportable_flag boolean [note: 'Indicates whether this complaint must be reported to regulatory authorities such as FDA, EPA, or CPSC.']
  resolution varchar [note: 'Resolution value for the Product Complaint record.']
  resolution_date date [note: 'Date when the complaint was resolved and closed.']
  resolution_outcome varchar [note: 'Final outcome or action taken to resolve the complaint with the complainant.']
  root_cause varchar [note: 'Identified root cause of the quality issue based on investigation findings.']
  sample_received_date date [note: 'Date when the returned product sample was received by the quality assurance team.']
  sample_returned_flag boolean [note: 'Indicates whether the complainant returned a physical product sample for laboratory analysis.']
  severity varchar [note: 'Severity value for the Product Complaint record.']
  severity_level varchar [note: 'Risk classification indicating the potential impact to consumer safety and business reputation.']
  source_record_code varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  source_system_code varchar [note: 'Source System Code value for the Product Complaint record.']
  uom varchar [note: 'Attribute uom of quality.product_complaint.']
  updated_timestamp timestamp [note: 'Attribute updated_timestamp of quality.product_complaint.']
  valid_from_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  valid_to_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']

  Note: 'Consumer or customer product complaint record with investigation, classification, and regulatory reportability tracking.'
}

Table quality.specification {
  specification_id varchar [pk, note: 'Unique identifier for the quality specification record. Primary key for this entity.']
  approved_supplier_list_id varchar [note: 'Foreign key linking to procurement.approved_supplier_list. Business justification: Supplier qualification requires documenting which material specification the supplier was qualified against. The ASL entry references the approved specification version. Linking specification to ASL e']
  formulation_id varchar [note: 'Attribute product_formulation_id of product.specification.']
  inspection_plan_id varchar [note: 'Reference to the SAP QM inspection plan that uses this specification. Links specification to operational quality control procedures.']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: Raw material and packaging material quality specifications must reference the material master to drive incoming inspection plans and CoA validation. specification has sku_id FKs for finished goods but']
  specification_material_sku_id varchar [note: 'Reference to the material or product this specification applies to. Links to the master material record in SAP MM.']
  specification_sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Quality specifications are defined per SKU to ensure manufacturing compliance and product release criteria.']
  superseded_by_specification_id varchar [note: 'Reference to the newer specification that replaces this one when status is superseded. Maintains specification version lineage.']
  amount decimal(18,4) [note: 'Attribute amount of quality.specification.']
  approval_date date [note: 'Date when this specification was formally approved for use. Part of the specification lifecycle audit trail.']
  category varchar [note: 'High-level classification of the type of quality attribute being specified. Groups related test characteristics for reporting and analysis.']
  coa_inclusion_flag boolean [note: 'Indicates whether test results for this specification must be included on the Certificate of Analysis provided to customers. Drives CoA generation logic.']
  code varchar [note: 'Attribute code of quality.specification.']
  created_timestamp timestamp [note: 'Date and time when this specification record was first created in the system. Part of the audit trail for compliance and traceability.']
  critical_quality_attribute_flag boolean [note: 'Indicates whether this characteristic is a Critical Quality Attribute that directly impacts product safety, efficacy, or regulatory compliance. CQAs require enhanced controls and documentation.']
  currency_code varchar [note: 'Attribute currency_code of quality.specification.']
  customer_requirement_flag boolean [note: 'Indicates whether this specification is driven by specific customer contractual requirements rather than internal or regulatory standards.']
  data_quality_score decimal(5,2) [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  description varchar [note: 'Attribute description of quality.specification.']
  effective_date date [note: 'Date/time of Effective Date.']
  effective_end_date date [note: 'The date after which this specification is no longer valid. Null indicates an open-ended specification. Used for specification versioning and supersession.']
  effective_from date [note: 'Attribute effective_from of quality.specification.']
  effective_start_date date [note: 'The date from which this specification becomes valid and must be used for quality control testing. Supports time-based specification management.']
  effective_until date [note: 'Attribute effective_until of quality.specification.']
  expiry_date date [note: 'Date/time of Expiry Date.']
  is_active boolean [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  last_modified_timestamp timestamp [note: 'Date and time when this specification record was last updated. Tracks change history for audit and compliance purposes.']
  lower_limit decimal(18,6) [note: 'Lower Limit value for the Specification record.']
  lower_spec_limit decimal(18,6) [note: 'Attribute lower_spec_limit of quality.specification.']
  lower_specification_limit decimal(18,6) [note: 'The minimum acceptable value for the test characteristic. Results below this limit indicate non-conformance.']
  material_type varchar [note: 'Attribute material_type of quality.specification.']
  name varchar [note: 'Attribute name of quality.specification.']
  next_review_date date [note: 'Scheduled date for the next periodic review of this specification. Used for compliance tracking and specification maintenance planning.']
  notes varchar [note: 'Additional context, special instructions, or clarifications related to this specification. May include testing conditions, sample preparation requirements, or interpretation guidance.']
  parameter_name varchar [note: 'Parameter Name value for the Specification record.']
  quantity decimal(18,4) [note: 'Attribute quantity of quality.specification.']
  record_source_system varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  regulatory_basis varchar [note: 'Regulatory Basis value for the Specification record.']
  review_frequency_months varchar [note: 'How often this specification must be reviewed and revalidated, expressed in months. Ensures specifications remain current and appropriate.']
  revision_number varchar [note: 'Attribute revision_number of quality.specification.']
  sampling_plan varchar [note: 'Description of the sampling methodology and sample size requirements for this test (e.g., AQL 2.5, n=10, ANSI/ASQ Z1.4). Ensures statistical validity of test results.']
  source_record_code varchar [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  source_system_code varchar [note: 'Source System Code value for the Specification record.']
  spec_category varchar [note: 'Attribute spec_category of quality.specification.']
  spec_code varchar [note: 'Spec Code value for the Specification record.']
  spec_name varchar [note: 'Spec Name value for the Specification record.']
  spec_number varchar [note: 'Attribute spec_number of quality.specification.']
  spec_status varchar [note: 'Spec Status value for the Specification record.']
  spec_type varchar [note: 'Spec Type value for the Specification record.']
  specification_number varchar [note: 'Business identifier for the quality specification, used for external reference and documentation. Unique across the organization.']
  specification_status varchar [note: 'Current lifecycle status of the specification. Only active specifications are used for quality control and Certificate of Analysis (CoA) generation.']
  specification_type varchar [note: 'Classification of the specification based on the material or product stage it applies to. Determines the applicable quality control procedures.']
  stability_indicating_flag boolean [note: 'Indicates whether this test characteristic is used in stability studies to monitor product degradation over time. Critical for shelf-life determination.']
  target_value decimal(18,6) [note: 'The ideal or nominal value for the test characteristic. Represents the center point of the acceptable range.']
  test_characteristic varchar [note: 'The specific quality attribute or property being measured or tested (e.g., pH, viscosity, color, weight, purity, microbial count). Defines what is being inspected.']
  test_equipment_required varchar [note: 'Description of specialized equipment or instrumentation needed to perform this test (e.g., HPLC, spectrophotometer, viscometer). Supports resource planning and capability assessment.']
  test_frequency varchar [note: 'How often this test characteristic must be measured during production or quality control. Drives inspection plan scheduling. [ENUM-REF-CANDIDATE: per_batch|per_lot|hourly|daily|weekly|monthly|on_demand — 7 candidates stripped; promote to reference product]']
  test_method varchar [note: 'Test Method value for the Specification record.']
  test_method_reference varchar [note: 'Reference to the standard test method or procedure used to measure the characteristic (e.g., ASTM D1475, USP 621, internal SOP number). Ensures consistent testing methodology.']
  unit_of_measure varchar [note: 'The unit in which the test characteristic is measured (e.g., mg/L, %, pH units, cP, CFU/g). Critical for interpreting specification limits.']
  uom varchar [note: 'Uom value for the Specification record.']
  updated_timestamp timestamp [note: 'Attribute updated_timestamp of quality.specification.']
  upper_limit decimal(18,6) [note: 'Upper Limit value for the Specification record.']
  upper_spec_limit decimal(18,6) [note: 'Attribute upper_spec_limit of quality.specification.']
  upper_specification_limit decimal(18,6) [note: 'The maximum acceptable value for the test characteristic. Results above this limit indicate non-conformance.']
  valid_from_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  valid_to_timestamp timestamp [note: 'Governance/lineage metadata added in v2 rebuild for ECM/MVM completeness.']
  veeva_vault_document_reference varchar [note: 'Reference to the controlled document in Veeva Vault that contains the full specification details and supporting documentation. Ensures document control and regulatory compliance.']
  version varchar [note: 'Version number of the specification to track revisions and changes over time. Follows major.minor versioning convention.']
  version_number varchar [note: 'Version Number value for the Specification record.']

  Note: 'Authoritative quality specification defining acceptance criteria, methods, and limits for a material or product characteristic.'
}

Table distribution.distribution_facility {
  distribution_facility_id varchar [pk, note: 'Primary key for facility']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: Multi-entity consumer goods companies assign each distribution facility to a legal entity for statutory reporting, intercompany billing, and tax compliance. Required for correct GL posting of facility']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Distribution facility operating costs (labor, utilities, maintenance) are allocated to a cost center for overhead reporting and P&L. Consumer goods finance teams require facility-level cost center ass']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Distribution facilities in consumer goods are mapped to profit centers for segment profitability reporting and distribution network P&L. Required for management reporting on distribution cost per prof']
  address_line_1 varchar [note: 'The address line 1 of the distribution facility record']
  amount decimal(18,4) [note: 'The amount of the distribution facility record']
  city varchar [note: 'The city of the distribution facility record']
  closed_date date [note: 'The closed date of the distribution facility record']
  code varchar [note: 'The distribution facility code of the distribution facility record']
  country_code varchar [note: 'The country code of the distribution facility record']
  created_timestamp timestamp [note: 'The created timestamp of the distribution facility record']
  cross_dock_enabled_flag boolean [note: 'The cross dock enabled flag of the distribution facility record']
  currency_code varchar [note: 'The currency code of the distribution facility record']
  dc_code varchar [note: 'The dc code of the distribution facility record']
  dc_name varchar [note: 'The dc name of the distribution facility record']
  description varchar [note: 'The distribution facility description of the distribution facility record']
  distribution_facility_status varchar [note: 'The distribution facility status of the distribution facility record']
  dock_doors_inbound varchar [note: 'The dock doors inbound of the distribution facility record']
  dock_doors_outbound varchar [note: 'The dock doors outbound of the distribution facility record']
  dsd_hub_flag boolean [note: 'The dsd hub flag of the distribution facility record']
  effective_from date [note: 'The effective from of the distribution facility record']
  effective_until date [note: 'The effective until of the distribution facility record']
  facility_code varchar [note: 'The facility code of the distribution facility record']
  facility_name varchar [note: 'The facility name of the distribution facility record']
  facility_type varchar [note: 'The facility type of the distribution facility record']
  gmp_certified_flag boolean [note: 'The gmp certified flag of the distribution facility record']
  hazmat_certified_flag boolean [note: 'The hazmat certified flag of the distribution facility record']
  inventory_rotation_method varchar [note: 'The inventory rotation method of the distribution facility record']
  latitude decimal(10,7) [note: 'The latitude of the distribution facility record']
  longitude decimal(10,7) [note: 'The longitude of the distribution facility record']
  modified_timestamp timestamp [note: 'The modified timestamp of the distribution facility record']
  name varchar [note: 'The distribution facility name of the distribution facility record']
  notes varchar [note: 'The notes of the distribution facility record']
  number_of_dock_doors varchar [note: 'The number of dock doors of the distribution facility record']
  opened_date date [note: 'The opened date of the distribution facility record']
  operational_status varchar [note: 'The operational status of the distribution facility record']
  otif_target_percentage decimal(5,2) [note: 'The otif target percentage of the distribution facility record']
  postal_code varchar [note: 'The postal code of the distribution facility record']
  quantity decimal(18,4) [note: 'The quantity of the distribution facility record']
  sap_plant_code varchar [note: 'The sap plant code of the distribution facility record']
  source_system_code varchar [note: 'The source system code of the distribution facility record']
  square_footage decimal(12,2) [note: 'The square footage of the distribution facility record']
  state_province varchar [note: 'The state province of the distribution facility record']
  storage_capacity_pallet_positions varchar [note: 'The storage capacity pallet positions of the distribution facility record']
  storage_capacity_pallets varchar [note: 'The storage capacity pallets of the distribution facility record']
  supply_network_node_code varchar [note: 'The supply network node id of the distribution facility record']
  temperature_controlled_flag boolean [note: 'The temperature controlled flag of the distribution facility record']
  time_zone varchar [note: 'The time zone of the distribution facility record']
  total_capacity_sqft decimal(12,2) [note: 'The total capacity sqft of the distribution facility record']
  uom varchar [note: 'The uom of the distribution facility record']
  updated_timestamp timestamp [note: 'The updated timestamp of the distribution facility record']
  wms_site_code varchar [note: 'The wms site code of the distribution facility record']

  Note: 'Master record for each physical distribution center (DC) or warehouse facility in the CPG network. Captures DC identity, location, type (ambient, chilled, frozen, DSD hub), capacity metrics, WMS integration identifiers (Blue Yonder site codes), SAP plant/storage location mappings, operating hours, and operational status. SSOT for DC facility master data across the distribution domain. [SSOT: authoritative table is manufacturing.manufacturing_facility; this table is a deprecated duplicate.] [SSOT: authoritative table is manufacturing.manufacturing_facility; this is a deprecated duplicate for concept \'facility\'.] [Non-authoritative; defers to SSOT manufacturing.manufacturing_facility for concept \'facility\'.]'
}

Table distribution.storage_location {
  storage_location_id varchar [pk, note: 'Primary key for storage_location']
  distribution_facility_id varchar [note: 'Identifier of the parent distribution center facility where this storage location resides.']
  abc_classification varchar [note: 'The abc classification of the distribution storage location record']
  aisle varchar [note: 'The aisle of the distribution storage location record']
  amount decimal(18,4) [note: 'The amount of the distribution storage location record']
  bay varchar [note: 'The bay of the distribution storage location record']
  bin_code varchar [note: 'The bin code of the distribution storage location record']
  bin_position varchar [note: 'The bin position of the distribution storage location record']
  blocked_date date [note: 'The blocked date of the distribution storage location record']
  blocked_reason varchar [note: 'The blocked reason of the distribution storage location record']
  created_timestamp timestamp [note: 'The created timestamp of the distribution storage location record']
  currency_code varchar [note: 'The currency code of the distribution storage location record']
  cycle_count_frequency varchar [note: 'The cycle count frequency of the distribution storage location record']
  distribution_storage_location_code varchar [note: 'The distribution storage location code of the distribution storage location record']
  distribution_storage_location_description varchar [note: 'The distribution storage location description of the distribution storage location record']
  distribution_storage_location_level varchar [note: 'The distribution storage location level of the distribution storage location record']
  distribution_storage_location_name varchar [note: 'The distribution storage location name of the distribution storage location record']
  distribution_storage_location_status varchar [note: 'The distribution storage location status of the distribution storage location record']
  dsd_eligible_flag boolean [note: 'The dsd eligible flag of the distribution storage location record']
  effective_date date [note: 'The effective date of the distribution storage location record']
  effective_from date [note: 'The effective from of the distribution storage location record']
  effective_until date [note: 'The effective until of the distribution storage location record']
  equipment_type_required varchar [note: 'The equipment type required of the distribution storage location record']
  expiration_date date [note: 'The expiration date of the distribution storage location record']
  fefo_eligible_flag boolean [note: 'The fefo eligible flag of the distribution storage location record']
  fifo_eligible_flag boolean [note: 'The fifo eligible flag of the distribution storage location record']
  hazmat_certified_flag boolean [note: 'The hazmat certified flag of the distribution storage location record']
  height_cm decimal(10,2) [note: 'The height cm of the distribution storage location record']
  is_blocked boolean [note: 'The is blocked of the distribution storage location record']
  is_pickable boolean [note: 'The is pickable of the distribution storage location record']
  level_code varchar [note: 'The level code of the distribution storage location record']
  location_code varchar [note: 'The location code of the distribution storage location record']
  location_type varchar [note: 'The location type of the distribution storage location record']
  max_volume_cubic_m decimal(12,3) [note: 'The max volume cubic m of the distribution storage location record']
  max_weight_kg decimal(12,3) [note: 'The max weight kg of the distribution storage location record']
  notes varchar [note: 'The notes of the distribution storage location record']
  quantity decimal(18,4) [note: 'The quantity of the distribution storage location record']
  source_system_code varchar [note: 'The source system code of the distribution storage location record']
  storage_class varchar [note: 'The storage class of the distribution storage location record']
  temperature_zone varchar [note: 'The temperature zone of the distribution storage location record']
  uom varchar [note: 'The uom of the distribution storage location record']
  updated_timestamp timestamp [note: 'The updated timestamp of the distribution storage location record']
  zone_code varchar [note: 'The zone code of the distribution storage location record']

  Note: 'Granular storage location master within a distribution center — aisles, bays, levels, bin positions, and pick faces as defined in Blue Yonder WMS. Tracks location type (bulk, pick, reserve, staging, dock), zone classification, temperature zone, weight/volume capacity, and FEFO/FIFO eligibility flags. Enables put-away and picking optimization at the slot level. [SSOT: authoritative table is inventory.inventory_storage_location; this table is a deprecated duplicate.] [SSOT: authoritative table is inventory.inventory_storage_location; this is a deprecated duplicate for concept \'storage_location\'.] [Non-authoritative; defers to SSOT inventory.inventory_storage_location for concept \'storage_location\'.]'
}

Table distribution.inbound_receipt {
  inbound_receipt_id varchar [pk, note: 'Unique identifier for the inbound receipt transaction. Primary key for this entity.']
  carrier_id varchar [note: 'Identifier of the transportation carrier that delivered the shipment to the distribution center.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Receiving operations incur expenses (labor, equipment) that are allocated to a cost center for expense tracking and budgeting.']
  inspection_plan_id varchar [note: 'Foreign key linking to quality.inspection_plan. Business justification: Inbound receipts trigger a specific inspection plan governing AQL level, sampling procedure, and test requirements. The receipt\'s quality_inspection_required_flag and quality_inspection_status fields ']
  logistics_shipment_id varchar [note: 'Foreign key linking to logistics.logistics_shipment. Business justification: Inbound freight audit and carrier performance: consumer goods DC receiving teams match inbound receipts to logistics shipments to validate carrier delivery performance, measure transit time accuracy, ']
  manufacturing_facility_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_facility. Business justification: Internal transfer receipt: inbound receipts from own plants need the source manufacturing facility to track internal logistics and cost allocation.']
  primary_inbound_distribution_facility_id varchar [note: 'Identifier of the distribution center facility where the goods were received.']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: In consumer goods, finished goods transfers from plant to DC are triggered by production orders. The inbound receipt at the DC must reference the originating production order for goods movement tracea']
  replenishment_order_id varchar [note: 'Foreign key linking to supply.supply_replenishment_order. Business justification: DRP-generated replenishment orders are the source documents for DC inbound receipts. DC receiving teams match receipts to replenishment orders for OTIF measurement, discrepancy resolution, and invento']
  return_order_id varchar [note: 'Foreign key linking to sales.return_order. Business justification: Consumer goods reverse logistics: customer return authorizations (return_order) must be matched to physical inbound receipts at the DC for quantity reconciliation, quality inspection disposition, and ']
  supplier_id varchar [note: 'Identifier of the supplier or vendor who shipped the goods, representing the counterparty in this receipt transaction.']
  supplier_site_id varchar [note: 'Foreign key linking to procurement.supplier_site. Business justification: Inbound receipts capture supplier_id but not supplier_site_id, losing site-level granularity needed for quality inspection routing, GMP compliance verification by site, and supplier site OTIF scorecar']
  accepted_quantity decimal(15,3) [note: 'Quantity of goods accepted into inventory after quality inspection, excluding rejected or damaged items.']
  actual_arrival timestamp [note: 'The actual arrival of the inbound receipt record']
  actual_arrival_timestamp timestamp [note: 'The actual arrival timestamp of the inbound receipt record']
  actual_receipt_timestamp timestamp [note: 'Precise date and time when the physical goods arrived and were checked in at the receiving dock, representing the principal business event for this transaction.']
  amount decimal(18,4) [note: 'The amount of the inbound receipt record']
  asn_number varchar [note: 'Reference to the Advanced Shipping Notice document sent by the supplier prior to shipment arrival, enabling pre-receipt planning and dock scheduling.']
  asn_reference varchar [note: 'The asn reference of the inbound receipt record']
  case_count varchar [note: 'Number of cases or cartons received in this inbound shipment.']
  code varchar [note: 'The inbound receipt code of the inbound receipt record']
  container_number varchar [note: 'ISO standard container identifier for ocean freight shipments, following the BIC (Bureau International des Containers) format.']
  created_timestamp timestamp [note: 'Date and time when this receipt record was first created in the system, representing the audit trail start point.']
  currency_code varchar [note: 'The currency code of the inbound receipt record']
  description varchar [note: 'The inbound receipt description of the inbound receipt record']
  discrepancy_flag boolean [note: 'Indicator of whether any discrepancies (quantity, quality, or documentation) were identified during the receiving process.']
  discrepancy_notes varchar [note: 'Free-text description providing additional details about any discrepancies identified during the receiving process.']
  discrepancy_reason varchar [note: 'Classification of the type of discrepancy identified during receiving, used for root cause analysis and supplier performance management.']
  dock_door varchar [note: 'The dock door of the inbound receipt record']
  dock_door_number varchar [note: 'Physical dock door location where the inbound shipment was unloaded, used for labor planning and dock utilization tracking.']
  effective_from date [note: 'The effective from of the inbound receipt record']
  effective_until date [note: 'The effective until of the inbound receipt record']
  expected_arrival_timestamp timestamp [note: 'The expected arrival timestamp of the inbound receipt record']
  expected_quantity decimal(15,3) [note: 'Total quantity of goods expected to be received based on the ASN or purchase order, used for discrepancy detection.']
  goods_receipt_document_number varchar [note: 'SAP Material Management (MM) goods receipt document number generated upon posting the receipt to inventory, linking WMS to ERP.']
  inbound_receipt_status varchar [note: 'The inbound receipt status of the inbound receipt record']
  last_modified_timestamp timestamp [note: 'Date and time when this receipt record was last updated, supporting audit trail and data lineage requirements.']
  name varchar [note: 'The inbound receipt name of the inbound receipt record']
  notes varchar [note: 'The notes of the inbound receipt record']
  otif_compliant_flag boolean [note: 'Indicator of whether this receipt met both on-time delivery and complete quantity requirements, key supplier performance metric.']
  pallet_count varchar [note: 'Number of pallets received in this inbound shipment, used for dock capacity planning and labor allocation.']
  putaway_completion_timestamp timestamp [note: 'Date and time when all received goods were moved from the receiving dock to their designated storage locations, completing the inbound process.']
  quality_inspection_required_flag boolean [note: 'Indicator of whether formal quality inspection was required for this receipt based on product category, supplier risk profile, or regulatory requirements.']
  quality_inspection_status varchar [note: 'Current status of the quality inspection process for this receipt, tracking progression through quality control workflow.']
  quantity decimal(18,4) [note: 'The quantity of the inbound receipt record']
  receipt_completed_timestamp timestamp [note: 'The receipt completed timestamp of the inbound receipt record']
  receipt_completion_timestamp timestamp [note: 'Date and time when all receiving activities (unloading, inspection, put-away) were completed and the receipt was closed in the WMS.']
  receipt_date date [note: 'The receipt date of the inbound receipt record']
  receipt_number varchar [note: 'Externally-known business identifier for the inbound receipt, used for tracking and reference across systems and with suppliers.']
  receipt_status varchar [note: 'Current lifecycle status of the inbound receipt transaction, tracking progression from scheduling through completion or exception handling.']
  receipt_type varchar [note: 'Classification of the inbound receipt based on the source and nature of the goods being received.']
  received_quantity decimal(15,3) [note: 'Actual total quantity of goods physically received and counted during the receiving process.']
  rejected_quantity decimal(15,3) [note: 'Quantity of goods rejected during receiving due to quality issues, damage, or non-conformance to specifications.']
  scheduled_arrival timestamp [note: 'The scheduled arrival of the inbound receipt record']
  scheduled_receipt_date date [note: 'Planned date for the inbound shipment to arrive at the distribution center, based on ASN or supplier commitment.']
  seal_intact_flag boolean [note: 'Indicator of whether the security seal was found intact upon arrival, critical for quality control and loss prevention.']
  seal_number varchar [note: 'Security seal identifier applied to the trailer or container, verified upon receipt to ensure shipment integrity and prevent tampering.']
  source_system_code varchar [note: 'The source system code of the inbound receipt record']
  temperature_check_required_flag boolean [note: 'Indicator of whether temperature verification was required for this receipt due to cold chain or temperature-sensitive product requirements.']
  temperature_compliant_flag boolean [note: 'Indicator of whether the recorded temperature was within acceptable range per product specifications and cold chain requirements.']
  temperature_reading_celsius decimal(5,2) [note: 'Actual temperature reading in Celsius recorded during receipt inspection for temperature-sensitive products, critical for cold chain compliance.']
  total_lines varchar [note: 'The total lines of the inbound receipt record']
  total_quantity decimal(18,4) [note: 'The total quantity of the inbound receipt record']
  total_units_received decimal(18,4) [note: 'The total units received of the inbound receipt record']
  trailer_number varchar [note: 'Unique identifier of the trailer or truck that delivered the shipment, used for tracking and carrier performance analysis.']
  unit_of_measure varchar [note: 'Standard unit of measure for the quantities recorded in this receipt (Each, Case, Pallet, Kilogram, Pound, Liter, Gallon). [ENUM-REF-CANDIDATE: EA|CS|PL|EA|KG|LB|LT|GL — 8 candidates stripped; promote to reference product]']
  uom varchar [note: 'The uom of the inbound receipt record']
  updated_timestamp timestamp [note: 'The updated timestamp of the inbound receipt record']

  Note: 'Transactional record capturing the physical receipt of goods at a DC from suppliers, manufacturing plants, or inter-DC transfers. Records ASN reference, carrier, trailer/container ID, dock door, receipt date/time, received quantity by SKU/lot, temperature check results, and discrepancy flags. Integrates with SAP WM goods receipt and Blue Yonder WMS inbound processing. Drives inventory on-hand updates and FEFO/FIFO lot registration.'
}

Table distribution.inbound_receipt_line {
  inbound_receipt_line_id varchar [pk, note: 'Unique identifier for the inbound receipt line. Primary key for this entity.']
  goods_receipt_id varchar [note: 'Foreign key linking to procurement.goods_receipt. Business justification: Line-level linkage between warehouse receiving lines and ERP goods receipt enables line-level 3-way match (PO line → GR → invoice line), critical for invoice discrepancy resolution, quality hold manag']
  inbound_receipt_id varchar [note: 'Reference to the parent inbound receipt header transaction. Links this line to the overall receipt event.']
  label_spec_id varchar [note: 'Foreign key linking to product.label_spec. Business justification: Consumer goods inbound receipt requires label compliance verification — confirming received product labels match the approved label spec for the target market (regulatory statements, ingredient declar']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: Consumer goods DCs receive raw materials and packaging components (not just finished SKUs) from suppliers. Inbound receipt lines for raw material/component receipts must reference the material master ']
  packaging_spec_id varchar [note: 'Foreign key linking to product.product_packaging_spec. Business justification: Consumer goods inbound receipt process requires packaging compliance verification — warehouse teams confirm received packaging matches the approved spec (dimensions, material, GS1 barcodes, recyclabil']
  po_line_id varchar [note: 'The po line id of the inbound receipt line record']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Link receipt line to SKU master for traceability and quality inspection; required by receipt processing and compliance audit reports.']
  specification_id varchar [note: 'Foreign key linking to quality.specification. Business justification: Each inbound receipt line is inspected against a product specification (physical, chemical, or microbiological). Linking receipt lines to specifications enables automated pass/fail evaluation during r']
  storage_location_id varchar [note: 'Foreign key linking to distribution.distribution_storage_location. Business justification: When goods are received at a DC, each receipt line is put away to a specific storage location (bin/bay/aisle). The inbound_receipt_line already tracks putaway_status and put_away_timestamp, confirming']
  supplier_id varchar [note: 'Reference to the supplier or vendor who shipped the goods. Used for supplier performance tracking and procurement analytics.']
  amount decimal(18,4) [note: 'The amount of the inbound receipt line record']
  asn_line_number varchar [note: 'Line number within the ASN document corresponding to this receipt line. Enables automated matching between ASN and physical receipt.']
  asn_number varchar [note: 'Advanced Shipping Notice document number sent by the supplier prior to shipment arrival. Used for pre-receipt planning and variance detection.']
  code varchar [note: 'The inbound receipt line code of the inbound receipt line record']
  condition_code varchar [note: 'Quality condition assessment of the received goods. Determines whether product can be put away into available inventory or requires special handling.']
  created_timestamp timestamp [note: 'Date and time when this receipt line record was first created in the warehouse management system. Audit trail for data lineage.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the unit cost and extended cost. Supports multi-currency procurement operations.']
  damage_description varchar [note: 'Free-text description of any damage, defects, or quality issues observed during receipt inspection. Used for claims and supplier performance tracking.']
  damaged_quantity decimal(18,4) [note: 'The damaged quantity of the inbound receipt line record']
  description varchar [note: 'The inbound receipt line description of the inbound receipt line record']
  effective_from date [note: 'The effective from of the inbound receipt line record']
  effective_until date [note: 'The effective until of the inbound receipt line record']
  expected_quantity decimal(18,4) [note: 'The expected quantity of the inbound receipt line record']
  expected_quantity_cases decimal(15,3) [note: 'Expected quantity in cases as specified in the Advanced Shipping Notice (ASN) or purchase order. Used for variance detection.']
  expected_quantity_eaches decimal(15,3) [note: 'Expected quantity in eaches as specified in the Advanced Shipping Notice (ASN) or purchase order. Used for variance detection.']
  expiration_date date [note: 'The expiration date of the inbound receipt line record']
  expiry_date date [note: 'Date when the product expires and can no longer be sold or used. Critical for FEFO rotation and inventory management in consumer goods.']
  extended_cost decimal(18,4) [note: 'Total cost for this receipt line calculated as unit cost multiplied by received quantity. Used for inventory valuation and financial reconciliation.']
  gtin varchar [note: 'Global Trade Item Number uniquely identifying the product in the supply chain. May be GTIN-8, GTIN-12, GTIN-13, or GTIN-14 format.']
  inbound_receipt_line_status varchar [note: 'The inbound receipt line status of the inbound receipt line record']
  inspection_status varchar [note: 'The inspection status of the inbound receipt line record']
  last_modified_timestamp timestamp [note: 'Date and time when this receipt line record was last updated. Audit trail for tracking changes to receipt data.']
  line_number varchar [note: 'Sequential line number within the inbound receipt. Used for ordering and referencing specific lines in the receipt document.']
  line_status varchar [note: 'The line status of the inbound receipt line record']
  lot_number varchar [note: 'Manufacturing lot or batch number assigned by the supplier. Critical for traceability, quality control, and recall management in consumer goods.']
  manufacture_date date [note: 'Date when the product was manufactured by the supplier. Used for shelf-life calculations and FEFO inventory rotation.']
  name varchar [note: 'The inbound receipt line name of the inbound receipt line record']
  notes varchar [note: 'The notes of the inbound receipt line record']
  pallet_code varchar [note: 'Unique identifier for the pallet or handling unit containing this receipt line. Used for put-away and storage location assignment.']
  purchase_order_line_number varchar [note: 'Line number on the purchase order corresponding to this receipt line. Enables three-way matching between PO, receipt, and invoice.']
  purchase_order_number varchar [note: 'Purchase order number authorizing the receipt of these goods. Links the receipt to the original procurement transaction.']
  put_away_timestamp timestamp [note: 'Date and time when the goods were put away into their assigned storage location. Used for warehouse productivity and cycle time measurement.']
  putaway_status varchar [note: 'The putaway status of the inbound receipt line record']
  quality_hold_flag boolean [note: 'The quality hold flag of the inbound receipt line record']
  quality_inspection_required_flag boolean [note: 'Indicates whether this receipt line requires quality inspection before being released to available inventory. True for regulated or high-risk products.']
  quality_inspection_status varchar [note: 'Status of quality inspection for this receipt line. Determines whether goods can be released to available inventory or must remain in quarantine.']
  quantity decimal(18,4) [note: 'The quantity of the inbound receipt line record']
  receipt_status varchar [note: 'Current processing status of this receipt line within the warehouse workflow. Tracks progression from initial receipt through put-away completion.']
  received_quantity decimal(18,4) [note: 'The received quantity of the inbound receipt line record']
  received_quantity_cases decimal(15,3) [note: 'Quantity of product received measured in cases. Represents the outer packaging unit typically used for warehouse handling.']
  received_quantity_eaches decimal(15,3) [note: 'Quantity of product received measured in individual units (eaches). Represents the consumer-facing unit count.']
  received_timestamp timestamp [note: 'Date and time when the goods were physically received at the warehouse dock. Critical for OTIF performance measurement and cycle time analytics.']
  rejected_quantity decimal(18,4) [note: 'The rejected quantity of the inbound receipt line record']
  source_system_code varchar [note: 'The source system code of the inbound receipt line record']
  sscc varchar [note: '18-digit Serial Shipping Container Code identifying the logistics unit. Global standard for tracking pallets and containers in the supply chain.']
  temperature_at_receipt_celsius decimal(5,2) [note: 'Temperature measurement in Celsius recorded at the time of receipt. Critical for cold chain compliance and product quality verification.']
  unit_cost decimal(15,4) [note: 'Cost per unit for the received goods as specified in the purchase order. Used for inventory valuation and COGS calculation.']
  unit_of_measure varchar [note: 'Primary unit of measure for the received quantity. Defines the counting and handling unit for warehouse operations.']
  uom varchar [note: 'The uom of the inbound receipt line record']
  upc varchar [note: 'Universal Product Code barcode identifier for the received item. Standard 12-digit UPC-A format used in North American retail.']
  updated_timestamp timestamp [note: 'The updated timestamp of the inbound receipt line record']
  variance_quantity_cases decimal(15,3) [note: 'Difference between expected and received quantity in cases. Positive values indicate overages, negative values indicate shortages.']
  variance_quantity_eaches decimal(15,3) [note: 'Difference between expected and received quantity in eaches. Positive values indicate overages, negative values indicate shortages.']

  Note: 'Line-level detail for each SKU/lot received within an inbound receipt transaction. Captures SKU code, GTIN, lot number, manufacture date, expiry date, received quantity (cases and eaches), unit of measure, pallet ID, temperature at receipt, and variance from expected ASN quantity. Supports FEFO/FIFO lot registration and discrepancy resolution workflows.'
}

Table distribution.outbound_order {
  outbound_order_id varchar [pk, note: 'Unique identifier for the outbound fulfillment order. Primary key for the outbound order entity.']
  account_address_id varchar [note: 'Foreign key linking to sales.account_address. Business justification: Consumer goods order fulfillment: outbound orders ship to a structured account delivery address for address validation, delivery scheduling, and EDI compliance. outbound_order.ship_to_address and ship']
  carrier_id varchar [note: 'Identifier of the transportation carrier assigned to deliver the outbound order. Used for freight planning, carrier performance tracking, and proof of delivery.']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: Outbound orders in multi-entity consumer goods companies are issued by a specific legal entity, driving revenue recognition, intercompany sales billing, and statutory reporting. Required for correct A']
  freight_order_id varchar [note: 'Foreign key linking to logistics.freight_order. Business justification: Freight order creation for every outbound order manages carrier tendering, freight cost tracking, and audit.']
  primary_outbound_distribution_facility_id varchar [note: 'Identifier of the distribution center fulfilling the outbound order. Determines inventory source and warehouse operations responsible for order execution.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Needed for revenue recognition and profit‑center reporting; each outbound order\'s sales revenue is attributed to a profit center.']
  retail_store_id varchar [note: 'Foreign key linking to sales.retail_store. Business justification: Consumer goods DSD and store replenishment: outbound orders are fulfilled to specific retail stores for OTIF tracking, planogram compliance, and OSA reporting at store level. trade_account_id alone is']
  sales_order_id varchar [note: 'Reference to the originating sales order document in the ERP system. Links outbound fulfillment to revenue recognition and customer order management.']
  sku_id varchar [note: 'FK to product.sku.sku_id — Links distribution outbound orders to product master. Required for product-level fulfillment analytics, category-level DC throughput reporting.']
  trade_account_id varchar [note: 'Identifier of the customer or retail account placing the outbound order. Links to trade account master for customer details, pricing agreements, and delivery preferences.']
  actual_delivery_date date [note: 'Date when the order was actually delivered to the customer destination. Used to calculate OTIF performance and delivery lead time.']
  actual_ship_date date [note: 'Date when the order was actually shipped from the distribution center. Used to measure warehouse execution performance against requested ship date.']
  amount decimal(18,4) [note: 'The amount of the outbound order record']
  backorder_flag boolean [note: 'Indicates whether any line items on the order are backordered due to insufficient inventory. True when ordered quantity exceeds available stock.']
  bill_of_lading_number varchar [note: 'Carrier-issued document number serving as receipt of goods and contract of carriage. Required for freight claims and proof of delivery.']
  cancellation_reason varchar [note: 'Reason code or description explaining why the order was cancelled. Examples include customer request, inventory shortage, credit hold, or duplicate order. Used for root cause analysis.']
  cancelled_timestamp timestamp [note: 'Date and time when the order was cancelled. Null for active orders. Used for cancellation rate analysis and order lifecycle reporting.']
  code varchar [note: 'The outbound order code of the outbound order record']
  created_timestamp timestamp [note: 'Date and time when the outbound order record was first created in the system. Audit field for data lineage and order lifecycle tracking.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the order value. Typically USD for domestic US operations, but may vary for export orders.']
  description varchar [note: 'The outbound order description of the outbound order record']
  effective_from date [note: 'The effective from of the outbound order record']
  effective_until date [note: 'The effective until of the outbound order record']
  fill_rate_percentage decimal(5,2) [note: 'Percentage of ordered quantity that was fulfilled from available inventory. Calculated as (shipped quantity / ordered quantity) * 100. Key metric for inventory availability and customer service.']
  hazmat_flag boolean [note: 'Indicates whether the order contains hazardous materials requiring special handling, labeling, and transportation compliance. True for products regulated under DOT hazmat rules.']
  incoterm varchar [note: 'International Commercial Terms defining the division of costs and risks between buyer and seller. Critical for export orders and freight responsibility determination. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]']
  last_modified_timestamp timestamp [note: 'Date and time when the outbound order record was last updated. Audit field for change tracking and data quality monitoring.']
  name varchar [note: 'The outbound order name of the outbound order record']
  notes varchar [note: 'The notes of the outbound order record']
  order_date date [note: 'Date when the outbound order was created or received from the customer. Principal business event timestamp for order lifecycle tracking.']
  order_status varchar [note: 'Current lifecycle status of the outbound order. Draft indicates order creation, released means ready for fulfillment, picking/packing/staged represent warehouse execution phases, shipped indicates in-transit, delivered confirms receipt, cancelled indicates order termination. [ENUM-REF-CANDIDATE: draft|released|picking|packing|staged|shipped|delivered|cancelled — 8 candidates stripped; promote to reference product]']
  order_type varchar [note: 'Classification of the outbound order based on fulfillment channel and destination. Retail replenishment serves store orders, DSD (Direct Store Delivery) bypasses DC, ecommerce serves online consumers, inter-DC transfer moves inventory between distribution centers, wholesale serves B2B customers, export serves international markets.']
  otif_commitment_flag boolean [note: 'Indicates whether this order is subject to formal OTIF performance measurement and customer scorecard reporting. True for orders with contractual delivery commitments.']
  outbound_order_status varchar [note: 'The outbound order status of the outbound order record']
  packing_slip_number varchar [note: 'Document number for the packing slip accompanying the shipment. Used for customer receiving and invoice reconciliation.']
  payment_terms varchar [note: 'Payment terms agreed with the customer for this order. Examples include Net 30, Net 60, COD (Cash on Delivery), or prepaid. Impacts accounts receivable and cash flow management.']
  pick_ticket_number varchar [note: 'Warehouse document number used to direct picking operations for this order. Generated by WMS when order is released to the warehouse floor.']
  priority varchar [note: 'The priority of the outbound order record']
  priority_code varchar [note: 'Priority level assigned to the outbound order for warehouse sequencing and resource allocation. Critical orders receive highest priority, rush orders are expedited, expedited orders have faster processing, standard orders follow normal flow.']
  promised_delivery_date date [note: 'The promised delivery date of the outbound order record']
  proof_of_delivery_timestamp timestamp [note: 'Date and time when delivery was confirmed by the recipient. Captured from carrier POD or customer signature. Used for OTIF measurement and freight audit.']
  purchase_order_number varchar [note: 'Customer\'s purchase order number provided for order tracking and invoice reconciliation. Required for EDI (Electronic Data Interchange) transactions with retail customers.']
  quantity decimal(18,4) [note: 'The quantity of the outbound order record']
  requested_ship_date date [note: 'Date when the customer or system requests the order to be shipped from the distribution center. Used for warehouse planning and scheduling.']
  required_delivery_date date [note: 'Date by which the order must be delivered to the customer destination. Critical for OTIF (On Time In Full) performance measurement and SLA compliance.']
  service_level varchar [note: 'Delivery speed commitment for the outbound order. Determines carrier selection, freight cost, and OTIF measurement criteria.']
  shipping_method varchar [note: 'Transportation mode used for order delivery. Ground for truck, air for expedited freight, ocean for international, rail for bulk, parcel for small packages, LTL (Less Than Truckload) for partial loads, FTL (Full Truckload) for full loads. [ENUM-REF-CANDIDATE: ground|air|ocean|rail|parcel|ltl|ftl — 7 candidates stripped; promote to reference product]']
  source_system_code varchar [note: 'The source system code of the outbound order record']
  special_handling_instructions varchar [note: 'Free-text instructions for warehouse and logistics teams regarding special handling requirements. May include temperature control, fragile handling, hazmat procedures, or customer-specific delivery instructions.']
  temperature_controlled_flag boolean [note: 'Indicates whether the order requires temperature-controlled storage and transportation. True for cold chain products requiring refrigeration or freezing.']
  total_lines varchar [note: 'The total lines of the outbound order record']
  total_order_quantity decimal(15,3) [note: 'Total quantity of units across all line items in the outbound order. Used for warehouse capacity planning and OTIF fill rate calculation.']
  total_order_value decimal(15,2) [note: 'Total monetary value of the outbound order before taxes and freight charges. Used for order prioritization, credit limit checks, and revenue forecasting.']
  total_order_volume_m3 decimal(12,3) [note: 'Total volume of the outbound order in cubic meters. Used for warehouse space planning, truck cube utilization, and pallet configuration.']
  total_order_weight_kg decimal(12,3) [note: 'Total weight of the outbound order in kilograms. Used for freight cost calculation, carrier capacity planning, and vehicle loading optimization.']
  total_quantity decimal(18,4) [note: 'The total quantity of the outbound order record']
  total_units decimal(18,4) [note: 'The total units of the outbound order record']
  tracking_number varchar [note: 'Carrier-provided tracking number for shipment visibility and customer self-service tracking. Used for parcel and LTL shipments.']
  uom varchar [note: 'The uom of the outbound order record']
  updated_timestamp timestamp [note: 'The updated timestamp of the outbound order record']

  Note: 'Master outbound fulfillment order record representing a customer or retailer replenishment request to be fulfilled from a DC. Captures order number, order type (retail replenishment, DSD, e-commerce, inter-DC transfer), customer/account reference, requested ship date, required delivery date, priority, OTIF commitment, and order status lifecycle. Sourced from SAP SD and Salesforce Consumer Goods Cloud order management.'
}

Table distribution.outbound_order_line {
  outbound_order_line_id varchar [pk, note: 'Unique identifier for the outbound order line item.']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Revenue GL account assignment at order line level drives revenue recognition reporting by product category in consumer goods. Mixed-category orders require line-level GL assignment for accurate P&L po']
  outbound_order_id varchar [note: 'Reference to the parent outbound fulfillment order header.']
  sku_id varchar [note: 'The sku id of the outbound order line record']
  storage_location_id varchar [note: 'Foreign key linking to distribution.distribution_storage_location. Business justification: Outbound order line items are stored in a DC location before picking. Adding a FK to distribution_storage_location enables location lookup and normalizes location data.']
  actual_ship_date date [note: 'Actual date the line was shipped from the distribution center.']
  allocated_quantity decimal(15,3) [note: 'Quantity allocated from warehouse inventory to this order line.']
  amount decimal(18,4) [note: 'The amount of the outbound order line record']
  base_unit_quantity decimal(15,3) [note: 'Quantity converted to base unit of measure for standardized reporting and inventory tracking.']
  code varchar [note: 'The outbound order line code of the outbound order line record']
  confirmed_quantity decimal(15,3) [note: 'Quantity confirmed available for fulfillment after ATP (Available to Promise) check.']
  created_timestamp timestamp [note: 'Date and time when the outbound order line record was first created in the system.']
  currency_code varchar [note: 'The currency code of the outbound order line record']
  customer_po_line_number varchar [note: 'Customer\'s purchase order line number for cross-reference and reconciliation.']
  description varchar [note: 'The outbound order line description of the outbound order line record']
  dsd_flag boolean [note: 'Indicates whether this line is part of a direct store delivery order bypassing retailer distribution centers.']
  edi_line_reference varchar [note: 'EDI transaction line reference number for electronic order processing and ASN generation.']
  effective_from date [note: 'The effective from of the outbound order line record']
  effective_until date [note: 'The effective until of the outbound order line record']
  expiry_date date [note: 'Product expiration date for FEFO inventory rotation and shelf-life management.']
  gtin varchar [note: 'Global trade item number (GTIN-8, GTIN-12, GTIN-13, or GTIN-14) for the product being shipped.']
  handling_unit_code varchar [note: 'Serial shipping container code (SSCC) or handling unit identifier for the container holding this line item.']
  hazmat_flag boolean [note: 'Indicates whether this line contains hazardous materials requiring special handling and documentation.']
  line_number varchar [note: 'Sequential line number within the outbound order for ordering and identification.']
  line_status varchar [note: 'Current fulfillment status of the order line in the warehouse execution lifecycle. [ENUM-REF-CANDIDATE: open|allocated|picked|packed|shipped|cancelled|short_shipped — 7 candidates stripped; promote to reference product]']
  line_volume_m3 decimal(15,6) [note: 'Total volume of the shipped quantity for this line in cubic meters.']
  line_weight_kg decimal(15,3) [note: 'Total weight of the shipped quantity for this line in kilograms.']
  lot_number varchar [note: 'Manufacturing lot or batch number for traceability and quality control.']
  name varchar [note: 'The outbound order line name of the outbound order line record']
  notes varchar [note: 'The notes of the outbound order line record']
  ordered_quantity decimal(15,3) [note: 'Quantity of the SKU originally requested by the customer in the order.']
  otif_status varchar [note: 'Line-level OTIF performance status indicating whether the line was delivered on time and in full quantity.']
  outbound_order_line_status varchar [note: 'The outbound order line status of the outbound order line record']
  pack_timestamp timestamp [note: 'Date and time when the line item was packed into shipping containers.']
  packed_quantity decimal(15,3) [note: 'Quantity packed into shipping containers and ready for dispatch.']
  pallet_code varchar [note: 'Pallet identifier if the line item was shipped on a palletized load.']
  pick_timestamp timestamp [note: 'Date and time when the line item was picked from warehouse inventory.']
  pick_zone varchar [note: 'Warehouse pick zone designation for labor management and routing optimization.']
  picked_quantity decimal(15,3) [note: 'Quantity physically picked from warehouse storage locations during fulfillment.']
  quantity decimal(18,4) [note: 'The quantity of the outbound order line record']
  requested_ship_date date [note: 'Customer-requested or system-calculated target ship date for this line.']
  serial_numbers varchar [note: 'Comma-separated list of serial numbers for serialized inventory items shipped on this line.']
  ship_timestamp timestamp [note: 'Date and time when the line item was shipped from the distribution center.']
  shipped_quantity decimal(15,3) [note: 'Quantity actually shipped to the customer, may differ from ordered due to short-ship scenarios.']
  short_ship_flag boolean [note: 'Indicates whether this line was short-shipped (shipped quantity less than ordered quantity).']
  short_ship_reason_code varchar [note: 'Reason code for short shipment (OOS=Out of Stock, DAMAGE=Damaged Inventory, RECALL=Product Recall, EXPIRED=Expired Product, ALLOCATION=Allocation Constraint).']
  source_system_code varchar [note: 'The source system code of the outbound order line record']
  temperature_controlled_flag boolean [note: 'Indicates whether this line requires temperature-controlled storage and transportation.']
  unit_of_measure varchar [note: 'Unit of measure for quantities (EA=Each, CS=Case, PL=Pallet, BX=Box, KG=Kilogram, LB=Pound, LT=Liter, GL=Gallon). [ENUM-REF-CANDIDATE: EA|CS|PL|BX|KG|LB|LT|GL — 8 candidates stripped; promote to reference product]']
  unit_volume_m3 decimal(12,6) [note: 'Volume per unit of the SKU in cubic meters for space utilization and load planning.']
  unit_weight_kg decimal(12,3) [note: 'Weight per unit of the SKU in kilograms for freight calculation and capacity planning.']
  uom varchar [note: 'The uom of the outbound order line record']
  upc varchar [note: 'Universal product code (UPC-A) for retail scanning and point-of-sale identification.']
  updated_timestamp timestamp [note: 'The updated timestamp of the outbound order line record']
  warehouse_location_code varchar [note: 'Distribution center or warehouse location code from which this line was fulfilled.']

  Note: 'Line-level detail for each SKU within an outbound fulfillment order. Records SKU code, GTIN, ordered quantity, confirmed quantity, allocated quantity, picked quantity, shipped quantity, unit of measure, lot number, expiry date, and line-level OTIF status. Enables order fill rate tracking, short-ship identification, and OSA impact analysis at the SKU-customer level.'
}

Table distribution.pick_task {
  pick_task_id varchar [pk, note: 'Unique identifier for the pick task record. Primary key for the pick_task data product.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Pick task labor costs are charged to a cost center; required for labor cost analysis and OTIF performance metrics.']
  destination_location_distribution_storage_location_id varchar [note: 'Reference to the target location where picked items are staged or packed (e.g., pack station, staging lane, loading dock).']
  distribution_facility_id varchar [note: 'Identifier of the distribution center or warehouse where the pick task is executed.']
  distribution_shipment_id varchar [note: 'Foreign key linking to distribution.distribution_shipment. Business justification: A pick task is executed to fulfill a specific outbound shipment in WMS operations. While pick_task already links to outbound_order and outbound_order_line, the direct link to distribution_shipment ena']
  outbound_order_id varchar [note: 'Reference to the parent outbound order or shipment order that generated this pick task.']
  outbound_order_line_id varchar [note: 'The outbound order line id of the pick task record']
  primary_pick_distribution_storage_location_id varchar [note: 'Reference to the warehouse storage location (bin, shelf, pallet position) from which inventory is picked.']
  sku_id varchar [note: 'Reference to the product SKU being picked or packed in this task.']
  amount decimal(18,4) [note: 'The amount of the pick task record']
  carton_code varchar [note: 'Unique identifier for the carton or shipping container into which items are packed. May be a license plate number (LPN) or SSCC (Serial Shipping Container Code).']
  code varchar [note: 'The pick task code of the pick task record']
  completed_timestamp timestamp [note: 'The completed timestamp of the pick task record']
  created_timestamp timestamp [note: 'Timestamp when the pick task record was first created in the WMS. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  currency_code varchar [note: 'The currency code of the pick task record']
  description varchar [note: 'The pick task description of the pick task record']
  dsd_flag boolean [note: 'Boolean indicator of whether this pick task is part of a Direct Store Delivery (DSD) execution workflow (true = DSD, false = standard distribution).']
  effective_from date [note: 'The effective from of the pick task record']
  effective_until date [note: 'The effective until of the pick task record']
  exception_code varchar [note: 'Code identifying any exception or issue encountered during task execution (e.g., short pick, damaged goods, location discrepancy). Null if no exception.']
  exception_notes varchar [note: 'Free-text notes entered by the operator or supervisor describing the exception or issue encountered during task execution.']
  gross_weight_kg decimal(12,3) [note: 'Total gross weight of the packed carton or pallet including product and packaging materials, measured in kilograms.']
  gs1_128_label varchar [note: 'The GS1-128 barcode label data applied to the carton or pallet, encoding SSCC, GTIN, lot, expiry, and other supply chain attributes.']
  height_cm decimal(10,2) [note: 'Height dimension of the packed carton or pallet, measured in centimeters.']
  last_modified_timestamp timestamp [note: 'Timestamp when the pick task record was last updated in the WMS. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  length_cm decimal(10,2) [note: 'Length dimension of the packed carton or pallet, measured in centimeters.']
  name varchar [note: 'The pick task name of the pick task record']
  net_weight_kg decimal(12,3) [note: 'Net weight of the product content only (excluding packaging), measured in kilograms.']
  notes varchar [note: 'The notes of the pick task record']
  otif_eligible_flag boolean [note: 'Boolean indicator of whether this pick task is subject to OTIF (On Time In Full) performance measurement (true = OTIF tracked, false = not tracked).']
  pack_station_code varchar [note: 'Reference to the packing station where the packing operation is performed. Applicable when task_type includes packing.']
  packaging_material_code varchar [note: 'Code identifying the type of packaging material used (e.g., corrugated box, poly bag, shrink wrap). Used for cartonization and sustainability tracking.']
  pallet_code varchar [note: 'Unique identifier for the pallet onto which cartons or items are loaded. Typically an SSCC or internal LPN.']
  pick_accuracy_flag boolean [note: 'Boolean indicator of whether the pick was accurate (true = picked quantity matches requested quantity and correct SKU/lot; false = discrepancy detected).']
  pick_list_number varchar [note: 'Human-readable pick list reference number assigned by the WMS for operator identification and tracking.']
  pick_method varchar [note: 'The pick method of the pick task record']
  pick_quantity decimal(15,3) [note: 'The quantity of SKU units to be picked for this task, measured in the SKU\'s base unit of measure.']
  pick_task_status varchar [note: 'The pick task status of the pick task record']
  picked_quantity decimal(15,3) [note: 'The actual quantity of SKU units picked by the operator. May differ from pick_quantity due to short picks or overages.']
  picking_strategy varchar [note: 'The picking methodology applied: discrete (single order), batch (multiple orders), zone (by warehouse zone), wave (grouped by wave), cluster (multi-order cart picking).']
  priority varchar [note: 'The priority of the pick task record']
  priority_level varchar [note: 'Priority classification of the pick task for sequencing and resource allocation: urgent (immediate), high (expedited), normal (standard), low (backlog).']
  quantity decimal(18,4) [note: 'The quantity of the pick task record']
  source_system_code varchar [note: 'The source system code of the pick task record']
  sscc varchar [note: '18-digit GS1 Serial Shipping Container Code uniquely identifying the logistics unit (carton or pallet) for tracking through the supply chain.']
  started_timestamp timestamp [note: 'The started timestamp of the pick task record']
  task_assigned_timestamp timestamp [note: 'Timestamp when the pick task was assigned to an operator by the WMS. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  task_completed_timestamp timestamp [note: 'Timestamp when the pick task was completed and confirmed by the operator or WMS. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  task_duration_seconds varchar [note: 'Total elapsed time in seconds from task start to completion. Used for labor productivity analysis and standard time calculation.']
  task_number varchar [note: 'The task number of the pick task record']
  task_started_timestamp timestamp [note: 'Timestamp when the operator began executing the pick task (scanned start or confirmed task initiation). Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  task_status varchar [note: 'Current lifecycle status of the pick task: pending (awaiting assignment), assigned (allocated to operator), in_progress (actively being executed), completed (finished successfully), cancelled (voided), on_hold (temporarily suspended).']
  task_type varchar [note: 'Discriminator indicating the type of fulfillment task: pick (picking only), pack (packing only), pick_and_pack (combined operation), or replenishment_pick (internal stock movement).']
  unit_of_measure varchar [note: 'The unit of measure for pick and picked quantities (e.g., EA for each, CS for case, PL for pallet).']
  uom varchar [note: 'The uom of the pick task record']
  updated_timestamp timestamp [note: 'The updated timestamp of the pick task record']
  width_cm decimal(10,2) [note: 'Width dimension of the packed carton or pallet, measured in centimeters.']

  Note: 'Fulfillment task record covering both picking and packing operations within DC outbound execution. For picking: captures pick list reference, source location, SKU, lot, pick quantity, assigned operator, wave/batch reference, pick accuracy flag, and task timestamps. For packing: captures pack station, carton/pallet ID, packed SKUs and quantities, packaging material, gross weight, dimensions, GS1-128/SSCC label, and packer operator. Supports wave picking, batch picking, zone picking, and cartonization strategies in Blue Yonder WMS. Task_type discriminator distinguishes pick vs pack execution steps.'
}

Table distribution.distribution_shipment {
  distribution_shipment_id varchar [pk, note: 'Unique identifier for the distribution shipment record. Primary key for the distribution shipment entity.']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: Campaign-level logistics cost attribution and OTIF reporting: CPG brand teams track shipment costs and on-time delivery rates per campaign (promotional launches, display programs). Direct campaign_id ']
  carrier_id varchar [note: 'The carrier id of the distribution shipment record']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Required for shipment cost allocation report; logistics expenses are charged to a cost center, a standard practice in consumer‑goods distribution.']
  freight_gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Freight cost GL account on shipments enables direct posting of outbound freight expenses to the correct P&L line in consumer goods. Required for freight cost accrual, carrier invoice matching, and log']
  lane_id varchar [note: 'Foreign key linking to logistics.lane. Business justification: Costing and transit planning use lane definitions; linking shipment to lane provides distance, rate, and compliance data.']
  manufacturing_facility_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_facility. Business justification: Shipment origin tracking: linking shipments to the originating manufacturing facility enables performance dashboards and OTIF analysis.']
  network_lane_id varchar [note: 'Foreign key linking to supply.network_lane. Business justification: Distribution shipments execute over supply network lanes. Supply planners reconcile actual shipment transit times and costs against planned lane parameters (lead time, OTIF target, cost-per-unit) for ']
  outbound_order_id varchar [note: 'Foreign key linking to distribution.outbound_order. Business justification: Shipment is a child of an outbound order; each shipment fulfills an order. Adding outbound_order_id to distribution_shipment creates the necessary parent link without creating a bidirectional relation']
  actual_delivery_date date [note: 'The actual delivery date of the distribution shipment record']
  amount decimal(18,4) [note: 'The amount of the distribution shipment record']
  code varchar [note: 'The distribution shipment code of the distribution shipment record']
  created_timestamp timestamp [note: 'The created timestamp of the distribution shipment record']
  currency_code varchar [note: 'The currency code of the distribution shipment record']
  delivery_date date [note: 'The delivery date of the distribution shipment record']
  description varchar [note: 'The distribution shipment description of the distribution shipment record']
  distribution_shipment_status varchar [note: 'The distribution shipment status of the distribution shipment record']
  effective_from date [note: 'The effective from of the distribution shipment record']
  effective_until date [note: 'The effective until of the distribution shipment record']
  expected_delivery_date date [note: 'The expected delivery date of the distribution shipment record']
  freight_cost decimal(18,4) [note: 'The freight cost of the distribution shipment record']
  name varchar [note: 'The distribution shipment name of the distribution shipment record']
  notes varchar [note: 'The notes of the distribution shipment record']
  quantity decimal(18,4) [note: 'The quantity of the distribution shipment record']
  ship_date date [note: 'The ship date of the distribution shipment record']
  shipment_number varchar [note: 'The shipment number of the distribution shipment record']
  shipment_status varchar [note: 'The shipment status of the distribution shipment record']
  source_system_code varchar [note: 'The source system code of the distribution shipment record']
  total_cartons varchar [note: 'The total cartons of the distribution shipment record']
  total_weight_kg decimal(12,3) [note: 'The total weight kg of the distribution shipment record']
  tracking_number varchar [note: 'The tracking number of the distribution shipment record']
  uom varchar [note: 'The uom of the distribution shipment record']
  updated_timestamp timestamp [note: 'The updated timestamp of the distribution shipment record']

  Note: 'Outbound shipment record representing the physical dispatch of goods from a DC to a customer, retailer, or downstream DC. Captures shipment number, carrier, trailer/container ID, seal number, dock door, scheduled and actual departure datetime, destination, total weight, total cube, pallet count, carton count, and OTIF status. Integrates with Blue Yonder WMS load planning and SAP SD goods issue. SSOT for DC-level outbound shipment execution distinct from the logistics domain\'s carrier-level shipment tracking. [SSOT: authoritative table is logistics.logistics_shipment; this table is a deprecated duplicate.] [SSOT: authoritative table is logistics.logistics_shipment; this is a deprecated duplicate for concept \'shipment\'.] [Non-authoritative; defers to SSOT logistics.logistics_shipment for concept \'shipment\'.]'
}

Table distribution.inventory_position {
  inventory_position_id varchar [pk, note: 'Primary key for inventory_position']
  batch_release_id varchar [note: 'Foreign key linking to quality.batch_release. Business justification: Inventory positions reflect QA-released stock — the stock_status and inventory_condition fields are directly determined by the batch release decision. This FK enables inventory availability reporting ']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Inventory carrying costs (storage, handling, obsolescence) are allocated to cost centers in consumer goods period-end close. Finance requires cost center on inventory positions for inventory carrying ']
  distribution_facility_id varchar [note: 'Identifier of the distribution center where the inventory is physically located.']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Inventory GL account assignment on position records supports balance sheet stock valuation, inventory write-down postings, and cycle count adjustment entries. In consumer goods ERP (SAP), valuation cl']
  inventory_policy_id varchar [note: 'Foreign key linking to supply.inventory_policy. Business justification: Inventory policies define safety stock targets, reorder points, and service level commitments that govern each DC\'s inventory position. DC planners compare actual inventory_position against policy tar']
  retail_store_id varchar [note: 'Foreign key linking to sales.retail_store. Business justification: Consumer goods VMI and store-level replenishment: inventory positions are earmarked for specific retail stores (retail_store.vmi_enabled_flag confirms VMI is modeled). Store-level inventory allocation']
  sku_id varchar [note: 'Identifier of the product SKU for which inventory position is tracked.']
  storage_location_id varchar [note: 'Foreign key linking to distribution.distribution_storage_location. Business justification: Inventory position records on‑hand quantities at a specific DC location. Linking to distribution_storage_location provides the authoritative location details and removes the generic storage_location_i']
  usage_decision_id varchar [note: 'Foreign key linking to quality.usage_decision. Business justification: Inventory positions (on_hold_quantity, quantity_quarantine, quantity_available) are directly governed by usage decisions. This FK links current inventory status to the specific QA usage decision that ']
  actual_weight decimal(18,3) [note: 'The actual measured weight of the inventory for catch weight items. Used for billing and compliance when item weight varies.']
  allocated_quantity decimal(18,4) [note: 'The allocated quantity of the inventory position record']
  amount decimal(18,4) [note: 'The amount of the inventory position record']
  available_quantity decimal(18,4) [note: 'The available quantity of the inventory position record']
  catch_weight_flag boolean [note: 'Indicates whether the SKU is a catch weight item requiring actual weight capture at transaction time (true) or standard weight (false).']
  code varchar [note: 'The inventory position code of the inventory position record']
  cost_per_unit decimal(18,4) [note: 'The unit cost of the inventory lot. Used for inventory valuation and cost of goods sold calculations. Business confidential financial data.']
  created_timestamp timestamp [note: 'The timestamp when this inventory position record was first created in the system. Used for audit trail and data lineage.']
  currency_code varchar [note: 'The three-letter ISO 4217 currency code for inventory valuation (e.g., USD, EUR, GBP).']
  days_on_hand varchar [note: 'The number of days the inventory has been on hand since receipt. Calculated as current date minus receipt date. Used for aging analysis.']
  days_to_expiry varchar [note: 'The number of days remaining until the inventory lot expires. Calculated as expiry date minus current date. Critical for FEFO rotation and markdown decisions.']
  description varchar [note: 'The inventory position description of the inventory position record']
  effective_from date [note: 'The effective from of the inventory position record']
  effective_until date [note: 'The effective until of the inventory position record']
  expiration_date date [note: 'The expiration date of the inventory position record']
  expiry_date date [note: 'The date on which the product lot expires and can no longer be sold or distributed. Critical for FEFO inventory management and regulatory compliance.']
  in_transit_quantity decimal(18,4) [note: 'The in transit quantity of the inventory position record']
  inventory_condition varchar [note: 'The physical condition classification of the inventory. Used for disposition decisions and channel restrictions.']
  inventory_position_status varchar [note: 'The inventory position status of the inventory position record']
  inventory_status varchar [note: 'The current operational status of the inventory position. Determines availability for picking and order fulfillment.']
  last_cycle_count_date date [note: 'The date when this inventory position was last physically counted during a cycle count operation. Used to schedule next count and assess inventory accuracy.']
  last_movement_date date [note: 'The date when inventory was last moved into or out of this storage location. Used for slow-moving inventory identification.']
  last_movement_type varchar [note: 'The type of the last inventory movement transaction that affected this position (receipt, putaway, pick, replenishment, transfer, adjustment, return). [ENUM-REF-CANDIDATE: receipt|putaway|pick|replenishment|transfer|adjustment|return — 7 candidates stripped; promote to reference product]']
  last_updated_timestamp timestamp [note: 'The timestamp when this inventory position record was last modified. Used for change tracking and data freshness assessment.']
  license_plate_number varchar [note: 'The warehouse management system license plate number assigned to the handling unit. Used for tracking and automated material handling.']
  lot_number varchar [note: 'The alphanumeric lot or batch number assigned during manufacturing. Used for traceability and recall management.']
  manufacture_date date [note: 'The date on which the product lot was manufactured. Used for shelf-life calculations and FEFO rotation.']
  name varchar [note: 'The inventory position name of the inventory position record']
  notes varchar [note: 'The notes of the inventory position record']
  on_hand_quantity decimal(18,4) [note: 'The on hand quantity of the inventory position record']
  on_hold_quantity decimal(18,4) [note: 'The on hold quantity of the inventory position record']
  owner_type varchar [note: 'Indicates the ownership model of the inventory (owned by company, consignment from supplier, customer-owned for returns, vendor-managed inventory).']
  pallet_code varchar [note: 'The unique identifier of the pallet or handling unit on which the inventory is stored. Used for warehouse automation and tracking.']
  pick_face_flag boolean [note: 'Indicates whether this inventory position is in a primary pick face location (true) or reserve storage (false). Pick face locations are optimized for order picking efficiency.']
  putaway_date date [note: 'The date when the inventory was put away into this storage location after receiving. Used for aging analysis and FEFO compliance.']
  quantity decimal(18,4) [note: 'The quantity of the inventory position record']
  quantity_allocated decimal(18,3) [note: 'The quantity of on-hand inventory that has been allocated to outbound orders or reservations but not yet picked. Reduces available-to-pick quantity.']
  quantity_available decimal(18,3) [note: 'The quantity available for new order allocation and picking. Calculated as quantity_on_hand minus quantity_allocated minus quantity_quarantine minus quantity_hold.']
  quantity_damaged decimal(18,3) [note: 'The quantity of inventory identified as damaged and not suitable for sale or distribution. Typically awaiting disposal or return to supplier.']
  quantity_hold decimal(18,3) [note: 'The quantity of inventory placed on hold due to quality issues, customer complaints, or pending investigation. Not available for picking.']
  quantity_on_hand decimal(18,3) [note: 'The total physical quantity of the SKU-lot currently present in the storage location. Measured in the SKU\'s base unit of measure.']
  quantity_quarantine decimal(18,3) [note: 'The quantity of inventory placed in quarantine status pending quality inspection or regulatory clearance. Not available for picking.']
  quantity_reserved decimal(18,3) [note: 'The quantity of inventory reserved for specific customers, channels, or promotional programs. Subset of allocated quantity with additional business constraints.']
  receipt_date date [note: 'The date when the inventory lot was received into the distribution center. Used for inventory aging and supplier performance tracking.']
  replenishment_flag boolean [note: 'Indicates whether this inventory position requires replenishment from reserve to pick face (true) or not (false). Triggers automated replenishment tasks.']
  snapshot_timestamp timestamp [note: 'The timestamp when this inventory position snapshot was captured. Used for point-in-time inventory reporting and trend analysis.']
  source_system_code varchar [note: 'The source system code of the inventory position record']
  stock_status varchar [note: 'The stock status of the inventory position record']
  storage_zone varchar [note: 'The logical zone within the distribution center where the inventory is stored (e.g., ambient, refrigerated, frozen, hazmat, high-velocity, reserve).']
  temperature_zone varchar [note: 'The temperature control zone classification for the storage location. Critical for cold chain compliance and product quality.']
  total_inventory_value decimal(18,2) [note: 'The total financial value of the inventory position calculated as quantity_on_hand multiplied by cost_per_unit. Used for balance sheet reporting. Business confidential financial data.']
  unit_of_measure varchar [note: 'The base unit of measure in which inventory quantities are tracked (Each, Case, Pallet, Pound, Kilogram, Liter, Gallon). [ENUM-REF-CANDIDATE: EA|CS|PL|LB|KG|L|GAL — 7 candidates stripped; promote to reference product]']
  uom varchar [note: 'The uom of the inventory position record']
  updated_timestamp timestamp [note: 'The updated timestamp of the inventory position record']
  weight_unit_of_measure varchar [note: 'The unit of measure for actual weight (Pound, Kilogram, Ounce, Gram). Applicable for catch weight items.']

  Note: 'Current on-hand inventory position at the DC-location-SKU-lot level within distribution center walls. Captures storage location, SKU, lot number, manufacture and expiry dates, quantity on hand, allocated quantity, available-to-pick (ATP) quantity, quarantine quantity, inventory status (available, hold, damaged, expired), and last cycle count date. This is the operational working inventory view for DC execution — distinct from the inventory domain\'s network-wide planning position which aggregates across all nodes.'
}

Table procurement.supplier {
  supplier_id varchar [pk, note: 'Unique identifier for the supplier record. Primary key for the supplier entity.']
  reconciliation_gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: In AP subledger accounting, each vendor/supplier master record references a reconciliation GL account that links the AP subledger to the general ledger. This is a standard SAP/ERP requirement for AP-t']
  address_line1 varchar [note: 'Primary street address line for the supplier\'s registered business location or headquarters.']
  address_line2 varchar [note: 'Secondary address line for additional location details such as suite, building, or floor number.']
  amount decimal(18,4) [note: 'The amount of the supplier record']
  approval_status varchar [note: 'The approval status of the supplier record']
  city varchar [note: 'City or municipality name where the supplier\'s business location is registered.']
  code varchar [note: 'Internal business identifier or code assigned to the supplier for procurement and ERP system reference.']
  contract_expiration_date date [note: 'Date when the current master supply agreement or contract with the supplier expires and requires renewal or renegotiation.']
  country_code varchar [note: 'Three-letter ISO country code identifying the country where the supplier is legally registered and operates.']
  created_timestamp timestamp [note: 'Timestamp when the supplier record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO currency code indicating the preferred currency for transactions and invoicing with this supplier.']
  description varchar [note: 'The supplier description of the supplier record']
  diversity_classification varchar [note: 'Classification indicating if the supplier qualifies as a diverse supplier (e.g., minority-owned, women-owned, veteran-owned, small business).']
  duns_number varchar [note: 'Nine-digit unique identifier assigned by Dun & Bradstreet to identify the supplier business entity globally.']
  edi_capable_flag boolean [note: 'Indicates whether the supplier has EDI capability for automated exchange of purchase orders, invoices, and shipping notices.']
  edi_identifier varchar [note: 'Unique EDI identifier or interchange ID used for electronic document exchange with the supplier.']
  effective_from date [note: 'The effective from of the supplier record']
  effective_until date [note: 'The effective until of the supplier record']
  fsc_certified_flag boolean [note: 'Indicates whether the supplier holds FSC certification for sustainable forestry and paper-based materials sourcing.']
  gln varchar [note: 'GS1 Global Location Number uniquely identifying the supplier\'s legal entity or physical location within the supply chain.']
  gmp_certified_flag boolean [note: 'Indicates whether the supplier is certified for Good Manufacturing Practices, critical for consumer goods quality and safety compliance.']
  incoterms varchar [note: 'Standard Incoterms code defining the responsibilities, costs, and risks between buyer and supplier for international shipments. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]']
  is_approved boolean [note: 'The is approved of the supplier record']
  is_strategic boolean [note: 'The is strategic of the supplier record']
  iso_9001_certified_flag boolean [note: 'Indicates whether the supplier maintains ISO 9001 quality management system certification.']
  last_audit_date date [note: 'Date of the most recent supplier audit or assessment conducted for quality, compliance, or sustainability verification.']
  lead_time_days varchar [note: 'Standard number of days required from purchase order placement to goods receipt for this supplier.']
  legal_name varchar [note: 'The legal name of the supplier record']
  modified_timestamp timestamp [note: 'Timestamp when the supplier record was last modified or updated in the system.']
  moq_quantity decimal(18,3) [note: 'Minimum order quantity required by the supplier for purchase orders to be accepted.']
  moq_unit varchar [note: 'Unit of measure for the minimum order quantity (e.g., EA, KG, LB, L, cases, pallets).']
  name varchar [note: 'The full legal name of the supplier or vendor organization as registered with governing authorities.']
  notes varchar [note: 'The notes of the supplier record']
  onboarding_date date [note: 'Date when the supplier was officially onboarded and approved for procurement activities.']
  onboarding_status varchar [note: 'Current stage of the supplier onboarding process tracking progress from initial registration through final approval.']
  payment_method varchar [note: 'Preferred method of payment for settling invoices with the supplier.']
  payment_terms varchar [note: 'Standard payment terms negotiated with the supplier defining the payment schedule and conditions (e.g., Net 30, Net 60, 2/10 Net 30).']
  performance_score decimal(5,2) [note: 'Overall performance score for the supplier based on quality, delivery, cost, and service metrics, typically on a 0-100 scale.']
  postal_code varchar [note: 'Postal or ZIP code for the supplier\'s business address used for mail delivery and logistics coordination.']
  primary_contact_email varchar [note: 'Email address of the primary supplier contact used for procurement communications and order coordination.']
  primary_contact_name varchar [note: 'Full name of the primary business contact person at the supplier organization responsible for account management.']
  primary_contact_phone varchar [note: 'Telephone number of the primary supplier contact for urgent procurement matters and order inquiries.']
  quantity decimal(18,4) [note: 'The quantity of the supplier record']
  risk_rating varchar [note: 'Risk assessment classification for the supplier based on financial stability, geopolitical factors, compliance history, and supply continuity.']
  rspo_certified_flag boolean [note: 'Indicates whether the supplier holds RSPO certification for sustainable palm oil sourcing practices.']
  source_system_code varchar [note: 'The source system code of the supplier record']
  state_province varchar [note: 'State, province, or regional administrative division for the supplier\'s business address.']
  supplier_number varchar [note: 'The supplier number of the supplier record']
  supplier_status varchar [note: 'Current lifecycle status of the supplier relationship indicating whether the supplier is eligible for procurement activities.']
  supplier_type varchar [note: 'Classification of the supplier based on the category of goods or services provided to the business.']
  tax_identification_number varchar [note: 'Government-issued tax identification number for the supplier (e.g., EIN in USA, VAT number in EU) used for tax reporting and compliance.']
  tax_number varchar [note: 'The tax number of the supplier record']
  tier varchar [note: 'Strategic classification of the supplier indicating their relationship status and procurement priority level with the organization.']
  uom varchar [note: 'The uom of the supplier record']
  updated_timestamp timestamp [note: 'The updated timestamp of the supplier record']
  vmi_eligible_flag boolean [note: 'Indicates whether the supplier is eligible and capable of participating in Vendor Managed Inventory programs.']

  Note: 'Master record for all suppliers, vendors, and contract manufacturers providing raw materials, packaging, and indirect goods. Captures supplier legal entity details, GS1/DUNS identifiers, tax registration, payment terms, MOQ terms, lead times, incoterms, preferred currency, supplier tier classification (strategic/preferred/approved/conditional), VMI eligibility flag, EDI capability, sustainability certifications (FSC, RSPO), and onboarding status. SSOT for supplier identity across the procurement domain.'
}

Table procurement.supplier_site {
  supplier_site_id varchar [pk, note: 'Unique identifier for the supplier site. Primary key for this entity.']
  manufacturing_facility_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_facility. Business justification: In consumer goods, supplier sites are qualified and mapped to specific manufacturing facilities they supply, based on GMP certification scope, proximity, and regulatory registration. Direct FK enables']
  supplier_id varchar [note: 'Reference to the parent supplier organization that owns or operates this site.']
  supply_network_node_id varchar [note: 'Foreign key linking to supply.network_node. Business justification: VMI programs map each supplier site to a specific distribution node to manage inventory ownership and replenishment.']
  address_line1 varchar [note: 'The address line1 of the supplier site record']
  address_line_1 varchar [note: 'Primary street address line for the supplier site location.']
  address_line_2 varchar [note: 'Secondary address line for building, suite, or unit information.']
  amount decimal(18,4) [note: 'The amount of the supplier site record']
  audit_score decimal(5,2) [note: 'Most recent audit score for this site, typically on a 0-100 scale, reflecting compliance and quality performance.']
  capacity_unit_of_measure varchar [note: 'Unit of measure for the site capacity metric (e.g., units_per_month, pallets, square_meters, kilograms_per_day).']
  certification_expiry_date date [note: 'Date when the primary site certifications expire and require renewal. Used for compliance monitoring and supplier audit scheduling.']
  city varchar [note: 'City or municipality where the supplier site is located.']
  code varchar [note: 'The supplier site code of the supplier site record']
  contact_email varchar [note: 'The contact email of the supplier site record']
  contact_name varchar [note: 'The contact name of the supplier site record']
  country_code varchar [note: 'ISO 3166-1 alpha-3 country code identifying the country where the site is located. Critical for country of origin tracking and regulatory compliance.']
  created_timestamp timestamp [note: 'Timestamp when this supplier site record was first created in the system.']
  currency_code varchar [note: 'The currency code of the supplier site record']
  description varchar [note: 'The supplier site description of the supplier site record']
  edi_capable boolean [note: 'Indicates whether this site is capable of exchanging purchase orders, invoices, and shipping notices via EDI.']
  effective_end_date date [note: 'Date when this supplier site was deactivated or ceased operations. Null for currently active sites.']
  effective_from date [note: 'The effective from of the supplier site record']
  effective_start_date date [note: 'Date when this supplier site became active and available for procurement operations.']
  effective_until date [note: 'The effective until of the supplier site record']
  email_address varchar [note: 'Primary email contact for the supplier site.']
  fax_number varchar [note: 'Fax number for the supplier site, if applicable.']
  fsc_certified boolean [note: 'Indicates whether this site holds FSC certification for sustainable forestry and paper sourcing.']
  gln varchar [note: 'GS1 Global Location Number uniquely identifying this physical site location for supply chain traceability and EDI transactions.']
  gmp_certified boolean [note: 'Indicates whether this site is certified for Good Manufacturing Practices, critical for pharmaceutical and food-grade materials.']
  is_active boolean [note: 'The is active of the supplier site record']
  is_primary_ship_from boolean [note: 'The is primary ship from of the supplier site record']
  iso_14001_certified boolean [note: 'Indicates whether this site holds ISO 14001 Environmental Management System certification.']
  iso_22716_certified boolean [note: 'Indicates whether this site holds ISO 22716 Good Manufacturing Practices for Cosmetics certification.']
  iso_9001_certified boolean [note: 'Indicates whether this site holds ISO 9001 Quality Management System certification.']
  last_audit_date date [note: 'Date of the most recent quality or compliance audit conducted at this site.']
  last_modified_timestamp timestamp [note: 'Timestamp when this supplier site record was last updated.']
  latitude decimal(10,7) [note: 'Geographic latitude coordinate of the supplier site, used for logistics optimization and distance calculations.']
  lead_time_days varchar [note: 'Standard lead time in days from this site to the buyer\'s receiving location, used for procurement planning and MRP calculations.']
  longitude decimal(10,7) [note: 'Geographic longitude coordinate of the supplier site, used for logistics optimization and distance calculations.']
  moq decimal(18,2) [note: 'Minimum order quantity required by this site for purchase orders.']
  moq_unit_of_measure varchar [note: 'Unit of measure for the minimum order quantity (e.g., units, cases, pallets, kilograms).']
  name varchar [note: 'The supplier site name of the supplier site record']
  next_audit_date date [note: 'Scheduled date for the next quality or compliance audit at this site.']
  notes varchar [note: 'The notes of the supplier site record']
  phone_number varchar [note: 'Primary contact phone number for the supplier site.']
  postal_code varchar [note: 'Postal or ZIP code for the supplier site address.']
  preferred_site_flag boolean [note: 'Indicates whether this site is designated as a preferred sourcing location based on performance, cost, or strategic criteria.']
  quantity decimal(18,4) [note: 'The quantity of the supplier site record']
  rspo_certified boolean [note: 'Indicates whether this site is certified by RSPO for sustainable palm oil sourcing.']
  site_capacity decimal(18,2) [note: 'Maximum production or storage capacity of the site, measured in units relevant to the site type (e.g., units per month for manufacturing, pallets for warehouse).']
  site_code varchar [note: 'Internal or supplier-assigned unique code identifying this site location.']
  site_manager_name varchar [note: 'Name of the site manager or primary contact person responsible for this location.']
  site_name varchar [note: 'Business name or designation of the supplier site facility.']
  site_status varchar [note: 'Current operational status of the supplier site in the procurement system.']
  site_type varchar [note: 'Classification of the site based on its primary business function.']
  source_system_code varchar [note: 'The source system code of the supplier site record']
  state_province varchar [note: 'State, province, or administrative region of the supplier site.']
  supplier_site_status varchar [note: 'The supplier site status of the supplier site record']
  time_zone varchar [note: 'IANA time zone identifier for the site location, used for scheduling deliveries and coordinating communications.']
  uom varchar [note: 'The uom of the supplier site record']
  updated_timestamp timestamp [note: 'The updated timestamp of the supplier site record']
  vmi_enabled boolean [note: 'Indicates whether this site participates in a VMI program where the supplier manages inventory levels at the buyer\'s location.']

  Note: 'Physical manufacturing, warehouse, or office locations associated with a supplier. Captures site address, site type (manufacturing/warehouse/office/port), GS1 GLN, country of origin, site capacity, certifications held at site level (ISO 9001, ISO 22716, GMP), site-level lead time, and active status. Supports multi-site supplier relationships and origin traceability for regulatory compliance.'
}

Table procurement.supplier_contract {
  supplier_contract_id varchar [pk, note: 'Unique identifier for the supplier contract record. Primary key.']
  category_id varchar [note: 'Foreign key linking to product.category. Business justification: Category-level supplier contracts are standard in consumer goods procurement — a single contract governs all SKUs within a product category (e.g., all personal care, all home care). Category managers ']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: Supplier contracts are executed by a specific legal entity (company code) for legal enforceability, tax jurisdiction, and financial commitment reporting. In multi-entity consumer goods companies, cont']
  manufacturing_facility_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_facility. Business justification: Supply contracts in consumer goods are frequently scoped to specific manufacturing plants (ingredient supply agreements, packaging contracts). Direct FK enables plant-level contract coverage analysis,']
  marketing_brand_id varchar [note: 'Foreign key linking to marketing.marketing_brand. Business justification: Brand-level contract management: in consumer goods, private-label and licensed-brand manufacturing contracts are scoped to a specific brand. Linking supplier_contract to marketing_brand enables brand ']
  supplier_id varchar [note: 'Reference to the supplier party with whom this contract is negotiated.']
  supplier_site_id varchar [note: 'Foreign key linking to procurement.supplier_site. Business justification: A supplier contract in consumer goods procurement is frequently negotiated with and scoped to a specific supplier site (e.g., a particular manufacturing plant or warehouse). Adding supplier_site_id to']
  amount decimal(18,4) [note: 'The amount of the supplier contract record']
  approval_date date [note: 'Date when the contract was formally approved by authorized signatories and became legally binding.']
  approved_by varchar [note: 'Name or identifier of the person or role who provided final approval for this contract.']
  auto_renew_flag boolean [note: 'The auto renew flag of the supplier contract record']
  auto_renewal_flag boolean [note: 'Indicates whether the contract automatically renews at expiry unless explicitly terminated by either party.']
  code varchar [note: 'The supplier contract code of the supplier contract record']
  contract_document_reference varchar [note: 'Reference identifier or URL to the signed contract document stored in document management system (e.g., Veeva Vault, SharePoint).']
  contract_number varchar [note: 'Externally-known unique business identifier for the contract, used in procurement systems and supplier communications.']
  contract_status varchar [note: 'Current lifecycle state of the contract: draft for initial creation, pending approval for review workflow, active for in-force agreements, suspended for temporary holds, expired for naturally ended contracts, terminated for early cancellation, or renewed for extended agreements. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|expired|terminated|renewed — 7 candidates stripped; promote to reference product]']
  contract_type varchar [note: 'Classification of the contract structure: framework agreement for multi-material commitments, blanket order for recurring purchases, spot purchase for one-time buys, long-term agreement for strategic partnerships, consignment for supplier-owned inventory, or vendor managed inventory (VMI) for supplier-controlled replenishment.']
  contract_value_total decimal(18,2) [note: 'Total monetary value committed under this contract across all line items and periods, used for spend tracking and budget allocation.']
  created_timestamp timestamp [note: 'Timestamp when this contract record was first created in the procurement system.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary values in this contract (e.g., USD, EUR, GBP).']
  delivery_terms varchar [note: 'Agreed delivery conditions including lead times, delivery windows, and logistics requirements.']
  description varchar [note: 'The supplier contract description of the supplier contract record']
  effective_date date [note: 'Date when the contract becomes legally binding and pricing terms take effect.']
  effective_from date [note: 'The effective from of the supplier contract record']
  effective_until date [note: 'The effective until of the supplier contract record']
  end_date date [note: 'The end date of the supplier contract record']
  expiry_date date [note: 'Date when the contract naturally ends unless renewed or terminated earlier. Nullable for open-ended agreements.']
  governing_law varchar [note: 'Legal jurisdiction and governing law under which the contract is interpreted and enforced (e.g., State of Delaware, English Law).']
  incoterms varchar [note: 'International Commercial Terms defining the responsibilities of buyer and supplier for shipping, insurance, and risk transfer (e.g., FOB, CIF, DDP). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]']
  last_modified_timestamp timestamp [note: 'Timestamp when this contract record was last updated, used for change tracking and audit purposes.']
  maximum_order_quantity decimal(15,3) [note: 'Maximum quantity allowed per purchase order line under this contract, used to manage supplier capacity and volume commitments.']
  minimum_order_quantity decimal(15,3) [note: 'Minimum quantity that must be ordered per purchase order line to qualify for contract pricing, expressed in base unit of measure.']
  modified_by varchar [note: 'User identifier of the person who last modified this contract record.']
  name varchar [note: 'The supplier contract name of the supplier contract record']
  notes varchar [note: 'Free-text field for additional contract details, special terms, or internal comments not captured in structured fields.']
  payment_terms varchar [note: 'Agreed payment conditions such as net 30, net 60, or early payment discount terms (e.g., 2/10 net 30).']
  penalty_clause varchar [note: 'Terms defining financial penalties for supplier non-compliance, late delivery, quality failures, or other contractual breaches.']
  price_escalation_formula varchar [note: 'Mathematical formula or index reference used to adjust prices over time, such as CPI-based adjustments or commodity index linkage.']
  pricing_mechanism varchar [note: 'Method by which prices are determined: fixed price for static rates, cost plus for markup on supplier costs, market indexed for commodity-linked pricing, volume tiered for quantity-based discounts, or rebate based for retrospective incentives.']
  purchasing_group varchar [note: 'The buyer or procurement team assigned to manage this contract, responsible for execution and supplier relationship.']
  purchasing_organization varchar [note: 'The organizational unit responsible for negotiating and managing this contract, typically aligned with regional or divisional procurement teams.']
  quality_specification varchar [note: 'Reference to quality standards, specifications, or inspection criteria that supplied materials must meet (e.g., GMP, ISO 9001, internal spec codes).']
  quantity decimal(18,4) [note: 'The quantity of the supplier contract record']
  quantity_unit_of_measure varchar [note: 'Base unit of measure for quantity commitments (e.g., KG, LTR, EA, MT) aligned with material master data.']
  rebate_terms varchar [note: 'Description of volume-based or performance-based rebate conditions, including thresholds, percentages, and settlement periods.']
  renewal_notice_days varchar [note: 'The renewal notice days of the supplier contract record']
  renewal_notice_period_days varchar [note: 'Number of days prior to expiry that either party must provide notice to prevent auto-renewal or initiate renewal negotiations.']
  sds_required_flag boolean [note: 'Indicates whether supplier must provide Safety Data Sheets for hazardous materials covered by this contract, per OSHA and EPA regulations.']
  source_system_code varchar [note: 'The source system code of the supplier contract record']
  start_date date [note: 'The start date of the supplier contract record']
  supplier_contract_status varchar [note: 'The supplier contract status of the supplier contract record']
  sustainability_certification varchar [note: 'Required sustainability certifications for materials under this contract, such as FSC (Forest Stewardship Council) for paper/packaging or RSPO (Roundtable on Sustainable Palm Oil) for palm oil derivatives.']
  target_quantity_total decimal(15,3) [note: 'Aggregate quantity commitment across all materials and line items over the contract period, used for volume-based pricing and rebate calculations.']
  termination_date date [note: 'Actual date when the contract was terminated early, either by mutual agreement or due to breach. Null if contract expired naturally or is still active.']
  termination_reason varchar [note: 'Business reason for early termination, such as supplier performance issues, strategic sourcing changes, or mutual agreement.']
  title varchar [note: 'The title of the supplier contract record']
  total_contract_value decimal(18,2) [note: 'The total contract value of the supplier contract record']
  uom varchar [note: 'The uom of the supplier contract record']
  updated_timestamp timestamp [note: 'The updated timestamp of the supplier contract record']

  Note: 'Procurement contracts and framework agreements negotiated with suppliers for raw materials, packaging, and indirect goods. Captures contract header (number, type, effective/expiry dates, total value, currency, pricing mechanism, rebate terms, penalty clauses, auto-renewal, governing law) and contract line items (material/SKU, agreed unit price, price UoM, target quantity, MOQ, max order quantity, price validity period, escalation formula, line status). Tracks contract lifecycle from draft through active to expired/terminated. Enables granular price and volume commitment tracking at the material level. Owns all line-level detail as embedded attributes.'
}

Table procurement.contract_line {
  contract_line_id varchar [pk, note: 'Unique identifier for the contract line item. Primary key for this entity.']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Contract line items are charged to specific GL accounts for cost tracking; required for contract‑based accounting.']
  manufacturing_facility_id varchar [note: 'Reference to the manufacturing plant or distribution center that will receive the material. Used for multi-site procurement and logistics planning.']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: Raw material and ingredient supply contracts in consumer goods are negotiated at the material level, not the finished SKU level. Contract lines for ingredients, fragrances, and packaging components re']
  sku_id varchar [note: 'Reference to the material, raw material, packaging component, or indirect good being procured under this contract line. Links to the product master for specifications and attributes.']
  supplier_contract_id varchar [note: 'Reference to the parent supplier contract that contains this line item. Links this line to the master agreement governing terms, supplier, and overall contract lifecycle.']
  supplier_site_id varchar [note: 'Foreign key linking to procurement.supplier_site. Business justification: Contract lines in consumer goods procurement frequently specify the supplier site responsible for fulfilling the line item (e.g., a specific manufacturing plant for a raw material or packaging compone']
  amount decimal(18,4) [note: 'The amount of the contract line record']
  blocked_reason varchar [note: 'Explanation for why the contract line is blocked or inactive. Provides business context for procurement restrictions (e.g., quality issue, supplier non-compliance, price dispute).']
  code varchar [note: 'The contract line code of the contract line record']
  committed_quantity decimal(18,4) [note: 'The committed quantity of the contract line record']
  contract_line_status varchar [note: 'The contract line status of the contract line record']
  created_timestamp timestamp [note: 'Date and time when this contract line record was first created in the system. Used for audit trail and data lineage tracking.']
  cumulative_invoiced_value decimal(18,2) [note: 'Total invoiced value for all purchase orders released against this contract line to date. Used for spend tracking and budget management.']
  cumulative_ordered_quantity decimal(18,3) [note: 'Total quantity ordered against this contract line to date. Used for tracking contract utilization and remaining commitment.']
  cumulative_received_quantity decimal(18,3) [note: 'Total quantity received against this contract line to date. Used for tracking actual fulfillment and supplier performance.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the unit price. Defines the monetary denomination for all pricing on this contract line.']
  description varchar [note: 'The contract line description of the contract line record']
  effective_from date [note: 'The effective from of the contract line record']
  effective_until date [note: 'The effective until of the contract line record']
  incoterm_code varchar [note: 'International Commercial Terms code defining the division of costs and risks between buyer and supplier for this line item. Governs shipping, insurance, and transfer of ownership responsibilities. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]']
  incoterm_location varchar [note: 'Named place or port associated with the Incoterm. Specifies the geographic point where cost and risk transfer occurs (e.g., supplier factory, destination port, buyer warehouse).']
  last_modified_timestamp timestamp [note: 'Date and time when this contract line record was most recently updated. Used for change tracking and audit trail.']
  lead_time_days varchar [note: 'Standard procurement lead time in days from purchase order placement to expected goods receipt. Used for Material Requirements Planning (MRP) and demand planning calculations.']
  line_number varchar [note: 'Sequential line number within the parent contract. Used for ordering and referencing specific line items in procurement documents and communications.']
  line_status varchar [note: 'Current lifecycle status of the contract line. Controls whether purchase orders can be created against this line and tracks the lines operational state.']
  material_group_code varchar [note: 'Classification code grouping similar materials for procurement analysis and reporting. Enables spend analysis by category (e.g., raw materials, packaging, indirect goods).']
  maximum_order_quantity decimal(18,3) [note: 'Maximum quantity that can be ordered per purchase order release against this contract line. May reflect supplier capacity constraints or buyer inventory limits.']
  minimum_order_quantity decimal(18,3) [note: 'Minimum quantity that must be ordered per purchase order release against this contract line. Enforces supplier-defined minimum batch sizes for economic production or logistics.']
  name varchar [note: 'The contract line name of the contract line record']
  notes varchar [note: 'Free-text notes capturing additional terms, special instructions, or contextual information for this contract line. Used for operational guidance and exception handling.']
  order_quantity_uom varchar [note: 'Unit of measure for minimum and maximum order quantities. Defines the measurement basis for order quantity constraints.']
  payment_terms_code varchar [note: 'Code representing the agreed payment terms for this contract line (e.g., Net 30, Net 60, 2/10 Net 30). Defines the payment due date calculation and any early payment discounts.']
  price_escalation_formula varchar [note: 'Formula or reference to index-based pricing adjustment mechanism. Defines how unit price will be adjusted over time based on commodity indices, inflation, or other agreed factors.']
  price_unit varchar [note: 'Quantity of the material to which the unit price applies. For example, if price is per 100 units, this field would be 100. Used in conjunction with unit_price to calculate effective per-unit cost.']
  price_uom varchar [note: 'Unit of measure for the price unit. Defines the measurement basis for pricing (e.g., EA for each, KG for kilogram, L for liter, M for meter).']
  purchasing_group_code varchar [note: 'Code identifying the procurement team or buyer responsible for managing this contract line. Used for workload distribution and accountability tracking.']
  quality_inspection_required boolean [note: 'Indicates whether incoming goods for this contract line must undergo quality inspection before acceptance. Enforces Good Manufacturing Practice (GMP) and quality assurance requirements.']
  quantity decimal(18,4) [note: 'The quantity of the contract line record']
  source_system_code varchar [note: 'The source system code of the contract line record']
  storage_location_code varchar [note: 'Code identifying the specific storage location within the plant where the material will be received and stored. Used for warehouse management and inventory tracking.']
  sustainability_certification varchar [note: 'Sustainability or ethical sourcing certification required for the material on this contract line. Supports compliance with corporate sustainability commitments and regulatory requirements. [ENUM-REF-CANDIDATE: FSC|RSPO|PEFC|Rainforest Alliance|Fair Trade|Organic|None — 7 candidates stripped; promote to reference product]']
  target_quantity decimal(18,3) [note: 'Planned or target quantity of material to be procured over the contract validity period. Used for volume commitment tracking and supplier capacity planning.']
  target_quantity_uom varchar [note: 'Unit of measure for the target quantity. Defines how the target volume is measured (e.g., EA, KG, L, M).']
  tax_code varchar [note: 'Tax classification code determining the applicable tax rate and tax jurisdiction for this contract line. Used for tax calculation and compliance reporting.']
  unit_price decimal(18,4) [note: 'Agreed price per unit of measure for the material or service. This is the base price before any discounts, surcharges, or escalations are applied.']
  uom varchar [note: 'The uom of the contract line record']
  updated_timestamp timestamp [note: 'The updated timestamp of the contract line record']
  validity_end_date date [note: 'Date on which the pricing and terms on this contract line expire. Purchase orders can reference this line only on or before this date. Nullable for open-ended agreements.']
  validity_start_date date [note: 'Date from which the pricing and terms on this contract line become effective. Purchase orders can reference this line only on or after this date.']
  valid_from date [note: 'The valid from of the contract line record']
  valid_to date [note: 'The valid to of the contract line record']

  Note: 'Individual line items within a supplier contract specifying material, packaging component, or service being procured. Captures material/SKU reference, agreed unit price, price unit of measure, target quantity, MOQ, maximum order quantity, price validity period, price escalation formula, and contract line status. Enables granular price and volume commitment tracking at the material level.'
}

Table procurement.purchase_requisition {
  purchase_requisition_id varchar [pk, note: 'Unique identifier for the purchase requisition record. Primary key.']
  approved_supplier_list_id varchar [note: 'Foreign key linking to procurement.approved_supplier_list. Business justification: When a purchase requisition is raised, procurement policy requires validation against the Approved Supplier List (ASL) to confirm the preferred supplier is authorized for the requested material. Addin']
  budget_id varchar [note: 'Foreign key linking to marketing.marketing_budget. Business justification: Marketing budget governance: purchase requisitions for marketing spend must be validated against the marketing budget at requisition stage. This link enables budget availability checks and committed-s']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: Marketing procurement procure-to-pay: requisitions for agency services, promotional materials, and media buys are raised against specific campaigns. Linking purchase_requisition to campaign enables ca']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Purchase requisitions reference GL accounts for budget checking, commitment accounting, and spend categorization before PO creation. \'general_ledger_account\' is a denormalized plain attribute on purch']
  manufacturing_facility_id varchar [note: 'Identifier of the manufacturing plant or facility requesting the materials or services.']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: Purchase requisitions for raw materials and packaging components in consumer goods manufacturing reference the material master, not the finished SKU. MRP-generated requisitions for ingredients and com']
  preferred_supplier_id varchar [note: 'Identifier of the preferred or recommended supplier for this requisition, based on contracts or sourcing strategy.']
  primary_purchase_cost_center_id varchar [note: 'The purchase cost center id of the purchase requisition record']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Requisitions need profit‑center tagging for budgeting and forecast alignment; used in spend planning reports.']
  sku_id varchar [note: 'Identifier of the material master record being requested, applicable for material requisitions.']
  supplier_contract_id varchar [note: 'Identifier of the purchasing contract or outline agreement against which this requisition should be fulfilled.']
  supply_network_node_id varchar [note: 'Foreign key linking to supply.network_node. Business justification: Requisitions must be tied to the network node where the material is needed for accurate supply planning and ATP calculations.']
  amount decimal(18,4) [note: 'The amount of the purchase requisition record']
  approval_level varchar [note: 'Current approval level in the multi-tier approval workflow (e.g., 1 for manager, 2 for director, 3 for VP).']
  approval_status varchar [note: 'The approval status of the purchase requisition record']
  approval_workflow_reference varchar [note: 'Identifier of the approval workflow instance governing this requisition, based on value thresholds and organizational rules.']
  approved_date date [note: 'Date when the purchase requisition received final approval and became eligible for purchase order creation.']
  code varchar [note: 'The purchase requisition code of the purchase requisition record']
  created_timestamp timestamp [note: 'Timestamp when the purchase requisition record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the estimated value (e.g., USD, EUR, GBP).']
  description varchar [note: 'The purchase requisition description of the purchase requisition record']
  effective_from date [note: 'The effective from of the purchase requisition record']
  effective_until date [note: 'The effective until of the purchase requisition record']
  estimated_total_value decimal(18,2) [note: 'Total estimated value of the purchase requisition (quantity × estimated unit price), used for budget control and approval routing.']
  estimated_unit_price decimal(18,4) [note: 'Estimated price per unit of the requested material or service, used for budgeting and approval thresholds.']
  internal_order_number varchar [note: 'Internal order number for tracking costs related to specific internal activities or campaigns.']
  last_modified_timestamp timestamp [note: 'Timestamp when the purchase requisition record was last updated.']
  material_group_code varchar [note: 'Classification code grouping similar materials for procurement and reporting purposes (e.g., raw materials, packaging, indirect goods).']
  name varchar [note: 'The purchase requisition name of the purchase requisition record']
  notes varchar [note: 'Additional free-text notes or special instructions provided by the requester for procurement or supplier reference.']
  priority varchar [note: 'Business priority level indicating urgency of the procurement request, used for expediting and resource allocation.']
  purchase_requisition_status varchar [note: 'Current lifecycle status of the purchase requisition in the approval and procurement workflow. [ENUM-REF-CANDIDATE: draft|submitted|approved|rejected|partially_ordered|fully_ordered|closed|cancelled — 8 candidates stripped; promote to reference product]']
  purchasing_group_code varchar [note: 'Code of the purchasing group (buyer team) responsible for processing this requisition.']
  purchasing_organization_code varchar [note: 'Code of the purchasing organization responsible for procuring the requested materials or services.']
  quantity decimal(18,4) [note: 'The quantity of the purchase requisition record']
  quantity_requested decimal(18,3) [note: 'Quantity of material or service units requested in the purchase requisition.']
  rejection_reason varchar [note: 'Free-text explanation provided by the approver if the requisition was rejected.']
  requested_date date [note: 'Date when the purchase requisition was created or submitted by the requesting department.']
  requester_email varchar [note: 'Email address of the employee who created the requisition, used for notifications and approvals.']
  requester_name varchar [note: 'Full name of the employee who created the purchase requisition.']
  required_date date [note: 'The required date of the purchase requisition record']
  required_delivery_date date [note: 'Date by which the requested materials or services must be delivered to meet operational or production requirements.']
  requisition_date date [note: 'The requisition date of the purchase requisition record']
  requisition_number varchar [note: 'Business identifier for the purchase requisition, typically system-generated and externally visible to requesters and procurement teams.']
  requisition_status varchar [note: 'The requisition status of the purchase requisition record']
  requisition_type varchar [note: 'Classification of the purchase requisition based on procurement scenario: standard purchase, subcontracting, consignment, stock transfer, service procurement, or third-party order.']
  sds_required_flag boolean [note: 'Indicates whether a Safety Data Sheet is required for the requested material due to hazardous or regulated chemical content.']
  source_of_supply varchar [note: 'Recommended or assigned source for fulfilling the requisition (preferred supplier, existing contract, stock transfer, external procurement, internal production).']
  source_system_code varchar [note: 'The source system code of the purchase requisition record']
  sustainability_flag boolean [note: 'Indicates whether the requisition is for sustainably sourced materials (FSC-certified, RSPO-certified, or other sustainability standards).']
  total_estimated_value decimal(18,2) [note: 'The total estimated value of the purchase requisition record']
  unit_of_measure varchar [note: 'Unit in which the requested quantity is expressed (e.g., KG, L, EA, M, BOX).']
  uom varchar [note: 'The uom of the purchase requisition record']
  updated_timestamp timestamp [note: 'The updated timestamp of the purchase requisition record']
  wbs_element varchar [note: 'Project work breakdown structure element for project-related requisitions, used for project cost tracking.']

  Note: 'Internal purchase requisition (PR) raised by manufacturing, R&D, marketing, or other departments requesting procurement of raw materials, packaging, or indirect goods. Captures requisition number, requesting cost center, material/service description, required quantity, unit of measure, required delivery date, estimated value, approval workflow status, and source of supply recommendation. Feeds the purchase order creation process and supports budget control and spend governance.'
}

Table procurement.purchase_order {
  purchase_order_id varchar [pk, note: 'Unique identifier for the purchase order. Primary key for the purchase order entity.']
  approved_supplier_list_id varchar [note: 'Foreign key linking to procurement.approved_supplier_list. Business justification: A purchase order as a whole is issued to an ASL-approved supplier for a specific material category or plant. Adding approved_supplier_list_id at the PO header level enables header-level ASL compliance']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: Campaign Procurement Tracking: PO for promotional items is linked to the specific marketing campaign driving the purchase, used in spend attribution reports.']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: Purchase orders are issued by a specific legal entity (company code) for intercompany procurement, tax jurisdiction determination, and financial consolidation. \'company_code\' exists as a denormalized ']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Required for PO cost allocation in financial reporting; finance tracks expenses per cost center, obvious to procurement analysts.']
  manufacturing_facility_id varchar [note: 'Reference to the manufacturing plant, distribution center, or facility where goods will be delivered. Critical for logistics planning and inventory allocation.']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: Required for Production‑Order‑Purchase‑Order traceability report linking each PO to the specific production order it fulfills.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Enables profit‑center profitability analysis of procurement spend; standard in consumer‑goods for margin reporting.']
  purchase_requisition_id varchar [note: 'Reference to the internal purchase requisition that triggered this purchase order. Links procurement execution to demand origination for budget tracking and approval audit.']
  sales_order_id varchar [note: 'Foreign key linking to sales.order. Business justification: Make‑to‑order production requires linking each sales order to its originating purchase order for planning and cost tracking.']
  supplier_contract_id varchar [note: 'Reference to the master procurement contract or blanket agreement under which this purchase order is issued. Used for contract compliance, pricing validation, and spend aggregation.']
  supplier_id varchar [note: 'Reference to the supplier from whom materials or services are being procured. Links to supplier master data.']
  supplier_site_id varchar [note: 'The supplier site id of the purchase order record']
  supply_network_node_id varchar [note: 'Foreign key linking to supply.network_node. Business justification: PO execution needs the destination network node to plan inbound shipments, track OTIF, and reconcile inventory at the correct node.']
  amount decimal(18,4) [note: 'The amount of the purchase order record']
  approval_date timestamp [note: 'Timestamp when the purchase order received final approval and was released for transmission to the supplier. Used for procurement cycle time measurement and approval workflow audit.']
  approval_status varchar [note: 'The approval status of the purchase order record']
  approved_by varchar [note: 'User ID or name of the person who provided final approval for this purchase order. Used for authorization audit and segregation of duties compliance.']
  cancellation_date date [note: 'Date when the purchase order was cancelled before completion. Used for supplier performance analysis, demand forecast accuracy, and procurement exception tracking.']
  cancellation_reason varchar [note: 'Free-text explanation for why the purchase order was cancelled. Examples: demand change, supplier unable to fulfill, duplicate order, pricing dispute. Used for root cause analysis and process improvement.']
  closed_date date [note: 'Date when the purchase order was administratively closed after all goods were received, invoices verified, and no further activity expected. Used for procurement lifecycle completion tracking.']
  code varchar [note: 'The purchase order code of the purchase order record']
  confirmed_delivery_date date [note: 'Date confirmed by the supplier for delivery. May differ from requested date due to supplier capacity, lead times, or material availability. Used for OTIF variance analysis.']
  created_timestamp timestamp [note: 'Timestamp when the purchase order record was first created in the system. Used for audit trail, procurement cycle time analysis, and data lineage tracking.']
  currency_code varchar [note: 'Three-letter ISO currency code for all monetary amounts on this purchase order. Used for foreign exchange management and financial consolidation.']
  description varchar [note: 'The purchase order description of the purchase order record']
  edi_status varchar [note: 'Status of EDI transmission to the supplier. Tracks whether PO was successfully sent via EDI 850, acknowledged via EDI 855, or encountered transmission errors. Critical for automated supplier integration.']
  edi_transmission_date timestamp [note: 'Timestamp when the purchase order was transmitted to the supplier via EDI. Used for supplier response time tracking and transmission audit.']
  effective_from date [note: 'The effective from of the purchase order record']
  effective_until date [note: 'The effective until of the purchase order record']
  freight_amount decimal(18,2) [note: 'Transportation and logistics charges associated with this purchase order. May be supplier-charged or third-party logistics costs.']
  goods_receipt_required boolean [note: 'Indicator whether physical goods receipt posting is required for this purchase order. True for materials, false for services or non-stock items. Controls three-way match process.']
  incoterms varchar [note: 'International commercial terms defining the division of costs, risks, and responsibilities between buyer and supplier for transportation and delivery. Examples: FOB (Free On Board), CIF (Cost Insurance Freight), DDP (Delivered Duty Paid). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]']
  incoterms_location varchar [note: 'Named place or port specified in the Incoterms clause where risk and cost transfer occurs. Examples: Shanghai Port, Supplier Warehouse, Buyer Plant.']
  invoice_receipt_required boolean [note: 'Indicator whether invoice verification is required before payment. Controls accounts payable workflow and three-way match completion.']
  modified_timestamp timestamp [note: 'Timestamp when the purchase order record was last updated. Used for change tracking, audit trail, and data synchronization across systems.']
  name varchar [note: 'The purchase order name of the purchase order record']
  net_order_value decimal(18,2) [note: 'Total purchase order value including taxes and freight. Represents the complete financial commitment to the supplier.']
  notes varchar [note: 'The notes of the purchase order record']
  order_date date [note: 'Date when the purchase order was created and issued to the supplier. Principal business event timestamp for procurement lead time calculation and supplier performance measurement.']
  payment_terms varchar [note: 'Code defining payment conditions such as net days, early payment discounts, and due date calculation. Examples: NET30, 2/10NET30, NET60. Critical for cash flow management and supplier relationship terms.']
  po_number varchar [note: 'Externally-known business identifier for the purchase order. Used for supplier communication, EDI transactions, and cross-system reference.']
  po_status varchar [note: 'Current lifecycle status of the purchase order. Tracks progression from creation through approval, supplier confirmation, goods receipt, and closure. Critical for procurement workflow management and OTIF tracking. [ENUM-REF-CANDIDATE: draft|submitted|approved|confirmed|in_transit|partially_received|fully_received|closed|cancelled — 9 candidates stripped; promote to reference product]']
  po_type varchar [note: 'Classification of the purchase order based on procurement strategy. Standard for one-time orders, blanket for recurring deliveries against a master agreement, contract for long-term commitments, subcontracting for external manufacturing, consignment for supplier-owned inventory, framework for multi-release agreements.']
  priority varchar [note: 'Business priority level for this purchase order. Urgent for production-critical materials, high for near-term demand, normal for standard replenishment, low for non-critical items.']
  purchase_order_status varchar [note: 'The purchase order status of the purchase order record']
  purchasing_group varchar [note: 'Code identifying the buyer or procurement team responsible for this purchase order. Used for workload distribution, performance tracking, and supplier communication routing.']
  purchasing_organization varchar [note: 'Code identifying the organizational unit responsible for procurement. Used for spend analysis, contract authority, and supplier relationship ownership.']
  quantity decimal(18,4) [note: 'The quantity of the purchase order record']
  requested_delivery_date date [note: 'Date by which the buyer requests delivery of goods or completion of services. Used for production planning, inventory management, and supplier commitment tracking.']
  source_system_code varchar [note: 'The source system code of the purchase order record']
  supplier_confirmation_date timestamp [note: 'Timestamp when the supplier confirmed acceptance of the purchase order. Used for supplier responsiveness measurement and order commitment tracking.']
  supplier_confirmation_method varchar [note: 'Channel through which the supplier acknowledged the purchase order. EDI 855 for automated acknowledgment, supplier portal for web-based confirmation, email/phone/fax for manual confirmation.']
  sustainability_certification varchar [note: 'Sustainability or ethical sourcing certification required for materials on this purchase order. FSC for forest products, RSPO for palm oil, fair trade for ethical labor, organic for agricultural inputs. Critical for corporate sustainability reporting and regulatory compliance.']
  tax_amount decimal(18,2) [note: 'Total tax amount applicable to this purchase order. Includes VAT, GST, sales tax, or other jurisdiction-specific taxes.']
  total_amount decimal(18,2) [note: 'The total amount of the purchase order record']
  total_order_value decimal(18,2) [note: 'Total monetary value of the purchase order including all line items, before taxes and freight. Used for budget tracking, spend analysis, and supplier performance measurement.']
  total_value decimal(18,4) [note: 'The total value of the purchase order record']
  transport_mode varchar [note: 'Primary method of transportation for delivery. Used for logistics planning, lead time estimation, and freight cost allocation.']
  uom varchar [note: 'The uom of the purchase order record']
  updated_timestamp timestamp [note: 'The updated timestamp of the purchase order record']
  vmi_indicator boolean [note: 'Flag indicating whether this purchase order is part of a VMI program where the supplier manages inventory levels and replenishment. True for VMI orders, false for buyer-managed procurement.']

  Note: 'Purchase order issued to a supplier for raw materials, packaging components, or indirect goods/services. Captures PO header (number, type, order date, supplier, delivery plant, payment terms, incoterms, total value, currency, EDI status, lifecycle status) and PO line items (material number, ordered quantity, unit price, delivery dates, batch requirements, GR/IR indicators, line status). Includes supplier order confirmations (confirmed dates, quantities, variances, confirmation method EDI 855/portal/email) and delivery schedule lines (planned/confirmed dates, quantities, transport mode, delivery status). Core transactional entity for procurement execution, three-way match, OTIF tracking, and proactive supply risk management.'
}

Table procurement.po_line {
  po_line_id varchar [pk, note: 'Unique identifier for the purchase order line item. Primary key for the po_line product.']
  approved_supplier_list_id varchar [note: 'Foreign key linking to procurement.approved_supplier_list. Business justification: Each PO line item must be validated against the ASL to confirm the supplier is approved for the specific material or SKU being ordered. A direct FK from po_line to approved_supplier_list enables line-']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: Line-level campaign cost allocation: blanket marketing POs may have individual lines for different campaigns (agency retainer splits, multi-campaign production runs). po_line.campaign_id enables granu']
  contract_line_id varchar [note: 'The contract line id of the po line record']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: PO lines are assigned to cost centers for budget commitment accounting and spend allocation. This drives budget availability checks at requisition/PO creation. \'cost_center\' is a denormalized plain at']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Each PO line posts to a GL account; required for accurate ledger posting and audit trails.']
  manufacturing_facility_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_facility. Business justification: PO lines can be delivered to different plants than the PO header in multi-plant consumer goods operations. plant_code is a denormalized plain-text field. Direct FK enables plant-level spend analysis, ']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: PO lines for raw materials, ingredients, and packaging components reference the material master for receiving, quality inspection, and inventory management. In consumer goods, the majority of PO lines']
  purchase_order_id varchar [note: 'Foreign key reference to the parent purchase order header. Links this line item to its containing purchase order document.']
  sku_id varchar [note: 'Foreign key reference to the material master record. Identifies the raw material, packaging component, or indirect good being ordered on this line.']
  amount decimal(18,4) [note: 'The amount of the po line record']
  batch_management_indicator boolean [note: 'Flag indicating whether the material on this line is subject to batch management. When true, batch number must be assigned during goods receipt for traceability.']
  code varchar [note: 'The po line code of the po line record']
  confirmed_delivery_date date [note: 'Supplier-confirmed delivery date for this line item. May differ from the requested delivery date based on supplier capacity and lead time.']
  created_timestamp timestamp [note: 'Date and time when this purchase order line was originally created in the system. Used for audit trail and procurement cycle time analysis.']
  currency_code varchar [note: 'Three-letter ISO currency code for the net price. Indicates the currency in which the supplier will be paid.']
  deletion_indicator boolean [note: 'Flag indicating whether this purchase order line has been marked for deletion. When true, the line is logically deleted but retained for audit purposes.']
  delivery_date date [note: 'Requested or confirmed delivery date for this purchase order line. Target date by which the supplier should deliver the material to the receiving plant.']
  description varchar [note: 'The po line description of the po line record']
  effective_from date [note: 'The effective from of the po line record']
  effective_until date [note: 'The effective until of the po line record']
  goods_receipt_indicator boolean [note: 'Flag indicating whether goods receipt is required for this purchase order line. When true, physical receipt must be posted before invoice can be processed.']
  goods_received_quantity decimal(18,3) [note: 'Cumulative quantity of material received against this purchase order line. Updated with each goods receipt posting. Used for delivery tracking and invoice matching.']
  incoterm_code varchar [note: 'International Commercial Terms code defining the delivery terms and transfer of risk between buyer and supplier. Examples: EXW, FOB, CIF, DDP.']
  incoterm_location varchar [note: 'Specific location or port associated with the Incoterm. Defines the point where responsibility and risk transfer occurs.']
  invoice_receipt_indicator boolean [note: 'Flag indicating whether invoice verification is required for this line. When true, supplier invoice must be matched and verified against this PO line.']
  invoiced_quantity decimal(18,3) [note: 'Cumulative quantity invoiced by the supplier for this purchase order line. Used for three-way matching between PO, goods receipt, and invoice.']
  last_modified_timestamp timestamp [note: 'Date and time when this purchase order line was last updated. Tracks the most recent change to any field on the line item.']
  lead_time_days varchar [note: 'Standard procurement lead time in days from order placement to expected delivery. Used for demand planning and inventory replenishment calculations.']
  line_number varchar [note: 'Sequential line item number within the purchase order. Determines the ordering and position of this line in the PO document.']
  line_status varchar [note: 'Current lifecycle status of the purchase order line. Tracks progression from open through goods receipt to closure or cancellation.']
  line_total decimal(18,2) [note: 'The line total of the po line record']
  manufacturer_part_number varchar [note: 'Original manufacturer\'s part number for the material. Important for quality assurance and regulatory compliance tracking.']
  material_group varchar [note: 'Classification code grouping similar materials for procurement analysis and reporting. Used for spend categorization and supplier segmentation.']
  minimum_order_quantity decimal(18,3) [note: 'Minimum order quantity required by the supplier for this material. Procurement must order at least this quantity to meet supplier terms.']
  name varchar [note: 'The po line name of the po line record']
  net_order_value decimal(18,2) [note: 'Total net value of this purchase order line calculated as ordered quantity multiplied by net price. Excludes taxes and freight.']
  net_price decimal(18,4) [note: 'Net unit price for the material excluding taxes and additional charges. Base price agreed with the supplier per price unit.']
  notes varchar [note: 'The notes of the po line record']
  order_quantity decimal(18,4) [note: 'The order quantity of the po line record']
  ordered_quantity decimal(18,3) [note: 'Quantity of material ordered on this purchase order line. Represents the total amount requested from the supplier.']
  outstanding_quantity decimal(18,3) [note: 'Remaining quantity yet to be received on this purchase order line. Calculated as ordered quantity minus goods received quantity.']
  over_delivery_tolerance_percent decimal(5,2) [note: 'Acceptable percentage by which the supplier may over-deliver beyond the ordered quantity. Used to control goods receipt tolerances.']
  po_line_status varchar [note: 'The po line status of the po line record']
  price_unit varchar [note: 'Quantity unit for which the net price applies. For example, price per 100 units or per 1000 units. Used to calculate total line value.']
  purchasing_group varchar [note: 'Code identifying the procurement team or buyer responsible for this purchase order line. Used for workload distribution and performance tracking.']
  quantity decimal(18,4) [note: 'The quantity of the po line record']
  received_quantity decimal(18,4) [note: 'The received quantity of the po line record']
  requested_delivery_date date [note: 'The requested delivery date of the po line record']
  requisitioner_name varchar [note: 'Name of the employee or department that requested this material through a purchase requisition. Provides accountability and cost center traceability.']
  short_text varchar [note: 'Additional short text or notes specific to this purchase order line. Provides supplementary information for procurement and receiving teams.']
  source_system_code varchar [note: 'The source system code of the po line record']
  storage_location varchar [note: 'Specific storage location or warehouse area within the plant where the material will be stored upon receipt. Used for inventory positioning.']
  supplier_material_number varchar [note: 'Supplier\'s own material or part number for this item. Used for cross-referencing and communication with the supplier.']
  tax_code varchar [note: 'Tax classification code determining the applicable tax rate and jurisdiction for this line item. Used for invoice verification and tax reporting.']
  under_delivery_tolerance_percent decimal(5,2) [note: 'Acceptable percentage by which the supplier may under-deliver below the ordered quantity. Used to control goods receipt tolerances and automatic PO closure.']
  unit_of_measure varchar [note: 'Unit of measure for the ordered quantity. Standard codes such as KG (kilogram), LT (liter), EA (each), MT (metric ton), CS (case).']
  unit_price decimal(18,4) [note: 'The unit price of the po line record']
  uom varchar [note: 'The uom of the po line record']
  updated_timestamp timestamp [note: 'The updated timestamp of the po line record']

  Note: 'Individual line items on a purchase order specifying the material, packaging component, or service being ordered. Captures PO line number, material number, material description, ordered quantity, unit of measure, confirmed delivery date, net price, price unit, storage location, batch management flag, goods receipt indicator, invoice receipt indicator, and line status. Enables granular tracking of delivery and invoice matching at the material level.'
}

Table procurement.goods_receipt {
  goods_receipt_id varchar [pk, note: 'Primary key for goods_receipt']
  carrier_id varchar [note: 'Foreign key linking to logistics.carrier. Business justification: Carrier performance attribution at receiving: consumer goods receiving teams record the delivering carrier on goods receipts for damage claims, OTIF compliance tracking, and carrier scorecard input. \'']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Goods receipts trigger GR/IR (Goods Receipt/Invoice Receipt) clearing account postings to a specific GL account. This is a fundamental inventory valuation and accrual accounting process in consumer go']
  manufacturing_facility_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_facility. Business justification: Goods receipts are posted to a specific manufacturing plant for inventory valuation, GMP traceability, and regulatory compliance. receiving_plant_code is a denormalized plain-text representation of th']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: Goods receipts for raw materials and ingredients must reference the material master for quality inspection lot creation, shelf-life/FEFO tracking, and inventory valuation. goods_receipt has material_c']
  po_line_id varchar [note: 'Reference to the specific line item on the purchase order for which goods were received. Enables line-level tracking and three-way match.']
  production_order_id varchar [note: 'Foreign key linking to manufacturing.production_order. Business justification: In MRP-driven consumer goods manufacturing, goods receipts of raw materials are triggered by specific production orders. Linking GR to production_order enables production cost settlement, material con']
  purchase_order_id varchar [note: 'Reference to the purchase order against which goods were received. Links this goods receipt to the originating procurement document.']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Finished goods receipts from contract manufacturers and private label suppliers reference the SKU for inventory posting, FEFO shelf-life tracking, and quality release in consumer goods. goods_receipt ']
  supplier_id varchar [note: 'Reference to the supplier or vendor who delivered the goods. Used for supplier performance scorecards and VMI reconciliation.']
  supplier_site_id varchar [note: 'Foreign key linking to procurement.supplier_site. Business justification: Goods are physically shipped FROM a specific supplier site. goods_receipt currently has supplier_id but lacks supplier_site_id, creating a gap in traceability. Knowing the originating site is critical']
  supply_network_node_id varchar [note: 'Foreign key linking to supply.network_node. Business justification: Inbound logistics requires linking each goods receipt to the warehouse node for accurate inventory updates and OTIF reporting.']
  accepted_quantity decimal(18,4) [note: 'The accepted quantity of the goods receipt record']
  amount decimal(18,4) [note: 'The amount of the goods receipt record']
  batch_number varchar [note: 'The supplier-provided or internally-assigned batch or lot number for traceability. Critical for quality management, recalls, and FEFO inventory management.']
  certificate_of_analysis_received_flag boolean [note: 'Indicates whether the supplier-provided Certificate of Analysis was received with the shipment. Required for GMP compliance and quality assurance.']
  code varchar [note: 'The goods receipt code of the goods receipt record']
  created_timestamp timestamp [note: 'The system timestamp when this goods receipt record was first created in the database. Used for audit trails and data lineage.']
  currency_code varchar [note: 'The three-letter ISO 4217 currency code in which the valuation amount is expressed. Typically the company code currency.']
  delivery_note_number varchar [note: 'The supplier-provided delivery note or packing slip number accompanying the shipment. Used for cross-referencing and dispute resolution.']
  description varchar [note: 'The goods receipt description of the goods receipt record']
  document_date date [note: 'The date printed on the supplier delivery note or packing slip. May differ from posting date due to processing delays.']
  effective_from date [note: 'The effective from of the goods receipt record']
  effective_until date [note: 'The effective until of the goods receipt record']
  expiry_date date [note: 'The date by which the received material must be consumed or disposed of. Used for FEFO (First Expired First Out) inventory rotation and shelf-life management.']
  goods_receipt_status varchar [note: 'The goods receipt status of the goods receipt record']
  gr_document_number varchar [note: 'The externally-known unique document number assigned to this goods receipt transaction. Used for audit trails, supplier communication, and three-way match processing.']
  gr_reversal_flag boolean [note: 'Indicates whether this goods receipt has been reversed (cancelled). True means the inventory posting has been negated due to return-to-vendor or data correction.']
  gr_status varchar [note: 'Current lifecycle status of the goods receipt. Indicates whether the receipt is active, has been reversed, or is awaiting quality inspection clearance.']
  inspection_lot_number varchar [note: 'The unique identifier for the quality inspection lot created for this goods receipt. Links to QM inspection results and certificate of analysis.']
  last_modified_timestamp timestamp [note: 'The system timestamp when this goods receipt record was last updated. Used for change tracking and audit trails.']
  lot_number varchar [note: 'The lot number of the goods receipt record']
  manufacturing_date date [note: 'The date on which the material was produced by the supplier. Used for shelf-life calculation and quality assurance.']
  movement_type varchar [note: 'The SAP movement type code that classifies the nature of the goods receipt transaction (e.g., 101 for GR against PO, 122 for return delivery). Determines inventory and financial posting logic.']
  name varchar [note: 'The goods receipt name of the goods receipt record']
  notes varchar [note: 'The notes of the goods receipt record']
  otif_compliance_flag boolean [note: 'Indicates whether this goods receipt met the On Time In Full criteria (received on or before requested date with full ordered quantity). Used for supplier performance scorecards.']
  posting_date date [note: 'The business date on which the goods receipt was posted to inventory. This is the principal business event timestamp for inventory valuation and OTIF measurement.']
  quality_inspection_required_flag boolean [note: 'Indicates whether the received goods must undergo quality inspection before being released for use. True triggers QM workflow and blocks stock until clearance.']
  quality_status varchar [note: 'The quality status of the goods receipt record']
  quantity decimal(18,4) [note: 'The quantity of the goods receipt record']
  receipt_date date [note: 'The receipt date of the goods receipt record']
  receipt_number varchar [note: 'The receipt number of the goods receipt record']
  receipt_status varchar [note: 'The receipt status of the goods receipt record']
  received_quantity decimal(18,3) [note: 'The physical quantity of goods received and accepted into inventory. This is the principal quantitative fact for this transaction.']
  rejected_quantity decimal(18,4) [note: 'The rejected quantity of the goods receipt record']
  remarks varchar [note: 'Free-text field for capturing additional notes, exceptions, or special handling instructions related to this goods receipt. Used for operational communication and audit context.']
  reversal_document_number varchar [note: 'The document number of the reversing goods receipt transaction, if this receipt was cancelled. Links to the offsetting inventory movement.']
  reversal_reason_code varchar [note: 'The business reason why this goods receipt was reversed. Used for root cause analysis and process improvement.']
  source_system_code varchar [note: 'The source system code of the goods receipt record']
  storage_location_code varchar [note: 'The specific storage location or warehouse zone within the receiving plant where goods were placed. Used for inventory positioning and picking optimization.']
  sustainable_sourcing_certification varchar [note: 'The sustainability certification standard under which the received material was sourced (e.g., FSC for paper/packaging, RSPO for palm oil). Supports ESG reporting and sustainable sourcing initiatives.']
  unit_of_measure varchar [note: 'The unit in which the received quantity is expressed (e.g., KG for kilograms, EA for each, L for liters). Must align with material master UOM.']
  unit_price decimal(18,4) [note: 'The per-unit price used for inventory valuation at the time of goods receipt. May be standard cost, moving average price, or PO price depending on valuation method.']
  uom varchar [note: 'The uom of the goods receipt record']
  updated_timestamp timestamp [note: 'The updated timestamp of the goods receipt record']
  valuation_amount decimal(18,2) [note: 'The total inventory value of the received goods in the company currency, calculated as received quantity multiplied by standard or moving average price. Used for financial posting and COGS calculation.']

  Note: 'Goods receipt (GR) event recorded when raw materials, packaging, or indirect goods are physically received at a plant or distribution center against a purchase order. Captures GR document number, posting date, receiving plant, storage location, received quantity per line, unit of measure, batch number, FEFO expiry date, quality inspection flag, movement type, and GR status. Triggers inventory update and three-way match process. Supports GR reversal and return-to-vendor scenarios.'
}

Table procurement.supplier_invoice {
  supplier_invoice_id varchar [pk, note: 'Unique identifier for the supplier invoice record. Primary key.']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: Supplier invoices are posted against a specific legal entity (company code) for multi-entity AP accounting, tax reporting, and financial statement consolidation. Every AP posting in consumer goods req']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Invoices are allocated to cost centers for expense tracking; required by internal budgeting controls.']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: AP invoices must map to a GL account for posting; essential for financial consolidation.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Profit‑center allocation of supplier invoices supports profitability analysis of purchased goods.']
  purchase_order_id varchar [note: 'Reference to the purchase order against which this invoice was issued.']
  supplier_contract_id varchar [note: 'Foreign key linking to procurement.supplier_contract. Business justification: Supplier invoices in consumer goods procurement are often validated against the governing contract (pricing, payment terms, rebate clauses). While the chain supplier_invoice → purchase_order → supplie']
  supplier_id varchar [note: 'Reference to the supplier who issued this invoice.']
  supplier_site_id varchar [note: 'Foreign key linking to procurement.supplier_site. Business justification: Supplier invoices are issued from a specific supplier site (billing location). Adding supplier_site_id to supplier_invoice enables site-level invoice tracking, supports multi-site supplier billing rec']
  amount decimal(18,4) [note: 'The amount of the supplier invoice record']
  approved_by varchar [note: 'User ID or name of the person who approved the invoice for payment.']
  approved_timestamp timestamp [note: 'Timestamp when the invoice was approved for payment.']
  baseline_date date [note: 'The baseline date used for calculating payment due date and cash discount periods.']
  blocking_reason_code varchar [note: 'Code indicating why the invoice is blocked from payment, if applicable. Empty if not blocked.']
  blocking_reason_description varchar [note: 'Detailed description of the reason the invoice is blocked from payment.']
  cash_discount_days varchar [note: 'The number of days within which payment must be made to qualify for the cash discount.']
  cash_discount_percentage decimal(5,2) [note: 'The percentage discount available for early payment per payment terms.']
  code varchar [note: 'The supplier invoice code of the supplier invoice record']
  created_timestamp timestamp [note: 'Timestamp when the invoice record was first created in the system.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the invoice amounts.']
  description varchar [note: 'The supplier invoice description of the supplier invoice record']
  discount_amount decimal(18,2) [note: 'Total discount amount applied to the invoice, including early payment discounts.']
  due_date date [note: 'The due date of the supplier invoice record']
  effective_from date [note: 'The effective from of the supplier invoice record']
  effective_until date [note: 'The effective until of the supplier invoice record']
  fiscal_period varchar [note: 'The fiscal period (month) within the fiscal year in which the invoice was posted.']
  fiscal_year varchar [note: 'The fiscal year in which the invoice was posted.']
  goods_receipt_date date [note: 'The date goods were received or services were confirmed, used for three-way match validation.']
  gross_amount decimal(18,2) [note: 'Total invoice amount before taxes and adjustments.']
  invoice_amount decimal(18,4) [note: 'The invoice amount of the supplier invoice record']
  invoice_date date [note: 'The date the supplier issued the invoice. This is the principal business event timestamp for the invoice.']
  invoice_description varchar [note: 'Free-text description or notes about the invoice provided by the supplier or entered during processing.']
  invoice_number varchar [note: 'The unique invoice number assigned by the supplier. This is the externally-known identifier for the invoice.']
  invoice_receipt_date date [note: 'The date the invoice was received by the organization.']
  invoice_status varchar [note: 'Current lifecycle status of the invoice in the accounts payable workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|posted|paid|blocked|cancelled — 7 candidates stripped; promote to reference product]']
  invoice_type varchar [note: 'Classification of the invoice type indicating the nature of the transaction.']
  line_item_count varchar [note: 'Total number of line items included in this invoice.']
  match_status varchar [note: 'The match status of the supplier invoice record']
  modified_by varchar [note: 'User ID or name of the person who last modified the invoice record.']
  modified_timestamp timestamp [note: 'Timestamp when the invoice record was last modified.']
  name varchar [note: 'The supplier invoice name of the supplier invoice record']
  net_amount decimal(18,2) [note: 'Total invoice amount payable after taxes and discounts. This is the final amount due to the supplier.']
  notes varchar [note: 'The notes of the supplier invoice record']
  payment_date date [note: 'The actual date payment was made to the supplier.']
  payment_due_date date [note: 'The date by which payment is due to the supplier per payment terms.']
  payment_method varchar [note: 'The method by which payment will be made to the supplier.']
  payment_reference_number varchar [note: 'Reference number assigned when payment is made, linking the invoice to the payment transaction.']
  payment_status varchar [note: 'The payment status of the supplier invoice record']
  payment_terms_code varchar [note: 'Code representing the payment terms agreed with the supplier (e.g., Net 30, Net 60, 2/10 Net 30).']
  plant_code varchar [note: 'The plant or facility code where goods were received or services were rendered.']
  posting_date date [note: 'The date the invoice was posted to the financial accounting system.']
  quantity decimal(18,4) [note: 'The quantity of the supplier invoice record']
  source_system_code varchar [note: 'The source system code of the supplier invoice record']
  supplier_invoice_status varchar [note: 'The supplier invoice status of the supplier invoice record']
  tax_amount decimal(18,2) [note: 'Total tax amount charged on the invoice.']
  three_way_match_status varchar [note: 'Result of the three-way match validation comparing purchase order, goods receipt, and invoice at header level.']
  tolerance_check_result varchar [note: 'Indicates whether the invoice passed tolerance checks for price and quantity variances.']
  uom varchar [note: 'The uom of the supplier invoice record']
  updated_timestamp timestamp [note: 'The updated timestamp of the supplier invoice record']
  withholding_tax_amount decimal(18,2) [note: 'Amount of withholding tax deducted from the invoice payment per regulatory requirements.']
  withholding_tax_code varchar [note: 'Code representing the withholding tax type and rate applied.']
  created_by varchar [note: 'User ID or name of the person who created the invoice record in the system.']

  Note: 'Supplier invoice received for goods or services delivered against a purchase order. Captures invoice header (supplier-assigned number, invoice date, posting date, gross amount, tax amount, currency, payment due date, three-way match status, tolerance check result, blocking reason, processing status) and invoice line items (referenced PO line, material/service description, invoiced quantity, unit price, line amount, tax code, line-level match status). Supports granular three-way match (PO vs GR vs invoice) at both header and line level. Feeds accounts payable and COGS allocation. Owns all line-level detail as embedded attributes.'
}

Table procurement.invoice_line {
  invoice_line_id varchar [pk, note: 'Primary key for invoice_line']
  campaign_id varchar [note: 'Foreign key linking to marketing.campaign. Business justification: Campaign actual-spend reporting: invoice lines for agency fees, media production, and promotional materials must be attributed to campaigns for campaign ROI and budget vs. actual reporting. Direct cam']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Invoice lines are allocated to cost centers for cost accounting, budget consumption tracking, and departmental spend reporting. \'cost_center_code\' is a denormalized plain attribute on invoice_line tha']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Invoice line items are posted to specific GL accounts for expense categorization, AP subledger-to-GL reconciliation, and financial reporting. \'gl_account_code\' is a denormalized plain attribute that s']
  goods_receipt_id varchar [note: 'Reference to the goods receipt line that this invoice line matches against. Enables three-way match verification between PO, GR, and invoice.']
  material_id varchar [note: 'Reference to the material master record for the invoiced item. Links to the product or raw material being purchased.']
  po_line_id varchar [note: 'Reference to the purchase order line that this invoice line corresponds to. Critical for three-way match validation (PO vs GR vs Invoice).']
  primary_supplier_invoice_id varchar [note: 'Reference to the parent supplier invoice header. Links this line item to the overall invoice document.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Invoice lines are allocated to profit centers for P&L reporting by brand or business segment — a standard consumer goods requirement. \'profit_center_code\' is a denormalized plain attribute on invoice_']
  amount decimal(18,4) [note: 'The amount of the invoice line record']
  amount_variance decimal(18,2) [note: 'Total amount variance for this line calculated as the difference between invoiced amount and expected amount based on PO and GR.']
  batch_number varchar [note: 'Batch or lot number for the material on this invoice line. Critical for quality traceability, recall management, and FEFO inventory management.']
  blocking_reason varchar [note: 'Reason code or description explaining why this invoice line is blocked from payment. Common reasons include price variance, quantity variance, or missing goods receipt.']
  code varchar [note: 'The invoice line code of the invoice line record']
  country_of_origin varchar [note: 'Three-letter ISO 3166 country code indicating where the material was manufactured or produced. Required for customs, trade compliance, and sustainable sourcing reporting. [ENUM-REF-CANDIDATE: USA|CHN|DEU|IND|BRA|MEX|CAN|GBR|FRA|ITA|JPN|KOR|THA|VNM|POL|ESP — 16 candidates stripped; promote to reference product]']
  created_timestamp timestamp [note: 'Timestamp when this invoice line record was first created in the system. Audit field for data lineage and compliance.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts on this invoice line. Must match the invoice header currency. [ENUM-REF-CANDIDATE: USD|EUR|GBP|JPY|CNY|INR|CAD|AUD|BRL|MXN — 10 candidates stripped; promote to reference product]']
  delivery_note_number varchar [note: 'Supplier delivery note or packing slip number referenced on this invoice line. Used for traceability and dispute resolution.']
  description varchar [note: 'The invoice line description of the invoice line record']
  discount_amount decimal(18,2) [note: 'Absolute discount amount applied to this invoice line. Alternative to or in addition to discount_percentage.']
  discount_percentage decimal(5,2) [note: 'Line-level discount percentage applied by the supplier. Reduces the net amount before tax calculation.']
  effective_from date [note: 'The effective from of the invoice line record']
  effective_until date [note: 'The effective until of the invoice line record']
  expiry_date date [note: 'Expiration or best-before date for the material batch. Essential for FEFO inventory rotation and regulatory compliance in consumer goods.']
  invoice_line_status varchar [note: 'The invoice line status of the invoice line record']
  invoiced_quantity decimal(18,3) [note: 'Quantity of material or service units invoiced on this line. Used for three-way match comparison against PO quantity and GR quantity.']
  line_amount decimal(18,2) [note: 'The line amount of the invoice line record']
  line_gross_amount decimal(18,2) [note: 'Total gross amount for this invoice line including taxes and charges. Sum of line_net_amount and line_tax_amount.']
  line_net_amount decimal(18,2) [note: 'Net amount for this invoice line before taxes and charges. Typically calculated as invoiced_quantity multiplied by unit_price, adjusted for any line-level discounts.']
  line_number varchar [note: 'Sequential line item number within the invoice. Determines the ordering and position of this line in the invoice document.']
  line_tax_amount decimal(18,2) [note: 'Total tax amount applicable to this invoice line. Calculated based on the tax code and net amount.']
  line_text varchar [note: 'Free-form text field for additional notes, comments, or special instructions related to this invoice line. May include supplier remarks or internal annotations.']
  match_status varchar [note: 'Three-way match status for this invoice line. Indicates whether the line matches the PO and GR within acceptable tolerance thresholds.']
  modified_timestamp timestamp [note: 'Timestamp when this invoice line record was last modified. Tracks changes for audit trail and data quality monitoring.']
  name varchar [note: 'The invoice line name of the invoice line record']
  notes varchar [note: 'The notes of the invoice line record']
  payment_terms_code varchar [note: 'Payment terms applicable to this invoice line if different from header-level terms. Defines due date calculation and early payment discount eligibility.']
  plant_code varchar [note: 'Manufacturing plant or distribution center code where the material is received or consumed. Links procurement to manufacturing and supply chain operations.']
  price_variance decimal(18,2) [note: 'Difference between invoiced unit price and PO unit price. Used to identify pricing discrepancies and trigger approval workflows.']
  quantity decimal(18,4) [note: 'The quantity of the invoice line record']
  quantity_variance decimal(18,3) [note: 'Difference between invoiced quantity and goods receipt quantity. Positive values indicate over-invoicing; negative values indicate under-invoicing.']
  sds_document_number varchar [note: 'Reference number for the Safety Data Sheet associated with this material. Required for hazardous materials and chemical ingredients per OSHA and REACH regulations.']
  source_system_code varchar [note: 'The source system code of the invoice line record']
  storage_location_code varchar [note: 'Specific storage location within the plant where the material is stored. Provides granular inventory tracking.']
  sustainability_certification varchar [note: 'Sustainability or ethical sourcing certification applicable to this material. Examples include FSC for paper/packaging, RSPO for palm oil, or organic certifications.']
  tax_amount decimal(18,2) [note: 'The tax amount of the invoice line record']
  tax_code varchar [note: 'Tax jurisdiction and rate code applied to this invoice line. Determines the tax calculation method and rate percentage.']
  tax_rate_percentage decimal(5,2) [note: 'Tax rate percentage applied to this line. Derived from the tax code configuration.']
  unit_of_measure varchar [note: 'Unit of measure for the invoiced quantity. Must match the UOM on the corresponding PO line and goods receipt for proper three-way match. [ENUM-REF-CANDIDATE: EA|KG|LB|L|GAL|M|FT|BOX|CASE|PALLET|EACH|TON|MT — 13 candidates stripped; promote to reference product]']
  unit_price decimal(18,4) [note: 'Price per unit of measure as stated on the invoice line. Compared against PO unit price during invoice verification to identify price variances.']
  uom varchar [note: 'The uom of the invoice line record']
  updated_timestamp timestamp [note: 'The updated timestamp of the invoice line record']
  withholding_tax_amount decimal(18,2) [note: 'Amount of withholding tax deducted from this invoice line payment. Reduces the net payment to the supplier.']
  withholding_tax_code varchar [note: 'Withholding tax code for this invoice line. Applicable in jurisdictions requiring tax withholding at source for certain supplier payments.']

  Note: 'Individual line items on a supplier invoice corresponding to specific PO lines or service entry sheets. Captures invoice line number, referenced PO line, material/service description, invoiced quantity, unit price, line amount, tax code, and line-level match status. Enables granular three-way match (PO line vs GR line vs invoice line) and supports COGS allocation at the material level.'
}

Table procurement.approved_supplier_list {
  approved_supplier_list_id varchar [pk, note: 'Unique identifier for the approved supplier list entry. Primary key for the ASL record.']
  manufacturing_facility_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_facility. Business justification: In consumer goods, ASLs are plant-specific — a supplier may be approved only for certain manufacturing facilities based on GMP certification scope or regulatory registration. plant_code is a denormali']
  marketing_brand_id varchar [note: 'Foreign key linking to marketing.marketing_brand. Business justification: Brand-scoped supplier qualification: in consumer goods, approved supplier lists for packaging, ingredients, and promotional materials are maintained per brand. Linking approved_supplier_list to market']
  material_id varchar [note: 'Foreign key linking to product.material. Business justification: ASL qualification in consumer goods is primarily defined at the material/ingredient level — which suppliers are approved to provide each raw material, fragrance, or packaging component. This is a fund']
  supplier_contract_id varchar [note: 'Reference to the master purchasing contract or framework agreement governing this supplier-material relationship. Links to contract management system.']
  supplier_id varchar [note: 'Reference to the supplier authorized to supply materials or services. Links to the supplier master record.']
  supplier_site_id varchar [note: 'Foreign key linking to procurement.supplier_site. Business justification: ASL entries are typically site-specific — a supplier may be approved for supply from one manufacturing site but not another. Adding supplier_site_id allows the ASL to specify which physical site of th']
  amount decimal(18,4) [note: 'The amount of the approved supplier list record']
  approval_authority varchar [note: 'Name or role of the person or committee who authorized the supplier approval. Provides accountability and audit trail.']
  approval_basis varchar [note: 'Method or evidence used to grant supplier approval. Audit = on-site supplier audit; Certification = third-party certification (ISO, FSC, RSPO); Qualification test = material sample testing; Performance review = historical performance analysis; Risk assessment = supply chain risk evaluation; Legacy approval = pre-existing authorization.']
  approval_date date [note: 'Date when the supplier was approved for this material-plant combination. Represents the effective start of authorization.']
  approval_expiration_date date [note: 'Date when the current approval expires and requires re-evaluation. Null indicates indefinite approval subject to periodic review.']
  approval_status varchar [note: 'Current authorization status of the supplier for this material-plant combination. Approved = full authorization; Conditional = approved with restrictions; Blocked = temporarily prohibited; Delisted = permanently removed; Pending = under evaluation; Suspended = on hold pending review.']
  approved_supplier_list_status varchar [note: 'The approved supplier list status of the approved supplier list record']
  blocking_date date [note: 'Date when the supplier was blocked, delisted, or suspended. Null when status is approved, conditional, or pending.']
  blocking_reason varchar [note: 'Explanation for why the supplier is blocked, delisted, or suspended. Includes quality issues, compliance violations, delivery failures, financial instability, or ethical concerns. Null when status is approved or conditional.']
  code varchar [note: 'The approved supplier list code of the approved supplier list record']
  compliance_status varchar [note: 'Regulatory and policy compliance status for this supplier-material combination. Compliant = meets all requirements; Non-compliant = violations identified; Under review = compliance assessment in progress; Exempted = waiver granted.']
  conditional_terms varchar [note: 'Specific restrictions or requirements when approval status is conditional. Examples: reduced order quantities, enhanced inspection, expedited payment terms, or geographic limitations. Null when status is not conditional.']
  created_timestamp timestamp [note: 'Date and time when this ASL entry was first created in the system. Follows ISO 8601 format yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  currency_code varchar [note: 'The currency code of the approved supplier list record']
  delivery_rating varchar [note: 'Supplier delivery performance rating for this material-plant combination. A = excellent (>95% OTIF); B = good (90-95% OTIF); C = acceptable (85-90% OTIF); D = marginal (80-85% OTIF); F = failing (<80% OTIF).']
  description varchar [note: 'The approved supplier list description of the approved supplier list record']
  edi_enabled_flag boolean [note: 'Indicates whether electronic purchase orders and confirmations are enabled for this supplier-material-plant combination. True = EDI transactions supported; False = manual processing.']
  effective_date date [note: 'The effective date of the approved supplier list record']
  effective_from date [note: 'The effective from of the approved supplier list record']
  effective_until date [note: 'The effective until of the approved supplier list record']
  expiry_date date [note: 'The expiry date of the approved supplier list record']
  inspection_required_flag boolean [note: 'Indicates whether incoming goods from this supplier-material combination require quality inspection before goods receipt posting. True = inspection mandatory; False = direct posting allowed.']
  last_audit_date date [note: 'Date of the most recent supplier audit or site visit for this material-plant combination. Used to track audit currency and schedule follow-ups.']
  last_modified_by varchar [note: 'User ID or name of the person who last updated this ASL entry. Tracks change accountability.']
  last_modified_timestamp timestamp [note: 'Date and time when this ASL entry was last modified. Follows ISO 8601 format yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  lead_time_days varchar [note: 'Standard procurement lead time in days from PO issuance to goods receipt for this supplier-material-plant combination. Used for MRP and demand planning.']
  moq_quantity decimal(18,3) [note: 'Minimum order quantity required by the supplier for this material-plant combination. Used to enforce purchasing constraints in PO creation.']
  moq_unit varchar [note: 'Unit of measure for the minimum order quantity. Examples: KG (kilograms), EA (each), LT (liters), MT (metric tons). Follows ISO 80000 or UN/CEFACT standards.']
  name varchar [note: 'The approved supplier list name of the approved supplier list record']
  next_audit_date date [note: 'Scheduled date for the next supplier audit or site visit. Drives proactive supplier quality management.']
  notes varchar [note: 'Free-text notes and comments regarding the supplier approval, special handling instructions, historical issues, or other relevant information for procurement and quality teams.']
  preference_rank varchar [note: 'The preference rank of the approved supplier list record']
  preferred_supplier_flag boolean [note: 'Indicates whether this supplier is the preferred source for this material-plant combination. True = preferred supplier with priority allocation; False = approved but not preferred.']
  price_validity_end_date date [note: 'End date of the current pricing agreement. Null indicates open-ended pricing subject to change notification.']
  price_validity_start_date date [note: 'Start date of the current pricing agreement for this supplier-material-plant combination. Used to enforce valid pricing periods in PO creation.']
  qualification_level varchar [note: 'The qualification level of the approved supplier list record']
  quality_rating varchar [note: 'Supplier quality performance rating for this material-plant combination. A = excellent (>98% acceptance); B = good (95-98%); C = acceptable (90-95%); D = marginal (85-90%); F = failing (<85%). Derived from quality inspection results.']
  quantity decimal(18,4) [note: 'The quantity of the approved supplier list record']
  re_evaluation_due_date date [note: 'Scheduled date for the next supplier performance review or qualification audit. Drives proactive supplier management activities.']
  risk_category varchar [note: 'Supply chain risk classification for this supplier-material-plant combination. Low = stable supply, multiple sources; Medium = moderate dependency; High = single source or volatile region; Critical = business-critical material with supply constraints.']
  sole_source_flag boolean [note: 'Indicates whether this supplier is the only approved source for this material-plant combination. True = sole source (supply risk); False = multiple sources available.']
  source_system_code varchar [note: 'The source system code of the approved supplier list record']
  sustainability_certification varchar [note: 'Sustainability certifications held by the supplier for this material. Pipe-separated list of certifications: FSC (Forest Stewardship Council), RSPO (Roundtable on Sustainable Palm Oil), Fair Trade, Rainforest Alliance, B Corp, Carbon Neutral. Supports sustainable sourcing initiatives.']
  uom varchar [note: 'The uom of the approved supplier list record']
  updated_timestamp timestamp [note: 'The updated timestamp of the approved supplier list record']
  vmi_eligible_flag boolean [note: 'Indicates whether this supplier-material-plant combination is eligible for Vendor Managed Inventory programs. True = VMI enabled; False = traditional procurement.']
  created_by varchar [note: 'User ID or name of the person who created this ASL entry. Provides accountability and audit trail.']

  Note: 'Approved Supplier List (ASL) entry defining which suppliers are authorized to supply specific materials or spend categories to specific plants. Captures material/category, supplier, plant, approval status (approved/conditional/blocked/delisted), approval date, re-evaluation due date, approval basis (audit/certification/qualification test), and blocking reason. Enforces sourcing compliance and prevents unauthorized supplier usage in PO creation.'
}

Table marketing.marketing_brand {
  marketing_brand_id varchar [pk, note: 'Unique identifier for the brand record. Primary key for the brand master data product.']
  parent_brand_marketing_brand_id varchar [note: 'Reference to the parent brand in the brand hierarchy. Null for masterbrand level. Used to establish brand family relationships and roll-up reporting.']
  product_brand_id varchar [note: 'FK to authoritative SSOT table product.product_brand (cross-domain duplicate resolution).']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Brand P&L reporting in CPG requires each brand mapped to a profit center. Finance controllers and brand managers run brand contribution margin reports using this link. Without it, brand-level profitab']
  amount decimal(18,4) [note: 'The amount of the marketing brand record']
  annual_marketing_budget decimal(15,2) [note: 'Total allocated marketing investment for the brand for the fiscal year, including media spend, trade promotion, consumer promotion, and agency fees.']
  annual_revenue_target decimal(15,2) [note: 'Planned annual revenue goal for the brand in the base currency. Used for budget planning, performance tracking, and brand portfolio prioritization.']
  architecture_tier varchar [note: 'Classification of the brand within the corporate brand architecture hierarchy. Masterbrand represents the corporate umbrella, subbrand is a distinct offering under the masterbrand, endorsed carries both corporate and product brand, ingredient brand is a component brand, private label is retailer-owned, and house brand is a proprietary store brand.']
  awareness_percent decimal(5,2) [note: 'Percentage of target consumers who recognize or recall the brand when prompted or unprompted. Measured through consumer surveys and market research panels.']
  brand_category varchar [note: 'Primary product category or market segment in which the brand competes. Examples include personal care, household cleaning, health and wellness, beauty, food and beverage.']
  brand_code varchar [note: 'Unique alphanumeric code assigned to the brand for operational reference across systems. Used in SKU (Stock Keeping Unit) hierarchies, trade promotion systems, and financial reporting.']
  brand_description varchar [note: 'Detailed narrative describing the brand\'s purpose, value proposition, and positioning in the market. Used for internal reference and marketing brief development.']
  brand_name varchar [note: 'The official registered name of the brand as it appears on product packaging, marketing materials, and consumer-facing communications.']
  brand_status varchar [note: 'Operational status of the brand. Active indicates current market presence with ongoing marketing investment, inactive is temporarily paused, pending launch is approved but not yet in market, under review is strategic assessment phase, sunset is planned phase-out, and archived is historical record only.']
  brand_tier varchar [note: 'The brand tier of the marketing brand record']
  code varchar [note: 'The marketing brand code of the marketing brand record']
  consideration_percent decimal(5,2) [note: 'Percentage of target consumers who would consider purchasing the brand when making a category purchase decision. Key indicator of brand relevance and competitive positioning.']
  created_timestamp timestamp [note: 'Timestamp when the brand record was first created in the system. Used for data lineage and audit trail purposes.']
  currency_code varchar [note: 'The currency code of the marketing brand record']
  description varchar [note: 'The marketing brand description of the marketing brand record']
  discontinuation_date date [note: 'Date when the brand was officially discontinued or withdrawn from active marketing. Null for active brands. Used for portfolio rationalization reporting and historical analysis.']
  effective_from date [note: 'The effective from of the marketing brand record']
  effective_until date [note: 'The effective until of the marketing brand record']
  equity_score decimal(5,2) [note: 'Composite metric measuring the overall strength and value of the brand based on consumer awareness, perceived quality, brand associations, and loyalty. Typically scaled 0-100 with higher scores indicating stronger brand equity.']
  geographic_market_scope varchar [note: 'Geographic reach of the brand\'s distribution and marketing activities. Global indicates worldwide presence, regional covers multiple countries in a region, national is single-country, and local is sub-national markets.']
  global_brand_flag boolean [note: 'The global brand flag of the marketing brand record']
  guidelines_url varchar [note: 'URL or file path to the comprehensive brand guidelines document containing logo usage, color specifications, typography, tone of voice, and visual identity standards.']
  health_index decimal(10,4) [note: 'The brand health index of the marketing brand record']
  is_licensed_brand boolean [note: 'Boolean flag indicating whether the brand is operated under a licensing agreement from another entity. True indicates licensed brand, false indicates owned brand.']
  is_private_label boolean [note: 'Boolean flag indicating whether the brand is a private label or store brand owned by a retail customer rather than the manufacturer. True indicates private label, false indicates manufacturer-owned brand.']
  launch_date date [note: 'Date when the brand was first introduced to the market. Used for brand age calculations, anniversary campaigns, and lifecycle analysis.']
  lifecycle_stage varchar [note: 'Current stage of the brand in its market lifecycle. Development indicates pre-launch planning, launch is initial market introduction, growth is rapid expansion phase, maturity is stable market presence, decline is decreasing market share, revitalization is strategic renewal effort, and discontinued indicates end of active marketing. [ENUM-REF-CANDIDATE: development|launch|growth|maturity|decline|revitalization|discontinued — 7 candidates stripped; promote to reference product]']
  logo_asset_url varchar [note: 'URL or file path to the official brand logo asset in the digital asset management system. Used for marketing materials, packaging design, and digital campaigns.']
  market_share_pct decimal(7,4) [note: 'The market share pct of the marketing brand record']
  marketing_brand_status varchar [note: 'The marketing brand status of the marketing brand record']
  modified_timestamp timestamp [note: 'Timestamp when the brand record was last updated. Used for change tracking and data quality monitoring.']
  name varchar [note: 'The marketing brand name of the marketing brand record']
  notes varchar [note: 'The notes of the marketing brand record']
  nps_score decimal(5,2) [note: 'Net Promoter Score measuring consumer willingness to recommend the brand to others. Calculated as percentage of promoters minus percentage of detractors, ranging from -100 to +100.']
  owner varchar [note: 'Legal entity or business unit that owns the intellectual property rights to the brand. May differ from the manufacturing or distribution entity.']
  portfolio_role varchar [note: 'The portfolio role of the marketing brand record']
  positioning varchar [note: 'The brand positioning of the marketing brand record']
  positioning_statement varchar [note: 'Concise statement defining the brand\'s unique value proposition, competitive differentiation, and emotional benefit to the target consumer. Foundation for all marketing communications.']
  preference_percent decimal(5,2) [note: 'Percentage of target consumers who prefer this brand over competitive alternatives. Indicates brand loyalty and pricing power potential.']
  primary_color_hex varchar [note: 'Hexadecimal color code for the primary brand color used in packaging, marketing materials, and digital assets. Ensures consistent brand identity across touchpoints.']
  primary_distribution_channel varchar [note: 'Main channel through which the brand reaches consumers. Examples include mass retail, specialty retail, e-commerce, DTC (Direct to Consumer), professional/salon, or foodservice.']
  quantity decimal(18,4) [note: 'The quantity of the marketing brand record']
  som_percent decimal(5,2) [note: 'Brand\'s percentage of total category sales volume or value. Primary metric for competitive market position and growth tracking.']
  source_system_code varchar [note: 'The source system code of the marketing brand record']
  sov_percent decimal(5,2) [note: 'Brand\'s share of total advertising and promotional activity within the category, measured across paid media, earned media, and owned channels. Key indicator of marketing investment relative to competitors.']
  subcategory varchar [note: 'Specific subcategory within the broader brand category. Provides granular classification for competitive analysis and shelf placement strategy.']
  sustainability_certification varchar [note: 'Third-party sustainability certifications or eco-labels associated with the brand, such as FSC (Forest Stewardship Council), RSPO (Roundtable on Sustainable Palm Oil), or B Corp. Multiple certifications separated by semicolons.']
  target_consumer_segment varchar [note: 'Primary demographic and psychographic profile of the intended consumer audience for the brand. Includes age range, income level, lifestyle attributes, and purchase behaviors.']
  target_segment varchar [note: 'The target segment of the marketing brand record']
  target_som_percent decimal(5,2) [note: 'Strategic target for the brand\'s market share. Used for annual planning, performance evaluation, and resource allocation decisions.']
  target_sov_percent decimal(5,2) [note: 'Strategic target for the brand\'s share of voice in the category. Used for media planning and budget allocation decisions. Typically set to exceed current SOM (Share of Market) to drive growth.']
  trademark_expiration_date date [note: 'Date when the current trademark registration expires and requires renewal. Critical for maintaining legal protection of brand assets.']
  trademark_jurisdiction varchar [note: 'Geographic territories or countries where the brand trademark is registered and legally protected. May include multiple jurisdictions separated by semicolons.']
  trademark_registration_date date [note: 'Date when the trademark was officially registered with the relevant trademark authority. Used for renewal tracking and IP portfolio management.']
  trademark_registration_number varchar [note: 'Official registration number assigned by the trademark authority for the brand name, logo, or other protected brand elements. Used for legal protection and IP (Intellectual Property) management.']
  uom varchar [note: 'The uom of the marketing brand record']
  updated_timestamp timestamp [note: 'The updated timestamp of the marketing brand record']
  valuation_amount decimal(18,2) [note: 'Estimated financial value of the brand as an intangible asset. Calculated using income, market, or cost approaches for financial reporting and M&A (Mergers and Acquisitions) purposes.']

  Note: 'Master record for each brand in the Consumer Goods portfolio. Captures brand identity, positioning, architecture tier (masterbrand, subbrand, endorsed), target consumer segment, brand equity scores, SOV (Share of Voice) benchmarks, brand health KPI targets, and lifecycle stage. Serves as the SSOT for brand master data referenced across campaign, media, and trade promotion domains. [SSOT: authoritative table is product.product_brand; this table is a deprecated duplicate.] [SSOT: authoritative table is product.product_brand; this is a deprecated duplicate for concept \'brand\'.] [Non-authoritative; defers to SSOT product.product_brand for concept \'brand\'.]'
}

Table marketing.campaign {
  campaign_id varchar [pk, note: 'Unique identifier for the marketing campaign. Primary key.']
  agency_id varchar [note: 'FK to marketing.agency']
  budget_id varchar [note: 'Foreign key linking to marketing.marketing_budget. Business justification: Campaigns draw from approved marketing budgets. Linking campaign to marketing_budget enables campaign-level budget tracking, variance analysis (planned vs. actual spend against approved budget), and f']
  category_id varchar [note: 'Reference to the product category this campaign targets. Links to the category hierarchy.']
  consumer_segment_id varchar [note: 'Foreign key linking to marketing.consumer_segment. Business justification: Campaign already has target_segment_id pointing to the cross-domain marketing.segment entity. This new FK links campaign to the marketing domain\'s own consumer_segment master, which captures marketing-']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Campaign expense allocation requires charging campaign spend to a specific cost center for budgeting.']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Campaign costs are posted to a specific GL account to support detailed expense reporting.']
  hierarchy_id varchar [note: 'Foreign key linking to product.hierarchy. Business justification: CPG campaigns are planned at product hierarchy levels (division, portfolio, category group) for portfolio-level P&L reporting and brand architecture alignment. A campaign for \'Premium Skincare\' maps t']
  primary_sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Campaign planning and ROI attribution need a primary SKU reference to allocate budget and measure lift per product.']
  product_brand_id varchar [note: 'Foreign key linking to product.product_brand. Business justification: CPG campaigns are executed at product brand level (e.g., \'Dove\' campaign) for brand ROI tracking and trade promotion planning. campaign.marketing_brand_id links to marketing_brand, but product_brand i']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Campaign ROI and marketing spend attribution by brand/business unit P&L requires campaigns linked to profit centers. CPG marketing finance teams report campaign spend against profit center budgets. Co']
  target_segment_id varchar [note: 'Reference to the predefined consumer segment this campaign is designed to reach. Links to consumer segmentation master data.']
  trade_account_id varchar [note: 'Foreign key linking to sales.trade_account. Business justification: Campaigns are often targeted to specific key trade accounts; the marketing team needs to link each campaign to the account for promotion planning and performance reporting.']
  actual_end_date date [note: 'The actual date the campaign concluded. May differ from planned end date due to extensions, early termination, or performance-based adjustments.']
  actual_media_spend_amount decimal(18,2) [note: 'The actual total media spend incurred for this campaign, in the company\'s reporting currency. Includes all paid media costs across channels.']
  actual_production_cost_amount decimal(18,2) [note: 'The actual cost incurred for creative production, including all content creation, design, video production, and asset development expenses.']
  actual_spend decimal(15,2) [note: 'The actual spend of the campaign record']
  actual_start_date date [note: 'The actual date the campaign went live and began execution. May differ from planned start date due to operational adjustments.']
  amount decimal(18,4) [note: 'The amount of the campaign record']
  approved_timestamp timestamp [note: 'The date and time when this campaign was formally approved for execution by authorized stakeholders, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).']
  budget_amount decimal(15,2) [note: 'The budget amount of the campaign record']
  campaign_status varchar [note: 'Current lifecycle state of the campaign: draft (initial planning), planned (scheduled), approved (ready for execution), active (currently running), paused (temporarily suspended), completed (finished), or cancelled (terminated before completion). [ENUM-REF-CANDIDATE: draft|planned|approved|active|paused|completed|cancelled — 7 candidates stripped; promote to reference product]']
  campaign_type varchar [note: 'Classification of the campaign by execution approach: ATL (Above The Line - mass media), BTL (Below The Line - targeted), digital (online channels), shopper (in-store/retail), influencer (social media partnerships), or integrated (multi-channel).']
  channel_mix varchar [note: 'Comma-separated list or description of marketing channels used in the campaign (e.g., TV, digital display, social media, print, radio, OOH, in-store).']
  code varchar [note: 'Short alphanumeric code used to identify and track the campaign across systems, media buys, and analytics platforms.']
  country_codes varchar [note: 'Comma-separated list of three-letter ISO 3166-1 alpha-3 country codes where the campaign is executed (e.g., USA,CAN,MEX).']
  created_timestamp timestamp [note: 'The date and time when this campaign record was first created in the system, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).']
  creative_concept varchar [note: 'High-level description of the creative theme, messaging strategy, and visual identity used in the campaign.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts in this campaign record (e.g., USD, EUR, GBP).']
  description varchar [note: 'Detailed narrative description of the campaign\'s purpose, strategy, key messages, and expected outcomes.']
  effective_from date [note: 'The effective from of the campaign record']
  effective_until date [note: 'The effective until of the campaign record']
  end_date date [note: 'The end date of the campaign record']
  geography_scope varchar [note: 'Geographic reach of the campaign: global (worldwide), regional (multi-country region), national (single country), or local (city/metro area).']
  is_active boolean [note: 'Boolean flag indicating whether the campaign is currently active (True) or inactive (False). Active campaigns are either running or scheduled to run.']
  kpi_target varchar [note: 'The kpi target of the campaign record']
  modified_timestamp timestamp [note: 'The date and time when this campaign record was last updated or modified, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).']
  name varchar [note: 'The official name or title of the marketing campaign as used in internal planning and external communications.']
  notes varchar [note: 'The notes of the campaign record']
  objective varchar [note: 'Primary business goal of the campaign: awareness (brand visibility), consideration (product evaluation), conversion (purchase), loyalty (retention), launch (new product introduction), or relaunch (product refresh).']
  planned_end_date date [note: 'The originally scheduled date for campaign conclusion as defined during planning phase.']
  planned_media_spend_amount decimal(18,2) [note: 'The budgeted total media spend allocated to this campaign during the planning phase, in the company\'s reporting currency.']
  planned_production_cost_amount decimal(18,2) [note: 'The budgeted cost for creative production, including content creation, design, video production, and asset development.']
  planned_start_date date [note: 'The originally scheduled date for campaign launch as defined during planning phase.']
  primary_channel varchar [note: 'The primary channel of the campaign record']
  quantity decimal(18,4) [note: 'The quantity of the campaign record']
  roi_pct decimal(10,4) [note: 'The roi pct of the campaign record']
  source_system_code varchar [note: 'The unique identifier for this campaign in the source operational system, used for traceability and reconciliation.']
  start_date date [note: 'The start date of the campaign record']
  target_audience varchar [note: 'Textual description of the intended consumer segment for this campaign, including demographic, psychographic, and behavioral characteristics.']
  target_reach varchar [note: 'The target reach of the campaign record']
  total_budget decimal(18,2) [note: 'The total budget of the campaign record']
  uom varchar [note: 'The uom of the campaign record']
  updated_timestamp timestamp [note: 'The updated timestamp of the campaign record']

  Note: 'Master record for each marketing campaign executed by Consumer Goods. Captures campaign name, type (ATL, BTL, digital, shopper, influencer, integrated), objective, target audience, brand association, channel mix, planned vs. actual media spend, campaign start/end dates, creative concept, campaign status, and owning brand/category. Sourced from Salesforce Consumer Goods Cloud and internal campaign management systems.'
}

Table marketing.campaign_flight {
  campaign_flight_id varchar [pk, note: 'Unique identifier for the campaign flight record. Primary key.']
  agency_id varchar [note: 'FK to marketing.agency']
  campaign_id varchar [note: 'Reference to the parent marketing campaign. A single campaign may have multiple flights across different channels or geographies.']
  category_id varchar [note: 'Foreign key linking to product.category. Business justification: Campaign flights are executed at product category level for category-specific media buying and Nielsen/IRI category share-of-voice measurement. campaign_flight.product_category is a denormalized text ']
  consumer_segment_id varchar [note: 'Foreign key linking to marketing.consumer_segment. Business justification: Campaign flights target specific consumer segments. The existing target_audience column is a free-text string that should be normalized to a FK reference to the marketing domain\'s consumer_segment mas']
  creative_asset_id varchar [note: 'Reference to the creative asset used in this flight. Links to creative asset management system for creative performance analysis.']
  marketing_brand_id varchar [note: 'Reference to the brand being promoted in this flight. Enables brand-level campaign performance aggregation.']
  media_plan_id varchar [note: 'Foreign key linking to marketing.media_plan. Business justification: Campaign flights are the execution of media plans. Linking a flight to its originating media plan enables plan vs. actual comparison at the flight level — comparing planned impressions, planned spend,']
  actual_end_date date [note: 'Actual date when the flight media execution ended. Captures real execution timeline for post-campaign analysis.']
  actual_impressions varchar [note: 'Actual number of impressions delivered during the flight. Core metric for reach and frequency analysis.']
  actual_start_date date [note: 'Actual date when the flight media execution began. Used for variance analysis against planned schedule.']
  amount decimal(18,4) [note: 'The amount of the campaign flight record']
  attribution_model varchar [note: 'Attribution methodology used to assign conversion credit to this flight. Critical for multi-touch attribution analysis.']
  budget_allocated_amount decimal(18,2) [note: 'Total budget allocated to this flight. Represents the planned media spend for this specific flight execution.']
  budget_amount decimal(15,2) [note: 'The budget amount of the campaign flight record']
  budget_spent_amount decimal(18,2) [note: 'Actual amount spent on this flight. Used for budget variance analysis and Return on Ad Spend (ROAS) calculation.']
  campaign_flight_status varchar [note: 'The campaign flight status of the campaign flight record']
  channel varchar [note: 'Primary media channel for this flight execution. Supports omnichannel campaign measurement across digital, TV, out-of-home, print, social media, and search.']
  clicks varchar [note: 'Total number of clicks generated by the flight. Primary engagement metric for digital and search campaigns.']
  code varchar [note: 'The campaign flight code of the campaign flight record']
  conversion_rate decimal(5,4) [note: 'Conversion rate expressed as a decimal (conversions divided by clicks or impressions). Measures campaign effectiveness in driving desired actions.']
  conversions varchar [note: 'Total number of conversions attributed to this flight. Conversion definition varies by campaign objective (purchase, sign-up, download, etc.).']
  cpa decimal(10,4) [note: 'Average cost per conversion for this flight. Critical metric for performance marketing and Return on Investment (ROI) analysis.']
  cpc decimal(10,4) [note: 'Average cost per click for this flight. Key efficiency metric for paid search and digital campaigns.']
  created_timestamp timestamp [note: 'Timestamp when this flight record was first created in the system. Used for audit trail and data lineage.']
  ctr decimal(5,4) [note: 'Click-through rate expressed as a decimal (clicks divided by impressions). Key performance indicator for digital campaign effectiveness.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for all monetary amounts in this flight record.']
  data_source varchar [note: 'Source system or platform from which performance data was captured (e.g., Meta API, Google Ads API, agency post-buy report, Nielsen IQ). Used for data lineage and quality assessment.']
  description varchar [note: 'The campaign flight description of the campaign flight record']
  effective_from date [note: 'The effective from of the campaign flight record']
  effective_until date [note: 'The effective until of the campaign flight record']
  end_date date [note: 'The end date of the campaign flight record']
  flight_budget decimal(18,2) [note: 'The flight budget of the campaign flight record']
  flight_code varchar [note: 'The flight code of the campaign flight record']
  flight_name varchar [note: 'Descriptive name of the campaign flight for business user identification and reporting.']
  flight_number varchar [note: 'Business identifier for the flight within the campaign. Used for external reporting and agency coordination.']
  flight_status varchar [note: 'Current lifecycle status of the campaign flight.']
  frequency decimal(5,2) [note: 'Average number of times an individual was exposed to the campaign (impressions divided by reach). Measures message repetition.']
  grp decimal(10,2) [note: 'Gross Rating Points for traditional media (TV, radio, OOH). Measures total audience delivery as a percentage of target population multiplied by frequency.']
  impressions_target varchar [note: 'The impressions target of the campaign flight record']
  last_modified_timestamp timestamp [note: 'Timestamp when this flight record was last updated. Supports change tracking and data freshness monitoring.']
  market_geography varchar [note: 'Geographic market or region where the flight is executed. Supports market-level performance tracking and regional campaign optimization.']
  measurement_date date [note: 'Date on which performance metrics were measured or reported. Supports daily granular performance tracking at the campaign-channel-market-date grain.']
  name varchar [note: 'The campaign flight name of the campaign flight record']
  notes varchar [note: 'Free-text notes or comments about the flight execution, performance anomalies, or special circumstances. Supports qualitative context for quantitative performance data.']
  placement_type varchar [note: 'Specific placement or ad format type within the channel (e.g., banner, video, native, sponsored post, display, search text ad). Enables placement-level optimization.']
  planned_impressions varchar [note: 'The planned impressions of the campaign flight record']
  platform varchar [note: 'Specific advertising platform or network (e.g., Meta, Google Ads, TikTok, programmatic DSP, linear TV network). Enables platform-specific performance analysis.']
  quantity decimal(18,4) [note: 'The quantity of the campaign flight record']
  reach varchar [note: 'Estimated number of unique individuals exposed to the campaign flight. Used for audience coverage analysis.']
  roas decimal(10,4) [note: 'Return on Ad Spend expressed as a ratio (revenue generated divided by ad spend). Primary metric for campaign profitability assessment.']
  scheduled_end_date date [note: 'Planned end date for the flight media run. Defines the flight duration for budget allocation and performance measurement.']
  scheduled_start_date date [note: 'Planned start date for the flight media run. Used for campaign planning and scheduling.']
  source_system_code varchar [note: 'The source system code of the campaign flight record']
  start_date date [note: 'The start date of the campaign flight record']
  target_impressions varchar [note: 'Planned number of impressions for this flight. Used for media planning and performance target setting.']
  uom varchar [note: 'The uom of the campaign flight record']
  updated_timestamp timestamp [note: 'The updated timestamp of the campaign flight record']
  video_completion_rate decimal(5,4) [note: 'Percentage of video views that were completed (watched to end). Measures creative engagement quality.']
  video_views varchar [note: 'Total number of video views for video creative flights. Applicable to digital video, social, and TV campaigns.']

  Note: 'Transactional record of campaign execution at the flight level, capturing performance metrics across ALL channels (digital, TV, OOH, print, social, search, programmatic) at the campaign-channel-market-date grain. Defines scheduled media run dates, channel, market/geography, budget allocation, and flight-level performance targets. Captures planned and actual impressions, clicks, CTR, video views, view-through rate, conversions, CPC, CPA, ROAS, reach, frequency, GRPs (traditional), and platform-specific metrics (Meta, Google, TikTok, programmatic DSP). A single campaign may have multiple flights across different channels or geographies. Sourced from digital ad platform APIs, agency post-buy reports, and media monitoring systems. Serves as the unified granular performance record for omnichannel campaign measurement.'
}

Table marketing.media_plan {
  media_plan_id varchar [pk, note: 'Unique identifier for the media plan record. Primary key.']
  agency_id varchar [note: 'The agency id of the media plan record']
  budget_id varchar [note: 'Foreign key linking to marketing.marketing_budget. Business justification: Media plans are constrained by and draw from approved marketing budgets. Linking media_plan to marketing_budget enables plan-level budget utilization tracking, ensures media plans are created within a']
  campaign_id varchar [note: 'Reference to the marketing campaign associated with this media plan.']
  category_id varchar [note: 'Foreign key linking to product.category. Business justification: CPG media plans are structured by product category for share-of-voice analysis and category-level media investment benchmarking (e.g., Nielsen SOV reports). Media plans span multiple campaigns; a dire']
  consumer_segment_id varchar [note: 'Foreign key linking to marketing.consumer_segment. Business justification: Media plans are designed to reach specific consumer segments. The existing target_audience column is a free-text string that should be normalized to a FK reference to the marketing domain\'s consumer_s']
  marketing_brand_id varchar [note: 'Reference to the brand for which this media plan is created.']
  supplier_contract_id varchar [note: 'Foreign key linking to procurement.supplier_contract. Business justification: Contract-governed media planning: media plans in consumer goods are authorized by agency or media-buying contracts negotiated through procurement. Linking media_plan to supplier_contract enables compl']
  amount decimal(18,4) [note: 'The amount of the media plan record']
  approved_by varchar [note: 'Name or identifier of the person who approved this media plan.']
  approved_date date [note: 'Date when this media plan was formally approved for execution.']
  budget_allocation_percent decimal(5,2) [note: 'Percentage of total campaign or brand budget allocated to this media plan line.']
  code varchar [note: 'The media plan code of the media plan record']
  created_timestamp timestamp [note: 'Timestamp when this media plan record was first created in the system.']
  creative_format varchar [note: 'Format of the creative asset planned for this media (e.g., 30-second spot, banner ad, full-page print, billboard).']
  currency_code varchar [note: 'Three-letter ISO currency code for the planned spend amount (e.g., USD, EUR, GBP).']
  daypart varchar [note: 'Time segment of day for broadcast media (e.g., Prime Time, Early Morning, Late Night, Daytime).']
  description varchar [note: 'The media plan description of the media plan record']
  effective_from date [note: 'The effective from of the media plan record']
  effective_until date [note: 'The effective until of the media plan record']
  end_date date [note: 'The end date of the media plan record']
  flight_end_date date [note: 'End date of the media flight or execution period for this plan.']
  flight_start_date date [note: 'Start date of the media flight or execution period for this plan.']
  frequency decimal(7,2) [note: 'The frequency of the media plan record']
  kpi_target varchar [note: 'Target Key Performance Indicator metric and value for measuring media plan success (e.g., Reach 70%, CTR 2.5%, ROAS 3.0).']
  market varchar [note: 'Geographic market or Designated Market Area (DMA) targeted by this media plan (e.g., USA, New York DMA, UK).']
  media_channel varchar [note: 'Primary media channel category for this plan line (TV, digital, out-of-home, print, social, search, programmatic, radio, cinema, podcast). [ENUM-REF-CANDIDATE: tv|digital|ooh|print|social|search|programmatic|radio|cinema|podcast — promote to reference product]']
  media_owner varchar [note: 'Name of the media owner or publisher (e.g., NBC, Google, Meta, Clear Channel).']
  media_plan_status varchar [note: 'The media plan status of the media plan record']
  media_subchannel varchar [note: 'Detailed subchannel or platform within the primary media channel (e.g., Facebook, Google Display, National TV, Local Radio).']
  media_type varchar [note: 'The media type of the media plan record']
  modified_timestamp timestamp [note: 'Timestamp when this media plan record was last modified or updated.']
  name varchar [note: 'The media plan name of the media plan record']
  notes varchar [note: 'Free-text notes, comments, or special instructions related to this media plan.']
  objective varchar [note: 'Primary marketing objective for this media plan (awareness, consideration, conversion, retention, trial).']
  plan_code varchar [note: 'Unique business identifier or code for the media plan used for external reference and tracking.']
  plan_name varchar [note: 'Business-friendly name or title of the media plan document.']
  plan_period varchar [note: 'The plan period of the media plan record']
  plan_status varchar [note: 'Current lifecycle status of the media plan indicating its approval and execution state.']
  plan_type varchar [note: 'Classification of the media plan by planning horizon and purpose.']
  plan_version varchar [note: 'Version number of this media plan document to track revisions and iterations.']
  planned_budget decimal(18,2) [note: 'The planned budget of the media plan record']
  planned_cpm decimal(18,2) [note: 'Planned cost per thousand impressions for this media investment.']
  planned_cpp decimal(18,2) [note: 'Planned cost per rating point for broadcast media investments.']
  planned_frequency decimal(5,2) [note: 'Planned average number of times the target audience will be exposed to the media message.']
  planned_grp decimal(18,2) [note: 'Planned Gross Rating Points representing the total reach multiplied by frequency for the target audience.']
  planned_impressions varchar [note: 'Total number of planned impressions (ad exposures) for this media plan.']
  planned_reach varchar [note: 'The planned reach of the media plan record']
  planned_reach_percent decimal(5,2) [note: 'Planned percentage of the target audience reached at least once during the planning period.']
  planned_spend_amount decimal(18,2) [note: 'Total planned media spend amount for this media plan in the base currency.']
  planning_period_end_date date [note: 'End date of the period covered by this media plan.']
  planning_period_start_date date [note: 'Start date of the period covered by this media plan.']
  quantity decimal(18,4) [note: 'The quantity of the media plan record']
  source_system_code varchar [note: 'The source system code of the media plan record']
  start_date date [note: 'The start date of the media plan record']
  target_grp decimal(10,2) [note: 'The target grp of the media plan record']
  target_reach_pct decimal(7,4) [note: 'The target reach pct of the media plan record']
  total_budget decimal(15,2) [note: 'The total budget of the media plan record']
  uom varchar [note: 'The uom of the media plan record']
  updated_timestamp timestamp [note: 'The updated timestamp of the media plan record']

  Note: 'Formal media plan document capturing planned media investments across channels (TV, digital, OOH, print, social, search, programmatic) for a brand or campaign. Includes planned impressions, GRPs, reach, frequency, CPM, total planned spend, agency, media owner, market, and planning period. Serves as the authoritative pre-buy record for media investment decisions.'
}

Table marketing.media_spend {
  media_spend_id varchar [pk, note: 'Unique identifier for the media spend transaction record. Primary key for the media spend data product.']
  agency_id varchar [note: 'The agency id of the media spend record']
  campaign_flight_id varchar [note: 'Foreign key linking to marketing.campaign_flight. Business justification: Media spend is incurred at the campaign flight level. Linking spend records to their originating flight enables granular spend tracking, flight-level ROI analysis, and reconciliation of invoiced spend']
  campaign_id varchar [note: 'Reference to the marketing campaign associated with this media spend transaction.']
  consumer_segment_id varchar [note: 'Foreign key linking to marketing.consumer_segment. Business justification: Media spend is tracked against target consumer segments for attribution and ROI analysis. The existing target_audience column is a free-text string that should be normalized to a FK reference to the m']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Media spend invoices are posted against cost centers to track advertising costs per organizational unit.']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Accounting of media spend requires a GL account reference for journal entry creation.']
  marketing_brand_id varchar [note: 'Reference to the brand for which this media spend was incurred.']
  media_plan_id varchar [note: 'Reference to the media plan that authorized this spend.']
  supplier_invoice_id varchar [note: 'Foreign key linking to procurement.supplier_invoice. Business justification: Media spend reconciliation: media spend records must be matched against supplier invoices from media vendors for three-way match and campaign actual-spend validation. media_spend.invoice_number is a d']
  agency_fee_amount decimal(18,2) [note: 'The agency service fee or commission charged for managing the media buy.']
  amount decimal(18,4) [note: 'The amount of the media spend record']
  buy_type varchar [note: 'The method by which the media inventory was purchased (e.g., Programmatic, Direct, Auction, Guaranteed).']
  channel varchar [note: 'The channel of the media spend record']
  clicks varchar [note: 'The clicks of the media spend record']
  clicks_delivered varchar [note: 'The total number of clicks generated by the media placement for this spend transaction.']
  code varchar [note: 'The media spend code of the media spend record']
  country_code varchar [note: 'The three-letter ISO 3166-1 alpha-3 country code where the media spend was incurred (e.g., USA, GBR, DEU).']
  cpc decimal(12,4) [note: 'The cpc of the media spend record']
  cpc_actual decimal(10,4) [note: 'The actual cost per click (CPC) achieved for this media spend, calculated as working spend divided by clicks delivered.']
  cpm decimal(10,4) [note: 'The cpm of the media spend record']
  cpm_actual decimal(10,4) [note: 'The actual cost per thousand impressions (CPM) achieved for this media spend, calculated as (working spend / impressions) * 1000.']
  cpv_actual decimal(10,4) [note: 'The actual cost per video view (CPV) achieved for this media spend, calculated as working spend divided by video views delivered.']
  created_timestamp timestamp [note: 'The timestamp when this media spend record was first created in the system.']
  currency_code varchar [note: 'The three-letter ISO 4217 currency code in which the spend amounts are denominated (e.g., USD, EUR, GBP).']
  description varchar [note: 'The media spend description of the media spend record']
  effective_from date [note: 'The effective from of the media spend record']
  effective_until date [note: 'The effective until of the media spend record']
  geography_scope varchar [note: 'The geographic scope of the media placement (e.g., National, Regional, Local, Global).']
  impressions varchar [note: 'The impressions of the media spend record']
  impressions_delivered varchar [note: 'The total number of ad impressions delivered for this spend transaction.']
  invoiced_spend_amount decimal(18,2) [note: 'The total amount invoiced by the media owner or agency for this media spend transaction.']
  is_active boolean [note: 'Boolean flag indicating whether this media spend record is currently active and valid (True) or has been voided or superseded (False).']
  market_name varchar [note: 'The name of the specific market or Designated Market Area (DMA) where the media was placed (e.g., New York, Los Angeles, London).']
  media_channel varchar [note: 'The media channel through which the advertising was delivered (e.g., TV, Digital Display, Social Media, Search). [ENUM-REF-CANDIDATE: TV|Radio|Print|Digital Display|Social Media|Search|Video|Out-of-Home|Programmatic|Influencer|Podcast|Streaming|Email|Mobile|Affiliate|Sponsorship|Other — 17 candidates stripped; promote to reference product]']
  media_owner_name varchar [note: 'The name of the media owner or publisher that provided the advertising inventory (e.g., Google, Meta, NBC Universal).']
  media_spend_status varchar [note: 'The media spend status of the media spend record']
  media_subchannel varchar [note: 'The specific subchannel or platform within the media channel (e.g., Facebook, Google Ads, CNN, Spotify).']
  media_vehicle varchar [note: 'The media vehicle of the media spend record']
  modified_timestamp timestamp [note: 'The timestamp when this media spend record was last modified or updated.']
  name varchar [note: 'The media spend name of the media spend record']
  non_working_spend_amount decimal(18,2) [note: 'The portion of invoiced spend allocated to agency fees, production costs, and other non-media expenses (non-working media).']
  notes varchar [note: 'Free-text notes or comments regarding this media spend transaction, including reconciliation notes or dispute details.']
  payment_date date [note: 'The date on which the invoice for this media spend was paid.']
  payment_status varchar [note: 'The payment status of the invoice associated with this media spend transaction.']
  placement_type varchar [note: 'The type of media placement or ad format (e.g., Banner, Video Pre-Roll, Native, Sponsored Post, 30-Second Spot).']
  planned_spend_amount decimal(18,2) [note: 'The originally planned or committed spend amount from the media plan for this channel and period.']
  production_cost_amount decimal(18,2) [note: 'The cost of creative production, ad serving, and other production-related expenses included in this spend transaction.']
  quantity decimal(18,4) [note: 'The quantity of the media spend record']
  reconciled_timestamp timestamp [note: 'The timestamp when this media spend record was reconciled against the media plan and delivery metrics.']
  reconciliation_status varchar [note: 'The current reconciliation status of this spend transaction against the media plan and delivery metrics.']
  source_system_code varchar [note: 'The unique identifier for this media spend record in the source system.']
  spend_amount decimal(15,2) [note: 'The spend amount of the media spend record']
  spend_date date [note: 'The date on which the media spend was incurred or invoiced.']
  spend_period varchar [note: 'The fiscal or calendar period (e.g., 2024-Q1, 2024-03) to which this spend is allocated for reporting purposes.']
  uom varchar [note: 'The uom of the media spend record']
  updated_timestamp timestamp [note: 'The updated timestamp of the media spend record']
  variance_to_plan_amount decimal(18,2) [note: 'The difference between invoiced spend and planned spend (invoiced minus planned), indicating over- or under-spend.']
  vendor_name varchar [note: 'The vendor name of the media spend record']
  video_views_delivered varchar [note: 'The total number of video views or completions delivered for video media placements.']
  working_spend_amount decimal(18,2) [note: 'The portion of invoiced spend that directly purchased media inventory (working media), excluding agency fees and production costs.']

  Note: 'Transactional record of actual media spend incurred per channel, campaign, brand, and time period. Captures invoiced spend, committed spend, variance to plan, media owner, agency fees, working vs. non-working spend classification, and cost-per-metric actuals (CPM, CPC, CPV). Sourced from agency billing systems and reconciled against media plan commitments.'
}

Table marketing.creative_asset {
  creative_asset_id varchar [pk, note: 'Unique identifier for the creative asset record. Primary key.']
  agency_id varchar [note: 'The agency id of the creative asset record']
  campaign_id varchar [note: 'Identifier of the marketing campaign this creative asset is associated with.']
  consumer_segment_id varchar [note: 'Foreign key linking to marketing.consumer_segment. Business justification: Creative assets are designed for specific consumer segments. The existing target_audience_segment column is a free-text string that should be normalized to a FK reference to the marketing domain\'s con']
  parent_asset_creative_asset_id varchar [note: 'Identifier of the parent creative asset if this asset is a derivative, localized version, or variant of another asset.']
  product_brand_id varchar [note: 'Foreign key linking to product.product_brand. Business justification: Brand equity creative assets (TV spots, brand guidelines, hero imagery) are owned at product brand level, not SKU level. creative_asset.sku_id covers SKU-specific assets; product_brand_id covers brand']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Creative assets (images, packaging) are created per SKU; linking enables asset tracking, compliance, and reuse.']
  actual_end_date date [note: 'Actual date when the creative asset was withdrawn or archived from active use.']
  actual_publish_date date [note: 'Actual date when the creative asset was published or went live.']
  amount decimal(18,4) [note: 'The amount of the creative asset record']
  approval_status varchar [note: 'Current approval status of the creative asset in the review workflow (draft, pending review, approved, rejected, expired).']
  asset_code varchar [note: 'Unique business identifier or code assigned to the creative asset for tracking and reference purposes.']
  asset_name varchar [note: 'Human-readable name or title of the creative asset (e.g., \'Spring Campaign Hero Banner\', \'Product Launch Video 30s\').']
  asset_type varchar [note: 'Classification of the creative asset by media type (video, image, audio, document, HTML, social post, email template). [ENUM-REF-CANDIDATE: video|image|audio|document|html|social_post|email_template — 7 candidates stripped; promote to reference product]']
  code varchar [note: 'The creative asset code of the creative asset record']
  compliance_notes varchar [note: 'Notes or comments from compliance and legal review regarding the creative asset.']
  compliance_review_status varchar [note: 'Status of regulatory and legal compliance review for the creative asset (not required, pending, approved, rejected).']
  content_category varchar [note: 'Business category or use case of the creative asset (TV commercial, digital banner, social media, print ad, packaging visual, influencer brief, blog post, email content, landing page, infographic). [ENUM-REF-CANDIDATE: tv_commercial|digital_banner|social_media|print_ad|packaging_visual|influencer_brief|blog_post|email_content|landing_page|infographic — 10 candidates stripped; promote to reference product]']
  content_format varchar [note: 'Specific file format or content format of the asset (e.g., MP4, JPEG, PNG, PDF, GIF, HTML5).']
  content_status varchar [note: 'Current publishing lifecycle status of the creative asset (planned, scheduled, published, archived, withdrawn).']
  created_timestamp timestamp [note: 'Timestamp when the creative asset record was first created in the system.']
  creative_asset_status varchar [note: 'The creative asset status of the creative asset record']
  creative_concept varchar [note: 'High-level creative concept or theme of the asset (e.g., \'Family Moments\', \'Sustainability Focus\', \'Product Innovation\').']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the production cost amount.']
  dam_reference_code varchar [note: 'Unique identifier or reference code in the Digital Asset Management system where the asset is stored.']
  description varchar [note: 'Detailed textual description of the creative asset content, purpose, and key messaging.']
  duration_seconds varchar [note: 'Duration of the creative asset in seconds (applicable to video and audio assets).']
  effective_from date [note: 'The effective from of the creative asset record']
  effective_until date [note: 'The effective until of the creative asset record']
  file_reference varchar [note: 'The file reference of the creative asset record']
  file_size_bytes varchar [note: 'Size of the creative asset file in bytes.']
  file_url varchar [note: 'The file url of the creative asset record']
  format varchar [note: 'The format of the creative asset record']
  geographic_scope varchar [note: 'Geographic regions or markets where the creative asset is approved for use (e.g., \'Global\', \'USA\', \'EMEA\').']
  height_pixels varchar [note: 'Height dimension of the creative asset in pixels (applicable to images, videos, and display ads).']
  is_master_version boolean [note: 'Flag indicating whether this is the master or primary version of the creative asset (True) or a derivative/variant (False).']
  keywords varchar [note: 'Comma-separated list of keywords or tags associated with the creative asset for search and discovery purposes.']
  language_code varchar [note: 'Two-letter ISO 639-1 language code representing the primary language of the creative asset content.']
  modified_timestamp timestamp [note: 'Timestamp when the creative asset record was last modified or updated.']
  name varchar [note: 'The creative asset name of the creative asset record']
  notes varchar [note: 'The notes of the creative asset record']
  planned_end_date date [note: 'Planned date for the creative asset to be withdrawn or archived from active use.']
  planned_publish_date date [note: 'Planned or scheduled date for the creative asset to be published or go live.']
  production_cost_amount decimal(18,2) [note: 'Total cost incurred to produce the creative asset.']
  publishing_channel varchar [note: 'Primary channel or platform where the creative asset is published or distributed (e.g., \'Facebook\', \'Instagram\', \'YouTube\', \'Website\', \'Email\', \'TV\').']
  quantity decimal(18,4) [note: 'The quantity of the creative asset record']
  rights_expiry_date date [note: 'Date when the usage rights or licensing for the creative asset expire.']
  source_system_code varchar [note: 'Unique identifier of the creative asset in the source system.']
  storage_location_url varchar [note: 'Full URL or file path where the creative asset is stored in the DAM or content repository.']
  thumbnail_url varchar [note: 'URL of the thumbnail or preview image for the creative asset.']
  uom varchar [note: 'The uom of the creative asset record']
  updated_timestamp timestamp [note: 'The updated timestamp of the creative asset record']
  usage_rights varchar [note: 'Description of usage rights, licensing terms, or restrictions governing how the creative asset may be used (e.g., \'Global rights\', \'North America only\', \'Digital channels only\').']
  usage_rights_expiry date [note: 'The usage rights expiry of the creative asset record']
  version_number varchar [note: 'Version number or identifier for the creative asset (e.g., \'v1.0\', \'v2.1\', \'Final\').']
  width_pixels varchar [note: 'Width dimension of the creative asset in pixels (applicable to images, videos, and display ads).']

  Note: 'Master record for each creative asset and content item (TV commercial, digital banner, social post, print ad, packaging visual, influencer brief, video, blog post, email template) used in marketing campaigns or published on owned/earned channels. Captures asset name, format, dimensions, file type, brand, campaign association, creative concept, approval status, rights/usage restrictions, expiry date, DAM reference ID, and content publishing metadata (planned publish date, actual publish date, publishing channel, content status, content type, target audience segment, content owner). Serves as the unified creative and content management record supporting brand compliance, creative reuse tracking, DAM integration, and coordinated omnichannel content calendar planning. No separate content calendar product exists — all scheduling and publishing metadata lives here.'
}

Table marketing.consumer_segment {
  consumer_segment_id varchar [pk, note: 'Unique identifier for the marketing consumer segment. Primary key.']
  marketing_brand_id varchar [note: 'The marketing brand id of the consumer segment record']
  age_range_lower varchar [note: 'Lower bound of the age range for consumers in this segment (in years). Null if age is not a defining characteristic.']
  age_range_upper varchar [note: 'Upper bound of the age range for consumers in this segment (in years). Null if age is not a defining characteristic.']
  amount decimal(18,4) [note: 'The amount of the consumer segment record']
  average_basket_size_usd decimal(12,2) [note: 'Average transaction or basket size in USD for consumers in this segment, used for campaign ROI modeling.']
  brand_affinity varchar [note: 'Brands or brand categories that this segment shows strong preference or loyalty toward. Used for brand-specific campaign targeting.']
  cltv_estimate_usd decimal(12,2) [note: 'Estimated Customer Lifetime Value in USD for consumers in this segment, used for prioritization and investment decisions.']
  code varchar [note: 'The consumer segment code of the consumer segment record']
  consumer_segment_status varchar [note: 'The consumer segment status of the consumer segment record']
  content_preference varchar [note: 'Types of marketing content that resonate with this segment (e.g., educational, promotional, user-generated, influencer, video).']
  country_codes varchar [note: 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this segment is applicable (e.g., USA, GBR, DEU).']
  created_timestamp timestamp [note: 'Timestamp when this segment record was first created in the system.']
  currency_code varchar [note: 'The currency code of the consumer segment record']
  data_source varchar [note: 'Primary data source or vendor used to define and validate this segment (e.g., Nielsen IQ, internal CRM, third-party data provider).']
  demographic_profile varchar [note: 'The demographic profile of the consumer segment record']
  description varchar [note: 'The consumer segment description of the consumer segment record']
  digital_engagement_level varchar [note: 'Level of digital channel engagement and activity for consumers in this segment (social media, email, mobile app, e-commerce).']
  effective_end_date date [note: 'Date when this segment definition is scheduled to be retired or replaced. Null for open-ended segments.']
  effective_from date [note: 'The effective from of the consumer segment record']
  effective_start_date date [note: 'Date when this segment definition became active and available for campaign targeting.']
  effective_until date [note: 'The effective until of the consumer segment record']
  geographic_scope varchar [note: 'Geographic reach or focus of this consumer segment (global, regional, national, or local).']
  income_bracket varchar [note: 'Income level classification for consumers in this segment, used for targeting and media planning.']
  innovation_adoption_profile varchar [note: 'Consumer adoption curve classification for new product launches and innovations (based on Rogers Diffusion of Innovations theory).']
  is_active boolean [note: 'Boolean flag indicating whether this segment is currently active and available for use in campaign planning and targeting.']
  key_characteristics varchar [note: 'Defining behavioral, demographic, or psychographic characteristics that distinguish this segment from others.']
  last_refresh_date date [note: 'Date when the segment definition, size estimate, or characteristics were last updated or recalculated.']
  messaging_tone_preference varchar [note: 'Preferred messaging tone and style for communications to this segment (e.g., aspirational, practical, humorous, authoritative).']
  modified_timestamp timestamp [note: 'Timestamp when this segment record was last modified or updated.']
  name varchar [note: 'The consumer segment name of the consumer segment record']
  notes varchar [note: 'The notes of the consumer segment record']
  nps_score_average decimal(5,2) [note: 'Average Net Promoter Score for consumers in this segment, indicating brand loyalty and advocacy potential.']
  price_sensitivity_level varchar [note: 'Degree of price sensitivity and responsiveness to promotions and discounts for consumers in this segment.']
  promotion_responsiveness varchar [note: 'Level of responsiveness to trade promotions, coupons, and special offers for consumers in this segment.']
  psychographic_profile varchar [note: 'The psychographic profile of the consumer segment record']
  purchase_frequency_profile varchar [note: 'Typical purchase frequency behavior of consumers in this segment for relevant product categories.']
  quantity decimal(18,4) [note: 'The quantity of the consumer segment record']
  refresh_frequency varchar [note: 'Planned frequency for updating segment membership and characteristics to maintain accuracy.']
  region_codes varchar [note: 'Comma-separated list of regional codes or identifiers where this segment is applicable (e.g., state, province, metro area codes).']
  segment_code varchar [note: 'Unique business identifier code for the consumer segment used across marketing systems and campaign planning tools.']
  segment_description varchar [note: 'Detailed description of the consumer segment including defining characteristics, behaviors, and strategic rationale.']
  segment_name varchar [note: 'Human-readable name of the consumer segment used in campaign planning and reporting.']
  segment_size varchar [note: 'The segment size of the consumer segment record']
  segment_size_estimate varchar [note: 'Estimated number of consumers or households that belong to this segment based on the most recent segmentation analysis.']
  segment_size_percentage decimal(5,2) [note: 'Percentage of the total addressable consumer base that this segment represents.']
  segment_status varchar [note: 'Current lifecycle status of the consumer segment indicating whether it is actively used in campaign targeting.']
  segment_type varchar [note: 'The segment type of the consumer segment record']
  segmentation_methodology varchar [note: 'Detailed methodology, algorithm, or analytical approach used to create this segment (e.g., RFM analysis, cluster analysis, decision tree).']
  segmentation_model_type varchar [note: 'The methodology or model used to define this consumer segment (behavioral, psychographic, demographic, geographic, needs-based, or hybrid).']
  size_estimate varchar [note: 'The size estimate of the consumer segment record']
  social_media_platform_preference varchar [note: 'Preferred social media platforms for consumers in this segment (e.g., Facebook, Instagram, TikTok, Twitter). Comma-separated list.']
  source_system_code varchar [note: 'The source system code of the consumer segment record']
  strategic_priority_tier varchar [note: 'Strategic importance ranking of this segment for marketing investment and campaign focus (tier 1 being highest priority).']
  sustainability_consciousness_level varchar [note: 'Level of environmental and sustainability awareness and preference for eco-friendly products within this segment.']
  target_channel_affinity varchar [note: 'Preferred marketing and sales channels for reaching this segment (e.g., digital, retail, DTC, social media, email). Comma-separated list of channel preferences.']
  uom varchar [note: 'The uom of the consumer segment record']
  updated_timestamp timestamp [note: 'The updated timestamp of the consumer segment record']
  value_index decimal(10,4) [note: 'The value index of the consumer segment record']

  Note: 'Reference master for consumer segmentation definitions used in targeting and campaign planning. Captures segment name, segmentation model (behavioral, psychographic, demographic, needs-based), segment size estimate, key characteristics, target channel affinity, brand affinity, and strategic priority tier. Used to align campaign targeting across digital, retail, and DTC channels. Distinct from consumer profile (owned by consumer domain).'
}

Table marketing.agency {
  agency_id varchar [pk, note: 'Unique identifier for the marketing agency partner. Primary key for the agency master record.']
  supplier_contract_id varchar [note: 'Foreign key linking to procurement.supplier_contract. Business justification: Agency contract management: marketing agencies are governed by formal procurement contracts. Linking agency directly to supplier_contract enables compliance teams to verify contract coverage, payment ']
  supplier_id varchar [note: 'Supplier record for this agency vendor.']
  address_line1 varchar [note: 'First line of the agency\'s primary business address (street address, building number).']
  address_line2 varchar [note: 'Second line of the agency\'s primary business address (suite, floor, building name). Nullable.']
  agency_status varchar [note: 'The agency status of the agency record']
  agency_type varchar [note: 'Primary classification of the agency based on core service offering: creative (brand and campaign creative development), media (media planning and buying), digital (digital marketing and social media), pr (public relations and communications), shopper (shopper marketing and retail execution), research (market research and consumer insights).']
  amount decimal(18,4) [note: 'The amount of the agency record']
  annual_retainer_amount decimal(18,2) [note: 'Total annual retainer fee amount committed under the current contract. Null if engagement is project-based only.']
  assigned_brands varchar [note: 'Comma-separated list of Consumer Goods brand names or brand identifiers that this agency is contracted to support.']
  city varchar [note: 'City of the agency\'s primary business address.']
  code varchar [note: 'Internal short code or identifier used to reference the agency in operational systems and reporting.']
  contact_email varchar [note: 'The contact email of the agency record']
  contact_name varchar [note: 'The contact name of the agency record']
  contract_end_date date [note: 'Scheduled expiration or termination date of the current agency contract. Null for open-ended agreements.']
  contract_start_date date [note: 'Effective start date of the current agency contract or master service agreement.']
  contract_status varchar [note: 'Current lifecycle status of the agency contract: active (contract in force), pending (contract under negotiation or awaiting signature), suspended (temporarily paused), terminated (ended before expiration), expired (contract term ended).']
  country_code varchar [note: 'ISO 3166-1 alpha-3 country code of the agency\'s primary business address (e.g., USA, GBR, DEU).']
  created_timestamp timestamp [note: 'Timestamp when this agency record was first created in the system.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for all monetary amounts associated with this agency (e.g., USD, EUR, GBP).']
  description varchar [note: 'The agency description of the agency record']
  duns_number varchar [note: 'Dun & Bradstreet DUNS number for the agency, used for vendor identification and credit assessment.']
  effective_from date [note: 'The effective from of the agency record']
  effective_until date [note: 'The effective until of the agency record']
  engagement_model varchar [note: 'Basis of the commercial relationship: retainer (ongoing monthly/annual fee), project (discrete project-based fees), hybrid (combination of retainer and project fees), performance (fee tied to performance metrics).']
  fee_structure varchar [note: 'Description of the agency\'s fee arrangement, including rate type (hourly, monthly retainer, project-based, commission percentage, performance-based) and any tiered or volume-based pricing.']
  holding_group varchar [note: 'Name of the parent holding company or network to which the agency belongs (e.g., WPP, Omnicom, Publicis, IPG, Dentsu). Null if the agency is independent.']
  is_active boolean [note: 'Indicates whether this agency record is currently active and available for assignment to campaigns and projects. False indicates the agency relationship has been terminated or is inactive.']
  is_minority_owned boolean [note: 'Indicates whether the agency is certified as a minority-owned business enterprise (MBE) for supplier diversity tracking and reporting.']
  is_preferred_vendor boolean [note: 'Indicates whether the agency is designated as a preferred or strategic vendor with priority consideration for new projects and campaigns.']
  is_woman_owned boolean [note: 'Indicates whether the agency is certified as a woman-owned business enterprise (WBE) for supplier diversity tracking and reporting.']
  last_performance_review_date date [note: 'Date of the most recent formal performance review or scorecard assessment for this agency.']
  markets_served varchar [note: 'Comma-separated list of geographic markets or regions where the agency provides services to Consumer Goods (e.g., North America, EMEA, APAC, LATAM, or specific country codes).']
  modified_timestamp timestamp [note: 'Timestamp when this agency record was last modified or updated.']
  name varchar [note: 'Legal or trade name of the marketing agency partner.']
  notes varchar [note: 'Free-text field for additional notes, special instructions, or context about the agency relationship, capabilities, or historical performance.']
  onboarding_date date [note: 'Date when the agency was formally onboarded and added to the approved agency roster for Consumer Goods.']
  payment_terms varchar [note: 'Standard payment terms agreed with the agency (e.g., Net 30, Net 60, milestone-based, advance payment). Defines when invoices are due.']
  performance_rating varchar [note: 'Most recent performance evaluation rating assigned to the agency based on quality of work, timeliness, collaboration, and business impact. Used for agency benchmarking and roster optimization.']
  postal_code varchar [note: 'Postal or ZIP code of the agency\'s primary business address.']
  primary_contact varchar [note: 'The primary contact of the agency record']
  primary_contact_email varchar [note: 'Email address of the primary agency contact for operational communication and coordination.']
  primary_contact_name varchar [note: 'Full name of the primary point of contact at the agency for day-to-day engagement and escalation.']
  primary_contact_phone varchar [note: 'Business phone number of the primary agency contact.']
  quantity decimal(18,4) [note: 'The quantity of the agency record']
  retainer_amount decimal(15,2) [note: 'The retainer amount of the agency record']
  retainer_fee decimal(18,2) [note: 'The retainer fee of the agency record']
  scope_of_services varchar [note: 'Detailed description of the services provided by the agency under the current engagement (e.g., brand strategy, creative production, media planning, digital campaign execution, influencer management, market research).']
  source_system_code varchar [note: 'Unique identifier of this agency record in the source operational system, used for traceability and reconciliation.']
  specialization varchar [note: 'The specialization of the agency record']
  state_province varchar [note: 'State, province, or region of the agency\'s primary business address.']
  tax_number varchar [note: 'Tax identification number or employer identification number (EIN) of the agency for tax reporting and compliance purposes.']
  termination_date date [note: 'Date when the agency relationship was formally terminated or the agency was removed from the active roster. Null if the agency is still active.']
  uom varchar [note: 'The uom of the agency record']
  updated_timestamp timestamp [note: 'The updated timestamp of the agency record']

  Note: 'Master record for marketing agency partners engaged by Consumer Goods. Captures agency name, agency type (creative, media, digital, PR, shopper, research, influencer), holding group, scope of services, retainer vs. project basis, primary contact, contract status, performance rating, markets served, assigned brands, and fee structure. Serves as the SSOT for agency partner identity and roster management within the marketing domain. Enables agency performance benchmarking and spend consolidation analysis.'
}

Table marketing.budget {
  budget_id varchar [pk, note: 'Unique identifier for the marketing budget allocation record. Primary key.']
  category_id varchar [note: 'Identifier of the product category to which this budget allocation is assigned. Null for brand-level or corporate-level budgets.']
  cost_center_id varchar [note: 'The cost center id of the marketing budget record']
  gl_account_id varchar [note: 'The gl account id of the marketing budget record']
  hierarchy_id varchar [note: 'Foreign key linking to product.hierarchy. Business justification: CPG marketing budgets are allocated at portfolio hierarchy levels (division, business unit) above category for annual operating plan (AOP) and zero-based budgeting processes. marketing_budget.category']
  product_brand_id varchar [note: 'Foreign key linking to product.product_brand. Business justification: CPG marketing budgets are allocated at product brand level for brand P&L management and brand investment tracking (e.g., A&P spend per brand). marketing_budget links to marketing_brand but not product']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Marketing budgets in CPG are approved and tracked at profit center level for brand P&L accountability. Budget vs. actual reporting by profit center is a standard finance-marketing governance process. ']
  allocated_amount decimal(18,2) [note: 'The allocated amount of the marketing budget record']
  amount decimal(18,2) [note: 'The budget amount of the marketing budget record']
  category varchar [note: 'The budget category of the marketing budget record']
  code varchar [note: 'The budget code of the marketing budget record']
  committed_amount decimal(18,2) [note: 'The committed amount of the marketing budget record']
  created_timestamp timestamp [note: 'The created timestamp of the marketing budget record']
  currency_code varchar [note: 'The currency code of the marketing budget record']
  effective_from date [note: 'The effective from of the marketing budget record']
  effective_until date [note: 'The effective until of the marketing budget record']
  fiscal_year varchar [note: 'The fiscal year of the marketing budget record']
  marketing_budget_code varchar [note: 'The marketing budget code of the marketing budget record']
  marketing_budget_description varchar [note: 'The marketing budget description of the marketing budget record']
  marketing_budget_name varchar [note: 'The marketing budget name of the marketing budget record']
  marketing_budget_status varchar [note: 'The marketing budget status of the marketing budget record']
  name varchar [note: 'The budget name of the marketing budget record']
  notes varchar [note: 'The notes of the marketing budget record']
  period varchar [note: 'The budget period of the marketing budget record']
  quantity decimal(18,4) [note: 'The quantity of the marketing budget record']
  remaining_amount decimal(18,2) [note: 'The remaining amount of the marketing budget record']
  source_system_code varchar [note: 'The source system code of the marketing budget record']
  spent_amount decimal(18,2) [note: 'The spent amount of the marketing budget record']
  uom varchar [note: 'The uom of the marketing budget record']
  updated_timestamp timestamp [note: 'The updated timestamp of the marketing budget record']

  Note: 'Marketing budget allocation record capturing planned and approved marketing investment by brand, category, channel, campaign type, and fiscal period. Captures total budget, working media budget, non-working budget, agency fees, research budget, committed spend, actual spend, variance, and budget owner. Distinct from finance domain general ledger — this is the marketing-owned investment planning record. [SSOT: authoritative table is finance.finance_budget; this table is a deprecated duplicate.] [SSOT] Superseded by authoritative table finance.finance_budget for concept \'budget\'. SSOT: canonical table is finance.finance_budget. [SSOT: authoritative table is finance.finance_budget; this is a deprecated duplicate for concept \'budget\'.] [Non-authoritative; defers to SSOT finance.finance_budget for concept \'budget\'.]'
}

Table finance.cost_center {
  cost_center_id varchar [pk, note: 'Unique identifier for the cost center. Primary key for the cost center master record in SAP S/4HANA CO module.']
  company_code_id varchar [note: 'The company code id of the cost center record']
  profit_center_id varchar [note: 'The profit center id of the cost center record']
  activity_type_indicator boolean [note: 'Flag indicating whether this cost center performs activity-based costing. True if the center provides measurable activities (e.g., machine hours, labor hours) that are allocated to cost objects.']
  allocation_method varchar [note: 'Method used for allocating costs from this cost center to other cost objects (products, profit centers). Critical for COGS calculation and overhead absorption.']
  amount decimal(18,4) [note: 'The amount of the cost center record']
  budget_profile_code varchar [note: 'Budget control profile defining budget planning rules, tolerance limits, and approval workflows for this cost center. Determines budget availability check behavior.']
  business_area_code varchar [note: 'Business area classification for code reporting. Represents a distinct line of business or product category (e.g., Personal Care, Home Care, Beauty) for consolidated financial analysis.']
  category varchar [note: 'Accounting classification indicating whether costs are direct (attributable to products), indirect (supporting operations), overhead (administrative), or capital (asset-related). Critical for COGS calculation and financial reporting.']
  code varchar [note: 'Business identifier for the cost center. Alphanumeric code used across SAP S/4HANA FI/CO modules for financial accountability tracking. Typically follows organizational naming conventions (e.g., plant code + department code).']
  cost_center_group varchar [note: 'Logical grouping of cost centers for consolidated reporting and analysis. Enables flexible aggregation beyond standard hierarchy (e.g., all brand marketing centers, all R&D centers).']
  cost_center_status varchar [note: 'Current lifecycle status of the cost center. Active centers accept postings; inactive centers are closed; blocked centers are temporarily suspended; planned centers are approved but not yet operational.']
  cost_center_type varchar [note: 'Classification of the cost center by functional area. Determines the nature of costs tracked and reporting hierarchy. Used for COGS allocation and EBITDA segmentation. [ENUM-REF-CANDIDATE: production|sales|marketing|distribution|administration|research_development|quality_assurance|procurement|finance|shared_services — 10 candidates stripped; promote to reference product]']
  country_code varchar [note: 'ISO 3166-1 alpha-3 country code where the cost center operates. Supports multi-country financial consolidation and regulatory reporting.']
  created_by_user varchar [note: 'User ID of the person who created the cost center master record. Audit trail for SOX compliance and data governance.']
  created_timestamp timestamp [note: 'Date and time when the cost center master record was created in the system. Audit trail for SOX compliance.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for cost center transactions. Defines the local currency for budget planning and actual cost recording.']
  department_code varchar [note: 'Department or functional unit code within the organization. Provides granular classification for workforce planning and departmental cost analysis.']
  description varchar [note: 'Extended description providing additional context about the cost center\'s purpose, scope, and responsibilities within the organization.']
  effective_from date [note: 'The effective from of the cost center record']
  effective_until date [note: 'The effective until of the cost center record']
  functional_area_code varchar [note: 'Functional area classification for cost-of-sales accounting. Distinguishes between manufacturing, sales, marketing, R&D, and administrative functions for COGS and operating expense allocation.']
  hierarchy_area varchar [note: 'Standard hierarchy assignment for organizational reporting. Defines the cost center\'s position in the corporate hierarchy tree for roll-up reporting and budget consolidation.']
  hierarchy_node varchar [note: 'The hierarchy node of the cost center record']
  last_modified_by_user varchar [note: 'User ID of the person who last modified the cost center master record. Audit trail for change tracking and SOX compliance.']
  last_modified_timestamp timestamp [note: 'Date and time when the cost center master record was last modified. Audit trail for change tracking and SOX compliance.']
  location_code varchar [note: 'Geographic location or site code for the cost center. Used for regional cost analysis and location-based reporting.']
  lock_indicator boolean [note: 'Flag indicating whether the cost center is locked for actual postings. Used during period-end close and organizational changes to prevent unintended transactions.']
  name varchar [note: 'Full descriptive name of the cost center. Human-readable label identifying the organizational unit (e.g., \'Brand Marketing - North America\', \'Manufacturing Plant 01 - Production Line A\').']
  notes varchar [note: 'The notes of the cost center record']
  parent_cost_center_code varchar [note: 'Code of the parent cost center in the organizational hierarchy. Enables hierarchical roll-up of costs for management reporting and budget aggregation.']
  plant_code varchar [note: 'Manufacturing plant or distribution center code associated with this cost center. Links production and logistics cost centers to physical facilities for COGS allocation.']
  quantity decimal(18,4) [note: 'The quantity of the cost center record']
  record_version varchar [note: 'Version number of the cost center master record. Incremented with each modification to support change history tracking and optimistic locking.']
  region_code varchar [note: 'Geographic region classification (e.g., NOAM, EMEA, APAC, LATAM) for regional financial reporting and performance benchmarking.']
  source_system_code varchar [note: 'Identifier of the source ERP system from which this cost center record originated. Supports multi-system landscapes and data lineage tracking.']
  statistical_indicator boolean [note: 'Flag indicating whether this is a statistical cost center used only for informational reporting without actual cost postings. Used for tracking non-financial metrics.']
  uom varchar [note: 'The uom of the cost center record']
  updated_timestamp timestamp [note: 'The updated timestamp of the cost center record']
  valid_from_date date [note: 'Date from which the cost center is valid and can accept cost postings. Supports time-dependent organizational changes and fiscal year transitions.']
  valid_to_date date [note: 'Date until which the cost center is valid. Nullable for open-ended cost centers. Used for organizational restructuring and cost center retirement.']
  valid_from date [note: 'The valid from of the cost center record']
  valid_to date [note: 'The valid to of the cost center record']

  Note: 'Master record for organizational cost centers used in SAP S/4HANA CO module. Defines the financial accountability units within the CPG enterprise — brand units, manufacturing plants, regional sales offices, and shared service centers. Each cost center carries a hierarchy path, responsible manager, controlling area, profit center assignment, currency, and active period. Serves as the foundational dimension for all cost accounting, COGS allocation, and EBITDA reporting.'
}

Table finance.profit_center {
  profit_center_id varchar [pk, note: 'Unique identifier for the profit center. Primary key for this entity representing an autonomous business segment within the consumer goods enterprise.']
  company_code_id varchar [note: 'The company code id of the profit center record']
  parent_profit_center_id varchar [note: 'Reference to the parent profit center in a hierarchical profit center structure. Enables roll-up reporting and EBITDA decomposition across organizational levels.']
  address_line_1 varchar [note: 'Primary street address line for the profit center\'s physical or administrative location. Organizational contact data classified as confidential.']
  address_line_2 varchar [note: 'Secondary address line for suite, building, or department information. Organizational contact data classified as confidential.']
  amount decimal(18,4) [note: 'The amount of the profit center record']
  brand_code varchar [note: 'Brand identifier for brand-based profit centers. Enables brand-level P&L reporting and brand portfolio management.']
  business_area_code varchar [note: 'Business area code representing a -code organizational unit for segment reporting. Enables consolidated financial statements by business segment.']
  channel_code varchar [note: 'Sales channel classification for channel-based profit centers: retail, wholesale, e-commerce, direct-to-consumer (DTC), foodservice, or export.']
  city varchar [note: 'City name for the profit center\'s location. Organizational contact data classified as confidential.']
  code varchar [note: 'Business identifier code for the profit center used in financial reporting and segment analysis. Externally-known unique code aligned with SAP S/4HANA CO-PCA master data.']
  consolidation_unit_code varchar [note: 'Code of the consolidation unit for. Links profit center to the financial consolidation hierarchy for IFRS/GAAP reporting.']
  cost_center_group_code varchar [note: 'Code of the cost center group associated with this profit center. Links profit center accounting to cost center accounting for overhead allocation and COGS calculation.']
  country_code varchar [note: 'Three-letter ISO 3166-1 alpha-3 country code for the profit center\'s location. Organizational contact data classified as confidential.']
  created_timestamp timestamp [note: 'Timestamp when this profit center record was first created in the system. Audit trail for record creation.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code for the profit center\'s local reporting currency. Used for revenue and cost tracking before consolidation.']
  description varchar [note: 'Detailed textual description of the profit center\'s business scope, responsibilities, and strategic objectives.']
  effective_from date [note: 'The effective from of the profit center record']
  effective_until date [note: 'The effective until of the profit center record']
  email_address varchar [note: 'General email address for the profit center for business correspondence. Organizational contact data classified as confidential.']
  fax_number varchar [note: 'Fax number for the profit center if applicable. Organizational contact data classified as confidential.']
  functional_area_code varchar [note: 'Functional area code representing the business function (e.g., production, sales, administration) for cost-of-sales accounting and functional P&L reporting.']
  geographic_region_code varchar [note: 'Three-letter ISO 3166-1 alpha-3 country or region code representing the primary geographic location of the profit center for regional segment reporting.']
  hierarchy_level varchar [note: 'Numeric level of this profit center within the organizational hierarchy. Level 1 represents top-level segments, with increasing numbers for deeper levels.']
  hierarchy_node varchar [note: 'The hierarchy node of the profit center record']
  last_modified_by_user varchar [note: 'Username or identifier of the user who last modified this profit center record. Audit trail for change accountability.']
  last_modified_timestamp timestamp [note: 'Timestamp when this profit center record was last updated. Audit trail for record modifications.']
  lock_indicator boolean [note: 'Boolean flag indicating whether the profit center is locked for transaction postings. Used during period-end close and audit processes.']
  name varchar [note: 'Full business name of the profit center representing the product line, brand, or geographic business unit.']
  notes varchar [note: 'The notes of the profit center record']
  phone_number varchar [note: 'Primary contact phone number for the profit center. Organizational contact data classified as confidential.']
  planning_enabled_flag boolean [note: 'Boolean flag indicating whether this profit center participates in budgeting and financial planning processes.']
  postal_code varchar [note: 'Postal or ZIP code for the profit center\'s location. Organizational contact data classified as confidential.']
  product_category_code varchar [note: 'Product category or product line code associated with this profit center. Used for product-based segment reporting and portfolio analysis.']
  profit_center_status varchar [note: 'Current lifecycle status of the profit center indicating whether it is operational, temporarily suspended, or permanently closed.']
  profit_center_type varchar [note: 'Classification of the profit center by organizational dimension: product line, brand, geographic region, sales channel, or business unit. Determines the segment reporting structure.']
  quantity decimal(18,4) [note: 'The quantity of the profit center record']
  responsible_person_email varchar [note: 'Email address of the profit center manager for financial reporting notifications and escalations.']
  responsible_person_name varchar [note: 'Name of the business leader or manager accountable for the profit center\'s financial performance and operational results.']
  segment varchar [note: 'The segment of the profit center record']
  segment_code varchar [note: 'Segment code for external segment reporting per IFRS 8 and US GAAP ASC 280. Represents reportable operating segments for investor disclosures.']
  short_name varchar [note: 'Abbreviated name or acronym for the profit center used in reports and dashboards for space-constrained displays.']
  source_system_code varchar [note: 'The source system code of the profit center record']
  sox_control_flag boolean [note: 'Boolean flag indicating whether this profit center is subject to SOX financial controls and audit requirements for publicly traded companies.']
  state_province_code varchar [note: 'State or province code for the profit center\'s location. Organizational contact data classified as confidential.']
  tax_jurisdiction_code varchar [note: 'Tax jurisdiction code for the profit center\'s location. Used for tax reporting and compliance with local tax authorities.']
  uom varchar [note: 'The uom of the profit center record']
  updated_timestamp timestamp [note: 'The updated timestamp of the profit center record']
  valid_from_date date [note: 'Effective start date from which this profit center is active and available for transaction postings. Supports time-dependent organizational structures.']
  valid_to_date date [note: 'Effective end date after which this profit center is no longer active. Null value indicates an open-ended validity period.']
  valuation_view varchar [note: 'Valuation perspective for profit center accounting: legal (statutory), group (IFRS/GAAP consolidation), profit center (internal transfer pricing), or management (operational view).']

  Note: 'Master record for profit centers representing autonomous business segments within the consumer goods enterprise — product lines, brands, or geographic business units. Tracks revenue, cost, and profitability at a granular level below the legal entity. Integrates with SAP S/4HANA CO-PCA (Profit Center Accounting) and Oracle Cloud Financials for segment reporting and EBITDA decomposition.'
}

Table finance.gl_account {
  gl_account_id varchar [pk, note: 'Unique identifier for the general ledger account. Primary key for the GL account master data.']
  company_code_id varchar [note: 'Reference to the company code (legal entity) to which this GL account belongs. Links to the company_code master data.']
  account_group varchar [note: 'The account group classification that controls field status, number ranges, and posting rules in the ERP system.']
  account_name varchar [note: 'The full descriptive name of the GL account as it appears in financial reports and statements.']
  account_number varchar [note: 'The externally-known unique account number in the chart of accounts. This is the business identifier used in financial postings and reporting.']
  account_short_name varchar [note: 'Abbreviated name or label for the GL account used in condensed reports and system displays.']
  account_status varchar [note: 'The current lifecycle status of the GL account: active (in use), inactive (not currently used but retained), pending approval (awaiting activation), or archived (historical only).']
  account_type varchar [note: 'The fundamental accounting classification of the account: asset, liability, equity, revenue, expense, or statistical (non-monetary).']
  amount decimal(18,4) [note: 'The amount of the gl account record']
  balance_sheet_classification varchar [note: 'For balance sheet accounts, indicates whether the account is a current asset, non-current asset, current liability, non-current liability, or equity. Not applicable for P&L accounts.']
  balance_sheet_flag boolean [note: 'The balance sheet flag of the gl account record']
  balance_sheet_indicator boolean [note: 'The balance sheet indicator of the gl account record']
  blocked_for_posting boolean [note: 'The blocked for posting of the gl account record']
  blocked_for_posting_flag boolean [note: 'Indicates whether the account is currently blocked for all postings. Used to prevent transactions to accounts that are under review, closed, or being restructured.']
  budget_control_flag boolean [note: 'Indicates whether budget availability checking is active for this account. When enabled, postings are validated against approved budgets.']
  cash_flow_category varchar [note: 'For accounts that impact cash flow, indicates the cash flow statement category: operating activities, investing activities, or financing activities. Not applicable for non-cash accounts.']
  code varchar [note: 'The gl account code of the gl account record']
  consolidation_account_number varchar [note: 'The corresponding account number in the group consolidation chart of accounts. Used for mapping local accounts to structures.']
  cost_center_required_flag boolean [note: 'Indicates whether a cost center assignment is mandatory when posting to this account. Used for internal cost allocation and management reporting.']
  cost_element_category varchar [note: 'For accounts that are cost elements, indicates whether it is a primary cost element (direct posting from FI) or secondary cost element (internal allocation only). Not applicable if not a cost element.']
  cost_element_flag boolean [note: 'Indicates whether this GL account is also defined as a cost element in the Controlling (CO) module for cost center and internal order postings.']
  created_by_user varchar [note: 'The user ID of the person who created this GL account record. Used for audit trail and accountability.']
  created_timestamp timestamp [note: 'The date and time when this GL account record was first created in the system.']
  currency_code varchar [note: 'The three-letter ISO 4217 currency code for the account\'s local currency. For multi-currency accounts, this is the primary reporting currency.']
  debit_credit_indicator varchar [note: 'Indicates whether the account normally carries a debit balance or credit balance in the general ledger.']
  description varchar [note: 'The gl account description of the gl account record']
  effective_from date [note: 'The effective from of the gl account record']
  effective_until date [note: 'The effective until of the gl account record']
  field_status_group varchar [note: 'The field status group that controls which fields are required, optional, or suppressed when posting to this account.']
  financial_statement_category varchar [note: 'The primary financial statement where this account appears: balance sheet, income statement (P&L), cash flow statement, retained earnings, or statistical.']
  financial_statement_line_item varchar [note: 'The specific line item or section within the financial statement where this account balance is reported (e.g., Current Assets, Cost of Goods Sold, Operating Expenses).']
  gl_account_number varchar [note: 'The gl account number of the gl account record']
  gl_account_status varchar [note: 'The gl account status of the gl account record']
  intercompany_clearing_flag boolean [note: 'Indicates whether this account is used for intercompany transactions that require clearing and elimination in consolidated financial statements.']
  last_modified_by_user varchar [note: 'The user ID of the person who last modified this GL account record. Used for audit trail and change tracking.']
  last_modified_timestamp timestamp [note: 'The date and time when this GL account record was last modified.']
  line_item_display_flag boolean [note: 'Indicates whether individual line item details are stored and can be displayed for this account. Required for detailed transaction analysis and audit trails.']
  name varchar [note: 'The gl account name of the gl account record']
  notes varchar [note: 'The notes of the gl account record']
  open_item_management_flag boolean [note: 'Indicates whether this account uses open item management for tracking and clearing individual line items (e.g., AR, AP, bank clearing accounts).']
  pl_category varchar [note: 'For income statement accounts, indicates the P&L category: gross revenue, net revenue, COGS, gross margin, operating expense (SG&A, marketing, trade spend), EBITDA, EBIT, or net income. Not applicable for balance sheet accounts. [ENUM-REF-CANDIDATE: gross_revenue|net_revenue|cogs|gross_margin|operating_expense|ebitda|ebit|net_income|not_applicable — 9 candidates stripped; promote to reference product]']
  pl_statement_flag boolean [note: 'The pl statement flag of the gl account record']
  planning_level varchar [note: 'The organizational level at which budget planning and forecasting is performed for this account (e.g., company code, profit center, cost center).']
  posting_allowed_flag boolean [note: 'Indicates whether direct postings are allowed to this account. Some accounts (e.g., summary or control accounts) may only accept postings from automated processes.']
  profit_center_required_flag boolean [note: 'Indicates whether a profit center assignment is mandatory when posting to this account. Used for segment reporting and profitability analysis.']
  quantity decimal(18,4) [note: 'The quantity of the gl account record']
  reconciliation_account_flag boolean [note: 'Indicates whether this is a reconciliation account (subledger control account) that summarizes detailed transactions from subsidiary ledgers such as AR, AP, or inventory.']
  retained_earnings_account_flag boolean [note: 'Indicates whether this is the retained earnings account where net income/loss is transferred during year-end closing.']
  sort_key varchar [note: 'The default sort key used for organizing and displaying line items within this account (e.g., posting date, document number, amount).']
  source_system_code varchar [note: 'The source system code of the gl account record']
  sox_control_account_flag boolean [note: 'Indicates whether this account is subject to SOX internal control requirements and enhanced audit procedures.']
  tax_category varchar [note: 'The tax treatment category for this account (e.g., taxable revenue, non-taxable revenue, input tax, output tax, tax-exempt). Used for VAT, sales tax, and GST reporting.']
  tax_code_allowed_flag boolean [note: 'Indicates whether tax codes can be entered when posting to this account. Typically true for revenue and expense accounts, false for balance sheet accounts.']
  uom varchar [note: 'The uom of the gl account record']
  updated_timestamp timestamp [note: 'The updated timestamp of the gl account record']
  valid_from_date date [note: 'The date from which this GL account is valid and available for posting. Used for time-dependent account structures.']
  valid_to_date date [note: 'The date until which this GL account is valid. After this date, the account is no longer available for posting. Null indicates no end date.']

  Note: 'General ledger chart of accounts master for the consumer goods enterprise. Defines every account in the COA including P&L accounts (revenue, COGS, trade spend, marketing, SG&A), balance sheet accounts (inventory, AR, AP, fixed assets), and statistical accounts. Stores account type, financial statement category, tax category, reconciliation account flag, currency, and controlling relevance. Source of truth for all financial postings in SAP S/4HANA FI and Oracle Cloud Financials.'
}

Table finance.ledger {
  ledger_id varchar [pk, note: 'Unique identifier for the financial ledger record. Primary key for the ledger entity.']
  company_code_id varchar [note: 'FK to finance.company_code']
  accounting_principle varchar [note: 'The accounting standard or principle applied in this ledger, such as International Financial Reporting Standards (IFRS), United States Generally Accepted Accounting Principles (US GAAP), local country-specific GAAP, tax accounting rules, or management accounting conventions.']
  amount decimal(18,4) [note: 'The amount of the ledger record']
  audit_trail_enabled boolean [note: 'Boolean flag indicating whether comprehensive audit trail logging is enabled for all postings and changes to this ledger, supporting regulatory compliance and forensic analysis.']
  base_currency_code varchar [note: 'Three-letter ISO 4217 currency code representing the base currency in which this ledger maintains balances (e.g., USD, EUR, GBP, JPY).']
  code varchar [note: 'Short alphanumeric code uniquely identifying the ledger within the enterprise. Used as the business identifier for the ledger in SAP S/4HANA FI and Oracle Cloud Financials.']
  consolidation_ledger_flag boolean [note: 'Boolean flag indicating whether this ledger is used for group consolidation purposes, aggregating financial data from multiple legal entities for consolidated financial statements.']
  created_timestamp timestamp [note: 'Timestamp recording when this ledger record was first created in the system. Part of the audit trail for ledger lifecycle management.']
  currency_code varchar [note: 'The currency code of the ledger record']
  currency_type varchar [note: 'Defines the currency perspective maintained in this ledger. Local currency represents the operating entity\'s functional currency, group currency is the consolidated reporting currency, hard currency is a stable reference currency (e.g., USD, EUR), and index currency supports inflation-adjusted reporting.']
  description varchar [note: 'Detailed textual description of the ledger\'s purpose, scope, and usage within the enterprise financial reporting architecture. Provides context for finance users and auditors.']
  effective_end_date date [note: 'The date on which this ledger ceases to be active and no longer accepts financial postings. Null for ledgers with indefinite validity.']
  effective_from date [note: 'The effective from of the ledger record']
  effective_start_date date [note: 'The date from which this ledger becomes active and begins accepting financial postings. Supports temporal validity for ledger lifecycle management.']
  effective_until date [note: 'The effective until of the ledger record']
  fiscal_year_variant varchar [note: 'Code identifying the fiscal year calendar structure used by this ledger, defining the number of posting periods, special periods, and year-end closing rules. Common in SAP S/4HANA FI to support diverse fiscal calendars across global entities.']
  is_leading_ledger boolean [note: 'Boolean flag indicating whether this is the leading ledger (primary book of record) for the company code. Only one ledger per company code can be designated as the leading ledger.']
  last_modified_by varchar [note: 'User identifier or name of the person who last modified this ledger record. Supports change tracking and audit trail for ledger configuration.']
  last_modified_timestamp timestamp [note: 'Timestamp recording when this ledger record was last modified. Enables change tracking and supports audit trail requirements for financial system configuration.']
  leading_ledger_flag boolean [note: 'The leading ledger flag of the ledger record']
  ledger_status varchar [note: 'Current operational status of the ledger. Active ledgers accept postings, inactive ledgers are configured but not yet in use, closed ledgers are archived and no longer accept postings, and suspended ledgers are temporarily disabled.']
  ledger_type varchar [note: 'Classification of the ledger indicating its role in the financial reporting architecture. Leading ledger is the primary book of record, parallel ledgers support alternative accounting principles (e.g., local GAAP), and extension ledgers provide management reporting views.']
  name varchar [note: 'Full descriptive name of the ledger for human-readable identification and reporting purposes.']
  notes varchar [note: 'The notes of the ledger record']
  posting_period_variant varchar [note: 'Code defining the posting period structure for this ledger, including the number of regular periods (typically 12 monthly periods) and special periods for year-end adjustments and closing entries.']
  quantity decimal(18,4) [note: 'The quantity of the ledger record']
  retention_period_years varchar [note: 'Number of years that financial data in this ledger must be retained to comply with statutory, tax, and regulatory record-keeping requirements. Common retention periods range from 7 to 10 years for financial records.']
  source_system_code varchar [note: 'The source system code of the ledger record']
  sox_compliant_flag boolean [note: 'Boolean flag indicating whether this ledger maintains controls and audit trails compliant with Sarbanes-Oxley Act Section 404 requirements for internal controls over financial reporting.']
  supports_cost_of_sales_accounting boolean [note: 'Boolean flag indicating whether this ledger supports cost of sales (COGS) accounting method, which matches costs directly to revenue in the period of sale, as opposed to period-based cost accounting.']
  supports_profit_center_accounting boolean [note: 'Boolean flag indicating whether this ledger maintains profit center accounting data for internal management reporting and profitability analysis by organizational unit.']
  supports_segment_reporting boolean [note: 'Boolean flag indicating whether this ledger supports segment reporting as required by IFRS 8 Operating Segments. Segment reporting enables financial analysis by business unit, product line, or geographic region.']
  uom varchar [note: 'The uom of the ledger record']
  updated_timestamp timestamp [note: 'The updated timestamp of the ledger record']
  valuation_view varchar [note: 'Defines the valuation perspective applied in this ledger. Legal valuation follows statutory requirements, group valuation applies consolidated group policies, profit center valuation supports internal management reporting, and cost center valuation tracks cost allocation.']
  created_by varchar [note: 'User identifier or name of the person who created this ledger record in the system. Supports audit trail and accountability for ledger configuration changes.']

  Note: 'Financial ledger master defining the accounting ledgers maintained in the enterprise — leading ledger (IFRS/GAAP), parallel ledgers for local GAAP, and extension ledgers for management reporting. Each ledger record captures ledger type, accounting principle, currency type, fiscal year variant, and posting period variant. Supports multi-GAAP reporting requirements common in global CPG companies operating across multiple regulatory jurisdictions.'
}

Table finance.journal_entry {
  journal_entry_id varchar [pk, note: 'Unique identifier for the journal entry record. Primary key for the journal entry header.']
  company_code_id varchar [note: 'The company code id of the journal entry record']
  cost_center_id varchar [note: 'Identifier of the cost center to which costs or revenues from this journal entry are allocated. Used for management accounting and EBITDA reporting.']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Journal entries reference GL accounts by code; adding gl_account_id FK normalizes the relationship and removes the redundant code column.']
  ledger_id varchar [note: 'Foreign key linking to finance.ledger. Business justification: Journal entries belong to a specific ledger; adding ledger_id FK links each entry to its ledger without removing existing ledger_group (kept for reporting).']
  profit_center_id varchar [note: 'Identifier of the profit center for segment reporting and profitability analysis. Used for EBITDA calculation by business unit.']
  amount decimal(18,4) [note: 'The amount of the journal entry record']
  approval_timestamp timestamp [note: 'Date and time when the journal entry was approved. Part of the SOX-compliant audit trail. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  baseline_payment_date date [note: 'The baseline date used for calculating payment terms and due dates for vendor invoices and customer receivables. Format: yyyy-MM-dd.']
  batch_input_session varchar [note: 'Identifier of the batch input session if this journal entry was created through automated batch processing. Used for tracking mass data uploads and interface postings.']
  business_area_code varchar [note: 'Code representing the business area or division for code reporting. Used for consolidated financial statements.']
  clearing_date date [note: 'The date on which this open item was cleared. Used for DSO and DIO calculation. Format: yyyy-MM-dd.']
  clearing_document_number varchar [note: 'Document number of the clearing document if this open item has been cleared (paid or offset). Used for accounts payable and receivable reconciliation.']
  code varchar [note: 'The journal entry code of the journal entry record']
  controlling_area varchar [note: 'Organizational unit in management accounting that represents a closed system for cost accounting. Used for internal management reporting.']
  created_timestamp timestamp [note: 'Date and time when this journal entry record was first created in the system. Part of the audit trail. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code representing the document currency in which the journal entry amounts are denominated. Examples: USD, EUR, GBP, JPY.']
  description varchar [note: 'The journal entry description of the journal entry record']
  document_date date [note: 'The date printed on the source document (invoice, receipt, payment voucher). May differ from posting date. Used for document control and audit trail. Format: yyyy-MM-dd.']
  document_number varchar [note: 'Unique alphanumeric identifier assigned to the accounting document within the company code and fiscal year. This is the externally visible business key for the journal entry.']
  document_type varchar [note: 'Classification code indicating the nature and source of the journal entry. Examples: SA (General Ledger Document), AB (Accounting Document), KR (Vendor Invoice), DR (Customer Invoice), DZ (Customer Payment), KA (Vendor Payment), KG (Vendor Credit Memo), KN (Customer Credit Memo), KZ (Payment Request), RE (Invoice Receipt), RV (Invoice Reversal), WA (Goods Issue), WE (Goods Receipt), ZP (Payment Posting). [ENUM-REF-CANDIDATE: SA|AB|KR|DR|DZ|KA|KG|KN|KZ|RE|RV|WA|WE|ZP — 14 candidates stripped; promote to reference product]']
  effective_from date [note: 'The effective from of the journal entry record']
  effective_until date [note: 'The effective until of the journal entry record']
  entry_date date [note: 'The date on which the journal entry was created or entered into the system. Used for audit trail and process monitoring. Format: yyyy-MM-dd.']
  entry_status varchar [note: 'The entry status of the journal entry record']
  entry_type varchar [note: 'The entry type of the journal entry record']
  exchange_rate decimal(15,5) [note: 'The exchange rate used to convert document currency amounts to local currency. Expressed as local currency per one unit of document currency. Null if document currency equals local currency.']
  exchange_rate_type varchar [note: 'Code indicating the type of exchange rate used for currency translation. Examples: M (Average Rate), B (Bank Buying Rate), G (Bank Selling Rate), P (Posting Date Rate).']
  fiscal_period varchar [note: 'Numeric period within the fiscal year (typically 1-12 for monthly periods, or 1-13 for year-end adjustments). Determines the reporting period for financial statements.']
  fiscal_year varchar [note: 'Four-digit year representing the fiscal year to which this journal entry is assigned. Used for period-based financial reporting and year-end closing.']
  functional_area_code varchar [note: 'Code classifying the journal entry by functional area (e.g., Production, Sales, Administration, R&D). Used for cost of goods sold (COGS) allocation and functional expense reporting.']
  header_text varchar [note: 'Free-form text field for additional information or explanation about the journal entry. Used for documentation and audit purposes.']
  intercompany_indicator boolean [note: 'Boolean flag indicating whether this journal entry involves intercompany transactions between different company codes within the enterprise. True if intercompany, False otherwise.']
  journal_entry_number varchar [note: 'The journal entry number of the journal entry record']
  journal_entry_status varchar [note: 'The journal entry status of the journal entry record']
  ledger_group varchar [note: 'Two-character code identifying the ledger or accounting principle under which this entry is recorded. Examples: 0L (Leading Ledger - IFRS), 2L (Local GAAP), 3L (Management Reporting). Supports parallel accounting for multiple reporting standards.']
  local_currency_code varchar [note: 'Three-letter ISO 4217 currency code representing the company code local currency. All amounts are translated to this currency for statutory reporting.']
  modified_timestamp timestamp [note: 'Date and time when this journal entry record was last modified. Part of the audit trail for tracking changes. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.']
  name varchar [note: 'The journal entry name of the journal entry record']
  notes varchar [note: 'The notes of the journal entry record']
  payment_terms_code varchar [note: 'Code representing the payment terms applicable to this document (e.g., Net 30, 2/10 Net 30). Used for cash flow forecasting and DSO tracking.']
  posted_by varchar [note: 'The posted by of the journal entry record']
  posting_date date [note: 'The date on which the journal entry is posted to the general ledger. This is the effective date for financial reporting and determines the fiscal period assignment. Format: yyyy-MM-dd.']
  posting_status varchar [note: 'Current lifecycle status of the journal entry. Values: draft (entry created but not posted), posted (entry successfully posted to GL), parked (entry saved for later posting), cancelled (entry voided before posting), reversed (entry reversed by a subsequent document).']
  quantity decimal(18,4) [note: 'The quantity of the journal entry record']
  reference_document_number varchar [note: 'External reference number from the source document (invoice number, purchase order number, payment reference). Used for cross-referencing and reconciliation.']
  reversal_flag boolean [note: 'The reversal flag of the journal entry record']
  reversal_indicator boolean [note: 'Boolean flag indicating whether this journal entry is a reversal of a previous entry. True if this is a reversal document, False otherwise.']
  reversal_reason_code varchar [note: 'Code indicating the reason for reversing the original document. Examples: 01 (Reversal in Current Period), 02 (Reversal in Next Period), 03 (Correction), 04 (Accrual Reversal), 05 (Error Correction), 06 (Period-End Adjustment). [ENUM-REF-CANDIDATE: 01|02|03|04|05|06|07|08|09 — promote to reference product]']
  reversed_document_number varchar [note: 'Document number of the original journal entry that is being reversed by this entry. Populated only when reversal_indicator is True.']
  source_system_code varchar [note: 'Code identifying the operational system of record from which this journal entry originated. Examples: SAP_FI (SAP S/4HANA Financial Accounting), SAP_CO (SAP Controlling), ORACLE_GL (Oracle Cloud General Ledger), ORACLE_AP (Oracle Accounts Payable), ORACLE_AR (Oracle Accounts Receivable), SFDC (Salesforce), WMS (Warehouse Management System), MES (Manufacturing Execution System). [ENUM-REF-CANDIDATE: SAP_FI|SAP_CO|ORACLE_GL|ORACLE_AP|ORACLE_AR|SFDC|WMS|MES — 8 candidates stripped; promote to reference product]']
  sox_control_flag boolean [note: 'Boolean flag indicating whether this journal entry is subject to SOX internal control testing and audit procedures. True if SOX-controlled, False otherwise.']
  tax_reporting_date date [note: 'The date relevant for tax reporting purposes. May differ from posting date based on tax jurisdiction rules. Format: yyyy-MM-dd.']
  total_credit decimal(18,4) [note: 'The total credit of the journal entry record']
  total_credit_amount decimal(18,2) [note: 'The total credit amount of the journal entry record']
  total_debit decimal(18,4) [note: 'The total debit of the journal entry record']
  total_debit_amount decimal(18,2) [note: 'The total debit amount of the journal entry record']
  trading_partner_company_code varchar [note: 'Company code of the intercompany trading partner if this is an intercompany transaction. Used for consolidation and elimination entries. Null if not an intercompany transaction.']
  transaction_code varchar [note: 'SAP transaction code or Oracle program identifier used to create this journal entry. Examples: FB01 (Post Document), FB50 (G/L Account Posting), MIRO (Enter Invoice), F-28 (Post Incoming Payments). Used for audit trail and process analysis.']
  uom varchar [note: 'The uom of the journal entry record']
  updated_timestamp timestamp [note: 'The updated timestamp of the journal entry record']

  Note: 'Core general ledger journal entry header capturing every financial posting in the consumer goods enterprise. Records document type (vendor invoice, customer payment, goods issue, payroll posting, accrual, reversal), posting date, fiscal period, company code, ledger, currency, exchange rate, reference document, and SOX-compliant posting user and approval chain. The authoritative transactional record for all financial activity sourced from SAP S/4HANA FI and Oracle Cloud Financials.'
}

Table finance.journal_entry_line {
  journal_entry_line_id varchar [pk, note: 'Unique identifier for the journal entry line item. Primary key for granular cost allocation, COGS decomposition, and SOX-compliant audit trail tracing at the line level.']
  cost_center_id varchar [note: 'The cost center id of the journal entry line record']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Journal entry lines store GL account code; FK to gl_account enables proper account lookup and eliminates duplicate code.']
  journal_entry_id varchar [note: 'Reference to the parent journal entry header document. Links this line to the overall journal entry batch and posting context.']
  profit_center_id varchar [note: 'The profit center id of the journal entry line record']
  purchase_order_id varchar [note: 'Foreign key linking to procurement.purchase_order. Business justification: Journal entry lines for GR/IR accruals, goods receipt postings, and AP invoice postings reference the originating PO for three-way match audit trails and procurement-to-pay reconciliation. This is a s']
  supplier_invoice_id varchar [note: 'Foreign key linking to procurement.supplier_invoice. Business justification: Journal entry lines generated from AP invoice processing reference the originating supplier invoice for AP subledger-to-GL reconciliation, audit trail completeness, and period-end AP accrual reporting']
  amount decimal(18,2) [note: 'The amount of the journal entry line record']
  amount_company_code_currency decimal(18,2) [note: 'Monetary amount converted to the local currency of the company code. Used for statutory reporting and local GAAP compliance.']
  amount_group_currency decimal(18,2) [note: 'Monetary amount converted to the currency. Enables consolidated financial reporting across all subsidiaries.']
  amount_transaction_currency decimal(18,2) [note: 'Monetary amount of this line item in the original transaction currency. Preserves the original posting amount before currency conversion.']
  assignment_field varchar [note: 'Free-text assignment field for additional reference information such as invoice number, purchase order, or payment reference. Enhances traceability.']
  baseline_payment_date date [note: 'Baseline date for payment terms calculation. Used to compute due dates and cash discount periods.']
  business_area_code varchar [note: 'Business area classification for code segment reporting. Enables consolidated financial statements by business segment.']
  clearing_date date [note: 'Date on which this open item was cleared or settled. Null if the item remains open.']
  clearing_document_number varchar [note: 'Document number of the clearing entry that settled this open item. Null if the item remains open.']
  code varchar [note: 'The journal entry line code of the journal entry line record']
  company_code varchar [note: 'Legal entity identifier representing the company or subsidiary for which this line is posted. Enables consolidated and statutory reporting.']
  company_code_currency_code varchar [note: 'ISO 4217 three-letter currency code for the company code local currency. Typically the statutory reporting currency of the legal entity.']
  created_timestamp timestamp [note: 'The created timestamp of the journal entry line record']
  currency_code varchar [note: 'The currency code of the journal entry line record']
  customer_account_number varchar [note: 'Customer account number for revenue and receivables postings. Links financial transactions to customer master data.']
  debit_credit_indicator varchar [note: 'Indicates whether this line is a debit (D) or credit (C) posting. Fundamental to double-entry bookkeeping and account balance calculation.']
  description varchar [note: 'The journal entry line description of the journal entry line record']
  document_amount decimal(18,4) [note: 'The document amount of the journal entry line record']
  due_date date [note: 'Date by which payment is due for payables or expected for receivables. Critical for DSO and cash flow management.']
  effective_from date [note: 'The effective from of the journal entry line record']
  effective_until date [note: 'The effective until of the journal entry line record']
  exchange_rate decimal(12,6) [note: 'Exchange rate applied to convert transaction currency to company code or group currency. Critical for currency translation audit trail.']
  functional_area_code varchar [note: 'Functional area classification (e.g., production, sales, administration, R&D). Supports cost-of-sales accounting and functional expense reporting.']
  group_currency_code varchar [note: 'ISO 4217 three-letter currency code for the currency. Typically USD or EUR for consumer goods companies.']
  internal_order_number varchar [note: 'Internal order for tracking costs of short-term jobs, events, or overhead activities. Enables job costing and overhead allocation.']
  journal_entry_line_status varchar [note: 'The journal entry line status of the journal entry line record']
  line_item_number varchar [note: 'Sequential line number within the journal entry header. Determines the ordering and position of this line in the document.']
  line_number varchar [note: 'The line number of the journal entry line record']
  line_text varchar [note: 'The line text of the journal entry line record']
  local_amount decimal(18,4) [note: 'The local amount of the journal entry line record']
  material_number varchar [note: 'Material or SKU associated with this line item for inventory and COGS postings. Links financial postings to product master data.']
  name varchar [note: 'The journal entry line name of the journal entry line record']
  notes varchar [note: 'The notes of the journal entry line record']
  payment_terms_code varchar [note: 'Payment terms applicable to this line item. Determines due date calculation and cash discount eligibility.']
  plant_code varchar [note: 'Manufacturing plant or distribution center associated with this line item. Supports plant-level cost accounting and inventory management.']
  posting_key varchar [note: 'Two-digit posting key controlling account type, debit/credit indicator, and field status. Fundamental to SAP FI posting logic.']
  quantity decimal(15,3) [note: 'Quantity of material or units associated with this line item. Enables unit cost calculation and inventory valuation.']
  reference_document_number varchar [note: 'External or internal document number referenced by this line (e.g., invoice, purchase order, contract). Supports document linkage and reconciliation.']
  reversal_indicator boolean [note: 'Flag indicating whether this line item is a reversal of a previous posting. True if this is a reversal entry.']
  reversed_document_number varchar [note: 'Document number of the original entry that this line reverses. Null if this is not a reversal.']
  source_system_code varchar [note: 'The source system code of the journal entry line record']
  special_gl_indicator varchar [note: 'Special GL indicator for down payments, bills of exchange, guarantees, or other special transactions. Enables special ledger processing.']
  storage_location_code varchar [note: 'Storage location within the plant for inventory-related postings. Enables warehouse-level inventory tracking and valuation.']
  tax_amount decimal(18,2) [note: 'Tax amount calculated for this line item in transaction currency. Supports VAT, sales tax, and other indirect tax reporting.']
  tax_code varchar [note: 'Tax code determining the tax treatment of this line item. Drives automatic tax calculation and tax reporting compliance.']
  text_description varchar [note: 'Descriptive text explaining the nature or purpose of this journal entry line. Provides human-readable context for audit and review.']
  trading_partner_code varchar [note: 'Identifier of the intercompany trading partner for intercompany transactions. Enables intercompany reconciliation and elimination entries.']
  transaction_currency_code varchar [note: 'ISO 4217 three-letter currency code for the transaction amount. Identifies the currency in which the original transaction was denominated.']
  unit_of_measure varchar [note: 'Unit of measure for the quantity field (e.g., EA, KG, LT). Standardizes quantity representation across transactions.']
  uom varchar [note: 'The uom of the journal entry line record']
  updated_timestamp timestamp [note: 'The updated timestamp of the journal entry line record']
  value_date date [note: 'Value date for cash management and bank reconciliation. Represents the effective date for interest calculation and cash position.']
  vendor_account_number varchar [note: 'Vendor account number for procurement and payables postings. Links financial transactions to vendor master data.']
  wbs_element_code varchar [note: 'WBS element for project-related postings. Links costs and revenues to specific projects, phases, or deliverables in project accounting.']

  Note: 'Individual line items of a general ledger journal entry. Each line captures the GL account, cost center, profit center, WBS element, business area, debit/credit indicator, amount in transaction currency, amount in company code currency, amount in group currency, tax code, and assignment field. Enables granular cost allocation, COGS decomposition, and audit trail tracing at the line level as required by SOX compliance.'
}

Table finance.ar_invoice {
  ar_invoice_id varchar [pk, note: 'Unique identifier for the accounts receivable invoice record. Primary key for the AR invoice entity.']
  company_code_id varchar [note: 'The company code id of the ar invoice record']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: AR invoices reference GL accounts by code; adding FK normalizes accounting data.']
  journal_entry_id varchar [note: 'Foreign key linking to finance.journal_entry. Business justification: In SAP S/4HANA FI, every AR invoice generates a corresponding FI document (journal entry) for the revenue and receivable posting. Linking ar_invoice to journal_entry enables full audit trail from trad']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: In SAP FI, AR invoices are assigned to profit centers for revenue recognition by business segment. This FK enables profit center-level revenue reporting and EBITDA analysis by segment. No redundant pr']
  sales_invoice_id varchar [note: 'Foreign key linking to sales.invoice. Business justification: AR invoice reconciliation process matches each AR invoice to the originating sales invoice for cash application.']
  trade_account_id varchar [note: 'Reference to the trade account (customer) to whom this invoice was issued. Links to the customer master record.']
  amount decimal(18,4) [note: 'The amount of the ar invoice record']
  amount_received decimal(18,2) [note: 'Total amount received from the customer against this invoice. May be less than total amount due to partial payments or deductions. Null for unpaid invoices.']
  ar_invoice_number varchar [note: 'The ar invoice number of the ar invoice record']
  ar_invoice_status varchar [note: 'The ar invoice status of the ar invoice record']
  billing_date date [note: 'Date when the invoice was created and issued to the customer. Principal business event timestamp for the invoice lifecycle.']
  billing_document_type varchar [note: 'SAP billing document type code indicating the nature of the invoice (e.g., F2=standard invoice, G2=credit memo, L2=debit memo). Determines accounting treatment and revenue recognition.']
  clearing_date date [note: 'Date when the invoice was cleared in the financial system, either through full payment or write-off. Null for open invoices.']
  clearing_reference varchar [note: 'Reference number assigned when the invoice is cleared in the financial system. Links to the clearing document for audit trail. Null for open invoices.']
  code varchar [note: 'The ar invoice code of the ar invoice record']
  created_timestamp timestamp [note: 'System timestamp when the invoice record was first created in the AR system. Used for audit trail and data lineage tracking.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code in which the invoice is denominated (e.g., USD, EUR, GBP). Critical for multi-currency reporting and foreign exchange management.']
  deduction_amount decimal(18,2) [note: 'Total amount of deductions taken by the customer against this invoice. Includes short-payments, chargebacks, and unauthorized deductions requiring resolution.']
  deduction_reason_code varchar [note: 'Code indicating the reason for customer deductions (e.g., pricing dispute, damaged goods, short shipment, promotional allowance). Used for deduction root cause analysis.']
  description varchar [note: 'The ar invoice description of the ar invoice record']
  dispute_flag boolean [note: 'Indicates whether the invoice is currently under dispute by the customer. True if disputed, false otherwise. Disputed invoices are excluded from standard collection processes.']
  dispute_reason varchar [note: 'Free-text description of the reason the customer is disputing the invoice. Used for dispute resolution and root cause analysis.']
  distribution_channel varchar [note: 'Channel through which the goods were sold (e.g., retail, wholesale, DTC, e-commerce). Used for channel profitability analysis.']
  dso_aging_bucket varchar [note: 'Aging category based on number of days the invoice has been outstanding past the due date. Used for DSO reporting, collections prioritization, and bad debt provisioning.']
  due_date date [note: 'Date by which payment is expected from the customer based on agreed payment terms. Used for Days Sales Outstanding (DSO) calculation and dunning.']
  dunning_level varchar [note: 'Current dunning level indicating the escalation stage of collection efforts (0=no dunning, 1=first reminder, 2=second reminder, etc.). Higher levels indicate more aggressive collection actions.']
  effective_from date [note: 'The effective from of the ar invoice record']
  effective_until date [note: 'The effective until of the ar invoice record']
  fiscal_period varchar [note: 'Fiscal period (month) within the fiscal year when the invoice was posted. Used for monthly financial reporting and trend analysis.']
  fiscal_year varchar [note: 'Fiscal year in which the invoice was posted. Used for year-over-year financial analysis and annual reporting.']
  gl_posting_date date [note: 'Date when the invoice was posted to the general ledger. Used for financial period assignment and month-end close processes.']
  gross_amount decimal(18,2) [note: 'Total invoice amount before any trade discounts, deductions, or adjustments. Represents the full billed value of goods or services.']
  invoice_date date [note: 'The invoice date of the ar invoice record']
  invoice_number varchar [note: 'Externally-known unique invoice number assigned by the billing system. Used for customer communication and payment reference.']
  invoice_status varchar [note: 'Current lifecycle status of the invoice in the accounts receivable process. Tracks progression from open through payment to clearing or write-off. [ENUM-REF-CANDIDATE: open|partially_paid|paid|cleared|written_off|disputed|cancelled — 7 candidates stripped; promote to reference product]']
  last_dunning_date date [note: 'Date when the most recent dunning notice was sent to the customer. Used to track collection activity frequency and determine next dunning action.']
  modified_by_user varchar [note: 'User ID of the person who last modified the invoice record. Required for SOX compliance and segregation of duties controls.']
  modified_timestamp timestamp [note: 'System timestamp when the invoice record was last modified. Used for change tracking and SOX compliance audit trails.']
  name varchar [note: 'The ar invoice name of the ar invoice record']
  net_amount decimal(18,2) [note: 'Invoice amount after trade discounts but before tax. This is the base amount subject to taxation and the primary value for revenue recognition.']
  notes varchar [note: 'The notes of the ar invoice record']
  outstanding_amount decimal(18,4) [note: 'The outstanding amount of the ar invoice record']
  outstanding_balance decimal(18,2) [note: 'Remaining unpaid balance on the invoice. Calculated as total amount minus amount received. Zero when invoice is fully paid or cleared.']
  payment_date date [note: 'Date when payment was received from the customer. Null for unpaid invoices. Used for DSO calculation and cash flow analysis.']
  payment_method varchar [note: 'Method by which the customer is expected to remit payment. Used for cash application automation and payment reconciliation.']
  payment_status varchar [note: 'The payment status of the ar invoice record']
  payment_terms varchar [note: 'The payment terms of the ar invoice record']
  payment_terms_code varchar [note: 'Code representing the payment terms agreed with the customer (e.g., Net 30, Net 60, 2/10 Net 30). Determines due date calculation and early payment discount eligibility.']
  quantity decimal(18,4) [note: 'The quantity of the ar invoice record']
  revenue_recognition_date date [note: 'Date when revenue from this invoice is recognized in the financial statements under ASC 606/IFRS 15. May differ from billing date based on performance obligation fulfillment.']
  sales_order_number varchar [note: 'Reference to the originating sales order that generated this invoice. Links invoice to order fulfillment and enables order-to-cash traceability.']
  sales_organization varchar [note: 'SAP sales organization responsible for the sale. Used for sales performance reporting and commission calculation.']
  shipment_number varchar [note: 'Reference to the shipment or delivery document associated with this invoice. Links billing to physical goods movement for OTIF tracking.']
  source_system_code varchar [note: 'The source system code of the ar invoice record']
  tax_amount decimal(18,2) [note: 'Total tax amount charged on the invoice, including sales tax, VAT, GST, or other applicable indirect taxes based on jurisdiction.']
  total_amount decimal(18,2) [note: 'Final invoice amount including all discounts and taxes. This is the total amount due from the customer and the target for cash application.']
  trade_discount_amount decimal(18,2) [note: 'Total trade discounts applied to the invoice, including volume discounts, promotional allowances, and negotiated rebates. Reduces gross amount to net amount.']
  uom varchar [note: 'The uom of the ar invoice record']
  updated_timestamp timestamp [note: 'The updated timestamp of the ar invoice record']
  write_off_amount decimal(18,2) [note: 'Amount written off as uncollectible bad debt. Null for invoices not written off. Impacts bad debt expense and allowance for doubtful accounts.']
  write_off_date date [note: 'Date when the invoice or portion thereof was written off as uncollectible. Null for invoices not written off.']
  write_off_reason_code varchar [note: 'Code indicating the reason for write-off (e.g., customer bankruptcy, uncollectible, small balance write-off). Used for bad debt analysis and credit policy refinement.']

  Note: 'Accounts receivable master record representing the full trade receivable lifecycle for consumer goods sales to retailers, distributors, and wholesalers. Owns invoice creation, payment terms, cash receipt application, partial payments, deductions/short-payments, clearing, and write-offs. Captures invoice number, billing date, due date, payment terms, gross amount, trade discounts, net amount, tax, currency, payment method, payment date, amount received, clearing reference, DSO aging bucket, dunning level, and deduction reason codes. The single source of truth for all receivable balances, cash application, deduction management, DSO tracking, cash flow forecasting, and revenue recognition under ASC 606/IFRS 15. Integrates with SAP S/4HANA SD billing and FI-AR.'
}

Table finance.ar_payment {
  ar_payment_id varchar [pk, note: 'Unique identifier for the accounts receivable payment record. Primary key.']
  ar_invoice_id varchar [note: 'The ar invoice id of the ar payment record']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: ar_payment currently stores company_code as a denormalized STRING. Replacing with a proper FK to company_code.company_code_id normalizes the relationship and enables multi-entity AR reporting. The com']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: ar_payment currently stores cost_center_code as a denormalized STRING. Replacing with a proper FK to cost_center.cost_center_id normalizes the relationship, enabling cost center-level cash receipt ana']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: AR payments store GL account code; FK to gl_account consolidates GL reference.']
  invoice_id varchar [note: 'Reference to the AR invoice being paid. Links payment to the originating billing document.']
  journal_entry_id varchar [note: 'Foreign key linking to finance.journal_entry. Business justification: AR cash receipts generate clearing journal entries in SAP FI (debit bank, credit AR). Linking ar_payment to journal_entry enables reconciliation of cash receipts to GL postings, supporting DSO trackin']
  trade_account_id varchar [note: 'Reference to the trade customer making the payment. Identifies the payer account.']
  amount decimal(18,4) [note: 'The amount of the ar payment record']
  applied_amount decimal(18,2) [note: 'Amount of payment applied to the invoice after deductions and adjustments. Net amount reducing accounts receivable balance.']
  ar_payment_number varchar [note: 'The ar payment number of the ar payment record']
  ar_payment_status varchar [note: 'The ar payment status of the ar payment record']
  bank_reference_number varchar [note: 'Bank transaction reference or confirmation number. Used for bank statement reconciliation and audit trail.']
  business_area_code varchar [note: 'Business area or division code for segment reporting. Used for internal management reporting and EBITDA analysis by business unit.']
  check_number varchar [note: 'Check number when payment method is check. Used for check reconciliation and fraud prevention.']
  clearing_document_number varchar [note: 'SAP clearing document number generated when payment is applied to open invoice. Used for financial reconciliation and audit.']
  code varchar [note: 'The ar payment code of the ar payment record']
  created_by_user varchar [note: 'User ID of the person or system that created the payment record. Used for SOX compliance and audit trail.']
  created_timestamp timestamp [note: 'Timestamp when the payment record was first created in the system. Used for audit trail and data lineage.']
  currency_code varchar [note: 'The currency code of the ar payment record']
  days_to_pay varchar [note: 'Number of days between invoice date and payment date. Key metric for Days Sales Outstanding (DSO) calculation and customer payment behavior analysis.']
  deduction_amount decimal(18,2) [note: 'Total amount of deductions taken by customer from the payment. Includes trade promotions, allowances, damages, and short payments.']
  deduction_notes varchar [note: 'Free-text notes explaining the deduction or short payment. Captures customer explanation and internal investigation details.']
  deduction_reason_code varchar [note: 'Reason code for customer deduction. Used for deduction management, dispute resolution, and root cause analysis. [ENUM-REF-CANDIDATE: trade_promotion|pricing_dispute|quantity_shortage|damaged_goods|quality_issue|freight_claim|administrative_error|unauthorized — 8 candidates stripped; promote to reference product]']
  description varchar [note: 'The ar payment description of the ar payment record']
  discount_amount decimal(18,2) [note: 'Cash discount or early payment discount amount taken by customer. Typically based on payment terms (e.g., 2/10 net 30).']
  due_date date [note: 'Original invoice due date. Used to determine if payment is on-time, early, or late for DSO and aging analysis.']
  edi_transaction_set_reference varchar [note: 'EDI 820 transaction set control number when payment received via EDI. Used for EDI reconciliation and compliance.']
  effective_from date [note: 'The effective from of the ar payment record']
  effective_until date [note: 'The effective until of the ar payment record']
  exchange_rate decimal(12,6) [note: 'Exchange rate applied to convert payment currency to local currency. Used when payment currency differs from invoice or local currency.']
  fiscal_period varchar [note: 'Fiscal period (month) when payment was posted. Used for monthly financial close and period-based reporting.']
  fiscal_year varchar [note: 'Fiscal year when payment was posted. Used for period-based financial reporting and year-over-year analysis.']
  local_currency_amount decimal(18,2) [note: 'Payment amount converted to company local currency using the exchange rate. Used for consolidated financial reporting.']
  local_currency_code varchar [note: 'ISO 4217 three-letter code for the company local currency. Used for financial reporting and consolidation.']
  lockbox_batch_number varchar [note: 'Lockbox batch identifier when payment received through bank lockbox service. Used for lockbox reconciliation.']
  modified_by_user varchar [note: 'User ID of the person or system that last modified the payment record. Used for SOX compliance and audit trail.']
  modified_timestamp timestamp [note: 'Timestamp when the payment record was last modified. Used for audit trail and change tracking.']
  name varchar [note: 'The ar payment name of the ar payment record']
  notes varchar [note: 'The notes of the ar payment record']
  overpayment_flag boolean [note: 'Indicates whether payment amount exceeds the invoice balance. True if customer paid more than owed.']
  partial_payment_flag boolean [note: 'Indicates whether this is a partial payment against the invoice. True if payment amount is less than invoice balance.']
  payment_amount decimal(18,2) [note: 'Total amount received in the payment transaction, in the payment currency. Gross payment before any deductions or adjustments.']
  payment_channel varchar [note: 'Channel through which payment was received. Distinguishes interface from payment instrument.']
  payment_currency_code varchar [note: 'ISO 4217 three-letter currency code for the payment amount. Identifies the currency in which payment was received.']
  payment_date date [note: 'Date when the payment was received or posted. Used for Days Sales Outstanding (DSO) calculation and cash flow analysis.']
  payment_document_number varchar [note: 'External payment document number or reference provided by the customer or payment processor. Used for reconciliation and audit trail.']
  payment_method varchar [note: 'Method or instrument used for payment. Includes ACH (Automated Clearing House), wire transfer, check, credit card, debit card, or EFT.']
  payment_processor_code varchar [note: 'Transaction identifier from third-party payment processor (e.g., Stripe, PayPal, Adyen). Used for processor reconciliation.']
  payment_reference varchar [note: 'The payment reference of the ar payment record']
  payment_status varchar [note: 'Current status of the payment in the cash application workflow. Tracks payment lifecycle from receipt through clearing. [ENUM-REF-CANDIDATE: received|cleared|applied|partially_applied|unapplied|reversed|rejected — 7 candidates stripped; promote to reference product]']
  payment_terms_code varchar [note: 'Payment terms code from the original invoice (e.g., NET30, 2/10NET30). Used to validate discount eligibility and calculate DSO.']
  posting_date date [note: 'Date when the payment was posted to the general ledger. Used for financial period assignment and reporting.']
  quantity decimal(18,4) [note: 'The quantity of the ar payment record']
  remittance_advice_number varchar [note: 'Reference number from customer remittance advice document. Links payment to customer payment notification (EDI 820 or paper remittance).']
  reversal_date date [note: 'Date when payment was reversed. Null if payment has not been reversed.']
  reversal_flag boolean [note: 'Indicates whether this payment has been reversed. True if payment was subsequently voided or returned.']
  reversal_reason_code varchar [note: 'Reason code for payment reversal. Includes NSF (non-sufficient funds), stop payment, duplicate, fraud, customer request, or system error. [ENUM-REF-CANDIDATE: NSF|stop_payment|duplicate|fraud|customer_request|bank_error|system_error — 7 candidates stripped; promote to reference product]']
  short_payment_flag boolean [note: 'Indicates whether customer paid less than invoice amount without authorized deduction. Triggers deduction management workflow.']
  source_system_code varchar [note: 'The source system code of the ar payment record']
  uom varchar [note: 'The uom of the ar payment record']
  updated_timestamp timestamp [note: 'The updated timestamp of the ar payment record']
  value_date date [note: 'Date when funds become available in the bank account. May differ from payment date due to clearing time.']

  Note: 'Accounts receivable payment record capturing cash receipts from trade customers against outstanding AR invoices. Records payment date, payment method (ACH, wire, check, EDI 820), amount received, currency, exchange rate, bank account, clearing document reference, partial payment flag, and deduction/short-payment details. Supports cash application, deduction management, and DSO calculation. Sourced from SAP S/4HANA FI-AR and Oracle Cloud Receivables.'
}

Table finance.ap_invoice {
  ap_invoice_id varchar [pk, note: 'Unique identifier for the accounts payable invoice record. Primary key for the AP invoice entity.']
  company_code_id varchar [note: 'The company code id of the ap invoice record']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: ap_invoice currently stores cost_center_code as a denormalized STRING. Replacing with a proper FK to cost_center.cost_center_id normalizes the relationship, enabling cost center-level AP spend analysi']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: AP invoices capture GL account code; FK to gl_account creates a true parent‑child relationship and removes the code column.']
  goods_receipt_id varchar [note: 'Reference to the goods receipt document used in three-way match verification to confirm materials or services were received.']
  journal_entry_id varchar [note: 'Foreign key linking to finance.journal_entry. Business justification: In SAP S/4HANA FI, every AP invoice generates a corresponding FI document (journal entry) for the expense and payable posting. Linking ap_invoice to journal_entry enables full audit trail from trade p']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: ap_invoice currently stores profit_center_code as a denormalized STRING. Replacing with a proper FK to profit_center.profit_center_id normalizes the relationship, enabling JOIN-based profit center rep']
  purchase_order_id varchar [note: 'Reference to the purchase order against which this invoice is matched. Used for three-way match verification.']
  supplier_id varchar [note: 'Unique identifier for the vendor or supplier who issued this invoice. Links to the vendor master record.']
  supplier_invoice_id varchar [note: 'Foreign key linking to procurement.supplier_invoice. Business justification: The finance AP invoice (ap_invoice) should reference the procurement supplier invoice (supplier_invoice) to complete the three-way match process (PO-GR-Invoice) and enable AP subledger reconciliation.']
  amount decimal(18,4) [note: 'The amount of the ap invoice record']
  ap_invoice_number varchar [note: 'The ap invoice number of the ap invoice record']
  ap_invoice_status varchar [note: 'The ap invoice status of the ap invoice record']
  baseline_date date [note: 'The reference date from which payment terms are calculated. Typically the invoice date or goods receipt date depending on payment term configuration.']
  clearing_document_number varchar [note: 'The financial document number that cleared the open payable balance. Links the invoice to the payment transaction for reconciliation.']
  code varchar [note: 'The ap invoice code of the ap invoice record']
  created_by_user varchar [note: 'The user ID of the person who created the invoice record. Required for SOX-compliant audit trails and segregation of duties verification.']
  created_timestamp timestamp [note: 'The date and time when the invoice record was first created in the system. Used for audit trails and Sarbanes-Oxley (SOX) compliance.']
  currency_code varchar [note: 'Three-letter ISO 4217 currency code indicating the currency in which the invoice is denominated (e.g., USD, EUR, GBP).']
  description varchar [note: 'The ap invoice description of the ap invoice record']
  discount_amount decimal(18,2) [note: 'The cash discount amount available if payment is made within the early payment discount period. Used for working capital optimization.']
  due_date date [note: 'The date by which payment must be made to the vendor according to the payment terms. Used for cash flow planning and Days Sales Outstanding (DSO) tracking.']
  early_payment_discount_taken decimal(18,2) [note: 'The actual cash discount amount captured by paying the invoice within the early payment discount period. Key metric for working capital optimization.']
  effective_from date [note: 'The effective from of the ap invoice record']
  effective_until date [note: 'The effective until of the ap invoice record']
  exchange_rate decimal(12,5) [note: 'The foreign exchange rate used to convert the invoice amount to the company\'s local currency for financial reporting.']
  fiscal_period varchar [note: 'The fiscal period (month) within the fiscal year in which the invoice was posted. Used for monthly financial reporting.']
  fiscal_year varchar [note: 'The fiscal year in which the invoice was posted. Used for period-based financial reporting and year-end closing.']
  gross_amount decimal(18,2) [note: 'The total invoice amount before any deductions, including all line items, taxes, and freight charges.']
  invoice_category varchar [note: 'Classification of the invoice by spend category (e.g., raw materials, packaging, contract manufacturing, indirect goods, services). Used for spend analytics and procurement reporting. [ENUM-REF-CANDIDATE: raw_materials|packaging|contract_manufacturing|indirect_goods|services|freight|utilities|rent — 8 candidates stripped; promote to reference product]']
  invoice_date date [note: 'The date the vendor issued the invoice. This is the document date from the vendor\'s invoice and is used for aging analysis.']
  invoice_description varchar [note: 'Free-text description or header text providing additional context about the invoice, such as the nature of goods or services purchased.']
  invoice_number varchar [note: 'The invoice number of the ap invoice record']
  invoice_status varchar [note: 'Current lifecycle status of the invoice in the accounts payable process. Tracks the invoice from receipt through payment and clearing. [ENUM-REF-CANDIDATE: draft|posted|approved|paid|partially_paid|cancelled|on_hold — 7 candidates stripped; promote to reference product]']
  match_status varchar [note: 'Status of the three-way match verification process comparing the invoice to the purchase order and goods receipt. Critical for payment approval workflow.']
  modified_by_user varchar [note: 'The user ID of the person who last modified the invoice record. Required for SOX-compliant audit trails.']
  modified_timestamp timestamp [note: 'The date and time when the invoice record was last modified. Used for change tracking and audit compliance.']
  name varchar [note: 'The ap invoice name of the ap invoice record']
  net_amount decimal(18,2) [note: 'The net payable amount after deducting any discounts or credits. This is the amount that will be paid to the vendor.']
  notes varchar [note: 'The notes of the ap invoice record']
  outstanding_amount decimal(18,4) [note: 'The outstanding amount of the ap invoice record']
  payment_amount decimal(18,2) [note: 'The actual amount paid to the vendor. May differ from net amount if partial payments or adjustments were made.']
  payment_block_code varchar [note: 'Code indicating if the invoice is blocked for payment and the reason for the block (e.g., price variance, quantity variance, quality issue, pending approval).']
  payment_date date [note: 'The actual date payment was executed to the vendor. Used for cash flow tracking and Days Inventory Outstanding (DIO) calculation.']
  payment_method varchar [note: 'The method by which payment will be or was made to the vendor (e.g., wire transfer, ACH, check, EFT, credit card, virtual card).']
  payment_status varchar [note: 'The payment status of the ap invoice record']
  payment_terms varchar [note: 'The payment terms of the ap invoice record']
  payment_terms_code varchar [note: 'Code representing the payment terms agreed with the vendor (e.g., Net 30, 2/10 Net 30). Defines the due date calculation and early payment discount eligibility.']
  posting_date date [note: 'The date the invoice was posted to the general ledger. This date determines the fiscal period for financial reporting.']
  quantity decimal(18,4) [note: 'The quantity of the ap invoice record']
  reference_document_number varchar [note: 'Additional reference number for cross-referencing to other documents such as delivery notes, packing slips, or contract numbers.']
  source_system_code varchar [note: 'The source system code of the ap invoice record']
  tax_amount decimal(18,2) [note: 'The total tax amount charged on the invoice, including sales tax, VAT, GST, or other applicable taxes.']
  tax_code varchar [note: 'The tax jurisdiction code or tax type applied to the invoice (e.g., sales tax, VAT, GST). Used for tax reporting and compliance.']
  total_amount decimal(18,4) [note: 'The total amount of the ap invoice record']
  uom varchar [note: 'The uom of the ap invoice record']
  updated_timestamp timestamp [note: 'The updated timestamp of the ap invoice record']
  vendor_bank_account_code varchar [note: 'Reference to the vendor\'s bank account to which payment was or will be sent. Required for electronic payment processing.']
  vendor_invoice_number varchar [note: 'The invoice number assigned by the vendor. This is the external reference number printed on the vendor\'s invoice document.']
  withholding_tax_amount decimal(18,2) [note: 'The amount of withholding tax deducted from the payment to the vendor as required by tax regulations. Must be remitted to tax authorities.']

  Note: 'Accounts payable master record representing the full trade payable lifecycle for raw materials, packaging, contract manufacturing, and indirect goods/services. Owns invoice receipt, three-way match verification, payment scheduling, payment execution, early payment discount capture, and clearing. Captures vendor invoice number, invoice date, posting date, due date, gross amount, tax, net amount, payment terms, currency, match status, payment method, payment date, payment amount, payment run ID, bank account reference, early discount taken, clearing document, and payment block details. The single source of truth for all payable balances, payment execution, DIO tracking, working capital optimization, and supplier payment management. Integrates with SAP S/4HANA MM-IV, FI-AP, and Oracle Cloud Payables.'
}

Table finance.ap_payment {
  ap_payment_id varchar [pk, note: 'Unique identifier for the accounts payable payment record. Primary key.']
  ap_invoice_id varchar [note: 'The ap invoice id of the ap payment record']
  company_code_id varchar [note: 'Foreign key linking to finance.company_code. Business justification: ap_payment currently stores company_code as a denormalized STRING. Replacing with a proper FK to company_code.company_code_id normalizes the relationship and enables multi-entity AP payment reporting.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: ap_payment currently stores cost_center_code as a denormalized STRING. Replacing with a proper FK to cost_center.cost_center_id normalizes the relationship, enabling cost center-level outgoing payment']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: AP payments include GL account code; FK to gl_account provides proper accounting linkage.']
  invoice_id varchar [note: 'Identifier of the invoice being paid. Links to the accounts payable invoice record.']
  journal_entry_id varchar [note: 'Foreign key linking to finance.journal_entry. Business justification: AP outgoing payments generate clearing journal entries in SAP FI (debit AP, credit bank). Linking ap_payment to journal_entry enables reconciliation of outgoing payments to GL postings, supporting DPO']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: ap_payment currently stores profit_center_code as a denormalized STRING. Replacing with a proper FK to profit_center.profit_center_id normalizes the relationship, enabling JOIN-based profit center rep']
  supplier_id varchar [note: 'Identifier of the supplier receiving the payment. Links to the supplier master data.']
  supplier_invoice_id varchar [note: 'Foreign key linking to procurement.supplier_invoice. Business justification: AP payments settle specific supplier invoices; this link is essential for payment-to-invoice matching, outstanding liability reporting, and cash flow forecasting. Without it, AP aging and payment stat']
  amount decimal(18,4) [note: 'The amount of the ap payment record']
  ap_payment_number varchar [note: 'The ap payment number of the ap payment record']
  ap_payment_status varchar [note: 'The ap payment status of the ap payment record']
  approved_by varchar [note: 'User ID or name of the person who approved the payment. Supports SOX-compliant audit trails and segregation of duties controls.']
  approved_date date [note: 'The date on which the payment was approved. Supports audit trails and payment cycle time analysis.']
  clearing_date date [note: 'The date on which the payment cleared the open invoice in the accounts payable subledger. Used for Days Inventory Outstanding (DIO) and working capital analysis.']
  clearing_document_number varchar [note: 'The document number assigned when the payment cleared the open invoice in the accounts payable subledger. Used for reconciliation and audit trails.']
  code varchar [note: 'The ap payment code of the ap payment record']
  created_timestamp timestamp [note: 'The timestamp when the payment record was first created in the system. Supports audit trails and data lineage tracking.']
  currency_code varchar [note: 'The currency code of the ap payment record']
  description varchar [note: 'The ap payment description of the ap payment record']
  discount_amount decimal(18,2) [note: 'The early payment discount amount taken by the company for paying the invoice before the discount deadline. Supports working capital optimization and supplier relationship management.']
  discount_due_date date [note: 'The date by which the payment must be made to qualify for the early payment discount. Used for working capital optimization decisions.']
  due_date date [note: 'The date by which the payment was contractually due to the supplier. Used to calculate on-time payment performance and avoid late payment penalties.']
  effective_from date [note: 'The effective from of the ap payment record']
  effective_until date [note: 'The effective until of the ap payment record']
  exchange_rate decimal(12,6) [note: 'The exchange rate applied to convert the payment amount from the payment currency to the company\'s local currency. Used for financial consolidation and reporting.']
  local_currency_amount decimal(18,2) [note: 'The payment amount converted to the company\'s local reporting currency using the exchange rate. Used for consolidated financial reporting and EBITDA calculations.']
  local_currency_code varchar [note: 'Three-letter ISO 4217 currency code for the company\'s local reporting currency (e.g., USD). Used for financial consolidation.']
  modified_by varchar [note: 'User ID or name of the person who last modified the payment record. Supports SOX-compliant audit trails and change tracking.']
  modified_timestamp timestamp [note: 'The timestamp when the payment record was last modified. Supports audit trails and change tracking for SOX compliance.']
  name varchar [note: 'The ap payment name of the ap payment record']
  net_payment_amount decimal(18,2) [note: 'The net payment amount after applying early payment discounts and any other adjustments. This is the actual amount transferred to the supplier.']
  notes varchar [note: 'The notes of the ap payment record']
  payment_amount decimal(18,2) [note: 'The gross payment amount remitted to the supplier in the payment currency, before any adjustments or discounts.']
  payment_approval_status varchar [note: 'Approval status of the payment. Pending indicates awaiting approval, approved indicates authorized for processing, rejected indicates payment was denied. Supports SOX-compliant approval workflows.']
  payment_block_code varchar [note: 'Code indicating if the payment was blocked for review or approval. Blank indicates no block. Used for payment control and fraud prevention.']
  payment_block_reason varchar [note: 'Description of the reason the payment was blocked (e.g., pending invoice verification, supplier on hold, duplicate payment suspected). Used for exception management.']
  payment_block_released_by varchar [note: 'User ID or name of the person who released the payment block and authorized the payment to proceed. Supports SOX-compliant audit trails.']
  payment_block_released_date date [note: 'The date on which the payment block was released and the payment was authorized to proceed. Supports audit trails and payment cycle time analysis.']
  payment_currency_code varchar [note: 'Three-letter ISO 4217 currency code for the payment amount (e.g., USD, EUR, GBP). Supports multi-currency payment processing.']
  payment_date date [note: 'The date on which the payment was issued or processed. Used for cash flow reporting and Days Sales Outstanding (DSO) calculations.']
  payment_document_number varchar [note: 'The externally-known payment document number assigned by the ERP system. Used for reconciliation and audit trails.']
  payment_method varchar [note: 'The payment instrument used to remit funds to the supplier. ACH (Automated Clearing House), wire transfer, check, EDI 820 (Electronic Data Interchange payment order), credit card, or direct debit.']
  payment_notes varchar [note: 'Free-text notes or comments about the payment. Used to capture special instructions, exceptions, or additional context for audit and reconciliation purposes.']
  payment_reference varchar [note: 'The payment reference of the ap payment record']
  payment_reference_number varchar [note: 'External reference number provided to the supplier for payment identification and reconciliation (e.g., check number, wire confirmation number, ACH trace number).']
  payment_status varchar [note: 'Current lifecycle status of the payment. Draft indicates initial creation, pending awaits approval, approved is ready for processing, processed has been sent to bank, cleared has been confirmed by bank, failed indicates processing error, cancelled indicates payment was voided. [ENUM-REF-CANDIDATE: draft|pending|approved|processed|cleared|failed|cancelled — 7 candidates stripped; promote to reference product]']
  payment_terms varchar [note: 'The payment terms agreed with the supplier (e.g., Net 30, 2/10 Net 30). Defines the due date and early payment discount eligibility.']
  quantity decimal(18,4) [note: 'The quantity of the ap payment record']
  remittance_advice_sent_date date [note: 'The date on which the remittance advice was sent to the supplier. Used for supplier communication tracking.']
  remittance_advice_sent_flag boolean [note: 'Boolean flag indicating whether a remittance advice was sent to the supplier to notify them of the payment details. True indicates sent, False indicates not sent.']
  source_system_code varchar [note: 'The source system code of the ap payment record']
  uom varchar [note: 'The uom of the ap payment record']
  updated_timestamp timestamp [note: 'The updated timestamp of the ap payment record']
  created_by varchar [note: 'User ID or name of the person who created the payment record. Supports SOX-compliant audit trails.']

  Note: 'Accounts payable payment record capturing outgoing payments to suppliers for raw materials, packaging, and services. Records payment date, payment method (ACH, wire, check, EDI 820), payment amount, currency, exchange rate, bank account, payment run ID, clearing document, early payment discount taken, and payment block release authorization. Supports cash flow management, supplier relationship management, and working capital optimization. Sourced from SAP S/4HANA FI-AP.'
}

Table finance.standard_cost {
  standard_cost_id varchar [pk, note: 'Unique identifier for the standard cost record. Primary key for the standard cost master data.']
  company_code_id varchar [note: 'The company code id of the standard cost record']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Standard cost records are defined per cost center; linking enables cost‑center level consolidation and provides a proper relational anchor.']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Standard costs are mapped to specific GL accounts (inventory valuation accounts, COGS accounts, variance accounts) in SAP CO/FI integration. This FK enables direct linkage between standard cost record']
  primary_standard_manufacturing_facility_id varchar [note: 'Reference to the manufacturing plant or production facility where this standard cost applies. Standard costs are plant-specific in CPG manufacturing.']
  primary_standard_sku_id varchar [note: 'Reference to the material (finished good, semi-finished good, or raw material) for which this standard cost is defined. Links to the product master.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: In CPG cost accounting, standard costs for finished goods and raw materials are assigned to profit centers for segment P&L reporting and COGS allocation by business unit. This FK enables profit center']
  supplier_contract_id varchar [note: 'Foreign key linking to procurement.supplier_contract. Business justification: Standard costs for purchased materials are derived from contracted prices in supplier agreements. This link enables cost accountants to trace standard cost basis to the underlying supply contract — a ']
  supplier_id varchar [note: 'Foreign key linking to procurement.supplier. Business justification: Standard costs for externally purchased materials are set based on the designated standard supplier\'s pricing. This link supports make-vs-buy analysis, cost variance reporting, and annual standard cos']
  amount decimal(18,4) [note: 'The amount of the standard cost record']
  approval_status varchar [note: 'The approval workflow status for this standard cost estimate. Ensures proper governance and SOX compliance for cost changes.']
  approved_by varchar [note: 'The user ID or name of the manager or controller who approved this standard cost estimate. Required for SOX compliance and audit trail.']
  approved_timestamp timestamp [note: 'The date and time when this standard cost estimate was approved. Critical for audit trail and SOX compliance.']
  bom_usage varchar [note: 'The BOM usage type (e.g., production, costing, engineering) that was used as the basis for material cost calculation in this estimate.']
  code varchar [note: 'The standard cost code of the standard cost record']
  cost_estimate_created_by varchar [note: 'The user ID or name of the cost accountant or system user who created this cost estimate. Used for audit trail and accountability.']
  cost_estimate_created_timestamp timestamp [note: 'The date and time when this standard cost record was first created in the source system. Critical for audit trail and SOX compliance.']
  cost_estimate_modified_by varchar [note: 'The user ID or name of the cost accountant or system user who last modified this cost estimate. Used for audit trail and change tracking.']
  cost_estimate_modified_timestamp timestamp [note: 'The date and time when this standard cost record was last modified in the source system. Critical for audit trail and SOX compliance.']
  cost_estimate_number varchar [note: 'The unique business identifier for the cost estimate document in the source ERP system. Used for audit trail and traceability.']
  cost_variance_amount decimal(18,4) [note: 'The absolute difference between the current standard cost and the previous standard cost. Positive indicates cost increase, negative indicates cost decrease.']
  cost_variance_percentage decimal(5,2) [note: 'The percentage change in standard cost compared to the previous period. Calculated as (current - previous) / previous * 100.']
  cost_version varchar [note: 'The cost version of the standard cost record']
  costing_lot_size decimal(18,3) [note: 'The production lot size (quantity) used as the basis for calculating the standard cost. Fixed costs are spread over this quantity.']
  costing_lot_size_uom varchar [note: 'The unit of measure for the costing lot size (e.g., EA, KG, L, CS). Must align with the materials base unit of measure.']
  costing_sheet varchar [note: 'The costing sheet identifier that defines the overhead calculation rules and surcharge rates applied in this cost estimate.']
  costing_type varchar [note: 'The type of cost estimate: standard (for inventory valuation), planned (for budgeting), actual (for variance analysis), or simulated (for what-if scenarios).']
  costing_version varchar [note: 'The costing version identifier that groups standard cost estimates for a specific planning or valuation scenario (e.g., current year, budget, simulation). Enables parallel costing scenarios.']
  created_timestamp timestamp [note: 'The created timestamp of the standard cost record']
  currency_code varchar [note: 'The three-letter ISO 4217 currency code in which the standard cost is expressed (e.g., USD, EUR, GBP).']
  description varchar [note: 'The standard cost description of the standard cost record']
  direct_labor_cost decimal(18,4) [note: 'The cost component for direct production labor (machine operators, line workers) allocated to one unit based on standard labor hours and rates.']
  effective_from date [note: 'The effective from of the standard cost record']
  effective_until date [note: 'The effective until of the standard cost record']
  fiscal_period varchar [note: 'The fiscal period (month) within the fiscal year for which this standard cost estimate is applicable. Enables period-specific cost tracking.']
  fiscal_year varchar [note: 'The fiscal year for which this standard cost estimate is applicable. Standard costs are typically set annually and used for budgeting and variance analysis.']
  fixed_overhead_cost decimal(18,4) [note: 'The cost component for fixed manufacturing overhead (plant management, utilities, rent) allocated to one unit based on the costing lot size.']
  freight_in_cost decimal(18,4) [note: 'The cost component for inbound freight and logistics to bring raw materials and packaging to the plant, allocated to one unit.']
  labor_cost decimal(18,4) [note: 'The labor cost of the standard cost record']
  machine_overhead_cost decimal(18,4) [note: 'The cost component for machine and equipment overhead (depreciation, maintenance, energy) allocated to one unit based on machine hours.']
  material_cost decimal(18,4) [note: 'The material cost of the standard cost record']
  name varchar [note: 'The standard cost name of the standard cost record']
  notes varchar [note: 'Free-text notes or comments about this standard cost estimate, such as assumptions, special considerations, or reasons for cost changes.']
  overhead_cost decimal(18,4) [note: 'The overhead cost of the standard cost record']
  packaging_material_cost decimal(18,4) [note: 'The cost component for packaging materials (primary, secondary, tertiary) used for one unit. Critical for CPG cost structure analysis.']
  previous_standard_cost decimal(18,4) [note: 'The total standard cost from the prior costing period or version. Used for variance analysis and cost trend reporting.']
  quantity decimal(18,4) [note: 'The quantity of the standard cost record']
  raw_material_cost decimal(18,4) [note: 'The cost component for raw materials consumed in the production of one unit. Key input for COGS and margin analysis.']
  release_date date [note: 'The date when this standard cost estimate was officially released and became active for inventory valuation and COGS calculation.']
  release_status varchar [note: 'The lifecycle status of the standard cost record: draft (under development), released (active for valuation), locked (frozen for audit), or archived (historical).']
  routing_usage varchar [note: 'The routing usage type (e.g., production, costing) that was used as the basis for labor and machine cost calculation in this estimate.']
  source_system_code varchar [note: 'The source system code of the standard cost record']
  standard_cost_status varchar [note: 'The standard cost status of the standard cost record']
  total_standard_cost decimal(18,4) [note: 'The total standard cost per unit of the material, summing all cost components (raw material, packaging, labor, overhead, freight). This is the authoritative cost for inventory valuation and COGS.']
  uom varchar [note: 'The uom of the standard cost record']
  updated_timestamp timestamp [note: 'The updated timestamp of the standard cost record']
  valid_from_date date [note: 'The start date from which this standard cost estimate is effective. Used for time-dependent cost valuation and COGS calculation.']
  valid_to_date date [note: 'The end date until which this standard cost estimate is effective. Nullable for open-ended validity.']
  valuation_variant varchar [note: 'The valuation variant that defines the costing methodology and cost component structure used for this estimate (e.g., full costing, marginal costing).']
  variable_overhead_cost decimal(18,4) [note: 'The cost component for variable manufacturing overhead (indirect materials, supplies, variable utilities) allocated to one unit.']
  valid_from date [note: 'The valid from of the standard cost record']
  valid_to date [note: 'The valid to of the standard cost record']

  Note: 'Standard cost master record for finished goods, semi-finished goods, and raw materials used in CPG manufacturing. Stores the cost estimate per SKU/material including cost component split (raw material, packaging, direct labor, machine overhead, fixed overhead, freight-in), costing version, validity period, plant, costing lot size, and release status. The authoritative source for inventory valuation, COGS calculation, and manufacturing variance analysis. Sourced from SAP S/4HANA CO-PC.'
}

Table finance.company_code {
  company_code_id varchar [pk, note: 'Primary key for company_code']
  parent_company_code_id varchar [note: 'Self-referencing FK on company_code (parent_company_code_id)']
  address_line1 varchar [note: 'First line of the entity\'s registered street address.']
  address_line2 varchar [note: 'Second line of the entity\'s registered street address (optional).']
  amount decimal(18,4) [note: 'The amount of the company code record']
  city varchar [note: 'City component of the entity\'s registered address.']
  classification_type varchar [note: 'Category describing the legal relationship of the entity within the corporate structure.']
  code varchar [note: 'Alphanumeric code used in ERP systems to identify the legal entity for accounting.']
  company_code varchar [note: 'The company code of the company code record']
  company_code_status varchar [note: 'The company code status of the company code record']
  company_name varchar [note: 'The company name of the company code record']
  cost_center_code varchar [note: 'Internal cost‑center identifier associated with the entity for budgeting.']
  country_code varchar [note: 'Three‑letter ISO country code where the legal entity is registered.']
  created_timestamp timestamp [note: 'The created timestamp of the company code record']
  currency_code varchar [note: 'ISO 4217 currency code used for reporting financials of the entity.']
  description varchar [note: 'The company code description of the company code record']
  effective_from date [note: 'Date when the legal entity became active for accounting purposes.']
  effective_to date [note: 'Date when the legal entity ceased to be active (null if still active).']
  effective_until date [note: 'The effective until of the company code record']
  email_address varchar [note: 'Main email address used for electronic correspondence with the entity.']
  fiscal_year_variant varchar [note: 'The fiscal year variant of the company code record']
  industry_code varchar [note: 'Standard industry classification (e.g., NAICS) for the entity.']
  is_consolidated_entity boolean [note: 'True if the entity is included in group financial consolidation.']
  is_public_company boolean [note: 'True if the entity is publicly listed; otherwise false.']
  legal_entity_type varchar [note: 'The legal entity type of the company code record']
  legal_name varchar [note: 'Full registered legal name of the company as per statutory filings.']
  lifecycle_status varchar [note: 'Current operational status of the legal entity.']
  local_currency varchar [note: 'The local currency of the company code record']
  name varchar [note: 'Human‑readable name of the legal entity.']
  notes varchar [note: 'The notes of the company code record']
  phone_number varchar [note: 'Main telephone number for the entity.']
  postal_code varchar [note: 'Postal or ZIP code of the entity\'s registered address.']
  primary_contact_method varchar [note: 'Preferred channel for official communications with the entity.']
  quantity decimal(18,4) [note: 'The quantity of the company code record']
  record_audit_created timestamp [note: 'Timestamp when the company code record was first created in the system.']
  record_audit_updated timestamp [note: 'Timestamp of the most recent modification to the company code record.']
  source_system_code varchar [note: 'The source system code of the company code record']
  state_province varchar [note: 'State or province component of the entity\'s registered address.']
  tax_number varchar [note: 'Government‑issued tax identification number for the legal entity.']
  uom varchar [note: 'The uom of the company code record']
  updated_timestamp timestamp [note: 'The updated timestamp of the company code record']
  value varchar [note: 'The value of the company code record']

  Note: 'Master reference table for company_code. Referenced by company_code_id.'
}

Table logistics.carrier {
  carrier_id varchar [pk, note: 'Unique surrogate identifier for the transportation carrier record in the Consumer Goods logistics master data. Primary key for all carrier-related references across shipments, freight orders, contracts, and invoices.']
  supplier_id varchar [note: 'Reference to the corresponding vendor/supplier master record in the ERP system (SAP S/4HANA or Oracle Cloud ERP) for this carrier. Links the carrier master to the procurement and accounts payable vendor record for freight invoice processing and payment.']
  amount decimal(18,4) [note: 'The amount of the carrier record']
  api_tracking_capable boolean [note: 'Indicates whether the carrier provides a real-time shipment tracking API for track-and-trace integration. Enables automated shipment status updates in the TMS without manual EDI 214 processing. Used in carrier technology capability assessment.']
  carbon_intensity_g_per_tkm decimal(12,4) [note: 'The carbon intensity g per tkm of the carrier record']
  carrier_status varchar [note: 'Current lifecycle status of the carrier in the Consumer Goods approved carrier program. Active carriers are eligible for shipment tendering. Suspended carriers are temporarily blocked pending compliance review. Blacklisted carriers are permanently disqualified. Drives carrier selection eligibility in TMS routing.']
  carrier_type varchar [note: 'Primary transportation mode classification of the carrier. Drives rate card selection, shipment planning rules, and EDI transaction sets. TL (Truckload), LTL (Less-Than-Truckload), parcel, rail, ocean, air, intermodal, and courier are the standard classifications in consumer goods logistics. [ENUM-REF-CANDIDATE: truckload|less_than_truckload|parcel|rail|ocean|air|intermodal|courier — promote to reference product]']
  co2_emission_rating varchar [note: 'The co2 emission rating of the carrier record']
  code varchar [note: 'The carrier code of the carrier record']
  cold_chain_capable boolean [note: 'Indicates whether the carrier has certified temperature-controlled transportation capability (refrigerated or frozen) for cold-chain compliant shipments of health, hygiene, and personal care products requiring temperature management. Critical for product safety and regulatory compliance.']
  contact_email varchar [note: 'The contact email of the carrier record']
  contact_name varchar [note: 'The contact name of the carrier record']
  contact_phone varchar [note: 'The contact phone of the carrier record']
  contract_end_date date [note: 'Expiry date of the current master transportation services agreement. Triggers contract renewal workflows and rate renegotiation processes. Shipment tendering to the carrier may be restricted after this date if no renewal is in place.']
  contract_start_date date [note: 'Effective start date of the current master transportation services agreement between Consumer Goods and the carrier. Defines the period during which contracted rates and service commitments are valid.']
  contract_status varchar [note: 'The contract status of the carrier record']
  country_code varchar [note: 'The country code of the carrier record']
  country_of_registration varchar [note: 'ISO 3166-1 alpha-3 country code where the carrier is legally registered and incorporated. Used for cross-border compliance checks, customs documentation, and carrier eligibility for specific trade lanes.']
  created_timestamp timestamp [note: 'Timestamp when the carrier master record was first created in the Consumer Goods logistics data platform. Provides audit trail for record provenance and data lineage tracking in the Databricks Silver Layer.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code in which freight rates and invoices are denominated for this carrier. Used in multi-currency freight cost management, FX conversion, and financial reporting.']
  description varchar [note: 'The carrier description of the carrier record']
  dot_number varchar [note: 'Unique identifier assigned by the U.S. Federal Motor Carrier Safety Administration (FMCSA) to commercial motor carriers operating in interstate commerce. Required for regulatory compliance verification and safety rating lookup. Mandatory for US-based trucking carriers.']
  duns_number varchar [note: 'Nine-digit Dun & Bradstreet Data Universal Numbering System (DUNS) number uniquely identifying the carrier\'s business entity globally. Used for supplier risk assessment, credit verification, and EDI trading partner identification.']
  edi_capable boolean [note: 'Indicates whether the carrier supports Electronic Data Interchange (EDI) for automated exchange of shipment tenders (204), load tenders (990), shipment status (214), and freight invoices (210). EDI-capable carriers are preferred for high-volume automated tendering in the TMS.']
  edi_code varchar [note: 'Carrier\'s EDI interchange identifier used in the ISA segment of X12 EDI transactions. Combined with the EDI qualifier, this uniquely identifies the carrier as an EDI trading partner. Required for automated tender and status message routing.']
  edi_qualifier varchar [note: 'Two-digit qualifier code identifying the type of EDI sender/receiver identifier used in ISA segment of X12 EDI transactions (e.g., 02 = DUNS, 08 = UCC/EAN, ZZ = Mutually Defined). Required for EDI trading partner setup and message routing.']
  effective_from date [note: 'The effective from of the carrier record']
  effective_until date [note: 'The effective until of the carrier record']
  fmcsa_rating_date date [note: 'Date on which the current FMCSA safety rating was issued or last updated. Used to assess rating currency and trigger re-evaluation workflows when ratings are older than the compliance review threshold.']
  fmcsa_safety_rating varchar [note: 'Official safety fitness rating assigned by the FMCSA to motor carriers based on compliance reviews and safety audits. Satisfactory rating is required for carrier approval in Consumer Goods\' carrier program. Conditional or Unsatisfactory ratings trigger carrier review or suspension. Mandatory compliance field for US trucking carriers.']
  geographic_coverage varchar [note: 'Description of the carrier\'s operational geographic coverage scope, including regions, countries, or trade lanes served. Used in TMS routing logic to filter eligible carriers by origin-destination pair. Examples: \'Continental US\', \'US-Canada cross-border\', \'Trans-Pacific\', \'EU domestic\'.']
  hazmat_cert_expiry_date date [note: 'Expiry date of the carrier\'s hazardous materials transportation certification. Triggers compliance alerts and blocks HAZMAT shipment tendering to the carrier if certification has lapsed.']
  hazmat_certified boolean [note: 'Indicates whether the carrier holds valid certification to transport hazardous materials (HAZMAT) as defined by DOT 49 CFR. Required for shipments of aerosols, flammable products, and chemical-based consumer goods. Validated against DOT HAZMAT registration database.']
  headquarters_address varchar [note: 'Full street address of the carrier\'s principal place of business or corporate headquarters. Used for legal correspondence, contract execution, and regulatory filings. Includes street, city, state/province, postal code, and country.']
  iata_code varchar [note: '2-3 character alphanumeric code assigned by IATA to identify air freight carriers. Used for air waybill generation, air freight booking, and international air cargo tracking. Applicable only to air freight carriers.']
  insurance_cargo_amount decimal(18,2) [note: 'Maximum coverage amount (in USD) of the carrier\'s cargo insurance policy covering loss or damage to goods in transit. Consumer Goods mandates minimum cargo insurance thresholds based on shipment value profiles. Critical for high-value CPG product shipments.']
  insurance_certificate_number varchar [note: 'Reference number of the carrier\'s current certificate of insurance (COI) on file with Consumer Goods. Used for insurance verification, claims processing, and audit trail of carrier compliance documentation.']
  insurance_expiry_date date [note: 'Date on which the carrier\'s insurance certificate expires. Triggers automated renewal reminder workflows and carrier status suspension if insurance lapses. Critical compliance field for carrier program management.']
  insurance_liability_amount decimal(18,2) [note: 'Maximum coverage amount (in USD) of the carrier\'s general liability insurance policy. Consumer Goods requires minimum liability coverage thresholds as a condition of carrier approval. Validated during carrier onboarding and annual renewal.']
  insurance_provider varchar [note: 'The insurance provider of the carrier record']
  is_cold_chain_capable boolean [note: 'The is cold chain capable of the carrier record']
  is_hazmat_certified boolean [note: 'The is hazmat certified of the carrier record']
  is_preferred_carrier boolean [note: 'The is preferred carrier of the carrier record']
  last_compliance_review_date date [note: 'Date of the most recent compliance review conducted for this carrier, covering safety ratings, insurance certificates, HAZMAT certifications, and contractual obligations. Used to schedule periodic re-evaluations and flag overdue reviews.']
  last_updated_timestamp timestamp [note: 'The last updated timestamp of the carrier record']
  legal_name varchar [note: 'Full legal registered business name of the transportation carrier as filed with regulatory authorities (FMCSA, state business registry). Used in contracts, freight invoices, and regulatory filings. Must match the name on the carrier\'s operating authority.']
  liability_coverage_amount decimal(18,2) [note: 'The liability coverage amount of the carrier record']
  max_payload_kg decimal(10,2) [note: 'Maximum weight capacity in kilograms that the carrier\'s standard equipment can transport per shipment. Used in load planning, shipment consolidation, and carrier eligibility checks to prevent overweight violations.']
  mc_number varchar [note: 'Operating authority number issued by the FMCSA to for-hire motor carriers transporting regulated commodities in interstate commerce. Distinct from DOT number — MC number grants operating authority while DOT number is for safety registration. Used in carrier compliance validation.']
  mode_of_transport varchar [note: 'The mode of transport of the carrier record']
  name varchar [note: 'The carrier name of the carrier record']
  notes varchar [note: 'The notes of the carrier record']
  on_time_delivery_pct decimal(5,2) [note: 'The on time delivery pct of the carrier record']
  onboarding_date date [note: 'Date on which the carrier was formally approved and onboarded into Consumer Goods\' carrier program, completing all compliance checks, insurance verification, and EDI/API setup. Marks the start of the carrier\'s operational eligibility.']
  payment_terms varchar [note: 'Contractual payment terms agreed with the carrier for freight invoice settlement. Drives accounts payable scheduling and cash flow planning. Standard terms in consumer goods logistics range from Net 15 to Net 60 days.']
  preferred_carrier boolean [note: 'Indicates whether the carrier has been designated as a preferred carrier in Consumer Goods\' carrier program, typically based on negotiated rates, service performance, and strategic partnership status. Preferred carriers receive priority in TMS automated tendering sequences.']
  primary_contact_email varchar [note: 'Business email address of the primary carrier contact for operational communications, tender notifications, and account management. Used in EDI onboarding and carrier portal access provisioning.']
  primary_contact_name varchar [note: 'Full name of the primary business contact at the carrier organization responsible for account management, contract negotiations, and escalation handling. Used in carrier relationship management and communication workflows.']
  primary_contact_phone varchar [note: 'Primary business telephone number for the carrier contact, used for operational coordination, shipment tracking inquiries, and exception management. Formatted per E.164 international standard.']
  quantity decimal(18,4) [note: 'The quantity of the carrier record']
  region_coverage varchar [note: 'The region coverage of the carrier record']
  scac_code varchar [note: 'Unique 2-4 character alpha code assigned by the National Motor Freight Traffic Association (NMFTA) to identify transportation carriers in North America. Used in EDI transactions (204, 214, 990) and freight billing. Mandatory for motor carriers operating in the US.']
  service_area_countries varchar [note: 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing the countries in which the carrier provides transportation services. Used for international shipment routing, customs compliance validation, and carrier eligibility filtering in cross-border logistics.']
  service_level_offered varchar [note: 'The service level offered of the carrier record']
  service_mode varchar [note: 'Service level classification offered by the carrier indicating transit speed and handling commitment. Drives SLA assignment, freight cost tier selection, and shipment routing logic in the TMS. Used in OTIF (On Time In Full) performance measurement.']
  source_system_code varchar [note: 'The source system code of the carrier record']
  tax_number varchar [note: 'Federal tax identification number (EIN/TIN) or VAT registration number of the carrier, used for tax compliance, 1099 reporting, and cross-border customs documentation. Required for freight invoice processing and IRS reporting.']
  temperature_range_max_c decimal(5,2) [note: 'Maximum temperature (in degrees Celsius) that the carrier\'s cold-chain equipment can maintain during transit. Combined with the minimum temperature range, defines the carrier\'s certified temperature corridor for cold-chain shipments.']
  temperature_range_min_c decimal(5,2) [note: 'Minimum temperature (in degrees Celsius) that the carrier\'s cold-chain equipment can maintain during transit. Used to validate carrier eligibility for temperature-sensitive product shipments and cold-chain compliance verification.']
  tracking_url_template varchar [note: 'URL template for the carrier\'s web-based shipment tracking portal, with a placeholder (e.g., {tracking_number}) for dynamic substitution. Used to generate direct tracking links in shipment notifications, customer portals, and internal TMS dashboards.']
  trade_name varchar [note: 'Doing-business-as (DBA) or trade name used by the carrier in commercial operations, which may differ from the legal registered name. Used in operational communications, carrier portals, and reporting where the trade name is more recognizable.']
  uom varchar [note: 'The uom of the carrier record']
  updated_timestamp timestamp [note: 'The updated timestamp of the carrier record']

  Note: 'Master record for all transportation carriers (trucking, rail, ocean, air, parcel) contracted by Consumer Goods. Captures carrier identity, SCAC/IATA codes, carrier type, service modes, geographic coverage, insurance certificates, safety ratings (FMCSA/DOT), EDI capability flags, and contractual status. SSOT for carrier identity referenced by shipments, freight orders, contracts, and invoices across inbound and outbound networks.'
}

Table logistics.carrier_contract {
  carrier_contract_id varchar [pk, note: 'Unique system-generated surrogate identifier for the carrier contract record in the logistics data platform. Primary key for the carrier_contract entity.']
  carrier_id varchar [note: 'Reference to the carrier (transportation service provider) party who is the counterparty to this freight contract. Links to the carrier master record.']
  supplier_contract_id varchar [note: 'The supplier contract id of the carrier contract record']
  accessorial_schedule_code varchar [note: 'Reference code identifying the accessorial charge schedule applicable to this contract. Accessorial charges include liftgate, residential delivery, inside delivery, detention, layover, hazmat handling, and temperature-controlled surcharges. Links to the accessorial rate table for freight audit and cost estimation.']
  accessorial_terms varchar [note: 'The accessorial terms of the carrier contract record']
  amount decimal(18,4) [note: 'The amount of the carrier contract record']
  approval_date date [note: 'Date on which the carrier contract was formally approved by the authorized approver. Used in contract governance, SOX audit trails, and procurement compliance reporting.']
  approved_by varchar [note: 'Name or employee identifier of the authorized approver who signed off on this carrier contract. Required for SOX financial controls compliance and procurement governance. Supports audit trail for contract authorization.']
  auto_renew_flag boolean [note: 'The auto renew flag of the carrier contract record']
  auto_renewal boolean [note: 'Indicates whether this carrier contract automatically renews at expiry unless terminated with advance notice. When true, the renewal_notice_days field defines the required notice period. Supports contract lifecycle management and procurement planning.']
  base_rate decimal(18,4) [note: 'The primary negotiated freight rate under this contract before surcharges and accessorial charges are applied. The unit of measure for this rate is defined by the rate_type field (e.g., per mile, per CWT, per pallet, flat). Used as the foundation for freight cost estimation and freight audit rate lookup.']
  billing_frequency varchar [note: 'Frequency at which the carrier submits freight invoices under this contract. Per-shipment billing generates an invoice for each delivery; weekly/bi-weekly/monthly billing consolidates charges into periodic invoices. Impacts freight audit workflow and accounts payable processing.']
  carrier_contract_status varchar [note: 'The carrier contract status of the carrier contract record']
  code varchar [note: 'The carrier contract code of the carrier contract record']
  cold_chain_required boolean [note: 'Indicates whether this contract covers temperature-controlled (cold chain) shipments requiring refrigerated or frozen transport. When true, cold chain compliance monitoring, temperature logging, and FEFO inventory management protocols apply. Relevant for health, hygiene, and perishable consumer goods.']
  contract_number varchar [note: 'Externally-known, human-readable contract reference number assigned by the procurement or logistics team. Used in EDI communications, freight audit, and carrier correspondence. Aligns with SAP S/4HANA MM contract document number.']
  contract_status varchar [note: 'Current lifecycle state of the carrier contract. Draft indicates contract is being authored; pending_approval is awaiting sign-off; active means the contract is in force; suspended means temporarily halted; expired means the term has lapsed; terminated means the contract was ended before expiry.']
  contract_type varchar [note: 'Classification of the freight contract by commercial arrangement type. Spot contracts cover single-shipment rates; committed contracts lock volume at negotiated rates; preferred carrier agreements define priority tender; dedicated contracts reserve capacity; intermodal covers multi-mode arrangements; 3PL master covers third-party logistics umbrella agreements.']
  created_timestamp timestamp [note: 'Timestamp when this carrier contract record was first created in the logistics data platform. Follows ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for data lineage, audit trail, and Silver layer ingestion tracking.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code in which all rates, charges, and financial commitments under this contract are denominated (e.g., USD, EUR, GBP). Required for multi-currency freight cost management and financial reporting.']
  description varchar [note: 'The carrier contract description of the carrier contract record']
  destination_country_code varchar [note: 'ISO 3166-1 alpha-3 three-letter country code for the destination country covered by this contract. Used for cross-border freight classification, customs compliance, and international rate applicability.']
  destination_region varchar [note: 'Geographic destination zone or region covered by this contract for lane-level rate applicability. May represent a state, ZIP zone, city cluster, or carrier-defined zone code. Used in freight cost estimation and tender evaluation.']
  detention_free_time_hours varchar [note: 'Number of hours the carrier\'s equipment (trailer/container) may remain at a Consumer Goods facility for loading or unloading without incurring detention charges. Exceeding this threshold triggers accessorial detention fees per the contract rate schedule.']
  edi_capable boolean [note: 'Indicates whether the carrier supports EDI (Electronic Data Interchange) for automated tender, shipment status, and invoice exchange under this contract. EDI-capable carriers enable automated load tendering (EDI 204), shipment status updates (EDI 214), and freight invoice processing (EDI 210).']
  effective_date date [note: 'The date on which the carrier contract becomes legally binding and rates become applicable for freight tendering and cost estimation. Aligns with SAP S/4HANA MM contract validity start date.']
  effective_from date [note: 'The effective from of the carrier contract record']
  effective_until date [note: 'The effective until of the carrier contract record']
  end_date date [note: 'The end date of the carrier contract record']
  expiry_date date [note: 'The date on which the carrier contract ceases to be valid and rates are no longer applicable. Nullable for evergreen contracts with no fixed end date. Aligns with SAP S/4HANA MM contract validity end date.']
  fuel_surcharge_basis varchar [note: 'Defines how the fuel surcharge is calculated and applied: as a percentage of the base freight rate, a flat amount per mile, a flat amount per shipment, or dynamically linked to the DOE diesel fuel price index. Determines the fuel surcharge computation method in freight audit.']
  fuel_surcharge_pct decimal(7,4) [note: 'The fuel surcharge pct of the carrier contract record']
  fuel_surcharge_rate decimal(8,4) [note: 'Contracted fuel surcharge rate expressed as a percentage of the base rate or as a fixed amount per unit, applied on top of the base freight rate to account for fuel cost variability. Linked to a fuel index table or DOE diesel price index. Critical for freight cost estimation and audit.']
  hazmat_certified boolean [note: 'Indicates whether the carrier is certified and authorized under this contract to transport hazardous materials (hazmat) including flammable, corrosive, or toxic consumer goods ingredients. When true, DOT/IATA hazmat compliance documentation is required.']
  insurance_coverage_amount decimal(18,2) [note: 'Maximum cargo insurance coverage amount provided by the carrier under this contract, expressed in the contract currency. Defines the financial liability limit for cargo loss or damage claims. Used in risk management and claims processing.']
  last_updated_timestamp timestamp [note: 'The last updated timestamp of the carrier contract record']
  liability_limit_amount decimal(18,2) [note: 'The liability limit amount of the carrier contract record']
  liability_limit_per_kg decimal(10,4) [note: 'Contractual carrier liability limit per kilogram of cargo for loss or damage claims, expressed in the contract currency. Used in freight claims management to calculate maximum recoverable amounts for damaged or lost shipments.']
  max_weight_kg decimal(10,3) [note: 'Maximum shipment weight in kilograms at which this contract rate applies. Defines the upper bound of the weight break tier. Null indicates no upper limit (applies to all weights above the minimum). Used in freight cost estimation and audit.']
  min_weight_kg decimal(10,3) [note: 'Minimum shipment weight in kilograms at which this contract rate applies. Defines the lower bound of the weight break tier for rate applicability. Used in freight cost estimation and audit to validate correct rate application.']
  minimum_volume_commitment decimal(18,2) [note: 'The minimum volume commitment of the carrier contract record']
  name varchar [note: 'The carrier contract name of the carrier contract record']
  notes varchar [note: 'The notes of the carrier contract record']
  origin_country_code varchar [note: 'ISO 3166-1 alpha-3 three-letter country code for the origin country covered by this contract. Used for cross-border freight classification, customs compliance, and international rate applicability.']
  origin_region varchar [note: 'Geographic origin zone or region covered by this contract for lane-level rate applicability. May represent a state, ZIP zone, city cluster, or carrier-defined zone code. Used in freight cost estimation and tender evaluation.']
  otif_penalty_rate decimal(8,4) [note: 'Contractual penalty rate applied to the carrier for OTIF (On Time In Full) failures, expressed as a percentage of the invoice value or a fixed amount per incident. OTIF is a key KPI in consumer goods supply chain performance management. Supports carrier performance management and deduction processing.']
  otif_threshold_pct decimal(5,2) [note: 'Minimum OTIF performance percentage the carrier must achieve to avoid penalty charges under this contract. Expressed as a percentage (e.g., 98.5 means 98.5% OTIF compliance required). Below this threshold, the otif_penalty_rate is triggered.']
  payment_terms varchar [note: 'Contractual payment terms defining when freight invoices must be settled after receipt. Net_30 means payment due within 30 days of invoice date. 2/10 Net 30 means a 2% discount if paid within 10 days. Drives accounts payable scheduling and freight audit payment processing.']
  penalty_clause varchar [note: 'The penalty clause of the carrier contract record']
  pickup_lead_time_hours varchar [note: 'Contracted lead time in hours from tender acceptance to carrier pickup at the origin facility. Used in shipment planning, load scheduling, and Blue Yonder WMS labor planning for dock door assignment.']
  quantity decimal(18,4) [note: 'The quantity of the carrier contract record']
  rate_basis varchar [note: 'The rate basis of the carrier contract record']
  rate_type varchar [note: 'Defines the unit basis on which the base_rate is charged. Per-mile rates apply to distance-based pricing; per-CWT (hundredweight) applies to weight-based LTL pricing; per-pallet applies to unit-load pricing; flat rate is a fixed charge per shipment regardless of weight or distance; per-kg and per-lb are weight-based variants used in air and parcel freight. [ENUM-REF-CANDIDATE: per_mile|per_cwt|per_pallet|per_shipment|flat|per_kg|per_lb — 7 candidates stripped; promote to reference product]']
  renewal_date date [note: 'The renewal date of the carrier contract record']
  renewal_notice_days varchar [note: 'Number of calendar days advance notice required to terminate or renegotiate this contract before auto-renewal. Applicable only when auto_renewal is true. Used in contract lifecycle management to trigger procurement review workflows.']
  service_level varchar [note: 'Contracted service level defining the speed and handling tier for shipments under this agreement. Drives SLA commitments, OTIF measurement thresholds, and rate applicability. Examples: standard ground, expedited, overnight, two-day, deferred, white-glove.']
  service_level_agreement varchar [note: 'The service level agreement of the carrier contract record']
  signed_by varchar [note: 'The signed by of the carrier contract record']
  signed_date date [note: 'The signed date of the carrier contract record']
  source_system_code varchar [note: 'The source system code of the carrier contract record']
  start_date date [note: 'The start date of the carrier contract record']
  temperature_max_c decimal(5,2) [note: 'Maximum temperature in degrees Celsius that must be maintained throughout transit for cold chain shipments under this contract. Applicable only when cold_chain_required is true. Exceedance triggers non-conformance reporting and potential product rejection.']
  temperature_min_c decimal(5,2) [note: 'Minimum temperature in degrees Celsius that must be maintained throughout transit for cold chain shipments under this contract. Applicable only when cold_chain_required is true. Used for cold chain compliance monitoring and carrier performance audits.']
  track_trace_method varchar [note: 'Method by which shipment tracking and status updates are provided by the carrier under this contract. EDI 214 is the standard electronic shipment status transaction; API enables real-time integration; portal requires manual check-in; email is manual notification. Drives track-and-trace capability in logistics operations.']
  transit_time_days varchar [note: 'Contracted standard transit time in calendar days from pickup to delivery for shipments under this contract and lane. Used as the SLA baseline for OTIF measurement, delivery promise, and ATP/CTP calculations in demand planning.']
  transport_mode varchar [note: 'Primary mode of transportation covered by this contract. TL (Truckload), LTL (Less-than-Truckload), intermodal, rail, ocean freight, air freight, parcel/small package, or drayage (port/terminal moves). Drives rate table applicability and freight audit logic. [ENUM-REF-CANDIDATE: truckload|ltl|intermodal|rail|ocean|air|parcel|drayage — 8 candidates stripped; promote to reference product]']
  uom varchar [note: 'The uom of the carrier contract record']
  updated_timestamp timestamp [note: 'Timestamp when this carrier contract record was most recently modified in the logistics data platform. Follows ISO 8601 format. Used for change data capture (CDC), data lineage, and audit trail in the Databricks Silver layer.']
  volume_commitment_units decimal(14,2) [note: 'Contracted minimum volume commitment by Consumer Goods to the carrier over the contract term, expressed in the unit defined by volume_commitment_uom (e.g., shipments, pallets, CWT, revenue miles). Failure to meet this commitment may trigger shortfall penalties or rate renegotiation.']
  volume_commitment_uom varchar [note: 'Unit of measure for the volume_commitment_units field. Defines whether the volume commitment is expressed in number of shipments, pallets, hundredweight (CWT), revenue miles, kilograms, or truckloads.']

  Note: 'Freight contract, rate agreement, and granular rate schedule between Consumer Goods and a carrier. Captures contract term dates, lane coverage, mode of transport, negotiated base rates, fuel surcharge tables, accessorial charge schedules, volume commitments, OTIF penalty clauses, contract status, and detailed rate records including rate type (per-mile/per-cwt/per-pallet/flat), origin/destination zones, weight breaks, effective/expiry dates, and currency. Supports freight cost estimation, tender evaluation, freight audit rate lookup, and carrier performance management.'
}

Table logistics.lane {
  lane_id varchar [pk, note: 'Unique system-generated identifier for the transportation lane record. Primary key for the lane entity in the logistics domain.']
  carrier_contract_id varchar [note: 'Reference to the carrier contract or rate agreement governing freight pricing and service terms on this lane. Links to the carrier contract master in the logistics domain.']
  destination_location_supply_network_node_id varchar [note: 'Reference to the destination facility, distribution center, retail store, or customer location where freight is delivered on this lane. Links to the location master in the logistics domain.']
  lane_operating_carrier_id varchar [note: 'The lane operating carrier id of the lane record']
  primary_lane_backup_carrier_id varchar [note: 'Reference to the secondary/backup carrier for this lane, used when the preferred carrier declines the tender or is unavailable. Represents the second position in the routing guide.']
  primary_lane_supply_network_node_id varchar [note: 'Reference to the origin facility, distribution center, plant, or supplier location from which freight departs on this lane. Links to the location master in the logistics domain.']
  amount decimal(18,4) [note: 'The amount of the lane record']
  annual_volume_loads varchar [note: 'Historical or planned annual shipment volume on this lane expressed in number of loads (truckloads, containers, or equivalent units). Used for carrier contract negotiations, network design, and freight spend forecasting.']
  annual_volume_weight_kg decimal(14,2) [note: 'Historical or planned annual freight weight moved on this lane in kilograms. Used for carrier contract negotiations, modal optimization, and carbon emissions intensity calculations per ISO 14001.']
  avg_transit_time_hours decimal(10,2) [note: 'The avg transit time hours of the lane record']
  benchmark_rate_flat decimal(12,2) [note: 'Lane-level flat cost benchmark (all-in rate per load/shipment) in the operating currency. Used for truckload lanes where per-km pricing is not applicable. Supports freight audit and carrier contract negotiation.']
  benchmark_rate_per_km decimal(10,4) [note: 'Lane-level cost benchmark expressed as rate per kilometer in the operating currency. Used for freight audit, carrier performance benchmarking, and transportation cost variance analysis. Confidential as it reflects negotiated contract intelligence.']
  carbon_emission_factor decimal(10,6) [note: 'Lane-level carbon emission intensity factor expressed as kilograms of CO2 equivalent per kilometer, based on transport mode and equipment type. Used for Scope 3 emissions reporting, sustainability KPIs, and ESG disclosures per ISO 14001 and EPA Greenhouse Gas Reporting Program.']
  classification varchar [note: 'Directional and functional classification of the lane within the supply chain network. Inbound covers supplier-to-plant/DC movements; outbound covers DC-to-customer/retailer; inter-facility covers plant-to-DC or DC-to-DC; last-mile covers final delivery to end consumer or store; reverse covers returns flow.']
  co2_per_shipment_kg decimal(12,4) [note: 'The co2 per shipment kg of the lane record']
  code varchar [note: 'Externally-known alphanumeric code uniquely identifying the transportation lane, used in carrier contracts, freight tenders, and TMS systems. Typically formatted as ORIGIN-DEST-MODE (e.g., CHI-NYC-TL). Aligns with SAP TM lane master data.']
  cold_chain_required boolean [note: 'Indicates whether this lane requires temperature-controlled transportation to maintain product integrity. When true, cold-chain compliance monitoring, temperature logging, and qualified carrier requirements apply. Critical for health, hygiene, and perishable consumer goods.']
  created_timestamp timestamp [note: 'Timestamp when this lane record was first created in the system. Used for data lineage, audit trail, and record lifecycle management. Conforms to ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).']
  cross_border boolean [note: 'Indicates whether this lane crosses an international border, requiring customs documentation, import/export compliance, and potentially additional transit time for border clearance. Drives customs broker assignment and trade compliance workflows.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code applicable to the lane benchmark rates and cost data (e.g., USD, EUR, GBP). Required for multi-currency freight cost consolidation and financial reporting.']
  customs_trade_zone varchar [note: 'Trade zone or customs agreement applicable to this cross-border lane (e.g., USMCA, EU Single Market, ASEAN). Determines duty rates, documentation requirements, and customs clearance procedures. Populated only for cross-border lanes.']
  description varchar [note: 'The lane description of the lane record']
  destination_city varchar [note: 'City name of the lane destination point. Used for geographic lane analysis, carrier rate zone determination, and network design reporting.']
  destination_country_code varchar [note: 'ISO 3166-1 alpha-3 country code for the lane destination. Required for cross-border lane classification, customs documentation, and international freight rate benchmarking.']
  destination_location varchar [note: 'The destination location of the lane record']
  destination_location_code varchar [note: 'Business-facing code for the destination location (e.g., customer DC code, store code, or GS1 Global Location Number). Used in EDI transactions, carrier communications, and freight audit matching.']
  destination_state_province varchar [note: 'ISO 3166-2 state or province code for the lane destination. Used in carrier rate zone mapping and freight cost benchmarking.']
  distance_km decimal(10,2) [note: 'Measured or calculated road/route distance between origin and destination in kilometers. Used for transit time estimation, fuel surcharge calculation, carrier rate benchmarking, and carbon emissions reporting per ISO 14001 and EPA guidelines.']
  dsd_eligible boolean [note: 'Indicates whether this lane supports Direct Store Delivery (DSD), where product is delivered directly from the manufacturer or distributor to the retail store, bypassing the retailer\'s distribution center. Relevant for high-velocity CPG categories.']
  effective_date date [note: 'Date from which this lane definition becomes active and available for freight planning, carrier assignment, and cost benchmarking. Used to manage lane versioning and contract period alignment.']
  effective_from date [note: 'The effective from of the lane record']
  effective_until date [note: 'The effective until of the lane record']
  equipment_type varchar [note: 'Type of transportation equipment required for this lane. Refrigerated (reefer) equipment is critical for cold-chain compliance in temperature-sensitive consumer goods. Drives carrier qualification and cost benchmarking. [ENUM-REF-CANDIDATE: dry_van|refrigerated|flatbed|tanker|container_20ft|container_40ft|container_45ft|parcel|bulk — promote to reference product]']
  expiry_date date [note: 'Date after which this lane definition is no longer valid for freight planning. Nullable for open-ended lanes. Used to manage contract renewals, network redesigns, and lane decommissioning.']
  hazmat_required boolean [note: 'Indicates whether this lane requires carriers certified for hazardous materials (HAZMAT) transport. Applicable for lanes carrying chemical, aerosol, or regulated consumer goods. Triggers carrier qualification checks and regulatory documentation requirements per DOT/EPA/OSHA.']
  is_active boolean [note: 'The is active of the lane record']
  lane_status varchar [note: 'Current lifecycle status of the transportation lane. Active lanes are available for freight tendering and route optimization. Inactive or suspended lanes are excluded from planning runs.']
  lane_type varchar [note: 'The lane type of the lane record']
  last_updated_timestamp timestamp [note: 'The last updated timestamp of the lane record']
  mode_of_transport varchar [note: 'The mode of transport of the lane record']
  modified_timestamp timestamp [note: 'Timestamp when this lane record was last updated. Used for change tracking, data freshness monitoring, and incremental ETL processing in the Databricks Silver Layer.']
  name varchar [note: 'Human-readable descriptive name for the transportation lane, typically combining origin and destination location names and transport mode (e.g., \'Chicago DC to New York RDC - Truckload\'). Used in reporting and carrier communication.']
  network_region varchar [note: 'Geographic or operational network region to which this lane belongs (e.g., Northeast, Southeast, Midwest, West Coast, EMEA, APAC). Used for network design segmentation, regional freight cost analysis, and carrier portfolio management.']
  notes varchar [note: 'The notes of the lane record']
  origin_city varchar [note: 'City name of the lane origin point. Used for geographic lane analysis, carrier rate zone determination, and network design reporting.']
  origin_country_code varchar [note: 'ISO 3166-1 alpha-3 country code for the lane origin. Required for cross-border lane classification, customs documentation, and international freight rate benchmarking.']
  origin_location varchar [note: 'The origin location of the lane record']
  origin_location_code varchar [note: 'Business-facing code for the origin location (e.g., plant code, DC code, or GS1 Global Location Number). Used in EDI transactions, carrier communications, and freight audit matching.']
  origin_state_province varchar [note: 'ISO 3166-2 state or province code for the lane origin. Used in carrier rate zone mapping, regulatory compliance (e.g., CARB emissions zones), and freight cost benchmarking.']
  otif_target_pct decimal(5,2) [note: 'Target OTIF (On Time In Full) performance percentage for this lane, representing the contractual or operational delivery reliability goal. Used as the KPI baseline for carrier performance scorecards and SLA compliance reporting.']
  preferred_mode varchar [note: 'The preferred mode of the lane record']
  quantity decimal(18,4) [note: 'The quantity of the lane record']
  routing_guide_rank varchar [note: 'Numeric rank of the preferred carrier in the lane routing guide sequence. Rank 1 is the primary carrier; higher ranks are fallback options. Used in automated freight tendering workflows to determine tender sequence.']
  service_level varchar [note: 'Contracted service level for this lane defining the speed and priority of freight movement. Standard is regular scheduled service; expedited is premium fast transit; economy is cost-optimized slower service; dedicated is exclusive carrier capacity; spot is ad-hoc market rate.']
  source_system_code varchar [note: 'Code identifying the operational system of record from which this lane record originated (e.g., SAP Transportation Management, Blue Yonder WMS). Used for data lineage tracking and reconciliation in the Databricks Silver Layer.']
  standard_transit_days varchar [note: 'Contractually agreed or operationally standard number of calendar days for freight to travel from origin to destination on this lane. Used as the baseline for OTIF (On Time In Full) measurement, delivery promise, and ATP/CTP calculations in SAP IBP.']
  temperature_max_c decimal(5,2) [note: 'Maximum allowable temperature in degrees Celsius for cold-chain lanes. Freight must be maintained at or below this threshold throughout transit. Used for carrier qualification, SLA monitoring, and regulatory compliance under FDA and GMP guidelines.']
  temperature_min_c decimal(5,2) [note: 'Minimum allowable temperature in degrees Celsius for cold-chain lanes. Freight must be maintained at or above this threshold throughout transit. Used for carrier qualification, SLA monitoring, and regulatory compliance under FDA and GMP guidelines.']
  transit_time_days decimal(6,2) [note: 'The transit time days of the lane record']
  transport_mode varchar [note: 'Primary mode of transportation used on this lane. Determines carrier pool, equipment type, transit time standards, and freight cost benchmarks. Truckload (TL) and Less-than-Truckload (LTL) are most common in CPG domestic networks. [ENUM-REF-CANDIDATE: truckload|less_than_truckload|intermodal|rail|air|ocean|parcel|courier|drayage — promote to reference product]']
  uom varchar [note: 'The uom of the lane record']
  updated_timestamp timestamp [note: 'The updated timestamp of the lane record']

  Note: 'Defined origin-to-destination transportation lane used for freight planning, carrier assignment, and cost benchmarking. Captures origin and destination location codes, transport mode, distance, transit time standard, lane classification (inbound/outbound/inter-facility/last-mile), preferred carrier assignments, volume history, and lane-level cost benchmarks. Foundational reference for route optimization, freight tendering, and network design.'
}

Table logistics.logistics_shipment {
  logistics_shipment_id varchar [pk, note: 'Unique surrogate identifier for the logistics shipment record in the lakehouse Silver layer. Primary key for this entity.']
  carrier_id varchar [note: 'Reference to the contracted carrier (trucking company, ocean liner, air freight provider, parcel carrier) responsible for executing this shipment.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Logistics shipments incur freight costs allocated to cost centers for P&L and budget reporting. In consumer goods, shipments (including DSD and inter-facility transfers) are directly assigned to cost ']
  destination_facility_distribution_center_distribution_facility_id varchar [note: 'Reference to the facility (distribution center, retail store, customer location, or 3PL node) to which the shipment is consigned.']
  distribution_shipment_id varchar [note: 'Foreign key linking to distribution.distribution_shipment. Business justification: Required for OTIF reporting: links each logistics shipment to its originating distribution shipment for status tracking.']
  freight_order_id varchar [note: 'Reference to the parent freight order or transportation order that authorized and planned this shipment movement.']
  lane_id varchar [note: 'Reference to the contracted transportation lane (origin-destination pair) governing rate, transit time, and carrier assignment for this shipment.']
  manufacturing_facility_id varchar [note: 'Foreign key linking to manufacturing.manufacturing_facility. Business justification: Traceability: link each shipment to its originating manufacturing facility for cost allocation and regulatory reporting.']
  origin_distribution_facility_id varchar [note: 'The origin distribution facility id of the logistics shipment record']
  origin_trade_account_id varchar [note: 'Foreign key linking to sales.trade_account. Business justification: Shipment origin account is needed for cost attribution, SLA reporting, and regulatory shipment origin documentation.']
  primary_logistics_distribution_facility_id varchar [note: 'Reference to the facility (plant, distribution center, warehouse, or supplier location) from which the shipment departs.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Shipment costs are attributed to profit centers for brand/channel profitability analysis in consumer goods. Logistics costs by profit center are required for segment reporting and trade spend analysis']
  sales_order_id varchar [note: 'Foreign key linking to sales.order. Business justification: Shipment tracking must reference the originating sales order for fulfillment status and revenue reconciliation.']
  actual_delivery_date date [note: 'The actual date the shipment was received and confirmed at the destination facility. Used for OTIF (On Time In Full) KPI calculation and carrier performance scorecarding.']
  actual_delivery_timestamp timestamp [note: 'Precise date and time the shipment was delivered and signed for at the destination, as captured by the carrier\'s POD (Proof of Delivery) system or electronic signature device. Enables time-window compliance measurement.']
  actual_pickup_date date [note: 'The actual pickup date of the logistics shipment record']
  actual_ship_date date [note: 'The actual date the shipment physically departed from the origin facility, as confirmed by the WMS or carrier. Used for OTIF (On Time In Full) measurement and freight audit.']
  amount decimal(18,4) [note: 'The amount of the logistics shipment record']
  bill_of_lading_number varchar [note: 'The bill of lading number of the logistics shipment record']
  bol_number varchar [note: 'Bill of Lading number issued by the carrier as the legal contract of carriage and receipt of goods. Required for freight audit, customs clearance, and proof of delivery. Key document in SAP S/4HANA SD and Blue Yonder WMS.']
  code varchar [note: 'The logistics shipment code of the logistics shipment record']
  cold_chain_required boolean [note: 'Indicates whether this shipment requires temperature-controlled cold chain handling throughout transit. Triggers cold chain compliance monitoring, reefer equipment assignment, and regulatory documentation for applicable product categories (e.g., perishables, pharmaceuticals).']
  container_number varchar [note: 'ISO 6346 standardized container identification number for ocean freight shipments (e.g., MSCU1234567). Used for port tracking, customs clearance, and demurrage/detention management.']
  created_timestamp timestamp [note: 'Timestamp when the shipment record was first created in the source system (TMS/ERP/WMS). Used for audit trail, data lineage, and SLA measurement from order-to-ship cycle time analysis.']
  currency_code varchar [note: 'The currency code of the logistics shipment record']
  description varchar [note: 'The logistics shipment description of the logistics shipment record']
  destination_address varchar [note: 'The destination address of the logistics shipment record']
  direction varchar [note: 'Indicates the direction of the shipment relative to the enterprise network: inbound (from supplier), outbound (to customer/retailer), interplant (between internal facilities), or return (reverse logistics).']
  effective_from date [note: 'The effective from of the logistics shipment record']
  effective_until date [note: 'The effective until of the logistics shipment record']
  exception_code varchar [note: 'Standardized code identifying the reason for a shipment exception or delay (e.g., weather delay, carrier capacity, customs hold, address correction, damaged goods). Used for root cause analysis and carrier performance management. [ENUM-REF-CANDIDATE: weather_delay|carrier_capacity|customs_hold|address_correction|damaged_goods|mechanical_failure|other — promote to reference product]']
  expected_delivery_date date [note: 'The expected delivery date of the logistics shipment record']
  freight_cost_amount decimal(14,2) [note: 'Total contracted or invoiced freight cost for this shipment in the transaction currency. Used for freight cost allocation to COGS (Cost of Goods Sold), carrier spend analytics, and freight audit reconciliation.']
  freight_cost_currency varchar [note: 'ISO 4217 three-letter currency code for the freight cost amount (e.g., USD, EUR, GBP). Required for multi-currency freight spend reporting and financial consolidation.']
  freight_terms varchar [note: 'Freight payment terms indicating who bears the freight cost: prepaid (shipper pays), collect (consignee pays), or third_party (a designated third party pays). Drives freight invoice routing and cost allocation.']
  fuel_surcharge_amount decimal(12,2) [note: 'Carrier-applied fuel surcharge amount for this shipment, separate from the base freight rate. Used for freight audit, cost variance analysis, and carrier contract compliance.']
  hazmat_flag boolean [note: 'Indicates whether the shipment contains hazardous materials requiring special handling, labeling, and documentation per DOT/IATA/IMDG regulations. Triggers HAZMAT compliance workflow and carrier notification.']
  incoterm varchar [note: 'The incoterm of the logistics shipment record']
  incoterms varchar [note: 'The incoterms of the logistics shipment record']
  incoterms_code varchar [note: 'International Commercial Terms (Incoterms) code defining the transfer of risk, cost responsibility, and delivery obligations between shipper and consignee. Governs freight cost allocation and insurance requirements. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — promote to reference product]']
  is_cold_chain boolean [note: 'The is cold chain of the logistics shipment record']
  is_hazmat boolean [note: 'The is hazmat of the logistics shipment record']
  last_updated_timestamp timestamp [note: 'The last updated timestamp of the logistics shipment record']
  logistics_shipment_status varchar [note: 'The logistics shipment status of the logistics shipment record']
  mode_of_transport varchar [note: 'The mode of transport of the logistics shipment record']
  name varchar [note: 'The logistics shipment name of the logistics shipment record']
  notes varchar [note: 'The notes of the logistics shipment record']
  origin_address varchar [note: 'The origin address of the logistics shipment record']
  otif_in_full boolean [note: 'Indicates whether the shipment was delivered with the complete ordered quantity, contributing to the OTIF (On Time In Full) KPI. Supports retailer compliance scorecarding and deduction management.']
  otif_on_time boolean [note: 'Indicates whether the shipment was delivered on or before the planned delivery date, contributing to the OTIF (On Time In Full) KPI. Derived from planned vs. actual delivery date comparison and stored for reporting efficiency.']
  planned_delivery_date date [note: 'The date on which the shipment is expected to arrive at the destination facility, based on contracted transit time and lane performance.']
  planned_pickup_date date [note: 'The planned pickup date of the logistics shipment record']
  planned_ship_date date [note: 'The date on which the shipment is scheduled to depart from the origin facility, as determined by the transportation plan or S&OP (Sales and Operations Planning) process.']
  pod_received boolean [note: 'Indicates whether a signed Proof of Delivery (POD) document has been received and validated for this shipment. Required for freight invoice payment release and dispute resolution.']
  pod_timestamp timestamp [note: 'Date and time the Proof of Delivery (POD) was electronically captured or received, as recorded by the carrier\'s mobile device or ePOD system. Used for freight audit and dispute resolution timelines.']
  priority_level varchar [note: 'The priority level of the logistics shipment record']
  pro_number varchar [note: 'Carrier-assigned Progressive (PRO) number used to track LTL (Less-Than-Truckload) shipments through the carrier\'s network. Essential for freight audit and claims management.']
  quantity decimal(18,4) [note: 'The quantity of the logistics shipment record']
  service_level varchar [note: 'Contracted carrier service level for this shipment, determining transit time commitment and freight rate tier. Drives SLA (Service Level Agreement) compliance measurement.']
  ship_date date [note: 'The ship date of the logistics shipment record']
  ship_timestamp timestamp [note: 'Precise date and time the shipment departed the origin facility, as recorded by the WMS or gate system. Used for transit time calculation and carrier SLA compliance.']
  shipment_number varchar [note: 'Externally-known business identifier for the shipment, typically generated by the TMS or ERP (e.g., SAP outbound delivery number or transportation order number). Used for track-and-trace and carrier communication.']
  shipment_status varchar [note: 'Current lifecycle status of the shipment. Drives OTIF (On Time In Full) measurement, exception management, and track-and-trace visibility. [ENUM-REF-CANDIDATE: planned|tendered|confirmed|in_transit|out_for_delivery|delivered|cancelled|exception — promote to reference product]']
  shipment_type varchar [note: 'The shipment type of the logistics shipment record']
  source_system_code varchar [note: 'The source system code of the logistics shipment record']
  temperature_max_c decimal(5,2) [note: 'Maximum allowable temperature in degrees Celsius for cold chain shipments. Exceedances trigger quality holds, product disposition reviews, and regulatory notifications.']
  temperature_min_c decimal(5,2) [note: 'Minimum allowable temperature in degrees Celsius for cold chain shipments. Used for reefer equipment configuration, carrier instructions, and cold chain compliance auditing.']
  temperature_range varchar [note: 'The temperature range of the logistics shipment record']
  three_pl_reference varchar [note: 'Reference number assigned by the 3PL (Third-Party Logistics) provider for this shipment in their WMS or TMS. Enables cross-system reconciliation and 3PL billing validation.']
  total_cases varchar [note: 'Total number of cases (cartons) included in the shipment. Used for pick/pack verification, receiving reconciliation, and OTIF (On Time In Full) quantity compliance.']
  total_freight_cost decimal(18,2) [note: 'The total freight cost of the logistics shipment record']
  total_pallets varchar [note: 'Total number of pallets included in the shipment. Used for dock scheduling, trailer loading planning, and carrier billing for LTL shipments.']
  total_pieces varchar [note: 'The total pieces of the logistics shipment record']
  total_volume_cbm decimal(18,4) [note: 'The total volume cbm of the logistics shipment record']
  total_volume_m3 decimal(12,4) [note: 'Total cubic volume of the shipment in cubic meters. Used for dimensional weight calculation, trailer utilization, and freight cost optimization.']
  total_weight_kg decimal(12,3) [note: 'Total gross weight of the shipment in kilograms, including packaging and pallets. Used for freight rate calculation, carrier billing, and compliance with road weight limits.']
  tracking_number varchar [note: 'Carrier-assigned tracking number for parcel or express shipments (e.g., UPS, FedEx, DHL tracking number). Enables real-time track-and-trace via carrier APIs and customer-facing shipment visibility portals.']
  transport_mode varchar [note: 'Mode of transportation used for this shipment. TL = Truckload, LTL = Less-Than-Truckload, parcel = small package carrier, ocean = sea freight, air = air freight, rail = rail freight. Drives freight cost allocation and transit time expectations.']
  uom varchar [note: 'The uom of the logistics shipment record']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the shipment record in the source system. Used for incremental data loading, change detection, and audit trail in the Silver layer lakehouse.']

  Note: 'Core transactional record representing a physical movement of goods from origin to destination. Captures shipment number, BOL (Bill of Lading), PRO number, carrier assignment, mode of transport (TL/LTL/parcel/ocean/air/rail), origin and destination facility, planned and actual ship/delivery dates, total weight and volume, freight terms (prepaid/collect/third-party), shipment status lifecycle, incoterms, cold-chain flag, and consolidation references. Central entity for track-and-trace, OTIF measurement, and freight cost allocation. References carrier, lane, and freight order. [SSOT] Superseded by authoritative table distribution.distribution_shipment for concept \'shipment\'. SSOT: canonical table is distribution.distribution_shipment. [SSOT for concept \'shipment\'.]'
}

Table logistics.shipment_leg {
  shipment_leg_id varchar [pk, note: 'Unique system-generated identifier for each individual shipment leg record within the logistics network. Serves as the primary key for the shipment_leg entity.']
  carrier_id varchar [note: 'Reference to the carrier (3PL, freight forwarder, or internal fleet) responsible for executing this specific leg of the shipment. Supports carrier performance analytics and freight cost allocation.']
  destination_network_node_id varchar [note: 'Reference to the logistics node (warehouse, plant, port, cross-dock, or distribution center) at which this leg arrives. Used for route optimization and delivery confirmation.']
  lane_id varchar [note: 'The lane id of the shipment leg record']
  origin_distribution_facility_id varchar [note: 'Foreign key linking to distribution.distribution_facility. Business justification: DC-level lane performance reporting: consumer goods logistics teams measure transit time and cost by originating DC. shipment_leg.origin_location_code is a denormalized text field; a proper FK to dist']
  primary_shipment_network_node_id varchar [note: 'Reference to the logistics node (warehouse, plant, port, cross-dock, or distribution center) from which this leg departs. Used for route optimization and network analysis.']
  accessorial_charges_amount decimal(18,4) [note: 'Additional carrier charges beyond the base freight rate for this leg, including fuel surcharges, detention, liftgate, residential delivery, or hazmat fees. Used in freight audit and total landed cost analysis.']
  actual_arrival timestamp [note: 'The actual arrival of the shipment leg record']
  actual_arrival_timestamp timestamp [note: 'Actual date and time at which the shipment leg arrived at the destination node as confirmed by the receiving facility or carrier. Used for OTIF measurement, dwell time analysis, and freight audit.']
  actual_departure timestamp [note: 'The actual departure of the shipment leg record']
  actual_departure_timestamp timestamp [note: 'Actual date and time at which the shipment leg departed from the origin node as recorded by the carrier or warehouse management system. Used for OTIF performance measurement and delay root-cause analysis.']
  actual_transit_hours decimal(8,2) [note: 'Actual elapsed transit time in hours for this leg, calculated from actual departure to actual arrival timestamps. Used for carrier performance benchmarking and OTIF analysis.']
  amount decimal(18,4) [note: 'The amount of the shipment leg record']
  bill_of_lading_number varchar [note: 'Unique Bill of Lading (BOL) number issued for this shipment leg. Serves as the legal contract between shipper and carrier and is required for customs clearance, freight audit, and proof of delivery.']
  carbon_emissions_kg decimal(12,4) [note: 'Estimated carbon dioxide equivalent (CO₂e) emissions in kilograms for this shipment leg, calculated based on transport mode, distance, and cargo weight. Supports sustainability reporting under ISO 14001 and ESG commitments.']
  carrier_pro_number varchar [note: 'Carrier-assigned Progressive (PRO) number or tracking number for this leg. Used for carrier track-and-trace, freight bill matching, and proof of delivery retrieval.']
  code varchar [note: 'The shipment leg code of the shipment leg record']
  created_timestamp timestamp [note: 'Date and time when this shipment leg record was first created in the system. Used for data lineage, audit trail, and Silver layer ingestion tracking.']
  currency_code varchar [note: 'The currency code of the shipment leg record']
  customs_clearance_required boolean [note: 'Indicates whether this leg crosses an international border and requires customs clearance (True). Triggers customs documentation workflows and compliance checks under applicable trade regulations.']
  customs_entry_number varchar [note: 'Official customs entry or declaration number assigned by the customs authority for this leg. Required for cross-border shipments and regulatory compliance documentation.']
  delay_reason_code varchar [note: 'Standardized code identifying the root cause of any departure or arrival delay on this leg (e.g., weather, customs hold, carrier capacity, traffic, mechanical failure). Used for OTIF root-cause analysis and carrier performance management. [ENUM-REF-CANDIDATE: weather|customs_hold|carrier_capacity|traffic|mechanical_failure|port_congestion|documentation — promote to reference product]']
  description varchar [note: 'The shipment leg description of the shipment leg record']
  destination_country_code varchar [note: 'ISO 3166-1 alpha-3 country code of the destination node for this leg (e.g., USA, DEU, GBR). Used for customs compliance, trade lane analysis, and carbon footprint reporting.']
  destination_location varchar [note: 'The destination location of the shipment leg record']
  destination_location_code varchar [note: 'The destination location code of the shipment leg record']
  distance_km decimal(12,2) [note: 'The distance km of the shipment leg record']
  effective_from date [note: 'The effective from of the shipment leg record']
  effective_until date [note: 'The effective until of the shipment leg record']
  estimated_arrival_timestamp timestamp [note: 'Most recent carrier-provided or system-calculated Estimated Time of Arrival (ETA) for this leg. Updated dynamically during transit to reflect real-time conditions. Distinct from planned arrival (static) and actual arrival (confirmed).']
  freight_audit_status varchar [note: 'Current status of the freight invoice audit process for this leg. Tracks whether the carrier invoice has been validated, approved for payment, or is under dispute. Supports freight audit and payment workflows.']
  freight_cost_amount decimal(18,4) [note: 'Gross freight cost charged by the carrier for this specific leg, expressed in the transaction currency. Used for freight cost allocation, COGS calculation, and carrier contract compliance auditing.']
  freight_cost_currency varchar [note: 'ISO 4217 three-letter currency code for the freight cost amount on this leg (e.g., USD, EUR, GBP). Required for multi-currency freight cost consolidation and financial reporting.']
  gross_weight_kg decimal(12,3) [note: 'Total gross weight in kilograms of the cargo on this leg, including packaging and pallets. Used for freight rate calculation, vehicle load compliance, and carrier billing validation.']
  incoterms_code varchar [note: 'INCOTERMS 2020 code defining the transfer of risk and responsibility between shipper and carrier/buyer for this leg (e.g., FOB, CIF, DAP). Determines freight cost ownership and insurance obligations. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]']
  is_cold_chain boolean [note: 'Indicates whether this leg requires temperature-controlled cold chain handling (True) for perishable or temperature-sensitive consumer goods (e.g., health, hygiene, or food products). Triggers cold chain monitoring and compliance checks.']
  is_hazmat boolean [note: 'Indicates whether this leg involves the transport of hazardous materials (True) as classified under DOT, IATA, or IMDG regulations. Triggers special handling, documentation (SDS), and carrier compliance requirements.']
  is_transshipment_point boolean [note: 'Indicates whether the destination node of this leg is an intermediate transshipment point (True) rather than the final delivery destination (False). Used to identify relay legs in intermodal routing and cost allocation.']
  last_updated_timestamp timestamp [note: 'Date and time when this shipment leg record was most recently modified. Used for incremental data loading, change detection, and audit trail in the Databricks Silver layer.']
  leg_cost_amount decimal(18,4) [note: 'The leg cost amount of the shipment leg record']
  leg_distance_km decimal(10,3) [note: 'Total distance in kilometers for this shipment leg from origin node to destination node. Used for freight cost calculation, carbon emissions estimation, and route optimization analytics.']
  leg_number varchar [note: 'Sequential integer indicating the order of this leg within the parent shipment (e.g., 1 = first leg, 2 = second leg). Enables reconstruction of the full shipment route in correct order.']
  leg_reference_number varchar [note: 'Externally-known alphanumeric identifier for this shipment leg, often assigned by the carrier or freight forwarder (e.g., waybill number, booking reference). Used for carrier communication and freight audit.']
  leg_sequence varchar [note: 'The leg sequence of the shipment leg record']
  leg_status varchar [note: 'Current lifecycle status of the shipment leg reflecting its operational state. Drives track-and-trace visibility and exception management workflows. [ENUM-REF-CANDIDATE: planned|in_transit|arrived|completed|cancelled|delayed — promote to reference product if additional statuses are required]']
  leg_type varchar [note: 'The leg type of the shipment leg record']
  mode_of_transport varchar [note: 'The mode of transport of the shipment leg record']
  name varchar [note: 'The shipment leg name of the shipment leg record']
  notes varchar [note: 'The notes of the shipment leg record']
  origin_country_code varchar [note: 'ISO 3166-1 alpha-3 country code of the origin node for this leg (e.g., USA, DEU, GBR). Used for customs compliance, trade lane analysis, and carbon footprint reporting.']
  pallet_count varchar [note: 'Number of pallets included in this shipment leg. Used for dock scheduling, vehicle load planning, and carrier billing reconciliation in consumer goods distribution.']
  planned_arrival timestamp [note: 'The planned arrival of the shipment leg record']
  planned_arrival_timestamp timestamp [note: 'Scheduled date and time at which the shipment leg is expected to arrive at the destination node. Used for receiving planning, dock scheduling, and OTIF target setting.']
  planned_departure timestamp [note: 'The planned departure of the shipment leg record']
  planned_departure_timestamp timestamp [note: 'Scheduled date and time at which the shipment leg is planned to depart from the origin node. Used for transportation planning, carrier booking, and On Time In Full (OTIF) baseline measurement.']
  planned_transit_hours decimal(8,2) [note: 'Expected transit duration in hours for this leg as defined in the carrier contract or transportation plan. Used as the baseline for on-time performance measurement and SLA compliance.']
  proof_of_delivery_status varchar [note: 'Status of the Proof of Delivery (POD) document for this leg. Tracks whether POD has been received, is pending, or is under dispute. Required for freight audit, accounts payable, and customer dispute resolution.']
  proof_of_delivery_timestamp timestamp [note: 'Date and time when the Proof of Delivery (POD) was confirmed or received for this leg. Used for OTIF measurement, freight audit closure, and customer service resolution.']
  quantity decimal(18,4) [note: 'The quantity of the shipment leg record']
  shipment_leg_status varchar [note: 'The shipment leg status of the shipment leg record']
  source_system_code varchar [note: 'The source system code of the shipment leg record']
  temperature_max_celsius decimal(5,2) [note: 'Maximum allowable temperature in degrees Celsius for cold chain compliance during this leg. Applicable to temperature-sensitive consumer goods. Used for cold chain monitoring and regulatory compliance reporting.']
  temperature_min_celsius decimal(5,2) [note: 'Minimum allowable temperature in degrees Celsius for cold chain compliance during this leg. Applicable to temperature-sensitive consumer goods. Used for cold chain monitoring and regulatory compliance reporting.']
  transit_time_hours decimal(10,2) [note: 'The transit time hours of the shipment leg record']
  transport_mode varchar [note: 'Primary mode of transportation used for this leg (e.g., road, rail, air, ocean, intermodal, courier). Determines applicable freight rates, transit time benchmarks, and regulatory requirements. Aligns with GS1 and INCOTERMS classification.']
  transport_service_type varchar [note: 'Service level classification for this leg (e.g., Full Truckload (FTL), Less-than-Truckload (LTL), parcel, express, standard, bulk). Impacts freight cost calculation and carrier selection logic.']
  uom varchar [note: 'The uom of the shipment leg record']
  updated_timestamp timestamp [note: 'The updated timestamp of the shipment leg record']
  vehicle_code varchar [note: 'Identifier of the vehicle, vessel, aircraft, or rail car assigned to execute this leg (e.g., truck license plate, vessel IMO number, flight number, rail car ID). Used for asset tracking and carrier compliance.']
  volume_cbm decimal(12,3) [note: 'Total cargo volume in cubic meters (CBM) for this leg. Used for volumetric freight rate calculation, container utilization analysis, and load planning optimization.']

  Note: 'Individual movement segment within a multi-leg shipment. Captures leg sequence, origin and destination nodes, carrier for the leg, mode of transport, planned and actual departure/arrival timestamps, leg distance, leg freight cost, transshipment point flag, and leg status. Enables granular track-and-trace and cost allocation across intermodal movements.'
}

Table logistics.shipment_item {
  shipment_item_id varchar [pk, note: 'Unique surrogate identifier for each shipment line item record in the logistics data platform. Primary key for the shipment_item entity.']
  batch_record_id varchar [note: 'Foreign key linking to manufacturing.batch_record. Business justification: Lot traceability and recall management: consumer goods regulations (FDA, CPSC) require knowing exactly which manufactured batch is in each shipment item. Enables batch-level recall execution and cold-']
  certificate_of_analysis_id varchar [note: 'Foreign key linking to quality.certificate_of_analysis. Business justification: Each shipment item in consumer goods (food, personal care, pharma) must be accompanied by a CoA for customs clearance, retailer compliance, and cold-chain verification. Linking shipment_item to certif']
  distribution_facility_id varchar [note: 'Reference to the warehouse or distribution center from which this item was picked and dispatched. Used for inventory depletion tracking, warehouse performance analytics, and DRP (Distribution Requirements Planning).']
  dtc_order_line_id varchar [note: 'Foreign key linking to consumer.dtc_order_line. Business justification: Line-level DTC fulfillment traceability — which shipment item fulfills which DTC order line — is required for partial shipment analysis, line-level OTIF, and returns processing. Currently dtc_order_li']
  inbound_receipt_line_id varchar [note: 'Foreign key linking to distribution.inbound_receipt_line. Business justification: Inbound ASN-to-receipt reconciliation: consumer goods supplier compliance and freight audit processes match shipment items against receipt lines to identify discrepancies, short deliveries, and damage']
  inspection_lot_id varchar [note: 'Foreign key linking to quality.inspection_lot. Business justification: Required for lot traceability report linking inspected lots to shipped items, enabling recall and compliance verification.']
  label_spec_id varchar [note: 'Foreign key linking to product.label_spec. Business justification: Regulatory compliance and recall management: shipment_item must record which label_spec version was applied for the destination market. Consumer goods regulators require traceability of label versions']
  logistics_shipment_id varchar [note: 'Reference to the parent shipment header record. Establishes the header-to-line relationship for all items within a single shipment dispatch event. Aligns with SAP SD delivery document header.']
  outbound_order_line_id varchar [note: 'Foreign key linking to distribution.outbound_order_line. Business justification: Order-to-shipment reconciliation: consumer goods OTIF reporting and short-ship analysis require matching each shipment item to the originating outbound order line. Logistics analysts and DC managers u']
  po_line_id varchar [note: 'Foreign key linking to procurement.po_line. Business justification: Inbound shipment-to-PO-line matching: consumer goods receiving operations match each shipped item to a specific PO line for quantity variance detection, over/under delivery tolerance checks, and goods']
  purchase_order_id varchar [note: 'Foreign key linking to procurement.purchase_order. Business justification: Inbound shipment OTIF tracking and receiving reconciliation: each shipment item must be traced to its originating PO for quantity confirmation, OTIF compliance reporting, and supplier performance meas']
  return_order_id varchar [note: 'Foreign key linking to sales.return_order. Business justification: Return shipment items must reference the authorizing return order (RMA) for reverse logistics tracking, credit memo processing, and quality inspection routing. Consumer goods reverse logistics teams m']
  sales_order_id varchar [note: 'Foreign key linking to sales.order. Business justification: Shipment item is the line-level fulfillment entity mapped to a sales order for OTIF reporting, order fill-rate analysis, and shipment-to-order reconciliation. sales_order_number is a denormalized text']
  sku_id varchar [note: 'Foreign key linking to product.sku. Business justification: Required for shipping manifest and inventory reconciliation; each shipment line must reference the master SKU to enable traceability, OTIF reporting, and regulatory compliance.']
  amount decimal(18,4) [note: 'The amount of the shipment item record']
  batch_number varchar [note: 'The batch number of the shipment item record']
  code varchar [note: 'The shipment item code of the shipment item record']
  confirmed_quantity decimal(18,4) [note: 'Quantity confirmed as received by the consignee at the delivery destination, captured from proof of delivery (POD) or EDI 214 acknowledgment. Used for invoice reconciliation and OTIF final measurement.']
  country_of_origin varchar [note: 'ISO 3166-1 alpha-3 country code indicating where the product was manufactured or substantially transformed. Required for customs declarations, import duty determination, and trade compliance reporting.']
  created_timestamp timestamp [note: 'Timestamp when this shipment item record was first created in the data platform, in ISO 8601 format with timezone offset. Used for data lineage, audit trail, and SLA measurement.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code in which unit_cost and line_value are expressed. Enables multi-currency financial consolidation and FX reporting.']
  declared_value decimal(18,4) [note: 'The declared value of the shipment item record']
  delivery_document_number varchar [note: 'ERP delivery document number (e.g., SAP outbound delivery number) associated with this shipment line. Serves as the primary cross-reference between the logistics execution system and the financial/order management system.']
  description varchar [note: 'The shipment item description of the shipment item record']
  effective_from date [note: 'The effective from of the shipment item record']
  effective_until date [note: 'The effective until of the shipment item record']
  expiry_date date [note: 'Expiration date of the product lot being shipped, used to enforce FEFO (First Expired First Out) inventory rotation, ensure shelf-life compliance at retail, and prevent shipment of expired goods.']
  gross_weight_kg decimal(18,4) [note: 'Total gross weight of this shipment line item in kilograms, including product, inner packaging, and outer packaging. Used for freight cost calculation, carrier capacity planning, and customs declarations.']
  harmonized_tariff_code varchar [note: 'Harmonized System (HS) tariff classification code for the product, used for customs clearance, import duty calculation, and international trade compliance. Typically 6-10 digits per WCO HS nomenclature.']
  is_controlled_substance boolean [note: 'Indicates whether this item contains a controlled substance subject to DEA scheduling, FDA drug regulations, or equivalent international narcotics controls. Triggers enhanced chain-of-custody documentation requirements.']
  is_dsd boolean [note: 'Indicates whether this item is fulfilled via Direct Store Delivery (DSD) channel, bypassing the retailer\'s distribution center and delivering directly to the store. Impacts route planning, SFA integration, and trade promotion settlement.']
  is_hazmat boolean [note: 'Indicates whether this shipment item is classified as a hazardous material requiring special handling, labeling, and transport documentation per DOT, IATA, or IMDG regulations. Triggers mandatory SDS (Safety Data Sheet) attachment.']
  is_temperature_sensitive boolean [note: 'Indicates whether this item requires temperature-controlled handling and transport (cold chain). When true, temperature range requirements and cold-chain compliance monitoring are enforced throughout the shipment lifecycle.']
  item_description varchar [note: 'Human-readable description of the product being shipped, including product name, variant, and pack size. Used on shipping documents, proof of delivery, and freight audit records.']
  item_status varchar [note: 'Current lifecycle status of this shipment line item. Tracks progression from warehouse picking through delivery confirmation. [ENUM-REF-CANDIDATE: planned|picked|loaded|in_transit|delivered|short_shipped|cancelled — promote to reference product]']
  line_number varchar [note: 'Sequential line number of this item within the parent shipment, used for ordering and referencing individual line items. Corresponds to SAP SD delivery item position number.']
  line_value decimal(18,4) [note: 'Total declared value of this shipment line item (shipped_quantity × unit_cost), used for customs valuation, cargo insurance, and financial reporting. Expressed in the shipment currency.']
  lot_number varchar [note: 'The lot number of the shipment item record']
  manufacture_date date [note: 'Date on which the product lot was manufactured. Used in conjunction with expiry date to calculate remaining shelf life at time of shipment and validate minimum remaining shelf life (MRSL) requirements.']
  max_temperature_c decimal(6,2) [note: 'Maximum allowable temperature in degrees Celsius for storage and transport of this item. Applicable when is_temperature_sensitive is true. Exceedances trigger quality holds and non-conformance reporting.']
  min_temperature_c decimal(6,2) [note: 'Minimum allowable temperature in degrees Celsius for storage and transport of this item. Applicable when is_temperature_sensitive is true. Used to configure cold-chain monitoring alerts and carrier SLA requirements.']
  name varchar [note: 'The shipment item name of the shipment item record']
  net_weight_kg decimal(18,4) [note: 'Net weight of the product content only in kilograms, excluding all packaging materials. Required for regulatory labeling compliance, customs documentation, and COGS (Cost of Goods Sold) reporting.']
  notes varchar [note: 'The notes of the shipment item record']
  ordered_quantity decimal(18,4) [note: 'Quantity of this item originally ordered by the customer or requested in the purchase order. Used for OTIF (On Time In Full) calculation and order fulfillment rate reporting.']
  package_count varchar [note: 'The package count of the shipment item record']
  packaging_type varchar [note: 'Type of packaging unit in which the item is shipped. Determines handling requirements, stacking rules, and warehouse slotting. Aligns with GS1 packaging hierarchy levels.']
  quality_hold_flag boolean [note: 'Indicates whether this shipment line item has been placed on a quality hold due to a failed QC inspection, temperature exceedance, or regulatory non-conformance. Items on hold must not be delivered until released by QA.']
  quantity decimal(18,4) [note: 'The quantity of the shipment item record']
  quantity_uom varchar [note: 'The quantity uom of the shipment item record']
  regulatory_approval_number varchar [note: 'Product registration or regulatory approval number required for cross-border shipments of regulated consumer goods (e.g., FDA registration, EPA registration, EU REACH authorization). Stored for customs and import compliance documentation.']
  rejection_reason varchar [note: 'Reason code or description for any quantity rejected or short-shipped on this line item, such as OOS (Out of Stock), quality hold, weight discrepancy, or carrier refusal. Used for root cause analysis and OTIF exception reporting.']
  sales_order_line varchar [note: 'Line item number within the originating sales order corresponding to this shipment item. Used for precise order-to-shipment reconciliation and partial fulfillment tracking.']
  serial_number varchar [note: 'Unique serial number assigned to an individual product unit, applicable for serialized items requiring unit-level traceability (e.g., high-value consumer electronics, regulated health products). Null for non-serialized bulk items.']
  shipment_item_status varchar [note: 'The shipment item status of the shipment item record']
  shipped_quantity decimal(18,4) [note: 'Actual quantity of this item loaded and dispatched in the shipment. May differ from ordered quantity due to partial fulfillment, OOS (Out of Stock) conditions, or substitution. Core metric for OTIF compliance.']
  source_system_code varchar [note: 'The source system code of the shipment item record']
  sscc varchar [note: 'GS1 Serial Shipping Container Code (SSCC) — an 18-digit identifier assigned to the logistic unit (pallet, case) containing this item. Enables pallet-level traceability and EDI 856 ASN compliance with retail trading partners.']
  storage_location varchar [note: 'Specific storage location or bin within the warehouse from which this item was picked, as recorded in the WMS. Used for warehouse slotting optimization and pick path efficiency analysis.']
  unit_cost decimal(18,4) [note: 'Standard cost per unit of measure for this item at time of shipment, used for COGS (Cost of Goods Sold) calculation, inventory valuation, and freight cost allocation. Sourced from SAP S/4HANA CO standard cost.']
  unit_of_measure varchar [note: 'Unit of measure in which the shipped quantity is expressed. Common values include EA (each), CS (case), PL (pallet), KG (kilogram), LB (pound), L (litre), GAL (gallon). Aligns with GS1 UOM codes. [ENUM-REF-CANDIDATE: EA|CS|PL|KG|LB|L|GAL — 7 candidates stripped; promote to reference product]']
  uom varchar [note: 'The uom of the shipment item record']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to this shipment item record, in ISO 8601 format with timezone offset. Used for change data capture (CDC), incremental ETL processing, and audit trail maintenance.']
  volume_cbm decimal(18,4) [note: 'The volume cbm of the shipment item record']
  volume_m3 decimal(18,6) [note: 'Cubic volume of this shipment line item in cubic metres, used for truck load planning, container utilization optimization, and freight rate calculation based on dimensional weight.']
  weight_kg decimal(18,4) [note: 'The weight kg of the shipment item record']

  Note: 'Line-item detail of goods included in a shipment. Captures SKU/GTIN, product description, ordered quantity, shipped quantity, unit of measure, gross weight, net weight, volume, hazmat flag, temperature-sensitive flag, lot/batch number, expiry date (FEFO compliance), and packaging type. Enables item-level traceability and cold-chain compliance tracking.'
}

Table logistics.delivery {
  delivery_id varchar [pk, note: 'Unique surrogate identifier for each delivery execution record in the Silver layer lakehouse. Primary key for the delivery data product.']
  address_id varchar [note: 'Foreign key linking to consumer.address. Business justification: DTC address deliverability analytics and address validation reporting require linking delivery records to the canonical consumer address. Eliminates denormalized address fields on delivery; enables de']
  carrier_id varchar [note: 'The carrier id of the delivery record']
  final_shipment_leg_id varchar [note: 'Foreign key linking to logistics.shipment_leg. Business justification: A delivery is the execution result of the final shipment leg in a multi-leg movement. shipment_leg captures leg sequence, origin/destination, actual arrival/departure timestamps, and leg-level freight']
  freight_order_id varchar [note: 'Foreign key linking to logistics.freight_order. Business justification: A delivery record represents the execution outcome of a freight order — the freight_order is the transportation planning and tendering record that authorizes the physical movement, while delivery capt']
  invoice_id varchar [note: 'Foreign key linking to sales.invoice. Business justification: Delivery completion triggers invoice payment processing and AR reconciliation. Billing teams match confirmed deliveries to sales invoices for dispute resolution and DSO management. A consumer goods AR']
  origin_distribution_facility_id varchar [note: 'Foreign key linking to distribution.distribution_facility. Business justification: DC delivery performance KPIs: consumer goods supply chain teams track on-time delivery rates by originating distribution facility to identify DC-level execution issues. This link enables facility-leve']
  retail_store_id varchar [note: 'Foreign key linking to sales.retail_store. Business justification: In DSD (Direct Store Delivery) operations, deliveries are made to specific retail stores. Store-level OTIF tracking, planogram compliance verification, and route optimization all require knowing which']
  sales_order_id varchar [note: 'Foreign key linking to sales.order. Business justification: Delivery execution is tied to a specific sales order; the link supports delivery confirmation and invoicing workflows.']
  shopper_id varchar [note: 'Foreign key linking to consumer.shopper. Business justification: DTC last-mile personalization (delivery time preferences, access instructions) and consumer identity verification at doorstep require knowing the end shopper on the delivery record. Enables carrier-fa']
  trade_account_id varchar [note: 'Reference to the consignee (receiving party) account — typically a retail store, distribution center, or wholesale customer — to whom the goods are delivered.']
  actual_delivery_date date [note: 'The actual delivery date of the delivery record']
  actual_delivery_timestamp timestamp [note: 'The actual date and time the delivery was completed at the consignee location, as recorded by the driver via DSD handheld, e-POD app, or paper scan. Principal business event timestamp for OTIF calculation and dispute resolution.']
  actual_temperature_c decimal(5,2) [note: 'Actual temperature in degrees Celsius recorded during delivery, captured by IoT sensor or driver log. Used to verify cold-chain compliance and support FDA/EU GDP regulatory reporting for temperature-sensitive goods.']
  address varchar [note: 'The address of the delivery record']
  amount decimal(18,4) [note: 'The amount of the delivery record']
  carrier_tracking_number varchar [note: 'External tracking number assigned by the carrier for track-and-trace visibility. Enables real-time shipment monitoring and customer-facing delivery status updates.']
  code varchar [note: 'The delivery code of the delivery record']
  cold_chain_required boolean [note: 'Indicates whether this delivery requires temperature-controlled cold-chain logistics (True) — applicable for perishable food, pharmaceutical, or temperature-sensitive consumer goods. Drives vehicle assignment and compliance monitoring.']
  consignee_name varchar [note: 'Legal or trading name of the receiving party (store, warehouse, or customer) at the delivery destination. Used for POD (Proof of Delivery) documentation and dispute resolution.']
  created_timestamp timestamp [note: 'Timestamp when the delivery record was first created in the source system (SAP S/4HANA SD outbound delivery creation). Audit trail field for data lineage and SOX compliance.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the freight cost amount (e.g., USD, EUR, GBP). Required for multi-currency freight cost reporting and financial consolidation.']
  delivered_quantity decimal(18,4) [note: 'Actual quantity of goods physically delivered and accepted at the consignee location. Core metric for OTIF (On Time In Full) in-full measurement, fill rate KPI, and invoice reconciliation.']
  delivery_number varchar [note: 'Externally-known business identifier for the delivery, typically sourced from SAP S/4HANA SD outbound delivery document (e.g., 80XXXXXXXX). Used in EDI communications, carrier coordination, and customer-facing tracking.']
  delivery_status varchar [note: 'Current lifecycle status of the delivery execution. \'full\' = all ordered quantities delivered; \'partial\' = some quantities delivered; \'failed\' = delivery attempt unsuccessful; \'refused\' = consignee rejected delivery; \'pending\' = delivery not yet attempted. Core field for OTIF (On Time In Full) calculation.']
  delivery_type varchar [note: 'Classification of the delivery method. DSD (Direct Store Delivery) = manufacturer delivers directly to retail shelf; warehouse = delivery to distribution center; cross_dock = transit without storage; drop_ship = vendor ships directly to consignee; returns = reverse logistics delivery. [ENUM-REF-CANDIDATE: DSD|warehouse|cross_dock|drop_ship|returns — promote to reference product]']
  description varchar [note: 'The delivery description of the delivery record']
  effective_from date [note: 'The effective from of the delivery record']
  effective_until date [note: 'The effective until of the delivery record']
  electronic_signature_flag boolean [note: 'Indicates whether the POD (Proof of Delivery) signature was captured electronically (True) via e-POD app or DSD handheld, or obtained on paper (False). Determines evidentiary strength for dispute resolution.']
  exception_code varchar [note: 'Standardized exception code identifying the reason for delivery failure, partial delivery, or refusal (e.g., CONSIGNEE_CLOSED, ADDRESS_NOT_FOUND, CAPACITY_EXCEEDED, REFUSED_QUALITY). Sourced from carrier or DSD system exception taxonomy. [ENUM-REF-CANDIDATE: promote to reference product]']
  exception_notes varchar [note: 'Free-text notes describing delivery discrepancies, exceptions, or special circumstances recorded by the driver or dispatcher. Supplements the structured exception code for dispute resolution and root cause analysis.']
  first_attempt_timestamp timestamp [note: 'Date and time of the first delivery attempt at the consignee location. Relevant when the delivery required multiple attempts (e.g., failed first attempt followed by successful re-delivery). Supports carrier performance analytics.']
  freight_cost_amount decimal(18,2) [note: 'Total freight cost incurred for this delivery in the transaction currency. Used for freight audit, carrier invoice reconciliation, COGS (Cost of Goods Sold) allocation, and logistics cost-to-serve analytics.']
  goods_condition_code varchar [note: 'Condition of goods as assessed at point of delivery receipt. \'good\' = acceptable; \'damaged\' = physical damage observed; \'partial_damage\' = some units damaged; \'temperature_breach\' = cold-chain violation detected; \'contaminated\' = product integrity compromised. Triggers quality investigation and regulatory reporting. [ENUM-REF-CANDIDATE: good|damaged|partial_damage|temperature_breach|contaminated — promote to reference product]']
  in_full_flag boolean [note: 'Indicates whether the full ordered quantity was delivered (True). Component of the OTIF (On Time In Full) KPI, enabling separate on-time vs. in-full root cause analysis and fill rate reporting.']
  is_complete boolean [note: 'The is complete of the delivery record']
  is_in_full boolean [note: 'The is in full of the delivery record']
  is_on_time boolean [note: 'The is on time of the delivery record']
  name varchar [note: 'The delivery name of the delivery record']
  notes varchar [note: 'The notes of the delivery record']
  on_time_flag boolean [note: 'Indicates whether the delivery was completed on or before the scheduled delivery date/time (True). Component of the OTIF (On Time In Full) KPI, enabling separate on-time vs. in-full root cause analysis.']
  ordered_quantity decimal(18,4) [note: 'Total quantity of goods ordered for this delivery as per the originating sales order. Baseline for OTIF (On Time In Full) in-full calculation and delivery fill rate measurement.']
  otif_flag boolean [note: 'Indicates whether this delivery met the OTIF (On Time In Full) KPI criteria — True if delivered on or before the scheduled date AND at 100% of ordered quantity. Core retail compliance metric for major retailers (e.g., Walmart OTIF penalty program).']
  photo_attachment_reference varchar [note: 'Storage reference or URL to photo evidence captured at delivery (e.g., goods condition, placement, damaged packaging). Supports POD (Proof of Delivery) documentation and insurance claims.']
  planned_delivery_date date [note: 'The planned delivery date of the delivery record']
  pod_source varchar [note: 'System or method used to capture the POD (Proof of Delivery). DSD_handheld = Direct Store Delivery device; epod_app = electronic POD mobile application; paper_scan = digitized paper document; EDI = Electronic Data Interchange confirmation; manual = manually entered. Determines data quality and evidentiary weight.']
  quantity decimal(18,4) [note: 'The quantity of the delivery record']
  quantity_uom varchar [note: 'Unit of measure for ordered and delivered quantities (e.g., EA=each, CS=case, PAL=pallet, KG=kilogram). Aligns with GS1 unit of measure codes and SAP base unit of measure configuration. [ENUM-REF-CANDIDATE: EA|CS|PAL|KG|LB|L|GAL — 7 candidates stripped; promote to reference product]']
  recipient_name varchar [note: 'Full name of the individual who physically received and signed for the delivery at the consignee location. Core POD (Proof of Delivery) field for dispute resolution and legal evidence.']
  refused_quantity decimal(18,4) [note: 'Quantity of goods refused or rejected by the consignee at point of delivery. Triggers reverse logistics, credit memo processing, and quality investigation workflows.']
  rejection_quantity decimal(18,4) [note: 'The rejection quantity of the delivery record']
  rejection_reason varchar [note: 'The rejection reason of the delivery record']
  scheduled_delivery_date date [note: 'The planned calendar date on which the delivery was scheduled to arrive at the consignee location. Used as the baseline for OTIF (On Time In Full) on-time measurement and SLA compliance.']
  scheduled_delivery_timestamp timestamp [note: 'The precise planned date and time window start for delivery at the consignee location. Supports time-window compliance measurement and carrier SLA (Service Level Agreement) tracking.']
  signature_captured boolean [note: 'The signature captured of the delivery record']
  signature_reference varchar [note: 'Storage reference or URL pointing to the captured electronic or scanned signature image for this delivery. Used as legal evidence in POD (Proof of Delivery) dispute resolution.']
  source_system_code varchar [note: 'The source system code of the delivery record']
  sscc varchar [note: 'GS1 Serial Shipping Container Code (SSCC) — 18-digit identifier assigned to the shipping unit (pallet, case, or container) for this delivery. Enables end-to-end supply chain traceability per GS1 standards.']
  temperature_max_c decimal(5,2) [note: 'Maximum allowable temperature in degrees Celsius for cold-chain delivery compliance. Compared against actual recorded temperature to detect cold-chain breaches and trigger regulatory reporting.']
  temperature_min_c decimal(5,2) [note: 'Minimum allowable temperature in degrees Celsius for cold-chain delivery compliance. Compared against actual recorded temperature to detect cold-chain breaches and trigger regulatory reporting.']
  uom varchar [note: 'The uom of the delivery record']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to the delivery record in the source system. Supports incremental data loading, audit trails, and change detection in the Silver layer.']
  window_end timestamp [note: 'The window end of the delivery record']
  window_start timestamp [note: 'The window start of the delivery record']

  Note: 'Record of final delivery execution and proof of delivery (POD) at the consignee location. Captures delivery number, shipment reference, consignee account, delivery address, scheduled and actual delivery timestamps, delivered quantity, delivery status (full/partial/failed/refused), recipient name and signature, electronic signature flag, condition of goods at receipt, photo attachment references, discrepancy notes, POD source (DSD handheld, e-POD app, paper scan), driver/vehicle reference, and exception codes. SSOT for last-mile delivery outcomes, OTIF calculation, and dispute resolution evidence.'
}

Table logistics.proof_of_delivery {
  proof_of_delivery_id varchar [pk, note: 'Unique system-generated identifier for the proof of delivery record. Primary key for this entity.']
  carrier_id varchar [note: 'Reference to the carrier or 3PL responsible for executing the delivery. Used for freight audit, carrier performance tracking, and dispute resolution.']
  delivery_id varchar [note: 'Reference to the delivery order (SAP outbound delivery document) associated with this POD. Enables traceability from POD back to the originating delivery instruction.']
  dtc_order_id varchar [note: 'Foreign key linking to consumer.dtc_order. Business justification: DTC consumer dispute resolution and returns authorization requires direct POD-to-DTC-order linkage. Customer service teams need to pull POD evidence against a specific DTC order without traversing shi']
  invoice_id varchar [note: 'Foreign key linking to sales.invoice. Business justification: POD documents are primary evidence in invoice dispute resolution processes. When a customer disputes a sales invoice, the AR team retrieves the POD to confirm delivery. Consumer goods companies requir']
  logistics_shipment_id varchar [note: 'Reference to the parent shipment for which this proof of delivery was captured. Links POD to the outbound or inbound shipment record.']
  shopper_id varchar [note: 'Foreign key linking to consumer.shopper. Business justification: Age-restricted product delivery (alcohol, tobacco) requires identity verification at doorstep tied to the specific shopper record. POD must reference the shopper for regulatory compliance (age verific']
  trade_account_id varchar [note: 'Reference to the consignee (retail customer, distributor, or DC) who received the goods. Supports PARTY_REFERENCE requirement for TRANSACTION_HEADER role.']
  amount decimal(18,4) [note: 'The amount of the proof of delivery record']
  bill_of_lading_number varchar [note: 'The bill of lading number issued by the carrier for this shipment. Serves as the primary legal transport document reference and is used in freight audit, customs compliance, and dispute resolution.']
  captured_by varchar [note: 'The captured by of the proof of delivery record']
  captured_device varchar [note: 'The captured device of the proof of delivery record']
  carrier_scan_timestamp timestamp [note: 'Timestamp of the carrier\'s own barcode or RFID scan event at the point of delivery, as transmitted via EDI or carrier portal. May differ from receipt_timestamp if there is a lag between physical delivery and system capture.']
  code varchar [note: 'The proof of delivery code of the proof of delivery record']
  cold_chain_compliant_flag boolean [note: 'Indicates whether the delivery maintained required cold-chain temperature conditions throughout transit (True = compliant). Critical for temperature-sensitive consumer goods (e.g., dairy, frozen, pharmaceutical). Supports FDA and ISO 22716 compliance.']
  created_timestamp timestamp [note: 'Timestamp when this POD record was first created in the system, either by a DSD handheld, e-POD app, or paper scan ingestion process. Supports audit trail and data lineage.']
  currency_code varchar [note: 'The currency code of the proof of delivery record']
  customer_reference_number varchar [note: 'The consignee\'s own purchase order or reference number for this delivery. Enables cross-referencing between the supplier\'s POD and the customer\'s receiving records for EDI reconciliation and dispute resolution.']
  damage_description varchar [note: 'The damage description of the proof of delivery record']
  damage_noted boolean [note: 'The damage noted of the proof of delivery record']
  damage_notes varchar [note: 'The damage notes of the proof of delivery record']
  damage_reported boolean [note: 'The damage reported of the proof of delivery record']
  delivered_quantity decimal(18,4) [note: 'Actual quantity of goods confirmed as received by the consignee at the time of delivery. Used to calculate OTIF (On Time In Full) fill rate and identify quantity discrepancies against the ordered quantity.']
  delivery_condition varchar [note: 'The delivery condition of the proof of delivery record']
  delivery_location_gln varchar [note: 'GS1 Global Location Number (GLN) of the delivery destination. Provides a globally unique, standardized identifier for the consignee location, enabling interoperability with trading partners and EDI systems.']
  delivery_location_name varchar [note: 'Name of the physical delivery location (e.g., store name, distribution center name, warehouse name). Provides human-readable identification of the delivery destination for reporting and operations.']
  delivery_status varchar [note: 'Current lifecycle status of the delivery event. Drives freight audit workflows, OTIF (On Time In Full) reporting, and dispute resolution processes. [ENUM-REF-CANDIDATE: pending|delivered|partially_delivered|failed|disputed|cancelled — promote to reference product if additional statuses are required]']
  delivery_temperature_c decimal(5,2) [note: 'Recorded temperature in degrees Celsius at the point of delivery for temperature-sensitive goods. Used to verify cold-chain compliance and support FDA regulatory reporting for perishable or pharmaceutical consumer goods.']
  delivery_timestamp timestamp [note: 'The delivery timestamp of the proof of delivery record']
  description varchar [note: 'The proof of delivery description of the proof of delivery record']
  discrepancy_flag boolean [note: 'Indicates whether a discrepancy was identified at the time of delivery (True = discrepancy exists). Triggers downstream dispute resolution, freight audit, and claims workflows.']
  discrepancy_notes varchar [note: 'Free-text description of any discrepancy observed at delivery, such as quantity shortages, damaged packaging, wrong items, or temperature excursions. Used in dispute resolution and freight audit processes.']
  discrepancy_type varchar [note: 'Categorical classification of the type of discrepancy identified at delivery. Enables structured reporting and root cause analysis across the logistics network. [ENUM-REF-CANDIDATE: quantity_shortage|overage|damaged_goods|wrong_item|temperature_breach|missing_documentation — promote to reference product]']
  dispute_resolution_date date [note: 'The date on which a delivery dispute was formally resolved. Used to measure dispute resolution cycle time and SLA compliance for freight audit and carrier management.']
  dispute_status varchar [note: 'Current status of any freight or delivery dispute associated with this POD. Tracks the lifecycle of dispute resolution from identification through closure. Supports freight audit and carrier claims management.']
  dsd_route_stop_sequence varchar [note: 'The sequential stop number of this delivery within the DSD route. Used for route optimization analysis, driver performance measurement, and DSD compliance reporting in Salesforce Consumer Goods Cloud.']
  effective_from date [note: 'The effective from of the proof of delivery record']
  effective_until date [note: 'The effective until of the proof of delivery record']
  electronic_signature_flag boolean [note: 'Indicates whether the POD was captured via electronic signature (True) or via paper-based signature (False). Drives e-POD compliance reporting and DSD handheld audit workflows.']
  exception_flag boolean [note: 'The exception flag of the proof of delivery record']
  freight_bill_number varchar [note: 'The carrier-issued freight bill or bill of lading (BOL) number associated with this delivery. Used to match POD records to freight invoices during freight audit and payment processes.']
  geofence_validated_flag boolean [note: 'Indicates whether the GPS coordinates captured at delivery were within the expected geofence boundary of the consignee location (True = within geofence). Used to detect fraudulent or erroneous POD captures in DSD operations.']
  geolocation_latitude decimal(9,6) [note: 'GPS latitude coordinate captured at the time of delivery confirmation. Used for geofencing validation, proof of delivery location verification, and DSD compliance auditing.']
  geolocation_longitude decimal(9,6) [note: 'GPS longitude coordinate captured at the time of delivery confirmation. Used alongside latitude for geofencing validation, delivery location verification, and DSD compliance auditing.']
  goods_condition varchar [note: 'Condition of the goods as assessed at the point of delivery by the recipient. Drives claims processing, carrier liability assessment, and quality incident reporting. [ENUM-REF-CANDIDATE: intact|damaged|partial_damage|refused|short_delivered — promote to reference product if additional conditions are required]']
  gps_latitude decimal(10,7) [note: 'The gps latitude of the proof of delivery record']
  gps_longitude decimal(10,7) [note: 'The gps longitude of the proof of delivery record']
  name varchar [note: 'The proof of delivery name of the proof of delivery record']
  notes varchar [note: 'The notes of the proof of delivery record']
  ordered_quantity decimal(18,4) [note: 'The quantity of goods that was originally ordered and expected to be delivered. Compared against delivered_quantity to compute fill rate and identify shortages or overages for OTIF reporting.']
  otif_flag boolean [note: 'Indicates whether this delivery met the OTIF (On Time In Full) criteria — delivered on or before the scheduled date and at the full ordered quantity (True = OTIF achieved). Core KPI for supply chain performance reporting.']
  photo_attachment_count varchar [note: 'Number of photo attachments captured and associated with this POD record. Indicates the volume of photographic evidence available for dispute resolution and claims processing.']
  photo_attachment_urls varchar [note: 'Comma-separated list of URL or file path references to photo images captured at delivery (e.g., photos of damaged goods, delivery location, pallet condition). Stored in secure document repository and referenced for dispute resolution.']
  photo_reference varchar [note: 'The photo reference of the proof of delivery record']
  pod_confirmation_method varchar [note: 'The method used to confirm delivery receipt (e.g., signature, PIN code, photo-only, verbal confirmation, unattended drop). Supports compliance with carrier SLA requirements and DSD operational standards.']
  pod_image_reference varchar [note: 'The pod image reference of the proof of delivery record']
  pod_number varchar [note: 'Externally-known business reference number for this POD document. Used in freight audit, dispute resolution, and EDI acknowledgement exchanges with carriers and customers.']
  pod_reference varchar [note: 'The pod reference of the proof of delivery record']
  pod_source varchar [note: 'The channel or method through which the POD was captured. Distinguishes between DSD (Direct Store Delivery) handheld devices, e-POD mobile applications, scanned paper documents, EDI transmissions, or carrier portal uploads. Critical for DSD compliance and data quality assessment.']
  pod_status varchar [note: 'The pod status of the proof of delivery record']
  pod_type varchar [note: 'The pod type of the proof of delivery record']
  proof_of_delivery_status varchar [note: 'The proof of delivery status of the proof of delivery record']
  quantity decimal(18,4) [note: 'The quantity of the proof of delivery record']
  quantity_uom varchar [note: 'Unit of measure for the delivered and ordered quantities (e.g., EA = Each, CS = Case, PAL = Pallet, KG = Kilogram). Ensures consistent quantity comparison across SKUs and delivery types. [ENUM-REF-CANDIDATE: EA|CS|PAL|KG|LB|L|GAL — 7 candidates stripped; promote to reference product]']
  receipt_timestamp timestamp [note: 'The exact date and time at which the consignee acknowledged receipt of the goods. This is the principal business event timestamp for the POD and is the authoritative time used for OTIF measurement and freight audit.']
  received_quantity decimal(18,4) [note: 'The received quantity of the proof of delivery record']
  recipient_name varchar [note: 'Full name of the individual at the consignee location who physically received and signed for the goods. Required for legal proof of delivery and dispute resolution.']
  recipient_signature_ref varchar [note: 'The recipient signature ref of the proof of delivery record']
  recipient_title varchar [note: 'Job title or role of the individual who received the goods (e.g., Receiving Manager, Store Associate, Warehouse Clerk). Provides context for authorization level of the signatory.']
  scheduled_delivery_date date [note: 'The planned delivery date as agreed in the delivery order or carrier SLA. Used to calculate on-time performance against the OTIF (On Time In Full) KPI.']
  signature_image_url varchar [note: 'URL or file path reference to the stored digital image of the recipient\'s signature. Used as legal evidence in freight disputes and customer claims. Stored in secure document repository.']
  signature_timestamp timestamp [note: 'The signature timestamp of the proof of delivery record']
  signed_by varchar [note: 'The signed by of the proof of delivery record']
  source_system_code varchar [note: 'The source system code of the proof of delivery record']
  uom varchar [note: 'The uom of the proof of delivery record']
  updated_timestamp timestamp [note: 'Timestamp of the most recent modification to this POD record, such as status updates, discrepancy note additions, or signature capture. Supports audit trail and dispute resolution.']
  vehicle_code varchar [note: 'Identifier of the vehicle or transport unit used for the delivery (e.g., truck registration number, fleet asset ID). Used for route optimization analysis, cold-chain compliance, and carrier audit.']

  Note: 'Formal POD record capturing evidence of successful goods receipt at the consignee. Captures delivery reference, recipient name and signature, timestamp of receipt, condition of goods at delivery (intact/damaged), photo attachment references, electronic signature flag, discrepancy notes, and POD source (DSD handheld, e-POD app, paper scan). Critical for dispute resolution, freight audit, and DSD compliance.'
}

Table logistics.freight_order {
  freight_order_id varchar [pk, note: 'Unique surrogate identifier for the freight order record in the lakehouse silver layer. Primary key for this entity.']
  batch_record_id varchar [note: 'Foreign key linking to manufacturing.batch_record. Business justification: Outbound finished-goods freight planning: in consumer goods, a freight order for factory pickup must reference the specific batch/lot being collected for GMP compliance, cold-chain documentation, and ']
  carrier_contract_id varchar [note: 'Reference to the carrier rate agreement or contract under which this freight order is priced. Null for spot-tendered orders without a pre-negotiated contract.']
  carrier_id varchar [note: 'Reference to the carrier (trucking company, parcel carrier, or 3PL) assigned to execute this freight order. Links to the carrier master.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Assigns internal cost center to freight orders for budgeting and chargeback of transportation expenses.']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Freight orders require GL account assignment for freight cost accruals posted before invoice receipt. In consumer goods, month-end accrual accounting requires freight orders to reference the GL accoun']
  lane_id varchar [note: 'The lane id of the freight order record']
  origin_distribution_facility_id varchar [note: 'Foreign key linking to distribution.distribution_facility. Business justification: Freight cost allocation by DC: consumer goods finance and logistics teams allocate freight spend to originating distribution facilities. freight_order.origin_location_code is denormalized text; a prop']
  primary_freight_network_node_id varchar [note: 'Reference to the delivery/destination location (retailer DC, customer warehouse, store, or end-consumer address) to which the freight order is directed.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Freight orders must be attributed to profit centers for logistics cost P&L reporting by brand or channel. freight_order already has cost_center_id but lacks profit_center_id. In consumer goods, freigh']
  sales_order_id varchar [note: 'Foreign key linking to sales.order. Business justification: Freight order creation is driven by a sales order; linking enables transport planning and order‑to‑shipment reporting.']
  trade_account_id varchar [note: 'Reference to the internal business unit or facility acting as the shipper/consignor for this freight order.']
  accessorial_charges_amount decimal(18,4) [note: 'Total accessorial charges (e.g., liftgate, detention, residential delivery, inside delivery, hazmat handling) applied to this freight order beyond the base rate and fuel surcharge.']
  actual_cost_amount decimal(18,4) [note: 'The actual cost amount of the freight order record']
  actual_delivery_timestamp timestamp [note: 'The actual date and time the carrier completed delivery at the destination location. Core field for OTIF (On Time In Full) measurement, carrier scorecard, and proof-of-delivery reconciliation.']
  actual_pickup_timestamp timestamp [note: 'The actual date and time the carrier picked up the freight at the origin location. Compared against the pickup window to determine on-time pickup performance for OTIF reporting.']
  agreed_freight_rate decimal(18,4) [note: 'The negotiated or spot-quoted rate agreed with the carrier for executing this freight order, expressed in the transaction currency. Used for freight cost accrual, freight audit, and carrier rate benchmarking.']
  amount decimal(18,4) [note: 'The amount of the freight order record']
  bill_of_lading_number varchar [note: 'Bill of Lading (BOL) number serving as the legal contract of carriage between the shipper and carrier. Required for freight claims, customs clearance, and proof-of-delivery documentation.']
  carrier_invoice_number varchar [note: 'Invoice number issued by the carrier for this freight order. Used for freight audit and payment matching in accounts payable. Populated upon receipt of carrier invoice.']
  code varchar [note: 'The freight order code of the freight order record']
  created_timestamp timestamp [note: 'Timestamp when this freight order record was first created in the source TMS system. Used for audit trail, data lineage, and SLA measurement from order creation to carrier acceptance.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for the agreed freight rate and all monetary amounts on this freight order (e.g., USD, EUR, GBP).']
  delivery_window_end timestamp [note: 'End of the agreed delivery time window at the destination location. Defines the latest acceptable delivery time per retailer or customer SLA.']
  delivery_window_start timestamp [note: 'Start of the agreed delivery time window at the destination location. Defines the earliest acceptable delivery time per retailer or customer SLA.']
  description varchar [note: 'The freight order description of the freight order record']
  destination_location varchar [note: 'The destination location of the freight order record']
  destination_location_code varchar [note: 'The destination location code of the freight order record']
  direction varchar [note: 'Indicates the direction of the freight movement relative to the company\'s network: inbound (from supplier to plant/DC), outbound (from plant/DC to customer/retailer), or interplant (between internal facilities).']
  effective_from date [note: 'The effective from of the freight order record']
  effective_until date [note: 'The effective until of the freight order record']
  equipment_type varchar [note: 'Type of transportation equipment required for this freight order (e.g., dry van, refrigerated/reefer, flatbed, tanker, intermodal container). Critical for cold-chain compliance for temperature-sensitive consumer goods. [ENUM-REF-CANDIDATE: dry_van|reefer|flatbed|tanker|intermodal|curtainsider|box_truck — promote to reference product]']
  estimated_cost_amount decimal(18,4) [note: 'The estimated cost amount of the freight order record']
  freight_audit_status varchar [note: 'Status of the freight invoice audit process for this freight order. Tracks whether the carrier invoice has been received, validated against the agreed rate, approved for payment, or disputed due to discrepancies.']
  freight_order_number varchar [note: 'Externally-visible, human-readable business identifier for the freight order as issued by the Transportation Management System (TMS). Used in carrier communications, EDI transactions, and proof-of-delivery documents.']
  freight_order_status varchar [note: 'The freight order status of the freight order record']
  fuel_surcharge_amount decimal(18,4) [note: 'Fuel surcharge applied to this freight order by the carrier, expressed in the transaction currency. Fuel surcharges are typically indexed to DOE diesel fuel price indices and are a standard component of carrier invoicing.']
  gross_weight_kg decimal(12,3) [note: 'Total gross weight of the shipment in kilograms, including product, packaging, and pallet weight. Used for carrier rate calculation, weight-based freight billing, and regulatory compliance for road transport weight limits.']
  incoterms varchar [note: 'The incoterms of the freight order record']
  incoterms_code varchar [note: 'International Commercial Terms (Incoterms) code defining the transfer of risk, cost responsibility, and delivery obligations between buyer and seller for this freight order. Governs freight cost ownership and insurance responsibility. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]']
  is_cold_chain boolean [note: 'Indicates whether this freight order requires temperature-controlled cold-chain transportation (e.g., refrigerated or frozen consumer goods). Triggers reefer equipment assignment and temperature monitoring requirements.']
  is_hazmat boolean [note: 'Indicates whether this freight order contains hazardous materials (hazmat) requiring special handling, placarding, and regulatory documentation per DOT 49 CFR and IATA/IMDG regulations.']
  last_updated_timestamp timestamp [note: 'Timestamp when this freight order record was last modified in the source TMS system. Used for incremental data loading, change detection, and audit trail in the lakehouse silver layer.']
  load_type varchar [note: 'Classification of the shipment load mode. FTL (Full Truckload) indicates the carrier\'s entire trailer is dedicated to this shipment; LTL (Less-than-Truckload) indicates shared trailer space; parcel indicates small-package carrier service; intermodal indicates multi-modal container movement; rail indicates rail freight.']
  mode_of_transport varchar [note: 'The mode of transport of the freight order record']
  name varchar [note: 'The freight order name of the freight order record']
  notes varchar [note: 'The notes of the freight order record']
  order_status varchar [note: 'Current lifecycle state of the freight order. Tracks progression from tendering to carrier through acceptance, in-transit movement, and final delivery or cancellation. [ENUM-REF-CANDIDATE: tendered|accepted|rejected|in_transit|delivered|cancelled — promote to reference product]']
  order_type varchar [note: 'The order type of the freight order record']
  pallet_count varchar [note: 'Number of pallets included in this freight order. Used for dock scheduling, trailer space planning, and carrier rate calculation for pallet-based pricing agreements.']
  pickup_window_end timestamp [note: 'End of the agreed pickup time window at the origin location. Defines the latest time the carrier may arrive for loading without incurring a late pickup penalty.']
  pickup_window_start timestamp [note: 'Start of the agreed pickup time window at the origin location. Defines the earliest time the carrier may arrive for loading. Used for dock scheduling and carrier compliance measurement.']
  pod_received boolean [note: 'Indicates whether a signed Proof of Delivery (POD) document has been received and recorded for this freight order. Required for freight payment release, dispute resolution, and retailer compliance.']
  pod_timestamp timestamp [note: 'Date and time the Proof of Delivery (POD) was received and confirmed. Used for delivery confirmation, OTIF (On Time In Full) final measurement, and freight payment processing.']
  priority_level varchar [note: 'The priority level of the freight order record']
  pro_number varchar [note: 'Carrier-assigned Progressive (PRO) number used as the primary tracking identifier for LTL (Less-than-Truckload) shipments. Issued by the carrier upon freight pickup and used for track-and-trace and freight claims.']
  quantity decimal(18,4) [note: 'The quantity of the freight order record']
  requested_delivery_date date [note: 'The date on which the shipper requests delivery at the destination location. Core input for OTIF (On Time In Full) performance measurement and retailer compliance scoring.']
  requested_pickup_date date [note: 'The date on which the shipper requests the carrier to pick up the freight at the origin location. Used for OTIF (On Time In Full) measurement and carrier performance tracking.']
  service_level varchar [note: 'Contracted service level for this freight order defining the expected transit time commitment (e.g., standard ground, expedited 2-day, overnight, same-day). Drives carrier selection and freight cost.']
  shipment_reference_number varchar [note: 'External reference number used by the carrier or 3PL to identify this shipment in their system. Enables cross-system track-and-trace and carrier invoice reconciliation via EDI (Electronic Data Interchange).']
  source_system_code varchar [note: 'The source system code of the freight order record']
  temperature_max_c decimal(5,2) [note: 'Maximum allowable temperature in degrees Celsius for cold-chain shipments. Applicable when is_cold_chain is True. Exceedance triggers a quality hold and potential product rejection per GMP (Good Manufacturing Practice) standards.']
  temperature_min_c decimal(5,2) [note: 'Minimum allowable temperature in degrees Celsius for cold-chain shipments. Applicable when is_cold_chain is True. Used for carrier compliance verification and cold-chain excursion detection.']
  tender_date timestamp [note: 'The tender date of the freight order record']
  tender_status varchar [note: 'The tender status of the freight order record']
  tendering_method varchar [note: 'Method used to tender the freight order to a carrier. Contract indicates a pre-negotiated rate agreement; spot indicates a one-time market rate; load_board indicates posting to a freight exchange; dedicated indicates a committed fleet arrangement; auction indicates a competitive bidding process.']
  tms_source_system varchar [note: 'Identifies the source Transportation Management System (TMS) from which this freight order record was ingested into the lakehouse. Supports data lineage, reconciliation, and multi-system integration auditing.']
  total_cost decimal(18,2) [note: 'The total cost of the freight order record']
  total_freight_cost decimal(18,4) [note: 'Total cost of this freight order including base rate, fuel surcharge, and all accessorial charges. Used for COGS (Cost of Goods Sold) allocation, freight budget vs. actuals reporting, and carrier invoice audit.']
  total_volume_m3 decimal(18,4) [note: 'The total volume m3 of the freight order record']
  total_weight_kg decimal(18,4) [note: 'The total weight kg of the freight order record']
  transport_mode varchar [note: 'Primary mode of transportation for this freight order. Drives regulatory requirements, transit time expectations, and carbon emissions calculation for sustainability reporting.']
  uom varchar [note: 'The uom of the freight order record']
  updated_timestamp timestamp [note: 'The updated timestamp of the freight order record']
  volume_m3 decimal(12,4) [note: 'Total cubic volume of the shipment in cubic meters. Used for LTL (Less-than-Truckload) dimensional weight calculation, trailer utilization analysis, and freight cost optimization.']

  Note: 'Transportation planning and tendering record issued to a carrier for a specific shipment movement. Captures freight order number, tendering method (spot/contract/load board), carrier assignment, load type (FTL/LTL/parcel), pickup and delivery locations, requested pickup window, freight order status (tendered/accepted/rejected/in-transit/delivered), agreed rate, and equipment type required. Sourced from SAP TM / Blue Yonder TMS.'
}

Table logistics.freight_invoice {
  freight_invoice_id varchar [pk, note: 'Unique surrogate identifier for the freight invoice record in the Consumer Goods lakehouse silver layer. Primary key for this entity.']
  ap_invoice_id varchar [note: 'Foreign key linking to finance.ap_invoice. Business justification: Freight invoices from carriers are processed through Accounts Payable. In consumer goods, freight audit and payment reconciliation requires linking the carrier\'s freight invoice to the corresponding A']
  carrier_contract_id varchar [note: 'Reference to the carrier rate contract against which this invoice is audited. Used in freight audit and pay (FAP) to validate invoiced charges against contracted rates.']
  carrier_id varchar [note: 'Reference to the carrier (transportation service provider) who issued this freight invoice. Links to the carrier master record.']
  cost_center_id varchar [note: 'Foreign key linking to finance.cost_center. Business justification: Needed to allocate freight invoice expense to the appropriate cost center for internal cost tracking and budgeting.']
  freight_order_id varchar [note: 'The freight order id of the freight invoice record']
  gl_account_id varchar [note: 'Foreign key linking to finance.gl_account. Business justification: Required for posting freight invoices to the general ledger; finance GL accounts are used for financial reporting of freight costs.']
  journal_entry_id varchar [note: 'Foreign key linking to finance.journal_entry. Business justification: Freight invoice posting generates a journal entry for freight cost accounting. In consumer goods, the GL posting of freight costs must be traceable to the originating freight invoice for audit complia']
  logistics_shipment_id varchar [note: 'Reference to the shipment record associated with this freight invoice. Enables reconciliation between transportation execution and billing.']
  profit_center_id varchar [note: 'Foreign key linking to finance.profit_center. Business justification: Allows assignment of freight invoice expense to profit center for profitability analysis of logistics services.']
  purchase_order_id varchar [note: 'Foreign key linking to procurement.purchase_order. Business justification: Freight invoice 3-way match process: AP teams reconcile freight invoices against the originating PO for inbound freight cost allocation and accrual. Consumer goods finance requires PO-level freight co']
  accessorial_amount decimal(18,4) [note: 'Total amount of accessorial charges on the invoice, including but not limited to liftgate, residential delivery, inside delivery, detention, redelivery, and hazmat fees. Audited against contracted accessorial schedules.']
  amount decimal(18,4) [note: 'The amount of the freight invoice record']
  approved_amount decimal(18,4) [note: 'Amount approved for payment to the carrier after freight audit review and any adjustments. May differ from invoiced total if disputes or corrections were applied. This is the amount that flows to accounts payable for payment.']
  audit_completed_timestamp timestamp [note: 'Date and time the freight audit review was completed for this invoice. Marks the transition from \'under_audit\' to \'approved\' or \'disputed\' status in the freight audit and pay (FAP) workflow.']
  audit_status varchar [note: 'The audit status of the freight invoice record']
  base_freight_amount decimal(18,4) [note: 'The base freight amount of the freight invoice record']
  bol_number varchar [note: 'Bill of Lading number issued by the carrier for the associated shipment. Key cross-reference document linking the freight invoice to the physical shipment and proof of delivery.']
  code varchar [note: 'The freight invoice code of the freight invoice record']
  contracted_amount decimal(18,4) [note: 'Expected freight charge calculated from the applicable carrier contract rate for this lane, mode, and service level. Used as the benchmark in freight audit to identify billing variances.']
  created_timestamp timestamp [note: 'Timestamp when the freight invoice record was first created in the Consumer Goods data platform. Supports audit trail, data lineage, and SLA tracking for invoice processing.']
  currency_code varchar [note: 'ISO 4217 three-letter currency code for all monetary amounts on this freight invoice (e.g., USD, EUR, GBP). Required for multi-currency freight operations and financial consolidation.']
  description varchar [note: 'The freight invoice description of the freight invoice record']
  destination_country_code varchar [note: 'ISO 3166-1 alpha-3 country code for the shipment destination. Required for cross-border freight, customs compliance, and international freight cost reporting.']
  destination_location_code varchar [note: 'Code identifying the shipment destination facility (customer DC, retail store, or consumer address) to which the freight was delivered. Used for lane-level freight cost analysis.']
  dispute_flag boolean [note: 'The dispute flag of the freight invoice record']
  dispute_notes varchar [note: 'Free-text notes describing the reason for disputing the freight invoice, including specific discrepancies identified during freight audit. Supports carrier communication and dispute resolution.']
  dispute_reason_code varchar [note: 'Standardized code indicating the reason for disputing the freight invoice (e.g., rate discrepancy, duplicate invoice, service failure, unauthorized accessorial). Populated when invoice_status is \'disputed\'. [ENUM-REF-CANDIDATE: rate_discrepancy|duplicate_invoice|service_failure|unauthorized_accessorial|weight_discrepancy|missing_bol — promote to reference product]']
  due_date date [note: 'The due date of the freight invoice record']
  edi_transaction_code varchar [note: 'EDI (Electronic Data Interchange) transaction set identifier for invoices received electronically via EDI 210 (Motor Carrier Freight Invoice) or equivalent. Enables traceability of electronic invoice transmission.']
  effective_from date [note: 'The effective from of the freight invoice record']
  effective_until date [note: 'The effective until of the freight invoice record']
  freight_class varchar [note: 'National Motor Freight Classification (NMFC) freight class assigned to the shipment (e.g., 50, 70, 100, 150). Determines LTL (Less-Than-Truckload) base rates and is a key audit point for freight invoice validation.']
  freight_invoice_status varchar [note: 'The freight invoice status of the freight invoice record']
  fuel_surcharge_amount decimal(18,4) [note: 'Carrier-applied fuel surcharge amount added to the base line-haul charge. Typically calculated as a percentage of line-haul based on the DOE (Department of Energy) fuel index. Key component for freight cost variance analysis.']
  invoice_currency_code varchar [note: 'The invoice currency code of the freight invoice record']
  invoice_date date [note: 'Date the carrier issued the freight invoice. Used to calculate payment due date, aging, and Days Sales Outstanding (DSO) metrics in freight payables.']
  invoice_number varchar [note: 'Carrier-assigned invoice number as printed on the freight invoice document. Externally known identifier used for carrier communication, dispute resolution, and payment remittance.']
  invoice_source varchar [note: 'Channel through which the freight invoice was received by Consumer Goods. Used to track EDI adoption rates and identify manual processing inefficiencies.']
  invoice_status varchar [note: 'Current workflow status of the freight invoice within the freight audit and pay (FAP) process. Drives processing actions and reporting.']
  invoice_type varchar [note: 'Classification of the freight invoice by document type. Distinguishes standard carrier invoices from credit memos, debit memos, rebills, and adjustments for accurate financial processing.']
  invoiced_amount decimal(18,2) [note: 'The invoiced amount of the freight invoice record']
  invoiced_total_amount decimal(18,4) [note: 'Total gross amount invoiced by the carrier, inclusive of line-haul, fuel surcharge, accessorials, and taxes. This is the amount the carrier is requesting for payment before audit adjustments.']
  is_cold_chain boolean [note: 'Indicates whether this freight invoice covers a temperature-controlled (cold chain) shipment requiring refrigerated or frozen transport. Relevant for Consumer Goods products with cold-chain compliance requirements.']
  is_hazmat boolean [note: 'Indicates whether the shipment covered by this invoice contains hazardous materials requiring special handling, labeling, and regulatory compliance. Triggers validation of hazmat accessorial charges.']
  last_updated_timestamp timestamp [note: 'The last updated timestamp of the freight invoice record']
  line_haul_amount decimal(18,4) [note: 'Base transportation charge for moving freight from origin to destination, excluding surcharges and accessorials. Core component of the freight invoice monetary triplet.']
  name varchar [note: 'The freight invoice name of the freight invoice record']
  notes varchar [note: 'The notes of the freight invoice record']
  origin_country_code varchar [note: 'ISO 3166-1 alpha-3 country code for the shipment origin. Required for cross-border freight, customs compliance, and international freight cost reporting.']
  origin_location_code varchar [note: 'Code identifying the shipment origin facility (plant, warehouse, or distribution center) from which the freight movement originated. Used for lane-level freight cost analysis and carrier performance reporting.']
  paid_date date [note: 'Date the payment was issued to the carrier for this freight invoice. Used to calculate Days Sales Outstanding (DSO), confirm on-time payment, and support carrier relationship management.']
  payment_date date [note: 'The payment date of the freight invoice record']
  payment_due_date date [note: 'Date by which payment must be made to the carrier per the contracted payment terms. Critical for cash flow management and avoiding late payment penalties.']
  payment_reference varchar [note: 'Internal payment document or check/ACH reference number assigned when the invoice was paid. Used to reconcile freight invoices against bank statements and carrier remittance advice.']
  payment_status varchar [note: 'The payment status of the freight invoice record']
  payment_terms varchar [note: 'The payment terms of the freight invoice record']
  payment_terms_code varchar [note: 'Code representing the payment terms agreed with the carrier (e.g., Net30, Net45, 2/10Net30). Determines the payment due date and any early payment discount eligibility.']
  pro_number varchar [note: 'Carrier-assigned Progressive (PRO) number used to track the shipment within the carrier\'s system. Standard identifier in LTL and TL freight for track-and-trace and invoice matching.']
  quantity decimal(18,4) [note: 'The quantity of the freight invoice record']
  received_timestamp timestamp [note: 'Date and time the freight invoice was received by Consumer Goods from the carrier, either via EDI (Electronic Data Interchange), email, or carrier portal. Marks the start of the freight audit and pay (FAP) cycle.']
  service_date date [note: 'Date the transportation service was rendered (pickup or delivery date). Used to match the invoice to the correct accounting period and validate service delivery.']
  service_level varchar [note: 'Carrier service level or product code for the transportation service rendered (e.g., standard ground, expedited, next-day, two-day). Used to validate that the invoiced service matches the contracted service level agreement (SLA).']
  shipment_weight_kg decimal(10,3) [note: 'Actual or billed shipment weight in kilograms as stated on the freight invoice. Used to validate weight-based freight charges against contracted rates and detect weight discrepancies.']
  source_system_code varchar [note: 'The source system code of the freight invoice record']
  tax_amount decimal(18,4) [note: 'Total tax amount applied to the freight invoice, including applicable federal, state, and local taxes on transportation services. Required for accurate financial reporting and tax compliance.']
  total_amount decimal(18,4) [note: 'The total amount of the freight invoice record']
  transport_mode varchar [note: 'Mode of transportation used for the shipment covered by this invoice. [ENUM-REF-CANDIDATE: TL|LTL|parcel|intermodal|air|ocean|rail — promote to reference product]']
  uom varchar [note: 'The uom of the freight invoice record']
  updated_timestamp timestamp [note: 'Timestamp when the freight invoice record was last modified in the Consumer Goods data platform. Used for change tracking, incremental data loads, and audit compliance.']
  variance_amount decimal(18,4) [note: 'Monetary difference between the invoiced total amount and the contracted rate amount (invoiced_total_amount minus contracted_amount). Positive value indicates overbilling by carrier; negative indicates underbilling. Central metric in the freight audit and pay (FAP) process.']

  Note: 'Carrier-issued freight invoice submitted to Consumer Goods for transportation services rendered. Captures invoice number, carrier reference, invoice date, payment due date, shipment/BOL references, invoiced charges (line-haul, fuel surcharge, accessorials), currency, invoice status (received/under-audit/approved/disputed/paid), and variance amount vs. contracted rate. Central to freight audit and pay (FAP) process.'
}

Table logistics.carrier_performance {
  carrier_performance_id varchar [pk, note: 'Unique surrogate identifier for each carrier performance scorecard record in the Silver Layer lakehouse.']
  carrier_contract_id varchar [note: 'Foreign key linking to logistics.carrier_contract. Business justification: A carrier performance scorecard is measured against the terms of a specific carrier contract — the contract defines OTIF thresholds (otif_threshold_pct), penalty rates (otif_penalty_rate), and service']
  carrier_id varchar [note: 'Reference to the carrier master record for which this performance scorecard is being measured.']
  distribution_facility_id varchar [note: 'Foreign key linking to distribution.distribution_facility. Business justification: Facility-level carrier scorecarding: in consumer goods, carrier OTIF and damage rates vary significantly by originating DC. Logistics and DC managers require carrier performance scorecards scoped to s']
  lane_id varchar [note: 'The lane id of the carrier performance record']
  amount decimal(18,4) [note: 'The amount of the carrier performance record']
  average_cost_per_shipment decimal(18,2) [note: 'The average cost per shipment of the carrier performance record']
  avg_transit_days decimal(5,2) [note: 'Average number of calendar days from actual pickup to actual delivery across all shipments in the measurement period. Compared against standard transit days to assess transit time performance.']
  carrier_contact_name varchar [note: 'Name of the carrier\'s primary account representative or performance manager who receives and acknowledges this scorecard.']
  carrier_performance_status varchar [note: 'The carrier performance status of the carrier performance record']
  claim_count varchar [note: 'The claim count of the carrier performance record']
  claim_rate_pct decimal(7,4) [note: 'The claim rate pct of the carrier performance record']
  claims_currency_code varchar [note: 'ISO 4217 three-letter currency code for the total_claims_amount field (e.g., USD, EUR, GBP).']
  claims_rate_pct decimal(5,2) [note: 'Percentage of shipments resulting in a freight claim (loss, damage, or shortage) during the measurement period. Key indicator of cargo handling quality.']
  code varchar [note: 'The carrier performance code of the carrier performance record']
  composite_score decimal(5,2) [note: 'Weighted composite score (0–100) summarizing the carrier\'s overall performance across all measured KPIs for the period. Drives performance tier assignment and contract renewal decisions.']
  cost_per_shipment decimal(18,4) [note: 'The cost per shipment of the carrier performance record']
  created_timestamp timestamp [note: 'Timestamp when this carrier performance scorecard record was first created in the Silver Layer lakehouse. Supports audit trail and data lineage tracking.']
  currency_code varchar [note: 'The currency code of the carrier performance record']
  damage_rate_pct decimal(5,2) [note: 'Percentage of shipments with reported product damage upon delivery during the measurement period. Distinct from claims rate as it isolates physical damage from loss/shortage events.']
  data_source_system varchar [note: 'Operational system of record from which the KPI data for this scorecard was sourced (e.g., SAP TM, Blue Yonder WMS, TradeEdge). Supports data lineage and audit traceability in the Silver Layer.']
  description varchar [note: 'The carrier performance description of the carrier performance record']
  dispute_flag boolean [note: 'Indicates whether the carrier has formally disputed the KPI results in this scorecard. True = dispute raised; False = no dispute. Triggers a review workflow when True.']
  dispute_reason varchar [note: 'Free-text description of the carrier\'s stated reason for disputing the scorecard results. Populated only when dispute_flag is True.']
  edi_compliance_rate_pct decimal(5,2) [note: 'Percentage of shipments for which the carrier transmitted all required EDI transaction sets (e.g., 214 shipment status, 210 freight invoice) accurately and on time during the measurement period.']
  effective_from date [note: 'The effective from of the carrier performance record']
  effective_until date [note: 'The effective until of the carrier performance record']
  evaluation_period_end date [note: 'The evaluation period end of the carrier performance record']
  evaluation_period_start date [note: 'The evaluation period start of the carrier performance record']
  freight_spend_currency_code varchar [note: 'ISO 4217 three-letter currency code for the total_freight_spend field (e.g., USD, EUR, GBP).']
  improvement_plan_flag boolean [note: 'Indicates whether a formal Carrier Improvement Plan (CIP) is active for this carrier as of this measurement period. True = improvement plan in effect; False = no active plan.']
  in_full_delivery_pct decimal(5,2) [note: 'The in full delivery pct of the carrier performance record']
  in_full_rate_pct decimal(5,2) [note: 'Percentage of shipments delivered with the complete ordered quantity, without short-shipment or partial delivery, during the measurement period.']
  invoice_accuracy_pct decimal(5,2) [note: 'The invoice accuracy pct of the carrier performance record']
  invoice_accuracy_rate_pct decimal(5,2) [note: 'Percentage of carrier freight invoices that matched the contracted rate without requiring correction or dispute during the measurement period. Supports freight audit and pay processes.']
  measurement_period varchar [note: 'The measurement period of the carrier performance record']
  measurement_period_type varchar [note: 'Granularity of the performance measurement window — weekly, monthly, quarterly, or annual. Determines the cadence at which KPIs are aggregated and reviewed.']
  name varchar [note: 'The carrier performance name of the carrier performance record']
  network_region varchar [note: 'Geographic network region covered by this scorecard (e.g., Northeast US, Western Europe, APAC). Enables regional performance benchmarking across the carrier network.']
  notes varchar [note: 'The notes of the carrier performance record']
  on_time_delivery_pct decimal(5,2) [note: 'The on time delivery pct of the carrier performance record']
  on_time_delivery_rate_pct decimal(5,2) [note: 'Percentage of shipments delivered to the destination within the committed delivery window during the measurement period. Distinct from OTIF as it excludes the in-full dimension.']
  on_time_pickup_rate_pct decimal(5,2) [note: 'Percentage of shipments where the carrier arrived at the origin facility within the scheduled pickup window during the measurement period.']
  otif_pct decimal(5,2) [note: 'The otif pct of the carrier performance record']
  otif_rate_pct decimal(5,2) [note: 'Percentage of shipments delivered both on time and in full during the measurement period. Core OTIF KPI used in carrier scorecards and contract compliance reviews. Calculated as (OTIF shipments / total shipments) × 100.']
  otif_target_pct decimal(5,2) [note: 'Contracted OTIF target percentage for this carrier and service level during the measurement period. Used to calculate variance against actual OTIF performance.']
  performance_score decimal(6,2) [note: 'The performance score of the carrier performance record']
  performance_tier varchar [note: 'Overall performance classification assigned to the carrier for this measurement period based on composite KPI scoring. Preferred = top-tier; Approved = meets standards; Probation = below threshold with improvement plan; Suspended = removed from routing guide pending review.']
  period_end_date date [note: 'Last calendar date of the measurement period covered by this scorecard record.']
  period_start_date date [note: 'First calendar date of the measurement period covered by this scorecard record.']
  period_type varchar [note: 'The period type of the carrier performance record']
  pod_compliance_rate_pct decimal(5,2) [note: 'Percentage of shipments for which a valid Proof of Delivery (POD) document was received within the contractually required timeframe during the measurement period.']
  prior_period_composite_score decimal(5,2) [note: 'Composite performance score from the immediately preceding measurement period. Enables trend analysis and period-over-period performance comparison without requiring a self-join.']
  quantity decimal(18,4) [note: 'The quantity of the carrier performance record']
  scorecard_finalized_date date [note: 'Calendar date on which the scorecard was locked as final after the dispute resolution window closed. Null if scorecard is not yet finalized.']
  scorecard_notes varchar [note: 'Free-text field for logistics team commentary on the scorecard, including context for performance anomalies, weather events, or force majeure conditions that impacted KPIs.']
  scorecard_number varchar [note: 'Externally-known business identifier for this scorecard record, used in carrier communications and contract review meetings. Format: CPSC-YYYY-MM-XXXXXX.']
  scorecard_published_date date [note: 'Calendar date on which the scorecard was formally published and shared with the carrier for review. Marks the start of the carrier\'s dispute window.']
  scorecard_rating varchar [note: 'The scorecard rating of the carrier performance record']
  scorecard_reference varchar [note: 'The scorecard reference of the carrier performance record']
  scorecard_status varchar [note: 'Current lifecycle state of the scorecard record. Draft = under calculation; Published = shared with carrier; Disputed = carrier has raised a challenge; Finalized = agreed and locked; Archived = historical.']
  service_level varchar [note: 'Service tier under which the carrier operated during this measurement period, enabling performance comparison within the same contracted service commitment.']
  source_system_code varchar [note: 'The source system code of the carrier performance record']
  tender_acceptance_pct decimal(5,2) [note: 'The tender acceptance pct of the carrier performance record']
  tender_acceptance_rate_pct decimal(5,2) [note: 'Percentage of load tenders accepted by the carrier on first offer during the measurement period. Low acceptance rates indicate capacity reliability issues and routing guide compliance failures.']
  tender_acceptance_target_pct decimal(5,2) [note: 'Contracted minimum tender acceptance rate for this carrier during the measurement period. Compared against actual tender acceptance rate to assess routing guide compliance.']
  total_claims_amount decimal(18,2) [note: 'Total monetary value of freight claims filed against the carrier during the measurement period, expressed in the reporting currency. Used for financial recovery tracking and carrier liability assessment.']
  total_freight_spend decimal(18,2) [note: 'Total freight cost paid to the carrier during the measurement period, including base freight, fuel surcharges, and accessorial charges. Used for spend analytics and contract benchmarking.']
  total_shipments varchar [note: 'Total number of shipments tendered to the carrier during the measurement period. Serves as the denominator for rate-based KPI calculations.']
  total_tenders varchar [note: 'Total number of load tenders issued to the carrier during the measurement period, including both accepted and rejected tenders.']
  transport_mode varchar [note: 'Mode of transportation for which this scorecard applies. Allows segmented performance analysis by mode (e.g., Truckload vs. Less-than-Truckload vs. Parcel). [ENUM-REF-CANDIDATE: TL|LTL|parcel|intermodal|ocean|air|rail — 7 candidates stripped; promote to reference product]']
  uom varchar [note: 'The uom of the carrier performance record']
  updated_timestamp timestamp [note: 'Timestamp of the most recent update to this carrier performance scorecard record. Used for incremental load detection and change data capture in the lakehouse pipeline.']

  Note: 'Periodic carrier performance scorecard record capturing measured KPIs for a carrier over a defined period. Captures carrier reference, measurement period (week/month/quarter), OTIF rate, on-time pickup rate, on-time delivery rate, tender acceptance rate, claims rate, damage rate, EDI compliance rate, and overall performance tier (preferred/approved/probation/suspended). Supports carrier relationship management and contract renewal decisions.'
}

