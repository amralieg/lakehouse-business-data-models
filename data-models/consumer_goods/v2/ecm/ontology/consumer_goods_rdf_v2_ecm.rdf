    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the audit finding, including observed deviation, evidence collected, and context of the non-conformance.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingNumber rdf:type rdf:Property ;
