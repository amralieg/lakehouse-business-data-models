    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cfrCitation rdf:type rdf:Property ;
    rdfs:label 'Cfr Citation' ;
    rdfs:comment 'Specific CFR (Code of Federal Regulations) citation or section under which the product is registered (e.g., 21 CFR 314 for NDAs, 40 CFR 152 for pesticides). Applicable primarily to US registrations.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRegistrationCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Registration Code' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscTrackingLabelRequired rdf:type rdf:Property ;
    rdfs:label 'Cpsc Tracking Label Required' ;
    rdfs:comment 'Indicates whether CPSC tracking label requirements apply to this registered product. True if tracking labels are required, False otherwise. Applicable to children\'s products and certain consumer goods.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryRegistrationDescription rdf:type rdf:Property ;
    rdfs:label 'Regulatory Registration Description' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the registration fee amount (e.g., USD, EUR, GBP, CAD).' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderAddress rdf:type rdf:Property ;
    rdfs:label 'Holder Address' ;
    rdfs:comment 'Full business address of the registration holder as registered with the regulatory authority. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderName rdf:type rdf:Property ;
    rdfs:label 'Holder Name' ;
    rdfs:comment 'Legal name of the company or entity that holds the registration. This is the registrant of record with the regulatory authority.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Ifra Compliance Flag' ;
    rdfs:comment 'Indicates whether the product formulation complies with IFRA standards for fragrance ingredients. True if IFRA-compliant, False otherwise. Relevant for cosmetic and personal care products.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the jurisdiction where the registration is valid (e.g., USA, DEU, GBR, CAN, BRA, JPN, AUS, CHN).' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionRegion rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Region' ;
    rdfs:comment 'Specific region, state, or province within the country where the registration applies (e.g., California, Ontario, Bavaria). Used for sub-national regulatory requirements.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Label Approval Number' ;
    rdfs:comment 'Approval number for the product label as reviewed and accepted by the regulatory authority. Critical for EPA pesticide registrations where label claims are strictly regulated.' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRegistrationName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Registration Name' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postMarketSurveillanceRequired rdf:type rdf:Property ;
    rdfs:label 'Post Market Surveillance Required' ;
    rdfs:comment 'Indicates whether post-market surveillance or pharmacovigilance reporting is required for this registration. True if surveillance is required, False otherwise.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productClassification rdf:type rdf:Property ;
    rdfs:label 'Product Classification' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeringAuthority rdf:type rdf:Property ;
    rdfs:label 'Registering Authority' ;
    rdfs:comment 'Name of the regulatory authority or governing body with which the product is registered (e.g., FDA, EPA, EU Commission, Health Canada, ANVISA). [ENUM-REF-CANDIDATE: FDA|EPA|CPSC|EU_REACH|Health_Canada|ANVISA|PMDA|TGA|SFDA|MHRA|BfR — promote to reference product]' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCategory rdf:type rdf:Property ;
    rdfs:label 'Registration Category' ;
    rdfs:comment 'Regulatory category or class of the registration as defined by the authority (e.g., OTC drug, prescription drug, general use pesticide, restricted use pesticide, cosmetic product, biocidal product).' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationType rdf:type rdf:Property ;
    rdfs:label 'Registration Type' ;
    rdfs:comment 'Type of registration action being recorded. Indicates whether this is a new registration, renewal of existing registration, amendment to existing registration, cancellation, variation, or transfer to another entity.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Email' ;
    rdfs:comment 'Email address of the primary regulatory affairs contact person for this registration. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
