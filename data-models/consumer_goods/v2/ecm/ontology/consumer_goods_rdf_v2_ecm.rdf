ind:esgCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Esg Commitment Id' ;
    rdfs:comment 'Foreign key linking to sustainability.esg_commitment. Business justification: ESG commitments are defined per facility for compliance; linking facility to its commitment enables facility-level ESG reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsgCommitment .

ind:jurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to regulatory.jurisdiction. Business justification: Facility compliance reporting must reference the jurisdiction governing its operations for regulatory filings and audit purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:regionId rdf:type rdf:Property ;
    rdfs:label 'Region Id' ;
    rdfs:comment 'add column region_id (BIGINT) with FK to shared.region.region_id - jurisdictions roll up to regions for reporting' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Region .

ind:supplyNetworkNodeId rdf:type rdf:Property ;
    rdfs:label 'Supply Network Node Id' ;
    rdfs:comment 'Foreign key linking to supply.network_node. Business justification: Required for Supply Network Planning report to map each plant to its network node, enabling ATP, capacity, and logistics calculations; domain experts expect this mapping.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkNode .

ind:addressLine1 rdf:type rdf:Property ;
