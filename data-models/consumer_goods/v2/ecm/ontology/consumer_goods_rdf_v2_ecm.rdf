    rdfs:comment 'Attribute dynamic_modification_rule of quality.inspection_plan.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpRelevant rdf:type rdf:Property ;
    rdfs:label 'Gmp Relevant' ;
    rdfs:comment 'Attribute gmp_relevant of quality.inspection_plan.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency' ;
    rdfs:comment 'Attribute inspection_frequency of quality.inspection_plan.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Lead Time Days' ;
    rdfs:comment 'Expected number of calendar days required to complete all inspections and testing defined in this plan. Used for production scheduling and inventory planning.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'Primary method used to perform the inspection: manual measurement, automated testing, laboratory analysis, visual examination, destructive testing, or non-destructive testing.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Plan Status' ;
    rdfs:comment 'Attribute status of quality.inspection_plan.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionSeverity rdf:type rdf:Property ;
    rdfs:label 'Inspection Severity' ;
    rdfs:comment 'Severity level of inspection based on supplier quality history and risk assessment. Tightened inspection applies stricter acceptance criteria.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStage rdf:type rdf:Property ;
    rdfs:label 'Inspection Stage' ;
    rdfs:comment 'Production or supply chain stage at which this inspection is triggered. Aligns with GMP critical control points.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Type of quality inspection this plan governs: incoming (supplier materials), in-process (production intermediates), final (finished goods), stability (shelf-life studies), release (batch release), or periodic (routine surveillance).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPlanName rdf:type rdf:Property ;
    rdfs:label 'Inspection Plan Name' ;
    rdfs:comment 'Attribute name of quality.inspection_plan.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Reference to the regulatory requirement, standard, or guideline that mandates this inspection (e.g., FDA 21 CFR Part 211, EU GMP Annex 1, ISO 22716). Critical for compliance audits.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleInspectorRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Inspector Role' ;
    rdfs:comment 'Job role or qualification level required for personnel authorized to perform inspections under this plan (e.g., QC Technician, QC Analyst, QC Manager). Ensures competency requirements are met.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision number of this inspection plan. Incremented each time the plan is updated. Part of change control and audit trail.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of sample units to be drawn per inspection lot. Determined by statistical sampling plan and AQL requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleUnit rdf:type rdf:Property ;
    rdfs:label 'Sample Unit' ;
    rdfs:comment 'Unit of measure for the sample (e.g., pieces, kg, liters, containers). Defines what constitutes one sample unit.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingProcedure rdf:type rdf:Property ;
    rdfs:label 'Sampling Procedure' ;
    rdfs:comment 'Attribute sampling_procedure of quality.inspection_plan.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Sampling Procedure Code' ;
    rdfs:comment 'Code identifying the sampling procedure to be followed: sample size, sampling frequency, sampling method (random, systematic, stratified). References approved sampling SOP.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skipLotAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Skip Lot Allowed Flag' ;
    rdfs:comment 'Indicates whether skip-lot inspection (reduced frequency based on consistent quality history) is permitted for this plan. Not allowed for GMP-critical inspections.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationVersion rdf:type rdf:Property ;
    rdfs:label 'Specification Version' ;
    rdfs:comment 'Version number of the quality specification document that this inspection plan implements. Ensures traceability to approved specifications.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testEquipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Test Equipment Required' ;
    rdfs:comment 'List or description of test equipment, instruments, or laboratory apparatus required to execute this inspection plan. Ensures resource availability.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageIndicator rdf:type rdf:Property ;
    rdfs:label 'Usage Indicator' ;
    rdfs:comment 'Attribute usage_indicator of quality.inspection_plan.' ;
    rdfs:domain ind:InspectionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundReceiptLineId rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Line Id' ;
    rdfs:comment 'Foreign key linking to distribution.inbound_receipt_line. Business justification: Required for traceability: inspection lot must reference the inbound receipt line that supplied the lot, enabling quality inspection reports to be linked to receipt data for OTIF and compliance audits' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundReceiptLine .

ind:inspectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspector Employee Id' ;
    rdfs:comment 'Identifier of the quality inspector or technician assigned to perform the inspection activities for this lot.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryInspectionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inspection Employee Id' ;
    rdfs:comment 'Identifier of the quality manager or authorized person who made the final usage decision for this inspection lot.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryInspectionLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Inspection Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the system user who last modified the inspection lot record. Maintains accountability for changes to quality data.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:certificateOfAnalysisNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Number' ;
    rdfs:comment 'Document number of the Certificate of Analysis issued for this inspection lot. Links to formal quality documentation in Veeva Vault.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaIssueDate rdf:type rdf:Property ;
    rdfs:label 'Coa Issue Date' ;
    rdfs:comment 'Date when the Certificate of Analysis was formally issued for this inspection lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionLotCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Code' ;
    rdfs:comment 'Attribute code of quality.inspection_lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date when the formal usage decision was made and recorded in the quality management system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Precise date and time when the usage decision was recorded. Used for audit trail and compliance reporting.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of defects or non-conformances identified during inspection. Used for quality metrics and trend analysis.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionLotDescription rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Description' ;
    rdfs:comment 'Attribute description of quality.inspection_lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionOutcome rdf:type rdf:Property ;
    rdfs:label 'Disposition Outcome' ;
    rdfs:comment 'Final outcome status of the lot after disposition decision and stock posting. Confirms the actual inventory movement executed.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionEndDate rdf:type rdf:Property ;
    rdfs:label 'Inspection End Date' ;
    rdfs:comment 'Date when all inspection and testing activities were completed for this lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionLocation rdf:type rdf:Property ;
    rdfs:label 'Inspection Location' ;
    rdfs:comment 'Physical location or quality lab where the inspection was performed. May be different from the plant code for centralized testing facilities.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Status' ;
    rdfs:comment 'Inspection Lot Status value for the Inspection Lot record.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Free-text field for inspector comments, observations, or special conditions noted during the inspection process.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPriority rdf:type rdf:Property ;
    rdfs:label 'Inspection Priority' ;
    rdfs:comment 'Priority level assigned to the inspection lot. Determines the sequence and urgency of inspection execution in the quality lab.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Date' ;
    rdfs:comment 'Date when the physical inspection and testing activities began for this lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle status of the inspection lot. Tracks progression from creation through inspection execution to final disposition decision.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotOriginNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Origin Number' ;
    rdfs:comment 'Document number of the originating transaction (production order number, purchase order number, delivery number, etc.) that triggered this inspection lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotOriginType rdf:type rdf:Property ;
    rdfs:label 'Lot Origin Type' ;
    rdfs:comment 'Source document type that triggered the creation of this inspection lot. Links the quality inspection to the originating business transaction.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotQuantity rdf:type rdf:Property ;
    rdfs:label 'Lot Quantity' ;
    rdfs:comment 'Total quantity of material in the inspection lot. Represents the population from which samples are drawn for inspection.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Lot Quantity Uom' ;
    rdfs:comment 'Unit of measure for the lot quantity (each, kilogram, liter, meter, etc.). Aligns with material master UOM. [ENUM-REF-CANDIDATE: EA|KG|L|M|M2|M3|BOX|CASE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotName rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Name' ;
    rdfs:comment 'Attribute name of quality.inspection_lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:origin rdf:type rdf:Property ;
    rdfs:label 'Origin' ;
    rdfs:comment 'Attribute inspection_lot_origin of quality.inspection_lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldReason rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Reason' ;
    rdfs:comment 'Detailed explanation of why the lot is under regulatory hold. Documents the specific compliance or quality concern requiring additional review.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'Date when the material must be re-inspected to confirm continued compliance with quality specifications. Applicable for raw materials and intermediates.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleQuantity rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity' ;
    rdfs:comment 'Quantity of material drawn as a sample for inspection testing. Determined by the inspection plan sampling procedure.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Sample Quantity Uom' ;
    rdfs:comment 'Unit of measure for the sample quantity drawn for testing. [ENUM-REF-CANDIDATE: EA|KG|L|M|M2|M3|BOX|CASE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockPostingInstruction rdf:type rdf:Property ;
    rdfs:label 'Stock Posting Instruction' ;
    rdfs:comment 'Instruction for inventory movement based on the usage decision. Determines the target stock type for material posting in warehouse management.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Warehouse storage location code where the inspected material is held during quality inspection.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemStatus rdf:type rdf:Property ;
    rdfs:label 'System Status' ;
    rdfs:comment 'Attribute system_status of quality.inspection_lot.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDecision rdf:type rdf:Property ;
    rdfs:label 'Usage Decision' ;
    rdfs:comment 'Final disposition decision for the inspected lot. Determines whether material can be released for use, must be reworked, or should be rejected.' ;
    rdfs:domain ind:InspectionLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDecisionCode rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Code' ;
    rdfs:comment 'Standardized code representing the usage decision. Used for automated stock posting and reporting in SAP QM.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResultId rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Id' ;
    rdfs:comment 'Unique identifier for the inspection result record. Primary key for granular QC (Quality Control) measurement and test result records captured at the characteristic level within an inspection lot.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionRecordedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspection Recorded By Employee Id' ;
    rdfs:comment 'Recorded By Employee Id referencing workforce.employee.employee_id.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:inspectionResultSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Specification Id' ;
    rdfs:comment 'Foreign key linking to quality.specification. Business justification: Link inspection_result to its governing specification for easy access to spec limits and versioning.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:sampleId rdf:type rdf:Property ;
    rdfs:label 'Sample Id' ;
    rdfs:comment 'Unique identifier of the physical sample from which this measurement was taken. Enables traceability back to the specific sample unit within the inspection lot.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsumerGoods .

ind:testEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Test Equipment Id' ;
    rdfs:comment 'Surrogate identifier: Test Equipment Id.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:characteristicCode rdf:type rdf:Property ;
    rdfs:label 'Characteristic Code' ;
    rdfs:comment 'Characteristic Code value for the Inspection Result record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characteristicName rdf:type rdf:Property ;
    rdfs:label 'Characteristic Name' ;
    rdfs:comment 'Characteristic Name value for the Inspection Result record.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Inclusion Flag' ;
    rdfs:comment 'Flag indicating whether this result should be included in the Certificate of Analysis (COA) document for the batch. True indicates inclusion; false indicates internal-only result.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionResultCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Code' ;
    rdfs:comment 'Attribute code of quality.inspection_result.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlChartRuleViolated rdf:type rdf:Property ;
    rdfs:label 'Control Chart Rule Violated' ;
    rdfs:comment 'Description of the specific SPC control chart rule that was violated (e.g., point beyond control limit, 7 consecutive points above centerline, 2 of 3 points beyond 2-sigma). Populated when control_chart_violation_flag is true.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlChartViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Control Chart Violation Flag' ;
    rdfs:comment 'Flag indicating whether this measurement violates SPC (Statistical Process Control) control chart rules (e.g., out of control limits, run rules, trend rules). True indicates a violation requiring investigation.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectClassification rdf:type rdf:Property ;
    rdfs:label 'Defect Classification' ;
    rdfs:comment 'Defect Classification value for the Inspection Result record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'Standardized code classifying the type of defect or non-conformance observed when result_status is fail. Used for defect trending and root cause analysis.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectSeverity rdf:type rdf:Property ;
    rdfs:label 'Defect Severity' ;
    rdfs:comment 'Classification of the severity of the non-conformance. Critical defects pose safety or regulatory risk; major defects affect functionality; minor defects are cosmetic or non-functional.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResultDescription rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Description' ;
    rdfs:comment 'Attribute description of quality.inspection_result.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationCode rdf:type rdf:Property ;
    rdfs:label 'Deviation Code' ;
    rdfs:comment 'Reference to an approved deviation or waiver document that authorizes acceptance of a non-conforming result. Populated when result_status is waived.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalConditionHumidity rdf:type rdf:Property ;
    rdfs:label 'Environmental Condition Humidity' ;
    rdfs:comment 'Relative humidity (percentage) at the time of measurement. Critical for tests sensitive to moisture levels.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalConditionTemperature rdf:type rdf:Property ;
    rdfs:label 'Environmental Condition Temperature' ;
    rdfs:comment 'Ambient temperature (in degrees Celsius) at the time of measurement. Critical for tests sensitive to environmental conditions.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationResult rdf:type rdf:Property ;
    rdfs:label 'Evaluation Result' ;
    rdfs:comment 'Evaluation Result value for the Inspection Result record.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCharacteristicCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Code' ;
    rdfs:comment 'Unique code identifying the specific quality characteristic being measured (e.g., pH level, viscosity, weight, color, microbial count). Corresponds to the master inspection characteristic definition.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCharacteristicName rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Name' ;
    rdfs:comment 'Human-readable name of the quality characteristic being tested (e.g., Product pH, Net Weight, Microbial Load, Color Consistency).' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionMethodCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Method Code' ;
    rdfs:comment 'Code identifying the standardized test method or procedure used to perform this measurement (e.g., ASTM method, USP method, internal SOP number).' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResultStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Status' ;
    rdfs:comment 'Attribute status of quality.inspection_result.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when this specific characteristic measurement was performed. Critical for time-sensitive tests and GMP audit trails.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:instrumentCode rdf:type rdf:Property ;
    rdfs:label 'Instrument Code' ;
    rdfs:comment 'Unique identifier of the measurement instrument or equipment used to capture this result (e.g., balance ID, pH meter ID, spectrophotometer ID). Required for GMP (Good Manufacturing Practice) audit trails and instrument calibration traceability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isWithinSpec rdf:type rdf:Property ;
    rdfs:label 'Is Within Spec' ;
    rdfs:comment 'Boolean indicator for Is Within Spec.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laboratoryCode rdf:type rdf:Property ;
    rdfs:label 'Laboratory Code' ;
    rdfs:comment 'Identifier of the laboratory or testing facility where this measurement was performed. May be an internal QC lab or an external contract lab.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Specification Limit' ;
    rdfs:comment 'The minimum acceptable value for this characteristic as defined in the product specification or quality standard. Values below this threshold indicate non-conformance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementUncertainty rdf:type rdf:Property ;
    rdfs:label 'Measurement Uncertainty' ;
    rdfs:comment 'Quantified estimate of the uncertainty or error margin associated with the measured value. Required for ISO 17025 compliance and advanced SPC (Statistical Process Control) analysis.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionResultName rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Name' ;
    rdfs:comment 'Attribute name of quality.inspection_result.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recorded Timestamp' ;
    rdfs:comment 'Attribute recorded_timestamp of quality.inspection_result.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Flag indicating whether this result must be reported to regulatory authorities (e.g., FDA, EPA) due to non-conformance or safety concerns. True indicates reportable event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text comments or observations recorded by the inspector regarding this measurement. May include notes on sample condition, procedural deviations, or contextual information.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Pass/fail status of this individual characteristic measurement. Pass indicates the measured value is within specification limits; fail indicates non-conformance; conditional indicates acceptance with restrictions; pending indicates awaiting review; waived indicates non-conformance accepted by authorized deviation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultUom rdf:type rdf:Property ;
    rdfs:label 'Result Uom' ;
    rdfs:comment 'Result Uom value for the Inspection Result record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValuation rdf:type rdf:Property ;
    rdfs:label 'Result Valuation' ;
    rdfs:comment 'Attribute result_valuation of quality.inspection_result.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValue rdf:type rdf:Property ;
    rdfs:label 'Result Value' ;
    rdfs:comment 'Result Value value for the Inspection Result record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultValueText rdf:type rdf:Property ;
    rdfs:label 'Result Value Text' ;
    rdfs:comment 'Result Value Text value for the Inspection Result record.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestIndicator rdf:type rdf:Property ;
    rdfs:label 'Retest Indicator' ;
    rdfs:comment 'Flag indicating whether this result is a retest of a previously failed or inconclusive measurement. True indicates this is a retest; false indicates initial test.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestReasonCode rdf:type rdf:Property ;
    rdfs:label 'Retest Reason Code' ;
    rdfs:comment 'Code indicating the reason for retesting this characteristic. Applicable only when retest_indicator is true.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Sequence Number' ;
    rdfs:comment 'Sequential number of this sample within the inspection lot (e.g., 1, 2, 3). Used to track sampling order and support statistical sampling plans.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Test Batch Number' ;
    rdfs:comment 'Batch or run number of the test reagents or consumables used during this measurement. Required for traceability in regulated environments.' ;
    rdfs:domain ind:InspectionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'Test Method value for the Inspection Result record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Specification Limit' ;
    rdfs:comment 'The maximum acceptable value for this characteristic as defined in the product specification or quality standard. Values above this threshold indicate non-conformance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageDecisionId rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Id' ;
    rdfs:comment 'Unique identifier for the quality control usage decision record. Primary key.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryUsageEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Usage Employee Id' ;
    rdfs:comment 'Reference to the quality control inspector or authorized personnel who made the usage decision. Required for accountability and audit trails.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:usageDecidedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Usage Decided By Employee Id' ;
    rdfs:comment 'Decided By Employee Id referencing workforce.employee.employee_id.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Accepted Quantity' ;
    rdfs:comment 'Accepted Quantity value for the Usage Decision record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Required Flag' ;
    rdfs:comment 'Indicates whether this usage decision triggers a CAPA process due to significant non-conformance. True=CAPA required, False=No CAPA needed. Links to continuous improvement.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionCode rdf:type rdf:Property ;
    rdfs:label 'Decision Code' ;
    rdfs:comment 'The formal quality control usage decision code. A=Accept (Unrestricted Use), R=Reject, Q=Quality Hold, S=Restricted Use (Sample/Scrap), X=Rework Required. Drives downstream inventory disposition.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDescription rdf:type rdf:Property ;
    rdfs:label 'Decision Description' ;
    rdfs:comment 'Decision Description value for the Usage Decision record.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionMakerName rdf:type rdf:Property ;
    rdfs:label 'Decision Maker Name' ;
    rdfs:comment 'Full name of the quality control inspector or authorized personnel who made the usage decision. Captured for audit and traceability purposes.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionText rdf:type rdf:Property ;
    rdfs:label 'Decision Text' ;
    rdfs:comment 'Detailed textual description or rationale for the usage decision. Captures the quality assessor\'s reasoning and any special conditions or instructions.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionType rdf:type rdf:Property ;
    rdfs:label 'Decision Type' ;
    rdfs:comment 'Decision Type value for the Usage Decision record.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Detailed description of the defect, non-conformance, or quality issue identified during inspection. Supports CAPA and continuous improvement processes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDecisionDescription rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Description' ;
    rdfs:comment 'Attribute description of quality.usage_decision.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Disposition value for the Usage Decision record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'The date when the material disposition action was completed (e.g., stock posted to unrestricted, blocked, or scrapped). Null if disposition is still pending.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Current status of the material disposition action following the usage decision. pending=Decision made but stock not yet moved, completed=Stock posting completed, cancelled=Decision reversed or voided.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAction rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action' ;
    rdfs:comment 'Attribute follow_up_action of quality.usage_decision.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDecisionName rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Name' ;
    rdfs:comment 'Attribute name of quality.usage_decision.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Quality Score value for the Usage Decision record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityAccepted rdf:type rdf:Property ;
    rdfs:label 'Quantity Accepted' ;
    rdfs:comment 'The quantity of material accepted for unrestricted use based on the usage decision. Measured in the material\'s base unit of measure.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRejected rdf:type rdf:Property ;
    rdfs:label 'Quantity Rejected' ;
    rdfs:comment 'The quantity of material rejected and not suitable for use. Measured in the material\'s base unit of measure. May trigger disposal or return to supplier.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRework rdf:type rdf:Property ;
    rdfs:label 'Quantity Rework' ;
    rdfs:comment 'The quantity of material designated for rework or reprocessing to meet quality standards. Measured in the material\'s base unit of measure.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:comment 'Rejected Quantity value for the Usage Decision record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockPostingType rdf:type rdf:Property ;
    rdfs:label 'Stock Posting Type' ;
    rdfs:comment 'Attribute stock_posting_type of quality.usage_decision.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:udCode rdf:type rdf:Property ;
    rdfs:label 'Ud Code' ;
    rdfs:comment 'Attribute ud_code of quality.usage_decision.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDecisionStatus rdf:type rdf:Property ;
    rdfs:label 'Usage Decision Status' ;
    rdfs:comment 'Attribute status of quality.usage_decision.' ;
    rdfs:domain ind:UsageDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonconformanceId rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Id' ;
    rdfs:comment 'Unique identifier for the nonconformance record. Primary key for the nonconformance data product.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Nonconformance .

ind:actionId rdf:type rdf:Property ;
    rdfs:label 'Action Id' ;
    rdfs:comment 'Foreign key linking to regulatory.regulatory_action. Business justification: Nonconformance findings can lead to regulatory enforcement actions; linking supports audit trails.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Action .

ind:inboundReceiptId rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Id' ;
    rdfs:comment 'Foreign key linking to distribution.inbound_receipt. Business justification: Required for receipt quality control: nonconformance must reference the inbound receipt that triggered the issue, enabling tracking of receipt-level defects and corrective actions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundReceipt .

ind:nonconformanceReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Reported By Employee Id' ;
    rdfs:comment 'Reported By Employee Id referencing workforce.employee.employee_id.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryNonconformanceClosedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Nonconformance Closed By User Employee Id' ;
    rdfs:comment 'User identifier of the quality professional who closed the nonconformance record after verification. Links to workforce/employee master data.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:transportExceptionId rdf:type rdf:Property ;
    rdfs:label 'Transport Exception Id' ;
    rdfs:comment 'Foreign key linking to logistics.transport_exception. Business justification: Captures transport-related nonconformance incidents, supporting root-cause analysis and corrective action planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportException .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date/time of Closed Date.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonconformanceCode rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Code' ;
    rdfs:comment 'Attribute code of quality.nonconformance.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentAction rdf:type rdf:Property ;
    rdfs:label 'Containment Action' ;
    rdfs:comment 'Immediate containment actions taken to prevent further occurrence or distribution of nonconforming product. Describes short-term corrective measures implemented before root cause analysis.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Containment Timestamp' ;
    rdfs:comment 'Date and time when containment actions were completed and verified effective. Critical for regulatory reporting and OTIF compliance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:defectCategory rdf:type rdf:Property ;
    rdfs:label 'Defect Category' ;
    rdfs:comment 'Attribute defect_category of quality.nonconformance.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonconformanceDescription rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Description' ;
    rdfs:comment 'Description value for the Nonconformance record.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'Date and time when the nonconformance was first detected or observed. Represents the real-world event time of quality issue identification.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionPoint rdf:type rdf:Property ;
    rdfs:label 'Detection Point' ;
    rdfs:comment 'Attribute detection_point of quality.nonconformance.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'Origin point where the nonconformance was first identified: QC inspection (quality control laboratory testing), manufacturing line (in-process detection), supplier receipt (incoming material inspection), customer complaint (consumer-reported issue), regulatory audit (FDA or regulatory body inspection), internal audit (GMP self-audit), or stability study (long-term product stability testing). [ENUM-REF-CANDIDATE: qc_inspection|manufacturing_line|supplier_receipt|customer_complaint|regulatory_audit|internal_audit|stability_study — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Disposition Approved By' ;
    rdfs:comment 'User identifier of the quality authority who approved the disposition decision. Links to workforce/employee master data for audit trail and GMP compliance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Approved Timestamp' ;
    rdfs:comment 'Date and time when the disposition decision was formally approved by quality authority. Critical for GMP audit trail and batch release decisions.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final disposition decision for the nonconforming product or material: use_as_is (approved for use despite nonconformance), rework (reprocess to meet specifications), scrap (destroy), return_to_supplier (send back to vendor), downgrade (sell as lower grade), or quarantine (hold pending further investigation).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial impact amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGmpRelated rdf:type rdf:Property ;
    rdfs:label 'Is Gmp Related' ;
    rdfs:comment 'Boolean indicator for Is Gmp Related.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonconformanceName rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Name' ;
    rdfs:comment 'Attribute name of quality.nonconformance.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncNumber rdf:type rdf:Property ;
    rdfs:label 'Nc Number' ;
    rdfs:comment 'Nc Number value for the Nonconformance record.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncStatus rdf:type rdf:Property ;
    rdfs:label 'Nc Status' ;
    rdfs:comment 'Nc Status value for the Nonconformance record.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncType rdf:type rdf:Property ;
    rdfs:label 'Nc Type' ;
    rdfs:comment 'Nc Type value for the Nonconformance record.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonconformanceStatus rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Status' ;
    rdfs:comment 'Current lifecycle status of the nonconformance record: open (newly created), in_investigation (root cause analysis underway), containment_active (immediate containment actions in progress), capa_assigned (corrective and preventive action assigned), closed (resolved and verified), or cancelled (invalidated).' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'External business identifier for the quality notification or nonconformance event. Corresponds to SAP QM notification number or Veeva Vault quality event identifier.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date when the nonconformance was reported to regulatory authorities, if applicable. Null if not reportable or not yet reported.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Attribute reported_date of quality.nonconformance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsiblePlantCode rdf:type rdf:Property ;
    rdfs:label 'Responsible Plant Code' ;
    rdfs:comment 'Manufacturing plant or facility code where the nonconformance originated or is being managed. Links to distribution_facility for organizational accountability.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Detailed findings from root cause investigation, including methodology used (5-Why, Fishbone, Fault Tree Analysis) and identified root causes. Supports CAPA development.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCapaClosedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Capa Closed By Employee Id' ;
    rdfs:comment 'Identifier of the employee who formally closed the CAPA record.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryCapaLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Capa Last Modified By Employee Id' ;
    rdfs:comment 'Identifier of the employee who last modified the CAPA record.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryCapaVerifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Capa Verified By Employee Id' ;
    rdfs:comment 'Identifier of the employee who performed the effectiveness verification.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCapaEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Capa Employee Id' ;
    rdfs:comment 'Identifier of the employee or team member assigned as the primary owner responsible for executing and closing the CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'The actual date when all CAPA actions were completed and verified, prior to formal closure.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Business-facing unique identifier for the CAPA record, typically formatted as CAPA-NNNNNN. Used for external communication and audit trails.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:comment 'Current lifecycle status of the CAPA record, tracking progression from initiation through closure. [ENUM-REF-CANDIDATE: open|investigation|action_plan|implementation|verification|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Classification of the CAPA as corrective (addressing existing nonconformance), preventive (preventing potential nonconformance), or combined (both corrective and preventive actions).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureComments rdf:type rdf:Property ;
    rdfs:label 'Closure Comments' ;
    rdfs:comment 'Final comments or notes recorded at the time of CAPA closure, summarizing outcomes and lessons learned.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'The date when the CAPA was formally closed after successful completion and verification of all actions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaCode rdf:type rdf:Property ;
    rdfs:label 'Capa Code' ;
    rdfs:comment 'Attribute code of quality.capa.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Corrective Action value for the Capa record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Amount' ;
    rdfs:comment 'Estimated or actual financial cost impact of the CAPA issue, including costs of investigation, rework, scrap, recall, or other remediation activities.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cost impact amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaDescription rdf:type rdf:Property ;
    rdfs:label 'Capa Description' ;
    rdfs:comment 'Detailed description of the nonconformance, audit finding, complaint, or stability failure that triggered the CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Date' ;
    rdfs:comment 'Date/time of Effectiveness Check Date.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessResult rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Result' ;
    rdfs:comment 'Effectiveness Result value for the Capa record.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Method' ;
    rdfs:comment 'The method or approach used to verify that the corrective and preventive actions were effective in resolving the issue and preventing recurrence (e.g., follow-up audit, process monitoring, trend analysis).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerificationResult rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verification Result' ;
    rdfs:comment 'The outcome of the effectiveness verification, indicating whether the CAPA actions successfully resolved the issue and prevented recurrence.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessVerified rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Verified' ;
    rdfs:comment 'Attribute effectiveness_verified of quality.capa.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'The date when the CAPA record was formally initiated and opened in the quality management system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaName rdf:type rdf:Property ;
    rdfs:label 'Capa Name' ;
    rdfs:comment 'Attribute name of quality.capa.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date/time of Opened Date.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Preventive Action value for the Capa record.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Description' ;
    rdfs:comment 'Detailed description of the preventive action(s) implemented to prevent recurrence of the issue or occurrence of similar issues.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemStatement rdf:type rdf:Property ;
    rdfs:label 'Problem Statement' ;
    rdfs:comment 'Attribute problem_statement of quality.capa.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processArea rdf:type rdf:Property ;
    rdfs:label 'Process Area' ;
    rdfs:comment 'The specific process, department, or functional area where the issue occurred (e.g., Manufacturing, Packaging, Quality Control, Supply Chain).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Flag' ;
    rdfs:comment 'Boolean indicator for Regulatory Impact Flag.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Method' ;
    rdfs:comment 'The methodology used to identify the root cause of the issue, such as 5 Whys, Fishbone Diagram, Fault Tree Analysis, Pareto Analysis, or Failure Mode and Effects Analysis (FMEA).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Reference Number' ;
    rdfs:comment 'Reference identifier of the originating event (e.g., nonconformance ID, audit finding ID, complaint ID) that triggered this CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'The origin or trigger event that initiated the CAPA, such as nonconformance, audit finding, customer complaint, supplier quality issue, stability study failure, or regulatory inspection finding.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'The planned or target date by which all CAPA actions should be completed and verified.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchReleaseId rdf:type rdf:Property ;
    rdfs:label 'Batch Release Id' ;
    rdfs:comment 'Unique identifier for the batch release decision record. Primary key for the batch release entity.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Batch Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person who last modified the batch release record. Required for audit trail and 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:batchReleaseCertificateOfAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Batch Release Certificate Of Analysis Id' ;
    rdfs:comment 'Attribute certificate_of_analysis_id of quality.batch_release.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificateOfAnalysis .

ind:batchReleasedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Batch Released By Employee Id' ;
    rdfs:comment 'Released By Employee Id referencing workforce.employee.employee_id.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryBatchReleaseCertificateOfAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Primary Batch Release Certificate Of Analysis Id' ;
    rdfs:comment 'Foreign key linking to quality.certificate_of_analysis. Business justification: Link batch_release to the Certificate of Analysis that documents the released batch, removing redundant reference number.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertificateOfAnalysis .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference to the complete audit trail log for all actions and approvals related to this batch release. Required for 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchReleaseStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Release Status' ;
    rdfs:comment 'Attribute status of quality.batch_release.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Batch Size Quantity' ;
    rdfs:comment 'Total quantity of finished goods produced in this batch. Used for yield calculation and inventory planning.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeUom rdf:type rdf:Property ;
    rdfs:label 'Batch Size Uom' ;
    rdfs:comment 'Unit of measure for the batch size quantity (e.g., kilograms, liters, units). Aligns with GS1 standards for trade item measurement. [ENUM-REF-CANDIDATE: kg|lbs|liters|gallons|units|cases|pallets — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchReleaseCode rdf:type rdf:Property ;
    rdfs:label 'Batch Release Code' ;
    rdfs:comment 'Attribute code of quality.batch_release.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchReleaseDescription rdf:type rdf:Property ;
    rdfs:label 'Batch Release Description' ;
    rdfs:comment 'Attribute description of quality.batch_release.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationCount rdf:type rdf:Property ;
    rdfs:label 'Deviation Count' ;
    rdfs:comment 'Number of manufacturing or quality deviations recorded during the production and testing of this batch. Used for quality trend analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Hold Initiated Date' ;
    rdfs:comment 'Date when the regulatory or business hold was placed on the batch. Nullable if no hold exists.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Detailed explanation of why the batch is on hold, if applicable. Includes regulatory citation, investigation reference, or customer complaint number.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingSiteCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Code' ;
    rdfs:comment 'Code identifying the manufacturing facility or plant where the batch was produced. Used for site-level quality tracking and regulatory reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchReleaseName rdf:type rdf:Property ;
    rdfs:label 'Batch Release Name' ;
    rdfs:comment 'Attribute name of quality.batch_release.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Product Registration Number' ;
    rdfs:comment 'Regulatory registration or approval number for the product in the target market. Required for FDA NDC, EU product registration, or equivalent.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionDate rdf:type rdf:Property ;
    rdfs:label 'Production Date' ;
    rdfs:comment 'Date when the batch manufacturing was completed. Critical for shelf-life calculation and FEFO inventory management.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaSignoffFlag rdf:type rdf:Property ;
    rdfs:label 'Qa Signoff Flag' ;
    rdfs:comment 'Boolean indicator for Qa Signoff Flag.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Inspection Status' ;
    rdfs:comment 'Overall status of QC inspection and testing for this batch. Summarizes results from multiple QC test records.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qpCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Qp Certification Flag' ;
    rdfs:comment 'Boolean indicator for Qp Certification Flag.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qpSignature rdf:type rdf:Property ;
    rdfs:label 'Qp Signature' ;
    rdfs:comment 'Attribute qp_signature of quality.batch_release.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qpSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qp Signature Timestamp' ;
    rdfs:comment 'Timestamp when the Qualified Person electronically signed the batch release decision. Part of 21 CFR Part 11 electronic signature compliance.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualifiedPersonName rdf:type rdf:Property ;
    rdfs:label 'Qualified Person Name' ;
    rdfs:comment 'Full name of the Qualified Person who signed off on the batch release. Required for regulatory audit trail.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Status' ;
    rdfs:comment 'Indicates if the batch is under any regulatory or business hold that prevents distribution. Holds may be imposed by FDA, EPA, internal quality, customer complaint, or recall investigation.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMarket rdf:type rdf:Property ;
    rdfs:label 'Regulatory Market' ;
    rdfs:comment 'Primary regulatory market or jurisdiction for which this batch was released. Different markets may have different release requirements and QP sign-off rules. [ENUM-REF-CANDIDATE: USA|CAN|MEX|GBR|DEU|FRA|ITA|ESP|CHN|JPN|AUS|BRA|IND — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDecision rdf:type rdf:Property ;
    rdfs:label 'Release Decision' ;
    rdfs:comment 'Final disposition decision for the batch: released for distribution, rejected for destruction, quarantine for further testing, conditional release with restrictions, pending review, or on hold pending investigation. Critical GMP control point.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseNotes rdf:type rdf:Property ;
    rdfs:label 'Release Notes' ;
    rdfs:comment 'Free-text notes and comments from the Qualified Person regarding the release decision. May include justification for conditional release or special handling instructions.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseNumber rdf:type rdf:Property ;
    rdfs:label 'Release Number' ;
    rdfs:comment 'Release Number value for the Batch Release record.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Release Quantity' ;
    rdfs:comment 'Attribute release_quantity of quality.batch_release.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Release Status value for the Batch Release record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Precise timestamp when the batch release decision was recorded in the system. Used for audit trail and regulatory compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Released Quantity' ;
    rdfs:comment 'Quantity of the batch that was approved for release and distribution. May be less than batch size if partial rejection occurred.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapQmInspectionLot rdf:type rdf:Property ;
    rdfs:label 'Sap Qm Inspection Lot' ;
    rdfs:comment 'SAP QM inspection lot number associated with this batch release. Links to SAP S/4HANA QM module for detailed inspection results and usage decisions.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityStudyReference rdf:type rdf:Property ;
    rdfs:label 'Stability Study Reference' ;
    rdfs:comment 'Reference number linking to the stability study protocol and results that support the assigned shelf life and expiry date for this batch.' ;
    rdfs:domain ind:BatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Id' ;
    rdfs:comment 'Unique identifier for the certificate of analysis record. Primary key.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Certificate Approved By Employee Id' ;
    rdfs:comment 'Attribute approved_by_employee_id of workforce.certificate_of_analysis.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:certificateIssuedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued By Employee Id' ;
    rdfs:comment 'Issued By Employee Id referencing workforce.employee.employee_id.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:certificateOfAnalysisLaboratoryId rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Laboratory Id' ;
    rdfs:comment 'Foreign key linking to quality.laboratory. Business justification: Link certificate_of_analysis to the laboratory that issued it, removing redundant name/code fields.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Laboratory .

ind:approvedFlag rdf:type rdf:Property ;
    rdfs:label 'Approved Flag' ;
    rdfs:comment 'Boolean indicator for Approved Flag.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Name' ;
    rdfs:comment 'Full name of the quality assurance professional authorized to approve and sign this certificate. Must have appropriate delegation of authority.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Title' ;
    rdfs:comment 'Job title or role of the authorized signatory (e.g., QA Manager, Quality Director, Laboratory Supervisor).' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSize rdf:type rdf:Property ;
    rdfs:label 'Batch Size' ;
    rdfs:comment 'Total quantity produced in the manufacturing batch. Used to assess sample representativeness and for statistical quality control.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateOfAnalysisStatus rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Status' ;
    rdfs:comment 'Attribute status of quality.certificate_of_analysis.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Classification of the certificate based on the material type being certified. Determines applicable test parameters and regulatory requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Number' ;
    rdfs:comment 'Coa Number value for the Certificate Of Analysis record.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaStatus rdf:type rdf:Property ;
    rdfs:label 'Coa Status' ;
    rdfs:comment 'Coa Status value for the Certificate Of Analysis record.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfAnalysisCode rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Code' ;
    rdfs:comment 'Attribute code of quality.certificate_of_analysis.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatement rdf:type rdf:Property ;
    rdfs:label 'Compliance Statement' ;
    rdfs:comment 'Attribute compliance_statement of quality.certificate_of_analysis.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Facing Flag' ;
    rdfs:comment 'Indicates whether this certificate is intended for external distribution to trade customers or is for internal use only. True if customer-facing.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerName rdf:type rdf:Property ;
    rdfs:label 'Customer Name' ;
    rdfs:comment 'Customer Name value for the Certificate Of Analysis record.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfAnalysisDescription rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Description' ;
    rdfs:comment 'Attribute description of quality.certificate_of_analysis.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL or file path to the digitally signed PDF or scanned image of the certificate stored in Veeva Vault or document management system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant Flag' ;
    rdfs:comment 'Indicates whether the batch and testing process were conducted under GMP conditions. True if GMP-compliant.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingSiteName rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Name' ;
    rdfs:comment 'Full name and location of the manufacturing site. Supports multi-site operations and regulatory site registration requirements.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfAnalysisName rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Name' ;
    rdfs:comment 'Attribute name of quality.certificate_of_analysis.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Overall Result value for the Certificate Of Analysis record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallResultStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Result Status' ;
    rdfs:comment 'Aggregate pass/fail status for all test parameters on this certificate. Determines batch release decision and customer distribution eligibility.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityTested rdf:type rdf:Property ;
    rdfs:label 'Quantity Tested' ;
    rdfs:comment 'The quantity of material sampled and tested for this certificate. Expressed in the material\'s base unit of measure.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityTestedUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Tested Uom' ;
    rdfs:comment 'Unit of measure for the quantity tested (e.g., kilograms, liters, units). Aligns with material master UOM.' ;
    rdfs:domain ind:CertificateOfAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Flag' ;
    rdfs:comment 'Indicates whether this certificate is required for regulatory submissions or compliance filings with FDA, EPA, or other governing bodies. True if required for submission.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierLotNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Lot Number' ;
    rdfs:comment 'The lot or batch number assigned by the supplier for raw materials or packaging materials. Used for supplier quality traceability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'The date on which quality control testing was performed for this certificate. May differ from manufacturing date for retained samples.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testMethodReference rdf:type rdf:Property ;
    rdfs:label 'Test Method Reference' ;
    rdfs:comment 'Reference to the analytical test methods used (e.g., USP, ASTM, internal method codes). May be a comma-separated list for multiple methods.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStabilityStudyId rdf:type rdf:Property ;
    rdfs:label 'Quality Stability Study Id' ;
    rdfs:comment 'Unique identifier for the stability study record. Primary key.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityStabilityStudy .

ind:qualityStabilityStudySpecificationId rdf:type rdf:Property ;
    rdfs:label 'Quality Stability Study Specification Id' ;
    rdfs:comment 'Foreign key linking to quality.specification. Business justification: Link quality_stability_study to the specification it validates, eliminating the free-text reference column.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:qualityStudyDirectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quality Study Director Employee Id' ;
    rdfs:comment 'Attribute study_director_employee_id of workforce.quality_stability_study.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedShelfLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Approved Shelf Life Months' ;
    rdfs:comment 'Regulatory-approved or final determined shelf life in months based on stability study results. May differ from proposed shelf life if data does not support full duration.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityStabilityStudyCode rdf:type rdf:Property ;
    rdfs:label 'Quality Stability Study Code' ;
    rdfs:comment 'Attribute code of quality.quality_stability_study.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Due Date' ;
    rdfs:comment 'Regulatory deadline by which stability study results must be submitted to the health authority. Applicable only when stability_commitment_flag is true.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:containerClosureSystem rdf:type rdf:Property ;
    rdfs:label 'Container Closure System' ;
    rdfs:comment 'Detailed specification of the container and closure materials and design used in the stability study. Critical for assessing barrier properties and product protection.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStabilityStudyDescription rdf:type rdf:Property ;
    rdfs:label 'Quality Stability Study Description' ;
    rdfs:comment 'Attribute description of quality.quality_stability_study.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMonths rdf:type rdf:Property ;
    rdfs:label 'Duration Months' ;
    rdfs:comment 'Duration Months value for the Quality Stability Study record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:humidityPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Percent' ;
    rdfs:comment 'Humidity Percent value for the Quality Stability Study record.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ichClimaticZone rdf:type rdf:Property ;
    rdfs:label 'Ich Climatic Zone' ;
    rdfs:comment 'International Council for Harmonisation (ICH) climatic zone classification for the intended market. Zone I (temperate), Zone II (subtropical/Mediterranean), Zone III (hot/dry), Zone IV (hot/humid). Determines required storage conditions.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingSite rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site' ;
    rdfs:comment 'Identifier or name of the manufacturing facility where the batch being tested was produced. Important for site-specific stability commitments.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStabilityStudyName rdf:type rdf:Property ;
    rdfs:label 'Quality Stability Study Name' ;
    rdfs:comment 'Attribute name of quality.quality_stability_study.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfSpecificationFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Specification Flag' ;
    rdfs:comment 'Indicates whether any test results during the study were out of specification, triggering investigation and potential corrective action. True if any OOS results occurred.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outOfTrendFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Trend Flag' ;
    rdfs:comment 'Indicates whether any test results showed unexpected trends or deviations from expected stability behavior, even if within specification. True if any OOT results occurred.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingConfiguration rdf:type rdf:Property ;
    rdfs:label 'Packaging Configuration' ;
    rdfs:comment 'Description of the primary and secondary packaging used for the stability samples (e.g., HDPE bottle with child-resistant cap, aluminum tube with flip-top cap). Packaging can significantly impact product stability.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedShelfLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Proposed Shelf Life Months' ;
    rdfs:comment 'Intended or claimed shelf life in months that this stability study is designed to support. Final shelf life determination is based on study results.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protocolReference rdf:type rdf:Property ;
    rdfs:label 'Protocol Reference' ;
    rdfs:comment 'Reference identifier for the approved stability study protocol document that defines test methods, sampling schedule, acceptance criteria, and storage conditions. Links to protocol management system or Veeva Vault.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStabilityStudyStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Stability Study Status' ;
    rdfs:comment 'Attribute status of quality.quality_stability_study.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPurpose rdf:type rdf:Property ;
    rdfs:label 'Regulatory Purpose' ;
    rdfs:comment 'Primary regulatory or business purpose for conducting the stability study. Registration studies support new product applications. Post-approval studies fulfill ongoing commitments. Change-control studies assess impact of manufacturing or formulation changes.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRegion rdf:type rdf:Property ;
    rdfs:label 'Regulatory Region' ;
    rdfs:comment 'Geographic region or regulatory authority for which this stability study is being conducted (e.g., USA, EU, Japan, Global). Different regions may have different storage condition requirements per ICH climatic zones.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Report Approval Date' ;
    rdfs:comment 'Date when the final stability study report was reviewed and approved by quality assurance. Marks formal completion of the study.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportReference rdf:type rdf:Property ;
    rdfs:label 'Report Reference' ;
    rdfs:comment 'Document identifier for the final stability study report. Links to document management system or Veeva Vault for full study documentation.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleLaboratory rdf:type rdf:Property ;
    rdfs:label 'Responsible Laboratory' ;
    rdfs:comment 'Name or identifier of the laboratory facility conducting the stability testing. May be internal quality control (QC) lab or external contract testing laboratory.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeTargetMonths rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Target Months' ;
    rdfs:comment 'Shelf Life Target Months value for the Quality Stability Study record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stabilityCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Stability Commitment Flag' ;
    rdfs:comment 'Indicates whether this study is part of a formal stability commitment made to a regulatory authority. True if this is a committed study that must be completed and reported per regulatory agreement.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Pct' ;
    rdfs:comment 'Target relative humidity percentage for the stability study storage condition.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageInstruction rdf:type rdf:Property ;
    rdfs:label 'Storage Instruction' ;
    rdfs:comment 'Consumer-facing storage instructions that will appear on product labeling, derived from stability study results (e.g., Store at room temperature, Do not freeze, Protect from light).' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyConclusion rdf:type rdf:Property ;
    rdfs:label 'Study Conclusion' ;
    rdfs:comment 'Summary conclusion of the stability study results, including whether the product met all acceptance criteria throughout the study duration and any recommendations for shelf life or storage conditions.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCoordinator rdf:type rdf:Property ;
    rdfs:label 'Study Coordinator' ;
    rdfs:comment 'Name or employee identifier of the person responsible for coordinating and overseeing the stability study execution.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Study Duration Months' ;
    rdfs:comment 'Planned total duration of the stability study in months. Typical durations are 6 months for accelerated studies, 12-36 months for real-time studies, and up to 60 months for long-term studies.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:studyEndDate rdf:type rdf:Property ;
    rdfs:label 'Study End Date' ;
    rdfs:comment 'Planned or actual completion date of the stability study. For ongoing studies, represents the projected completion date based on protocol duration.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyNumber rdf:type rdf:Property ;
    rdfs:label 'Study Number' ;
    rdfs:comment 'Business identifier for the stability study, typically assigned by the quality management system or laboratory information management system (LIMS). Used for external reference and regulatory submissions.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStartDate rdf:type rdf:Property ;
    rdfs:label 'Study Start Date' ;
    rdfs:comment 'Date when the stability study was initiated and samples were placed on stability storage. Marks the beginning of the study timeline for time-point calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyStatus rdf:type rdf:Property ;
    rdfs:label 'Study Status' ;
    rdfs:comment 'Current lifecycle status of the stability study. Tracks progression from planning through completion or discontinuation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Temperature Celsius value for the Quality Stability Study record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testParameters rdf:type rdf:Property ;
    rdfs:label 'Test Parameters' ;
    rdfs:comment 'List of quality attributes and test methods included in the stability protocol (e.g., appearance, pH, assay, impurities, microbial limits, viscosity). Comma-separated or structured list.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingFrequency rdf:type rdf:Property ;
    rdfs:label 'Testing Frequency' ;
    rdfs:comment 'Schedule of time points at which samples are pulled and tested (e.g., 0, 3, 6, 9, 12, 18, 24, 36 months). Defined in the study protocol and varies by study type.' ;
    rdfs:domain ind:QualityStabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityResultId rdf:type rdf:Property ;
    rdfs:label 'Stability Result Id' ;
    rdfs:comment 'Unique identifier for the stability test result record. Primary key for the stability result entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StabilityResult .

ind:originalResultStabilityResultId rdf:type rdf:Property ;
    rdfs:label 'Original Result Stability Result Id' ;
    rdfs:comment 'Reference to the original stability result record if this is a retest.' ;
    rdfs:domain ind:StabilityResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StabilityResult .

ind:stabilityRecordedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Stability Recorded By Employee Id' ;
    rdfs:comment 'Recorded By Employee Id referencing workforce.employee.employee_id.' ;
    rdfs:domain ind:StabilityResult ;
    rdf:type owl:ObjectProperty ;
