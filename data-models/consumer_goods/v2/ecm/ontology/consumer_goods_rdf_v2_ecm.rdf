ind:expectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity' ;
    rdfs:comment 'Total quantity of goods expected to be received based on the ASN or purchase order, used for discrepancy detection.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Document Number' ;
    rdfs:comment 'SAP Material Management (MM) goods receipt document number generated upon posting the receipt to inventory, linking WMS to ERP.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Status' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundReceiptName rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Name' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Compliant Flag' ;
    rdfs:comment 'Indicator of whether this receipt met both on-time delivery and complete quantity requirements, key supplier performance metric.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Number of pallets received in this inbound shipment, used for dock capacity planning and labor allocation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:putawayCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Putaway Completion Timestamp' ;
    rdfs:comment 'Date and time when all received goods were moved from the receiving dock to their designated storage locations, completing the inbound process.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Current status of the quality inspection process for this receipt, tracking progression through quality control workflow.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Completed Timestamp' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Completion Timestamp' ;
    rdfs:comment 'Date and time when all receiving activities (unloading, inspection, put-away) were completed and the receipt was closed in the WMS.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The date when the inventory lot was received into the distribution center. Used for inventory aging and supplier performance tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Externally-known business identifier for the inbound receipt, used for tracking and reference across systems and with suppliers.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the inbound receipt transaction, tracking progression from scheduling through completion or exception handling.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptType rdf:type rdf:Property ;
    rdfs:label 'Receipt Type' ;
    rdfs:comment 'Classification of the inbound receipt based on the source and nature of the goods being received.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledArrival rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Receipt Date' ;
    rdfs:comment 'Planned date for the inbound shipment to arrive at the distribution center, based on ASN or supplier commitment.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Indicator of whether the security seal was found intact upon arrival, critical for quality control and loss prevention.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Security seal identifier applied to the trailer or container, verified upon receipt to ensure shipment integrity and prevent tampering.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Check Required Flag' ;
    rdfs:comment 'Indicator of whether temperature verification was required for this receipt due to cold chain or temperature-sensitive product requirements.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Compliant Flag' ;
    rdfs:comment 'Indicator of whether the recorded temperature was within acceptable range per product specifications and cold chain requirements.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureReadingCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Reading Celsius' ;
    rdfs:comment 'Actual temperature reading in Celsius recorded during receipt inspection for temperature-sensitive products, critical for cold chain compliance.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLines rdf:type rdf:Property ;
    rdfs:label 'Total Lines' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'Aggregate quantity of units to be picked in the wave.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUnitsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Units Received' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trailerNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Number' ;
    rdfs:comment 'Unique identifier of the trailer or truck that delivered the shipment, used for tracking and carrier performance analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Unique identifier for the purchase order line item. Primary key for the po_line product.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:asnLineNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Line Number' ;
    rdfs:comment 'Line number within the ASN document corresponding to this receipt line. Enables automated matching between ASN and physical receipt.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inboundReceiptLineCode rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Line Code' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionCode rdf:type rdf:Property ;
    rdfs:label 'Condition Code' ;
    rdfs:comment 'Quality condition assessment of the received goods. Determines whether product can be put away into available inventory or requires special handling.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Free-text description of any damage, defects, or quality issues observed during receipt inspection. Used for claims and supplier performance tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damagedQuantity rdf:type rdf:Property ;
    rdfs:label 'Damaged Quantity' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundReceiptLineDescription rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Line Description' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedQuantityCases rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity Cases' ;
    rdfs:comment 'Expected quantity in cases as specified in the Advanced Shipping Notice (ASN) or purchase order. Used for variance detection.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedQuantityEaches rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity Eaches' ;
    rdfs:comment 'Expected quantity in eaches as specified in the Advanced Shipping Notice (ASN) or purchase order. Used for variance detection.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedCost rdf:type rdf:Property ;
    rdfs:label 'Extended Cost' ;
    rdfs:comment 'Total cost for this receipt line calculated as unit cost multiplied by received quantity. Used for inventory valuation and financial reconciliation.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundReceiptLineStatus rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Line Status' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundReceiptLineName rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Line Name' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletCode rdf:type rdf:Property ;
    rdfs:label 'Pallet Code' ;
    rdfs:comment 'Unique identifier for the pallet or handling unit containing this receipt line. Used for put-away and storage location assignment.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderLineNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Line Number' ;
    rdfs:comment 'Line number on the purchase order corresponding to this receipt line. Enables three-way matching between PO, receipt, and invoice.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:putAwayTimestamp rdf:type rdf:Property ;
    rdfs:label 'Put Away Timestamp' ;
    rdfs:comment 'Date and time when the goods were put away into their assigned storage location. Used for warehouse productivity and cycle time measurement.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:putawayStatus rdf:type rdf:Property ;
    rdfs:label 'Putaway Status' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Flag' ;
    rdfs:comment 'Indicates whether this shipment line item has been placed on a quality hold due to a failed QC inspection, temperature exceedance, or regulatory non-conformance. Items on hold must not be delivered until released by QA.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedQuantityCases rdf:type rdf:Property ;
    rdfs:label 'Received Quantity Cases' ;
    rdfs:comment 'Quantity of product received measured in cases. Represents the outer packaging unit typically used for warehouse handling.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedQuantityEaches rdf:type rdf:Property ;
    rdfs:label 'Received Quantity Eaches' ;
    rdfs:comment 'Quantity of product received measured in individual units (eaches). Represents the consumer-facing unit count.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sscc rdf:type rdf:Property ;
    rdfs:label 'Sscc' ;
    rdfs:comment '18-digit Serial Shipping Container Code identifying the logistics unit. Global standard for tracking pallets and containers in the supply chain.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtReceiptCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature At Receipt Celsius' ;
    rdfs:comment 'Temperature measurement in Celsius recorded at the time of receipt. Critical for cold chain compliance and product quality verification.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantityCases rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity Cases' ;
    rdfs:comment 'Difference between expected and received quantity in cases. Positive values indicate overages, negative values indicate shortages.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantityEaches rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity Eaches' ;
    rdfs:comment 'Difference between expected and received quantity in eaches. Positive values indicate overages, negative values indicate shortages.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Code' ;
    rdfs:comment 'Code identifying the distribution center or warehouse facility where the receipt occurred. Used for multi-site inventory management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayTaskId rdf:type rdf:Property ;
    rdfs:label 'Putaway Task Id' ;
    rdfs:comment 'Unique identifier for the putaway task record generated by the WMS. Primary key for the putaway task entity.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionShipmentId rdf:type rdf:Property ;
    rdfs:label 'Distribution Shipment Id' ;
    rdfs:comment 'Identifier of the inbound shipment or receipt that triggered this putaway task, linking the task back to the receiving process for traceability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionShipment .

ind:primaryPutawayDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Putaway Distribution Storage Location Id' ;
    rdfs:comment 'Identifier of the warehouse location from which the goods are being moved (e.g., receiving dock, staging area, reserve storage).' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:putawayAssignedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Putaway Assigned Employee Id' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:putawayDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Putaway Distribution Storage Location Id' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:putawayEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Putaway Employee Id' ;
    rdfs:comment 'Identifier of the warehouse associate or operator assigned to execute this putaway task, used for labor tracking and productivity measurement.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetLocationDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Target Location Distribution Storage Location Id' ;
    rdfs:comment 'Identifier of the warehouse location to which the goods are being moved (e.g., reserve storage bin, pick face slot, cross-dock staging).' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:putawayTaskCode rdf:type rdf:Property ;
    rdfs:label 'Putaway Task Code' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Confirmation Method' ;
    rdfs:comment 'The method used by the warehouse operator to confirm task completion: barcode scan, RFID tag read, manual entry, voice-directed picking system, or vision-based verification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cubeCubicFeet rdf:type rdf:Property ;
    rdfs:label 'Cube Cubic Feet' ;
    rdfs:comment 'The total volume in cubic feet of the goods being moved, used for space utilization analysis and slotting optimization.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Minutes' ;
    rdfs:comment 'The elapsed time in minutes from task start to task completion, a key labor productivity KPI used to measure warehouse associate efficiency and identify process bottlenecks.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:putawayTaskDescription rdf:type rdf:Property ;
    rdfs:label 'Putaway Task Description' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Free-text description of the exception or issue encountered during putaway execution, providing additional context for operational review and corrective action.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStrategy rdf:type rdf:Property ;
    rdfs:label 'Movement Strategy' ;
    rdfs:comment 'The inventory rotation or replenishment strategy applied to this putaway task: FEFO (First Expired First Out), FIFO (First In First Out), min/max threshold-based, kanban pull signal, wave-driven batch, zone-based slotting, or ABC classification velocity-based. [ENUM-REF-CANDIDATE: FEFO|FIFO|min_max|kanban|wave_driven|zone_based|ABC_classification — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayTaskName rdf:type rdf:Property ;
    rdfs:label 'Putaway Task Name' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayTaskStatus rdf:type rdf:Property ;
    rdfs:label 'Putaway Task Status' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Check Completed Flag' ;
    rdfs:comment 'Boolean flag indicating whether the required quality inspection has been completed and passed, enabling downstream processes to proceed.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Check Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether a quality inspection is required before or after putaway completion, typically for high-value items, temperature-sensitive goods, or regulatory compliance.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceLocationCode rdf:type rdf:Property ;
    rdfs:label 'Source Location Code' ;
    rdfs:comment 'Human-readable code of the source location (e.g., DOCK-A-01, STAGE-B-05) used by warehouse operators for navigation and scanning.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'The source system or module that generated this putaway task record (e.g., BLUE_YONDER_WMS, SAP_EWM, MANHATTAN_WMS), used for data lineage and integration troubleshooting.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLocationCode rdf:type rdf:Property ;
    rdfs:label 'Target Location Code' ;
    rdfs:comment 'Human-readable code of the target location (e.g., A-12-03-B, PICK-C-22) used by warehouse operators for navigation and scanning.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskAssignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Assigned Timestamp' ;
    rdfs:comment 'The date and time when the putaway task was assigned to a warehouse operator, used to measure assignment latency and labor allocation efficiency.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Cancelled Timestamp' ;
    rdfs:comment 'The date and time when the putaway task was cancelled, applicable when the task is aborted due to inventory discrepancies, system errors, or operational changes.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Completed Timestamp' ;
    rdfs:comment 'The date and time when the putaway task was completed (e.g., goods confirmed in target location), marking the end of the task lifecycle and enabling cycle time KPI calculation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Created Timestamp' ;
    rdfs:comment 'The date and time when the putaway task was created by the WMS, marking the start of the task lifecycle and used for cycle time calculation.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'Human-readable business identifier for the putaway task, typically generated by Blue Yonder WMS for tracking and operator reference.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Started Timestamp' ;
    rdfs:comment 'The date and time when the warehouse operator began executing the putaway task (e.g., scanned the source location or pallet), used for labor productivity tracking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the putaway task indicating its execution state within the warehouse workflow.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the putaway task based on the movement purpose: inbound putaway (receiving dock to storage), replenishment (reserve to pick face), cross-dock (dock to dock), returns putaway (returns area to storage), or internal transfer.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDistanceFeet rdf:type rdf:Property ;
    rdfs:label 'Travel Distance Feet' ;
    rdfs:comment 'The physical distance in feet traveled by the warehouse operator from source to target location, used for slotting optimization and labor efficiency analysis.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waveCode rdf:type rdf:Property ;
    rdfs:label 'Wave Code' ;
    rdfs:comment 'Identifier of the wave or batch of tasks to which this putaway task belongs, used for wave-driven replenishment and coordinated task execution.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightLbs rdf:type rdf:Property ;
    rdfs:label 'Weight Lbs' ;
    rdfs:comment 'The total weight in pounds of the goods being moved in this putaway task, used for equipment selection, labor safety, and capacity planning.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundOrderId rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Id' ;
    rdfs:comment 'Unique identifier for the outbound fulfillment order. Primary key for the outbound order entity.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundOrder .

ind:freightOrderId rdf:type rdf:Property ;
    rdfs:label 'Freight Order Id' ;
    rdfs:comment 'Foreign key linking to logistics.freight_order. Business justification: Freight order creation for every outbound order manages carrier tendering, freight cost tracking, and audit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightOrder .

ind:outboundDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Outbound Distribution Facility Id' ;
    rdfs:comment 'Identifier of the distribution center fulfilling the outbound order. Determines inventory source and warehouse operations responsible for order execution.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:outboundSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Outbound Sales Order Id' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:outboundShipToLocationDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Outbound Ship To Location Distribution Facility Id' ;
    rdfs:comment 'Identifier of the destination location where the order will be delivered. May reference retail store, warehouse, or customer facility.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:waveId rdf:type rdf:Property ;
    rdfs:label 'Wave Id' ;
    rdfs:comment 'Identifier of the picking wave that generated the orders included in this load plan. Links load planning to upstream warehouse execution.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wave .

ind:backorderFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Flag' ;
    rdfs:comment 'Indicates whether any line items on the order are backordered due to insufficient inventory. True when ordered quantity exceeds available stock.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Carrier-issued document number serving as receipt of goods and contract of carriage. Required for freight claims and proof of delivery.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundOrderCode rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Code' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundOrderDescription rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Description' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Percentage' ;
    rdfs:comment 'Percentage of ordered quantity that was fulfilled from available inventory. Calculated as (shipped quantity / ordered quantity) * 100. Key metric for inventory availability and customer service.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundOrderName rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Name' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Commitment Flag' ;
    rdfs:comment 'Indicates whether this order is subject to formal OTIF performance measurement and customer scorecard reporting. True for orders with contractual delivery commitments.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outboundOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Status' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingSlipNumber rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Number' ;
    rdfs:comment 'Document number for the packing slip accompanying the shipment. Used for customer receiving and invoice reconciliation.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Pick Ticket Number' ;
    rdfs:comment 'Warehouse document number used to direct picking operations for this order. Generated by WMS when order is released to the warehouse floor.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Timestamp' ;
    rdfs:comment 'Date and time when delivery was confirmed by the recipient. Captured from carrier POD or customer signature. Used for OTIF measurement and freight audit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'Date when the customer or system requests the order to be shipped from the distribution center. Used for warehouse planning and scheduling.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the order must be delivered to the customer destination. Critical for OTIF (On Time In Full) performance measurement and SLA compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipToAddress rdf:type rdf:Property ;
    rdfs:label 'Ship To Address' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Order Quantity' ;
    rdfs:comment 'Total quantity of units across all line items in the outbound order. Used for warehouse capacity planning and OTIF fill rate calculation.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Total monetary value of the outbound order before taxes and freight charges. Used for order prioritization, credit limit checks, and revenue forecasting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Order Volume M3' ;
    rdfs:comment 'Total volume of the outbound order in cubic meters. Used for warehouse space planning, truck cube utilization, and pallet configuration.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Order Weight Kg' ;
    rdfs:comment 'Total weight of the outbound order in kilograms. Used for freight cost calculation, carrier capacity planning, and vehicle loading optimization.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnits rdf:type rdf:Property ;
    rdfs:label 'Total Units' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labelVersionId rdf:type rdf:Property ;
    rdfs:label 'Label Version Id' ;
    rdfs:comment 'Foreign key linking to regulatory.label_version. Business justification: Label version compliance check before order fulfillment guarantees the label used for the SKU is approved for the destination market.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabelVersion .

ind:baseUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Unit Quantity' ;
    rdfs:comment 'Quantity converted to base unit of measure for standardized reporting and inventory tracking.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundOrderLineCode rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Line Code' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPoLineNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Po Line Number' ;
    rdfs:comment 'Customer\'s purchase order line number for cross-reference and reconciliation.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundOrderLineDescription rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Line Description' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediLineReference rdf:type rdf:Property ;
    rdfs:label 'Edi Line Reference' ;
    rdfs:comment 'EDI transaction line reference number for electronic order processing and ASN generation.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingUnitCode rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Code' ;
    rdfs:comment 'Serial shipping container code (SSCC) or handling unit identifier for the container holding this line item.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Line Volume M3' ;
    rdfs:comment 'Total volume of the shipped quantity for this line in cubic meters.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineWeightKg rdf:type rdf:Property ;
    rdfs:label 'Line Weight Kg' ;
    rdfs:comment 'Total weight of the shipped quantity for this line in kilograms.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundOrderLineName rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Line Name' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'Quantity of the SKU originally requested by the customer in the order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundOrderLineStatus rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Line Status' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Timestamp' ;
    rdfs:comment 'Date and time when the line item was packed into shipping containers.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packedQuantity rdf:type rdf:Property ;
    rdfs:label 'Packed Quantity' ;
    rdfs:comment 'Quantity packed into shipping containers and ready for dispatch.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Timestamp' ;
    rdfs:comment 'Date and time when the line item was picked from warehouse inventory.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickZone rdf:type rdf:Property ;
    rdfs:label 'Pick Zone' ;
    rdfs:comment 'Warehouse pick zone designation for labor management and routing optimization.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickedQuantity rdf:type rdf:Property ;
    rdfs:label 'Picked Quantity' ;
    rdfs:comment 'Quantity physically picked from warehouse storage locations during fulfillment.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumbers rdf:type rdf:Property ;
    rdfs:label 'Serial Numbers' ;
    rdfs:comment 'Comma-separated list of serial numbers for serialized inventory items shipped on this line.' ;
