ind:sdsName rdf:type rdf:Property ;
    rdfs:label 'Sds Name' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingGroup rdf:type rdf:Property ;
