ind:tradeAccountDescription rdf:type rdf:Property ;
    rdfs:label 'Trade Account Description' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Delivery Flag' ;
    rdfs:comment 'Indicates whether this trade account receives direct store delivery (DSD) shipments bypassing the retailers distribution center.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunNumber rdf:type rdf:Property ;
    rdfs:label 'Dun Number' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'The 9-digit DUNS number assigned by Dun & Bradstreet for unique identification of the business entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'The first line of the street address for the trade account headquarters or primary business location.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line2' ;
    rdfs:comment 'The second line of the street address (suite, floor, building) for the trade account headquarters.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'The city name of the trade account headquarters location.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'The 3-letter ISO 3166-1 alpha-3 country code for the trade account headquarters location (e.g., USA, CAN, MEX, GBR, DEU).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'The postal code or ZIP code of the trade account headquarters location.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'The state, province, or administrative region of the trade account headquarters location.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'The official registered legal name of the trade partner organization as it appears on legal documents and contracts.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeAccountName rdf:type rdf:Property ;
    rdfs:label 'Trade Account Name' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifSlaTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Otif Sla Target Percent' ;
    rdfs:comment 'The contractual OTIF service level agreement target percentage for order fulfillment performance (e.g., 95.00 represents 95% of orders delivered on time and in full).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'The standard payment terms code governing invoice payment due dates and early payment discounts (e.g., Net 30, Net 60, 2/10 Net 30).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The account status immediately prior to the most recent status change, maintained for audit trail and lifecycle analysis.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'The business email address of the primary contact for order management, invoicing, and account communications.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'The full name of the primary business contact or account manager at the trade partner organization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'The business phone number of the primary contact, including country code and extension if applicable.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Primary Language Code' ;
    rdfs:comment 'The 2-letter ISO 639-1 language code for the preferred communication language with this trade account (e.g., en, es, fr, de).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeReason rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason' ;
    rdfs:comment 'The business reason or justification for the most recent account status change (e.g., payment default, business closure, credit improvement, contract renewal).' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Status Change Timestamp' ;
    rdfs:comment 'The date and time when the most recent account status change occurred.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:statusChangedByUser rdf:type rdf:Property ;
    rdfs:label 'Status Changed By User' ;
    rdfs:comment 'The user ID or name of the person who executed the most recent account status change, for audit and accountability purposes.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Flag' ;
    rdfs:comment 'Indicates whether this trade account holds a valid tax exemption certificate for sales tax or VAT purposes.' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'The government-issued tax identification number for this legal entity (e.g., EIN in USA, VAT number in EU, GST number in other jurisdictions).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdpCount rdf:type rdf:Property ;
    rdfs:label 'Tdp Count' ;
    rdfs:comment 'The total number of distribution points (store locations or outlets) operated by this trade account where products can be sold.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradeAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Trade Account Status' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeChannel rdf:type rdf:Property ;
    rdfs:label 'Trade Channel' ;
    rdfs:comment 'The primary retail or distribution channel through which this trade account operates: grocery (supermarkets), mass (mass merchandisers), club (warehouse clubs), drug (pharmacy chains), convenience stores, foodservice (restaurants/institutions), or e-commerce (online retailers). [ENUM-REF-CANDIDATE: grocery|mass|club|drug|convenience|foodservice|e-commerce — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TradeAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountContactId rdf:type rdf:Property ;
    rdfs:label 'Account Contact Id' ;
    rdfs:comment 'Reference to another account contact record representing this contact\'s direct manager or supervisor within the trade account organization. Enables organizational hierarchy mapping.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountContact .

ind:accountContactStatus rdf:type rdf:Property ;
    rdfs:label 'Account Contact Status' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistantName rdf:type rdf:Property ;
    rdfs:label 'Assistant Name' ;
    rdfs:comment 'The name of the contact\'s administrative assistant or executive assistant, if applicable. Used for scheduling and communication routing.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistantPhone rdf:type rdf:Property ;
    rdfs:label 'Assistant Phone' ;
    rdfs:comment 'The phone number of the contact\'s administrative assistant. Used for scheduling and communication routing.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountContactCode rdf:type rdf:Property ;
    rdfs:label 'Account Contact Code' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactNotes rdf:type rdf:Property ;
    rdfs:label 'Contact Notes' ;
    rdfs:comment 'Free-form text field for capturing additional notes, preferences, or context about the contact. Used by sales representatives to document relationship insights.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'The contact\'s role in the buying decision process. Distinguishes between primary decision-makers, influencers, and administrative contacts. Critical for sales force automation and account planning.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. Active contacts are currently employed and engaged with the account. Inactive or terminated contacts are retained for historical reference.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact\'s primary functional role at the trade account. Determines which business processes and communications this contact participates in.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountContactDescription rdf:type rdf:Property ;
    rdfs:label 'Account Contact Description' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the contact, if applicable. Still used in some trade channels for purchase orders and formal documentation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDecisionMaker rdf:type rdf:Property ;
    rdfs:label 'Is Decision Maker' ;
    rdfs:comment 'Boolean flag indicating whether this contact has purchasing authority and decision-making power for the account. True if decision maker, False otherwise.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Boolean flag indicating whether this contact is the primary point of contact for the trade account. True if primary, False otherwise.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'The official job title or position held by the contact at the trade account organization. Examples include Senior Buyer, Category Manager, Supply Chain Director.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'The date of the most recent interaction or communication with this contact. Used to track engagement frequency and identify dormant relationships.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'The URL of the contact\'s LinkedIn professional profile. Used for social selling and relationship intelligence.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile or cellular phone number for the contact. Used for urgent communications and field-based retail execution activities.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountContactName rdf:type rdf:Property ;
    rdfs:label 'Account Contact Name' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Next Follow Up Date' ;
    rdfs:comment 'The scheduled date for the next planned follow-up or interaction with this contact. Supports proactive account management and sales cadence planning.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInEmail rdf:type rdf:Property ;
    rdfs:label 'Opt In Email' ;
    rdfs:comment 'Boolean flag indicating whether the contact has opted in to receive commercial email communications. True if opted in, False if opted out. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInPhone rdf:type rdf:Property ;
    rdfs:label 'Opt In Phone' ;
    rdfs:comment 'Boolean flag indicating whether the contact has opted in to receive commercial phone communications. True if opted in, False if opted out. Required for telemarketing compliance.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInSms rdf:type rdf:Property ;
    rdfs:label 'Opt In Sms' ;
    rdfs:comment 'Boolean flag indicating whether the contact has opted in to receive commercial SMS or text message communications. True if opted in, False if opted out.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleTitle rdf:type rdf:Property ;
    rdfs:label 'Role Title' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceUserCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce User Code' ;
    rdfs:comment 'The Salesforce user ID of the sales representative or account manager responsible for this contact. Links to the internal sales team member managing the relationship.' ;
    rdfs:domain ind:AccountContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'The sales territory or region code to which this contact and their account are assigned. Used for sales force automation and territory management.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountAddressId rdf:type rdf:Property ;
    rdfs:label 'Account Address Id' ;
    rdfs:comment 'Unique identifier for the account address record. Primary key.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountAddress .

ind:accountAddressStatus rdf:type rdf:Property ;
    rdfs:label 'Account Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active addresses are available for transactions; inactive addresses are retained for historical reporting; pending addresses await validation; closed addresses are permanently retired.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine3 rdf:type rdf:Property ;
    rdfs:label 'Address Line 3' ;
    rdfs:comment 'Additional address line for complex addresses, building names, or delivery instructions. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressValidationDate rdf:type rdf:Property ;
    rdfs:label 'Address Validation Date' ;
    rdfs:comment 'Date when the address was last validated against postal authority databases. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Address Validation Status' ;
    rdfs:comment 'Status of address verification against postal authority databases. Validated addresses improve delivery success rates and reduce logistics costs.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountAddressCode rdf:type rdf:Property ;
    rdfs:label 'Account Address Code' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Special instructions for delivery personnel including receiving hours, dock locations, access codes, contact requirements, and handling instructions. Critical for On Time In Full (OTIF) performance.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountAddressDescription rdf:type rdf:Property ;
    rdfs:label 'Account Address Description' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorNumber rdf:type rdf:Property ;
    rdfs:label 'Dock Door Number' ;
    rdfs:comment 'Specific dock door or bay number for deliveries at warehouse or distribution center locations. Used by carriers and Direct Store Delivery (DSD) drivers.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdRouteEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Route Eligible Flag' ;
    rdfs:comment 'Indicates whether this location is eligible for Direct Store Delivery (DSD) routing (True) or requires warehouse distribution (False). Critical for route planning and logistics optimization.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediLocationQualifier rdf:type rdf:Property ;
    rdfs:label 'Edi Location Qualifier' ;
    rdfs:comment 'EDI X12 location qualifier code used in Electronic Data Interchange (EDI) transactions to identify the address role (e.g., ST for ship-to, BT for bill-to, SF for ship-from). Supports automated order processing and Advanced Shipping Notice (ASN) generation.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inactivationReason rdf:type rdf:Property ;
    rdfs:label 'Inactivation Reason' ;
    rdfs:comment 'Business reason for address inactivation (e.g., location closed, address changed, account terminated, consolidation). Used for audit trails and business intelligence.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountAddressName rdf:type rdf:Property ;
    rdfs:label 'Account Address Name' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Address Flag' ;
    rdfs:comment 'Indicates whether this is the primary address for the account (True) or a secondary/alternate address (False). Used for default shipping and billing operations.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Receiving Hours End' ;
    rdfs:comment 'End time for receiving deliveries at this location in 24-hour format (HH:mm). Used for delivery scheduling and On Time In Full (OTIF) compliance.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Receiving Hours Start' ;
    rdfs:comment 'Start time for receiving deliveries at this location in 24-hour format (HH:mm). Used for delivery scheduling and On Time In Full (OTIF) compliance.' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardizedAddressFlag rdf:type rdf:Property ;
    rdfs:label 'Standardized Address Flag' ;
    rdfs:comment 'Indicates whether the address has been standardized to postal authority format (True) or remains in original input format (False).' ;
    rdfs:domain ind:AccountAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction identifier for sales tax, value-added tax (VAT), or goods and services tax (GST) calculation. Used in invoice generation and financial reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique identifier for the account hierarchy relationship record. Primary key.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childAccountTradeAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Account Trade Account Id' ;
    rdfs:comment 'Identifier of the child account in the hierarchy. References the lower-level organizational entity (e.g., store, banner, chain).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAccount .

ind:childTradeAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Trade Account Id' ;
    rdfs:comment 'add column child_trade_account_id (BIGINT) with FK to sales.trade_account.trade_account_id - hierarchy needs explicit child linkage' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAccount .

ind:primaryTradeAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Trade Account Id' ;
    rdfs:comment 'Identifier of the parent account in the hierarchy. References the higher-level organizational entity (e.g., banner, chain, parent corporation).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAccount .

ind:accountHierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Status' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acvRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Acv Rollup Flag' ;
    rdfs:comment 'Indicates whether All Commodity Volume (ACV) metrics should be rolled up from child to parent account. True means include in ACV aggregation; false means exclude. Critical for market coverage and distribution analysis.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Code' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Flag' ;
    rdfs:comment 'Indicates whether financial and operational metrics from the child account should be consolidated into the parent account for reporting purposes. True means consolidate; false means report separately. Critical for All Commodity Volume (ACV), Total Distribution Points (TDP), trade spend, and sales performance roll-ups.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountHierarchyDescription rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Description' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyDepth rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Depth' ;
    rdfs:comment 'Numeric depth of the child account within the hierarchy tree, with 1 representing the top level (parent corporation) and increasing numbers representing deeper levels (chain, banner, store). Used for recursive queries and hierarchy traversal.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Type of organizational hierarchy relationship. Commercial hierarchies support sales and trade promotion roll-ups; logistics hierarchies support distribution and delivery planning; financial hierarchies support invoicing and payment consolidation; reporting hierarchies support management reporting structures; legal hierarchies represent corporate ownership; operational hierarchies support day-to-day execution.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyName rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Name' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of ownership or control the parent account has over the child account. Used for proportional consolidation in financial and operational reporting. Range 0.00 to 100.00.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryHierarchyFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Hierarchy Flag' ;
    rdfs:comment 'Indicates whether this is the primary hierarchical relationship for the child account when multiple hierarchy types exist. True means this is the default hierarchy for reporting and analytics; false means this is a secondary or alternate hierarchy.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipCode rdf:type rdf:Property ;
    rdfs:label 'Relationship Code' ;
    rdfs:comment 'Business code or identifier representing the nature of the parent-child relationship. May include codes for wholly-owned subsidiary, franchise, joint venture, affiliate, or other relationship types specific to the consumer goods trade channel.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipName rdf:type rdf:Property ;
    rdfs:label 'Relationship Name' ;
    rdfs:comment 'Human-readable name or description of the hierarchical relationship. Provides business context for the parent-child linkage (e.g., Regional Banner Group, Corporate Ownership, Distribution Network).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current status of the hierarchical relationship. Active indicates the relationship is currently in effect; inactive indicates the relationship has ended; pending indicates the relationship is awaiting activation; suspended indicates the relationship is temporarily paused; terminated indicates the relationship has been permanently ended.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollupWeight rdf:type rdf:Property ;
    rdfs:label 'Rollup Weight' ;
    rdfs:comment 'Weighting factor applied when rolling up metrics from child to parent account. Used for proportional allocation of All Commodity Volume (ACV), Total Distribution Points (TDP), trade spend, and sales performance when a child account participates in multiple hierarchies or has split ownership.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Sales Rollup Flag' ;
    rdfs:comment 'Indicates whether sales performance metrics should be rolled up from child to parent account. True means include in sales aggregation; false means exclude. Essential for Sales and Operations Planning (S&OP) and Integrated Business Planning (IBP).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tdpRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Tdp Rollup Flag' ;
    rdfs:comment 'Indicates whether Total Distribution Points (TDP) metrics should be rolled up from child to parent account. True means include in TDP aggregation; false means exclude. Essential for numeric distribution and weighted distribution reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeSpendRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Trade Spend Rollup Flag' ;
    rdfs:comment 'Indicates whether trade promotion spending should be rolled up from child to parent account. True means include in trade spend aggregation; false means exclude. Critical for Trade Promotion Management (TPM) and Trade Promotion Optimization (TPO) reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediTradingPartnerId rdf:type rdf:Property ;
    rdfs:label 'Edi Trading Partner Id' ;
    rdfs:comment 'EDI trading partner identifier used for electronic order transmission, invoicing, and Advanced Shipping Notices (ASN).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdiTradingPartner .

ind:storeManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Store Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Required for Store Manager Assignment report linking each store to the responsible employee manager.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acvWeight rdf:type rdf:Property ;
    rdfs:label 'Acv Weight' ;
    rdfs:comment 'All Commodity Volume (ACV) weighting factor representing this stores share of total market volume, used for distribution and market share calculations.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bannerName rdf:type rdf:Property ;
    rdfs:label 'Banner Name' ;
    rdfs:comment 'The retail banner or brand under which this store operates (e.g., Walmart Supercenter, Target, Kroger).' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailStoreCode rdf:type rdf:Property ;
    rdfs:label 'Retail Store Code' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailStoreDescription rdf:type rdf:Property ;
    rdfs:label 'Retail Store Description' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdRouteCode rdf:type rdf:Property ;
    rdfs:label 'Dsd Route Code' ;
    rdfs:comment 'Route code or identifier for Direct Store Delivery (DSD) logistics and delivery scheduling.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Visit Date' ;
    rdfs:comment 'Date of the most recent retail execution visit or sales call to this store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retailStoreName rdf:type rdf:Property ;
    rdfs:label 'Retail Store Name' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledVisitDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Visit Date' ;
    rdfs:comment 'Date of the next planned retail execution visit or sales call to this store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Date when the store first opened for business operations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours for the store (e.g., Mon-Fri 8am-10pm, Sat-Sun 9am-9pm) used for retail execution visit planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osaTargetPct rdf:type rdf:Property ;
    rdfs:label 'Osa Target Pct' ;
    rdfs:comment 'Target On Shelf Availability (OSA) percentage for this store indicating expected in-stock performance for key Stock Keeping Units (SKUs).' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifSlaTargetPct rdf:type rdf:Property ;
    rdfs:label 'Otif Sla Target Pct' ;
    rdfs:comment 'Target On Time In Full (OTIF) service level percentage agreed with this store for delivery performance measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planogramZone rdf:type rdf:Property ;
    rdfs:label 'Planogram Zone' ;
    rdfs:comment 'Planogram zone or cluster assignment indicating which shelf layout and assortment plan applies to this store.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posSystemType rdf:type rdf:Property ;
    rdfs:label 'Pos System Type' ;
    rdfs:comment 'Type or vendor of the Point of Sale (POS) system used at this store for transaction processing and sales data capture.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailStoreStatus rdf:type rdf:Property ;
    rdfs:label 'Retail Store Status' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeFormat rdf:type rdf:Property ;
    rdfs:label 'Store Format' ;
    rdfs:comment 'The retail format classification of the store indicating size, assortment, and operational model. [ENUM-REF-CANDIDATE: hypermarket|supermarket|convenience|club|drug|dollar|specialty|e-commerce_fulfillment_center — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeName rdf:type rdf:Property ;
    rdfs:label 'Store Name' ;
    rdfs:comment 'The official name or designation of the retail store location.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeNumber rdf:type rdf:Property ;
    rdfs:label 'Store Number' ;
    rdfs:comment 'The retailer-assigned unique store number or code used for operational identification and Direct Store Delivery (DSD) routing.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storePhone rdf:type rdf:Property ;
    rdfs:label 'Store Phone' ;
    rdfs:comment 'Primary contact phone number for the retail store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeSizeSqFt rdf:type rdf:Property ;
    rdfs:label 'Store Size Sq Ft' ;
    rdfs:comment 'Total retail selling space of the store measured in square feet, used for All Commodity Volume (ACV) and Total Distribution Points (TDP) calculations.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storeStatus rdf:type rdf:Property ;
    rdfs:label 'Store Status' ;
    rdfs:comment 'Current operational status of the retail store location.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeTier rdf:type rdf:Property ;
    rdfs:label 'Store Tier' ;
    rdfs:comment 'Strategic tier classification (e.g., Tier 1, Tier 2) indicating store importance based on volume, profitability, or strategic value for prioritized retail execution.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdpWeight rdf:type rdf:Property ;
    rdfs:label 'Tdp Weight' ;
    rdfs:comment 'Total Distribution Points (TDP) weighting factor representing this stores contribution to numeric distribution metrics.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingArea rdf:type rdf:Property ;
    rdfs:label 'Trading Area' ;
    rdfs:comment 'Geographic trading area or market designation (e.g., metro area, region) used for sales territory and distribution planning.' ;
    rdfs:domain ind:RetailStore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentSlaHours rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Sla Hours' ;
    rdfs:comment 'The contractual turnaround time (in hours) for Consumer Goods to send functional acknowledgments (997) or business acknowledgments (855) back to the trading partner after receiving an EDI transaction.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:as2Identifier rdf:type rdf:Property ;
    rdfs:label 'As2 Identifier' ;
    rdfs:comment 'The AS2 identifier (AS2-From or AS2-To) used in AS2 message headers when AS2 protocol is in use.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Edi Trading Partner Code' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationProtocol rdf:type rdf:Property ;
    rdfs:label 'Communication Protocol' ;
    rdfs:comment 'The communication protocol used to transmit EDI documents between Consumer Goods and the trading partner (e.g., AS2 for secure internet-based exchange, SFTP for file transfer, VAN for value-added network).' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'The email address of the primary EDI contact at the trading partner for operational communication and issue escalation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'The name of the primary EDI coordinator or technical contact at the trading partner organization responsible for EDI operations and issue resolution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'The phone number of the primary EDI contact at the trading partner for urgent operational issues.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTradingPartnerDescription rdf:type rdf:Property ;
    rdfs:label 'Edi Trading Partner Description' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Required' ;
    rdfs:comment 'Indicates whether EDI transmissions must include digital signatures for non-repudiation (common in AS2 protocol).' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediGoLiveDate rdf:type rdf:Property ;
    rdfs:label 'Edi Go Live Date' ;
    rdfs:comment 'The date when EDI transactions with this trading partner went live in production.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ediPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Edi Partner Code' ;
    rdfs:comment 'The unique EDI partner identifier assigned to the trading partner, used in EDI envelope headers (ISA/GS segments) to route transactions.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediStandard rdf:type rdf:Property ;
    rdfs:label 'Edi Standard' ;
    rdfs:comment 'The EDI messaging standard used for communication with this trading partner (e.g., ANSI X12 for North America, UN/EDIFACT for international).' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTradingPartnerStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Trading Partner Status' ;
    rdfs:comment 'Current operational status of the EDI trading partner configuration (active for live production, testing for certification phase, inactive for discontinued partners, suspended for temporary holds).' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediVersion rdf:type rdf:Property ;
    rdfs:label 'Edi Version' ;
    rdfs:comment 'The specific version of the EDI standard in use (e.g., 004010, 005010 for ANSI X12; D96A, D01B for EDIFACT).' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionRequired rdf:type rdf:Property ;
    rdfs:label 'Encryption Required' ;
    rdfs:comment 'Indicates whether EDI transmissions with this trading partner must be encrypted (e.g., AS2 with encryption, SFTP with SSH).' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentType rdf:type rdf:Property ;
    rdfs:label 'Environment Type' ;
    rdfs:comment 'Indicates whether this EDI configuration is for production transactions, testing/certification, or development purposes.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gsQualifier rdf:type rdf:Property ;
    rdfs:label 'Gs Qualifier' ;
    rdfs:comment 'GS application sender/receiver code qualifier that identifies the type of identification being used in the GS segment.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gsReceiverCode rdf:type rdf:Property ;
    rdfs:label 'Gs Receiver Code' ;
    rdfs:comment 'The application receiver code used in the GS03 segment, identifying the trading partner as the receiver at the functional group level.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gsSenderCode rdf:type rdf:Property ;
    rdfs:label 'Gs Sender Code' ;
    rdfs:comment 'The application sender code used in the GS02 segment, identifying Consumer Goods as the sender at the functional group level.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isaQualifier rdf:type rdf:Property ;
    rdfs:label 'Isa Qualifier' ;
    rdfs:comment 'ISA interchange ID qualifier code that identifies the type of identification being used in the ISA segment (e.g., 01=DUNS, 14=DUNS+4, ZZ=Mutually Defined). [ENUM-REF-CANDIDATE: 01|14|20|27|28|29|30|33|ZZ — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isaReceiverCode rdf:type rdf:Property ;
    rdfs:label 'Isa Receiver Code' ;
    rdfs:comment 'The receiver identification code used in the ISA08 segment of outbound EDI transactions, representing the trading partner receiving the data.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isaSenderCode rdf:type rdf:Property ;
    rdfs:label 'Isa Sender Code' ;
    rdfs:comment 'The sender identification code used in the ISA06 segment of outbound EDI transactions from Consumer Goods to the trading partner.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdnRequested rdf:type rdf:Property ;
    rdfs:label 'Mdn Requested' ;
    rdfs:comment 'Indicates whether Consumer Goods requests a Message Disposition Notification (MDN) receipt from the trading partner when using AS2 protocol.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediTradingPartnerName rdf:type rdf:Property ;
    rdfs:label 'Edi Trading Partner Name' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerIdValue rdf:type rdf:Property ;
    rdfs:label 'Partner Id Value' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerQualifier rdf:type rdf:Property ;
    rdfs:label 'Partner Qualifier' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingSlaHours rdf:type rdf:Property ;
    rdfs:label 'Processing Sla Hours' ;
    rdfs:comment 'The contractual turnaround time (in hours) for Consumer Goods to process inbound EDI transactions (e.g., convert 850 PO into sales order) after receipt.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sftpDirectoryInbound rdf:type rdf:Property ;
    rdfs:label 'Sftp Directory Inbound' ;
    rdfs:comment 'The directory path on the SFTP server where Consumer Goods retrieves inbound EDI files from the trading partner.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sftpDirectoryOutbound rdf:type rdf:Property ;
    rdfs:label 'Sftp Directory Outbound' ;
    rdfs:comment 'The directory path on the SFTP server where Consumer Goods deposits outbound EDI files for the trading partner to retrieve.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sftpHost rdf:type rdf:Property ;
    rdfs:label 'Sftp Host' ;
    rdfs:comment 'The SFTP server hostname or IP address used for file-based EDI exchange when SFTP protocol is in use.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sftpPort rdf:type rdf:Property ;
    rdfs:label 'Sftp Port' ;
    rdfs:comment 'The TCP port number used for SFTP connections (typically 22).' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sftpUsername rdf:type rdf:Property ;
    rdfs:label 'Sftp Username' ;
    rdfs:comment 'The username credential used to authenticate to the trading partner SFTP server.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionSet810Enabled rdf:type rdf:Property ;
    rdfs:label 'Transaction Set 810 Enabled' ;
    rdfs:comment 'Indicates whether Consumer Goods sends 810 Invoice transaction sets to the trading partner for billing.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionSet846Enabled rdf:type rdf:Property ;
    rdfs:label 'Transaction Set 846 Enabled' ;
    rdfs:comment 'Indicates whether inventory position data is exchanged via 846 Inventory Inquiry/Advice transaction sets for Vendor Managed Inventory (VMI) programs.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionSet850Enabled rdf:type rdf:Property ;
    rdfs:label 'Transaction Set 850 Enabled' ;
    rdfs:comment 'Indicates whether the trading partner sends 850 Purchase Order transaction sets to Consumer Goods.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionSet852Enabled rdf:type rdf:Property ;
    rdfs:label 'Transaction Set 852 Enabled' ;
    rdfs:comment 'Indicates whether the trading partner sends 852 Product Activity Data (POS sales data) to Consumer Goods for demand sensing and replenishment.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionSet855Enabled rdf:type rdf:Property ;
    rdfs:label 'Transaction Set 855 Enabled' ;
    rdfs:comment 'Indicates whether Consumer Goods sends 855 Purchase Order Acknowledgment transaction sets back to the trading partner.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionSet856Enabled rdf:type rdf:Property ;
    rdfs:label 'Transaction Set 856 Enabled' ;
    rdfs:comment 'Indicates whether Consumer Goods sends 856 Advanced Ship Notice transaction sets to notify the trading partner of shipments.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionSet867Enabled rdf:type rdf:Property ;
    rdfs:label 'Transaction Set 867 Enabled' ;
    rdfs:comment 'Indicates whether the trading partner sends 867 Product Transfer and Resale Report transaction sets for secondary sales visibility (distributor to retailer).' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionSet997Enabled rdf:type rdf:Property ;
    rdfs:label 'Transaction Set 997 Enabled' ;
    rdfs:comment 'Indicates whether 997 Functional Acknowledgment transaction sets are exchanged to confirm receipt and syntactic validation of EDI documents.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vanMailboxCode rdf:type rdf:Property ;
    rdfs:label 'Van Mailbox Code' ;
    rdfs:comment 'The mailbox identifier assigned by the VAN provider for routing EDI documents to and from the trading partner.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vanProvider rdf:type rdf:Property ;
    rdfs:label 'Van Provider' ;
    rdfs:comment 'The name of the Value-Added Network provider facilitating EDI exchange (e.g., SPS Commerce, TrueCommerce, Cleo) when VAN protocol is in use.' ;
    rdfs:domain ind:EdiTradingPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCustomerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Employee Id' ;
    rdfs:comment 'Reference to the manufacturer employee (demand planner or supply planner) responsible for managing this VMI agreement and executing replenishment decisions.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCustomerModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Customer Modified By User Employee Id' ;
    rdfs:comment 'System user identifier of the person who last modified this VMI agreement record. Supports audit and accountability.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:customerVmiAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Customer Vmi Agreement Code' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the signed legal contract document stored in the document management system (e.g., Veeva Vault, SharePoint).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveredSkuCount rdf:type rdf:Property ;
    rdfs:label 'Covered Sku Count' ;
    rdfs:comment 'Total number of distinct SKUs included in the VMI agreement scope. Used for agreement complexity assessment and system configuration.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerVmiAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Vmi Agreement Status' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerVmiAgreementDescription rdf:type rdf:Property ;
    rdfs:label 'Customer Vmi Agreement Description' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryOwnershipModel rdf:type rdf:Property ;
    rdfs:label 'Inventory Ownership Model' ;
    rdfs:comment 'Defines who owns the inventory at the trade account location: customer-owned (traditional), supplier-owned consignment (ownership transfers at sale), shared risk, or pay-on-scan (ownership transfers at POS scan).' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryVisibilityMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Visibility Method' ;
    rdfs:comment 'Technical method by which the manufacturer receives inventory position data from the trade account: EDI 846 (inventory inquiry/advice), API integration, web portal access, manual reports, WMS integration, or none.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the most recent formal performance review meeting or report for this VMI agreement. Used to track review compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerVmiAgreementName rdf:type rdf:Property ;
    rdfs:label 'Customer Vmi Agreement Name' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Performance Review Date' ;
    rdfs:comment 'Scheduled date for the next formal performance review meeting or report. Drives calendar reminders and preparation workflows.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderTransmissionMethod rdf:type rdf:Property ;
    rdfs:label 'Order Transmission Method' ;
    rdfs:comment 'Method by which replenishment orders are transmitted to the trade account or their systems: EDI 850 (purchase order), API, web portal, email, fax, or manual entry.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmountPerIncident rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Per Incident' ;
    rdfs:comment 'Fixed financial penalty amount charged per SLA violation incident (e.g., per OOS event, per late delivery). Expressed in the agreement currency.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseEnabled rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Enabled' ;
    rdfs:comment 'Indicates whether the VMI agreement includes financial penalties or chargebacks for SLA violations (e.g., missed OTIF targets, excess OOS incidents).' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Performance Review Frequency' ;
    rdfs:comment 'Cadence at which the manufacturer and trade account conduct formal performance reviews of VMI metrics (fill rate, OTIF, inventory turns, OOS incidents).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posDataSharingEnabled rdf:type rdf:Property ;
    rdfs:label 'Pos Data Sharing Enabled' ;
    rdfs:comment 'Indicates whether the trade account shares real-time or near-real-time POS (point of sale) data with the manufacturer to improve demand sensing accuracy.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days advance notice required before the end date to trigger renewal or termination discussions. Typically 30, 60, or 90 days.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skuScopeType rdf:type rdf:Property ;
    rdfs:label 'Sku Scope Type' ;
    rdfs:comment 'Defines the breadth of SKU coverage in the VMI agreement: all SKUs, specific product category, specific brand, explicit SKU list, or custom selection criteria.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetFillRatePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target Fill Rate Percent' ;
    rdfs:comment 'Contractual target for order fill rate (percentage of ordered quantity delivered) that the manufacturer commits to achieve under this VMI agreement. Typically 95-99%.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetOosIncidentsPerMonth rdf:type rdf:Property ;
    rdfs:label 'Sla Target Oos Incidents Per Month' ;
    rdfs:comment 'Maximum allowable number of out-of-stock incidents per month at the trade account location under this VMI agreement. Exceeding this triggers penalty or review clauses.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetOtifPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target Otif Percent' ;
    rdfs:comment 'Contractual target for OTIF (On Time In Full) delivery performance that the manufacturer commits to achieve. Measures both timeliness and completeness of deliveries.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradePartnerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Trade Partner Contact Email' ;
    rdfs:comment 'Email address of the primary trade account contact for VMI communications, forecast sharing, and issue escalation.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradePartnerContactName rdf:type rdf:Property ;
    rdfs:label 'Trade Partner Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the trade account responsible for VMI coordination and issue resolution.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradePartnerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Trade Partner Contact Phone' ;
    rdfs:comment 'Phone number of the primary trade account contact for urgent VMI issues and escalations.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiProgramType rdf:type rdf:Property ;
    rdfs:label 'Vmi Program Type' ;
    rdfs:comment 'Classification of the VMI program model: full VMI (supplier owns inventory decisions), CMI/Co-Managed Inventory (collaborative), consignment (supplier owns inventory until sale), supplier-managed replenishment, continuous replenishment, or vendor-owned inventory.' ;
    rdfs:domain ind:CustomerVmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSlaId rdf:type rdf:Property ;
    rdfs:label 'Account Sla Id' ;
    rdfs:comment 'Unique identifier for the account service level agreement record. Primary key.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Needed for SLA ownership tracking; SLA records must reference the employee managing the account.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountSlaStatus rdf:type rdf:Property ;
    rdfs:label 'Account Sla Status' ;
    rdfs:comment 'Current lifecycle state of the SLA. Draft indicates pending approval; active indicates in force; suspended indicates temporarily paused; expired indicates end date reached; terminated indicates early cancellation; under review indicates renegotiation in progress.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSlaCode rdf:type rdf:Property ;
    rdfs:label 'Account Sla Code' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference to the master commercial contract or trading agreement under which this SLA is governed. Links SLA to broader contractual framework.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSlaDescription rdf:type rdf:Property ;
    rdfs:label 'Account Sla Description' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationProcedure rdf:type rdf:Property ;
    rdfs:label 'Escalation Procedure' ;
    rdfs:comment 'Description of the process and contacts for escalating SLA breaches or disputes. Includes escalation levels, response times, and resolution authority.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionConditions rdf:type rdf:Property ;
    rdfs:label 'Exclusion Conditions' ;
    rdfs:comment 'Description of circumstances under which SLA performance measurement is suspended or penalties waived (e.g., force majeure, natural disasters, customer-caused delays, system outages).' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Target Pct' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveTerms rdf:type rdf:Property ;
    rdfs:label 'Incentive Terms' ;
    rdfs:comment 'Description of rewards or bonuses provided when performance exceeds the target. May include volume bonuses, preferred status, or co-investment in joint initiatives.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPerformanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Performance Threshold' ;
    rdfs:comment 'Lowest acceptable performance level before penalties or escalation are triggered. Typically set below the target to allow for minor variance.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountSlaName rdf:type rdf:Property ;
    rdfs:label 'Account Sla Name' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Team' ;
    rdfs:comment 'Name or identifier of the internal commercial, sales, or customer service team responsible for managing this SLA and the account relationship.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary value of penalty per occurrence or per measurement period when SLA is breached. Nullable if penalty is non-monetary or variable.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Cadence at which SLA performance reports are generated and shared with the account. On-demand indicates ad-hoc reporting upon request. [ENUM-REF-CANDIDATE: daily|weekly|biweekly|monthly|quarterly|annual|on_demand — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaNumber rdf:type rdf:Property ;
    rdfs:label 'Sla Number' ;
    rdfs:comment 'Business identifier for the SLA. Externally-known unique code used in contracts and commercial communications.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'Service tier classification indicating the level of commitment and priority. Higher tiers typically receive more favorable terms, faster response, and stricter performance guarantees.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Category of service level commitment. OTIF (On Time In Full) measures delivery timeliness and completeness; fill rate measures order fulfillment percentage; lead time measures order-to-delivery duration; invoice accuracy measures billing correctness; claims resolution measures dispute handling speed; order accuracy measures picking/shipping correctness.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetricUnit rdf:type rdf:Property ;
    rdfs:label 'Target Metric Unit' ;
    rdfs:comment 'Unit of measure for the target metric value. Percentage for rate-based metrics (OTIF, fill rate, accuracy); days or hours for time-based metrics (lead time, resolution time); count for volume-based metrics; ratio for comparative metrics.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetricValue rdf:type rdf:Property ;
    rdfs:label 'Target Metric Value' ;
    rdfs:comment 'Quantitative performance target that must be achieved. For OTIF this is percentage (e.g., 95.00 for 95%); for lead time this is days; for fill rate this is percentage; for invoice accuracy this is percentage; for claims resolution this is days.' ;
    rdfs:domain ind:AccountSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the SLA before the effective end date.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountSegmentId rdf:type rdf:Property ;
    rdfs:label 'Account Segment Id' ;
    rdfs:comment 'Unique identifier for the account segment record. Primary key.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAccountEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Employee Id' ;
    rdfs:comment 'Identifier of the user or system that assigned this segment classification.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountSegmentStatus rdf:type rdf:Property ;
    rdfs:label 'Account Segment Status' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acvTier rdf:type rdf:Property ;
    rdfs:label 'Acv Tier' ;
    rdfs:comment 'Tier classification based on All Commodity Volume, representing the total retail sales volume of the account across all product categories.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedSalesRegion rdf:type rdf:Property ;
    rdfs:label 'Assigned Sales Region' ;
    rdfs:comment 'Sales region or territory to which this account segment is assigned for field sales coverage and quota allocation.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelTier rdf:type rdf:Property ;
    rdfs:label 'Channel Tier' ;
    rdfs:comment 'Hierarchical tier assignment within the channel, indicating relative importance or volume contribution (tier_1 = highest, tier_4 = lowest).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Account Segment Code' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitTier rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Tier' ;
    rdfs:comment 'Credit limit tier classification for accounts in this segment, determining maximum outstanding receivables allowed.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerTier rdf:type rdf:Property ;
    rdfs:label 'Customer Tier' ;
    rdfs:comment 'Customer value tier assignment based on revenue, volume, or strategic importance (platinum = highest value, standard = baseline).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSegmentDescription rdf:type rdf:Property ;
    rdfs:label 'Account Segment Description' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Eligible Flag' ;
    rdfs:comment 'Indicates whether the account is eligible for Direct Store Delivery, bypassing distribution centers for direct product delivery to retail locations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediTradingPartnerFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Trading Partner Flag' ;
    rdfs:comment 'Indicates whether the account is configured as an EDI trading partner for automated order and invoice exchange.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldSalesCallFrequency rdf:type rdf:Property ;
    rdfs:label 'Field Sales Call Frequency' ;
    rdfs:comment 'Recommended frequency of field sales representative visits based on account segment and strategic priority.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSegmentName rdf:type rdf:Property ;
    rdfs:label 'Account Segment Name' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryChannelCode rdf:type rdf:Property ;
    rdfs:label 'Primary Channel Code' ;
    rdfs:comment 'Code representing the primary channel classification (e.g., RETAIL, FOODSERVICE, WHOLESALE, DTC).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryChannelName rdf:type rdf:Property ;
    rdfs:label 'Primary Channel Name' ;
    rdfs:comment 'Full name of the primary channel (e.g., Retail, Foodservice, Wholesale, Direct to Consumer).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryChannelCode rdf:type rdf:Property ;
    rdfs:label 'Secondary Channel Code' ;
    rdfs:comment 'Code representing the secondary channel sub-classification (e.g., GROCERY, MASS, CLUB, DRUG, CONVENIENCE, ECOMMERCE, QSR, INSTITUTIONAL).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryChannelName rdf:type rdf:Property ;
    rdfs:label 'Secondary Channel Name' ;
    rdfs:comment 'Full name of the secondary channel sub-classification (e.g., Grocery, Mass Merchandiser, Club, Drug, Convenience Store, E-Commerce, Quick Service Restaurant, Institutional).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentAssignmentReason rdf:type rdf:Property ;
    rdfs:label 'Segment Assignment Reason' ;
    rdfs:comment 'Business rationale or trigger for this segment assignment (e.g., annual review, volume threshold met, strategic partnership established).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentTier rdf:type rdf:Property ;
    rdfs:label 'Segment Tier' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentationModelVersion rdf:type rdf:Property ;
    rdfs:label 'Segmentation Model Version' ;
    rdfs:comment 'Version identifier of the segmentation model or algorithm used to assign this segment (e.g., 2024.Q1, V3.2).' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriorityFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Flag' ;
    rdfs:comment 'Indicates whether this account is designated as a strategic priority for executive engagement and resource allocation.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tdpTier rdf:type rdf:Property ;
    rdfs:label 'Tdp Tier' ;
    rdfs:comment 'Tier classification based on Total Distribution Points, representing the weighted distribution reach of the account.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradePromotionEligibility rdf:type rdf:Property ;
    rdfs:label 'Trade Promotion Eligibility' ;
    rdfs:comment 'Eligibility status for trade promotion programs and funding allocation based on segment classification.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Eligible Flag' ;
    rdfs:comment 'Indicates whether the account is eligible for Vendor Managed Inventory programs where the supplier manages inventory replenishment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountAssortmentId rdf:type rdf:Property ;
    rdfs:label 'Account Assortment Id' ;
    rdfs:comment 'Unique identifier for the account assortment record. Primary key for this entity.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountAssortment .

ind:authorizedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Authorized By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Assortment Authorization audit requires linking the approving employee to each assortment entry.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountAssortmentStatus rdf:type rdf:Property ;
    rdfs:label 'Account Assortment Status' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentType rdf:type rdf:Property ;
    rdfs:label 'Assortment Type' ;
    rdfs:comment 'Classification of the assortment item. Core range items are permanent listings; seasonal items are time-bound; promotional items support trade promotions; new items are recent launches; limited edition items are short-run offerings; test market items are regional trials.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'The date when this assortment listing was formally authorized or approved. Used for compliance and audit purposes.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedDistributionPoints rdf:type rdf:Property ;
    rdfs:label 'Authorized Distribution Points' ;
    rdfs:comment 'The number of store locations or distribution points within the account where this SKU is authorized for sale. Used for TDP and ACV calculations.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryRole rdf:type rdf:Property ;
    rdfs:label 'Category Role' ;
    rdfs:comment 'The strategic role this SKU plays in the category assortment. Destination items drive traffic; routine items are everyday purchases; occasional items are infrequent buys; convenience items are impulse purchases.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountAssortmentCode rdf:type rdf:Property ;
    rdfs:label 'Account Assortment Code' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delistDate rdf:type rdf:Property ;
    rdfs:label 'Delist Date' ;
    rdfs:comment 'The date when the product was or will be removed from the authorized assortment. Null for active listings. Used for OSA monitoring and distribution gap analysis.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountAssortmentDescription rdf:type rdf:Property ;
    rdfs:label 'Account Assortment Description' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Flag' ;
    rdfs:comment 'Indicates whether this SKU is delivered via direct store delivery to this account. True if DSD; false if warehouse delivery.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusive Flag' ;
    rdfs:comment 'Indicates whether this SKU is exclusive to this account (not available to other retailers). True if exclusive; false if non-exclusive.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether the audit program is required by regulation or policy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Shipment Date' ;
    rdfs:comment 'The most recent date when this SKU was shipped to this account. Used for on-time in-full (OTIF) tracking and distribution monitoring.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:launchWave rdf:type rdf:Property ;
    rdfs:label 'Launch Wave' ;
    rdfs:comment 'The launch wave or phase identifier for new item introductions. Used to track rollout progress and coordinate new item launch activities.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingDate rdf:type rdf:Property ;
    rdfs:label 'Listing Date' ;
    rdfs:comment 'The date when the product was first authorized for sale to this account. Marks the start of the assortment agreement for this SKU.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listingStatus rdf:type rdf:Property ;
    rdfs:label 'Listing Status' ;
    rdfs:comment 'Current status of the product listing with the account. Listed indicates active authorization; delisted indicates removal from assortment; pending indicates approval in progress; suspended indicates temporary hold; discontinued indicates permanent removal.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqUnit rdf:type rdf:Property ;
    rdfs:label 'Moq Unit' ;
    rdfs:comment 'The unit of measure for the minimum order quantity. Defines whether MOQ is expressed in eaches, cases, pallets, layers, or inner packs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountAssortmentName rdf:type rdf:Property ;
    rdfs:label 'Account Assortment Name' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramSlotCount rdf:type rdf:Property ;
    rdfs:label 'Planogram Slot Count' ;
    rdfs:comment 'The number of shelf facings or slots allocated to this SKU in the retailers planogram. Used for on-shelf availability (OSA) monitoring and space management analysis.' ;
    rdfs:domain ind:AccountAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this assortment item is part of a trade promotion or promotional event. True if promotional; false if regular assortment.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountCreditProfileId rdf:type rdf:Property ;
    rdfs:label 'Account Credit Profile Id' ;
    rdfs:comment 'Unique identifier for the account credit profile record. Primary key.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountCreditProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Account Credit Profile Status' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Available Credit Amount' ;
    rdfs:comment 'Remaining credit capacity available for new orders, calculated as credit limit minus current exposure. Used for order release decisions.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankruptcyFilingDate rdf:type rdf:Property ;
    rdfs:label 'Bankruptcy Filing Date' ;
    rdfs:comment 'Date when the account filed for bankruptcy. Null if no bankruptcy filing exists.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankruptcyFlag rdf:type rdf:Property ;
    rdfs:label 'Bankruptcy Flag' ;
    rdfs:comment 'Indicates whether this account has filed for bankruptcy or is in bankruptcy proceedings. True = bankruptcy status, False = no bankruptcy.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountCreditProfileCode rdf:type rdf:Property ;
    rdfs:label 'Account Credit Profile Code' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAnalystNotes rdf:type rdf:Property ;
    rdfs:label 'Credit Analyst Notes' ;
    rdfs:comment 'Free-text notes from the credit analyst documenting credit decisions, risk factors, payment behavior, disputes, and other relevant credit management information.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldDate rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Date' ;
    rdfs:comment 'Date when the credit hold was placed on this account. Null if no hold is currently active.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditHoldReasonCode rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Reason Code' ;
    rdfs:comment 'Code indicating the reason for credit hold (e.g., OVERLIMIT = exceeded credit limit, PASTDUE = overdue invoices, DISPUTE = payment dispute, BANKRUPTCY = customer bankruptcy filing).' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Status' ;
    rdfs:comment 'Current credit hold status for this account. Active = credit hold in effect, orders blocked; Released = no hold, orders allowed; Manual Review = requires credit analyst approval; Blocked = permanently blocked.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditInsuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Coverage Amount' ;
    rdfs:comment 'Maximum insured amount under the trade credit insurance policy for this account. Null if no insurance coverage exists.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditInsuranceCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Coverage Flag' ;
    rdfs:comment 'Indicates whether this account is covered by trade credit insurance. True = covered, False = not covered.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditInsurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Policy Number' ;
    rdfs:comment 'Policy number for the trade credit insurance covering this account. Null if no insurance coverage exists.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditInsuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Provider' ;
    rdfs:comment 'Name of the trade credit insurance provider (e.g., Euler Hermes, Atradius, Coface). Null if no insurance coverage exists.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the credit limit amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitOverrideExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Override Expiry Date' ;
    rdfs:comment 'Expiration date for a temporary credit limit override. After this date, the credit limit reverts to the standard amount. Null if no override is active.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimitOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Override Flag' ;
    rdfs:comment 'Indicates whether the credit limit has been manually overridden by credit management (e.g., temporary increase for seasonal demand). True = override active, False = standard limit.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimitOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Override Reason' ;
    rdfs:comment 'Business justification for the credit limit override (e.g., \'Seasonal demand increase for Q4 holiday period\', \'Strategic account expansion\').' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Credit Review Date' ;
    rdfs:comment 'Date of the most recent credit review for this account. Credit reviews are typically conducted annually or triggered by significant events (payment default, financial distress).' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditUsed rdf:type rdf:Property ;
    rdfs:label 'Credit Used' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Current Exposure Amount' ;
    rdfs:comment 'Current outstanding receivables balance for this account, including open invoices, unbilled deliveries, and pending orders. Updated in real-time from SAP FI-AR.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountCreditProfileDescription rdf:type rdf:Property ;
    rdfs:label 'Account Credit Profile Description' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsoActualDays rdf:type rdf:Property ;
    rdfs:label 'Dso Actual Days' ;
    rdfs:comment 'Actual DSO (Days Sales Outstanding) for this account over the trailing 90-day period, calculated as (Average Accounts Receivable / Revenue) × Number of Days.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dsoTargetDays rdf:type rdf:Property ;
    rdfs:label 'Dso Target Days' ;
    rdfs:comment 'Target DSO (Days Sales Outstanding) for this account, representing the expected number of days to collect payment. Used for performance monitoring and credit risk assessment.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning level (collection escalation stage) for this account. 0 = no dunning, 1-9 = escalating collection actions. Higher levels indicate more aggressive collection efforts.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalCreditRating rdf:type rdf:Property ;
    rdfs:label 'External Credit Rating' ;
    rdfs:comment 'Credit rating from external credit bureau or rating agency (e.g., Dun & Bradstreet PAYDEX score, Experian rating). Format varies by provider.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCreditScore rdf:type rdf:Property ;
    rdfs:label 'External Credit Score' ;
    rdfs:comment 'Numeric credit score from external credit bureau (e.g., PAYDEX score 0-100, FICO commercial score). Higher scores indicate lower risk.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalCreditRating rdf:type rdf:Property ;
    rdfs:label 'Internal Credit Rating' ;
    rdfs:comment 'Internal credit rating assigned by the company\'s credit analysts based on payment history, financial strength, and business relationship. Scale: AAA (highest) to D (default). [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date of the most recent dunning notice (collection letter) sent to this account. Null if no dunning has occurred.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountCreditProfileName rdf:type rdf:Property ;
    rdfs:label 'Account Credit Profile Name' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCreditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Credit Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic credit review. Used for credit management workflow and compliance with internal credit policy.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethodPreference rdf:type rdf:Property ;
    rdfs:label 'Payment Method Preference' ;
    rdfs:comment 'Preferred payment method for this account. ACH = Automated Clearing House, Wire = wire transfer, Check = paper check, EDI = Electronic Data Interchange payment, Credit Card = corporate credit card.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Description' ;
    rdfs:comment 'Human-readable description of payment terms (e.g., \'Net 30 days\', \'Net 60 days\', \'2% discount if paid within 10 days, net 30\', \'Cash on Delivery\').' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current status of this credit profile record. Active = currently in use, Inactive = historical/superseded, Suspended = temporarily disabled, Under Review = pending credit analyst review.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClass rdf:type rdf:Property ;
    rdfs:label 'Risk Class' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountPricingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Account Pricing Agreement Id' ;
    rdfs:comment 'Unique identifier for the account pricing agreement record. Primary key.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountPricingAgreement .

ind:accountEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Employee Id' ;
    rdfs:comment 'The user ID of the person who most recently modified this pricing agreement record, establishing accountability for changes.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priceListId rdf:type rdf:Property ;
    rdfs:label 'Price List Id' ;
    rdfs:comment 'Reference to the master price list that serves as the base for this agreement. The price list contains SKU-level pricing that may be further adjusted by discounts and rebates defined in this agreement.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:primaryAccountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Manager Employee Id' ;
    rdfs:comment 'The employee ID of the account manager or key account manager responsible for this trade relationship and pricing agreement.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountPricingAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Account Pricing Agreement Status' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name for the pricing agreement, typically including the account name and agreement period for easy identification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether this agreement automatically renews at the end of the effective period. When true, the agreement extends for another term unless either party provides termination notice.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Base Discount Percent' ;
    rdfs:comment 'The negotiated base discount percentage applied to list prices for this account. This is the foundational discount before any volume rebates or promotional allowances.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountPricingAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Account Pricing Agreement Code' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountPricingAgreementDescription rdf:type rdf:Property ;
    rdfs:label 'Account Pricing Agreement Description' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'The distribution channel through which products are sold under this agreement (e.g., retail, foodservice, wholesale, DTC). Different channels may have different pricing structures.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyPaymentDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Percent' ;
    rdfs:comment 'The discount percentage offered if the account pays invoices before the standard payment due date, incentivizing faster payment.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msrpGuidanceAmount rdf:type rdf:Property ;
    rdfs:label 'Msrp Guidance Amount' ;
    rdfs:comment 'The manufacturer\'s suggested retail price for products covered by this agreement. Similar to RSP but typically used for durable goods and higher-value items.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountPricingAgreementName rdf:type rdf:Property ;
    rdfs:label 'Account Pricing Agreement Name' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'The tier level assigned to this account within the pricing hierarchy, determining the base discount level. Higher tiers typically receive better pricing based on volume commitments, strategic importance, or relationship strength.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalAllowanceCapAmount rdf:type rdf:Property ;
    rdfs:label 'Promotional Allowance Cap Amount' ;
    rdfs:comment 'The maximum dollar amount available for promotional allowances during the agreement period. Caps the total promotional funding regardless of purchase volume.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalAllowancePercent rdf:type rdf:Property ;
    rdfs:label 'Promotional Allowance Percent' ;
    rdfs:comment 'The negotiated promotional allowance percentage that the account can apply toward trade promotions, displays, and marketing activities. This is a fund allocation for cooperative marketing efforts.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rspGuidanceAmount rdf:type rdf:Property ;
    rdfs:label 'Rsp Guidance Amount' ;
    rdfs:comment 'The manufacturer\'s recommended selling price guidance provided to the trade account for consumer-facing pricing. This is advisory and not binding, but helps maintain brand positioning and margin expectations.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Code' ;
    rdfs:comment 'The sales organization responsible for managing this pricing agreement. In SAP S/4HANA, this determines the organizational unit that owns the customer relationship and pricing terms.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeRebateEnabled rdf:type rdf:Property ;
    rdfs:label 'Volume Rebate Enabled' ;
    rdfs:comment 'Indicates whether volume-based rebates are active for this agreement. When true, the account qualifies for additional discounts based on purchase volume thresholds.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeRebatePercent1 rdf:type rdf:Property ;
    rdfs:label 'Volume Rebate Percent 1' ;
    rdfs:comment 'The additional rebate percentage applied when volume rebate threshold 1 is met or exceeded.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeRebatePercent2 rdf:type rdf:Property ;
    rdfs:label 'Volume Rebate Percent 2' ;
    rdfs:comment 'The additional rebate percentage applied when volume rebate threshold 2 is met or exceeded.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeRebatePercent3 rdf:type rdf:Property ;
    rdfs:label 'Volume Rebate Percent 3' ;
    rdfs:comment 'The additional rebate percentage applied when volume rebate threshold 3 is met or exceeded.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeRebateThreshold1 rdf:type rdf:Property ;
    rdfs:label 'Volume Rebate Threshold 1' ;
    rdfs:comment 'The first volume threshold (in currency or units) that triggers an additional rebate percentage. Represents the minimum purchase volume required to qualify for the first tier of volume-based discounts.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeRebateThreshold2 rdf:type rdf:Property ;
    rdfs:label 'Volume Rebate Threshold 2' ;
    rdfs:comment 'The second volume threshold that triggers a higher rebate percentage. Represents the purchase volume required to qualify for the second tier of volume-based discounts.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeRebateThreshold3 rdf:type rdf:Property ;
    rdfs:label 'Volume Rebate Threshold 3' ;
    rdfs:comment 'The third volume threshold that triggers the highest rebate percentage. Represents the purchase volume required to qualify for the third tier of volume-based discounts.' ;
    rdfs:domain ind:AccountPricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Account Status History Id' ;
    rdfs:comment 'Unique identifier for each account status change event record. Primary key for the account status history audit trail.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedHistoryAccountStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Reversed History Account Status History Id' ;
    rdfs:comment 'Foreign key reference to the original account_status_history record that this entry reverses or corrects. Null if this is not a reversal entry.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountStatusHistory .

ind:accountStatusHistoryStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status History Status' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByUserName rdf:type rdf:Property ;
    rdfs:label 'Approved By User Name' ;
    rdfs:comment 'Full name of the approver who authorized the status change. Denormalized for audit readability.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeMethod rdf:type rdf:Property ;
    rdfs:label 'Change Method' ;
    rdfs:comment 'The method by which the status change was executed: manual user action, automated workflow, batch process, API call, or EDI transaction. Distinguishes human-initiated vs system-initiated changes.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Business reason for creating this new label version (e.g., \'Regulatory requirement change\', \'Ingredient reformulation\', \'Packaging redesign\', \'Correction of error\').' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Change Source System' ;
    rdfs:comment 'The operational system or application that originated the status change event (e.g., SAP_SD, SALESFORCE_CG_CLOUD, CREDIT_MANAGEMENT_SYSTEM, EDI_GATEWAY). Used for traceability and system integration audit.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedByUserName rdf:type rdf:Property ;
    rdfs:label 'Changed By User Name' ;
    rdfs:comment 'Full name of the user who initiated the status change. Denormalized for audit readability and historical reporting when user records may be archived.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatusHistoryCode rdf:type rdf:Property ;
    rdfs:label 'Account Status History Code' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceViolationCode rdf:type rdf:Property ;
    rdfs:label 'Compliance Violation Code' ;
    rdfs:comment 'Standardized code identifying the specific compliance violation that triggered a compliance hold or suspension. Null if status change is not compliance-related.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAtChange rdf:type rdf:Property ;
    rdfs:label 'Credit Limit At Change' ;
    rdfs:comment 'The credit limit assigned to the trade account at the time of this status change. Captured for historical credit risk analysis and compliance audit. Expressed in the accounts base currency.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysSalesOutstandingAtChange rdf:type rdf:Property ;
    rdfs:label 'Days Sales Outstanding At Change' ;
    rdfs:comment 'The DSO metric for the trade account at the time of status change. Measures average collection period and provides context for payment-related status transitions.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountStatusHistoryDescription rdf:type rdf:Property ;
    rdfs:label 'Account Status History Description' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediControlNumber rdf:type rdf:Property ;
    rdfs:label 'Edi Control Number' ;
    rdfs:comment 'The unique control number of the EDI transaction that triggered or communicated this status change. Used for EDI audit trail and reconciliation. Null for non-EDI status changes.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransactionSet rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Set' ;
    rdfs:comment 'The EDI transaction set code (e.g., 846 Inventory Inquiry, 997 Functional Acknowledgment) associated with this status change if the change was triggered by or communicated via EDI. Null for non-EDI status changes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Hold Release Date' ;
    rdfs:comment 'The scheduled or actual date when a hold status was or will be released. Used for temporary holds with defined resolution timelines. Null for permanent status changes or non-hold statuses.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Specific classification of hold when the new status is a hold state. Distinguishes between credit holds, compliance holds, quality holds, legal holds, and payment holds. Null if status is not a hold state.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatusHistoryName rdf:type rdf:Property ;
    rdfs:label 'Account Status History Name' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The status of the trade account after this change event. Captures the to-state in the account lifecycle transition. [ENUM-REF-CANDIDATE: new|active|on_hold|credit_hold|compliance_hold|suspended|closed|inactive — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'The date and time when the status change notification was sent. Null if no notification was sent or if notification failed.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outstandingBalanceAtChange rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance At Change' ;
    rdfs:comment 'The total outstanding receivables balance for the trade account at the time of this status change. Provides financial context for credit-related status transitions. Expressed in the accounts base currency.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether this status change event must be included in regulatory reporting submissions (e.g., SOX compliance, FDA audit trails, anti-money laundering reports). True if regulatory disclosure is required.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Impact Flag' ;
    rdfs:comment 'Indicates whether this status change affects the accounts SLA terms or service level commitments. True if SLA metrics or obligations are modified by this status transition.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusChangeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the status change (e.g., CREDIT_LIMIT_EXCEEDED, COMPLIANCE_VIOLATION, CUSTOMER_REQUEST, ACCOUNT_CLOSURE, REACTIVATION_APPROVED). Used for categorization and root cause analysis.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of why the account status was changed. Provides context beyond the reason code for audit and compliance purposes.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference identifier or URI to supporting documentation for this status change (e.g., approval memo, compliance report, customer correspondence, legal notice). Used to link audit trail to source documents.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeDate rdf:type rdf:Property ;
    rdfs:label 'Change Date' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountComplianceRecordId rdf:type rdf:Property ;
    rdfs:label 'Account Compliance Record Id' ;
    rdfs:comment 'Unique identifier for the account compliance record. Primary key for this entity.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountComplianceRecord .

ind:environmentalPermitId rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Id' ;
    rdfs:comment 'Foreign key linking to sustainability.environmental_permit. Business justification: Compliance records reference the specific environmental permit governing the account\'s operations for regulatory reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvironmentalPermit .

ind:verifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verified By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Compliance verification reports must capture which employee performed the verification for each record.' ;
    rdfs:domain ind:AccountComplianceRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountComplianceRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Account Compliance Record Status' ;
    rdfs:domain ind:AccountComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Date when the supplier quality assessment was conducted or completed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountComplianceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Account Compliance Record Code' ;
    rdfs:domain ind:AccountComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScope rdf:type rdf:Property ;
    rdfs:label 'Compliance Scope' ;
    rdfs:comment 'Describes the scope or coverage of the compliance record, such as specific product categories, geographic regions, or business activities covered by this license or certification.' ;
    rdfs:domain ind:AccountComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current lifecycle status of the compliance record. Indicates whether the license or certification is currently valid, expired, pending approval, suspended, or revoked.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceType rdf:type rdf:Property ;
    rdfs:label 'Compliance Type' ;
    rdfs:comment 'The category of compliance or regulatory requirement. Defines the nature of the license, certification, or regulatory registration required to conduct business with this trade partner.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountComplianceRecordDescription rdf:type rdf:Property ;
    rdfs:label 'Account Compliance Record Description' ;
    rdfs:domain ind:AccountComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference identifier or URI pointing to the scanned or digital copy of the compliance document stored in the document management system (e.g., Veeva Vault). Enables audit trail and verification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'The name of the governmental body, regulatory agency, or certification organization that issued the license or certification (e.g., FDA, EPA, State Department of Health, EU REACH).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the country in which the issuing authority operates (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Issuing State Province' ;
    rdfs:comment 'The state, province, or regional subdivision within the issuing country where the license or certification was granted. Relevant for jurisdictions with state-level regulatory requirements.' ;
    rdfs:domain ind:AccountComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'The most recent date on which this compliance record was successfully renewed. Nullable if never renewed. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'The unique alphanumeric identifier assigned by the issuing authority for this license, permit, or certification. Used for verification and audit purposes.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountComplianceRecordName rdf:type rdf:Property ;
    rdfs:label 'Account Compliance Record Name' ;
    rdfs:domain ind:AccountComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'The date on which the most recent compliance notification (renewal reminder, expiry alert) was sent. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The date by which the license or certification must be renewed to avoid lapse. Used for proactive compliance monitoring and alerts. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Indicates the current state of the renewal process for this compliance record. Tracks whether renewal is pending, submitted, approved, rejected, or overdue.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Assessment of the business risk associated with non-compliance or lapse of this record. Critical risk indicates that business cannot be conducted without this compliance in place.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderOwningRepId rdf:type rdf:Property ;
    rdfs:label 'Order Owning Rep Id' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:orderSalesRepId rdf:type rdf:Property ;
    rdfs:label 'Order Sales Rep Id' ;
    rdfs:comment 'Reference to the sales representative or account manager who created or owns this order. Used for commission calculation and SFA reporting.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:pricingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Id' ;
    rdfs:comment 'Foreign key linking to sales.pricing_agreement. Business justification: Orders are governed by a pricing agreement; linking captures contract context.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingAgreement .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.territory. Business justification: Directly assigning a territory to an order simplifies reporting and analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:orderCode rdf:type rdf:Property ;
    rdfs:label 'Order Code' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsAmount rdf:type rdf:Property ;
    rdfs:label 'Cogs Amount' ;
    rdfs:comment 'Total cost of goods sold for all items on this order. Used for gross margin calculation and profitability analysis.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by supply chain and logistics based on ATP/CTP availability. Committed date for OTIF tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderDescription rdf:type rdf:Property ;
    rdfs:label 'Order Description' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'The product division or business unit for this order. Used for divisional P&L reporting and product line segmentation.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Freight and shipping charges applied to the order. May be customer-paid or supplier-absorbed depending on terms.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Amount' ;
    rdfs:comment 'Gross profit on the order calculated as total revenue less COGS. Key profitability metric for order-level margin analysis.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderName rdf:type rdf:Property ;
    rdfs:label 'Order Name' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifStatus rdf:type rdf:Property ;
    rdfs:label 'Otif Status' ;
    rdfs:comment 'Indicates whether the order was delivered on time and in full per customer commitment. Key supply chain KPI for customer service measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'The customers purchase order number provided at order placement. Required for EDI transactions and invoice matching.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The delivery date requested by the customer at the time of order placement. Used for OTIF performance measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesOffice rdf:type rdf:Property ;
    rdfs:label 'Sales Office' ;
    rdfs:comment 'The sales office or branch that originated this order. Used for territory management and sales force performance tracking.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganization rdf:type rdf:Property ;
    rdfs:label 'Sales Organization' ;
    rdfs:comment 'The sales organization responsible for this order. Defines the selling entity and organizational hierarchy for reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Document Number' ;
    rdfs:comment 'The native SAP SD sales order document number. Used for system-to-system integration and ERP traceability.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'The transportation mode selected for order delivery. Impacts delivery time, cost, and carrier selection.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for customer-specific delivery instructions, packaging requirements, or handling notes for warehouse and logistics teams.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Unique system identifier for the invoice record. Primary key.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Invoice generation audit needs the employee responsible for creating the invoice to satisfy financial controls.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:invoiceSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Invoice Sales Order Id' ;
    rdfs:comment 'Reference to the originating sales order that this invoice fulfills. Links invoice to order for order-to-cash reconciliation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:sourceOrderId rdf:type rdf:Property ;
    rdfs:label 'Source Order Id' ;
    rdfs:comment 'Foreign key linking to sales.order. Business justification: Linking account call to the order it generated removes need for separate flag and amount fields.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the period covered by this invoice. Used for period-based billing and revenue allocation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this invoice. Relevant for subscription, service, or recurring billing scenarios.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingType rdf:type rdf:Property ;
    rdfs:label 'Billing Type' ;
    rdfs:comment 'Classification of the invoice document type: standard invoice for goods/services, credit memo for returns/adjustments, debit memo for additional charges, proforma for advance notice, intercompany for internal transfers, or consignment for stock-based billing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Timestamp when the invoice was cancelled or voided. Null for active invoices. Used for cancelled invoice reporting and audit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:invoiceCode rdf:type rdf:Property ;
    rdfs:label 'Invoice Code' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfGoodsSoldAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold Amount' ;
    rdfs:comment 'Total standard cost of all products billed on this invoice. Used for gross margin calculation and profitability analysis at invoice level.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysSalesOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Sales Outstanding' ;
    rdfs:comment 'Number of days between invoice date and payment date (or current date if unpaid). Key metric for working capital management and customer payment behavior analysis.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description or notes about the invoice provided by the supplier or entered during processing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Boolean indicator that the customer has raised a dispute or deduction claim against this invoice. Triggers collections hold and dispute resolution workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'Standardized code categorizing the reason for invoice dispute. Enables root cause analysis of deductions and customer dissatisfaction. [ENUM-REF-CANDIDATE: pricing|quantity|quality|delivery|promotion|damaged_goods|not_received — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Edi Document Number' ;
    rdfs:comment 'Unique EDI transaction control number assigned when invoice is transmitted via EDI 810. Used for EDI audit trail and error resolution.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Status' ;
    rdfs:comment 'Status of EDI 810 invoice transmission to customer\'s system. Tracks electronic invoice delivery for large retail and distributor accounts.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Amount' ;
    rdfs:comment 'Total freight, shipping, and logistics charges added to the invoice. May be separately itemized for customer transparency.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total invoice value before any deductions, including all line items, charges, and fees but before trade discounts and taxes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'Three-letter Incoterm code defining the division of costs and risks between buyer and seller (e.g., FOB, CIF, DDP). Critical for international trade invoicing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date the invoice was officially issued to the customer. This is the accounting date used for revenue recognition and aging calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally-visible unique invoice document number used for customer communication, payment reconciliation, and accounts receivable tracking. Typically follows company-specific numbering scheme.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current state of the invoice in the accounts receivable lifecycle. Tracks progression from draft through payment completion or dispute resolution. [ENUM-REF-CANDIDATE: draft|issued|sent|partially_paid|paid|overdue|cancelled|disputed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceName rdf:type rdf:Property ;
    rdfs:label 'Invoice Name' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Final invoice total after all discounts, charges, and taxes. This is the amount due from the customer and recorded in accounts receivable.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'Remaining unpaid balance on the invoice. Calculated as net_amount minus paid_amount. Used for aging analysis and collections prioritization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Cumulative amount received against this invoice across all payment transactions. Used to calculate outstanding balance.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External payment reference number provided by the customer or payment processor for reconciliation. Links invoice to bank statement or remittance advice.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Category' ;
    rdfs:comment 'Classification determining how revenue from this invoice is recognized per accounting standards (ASC 606 / IFRS 15). Drives financial reporting and revenue allocation logic.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Trade Discount Amount' ;
    rdfs:comment 'Total trade promotion discounts, volume rebates, and negotiated price reductions applied at invoice level. Reduces gross amount to arrive at net taxable amount.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseListPrice rdf:type rdf:Property ;
    rdfs:label 'Base List Price' ;
    rdfs:comment 'Standard manufacturer list price before any discounts, allowances, or negotiated reductions are applied.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Code' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedNetPrice rdf:type rdf:Property ;
    rdfs:label 'Contracted Net Price' ;
    rdfs:comment 'Agreed net price per unit after applying all negotiated discounts and allowances as defined in the pricing agreement.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingAgreementDescription rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Description' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount off the base list price granted to the customer under this pricing agreement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'Minimum monetary value required per order to qualify for the contracted pricing terms.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User identifier or name of the person who last modified the pricing agreement record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpPrice rdf:type rdf:Property ;
    rdfs:label 'Msrp Price' ;
    rdfs:comment 'Manufacturer suggested retail price for consumer-facing pricing, used for price positioning and margin calculation.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingAgreementName rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Name' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Price Protection Flag' ;
    rdfs:comment 'Indicates whether the customer is protected from price increases during the agreement period.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the pricing agreement indicating its operational state and enforceability.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productScope rdf:type rdf:Property ;
    rdfs:label 'Product Scope' ;
    rdfs:comment 'Defines the breadth of product coverage: all products, specific product category, individual SKUs, or brand-level pricing.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalAllowance rdf:type rdf:Property ;
    rdfs:label 'Promotional Allowance' ;
    rdfs:comment 'Additional allowance or discount provided to support trade promotions, in-store displays, or marketing activities.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount' ;
    rdfs:comment 'Fixed monetary rebate amount granted per unit or per transaction under the pricing agreement terms.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebatePercentage rdf:type rdf:Property ;
    rdfs:label 'Rebate Percentage' ;
    rdfs:comment 'Percentage rebate granted to the customer upon achieving volume thresholds or other performance criteria defined in the agreement.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rspPrice rdf:type rdf:Property ;
    rdfs:label 'Rsp Price' ;
    rdfs:comment 'Manufacturer recommended selling price to be used by the retailer or distributor at point of sale.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeThresholdQuantity rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Quantity' ;
    rdfs:comment 'Minimum order or cumulative purchase quantity required to qualify for the contracted pricing tier or volume-based discount.' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeThresholdUom rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Uom' ;
    rdfs:comment 'Unit of measure for the volume threshold quantity (e.g., EA for each, CS for case, PAL for pallet).' ;
    rdfs:domain ind:PricingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityAssignedSalesRepId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Assigned Sales Rep Id' ;
    rdfs:comment 'Reference to the sales representative (field sales, key account manager, or territory manager) responsible for managing this opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:opportunityOwningRepId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Owning Rep Id' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:submissionId rdf:type rdf:Property ;
    rdfs:label 'Submission Id' ;
    rdfs:comment 'Foreign key linking to regulatory.submission. Business justification: Sales pipeline tracks regulatory submission status; linking opportunity to submission enables monitoring approval impact on forecast.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Timestamp when this opportunity was marked as closed-won or closed-lost. Null if opportunity is still open. Used for sales cycle duration analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:opportunityCode rdf:type rdf:Property ;
    rdfs:label 'Opportunity Code' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveDisplacementContext rdf:type rdf:Property ;
    rdfs:label 'Competitive Displacement Context' ;
    rdfs:comment 'Description of competitive dynamics: which competitor\'s product(s) this opportunity aims to displace, or whether this is a net-new distribution gain without displacement. Used for competitive intelligence and win/loss analysis.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityDescription rdf:type rdf:Property ;
    rdfs:label 'Opportunity Description' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAcvGain rdf:type rdf:Property ;
    rdfs:label 'Estimated Acv Gain' ;
    rdfs:comment 'Projected gain in ACV (All Commodity Volume) if this opportunity closes successfully. ACV measures the total retail sales volume of stores carrying the product.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedAnnualRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Revenue' ;
    rdfs:comment 'Projected incremental annual revenue from this opportunity if closed-won, in the base currency. Used for pipeline value calculation and sales forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedSkuCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Sku Count' ;
    rdfs:comment 'Number of SKUs (Stock Keeping Units) expected to be authorized or listed if this opportunity closes successfully. Used for distribution point forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedTdpGain rdf:type rdf:Property ;
    rdfs:label 'Estimated Tdp Gain' ;
    rdfs:comment 'Projected gain in TDP (Total Distribution Points) if this opportunity closes successfully. TDP measures the number of stores carrying the product weighted by store importance.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Value' ;
    rdfs:comment 'Estimated total monetary value of the procurement. Used for budget planning, approval routing, and supplier qualification thresholds.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Anticipated date when the opportunity will reach closed-won or closed-lost stage. Used for sales pipeline forecasting and quota planning.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'Fiscal quarter in which the opportunity is expected to close, formatted as \'Q1 2024\', \'Q2 2024\', etc. Used for quarterly sales forecasting and quota tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastCategory rdf:type rdf:Property ;
    rdfs:label 'Forecast Category' ;
    rdfs:comment 'Sales forecast category for pipeline management: pipeline (early stage, low confidence), best_case (possible upside), commit (high confidence, included in quota forecast), or closed (deal finalized).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'Soft-delete flag indicating whether this opportunity record has been logically deleted. True if deleted, False if active. Used for audit trail and data retention compliance.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jbpAlignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Jbp Alignment Flag' ;
    rdfs:comment 'Indicates whether this opportunity is aligned with a formal JBP (Joint Business Planning) agreement with the retailer or distributor. True if aligned, False otherwise.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Origin of the opportunity: inbound inquiry from retailer, field sales prospecting, trade show contact, referral, marketing campaign, or expansion within existing account.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Primary reason for opportunity closure as closed-lost: price (not competitive), product fit (product did not meet needs), competitive loss (lost to competitor), timing (wrong time for buyer), budget constraints, no decision made, or other. Null if not closed-lost. [ENUM-REF-CANDIDATE: price|product_fit|competitive_loss|timing|budget_constraints|no_decision|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Business-friendly name describing the opportunity (e.g., \'Q2 2024 SKU Authorization - Retailer X\', \'New DTC Channel Launch - Product Line Y\').' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStepDescription rdf:type rdf:Property ;
    rdfs:label 'Next Step Description' ;
    rdfs:comment 'Description of the next action or milestone required to advance this opportunity (e.g., \'Schedule buyer meeting\', \'Submit pricing proposal\', \'Finalize contract terms\').' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityStatus rdf:type rdf:Property ;
    rdfs:label 'Opportunity Status' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityType rdf:type rdf:Property ;
    rdfs:label 'Opportunity Type' ;
    rdfs:comment 'Classification of the opportunity by business objective: new retail account acquisition, SKU (Stock Keeping Unit) authorization/listing expansion, new channel entry (e.g., e-commerce, DSD), distribution gain with retailer/distributor, shelf space expansion, or promotional program. [ENUM-REF-CANDIDATE: new_account_acquisition|sku_authorization|sku_listing_expansion|channel_entry|distribution_gain|shelf_space_expansion|promotional_program — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityPct rdf:type rdf:Property ;
    rdfs:label 'Probability Pct' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:probabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Probability Percentage' ;
    rdfs:comment 'Estimated probability of closing this opportunity successfully, expressed as a percentage (0.00 to 100.00). Used for weighted pipeline forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productCategoryFocus rdf:type rdf:Property ;
    rdfs:label 'Product Category Focus' ;
    rdfs:comment 'Primary product category or brand family targeted by this opportunity (e.g., \'Personal Care - Skincare\', \'Household Cleaning\', \'Health & Wellness\'). Free-text field for flexibility.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage in the sales opportunity lifecycle: prospecting (initial contact), qualification (fit assessment), needs analysis (requirements gathering), proposal (offer submitted), negotiation (terms discussion), closed-won (deal secured), or closed-lost (deal not secured). [ENUM-REF-CANDIDATE: prospecting|qualification|needs_analysis|proposal|negotiation|closed_won|closed_lost — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winReason rdf:type rdf:Property ;
    rdfs:label 'Win Reason' ;
    rdfs:comment 'Primary reason for opportunity closure as closed-won: price advantage, product quality, brand strength, relationship with buyer, innovation/differentiation, service level, or other. Null if not closed-won. [ENUM-REF-CANDIDATE: price|product_quality|brand_strength|relationship|innovation|service_level|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountOwningRepId rdf:type rdf:Property ;
    rdfs:label 'Account Owning Rep Id' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:accountSalesRepId rdf:type rdf:Property ;
    rdfs:label 'Account Sales Rep Id' ;
    rdfs:comment 'Reference to the field sales representative who conducted the store visit. Links to workforce employee data.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:accountCallStatus rdf:type rdf:Property ;
    rdfs:label 'Account Call Status' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activitiesCompleted rdf:type rdf:Property ;
    rdfs:label 'Activities Completed' ;
    rdfs:comment 'Summary of activities performed during the store visit, such as shelf audits, order placement, merchandising, training, or promotional setup. Free-text field capturing execution details.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callDate rdf:type rdf:Property ;
    rdfs:label 'Call Date' ;
    rdfs:comment 'The calendar date on which the store visit occurred. Used for daily sales activity tracking and field sales Key Performance Indicator (KPI) reporting.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:callDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Call Duration Minutes' ;
    rdfs:comment 'Total time spent at the store location in minutes. Key metric for field sales productivity analysis and route optimization.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call End Timestamp' ;
    rdfs:comment 'Precise date and time when the sales representative completed the store visit. Used to calculate call duration and productivity metrics.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callNotes rdf:type rdf:Property ;
    rdfs:label 'Call Notes' ;
    rdfs:comment 'Additional free-text notes and observations captured by the sales representative during the store visit. Provides qualitative context for the call record.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callNumber rdf:type rdf:Property ;
    rdfs:label 'Call Number' ;
    rdfs:comment 'Business identifier for the account call, typically generated by the Sales Force Automation (SFA) system. Used for external reference and tracking.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callObjective rdf:type rdf:Property ;
    rdfs:label 'Call Objective' ;
    rdfs:comment 'Primary business objective or goal for the store visit. Free-text description of what the sales representative intended to accomplish during the call.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callOutcome rdf:type rdf:Property ;
    rdfs:label 'Call Outcome' ;
    rdfs:comment 'Overall outcome assessment of the store visit. Indicates whether call objectives were achieved and execution was successful.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call Start Timestamp' ;
    rdfs:comment 'Precise date and time when the sales representative began the store visit. Captured via mobile Sales Force Automation (SFA) application for time-in-store analytics.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callStatus rdf:type rdf:Property ;
    rdfs:label 'Call Status' ;
    rdfs:comment 'Current lifecycle status of the account call. Tracks progression from scheduled visit through completion or cancellation.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callType rdf:type rdf:Property ;
    rdfs:label 'Call Type' ;
    rdfs:comment 'Classification of the account call purpose. Distinguishes between routine visits, promotional activities, merchandising support, compliance audits, New Product Development (NPD) launches, and issue resolution.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCallCode rdf:type rdf:Property ;
    rdfs:label 'Account Call Code' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorActivityObserved rdf:type rdf:Property ;
    rdfs:label 'Competitor Activity Observed' ;
    rdfs:comment 'Free-text notes on competitor promotional activities, new product launches, pricing changes, or merchandising observed during the store visit. Competitive intelligence capture.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorPricingFlag rdf:type rdf:Property ;
    rdfs:label 'Competitor Pricing Flag' ;
    rdfs:comment 'Indicates whether competitor pricing information was collected during the store visit. Used to trigger pricing analysis and response.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionsCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Completed Flag' ;
    rdfs:comment 'Indicates whether identified corrective actions were completed during the same store visit. Tracks immediate issue resolution effectiveness.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Description of corrective actions identified during the visit, such as restocking Out of Stock (OOS) items, fixing Planogram (POG) violations, or addressing pricing discrepancies.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCallDescription rdf:type rdf:Property ;
    rdfs:label 'Account Call Description' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Display Compliance Flag' ;
    rdfs:comment 'Indicates whether promotional displays and secondary placements are set up according to trade promotion agreements and merchandising standards.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayType rdf:type rdf:Property ;
    rdfs:label 'Display Type' ;
    rdfs:comment 'Type of promotional display observed or set up during the store visit. Captures secondary placement strategy execution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facingsActual rdf:type rdf:Property ;
    rdfs:label 'Facings Actual' ;
    rdfs:comment 'Actual number of product facings observed during the store visit. Used to calculate facing compliance and identify shelf space gaps.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facingsRequired rdf:type rdf:Property ;
    rdfs:label 'Facings Required' ;
    rdfs:comment 'Total number of product facings specified in the Planogram (POG) for this store. Represents the target shelf presence.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'Geographic latitude coordinate captured when the call was logged via mobile Sales Force Automation (SFA) application. Used to verify store visit location and route compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'Geographic longitude coordinate captured when the call was logged via mobile Sales Force Automation (SFA) application. Used to verify store visit location and route compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mobileDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Mobile Device Code' ;
    rdfs:comment 'Identifier of the mobile device used to capture the account call record. Used for Sales Force Automation (SFA) system audit and device management.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCallName rdf:type rdf:Property ;
    rdfs:label 'Account Call Name' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCallDate rdf:type rdf:Property ;
    rdfs:label 'Next Call Date' ;
    rdfs:comment 'Scheduled date for the next store visit. Used for call frequency planning and route optimization.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oosItemsCount rdf:type rdf:Property ;
    rdfs:label 'Oos Items Count' ;
    rdfs:comment 'Number of Stock Keeping Units (SKUs) found to be Out of Stock (OOS) during the store visit. Key metric for On Shelf Availability (OSA) tracking.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oosItemsList rdf:type rdf:Property ;
    rdfs:label 'Oos Items List' ;
    rdfs:comment 'Comma-separated list of Stock Keeping Unit (SKU) codes or product names that were Out of Stock (OOS) during the visit. Used for replenishment prioritization.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoEvidenceCount rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Count' ;
    rdfs:comment 'Number of photos captured during the store visit via mobile Sales Force Automation (SFA) application. Used for visual compliance verification and audit trails.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:photoStorageReference rdf:type rdf:Property ;
    rdfs:label 'Photo Storage Reference' ;
    rdfs:comment 'Reference identifier or Uniform Resource Locator (URL) to the location where call photos are stored. Links to external document management or cloud storage system.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pogComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Pog Compliance Score' ;
    rdfs:comment 'Overall compliance score for Planogram (POG) execution at the store, typically expressed as a percentage. Measures how well the actual shelf layout matches the planned POG.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Originally planned date for the store visit. Used to track adherence to call plans and route schedules.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shelfPositionCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Shelf Position Compliant Flag' ;
    rdfs:comment 'Indicates whether products are placed in the correct shelf position as specified in the Planogram (POG). Critical for optimal product visibility and sales.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Captured Flag' ;
    rdfs:comment 'Indicates whether a digital signature was captured from the store contact to confirm the visit and any agreements made. Used for audit and compliance purposes.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureReference rdf:type rdf:Property ;
    rdfs:label 'Signature Reference' ;
    rdfs:comment 'Reference identifier to the stored digital signature image. Links to external document storage system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeContactName rdf:type rdf:Property ;
    rdfs:label 'Store Contact Name' ;
    rdfs:comment 'Name of the store manager or key contact person met during the visit. Used for relationship tracking and follow-up coordination.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syncStatus rdf:type rdf:Property ;
    rdfs:label 'Sync Status' ;
    rdfs:comment 'Synchronization status of the call record between the mobile Sales Force Automation (SFA) application and the central system. Tracks data integration completeness.' ;
    rdfs:domain ind:AccountCall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramComplianceId rdf:type rdf:Property ;
    rdfs:label 'Planogram Compliance Id' ;
    rdfs:comment 'Primary key for planogram_compliance' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Auditor Employee Id' ;
    rdfs:comment 'Reference to the sales representative or merchandiser who conducted the planogram compliance audit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualFacingsCount rdf:type rdf:Property ;
    rdfs:label 'Actual Facings Count' ;
    rdfs:comment 'The actual number of product facings observed during the audit for the audited category or SKU (Stock Keeping Unit).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Audit Duration Minutes' ;
    rdfs:comment 'The total time spent conducting the planogram compliance audit, measured in minutes.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Timestamp' ;
    rdfs:comment 'The precise date and time when the planogram compliance audit was conducted, including time zone information.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'The type of planogram compliance audit conducted (scheduled routine audit, ad hoc spot check, follow-up audit, promotional display audit).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramComplianceCode rdf:type rdf:Property ;
    rdfs:label 'Planogram Compliance Code' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compliancePct rdf:type rdf:Property ;
    rdfs:label 'Compliance Pct' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceTrend rdf:type rdf:Property ;
    rdfs:label 'Compliance Trend' ;
    rdfs:comment 'Indicates the trend in planogram compliance for this account compared to previous audits (improving, stable, declining).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective actions needed to achieve planogram compliance, including specific merchandising tasks.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPriority rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Priority' ;
    rdfs:comment 'The priority level assigned to the corrective action based on business impact and urgency (critical, high, medium, low).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Indicates whether corrective action is required to bring the shelf display into planogram compliance (True = action required, False = no action required).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planogramComplianceDescription rdf:type rdf:Property ;
    rdfs:label 'Planogram Compliance Description' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Display Compliance Score' ;
    rdfs:comment 'Overall compliance score for the planogram audit, typically expressed as a percentage (0.00 to 100.00) indicating adherence to the planogram specifications.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facingsVariance rdf:type rdf:Property ;
    rdfs:label 'Facings Variance' ;
    rdfs:comment 'The difference between required and actual facings count (actual minus required), indicating over- or under-representation on shelf.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planogramComplianceName rdf:type rdf:Property ;
    rdfs:label 'Planogram Compliance Name' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oosSkuList rdf:type rdf:Property ;
    rdfs:label 'Oos Sku List' ;
    rdfs:comment 'Comma-separated list of SKU (Stock Keeping Unit) codes that were identified as out of stock during the audit.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Osa Compliance Flag' ;
    rdfs:comment 'Indicates whether the audit met the minimum On Shelf Availability (OSA) threshold for the category (True = compliant, False = non-compliant).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoCount rdf:type rdf:Property ;
    rdfs:label 'Photo Count' ;
    rdfs:comment 'The number of photos captured during the planogram compliance audit for documentation and evidence purposes.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:photoEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Reference' ;
    rdfs:comment 'Reference identifier or URI to photographic evidence captured during the audit, stored in the document management system.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Planogram Compliance Status' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pogEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Pog Effective Date' ;
    rdfs:comment 'The date from which the audited planogram version became effective at the retail location.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pogVersionCode rdf:type rdf:Property ;
    rdfs:label 'Pog Version Code' ;
    rdfs:comment 'The version identifier of the planogram being audited against, indicating the specific layout and merchandising plan.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousAuditScore rdf:type rdf:Property ;
    rdfs:label 'Previous Audit Score' ;
    rdfs:comment 'The display compliance score from the most recent previous audit for comparison and trend analysis.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredFacingsCount rdf:type rdf:Property ;
    rdfs:label 'Required Facings Count' ;
    rdfs:comment 'The number of product facings (shelf positions) required by the planogram for the audited category or SKU (Stock Keeping Unit).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shelfLevel rdf:type rdf:Property ;
    rdfs:label 'Shelf Level' ;
    rdfs:comment 'The vertical shelf position where the product is placed (eye level, top shelf, middle shelf, bottom shelf, end cap).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeManagerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Store Manager Notified Flag' ;
    rdfs:comment 'Indicates whether the store manager was notified of the planogram compliance findings during or after the audit (True = notified, False = not notified).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unauthorizedSkuList rdf:type rdf:Property ;
    rdfs:label 'Unauthorized Sku List' ;
    rdfs:comment 'Comma-separated list of unauthorized SKU (Stock Keeping Unit) codes found on the shelf that are not part of the approved planogram.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unauthorizedSubstitutionFlag rdf:type rdf:Property ;
    rdfs:label 'Unauthorized Substitution Flag' ;
    rdfs:comment 'Indicates whether unauthorized product substitutions were found in place of the planogram-specified SKUs (Stock Keeping Units) (True = substitutions found, False = no substitutions).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posTransactionId rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Id' ;
    rdfs:comment 'Unique identifier for the point-of-sale transaction record. Primary key for the POS transaction entity.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cashierEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cashier Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: POS transactions record the cashier employee for labor tracking, shift reporting, and audit of sales.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acvFlag rdf:type rdf:Property ;
    rdfs:label 'Acv Flag' ;
    rdfs:comment 'Indicates whether this store is included in the All Commodity Volume (ACV) universe for weighted distribution calculations. Used for Total Distribution Points (TDP) and ACV metrics.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselineSalesFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Sales Flag' ;
    rdfs:comment 'Indicates whether the transaction represents baseline (non-promotional) sales. Used to separate baseline from incremental promotional volume in Trade Promotion Management (TPM) analysis.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Code' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceFileCode rdf:type rdf:Property ;
    rdfs:label 'Data Source File Code' ;
    rdfs:comment 'The identifier of the source data file or feed from which this transaction record was extracted. Used for data lineage and reconciliation.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posTransactionDescription rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Description' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedRetailValue rdf:type rdf:Property ;
    rdfs:label 'Extended Retail Value' ;
    rdfs:comment 'The total retail sales value for this transaction line (units sold multiplied by retail selling price). Core metric for revenue and market share analysis.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketName rdf:type rdf:Property ;
    rdfs:label 'Market Name' ;
    rdfs:comment 'The designated market area or geographic market classification for the store location. Used for market-level Share of Market (SOM) analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posTransactionName rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Name' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfStockFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Stock Flag' ;
    rdfs:comment 'Indicates whether an out-of-stock condition was detected at the store during the transaction period. Used for On-Shelf Availability (OSA) monitoring.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posTransactionStatus rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Status' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'The timestamp when the POS transaction record was processed and loaded into the lakehouse silver layer. Used for data pipeline monitoring.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The granularity or aggregation period of the POS data as provided by the source (e.g., Daily, Weekly, Monthly). Varies by syndicated data provider.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Retail Selling Price' ;
    rdfs:comment 'The per-unit retail price at which the product was sold to the consumer. Used for price compliance monitoring against Recommended Selling Price (RSP) and Manufacturer Suggested Retail Price (MSRP).' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesAmount rdf:type rdf:Property ;
    rdfs:label 'Sales Amount' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'The retailer-specific Stock Keeping Unit code identifying the product variant sold. May differ from manufacturer SKU.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCity rdf:type rdf:Property ;
    rdfs:label 'Store City' ;
    rdfs:comment 'The city where the retail store is located. Used for geographic sales analysis.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCountryCode rdf:type rdf:Property ;
    rdfs:label 'Store Country Code' ;
    rdfs:comment 'The three-letter ISO 3166-1 alpha-3 country code where the retail store is located.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storePostalCode rdf:type rdf:Property ;
    rdfs:label 'Store Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the retail store location. Used for micro-market analysis.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeStateProvince rdf:type rdf:Property ;
    rdfs:label 'Store State Province' ;
    rdfs:comment 'The state or province where the retail store is located. Used for regional sales analysis.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsSold rdf:type rdf:Property ;
    rdfs:label 'Units Sold' ;
    rdfs:comment 'The quantity of product units sold in this transaction. Core metric for demand sensing and sell-through analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weekEndingDate rdf:type rdf:Property ;
    rdfs:label 'Week Ending Date' ;
    rdfs:comment 'The Saturday date marking the end of the reporting week for weekly aggregated POS data. Standard for Nielsen IQ and IRI/Circana weekly reporting.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnOrderId rdf:type rdf:Property ;
    rdfs:label 'Return Order Id' ;
    rdfs:comment 'Unique identifier for the return order record. Primary key.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnOrder .

ind:originatingSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Originating Sales Order Id' ;
    rdfs:comment 'Reference to the original sales order that this return is associated with.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:processedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Processed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Return processing must capture the employee handling the return for accountability and quality control.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:wasteGenerationId rdf:type rdf:Property ;
    rdfs:label 'Waste Generation Id' ;
    rdfs:comment 'Foreign key linking to sustainability.waste_generation. Business justification: Returned goods generate waste; linking return orders to waste generation records enables accurate waste reporting and cost recovery.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteGeneration .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Additional adjustments applied to the return value (e.g., damage deductions, handling fees, promotional credits).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnOrderCode rdf:type rdf:Property ;
    rdfs:label 'Return Order Code' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Issued Date' ;
    rdfs:comment 'Date when the credit memo was officially issued to the customer.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Unique credit memo document number issued for this return in the financial system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoPostedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Posted Date' ;
    rdfs:comment 'Date when the credit memo was posted to the general ledger for financial settlement.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Status' ;
    rdfs:comment 'Current status of the credit memo in the accounts receivable settlement process. [ENUM-REF-CANDIDATE: not_requested|requested|approved|issued|posted|rejected|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerResponsibleFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Responsible Flag' ;
    rdfs:comment 'Indicates whether the customer is financially responsible for the return (True) or the business absorbs the cost (False).' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnOrderDescription rdf:type rdf:Property ;
    rdfs:label 'Return Order Description' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionInstruction rdf:type rdf:Property ;
    rdfs:label 'Disposition Instruction' ;
    rdfs:comment 'Instruction for handling the returned goods based on inspection results and business rules. [ENUM-REF-CANDIDATE: return_to_stock|destroy|rework|donate|quarantine|return_to_vendor|scrap — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Goods Received Date' ;
    rdfs:comment 'Date when the returned goods were physically received at the return processing facility or warehouse.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Completed Date' ;
    rdfs:comment 'Date when quality inspection of the returned goods was completed.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Name of the quality inspector who performed the inspection of returned goods.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Number' ;
    rdfs:comment 'Manufacturing lot or batch number of the returned product for traceability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnOrderName rdf:type rdf:Property ;
    rdfs:label 'Return Order Name' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Original Unit Price' ;
    rdfs:comment 'Original unit price at which the product was sold in the originating sales order.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Result' ;
    rdfs:comment 'Result of the quality inspection performed on the returned goods.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnAmount rdf:type rdf:Property ;
    rdfs:label 'Return Amount' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Date' ;
    rdfs:comment 'Date when the return was officially authorized by the business for processing.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Number' ;
    rdfs:comment 'Externally-known unique authorization number issued for this return request. Format: RMA-XXXXXXXX.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Return Order Status' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnOrderType rdf:type rdf:Property ;
    rdfs:label 'Return Order Type' ;
    rdfs:comment 'Classification of the return based on the originating channel: retail account, distributor, direct-to-consumer, or wholesale.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnRequestDate rdf:type rdf:Property ;
    rdfs:label 'Return Request Date' ;
    rdfs:comment 'Date when the return request was initiated by the customer or account.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnShippingCost rdf:type rdf:Property ;
    rdfs:label 'Return Shipping Cost' ;
    rdfs:comment 'Cost incurred for shipping the returned goods back to the warehouse.' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnValueGross rdf:type rdf:Property ;
    rdfs:label 'Return Value Gross' ;
    rdfs:comment 'Gross monetary value of the returned goods before any deductions (returned quantity × original unit price).' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnValueNet rdf:type rdf:Property ;
    rdfs:label 'Return Value Net' ;
    rdfs:comment 'Net monetary value to be credited to the customer after restocking fees and adjustments (gross - restocking fee - adjustments).' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Quantity of units being returned.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity Uom' ;
    rdfs:comment 'Unit of measure for the returned quantity (EA=Each, CS=Case, PL=Pallet, KG=Kilogram, LB=Pound, L=Liter, GAL=Gallon). [ENUM-REF-CANDIDATE: EA|CS|PL|KG|LB|L|GAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseLocationCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Code' ;
    rdfs:comment 'Code identifying the warehouse or distribution center where the returned goods were received.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCount rdf:type rdf:Property ;
    rdfs:label 'Account Count' ;
    rdfs:comment 'Total number of retail trade accounts assigned to this territory. Used for workload balancing and territory design.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acvCoverage rdf:type rdf:Property ;
    rdfs:label 'Acv Coverage' ;
    rdfs:comment 'Estimated All Commodity Volume (ACV) represented by the retail accounts in this territory, expressed in currency. ACV measures the total sales volume of all products sold through the retail outlets in the territory, used for market potential assessment.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Quota Amount' ;
    rdfs:comment 'Annual sales quota or revenue target assigned to this territory, expressed in the company\'s reporting currency. Used for sales performance management and incentive compensation.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Call Frequency Days' ;
    rdfs:comment 'Standard call frequency in days for sales representative visits to accounts in this territory (e.g., 7 for weekly, 14 for bi-weekly, 30 for monthly). Used for SFA route planning.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelAssignment rdf:type rdf:Property ;
    rdfs:label 'Channel Assignment' ;
    rdfs:comment 'Primary retail channel or trade class that this territory covers. Aligns with consumer goods distribution channels including grocery, drug, mass merchandiser, club, convenience, e-commerce, and Direct-to-Consumer (DTC). [ENUM-REF-CANDIDATE: grocery|drug|mass|club|convenience|e_commerce|foodservice|wholesale|dtc|multi_channel — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Description' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:district rdf:type rdf:Property ;
    rdfs:label 'District' ;
    rdfs:comment 'Mid-level geographic or organizational district within a region. Represents a grouping of territories managed by a district sales manager.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Capability Flag' ;
    rdfs:comment 'Indicates whether the majority of accounts in this territory support Electronic Data Interchange (EDI) for automated order processing, invoicing, and inventory management.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable name of the sales territory, typically reflecting geographic region or account grouping (e.g., \'Northeast Metro\', \'California Key Accounts\').' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pogComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pog Compliance Required Flag' ;
    rdfs:comment 'Indicates whether field sales representatives in this territory are required to monitor and enforce Planogram (POG) compliance for product placement and shelf merchandising.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalCodeList rdf:type rdf:Property ;
    rdfs:label 'Postal Code List' ;
    rdfs:comment 'Comma-separated or structured list of postal codes included in this territory. Used for precise geographic assignment and routing optimization.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quota Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the quota amount (e.g., \'USD\', \'CAD\', \'EUR\').' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceList rdf:type rdf:Property ;
    rdfs:label 'State Province List' ;
    rdfs:comment 'Comma-separated list of states or provinces covered by this territory (e.g., \'NY,NJ,CT\' or \'CA,NV,AZ\'). Used for state-level sales reporting and compliance.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCount rdf:type rdf:Property ;
    rdfs:label 'Store Count' ;
    rdfs:comment 'Total number of retail store locations (points of distribution) within this territory. Key metric for coverage planning and Sales Force Automation (SFA) routing.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tdpCoverage rdf:type rdf:Property ;
    rdfs:label 'Tdp Coverage' ;
    rdfs:comment 'Total Distribution Points (TDP) covered by this territory, representing the number of stores where the company\'s products are authorized for distribution. Critical metric for distribution reach and On-Shelf Availability (OSA).' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the territory. Active territories are operational and assigned to sales representatives; inactive territories are no longer in use; pending territories are being set up.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of the territory based on sales coverage model. Field territories cover geographic regions with multiple accounts; key account territories focus on strategic retail partners; national account territories manage enterprise-wide relationships.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeClass rdf:type rdf:Property ;
    rdfs:label 'Trade Class' ;
    rdfs:comment 'Detailed trade classification or sub-channel segmentation within the primary channel (e.g., \'Supermarket\', \'Drug Chain\', \'Dollar Store\', \'Online Pure Play\'). Used for granular channel analytics.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repId rdf:type rdf:Property ;
    rdfs:label 'Rep Id' ;
    rdfs:comment 'Primary key for rep' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerRepId rdf:type rdf:Property ;
    rdfs:label 'Manager Rep Id' ;
    rdfs:comment 'Reference to the sales representative record of this rep\'s direct manager. Supports hierarchical reporting and approval workflows in the sales organization.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Sales rep\'s position defines role, grade, and compensation; needed for payroll and career path tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:badgeNumber rdf:type rdf:Property ;
    rdfs:label 'Badge Number' ;
    rdfs:comment 'Physical security badge or identification number issued to the sales representative. Used for facility access and field audit verification.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelSpecialization rdf:type rdf:Property ;
    rdfs:label 'Channel Specialization' ;
    rdfs:comment 'Primary sales channel focus for this representative. Retail covers traditional grocery and drug stores; wholesale covers distributors; DTC (Direct to Consumer) covers company-owned stores and online; e-commerce covers digital marketplaces; foodservice covers restaurants and institutions; convenience covers c-stores and gas stations; mass merchandise covers big-box retailers. [ENUM-REF-CANDIDATE: retail|wholesale|dtc|ecommerce|foodservice|convenience|mass_merchandise — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repCode rdf:type rdf:Property ;
    rdfs:label 'Rep Code' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionPlanCode rdf:type rdf:Property ;
    rdfs:label 'Commission Plan Code' ;
    rdfs:comment 'Identifier for the commission or incentive compensation plan assigned to this sales representative. Links to the compensation management system for payout calculation.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Current Quota Amount' ;
    rdfs:comment 'Current sales quota target amount for the active quota period. Measured in the sales organization\'s reporting currency. Used for performance tracking and commission calculation.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repDescription rdf:type rdf:Property ;
    rdfs:label 'Rep Description' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the sales representative was hired into the sales organization. Used for tenure calculations, commission eligibility, and performance benchmarking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Certification Date' ;
    rdfs:comment 'Date the sales representative last completed required certifications or training. Used to track recertification schedules and compliance status.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile phone number of the sales representative. Used for SFA mobile app authentication, emergency contact, and field communication.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repName rdf:type rdf:Property ;
    rdfs:label 'Rep Name' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Most recent performance evaluation rating for the sales representative. Exceeds indicates above-quota performance; meets indicates on-target; below indicates under-performing; new_hire indicates insufficient tenure for rating.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriod rdf:type rdf:Property ;
    rdfs:label 'Quota Period' ;
    rdfs:comment 'Frequency at which sales quotas are assigned and measured for this representative. Monthly quotas are typical for field sales; quarterly for key accounts; annual for national accounts.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repNumber rdf:type rdf:Property ;
    rdfs:label 'Rep Number' ;
    rdfs:comment 'Business identifier for the sales representative, typically assigned by the sales organization. Used in Salesforce Consumer Goods Cloud and SAP S/4HANA SD module for sales force automation and order capture.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repStatus rdf:type rdf:Property ;
    rdfs:label 'Rep Status' ;
    rdfs:comment 'Current lifecycle status of the sales representative. Active reps are assigned territories and quotas; inactive reps are temporarily not selling; on_leave indicates approved absence; suspended indicates disciplinary hold; terminated indicates employment ended.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repType rdf:type rdf:Property ;
    rdfs:label 'Rep Type' ;
    rdfs:comment 'Classification of the sales representative role. Field sales covers territory-based retail execution; key account manager handles strategic retail accounts; national account manager manages top-tier national chains; inside sales supports telesales and e-commerce; DSD (Direct Store Delivery) driver combines delivery and merchandising; regional manager oversees field teams.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesGroup rdf:type rdf:Property ;
    rdfs:label 'Sales Group' ;
    rdfs:comment 'SAP S/4HANA SD sales group code. Represents the functional team or product line focus within the sales organization (e.g., health and beauty, household care, personal care).' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sfaUserCode rdf:type rdf:Property ;
    rdfs:label 'Sfa User Code' ;
    rdfs:comment 'User identifier in the Sales Force Automation system (Salesforce Consumer Goods Cloud). Used to link mobile app activity, retail execution records, and call reports to this sales representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date the sales representative left the organization or was terminated. Null for active employees. Used for historical sales attribution and territory transition analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vehicleAssigned rdf:type rdf:Property ;
    rdfs:label 'Vehicle Assigned' ;
    rdfs:comment 'Indicates whether a company vehicle has been assigned to this sales representative. True for DSD drivers and field sales reps with company cars; false for inside sales and office-based roles.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotaId rdf:type rdf:Property ;
    rdfs:label 'Quota Id' ;
    rdfs:comment 'Unique identifier for the sales quota assignment record.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountTeamId rdf:type rdf:Property ;
    rdfs:label 'Account Team Id' ;
    rdfs:comment 'Identifier of the account team to which this quota is assigned.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountTeam .

ind:quotaOwningRepId rdf:type rdf:Property ;
    rdfs:label 'Quota Owning Rep Id' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:quotaSalesRepId rdf:type rdf:Property ;
    rdfs:label 'Quota Sales Rep Id' ;
    rdfs:comment 'Identifier of the sales representative to whom this quota is assigned.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:acceleratorRate rdf:type rdf:Property ;
    rdfs:label 'Accelerator Rate' ;
    rdfs:comment 'Enhanced commission rate applied when stretch target is exceeded.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaCode rdf:type rdf:Property ;
    rdfs:label 'Quota Code' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'Commission percentage rate applied when quota is achieved.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Customer segment or account classification to which this quota applies (e.g., national accounts, regional chains, independent retailers).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaDescription rdf:type rdf:Property ;
    rdfs:label 'Quota Description' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'Fiscal month within the year (1-12) for which the quota is assigned.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Threshold' ;
    rdfs:comment 'Minimum performance threshold required for quota credit or commission eligibility.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaName rdf:type rdf:Property ;
    rdfs:label 'Quota Name' ;
    rdfs:comment 'Descriptive name for the quota assignment.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:period rdf:type rdf:Property ;
    rdfs:label 'Period' ;
    rdfs:comment 'Fiscal period (month) of the posting within the fiscal year.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaAmount rdf:type rdf:Property ;
    rdfs:label 'Quota Amount' ;
    rdfs:comment 'Annual sales quota assigned to the team, in local currency.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaNumber rdf:type rdf:Property ;
    rdfs:label 'Quota Number' ;
    rdfs:comment 'Business identifier or reference number for the quota assignment.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaStatus rdf:type rdf:Property ;
    rdfs:label 'Quota Status' ;
    rdfs:comment 'Current lifecycle status of the quota assignment. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaType rdf:type rdf:Property ;
    rdfs:label 'Quota Type' ;
    rdfs:comment 'Type of quota being assigned. Revenue = monetary sales target, Volume = unit/case target, New Distribution = new store/outlet target, TDP (Total Distribution Points) = weighted distribution target, ACV (All Commodity Volume) = market coverage target, Unit Sales = individual unit target, Gross Margin = profitability target. [ENUM-REF-CANDIDATE: revenue|volume|new_distribution|tdp|acv|unit_sales|gross_margin — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stretchTarget rdf:type rdf:Property ;
    rdfs:label 'Stretch Target' ;
    rdfs:comment 'Aspirational or stretch goal beyond the base quota value, used for incentive compensation.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionPointId rdf:type rdf:Property ;
    rdfs:label 'Distribution Point Id' ;
    rdfs:comment 'Unique identifier for the distribution point record. Primary key.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Actual Retail Price' ;
    rdfs:comment 'Current actual retail selling price observed at this distribution point, may differ from RSP/MSRP.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acvPercentage rdf:type rdf:Property ;
    rdfs:label 'Acv Percentage' ;
    rdfs:comment 'The ACV percentage contribution of this retail location to the total category volume, used for weighted distribution metrics.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acvWeightedFlag rdf:type rdf:Property ;
    rdfs:label 'Acv Weighted Flag' ;
    rdfs:comment 'Indicates whether this distribution point is included in ACV-weighted distribution calculations (True/False). ACV-weighted stores represent a significant portion of category sales volume.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionPointCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Point Code' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPointDescription rdf:type rdf:Property ;
    rdfs:label 'Distribution Point Description' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionPointStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Point Status' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionSource rdf:type rdf:Property ;
    rdfs:label 'Distribution Source' ;
    rdfs:comment 'Source system or method used to confirm distribution at this point (sell-in confirmed from ERP, POS verified from transaction data, syndicated data from Nielsen/IRI, field audit from sales force, retailer feed from EDI).' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current lifecycle status of the SKU at this distribution point. Active indicates the product is currently distributed and available for sale; authorized indicates approval but not yet active; delisted indicates removal from distribution; inactive indicates temporary suspension.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Verification Date' ;
    rdfs:comment 'Date when the distribution status was last verified or confirmed through the distribution source.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ediEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Enabled Flag' ;
    rdfs:comment 'Indicates whether this distribution point supports EDI transactions for order and inventory management (True/False).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facingCount rdf:type rdf:Property ;
    rdfs:label 'Facing Count' ;
    rdfs:comment 'Number of product facings (front-facing units) allocated to this SKU on the retail shelf at this location.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'Geographic market or region code for this distribution point, used for regional distribution analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPosSaleDate rdf:type rdf:Property ;
    rdfs:label 'Last Pos Sale Date' ;
    rdfs:comment 'Most recent date when a POS transaction was recorded for this SKU at this location, used to verify active distribution.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionPointName rdf:type rdf:Property ;
    rdfs:label 'Distribution Point Name' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osaStatus rdf:type rdf:Property ;
    rdfs:label 'Osa Status' ;
    rdfs:comment 'Current on-shelf availability status of the SKU at this location, indicating whether the product is physically available for purchase.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramSlotReference rdf:type rdf:Property ;
    rdfs:label 'Planogram Slot Reference' ;
    rdfs:comment 'Reference to the planogram slot or shelf position where this SKU is merchandised at the store.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pogComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Pog Compliance Flag' ;
    rdfs:comment 'Indicates whether the SKU placement at this location is compliant with the authorized planogram (True/False).' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfPosition rdf:type rdf:Property ;
    rdfs:label 'Shelf Position' ;
    rdfs:comment 'Vertical and horizontal shelf position classification for the SKU at this location (eye level, top shelf, middle shelf, bottom shelf, end cap, promotional display).' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tdpCountFlag rdf:type rdf:Property ;
    rdfs:label 'Tdp Count Flag' ;
    rdfs:comment 'Indicates whether this distribution point is counted in TDP metrics (True/False). Used to calculate numeric distribution reach.' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vmiFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Flag' ;
    rdfs:comment 'Indicates whether this distribution point operates under a Vendor Managed Inventory agreement (True/False).' ;
    rdfs:domain ind:DistributionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByPriceListId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Price List Id' ;
    rdfs:comment 'Reference to the newer price list that replaces this one when status is superseded. Enables price list succession tracking and historical pricing analysis.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:priceListCode rdf:type rdf:Property ;
    rdfs:label 'Price List Code' ;
    rdfs:comment 'Unique business identifier code for the price list used in SAP SD pricing procedures and condition records. Externally-known identifier used in pricing agreements and sales documents.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListDescription rdf:type rdf:Property ;
    rdfs:label 'Price List Description' ;
    rdfs:comment 'Detailed description of the price list purpose, scope, and applicability including target customer segments and product categories covered.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Freight Inclusion Flag' ;
    rdfs:comment 'Indicates whether freight costs are included in the prices in this list. True when prices are freight-inclusive (delivered pricing), false when prices are ex-works or FOB.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moqUom rdf:type rdf:Property ;
    rdfs:label 'Moq Uom' ;
    rdfs:comment 'Unit of measure for the minimum order quantity threshold. May differ from price UoM to support different ordering and pricing units.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpFlag rdf:type rdf:Property ;
    rdfs:label 'Msrp Flag' ;
    rdfs:comment 'Indicates whether this price list contains manufacturer suggested retail prices (MSRP). True when prices represent official MSRP for consumer-facing pricing and promotional compliance.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceListName rdf:type rdf:Property ;
    rdfs:label 'Price List Name' ;
    rdfs:comment 'Descriptive business name of the price list for identification and reporting purposes.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBasis rdf:type rdf:Property ;
    rdfs:label 'Price Basis' ;
    rdfs:comment 'Pricing methodology or basis used to establish prices in this list. List price indicates standard published pricing, cost plus indicates markup over cost, market based indicates alignment with market rates, competitive indicates positioning relative to competitors, value based indicates pricing tied to customer value perception.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListStatus rdf:type rdf:Property ;
    rdfs:label 'Price List Status' ;
    rdfs:comment 'Current lifecycle status of the price list. Draft indicates under development, pending approval indicates awaiting authorization, active indicates currently in use, inactive indicates temporarily disabled, expired indicates past validity period, superseded indicates replaced by newer version.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListType rdf:type rdf:Property ;
    rdfs:label 'Price List Type' ;
    rdfs:comment 'Classification of the price list by its business purpose and application context. Standard lists provide baseline pricing, promotional lists support time-limited campaigns, contract lists support negotiated agreements, channel-specific lists apply to distribution channels, seasonal lists support seasonal pricing strategies, and clearance lists support inventory liquidation.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceProtectionDays rdf:type rdf:Property ;
    rdfs:label 'Price Protection Days' ;
    rdfs:comment 'Number of days of price protection coverage offered under this price list. Defines the lookback period for retroactive price adjustments when price protection is enabled.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceRoundingRule rdf:type rdf:Property ;
    rdfs:label 'Price Rounding Rule' ;
    rdfs:comment 'Rounding rule applied to calculated prices from this list. Supports psychological pricing strategies and currency denomination constraints.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingConditionType rdf:type rdf:Property ;
    rdfs:label 'Pricing Condition Type' ;
    rdfs:comment 'SAP SD condition type code that defines how prices from this list are applied in pricing procedures (e.g., PR00 for base price, K004 for material price). Links price list to SAP pricing schema configuration.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rspFlag rdf:type rdf:Property ;
    rdfs:label 'Rsp Flag' ;
    rdfs:comment 'Indicates whether this price list contains recommended selling prices (RSP) for retail partners. True when prices represent manufacturer-suggested retail pricing guidance.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Classification' ;
    rdfs:comment 'Tax category or classification code applicable to prices in this list. Determines tax treatment for products priced under this list in compliance with jurisdictional tax regulations.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListItemId rdf:type rdf:Property ;
    rdfs:label 'Price List Item Id' ;
    rdfs:comment 'Unique identifier for the price list item record. Primary key for this entity.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceListItemCode rdf:type rdf:Property ;
    rdfs:label 'Price List Item Code' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'The SAP SD condition type code that defines the pricing logic for this item (e.g., PR00 for base price, K004 for customer discount). Maps to SAP pricing procedure.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPrice rdf:type rdf:Property ;
    rdfs:label 'Cost Price' ;
    rdfs:comment 'The standard cost or COGS for this SKU in the specified currency. Used for margin analysis and profitability calculations. Business-confidential data.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceListItemDescription rdf:type rdf:Property ;
    rdfs:label 'Price List Item Description' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemSequence rdf:type rdf:Property ;
    rdfs:label 'Item Sequence' ;
    rdfs:comment 'Sequential line number of this item within the parent price list. Used for ordering and display purposes.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'The base list price for this SKU in the specified currency and unit of measure. Represents the standard selling price before any discounts or promotions.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginPercentage rdf:type rdf:Property ;
    rdfs:label 'Margin Percentage' ;
    rdfs:comment 'The target gross margin percentage for this price list item, calculated as (list_price - cost_price) / list_price * 100. Business-confidential data.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceListItemName rdf:type rdf:Property ;
    rdfs:label 'Price List Item Name' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this price list item represents a manual override of standard pricing logic. True if this is an exception price.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceListItemStatus rdf:type rdf:Property ;
    rdfs:label 'Price List Item Status' ;
    rdfs:comment 'Current lifecycle status of this price list item. Controls whether the item can be used in pricing calculations.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Pricing Unit Quantity' ;
    rdfs:comment 'The quantity of base units represented by one pricing unit. For example, if price is per case and a case contains 12 units, this value is 12.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapConditionRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Condition Record Number' ;
    rdfs:comment 'The unique SAP SD condition record number for this price list item. Enables traceability back to the source ERP system.' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleBasis rdf:type rdf:Property ;
    rdfs:label 'Scale Basis' ;
    rdfs:comment 'The basis for volume-based pricing scales (e.g., quantity, order value, weight, volume). Defines how tiered pricing thresholds are measured.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleQuantityFrom rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity From' ;
    rdfs:comment 'The lower bound of the quantity range for which this price applies in a tiered pricing structure. Used for volume discount calculations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleQuantityTo rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity To' ;
    rdfs:comment 'The upper bound of the quantity range for which this price applies in a tiered pricing structure. Null indicates no upper limit for the highest tier.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesDeductionId rdf:type rdf:Property ;
    rdfs:label 'Sales Deduction Id' ;
    rdfs:comment 'Unique identifier for the sales deduction record. Primary key.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionDeductionId rdf:type rdf:Property ;
    rdfs:label 'Promotion Deduction Id' ;
    rdfs:comment 'Foreign key linking to promotion.promotion_deduction. Business justification: Audit trail linking sales deductions to their originating promotion deduction is required for compliance and dispute resolution.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromotionDeduction .

ind:agingDays rdf:type rdf:Property ;
    rdfs:label 'Aging Days' ;
    rdfs:comment 'The number of days the deduction has been open since the deduction date, used for aging analysis and collection prioritization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'The amount approved by the business for write-off or credit after review and validation of the deduction claim.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimedAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Amount' ;
    rdfs:comment 'The total amount claimed or deducted by the customer or distributor from the invoice payment.' ;
    rdfs:domain ind:SalesDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesDeductionCode rdf:type rdf:Property ;
    rdfs:label 'Sales Deduction Code' ;
    rdfs:domain ind:SalesDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'The legal entity or company code in the ERP system that owns the accounts receivable and deduction record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'The cost center responsible for absorbing the deduction expense, used for internal cost allocation and management reporting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Reference Number' ;
    rdfs:comment 'The reference number or claim number provided by the customer or distributor for tracking the deduction on their side.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionAmount rdf:type rdf:Property ;
    rdfs:label 'Deduction Amount' ;
    rdfs:comment 'Total deductions taken by the retailer against invoices for this promotion. Used for reconciliation and settlement tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionDate rdf:type rdf:Property ;
    rdfs:label 'Deduction Date' ;
    rdfs:comment 'The date on which the deduction was raised or recorded by the customer or distributor.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deductionNumber rdf:type rdf:Property ;
    rdfs:label 'Deduction Number' ;
    rdfs:comment 'Externally-known unique business identifier for the deduction, often provided by the customer or generated by the accounts receivable system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionStatus rdf:type rdf:Property ;
    rdfs:label 'Deduction Status' ;
    rdfs:comment 'Current lifecycle status of the deduction: open, under review, approved, rejected, written off, or partially approved.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionType rdf:type rdf:Property ;
    rdfs:label 'Deduction Type' ;
    rdfs:comment 'Classification of the deduction reason: trade promotion claim, pricing dispute, shortage claim, quality claim, freight allowance, or damaged goods claim.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesDeductionDescription rdf:type rdf:Property ;
    rdfs:label 'Sales Deduction Description' ;
    rdfs:domain ind:SalesDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'The portion of the claimed amount that is under dispute and has not been approved or rejected.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesDeductionName rdf:type rdf:Property ;
    rdfs:label 'Sales Deduction Name' ;
    rdfs:domain ind:SalesDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Detailed explanation or categorization of the underlying root cause identified during deduction investigation (e.g., system pricing error, promotional terms misalignment, delivery shortage).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesDeductionStatus rdf:type rdf:Property ;
    rdfs:label 'Sales Deduction Status' ;
    rdfs:domain ind:SalesDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapFiDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Document Number' ;
    rdfs:comment 'The SAP FI document number generated when the deduction is posted to the general ledger for financial accounting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Valid Claim Flag' ;
    rdfs:comment 'Indicates whether the deduction claim was determined to be valid based on investigation and supporting documentation.' ;
    rdfs:domain ind:SalesDeduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesRebateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Sales Rebate Agreement Id' ;
    rdfs:comment 'Unique identifier for the sales rebate agreement record. Primary key.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesRebateAgreement .

ind:accrualMethod rdf:type rdf:Property ;
    rdfs:label 'Accrual Method' ;
    rdfs:comment 'Method used to accrue rebate liabilities: at invoice creation, upon payment receipt, at shipment, or periodic batch calculation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accruedRebateAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Rebate Amount' ;
    rdfs:comment 'Total rebate amount accrued to date under this agreement but not yet settled or paid.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'The metric used to calculate rebate eligibility and amounts: revenue value, unit volume, gross sales, or net sales.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRebateAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Sales Rebate Agreement Code' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRebateAgreementDescription rdf:type rdf:Property ;
    rdfs:label 'Sales Rebate Agreement Description' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Last Settlement Date' ;
    rdfs:comment 'Date of the most recent rebate settlement payment made under this agreement.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumRebateAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Rebate Amount' ;
    rdfs:comment 'Cap on the total rebate amount that can be earned under this agreement during its term. Nullable if no cap applies.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumQualificationAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Qualification Amount' ;
    rdfs:comment 'Minimum purchase amount or volume required for the customer to qualify for any rebate under this agreement.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesRebateAgreementName rdf:type rdf:Property ;
    rdfs:label 'Sales Rebate Agreement Name' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebatePct rdf:type rdf:Property ;
    rdfs:label 'Rebate Pct' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateType rdf:type rdf:Property ;
    rdfs:label 'Rebate Type' ;
    rdfs:comment 'Classification of the rebate agreement based on the performance criteria: volume-based, growth-based, new product introduction, category performance, product mix, or customer loyalty.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retroactiveFlag rdf:type rdf:Property ;
    rdfs:label 'Retroactive Flag' ;
    rdfs:comment 'Indicates whether rebate rate increases apply retroactively to all prior purchases when a higher tier is reached.' ;
    rdfs:domain ind:SalesRebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesRebateAgreementStatus rdf:type rdf:Property ;
