    rdfs:comment 'Reference to the cartonization algorithm or business rule used to determine optimal packing configuration.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packTaskCode rdf:type rdf:Property ;
    rdfs:label 'Pack Task Code' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTaskDescription rdf:type rdf:Property ;
    rdfs:label 'Pack Task Description' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationFacilityCode rdf:type rdf:Property ;
