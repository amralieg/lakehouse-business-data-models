    rdfs:comment 'The specific social media platform used when channel is social_share. Enables platform-level referral performance benchmarking. [ENUM-REF-CANDIDATE: facebook|instagram|twitter_x|whatsapp|tiktok|pinterest|snapchat|linkedin|other — promote to reference product]' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

