ind:precautionaryStatements rdf:type rdf:Property ;
    rdfs:label 'Precautionary Statements' ;
    rdfs:comment 'Standardized GHS precautionary statements (P-codes) describing recommended measures to minimize or prevent adverse effects (e.g., P210: Keep away from heat/sparks/open flames).' ;
    rdfs:domain ind:Sds ;
