    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionCode rdf:type rdf:Property ;
    rdfs:label 'Submission Code' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Person Email' ;
    rdfs:comment 'Email address of the internal regulatory affairs contact person for correspondence related to this submission.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Person Phone' ;
    rdfs:comment 'Phone number of the internal regulatory affairs contact person for inquiries related to this submission.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionOutcome rdf:type rdf:Property ;
    rdfs:label 'Decision Outcome' ;
    rdfs:comment 'Final outcome or decision rendered by the regulatory authority (approved, approved with conditions, rejected, withdrawn, pending).' ;
