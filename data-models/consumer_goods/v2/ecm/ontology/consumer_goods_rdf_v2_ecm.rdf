    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Author Employee Id' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accidentalReleaseMeasures rdf:type rdf:Property ;
