ind:dossierName rdf:type rdf:Property ;
    rdfs:label 'Dossier Name' ;
    rdfs:domain ind:Dossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postMarketSurveillanceIncluded rdf:type rdf:Property ;
