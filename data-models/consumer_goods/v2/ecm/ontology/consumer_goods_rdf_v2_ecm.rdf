    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:acknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Date' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Decision Date' ;
    rdfs:comment 'Actual date on which the regulatory authority issued a final decision (approval, rejection, or other outcome) on the submission.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorityJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Authority Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the jurisdiction of the regulatory authority (e.g., USA, DEU, GBR, CAN).' ;
