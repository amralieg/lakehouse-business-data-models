    rdfs:comment 'Primary target audience or consumer segment for the creative asset (e.g., \'Millennials\', \'Parents with young children\', \'Health-conscious consumers\').' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
