    rdfs:range xsd:string .

ind:autoignitionTemperature rdf:type rdf:Property ;
    rdfs:label 'Autoignition Temperature' ;
    rdfs:comment 'Temperature at which the substance will spontaneously ignite without an external ignition source.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsCode rdf:type rdf:Property ;
    rdfs:label 'Sds Code' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsDescription rdf:type rdf:Property ;
    rdfs:label 'Sds Description' ;
