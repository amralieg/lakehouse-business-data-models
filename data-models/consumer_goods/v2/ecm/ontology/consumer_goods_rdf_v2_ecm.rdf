    rdfs:comment 'Name or identifier of the quality manager or authorized personnel who approved the closure of the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingCode rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Code' ;
    rdfs:comment 'Attribute code of quality.audit_finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionSummary rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Summary' ;
    rdfs:comment 'Summary of the corrective actions taken or planned to remediate the finding and prevent recurrence.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingDescription rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Description' ;
    rdfs:comment 'Description value for the Audit Finding record.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
