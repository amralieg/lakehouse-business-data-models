    rdfs:comment 'Total amount for this confirmation line, calculated as confirmed_quantity * unit_price. Used for financial reconciliation and invoice matching.' ;
    rdfs:domain ind:PoConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

