    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentStage rdf:type rdf:Property ;
    rdfs:label 'Current Stage' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rdProjectDescription rdf:type rdf:Property ;
    rdfs:label 'Rd Project Description' ;
    rdfs:domain ind:RdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:desiredBenefits rdf:type rdf:Property ;
