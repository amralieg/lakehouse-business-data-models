    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compilationDate rdf:type rdf:Property ;
    rdfs:label 'Compilation Date' ;
    rdfs:comment 'Date when the dossier compilation was completed and finalized for submission or review.' ;
