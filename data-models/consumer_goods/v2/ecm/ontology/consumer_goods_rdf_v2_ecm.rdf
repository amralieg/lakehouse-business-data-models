ind:regulatoryContactName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Name' ;
    rdfs:comment 'Name of the primary regulatory affairs contact person responsible for this registration. Used for correspondence and regulatory inquiries.' ;
