    rdfs:comment 'Attribute description of quality.gmp_audit.' ;
    rdfs:domain ind:GmpAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingCount rdf:type rdf:Property ;
