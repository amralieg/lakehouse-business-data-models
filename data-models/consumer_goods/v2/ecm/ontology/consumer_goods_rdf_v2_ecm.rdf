    rdfs:range xsd:string .

ind:euReachCompliant rdf:type rdf:Property ;
    rdfs:label 'Eu Reach Compliant' ;
    rdfs:comment 'Indicates whether the packaging material complies with EU REACH regulation for chemical substance registration and restriction.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fdaFoodContactApproved rdf:type rdf:Property ;
    rdfs:label 'Fda Food Contact Approved' ;
    rdfs:comment 'Indicates whether the packaging material is approved for direct food contact per FDA regulations.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formulationCompatibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Formulation Compatibility Status' ;
    rdfs:comment 'Status of compatibility testing between the packaging material and the product formulation, indicating whether the packaging is suitable for the intended product.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecyclable rdf:type rdf:Property ;
    rdfs:label 'Is Recyclable' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialGrade rdf:type rdf:Property ;
    rdfs:label 'Material Grade' ;
    rdfs:comment 'Specific grade or quality designation of the material, including food-grade, pharmaceutical-grade, or recycled content specifications.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchPackagingSpecName rdf:type rdf:Property ;
    rdfs:label 'Research Packaging Spec Name' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prototypeBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Prototype Batch Number' ;
    rdfs:comment 'Batch or lot number of the prototype packaging samples produced for evaluation, linking to physical samples in R&D inventory.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchPackagingSpecStatus rdf:type rdf:Property ;
    rdfs:label 'Research Packaging Spec Status' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tamperEvidentFeature rdf:type rdf:Property ;
    rdfs:label 'Tamper Evident Feature' ;
    rdfs:comment 'Indicates whether the packaging includes tamper-evident features such as breakable seals, shrink bands, or induction seals.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalDrawingReference rdf:type rdf:Property ;
    rdfs:label 'Technical Drawing Reference' ;
    rdfs:comment 'Reference identifier or file path to the detailed technical drawing or CAD file for the packaging component.' ;
    rdfs:domain ind:ResearchPackagingSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Safety Assessment Id' ;
    rdfs:comment 'Primary key for safety_assessment' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Safety Assessor Employee Id' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:safetyResponsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Safety Responsible Employee Id' ;
    rdfs:comment 'Reference to the user who approved the safety assessment for regulatory submission.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersedesAssessmentSafetyAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Assessment Safety Assessment Id' ;
    rdfs:comment 'Reference to the previous safety assessment record that this version supersedes, maintaining audit trail of assessment history.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyAssessment .

ind:applicationFrequency rdf:type rdf:Property ;
    rdfs:label 'Application Frequency' ;
    rdfs:comment 'Recommended frequency of product application (e.g., once daily, twice daily, as needed, weekly).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationSite rdf:type rdf:Property ;
    rdfs:label 'Application Site' ;
    rdfs:comment 'Body site(s) where the product is intended to be applied (e.g., face, hands, scalp, body, mucous membranes).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentCode rdf:type rdf:Property ;
    rdfs:label 'Assessment Code' ;
    rdfs:comment 'Unique business identifier for the safety assessment, used for external reference and regulatory submissions.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentResult rdf:type rdf:Property ;
    rdfs:label 'Assessment Result' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Start Date' ;
    rdfs:comment 'Date on which the safety assessment work commenced.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Full name of the qualified safety assessor who conducted the evaluation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorQualification rdf:type rdf:Property ;
    rdfs:label 'Assessor Qualification' ;
    rdfs:comment 'Professional qualifications and credentials of the safety assessor (e.g., PhD Toxicology, Registered Pharmacist, Diploma in Pharmaceutical Medicine).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Assessor Registration Number' ;
    rdfs:comment 'Professional registration or license number of the safety assessor, as required by regulatory authorities.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyAssessmentCode rdf:type rdf:Property ;
    rdfs:label 'Safety Assessment Code' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conclusion rdf:type rdf:Property ;
    rdfs:label 'Conclusion' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsOfUse rdf:type rdf:Property ;
    rdfs:label 'Conditions Of Use' ;
    rdfs:comment 'Specific conditions under which the product is deemed safe, including application site, frequency, duration, and target population (e.g., adults only, rinse-off only, not for use on damaged skin).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contraindications rdf:type rdf:Property ;
    rdfs:label 'Contraindications' ;
    rdfs:comment 'Specific conditions or populations for which the product should not be used (e.g., not for use on broken skin, avoid if allergic to fragrance, not suitable for children under 3).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpnpNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Cpnp Notification Required' ;
    rdfs:comment 'Flag indicating whether this assessment supports a product requiring notification in the EU CPNP system.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyAssessmentDescription rdf:type rdf:Property ;
    rdfs:label 'Safety Assessment Description' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLocation rdf:type rdf:Property ;
    rdfs:label 'Document Location' ;
    rdfs:comment 'File path or document management system reference where the full safety assessment report is stored (e.g., Veeva Vault document ID).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureDuration rdf:type rdf:Property ;
    rdfs:label 'Exposure Duration' ;
    rdfs:comment 'Duration of product contact with skin or mucous membranes (e.g., rinse-off, leave-on, brief contact).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaRegistrationRequired rdf:type rdf:Property ;
    rdfs:label 'Fda Registration Required' ;
    rdfs:comment 'Flag indicating whether this assessment supports a product requiring FDA registration or notification in the United States.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelWarningsRequired rdf:type rdf:Property ;
    rdfs:label 'Label Warnings Required' ;
    rdfs:comment 'Mandatory label warnings and precautionary statements required based on the safety assessment (e.g., avoid contact with eyes, for external use only, keep out of reach of children).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginOfSafety rdf:type rdf:Property ;
    rdfs:label 'Margin Of Safety' ;
    rdfs:comment 'Calculated margin of safety ratio (NOAEL/SED), indicating the safety buffer between the no observed adverse effect level and systemic exposure dose.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyAssessmentName rdf:type rdf:Property ;
    rdfs:label 'Safety Assessment Name' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of the safety assessment, typically required every 3-5 years or when formulation changes occur.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noaelValue rdf:type rdf:Property ;
    rdfs:label 'Noael Value' ;
    rdfs:comment 'No Observed Adverse Effect Level in mg/kg body weight/day, derived from toxicological studies.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryMarketScope rdf:type rdf:Property ;
    rdfs:label 'Regulatory Market Scope' ;
    rdfs:comment 'Geographic markets and regulatory jurisdictions for which this safety assessment is intended (e.g., EU, USA, ASEAN, China, Brazil).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedSubstancesCompliance rdf:type rdf:Property ;
    rdfs:label 'Restricted Substances Compliance' ;
    rdfs:comment 'Flag indicating whether the formulation complies with all restricted substance regulations (EU Annexes II-VI, FDA prohibited ingredients).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedSubstancesFindings rdf:type rdf:Property ;
    rdfs:label 'Restricted Substances Findings' ;
    rdfs:comment 'Details of any restricted substances identified in the formulation and their compliance status with maximum concentration limits.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyConclusion rdf:type rdf:Property ;
    rdfs:label 'Safety Conclusion' ;
    rdfs:comment 'Overall safety conclusion reached by the assessor: safe for intended use, unsafe, conditionally safe (with restrictions), or insufficient data to conclude.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingStudiesSummary rdf:type rdf:Property ;
    rdfs:label 'Supporting Studies Summary' ;
    rdfs:comment 'Summary of key toxicological and clinical studies used to support the safety assessment, including study types and outcomes.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemicExposureEstimate rdf:type rdf:Property ;
    rdfs:label 'Systemic Exposure Estimate' ;
    rdfs:comment 'Estimated systemic exposure dose in mg/kg body weight/day, calculated from dermal absorption and usage patterns.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPopulation rdf:type rdf:Property ;
    rdfs:label 'Target Population' ;
    rdfs:comment 'Intended consumer population for the product (e.g., adults, children over 3 years, infants, pregnant women, general population).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toxicologicalEndpointsEvaluated rdf:type rdf:Property ;
    rdfs:label 'Toxicological Endpoints Evaluated' ;
    rdfs:comment 'List of toxicological endpoints assessed (e.g., acute toxicity, skin irritation, eye irritation, skin sensitization, repeated dose toxicity, mutagenicity, carcinogenicity, reproductive toxicity).' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toxicologySummary rdf:type rdf:Property ;
    rdfs:label 'Toxicology Summary' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:undesirableEffectsReported rdf:type rdf:Property ;
    rdfs:label 'Undesirable Effects Reported' ;
    rdfs:comment 'Description of any undesirable effects observed in toxicological studies or post-market surveillance that are relevant to the safety assessment.' ;
    rdfs:domain ind:SafetyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleUpTrialId rdf:type rdf:Property ;
    rdfs:label 'Scale Up Trial Id' ;
    rdfs:comment 'Unique identifier for the manufacturing scale-up trial record. Primary key for the scale-up trial entity.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryScaleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Scale Employee Id' ;
    rdfs:comment 'Reference to the manufacturing manager or technical authority who signed off on the scale-up trial and manufacturing readiness.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualOutputKg rdf:type rdf:Property ;
    rdfs:label 'Actual Output Kg' ;
    rdfs:comment 'Actual quantity of finished product produced during the scale-up trial measured in kilograms.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appearanceAssessment rdf:type rdf:Property ;
    rdfs:label 'Appearance Assessment' ;
    rdfs:comment 'Visual evaluation of product appearance including texture, homogeneity, and any defects observed during the trial.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleUpTrialCode rdf:type rdf:Property ;
    rdfs:label 'Scale Up Trial Code' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorMeasurement rdf:type rdf:Property ;
    rdfs:label 'Color Measurement' ;
    rdfs:comment 'Objective color measurement of the scaled-up batch using colorimetry or visual assessment against standard.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleUpTrialDescription rdf:type rdf:Property ;
    rdfs:label 'Scale Up Trial Description' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationDescription rdf:type rdf:Property ;
    rdfs:label 'Deviation Description' ;
    rdfs:comment 'Detailed description of any process deviations, non-conformances, or unexpected observations during the scale-up trial.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Deviation Impact Assessment' ;
    rdfs:comment 'Assessment of the impact of observed deviations on product quality, safety, and manufacturing readiness.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationObservedFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Observed Flag' ;
    rdfs:comment 'Boolean indicator of whether any process deviations from the standard manufacturing procedure were observed during the trial.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentConfiguration rdf:type rdf:Property ;
    rdfs:label 'Equipment Configuration' ;
    rdfs:comment 'Description of the manufacturing equipment setup used during the trial, including mixer type, vessel capacity, and auxiliary equipment.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heatingRateCelsiusPerMin rdf:type rdf:Property ;
    rdfs:label 'Heating Rate Celsius Per Min' ;
    rdfs:comment 'Rate at which the batch was heated during processing, important for thermal-sensitive formulations.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inProcessTestResults rdf:type rdf:Property ;
    rdfs:label 'In Process Test Results' ;
    rdfs:comment 'Summary of all in-process quality control tests performed during the scale-up trial, including pass/fail status for each checkpoint.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingReadinessLevel rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Readiness Level' ;
    rdfs:comment 'Assessment of manufacturing readiness for commercial production based on trial outcomes and technology transfer completion.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingSignOffDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Sign Off Date' ;
    rdfs:comment 'Date when manufacturing operations formally approved the scale-up trial results and confirmed readiness for commercial production.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mixingSpeedRpm rdf:type rdf:Property ;
    rdfs:label 'Mixing Speed Rpm' ;
    rdfs:comment 'Rotational speed of the mixing equipment during the trial, critical process parameter for scale-up consistency.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scaleUpTrialName rdf:type rdf:Property ;
    rdfs:label 'Scale Up Trial Name' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextSteps rdf:type rdf:Property ;
    rdfs:label 'Next Steps' ;
    rdfs:comment 'Documented next actions required following the scale-up trial, such as additional trials, process optimization, or commercial launch preparation.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odorAssessment rdf:type rdf:Property ;
    rdfs:label 'Odor Assessment' ;
    rdfs:comment 'Sensory evaluation of the product fragrance and odor profile compared to bench-scale formulation.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderOfAddition rdf:type rdf:Property ;
    rdfs:label 'Order Of Addition' ;
    rdfs:comment 'Documented sequence in which raw materials and ingredients were added during the manufacturing process, critical for formulation reproducibility.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailRationale rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Rationale' ;
    rdfs:comment 'Detailed justification for the trial status decision, including quality assessment, process performance, and readiness for commercial production.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Process Temperature Celsius' ;
    rdfs:comment 'Target processing temperature maintained during the scale-up trial, critical for formulation stability and quality.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualitySignOffDate rdf:type rdf:Property ;
    rdfs:label 'Quality Sign Off Date' ;
    rdfs:comment 'Date when quality assurance formally approved the scale-up trial results and confirmed product quality meets specifications.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scaleFactor rdf:type rdf:Property ;
    rdfs:label 'Scale Factor' ;
    rdfs:comment 'Multiplication factor representing the scale-up ratio from bench scale to pilot or commercial scale (e.g., 10x, 100x, 1000x).' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleUpTrialStatus rdf:type rdf:Property ;
    rdfs:label 'Scale Up Trial Status' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyTransferChecklistStatus rdf:type rdf:Property ;
    rdfs:label 'Technology Transfer Checklist Status' ;
    rdfs:comment 'Completion status of the formal technology transfer checklist documenting all required activities and sign-offs.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialCode rdf:type rdf:Property ;
    rdfs:label 'Trial Code' ;
    rdfs:comment 'Business identifier code assigned to the scale-up trial for external reference and tracking across R&D and manufacturing systems.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialCostAmount rdf:type rdf:Property ;
    rdfs:label 'Trial Cost Amount' ;
    rdfs:comment 'Total cost incurred for conducting the scale-up trial including raw materials, labor, equipment time, and testing.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trialDate rdf:type rdf:Property ;
    rdfs:label 'Trial Date' ;
    rdfs:comment 'The date on which the scale-up trial was conducted at the manufacturing facility.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialStatus rdf:type rdf:Property ;
    rdfs:label 'Trial Status' ;
    rdfs:comment 'Overall outcome status of the scale-up trial: pass (successful), fail (unsuccessful), conditional_pass (passed with minor issues), in_progress (ongoing), or cancelled.' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialType rdf:type rdf:Property ;
    rdfs:label 'Trial Type' ;
    rdfs:comment 'Classification of the scale-up trial based on production scale: pilot (small-scale test), semi-commercial (intermediate scale), commercial (full production scale), or validation (qualification run).' ;
    rdfs:domain ind:ScaleUpTrial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendedStudyProtocolId rdf:type rdf:Property ;
    rdfs:label 'Amended Study Protocol Id' ;
    rdfs:comment 'Self-referencing FK on study_protocol (amended_study_protocol_id)' ;
    rdfs:domain ind:StudyProtocol ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyProtocol .

ind:studyAuthorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Study Author Employee Id' ;
    rdfs:domain ind:StudyProtocol ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:studyResponsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Study Responsible Employee Id' ;
    rdfs:comment 'Unique identifier for the sponsor entity.' ;
    rdfs:domain ind:StudyProtocol ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date on which the amendment became effective.' ;
    rdfs:domain ind:StudyProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential number of the amendment applied to the protocol.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blinding rdf:type rdf:Property ;
    rdfs:label 'Blinding' ;
    rdfs:comment 'Degree of masking applied in the study.' ;
    rdfs:domain ind:StudyProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyProtocolCode rdf:type rdf:Property ;
    rdfs:label 'Study Protocol Code' ;
    rdfs:domain ind:StudyProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Creation Timestamp' ;
    rdfs:comment 'Timestamp when the protocol record was first created in the system.' ;
    rdfs:domain ind:StudyProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataRetentionPeriod rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period' ;
    rdfs:comment 'Number of days the study data must be retained after completion.' ;
