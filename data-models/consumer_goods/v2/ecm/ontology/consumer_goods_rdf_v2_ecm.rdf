ind:contentCategory rdf:type rdf:Property ;
    rdfs:label 'Content Category' ;
    rdfs:comment 'Business category or use case of the creative asset (TV commercial, digital banner, social media, print ad, packaging visual, influencer brief, blog post, email content, landing page, infographic). [ENUM-REF-CANDIDATE: tv_commercial|digital_banner|social_media|print_ad|packaging_visual|influencer_brief|blog_post|email_content|landing_page|infographic — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentFormat rdf:type rdf:Property ;
    rdfs:label 'Content Format' ;
    rdfs:comment 'Specific file format or content format of the asset (e.g., MP4, JPEG, PNG, PDF, GIF, HTML5).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentStatus rdf:type rdf:Property ;
    rdfs:label 'Content Status' ;
    rdfs:comment 'Current publishing lifecycle status of the creative asset (planned, scheduled, published, archived, withdrawn).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAgencyName rdf:type rdf:Property ;
    rdfs:label 'Creative Agency Name' ;
    rdfs:comment 'Name of the external creative agency or partner that produced the creative asset.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAssetStatus rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Status' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Dam Reference Code' ;
    rdfs:comment 'Unique identifier or reference code in the Digital Asset Management system where the asset is stored.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAssetDescription rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Description' ;
    rdfs:comment 'Detailed textual description of the creative asset content, purpose, and key messaging.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileReference rdf:type rdf:Property ;
    rdfs:label 'File Reference' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
