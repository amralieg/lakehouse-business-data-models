    rdfs:comment 'Date by which the audited facility must submit a formal response to audit findings, including corrective and preventive actions (CAPA).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Actual date when the facility submitted its formal response to the audit findings.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalFindingsCount rdf:type rdf:Property ;
