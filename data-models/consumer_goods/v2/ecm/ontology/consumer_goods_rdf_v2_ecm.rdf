    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calculationType rdf:type rdf:Property ;
    rdfs:label 'Calculation Type' ;
    rdfs:comment 'Method used to calculate the condition value (fixed amount, percentage, quantity-based scale, value-based scale).' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceConditionCode rdf:type rdf:Property ;
    rdfs:label 'Price Condition Code' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionClass rdf:type rdf:Property ;
    rdfs:label 'Condition Class' ;
    rdfs:comment 'High-level classification of the condition (price, discount, surcharge, freight, tax) for grouping and reporting purposes.' ;
