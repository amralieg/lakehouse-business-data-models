ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for placing the product under regulatory hold. [ENUM-REF-CANDIDATE: contamination|labeling_error|stability_failure|microbial_excursion|foreign_material|potency_deviation|regulatory_inspection|consumer_complaint|supplier_issue — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
