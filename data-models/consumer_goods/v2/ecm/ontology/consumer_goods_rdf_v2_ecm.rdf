    rdfs:range ind:ManufacturingBom .

ind:manufacturingSkuId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Sku Id' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:primaryManufacturingSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Manufacturing Sku Id' ;
    rdfs:comment 'Reference to the finished good or semi-finished SKU that this BOM defines. Links to the product master for which this material structure applies.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:allergenFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Flag' ;
    rdfs:comment 'Indicates whether this component contains or may contain allergens as defined by FDA and EU REACH regulations. True if allergen present. Used for product labeling, consumer safety warnings, and regulatory compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternativeItemPriority rdf:type rdf:Property ;
    rdfs:label 'Alternative Item Priority' ;
    rdfs:comment 'The selection priority for this component within its alternative item group. Lower numbers indicate higher priority. Used by MRP to determine preferred material selection when multiple alternatives are available.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Indicates whether this component is automatically consumed (backflushed) when the finished good is confirmed in the MES system, rather than requiring explicit material issue transactions. True if backflushed. Common for high-volume, low-value components.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the base quantity (e.g., EA for each, KG for kilogram, L for liter, BOX for box). Must align with the SKU primary UOM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM. Active BOMs are used for production planning and MRP runs. Inactive or obsolete BOMs are retained for historical reference and regulatory traceability.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomVersion rdf:type rdf:Property ;
    rdfs:label 'Bom Version' ;
    rdfs:comment 'Version of the bill of materials used for this batch. Ensures traceability of raw material specifications.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentEffectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Component Effective End Date' ;
    rdfs:comment 'The date after which this specific component is no longer valid within the BOM structure. Nullable for open-ended components. Used for material phase-out and supplier transition management.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:componentEffectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Component Effective Start Date' ;
    rdfs:comment 'The date from which this specific component becomes valid within the BOM structure. Supports phased material transitions, supplier changes, and cost optimization initiatives.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:componentItemCategory rdf:type rdf:Property ;
    rdfs:label 'Component Item Category' ;
    rdfs:comment 'Classification of the component type. Stock items are inventory-managed materials, non-stock are direct procurement items, phantom are intermediate assemblies not physically stocked, text items are instructions, and variable size items have flexible dimensions.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentQuantity rdf:type rdf:Property ;
    rdfs:label 'Component Quantity' ;
    rdfs:comment 'The quantity of this component required to produce the base quantity of the finished good. Used for MRP explosion, production order material requirements, and COGS calculation.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Component Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the component quantity (e.g., KG for raw materials, EA for packaging units, L for liquids). Must align with the component material master UOM.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Percentage' ;
    rdfs:comment 'The percentage of total product cost attributed to this component. Used for COGS calculation, profitability analysis, and cost optimization initiatives. Sum of all component cost allocations should equal 100% for the BOM.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalComponentFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Component Flag' ;
    rdfs:comment 'Indicates whether this component is critical for product quality, safety, or regulatory compliance. True if critical. Triggers enhanced quality control, supplier qualification requirements, and inventory safety stock policies.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotSizeRequirement rdf:type rdf:Property ;
    rdfs:label 'Lot Size Requirement' ;
    rdfs:comment 'Defines the lot sizing rule for this component in production orders. Exact requires precise quantity, minimum allows overages, multiple requires quantities in specific increments, none has no restriction. Impacts material planning and waste management.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingBomStatus rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Bom Status' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumLotSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Lot Size' ;
    rdfs:comment 'The minimum quantity that must be procured or produced for this component. Driven by supplier MOQ, production batch constraints, or economic order quantity calculations. Nullable if no minimum applies.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plmSystemReference rdf:type rdf:Property ;
    rdfs:label 'Plm System Reference' ;
    rdfs:comment 'External reference identifier linking this BOM to the source PLM system record. Enables traceability to engineering change orders, formulation documents, and R&D specifications.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text field capturing regulatory compliance requirements, restrictions, or special handling instructions for this component. Includes FDA registration numbers, EU REACH compliance status, GMP requirements, and safety data sheet references.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapFactorPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Percentage' ;
    rdfs:comment 'The expected waste or loss percentage for this component during production. Used to adjust gross material requirements in MRP runs. Typical values range from 0% to 10% depending on material type and process complexity.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Unique identifier for the production routing master record. Primary key.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:primaryRoutingCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Routing Created By User Employee Id' ;
    rdfs:comment 'User identifier of the person who created this routing record. Supports audit trail and data lineage.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRoutingLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Routing Last Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person who last modified this routing record. Supports audit trail and change tracking.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:changeoverTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Time Minutes' ;
    rdfs:comment 'Time required to transition production lines from the previous product to this routing. Critical for production scheduling and minimizing downtime.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingDescription rdf:type rdf:Property ;
    rdfs:label 'Routing Description' ;
    rdfs:comment 'Detailed textual description of the routing, including its purpose, scope, and any special instructions for production planners and shop floor operators.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedScrapPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Scrap Percentage' ;
    rdfs:comment 'Overall expected scrap percentage for the routing, representing anticipated waste or defects. Used for material planning and cost estimation.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Yield Percentage' ;
    rdfs:comment 'Overall expected yield percentage for the routing, representing the ratio of good output to total input. Used for production planning and variance analysis.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Critical Flag' ;
    rdfs:comment 'Indicates whether this routing includes GMP-critical operations requiring enhanced documentation, validation, and compliance controls per ISO 22716 and FDA regulations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipcCheckpointCount rdf:type rdf:Property ;
    rdfs:label 'Ipc Checkpoint Count' ;
    rdfs:comment 'Number of in-process control checkpoints defined in this routing. IPC checkpoints are quality inspection points during production per ISO 22716 and GMP requirements.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotSizeRestriction rdf:type rdf:Property ;
    rdfs:label 'Lot Size Restriction' ;
    rdfs:comment 'Constraint on production lot sizes for this routing. Fixed requires exact base quantity; minimum/maximum define bounds; multiple requires lot sizes to be multiples of base quantity; none allows any lot size.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumLotSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Lot Size' ;
    rdfs:comment 'Maximum production lot size allowed for this routing. Nullable if no maximum constraint exists.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationCount rdf:type rdf:Property ;
    rdfs:label 'Operation Count' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationDescription rdf:type rdf:Property ;
    rdfs:label 'Operation Description' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationSequence rdf:type rdf:Property ;
    rdfs:label 'Operation Sequence' ;
    rdfs:comment 'JSON array or delimited string capturing the complete sequence of operation steps. Each operation includes: operation_number, work_center_code, operation_description, control_key (internal_processing|external_processing|milestone), setup_time_minutes, machine_time_minutes, labor_time_minutes, yield_quantity, scrap_percentage, gmp_critical_step_flag, ipc_checkpoint_flag. This is the single authoritative source for all routing operation data — no separate operation entity exists.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionSchedulerCode rdf:type rdf:Property ;
    rdfs:label 'Production Scheduler Code' ;
    rdfs:comment 'Code identifying the production scheduling strategy or algorithm used for this routing (e.g., forward scheduling, backward scheduling, finite capacity).' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Business identifier for the routing. Externally-known unique code used in production planning and scheduling systems.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Status' ;
    rdfs:comment 'Current lifecycle status of the routing. Active routings are available for production scheduling; draft routings are under development; inactive routings are temporarily disabled; obsolete routings are retired; under_review routings are pending approval.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingType rdf:type rdf:Property ;
    rdfs:label 'Routing Type' ;
    rdfs:comment 'Classification of the routing defining its usage pattern. Standard routings are default production paths; reference routings are templates; rate routings define production rates; alternative routings provide backup paths; special routings are for one-time or custom production runs.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingVersion rdf:type rdf:Property ;
    rdfs:label 'Routing Version' ;
    rdfs:comment 'Version of the production routing used for this batch. Documents the manufacturing process steps executed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runTimePerUnitMinutes rdf:type rdf:Property ;
    rdfs:label 'Run Time Per Unit Minutes' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCostAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Amount' ;
    rdfs:comment 'Standard production cost per base quantity for this routing, including labor, machine, and overhead costs. Used for cost accounting and variance analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLaborTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Labor Time Minutes' ;
    rdfs:comment 'Cumulative labor time across all operations in the routing, used for workforce planning and standard cost calculation.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMachineTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Machine Time Minutes' ;
    rdfs:comment 'Cumulative machine processing time across all operations in the routing, used for capacity planning and Overall Equipment Effectiveness (OEE) calculations.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSetupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Setup Time Minutes' ;
    rdfs:comment 'Cumulative setup time across all operations in the routing, used for capacity planning and scheduling.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStandardLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Standard Lead Time Hours' ;
    rdfs:comment 'Total cumulative lead time in hours required to complete all operations in this routing, including setup, processing, and queue times. Used for Material Requirements Planning (MRP) and capacity planning.' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStandardTimeMin rdf:type rdf:Property ;
    rdfs:label 'Total Standard Time Min' ;
    rdfs:domain ind:Routing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Order Id' ;
    rdfs:comment 'Unique identifier for the production order. Primary key for the production order entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:inspectionPlanId rdf:type rdf:Property ;
    rdfs:label 'Inspection Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_plan. Business justification: Production orders trigger an inspection plan; linking allows the order execution system to retrieve the exact inspection plan governing sampling and testing for that batch.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionPlan .

ind:salesOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Id' ;
    rdfs:comment 'Foreign key linking to sales.order. Business justification: Order fulfillment process requires linking each production order to the originating sales order to track manufacturing against sales commitments.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual cost incurred for the production order. Includes material, labor, and overhead costs. Used for variance analysis.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEnd rdf:type rdf:Property ;
    rdfs:label 'Actual End' ;
    rdfs:comment 'Actual end datetime' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date when the audit fieldwork was completed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Timestamp' ;
    rdfs:comment 'Actual date and time when production execution completed. Used for OEE calculation and performance analysis.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStart rdf:type rdf:Property ;
    rdfs:label 'Actual Start' ;
    rdfs:comment 'Actual start datetime' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when the audit commenced on-site or remotely.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when production execution began on the shop floor. Captured from MES system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Unique batch or lot number assigned to the production run. Critical for traceability and recall management per GMP requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'Actual quantity produced and confirmed as good output. Represents yield after quality inspection.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costObject rdf:type rdf:Property ;
    rdfs:label 'Cost Object' ;
    rdfs:comment 'Cost object (production order number or process order) used for collecting actual costs. Links to CO-PC product costing.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Minutes' ;
    rdfs:comment 'Total unplanned downtime in minutes during production execution. Impacts OEE availability component.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'Inspection lot number created for quality control of the production output. Links to QM inspection results.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpController rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller' ;
    rdfs:comment 'Three-character code identifying the MRP controller responsible for planning this material. Links to planner master data.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeePercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Percentage' ;
    rdfs:comment 'Overall Equipment Effectiveness percentage for this production run. Calculated as Availability × Performance × Quality. Industry standard KPI.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business identifier for the production order. Externally-known unique order number assigned by SAP S/4HANA PP system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Quantity' ;
    rdfs:comment 'Planned quantity to be produced in base unit of measure. Target output for the production order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the production order. CRTD=Created, REL=Released, PCNF=Partially Confirmed, TECO=Technically Complete, CNF=Confirmed, DLV=Delivered, CLSD=Closed. [ENUM-REF-CANDIDATE: CRTD|REL|PCNF|TECO|CNF|DLV|CLSD — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of production order. PP01=Standard Production, PP03=Rework, PP05=Co-Product, PP10=Process Order, PP20=Batch Order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCost rdf:type rdf:Property ;
    rdfs:label 'Planned Cost' ;
    rdfs:comment 'Standard or planned cost for producing the order quantity. Calculated from BOM and routing costs.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'The quantity of the SKU planned to be produced or procured in this order, expressed in the base unit of measure.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level for production scheduling. 1=Highest priority (rush/expedite), 5=Lowest priority (standard). Used for sequencing and resource allocation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionSupervisor rdf:type rdf:Property ;
    rdfs:label 'Production Supervisor' ;
    rdfs:comment 'Name of the production supervisor responsible for overseeing execution of this order on the shop floor.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Indicates whether quality inspection is mandatory before goods receipt. Drives QM integration and inspection lot creation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releasedBy rdf:type rdf:Property ;
    rdfs:label 'Released By' ;
    rdfs:comment 'User ID of the person who released the production order for execution. Audit trail for production authorization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'Date and time when the production order was released for shop floor execution. Triggers material availability check and capacity reservation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledEnd rdf:type rdf:Property ;
    rdfs:label 'Scheduled End' ;
    rdfs:comment 'Scheduled end datetime' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned end date for the audit as communicated to the facility.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledFinishDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Date' ;
    rdfs:comment 'Planned date when production is scheduled to complete. Used for capacity planning and delivery commitments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStart rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start' ;
    rdfs:comment 'Scheduled start datetime' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date when production is scheduled to begin. Set during production planning and MRP run.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'Quantity of material scrapped or rejected during production. Used for yield analysis and cost accounting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementRule rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule' ;
    rdfs:comment 'Rule for settling production order costs. FUL=Full settlement, PAR=Partial settlement, PER=Periodic settlement.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'Actual yield percentage calculated as (confirmed_quantity / order_quantity) * 100. Key performance metric for production efficiency.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchRecordId rdf:type rdf:Property ;
    rdfs:label 'Batch Record Id' ;
    rdfs:comment 'Unique identifier for the electronic batch manufacturing record (eBMR). Primary key for GMP-compliant batch traceability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:carbonOffsetId rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Id' ;
    rdfs:comment 'Foreign key linking to sustainability.carbon_offset. Business justification: Batch-level carbon neutrality uses purchased offsets; linking batch to offset record provides traceability and reporting of offset usage.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarbonOffset .

ind:primaryBatchEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Batch Employee Id' ;
    rdfs:comment 'Reference to the quality assurance personnel who performed final batch release. Links to workforce master data.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Batch-to-PO traceability is needed for audit, recall, and cost allocation linking each manufactured batch to its sourcing PO.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Actual cost per unit incurred for this batch. Includes material, labor, and overhead variances.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizeActual rdf:type rdf:Property ;
    rdfs:label 'Batch Size Actual' ;
    rdfs:comment 'Actual production quantity achieved for this batch. Used for yield calculation and inventory reconciliation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizePlanned rdf:type rdf:Property ;
    rdfs:label 'Batch Size Planned' ;
    rdfs:comment 'Planned production quantity for this batch as specified in the production order. Measured in base unit of measure.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the batch. Controls inventory availability and distribution eligibility per GMP workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Minutes' ;
    rdfs:comment 'Time in minutes required for line changeover before this batch. Key metric for SMED and lean manufacturing initiatives.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:electronicSignatureCount rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Count' ;
    rdfs:comment 'Number of electronic signatures captured during batch record lifecycle. Required for FDA 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Gmp Deviation Count' ;
    rdfs:comment 'Number of GMP deviations recorded for this batch. Used for quality trend analysis and CAPA tracking.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Deviation Flag' ;
    rdfs:comment 'Indicates whether any GMP deviations were recorded during batch production. Triggers quality review workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpReviewed rdf:type rdf:Property ;
    rdfs:label 'Gmp Reviewed' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotBatchId rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Id' ;
    rdfs:comment 'Foreign key linking to inventory.lot_batch. Business justification: Regulatory traceability: links each production batch to its inventory lot batch for recall investigations and quality audits.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotBatch .

ind:lotGenealogyCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Lot Genealogy Complete Flag' ;
    rdfs:comment 'Indicates whether complete raw material lot traceability has been captured for this batch. Required for recall readiness.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Attribute manufacture_date of quality.batch_release.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturedQuantity rdf:type rdf:Property ;
    rdfs:label 'Manufactured Quantity' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'Calendar date of batch production. Printed on product packaging for consumer information and regulatory compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing End Timestamp' ;
    rdfs:comment 'Date and time when batch production was completed and final packaging finished. Used for cycle time analysis.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manufacturingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Start Timestamp' ;
    rdfs:comment 'Date and time when batch production was initiated on the shop floor. Captured from MES system.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Release Flag' ;
    rdfs:comment 'Indicates whether the batch has been released by Quality Assurance for distribution. Required before inventory availability.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Quality Release Timestamp' ;
    rdfs:comment 'Date and time when Quality Assurance approved the batch for release. Marks transition from quarantine to available inventory.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityProduced rdf:type rdf:Property ;
    rdfs:label 'Quantity Produced' ;
    rdfs:comment 'The total quantity of product manufactured in this lot or batch, measured in the base unit of measure.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether this batch is subject to a product recall. Triggers supply chain hold and customer notification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Recall Initiated Date' ;
    rdfs:comment 'Date when recall was initiated for this batch. Used for regulatory reporting and recall effectiveness tracking.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordLockedFlag rdf:type rdf:Property ;
    rdfs:label 'Record Locked Flag' ;
    rdfs:comment 'Indicates whether this batch record is locked from further edits. Required for GMP record integrity after quality release.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether batch is on regulatory hold pending investigation or approval. Prevents distribution until cleared.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the batch was officially released for distribution and sale. Marks the point at which product becomes available to promise (ATP).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:released rdf:type rdf:Property ;
    rdfs:label 'Released' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewByException rdf:type rdf:Property ;
    rdfs:label 'Review By Exception' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reworkQuantity rdf:type rdf:Property ;
    rdfs:label 'Rework Quantity' ;
    rdfs:comment 'Quantity of product requiring rework during batch production. Indicator of process capability and quality issues.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:veevaVaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Reference' ;
    rdfs:comment 'Reference to the master batch record document stored in Veeva Vault. Links to regulatory document management system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeRecordId rdf:type rdf:Property ;
    rdfs:label 'Oee Record Id' ;
    rdfs:comment 'Unique identifier for the OEE measurement record. Primary key for the OEE record entity.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOeeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Oee Employee Id' ;
    rdfs:comment 'Identifier of the supervisor responsible for the production shift.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Actual Cycle Time Seconds' ;
    rdfs:comment 'Average actual time in seconds to produce one unit during the shift, calculated as Actual Operating Time / Total Units Produced.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualOperatingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Operating Time Minutes' ;
    rdfs:comment 'Actual time the production line was operating during the shift in minutes, after subtracting unplanned downtime.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualRuntimeMin rdf:type rdf:Property ;
    rdfs:label 'Actual Runtime Min' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availabilityPct rdf:type rdf:Property ;
    rdfs:label 'Availability Pct' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availabilityRate rdf:type rdf:Property ;
    rdfs:label 'Availability Rate' ;
    rdfs:comment 'Percentage of planned production time that the line was actually operating, calculated as (Planned Production Time - Downtime) / Planned Production Time. Component of OEE calculation.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeoverCount rdf:type rdf:Property ;
    rdfs:label 'Changeover Count' ;
    rdfs:comment 'Number of product or format changeovers performed during the shift. Impacts availability and performance metrics.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Method by which OEE data was captured (automated from sensors, manual entry, or semi-automated).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodUnitsProduced rdf:type rdf:Property ;
    rdfs:label 'Good Units Produced' ;
    rdfs:comment 'Count of units that passed quality inspection and met specifications, calculated as Total Units Produced - Total Units Rejected.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:idealCycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Ideal Cycle Time Seconds' ;
    rdfs:comment 'Theoretical minimum time in seconds to produce one unit at maximum design speed under optimal conditions.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesDataSource rdf:type rdf:Property ;
    rdfs:label 'Mes Data Source' ;
    rdfs:comment 'Source system identifier for the OEE data, typically Siemens Opcenter MES or equivalent system.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:microStopCount rdf:type rdf:Property ;
    rdfs:label 'Micro Stop Count' ;
    rdfs:comment 'Number of brief stoppages (typically under 5 minutes) that impact performance but may not be classified as downtime.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oeePct rdf:type rdf:Property ;
    rdfs:label 'Oee Pct' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeStatus rdf:type rdf:Property ;
    rdfs:label 'Oee Status' ;
    rdfs:comment 'Current lifecycle status of the OEE record indicating validation and approval state.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorCount rdf:type rdf:Property ;
    rdfs:label 'Operator Count' ;
    rdfs:comment 'Number of operators assigned to the production line during the shift.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performancePct rdf:type rdf:Property ;
    rdfs:label 'Performance Pct' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceRate rdf:type rdf:Property ;
    rdfs:label 'Performance Rate' ;
    rdfs:comment 'Percentage of ideal production speed achieved, calculated as (Ideal Cycle Time × Total Units Produced) / Actual Operating Time. Component of OEE calculation.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedProductionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Production Time Minutes' ;
    rdfs:comment 'Total scheduled production time for the shift in minutes, excluding planned downtime such as breaks and scheduled maintenance.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedRuntimeMin rdf:type rdf:Property ;
    rdfs:label 'Planned Runtime Min' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityLossMinutes rdf:type rdf:Property ;
    rdfs:label 'Quality Loss Minutes' ;
    rdfs:comment 'Time equivalent of production lost due to quality defects and rework in minutes.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityPct rdf:type rdf:Property ;
    rdfs:label 'Quality Pct' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityRate rdf:type rdf:Property ;
    rdfs:label 'Quality Rate' ;
    rdfs:comment 'Percentage of good units produced without defects, calculated as (Total Units Produced - Total Units Rejected) / Total Units Produced. Component of OEE calculation.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Date and time when the OEE record was first created in the system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordDate rdf:type rdf:Property ;
    rdfs:label 'Record Date' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Date and time when the OEE record was last modified.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reworkUnits rdf:type rdf:Property ;
    rdfs:label 'Rework Units' ;
    rdfs:comment 'Count of units that required rework or reprocessing to meet quality standards during the shift.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scrapWeightKg rdf:type rdf:Property ;
    rdfs:label 'Scrap Weight Kg' ;
    rdfs:comment 'Total weight of scrap material generated during the shift in kilograms.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shift rdf:type rdf:Property ;
    rdfs:label 'Shift' ;
    rdfs:comment 'Work shift during which the incident occurred.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Code identifying the production shift during which the changeover occurred.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDate rdf:type rdf:Property ;
    rdfs:label 'Shift Date' ;
    rdfs:comment 'Calendar date on which the production shift occurred. Principal business event timestamp for OEE measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftName rdf:type rdf:Property ;
    rdfs:label 'Shift Name' ;
    rdfs:comment 'Descriptive name of the production shift (e.g., day, evening, night).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftNumber rdf:type rdf:Property ;
    rdfs:label 'Shift Number' ;
    rdfs:comment 'Sequential shift identifier within the shift date (e.g., 1 for first shift, 2 for second shift, 3 for third shift).' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speedLossMinutes rdf:type rdf:Property ;
    rdfs:label 'Speed Loss Minutes' ;
    rdfs:comment 'Time lost due to production running below ideal cycle time in minutes, representing performance inefficiency.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnitsProduced rdf:type rdf:Property ;
    rdfs:label 'Total Units Produced' ;
    rdfs:comment 'Total count of units produced during the shift, including both good units and rejected units.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitsRejected rdf:type rdf:Property ;
    rdfs:label 'Total Units Rejected' ;
    rdfs:comment 'Total count of units rejected due to quality defects during the shift.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unplannedStopCount rdf:type rdf:Property ;
    rdfs:label 'Unplanned Stop Count' ;
    rdfs:comment 'Number of unplanned production stoppages during the shift.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when the OEE record was validated by production management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeEventId rdf:type rdf:Property ;
    rdfs:label 'Downtime Event Id' ;
    rdfs:comment 'Unique identifier for the downtime event record. Primary key for the downtime event entity.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDowntimeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Downtime Employee Id' ;
    rdfs:comment 'Identifier of the production operator who reported or was present during the downtime event.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:shiftScheduleId rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule Id' ;
    rdfs:comment 'Identifier of the production shift during which the downtime event occurred.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftSchedule .

ind:batchHoldRequired rdf:type rdf:Property ;
    rdfs:label 'Batch Hold Required' ;
    rdfs:comment 'Indicates whether production batches affected by this downtime event require quality hold pending investigation.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of the corrective action taken to resolve the downtime event and restore production.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Source system or method by which the downtime event was captured (MES automatic detection, manual operator entry, sensor, SCADA).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeCategory rdf:type rdf:Property ;
    rdfs:label 'Downtime Category' ;
    rdfs:comment 'High-level classification of the downtime event type. [ENUM-REF-CANDIDATE: mechanical_failure|electrical_failure|changeover|material_shortage|operator_absence|planned_maintenance|cleaning_sanitation|quality_hold|tooling_issue|system_failure|unplanned_maintenance — promote to reference product]' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime End Timestamp' ;
    rdfs:comment 'Timestamp when the downtime event ended and production resumed. Null if downtime is ongoing.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for any delays or extended downtime during the changeover.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime Start Timestamp' ;
    rdfs:comment 'Timestamp when the downtime event began. Captured from MES system or manual entry.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeType rdf:type rdf:Property ;
    rdfs:label 'Downtime Type' ;
    rdfs:comment 'Indicates whether the downtime was planned (scheduled maintenance, changeover) or unplanned (breakdown, shortage).' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMin rdf:type rdf:Property ;
    rdfs:label 'Duration Min' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total duration of the downtime event measured in minutes. Calculated as the difference between end and start timestamps.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Timestamp when the DRP run execution finished or was terminated.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:equipmentFailureMode rdf:type rdf:Property ;
    rdfs:label 'Equipment Failure Mode' ;
    rdfs:comment 'Specific failure mode of the equipment that caused the downtime, used for reliability analysis and FMEA.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Level of management escalation required or triggered by this downtime event based on duration and impact.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event End Timestamp' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Start Timestamp' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated financial impact of the downtime event in local currency, including lost production value and recovery costs.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPlanned rdf:type rdf:Property ;
    rdfs:label 'Is Planned' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether automated notifications were sent to relevant stakeholders about this downtime event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oeeImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Oee Impact Flag' ;
    rdfs:comment 'Indicates whether this downtime event is included in OEE availability loss calculations.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Required' ;
    rdfs:comment 'Indicates whether preventive action is required to avoid recurrence of this downtime event.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionLossUnits rdf:type rdf:Property ;
    rdfs:label 'Production Loss Units' ;
    rdfs:comment 'Estimated number of production units lost due to this downtime event, based on standard production rate.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Timestamp when the downtime event was first reported or logged in the system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current status of the downtime event resolution process.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Department responsible for addressing or preventing this type of downtime event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code identifying the root cause of the downtime event. Aligned with facility-specific root cause taxonomy.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed textual description of the root cause analysis findings for this downtime event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Indicates whether the downtime event was associated with a safety incident or near-miss.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Severity classification of the downtime event based on impact to production schedule and safety.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Timestamp when the DRP run execution began.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeoverId rdf:type rdf:Property ;
    rdfs:label 'Changeover Id' ;
    rdfs:comment 'Unique identifier for the changeover event. Primary key for the changeover record.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryChangeoverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Changeover Employee Id' ;
    rdfs:comment 'Identifier of the primary operator or technician responsible for executing the changeover.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Minutes' ;
    rdfs:comment 'Actual elapsed time in minutes from changeover start to completion, calculated from actual start and end timestamps.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the changeover execution was completed and the line was ready for production.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeoverEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Changeover End Timestamp' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeoverStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Changeover Start Timestamp' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeoverStatus rdf:type rdf:Property ;
    rdfs:label 'Changeover Status' ;
    rdfs:comment 'Current lifecycle status of the changeover event indicating its progress through the execution workflow.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverType rdf:type rdf:Property ;
    rdfs:label 'Changeover Type' ;
    rdfs:comment 'Classification of the changeover based on the nature of the change: flavor (product variant), format (packaging type), size (package size), cleaning (sanitation), material (raw material switch), or color (product color change).' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleaningRequired rdf:type rdf:Property ;
    rdfs:label 'Cleaning Required' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cleaningVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cleaning Verification Timestamp' ;
    rdfs:comment 'Date and time when the GMP cleaning verification was completed and approved by quality assurance.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason Description' ;
    rdfs:comment 'Detailed description of the reason for any delays or extended downtime during the changeover execution.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentAdjustmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Equipment Adjustment Required Flag' ;
    rdfs:comment 'Indicates whether mechanical or equipment adjustments were required as part of the changeover process.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstPassYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'First Pass Yield Percentage' ;
    rdfs:comment 'Percentage of production output that met quality standards on the first production run immediately following the changeover, indicating changeover quality effectiveness.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpCleaningVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Cleaning Verified Flag' ;
    rdfs:comment 'Indicates whether the required GMP cleaning and sanitation procedures were completed and verified as part of the changeover process.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:improvementInitiativeCode rdf:type rdf:Property ;
    rdfs:label 'Improvement Initiative Code' ;
    rdfs:comment 'Identifier linking this changeover to a specific continuous improvement initiative or project.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialWasteKg rdf:type rdf:Property ;
    rdfs:label 'Material Waste Kg' ;
    rdfs:comment 'Quantity of raw material or work-in-process material wasted or scrapped during the changeover, measured in kilograms.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeImpactPercentage rdf:type rdf:Property ;
    rdfs:label 'Oee Impact Percentage' ;
    rdfs:comment 'Calculated impact of this changeover event on the production lines overall equipment effectiveness for the shift or day, expressed as a percentage.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'Planned date and time when the changeover was scheduled to be completed according to the production schedule.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned date and time when the changeover was scheduled to begin according to the production schedule.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:smedImprovementFlag rdf:type rdf:Property ;
    rdfs:label 'Smed Improvement Flag' ;
    rdfs:comment 'Indicates whether this changeover was part of a SMED continuous improvement initiative or pilot program.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Duration Minutes' ;
    rdfs:comment 'Standard or target duration in minutes for this type of changeover based on engineering standards and historical performance.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teamSize rdf:type rdf:Property ;
    rdfs:label 'Team Size' ;
    rdfs:comment 'Number of operators or technicians involved in executing the changeover.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toolingChangeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Tooling Change Required Flag' ;
    rdfs:comment 'Indicates whether tooling or die changes were required as part of the changeover process.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Variance Minutes' ;
    rdfs:comment 'Difference in minutes between actual and standard changeover duration. Positive values indicate the changeover took longer than standard; negative values indicate faster than standard performance.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldRecordId rdf:type rdf:Property ;
    rdfs:label 'Yield Record Id' ;
    rdfs:comment 'Unique identifier for the yield tracking record. Primary key for the yield record entity.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryYieldEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Yield Employee Id' ;
    rdfs:comment 'Reference to the production operator or technician who recorded the yield measurement. Links to workforce master data for training and performance tracking.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryYieldLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Yield Last Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person or system account that last modified this yield record. Audit trail for data governance and regulatory compliance.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualYield rdf:type rdf:Property ;
    rdfs:label 'Actual Yield' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Percentage' ;
    rdfs:comment 'Actual yield percentage achieved calculated as (output_quantity / input_quantity) * 100. Key Performance Indicator (KPI) for manufacturing efficiency.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualYieldQty rdf:type rdf:Property ;
    rdfs:label 'Actual Yield Qty' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Record Status' ;
    rdfs:comment 'Current lifecycle status of the batch record documentation. Tracks progression through Good Manufacturing Practice (GMP) review and approval workflow.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Cost center responsible for this manufacturing operation. Used for Cost of Goods Sold (COGS) allocation and variance accounting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Document Number' ;
    rdfs:comment 'Document number in the Enterprise Resource Planning (ERP) system (SAP S/4HANA) that records the goods movement associated with this yield. Links to material document for inventory reconciliation.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputQuantity rdf:type rdf:Property ;
    rdfs:label 'Input Quantity' ;
    rdfs:comment 'Total quantity of raw materials or semi-finished goods consumed as input for this operation. Used to calculate theoretical yield and material consumption variance.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'Date and time when the yield measurement was captured at the work center. Critical for Manufacturing Execution System (MES) integration and real-time production monitoring.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mesTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Mes Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier from the Manufacturing Execution System (MES) that originated this yield record. Enables traceability to Siemens Opcenter MES source data.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation End Timestamp' ;
    rdfs:comment 'Date and time when the manufacturing operation completed. Used to calculate cycle time and Overall Equipment Effectiveness (OEE).' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation Start Timestamp' ;
    rdfs:comment 'Date and time when the manufacturing operation began. Used to calculate cycle time and Overall Equipment Effectiveness (OEE).' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outputQuantity rdf:type rdf:Property ;
    rdfs:label 'Output Quantity' ;
    rdfs:comment 'Total quantity of finished or semi-finished goods produced as output from this operation. Represents the good production yield before scrap and rework.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedYieldQty rdf:type rdf:Property ;
    rdfs:label 'Planned Yield Qty' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionLineCode rdf:type rdf:Property ;
    rdfs:label 'Production Line Code' ;
    rdfs:comment 'Specific production line identifier within the plant. Enables line-level yield analysis and capacity planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Lot Number' ;
    rdfs:comment 'Quality Control (QC) inspection lot number associated with this yield record. Links yield data to quality inspection results for Good Manufacturing Practice (GMP) compliance.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingOperationNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Operation Number' ;
    rdfs:comment 'Specific operation sequence number within the production routing where yield is measured. Identifies the manufacturing step in the Bill of Materials (BOM) routing.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapQty rdf:type rdf:Property ;
    rdfs:label 'Scrap Qty' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Per Unit' ;
    rdfs:comment 'Standard cost per unit of output based on Bill of Materials (BOM) and routing. Used to calculate yield variance impact on Cost of Goods Sold (COGS).' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:theoreticalYield rdf:type rdf:Property ;
    rdfs:label 'Theoretical Yield' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:theoreticalYieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Theoretical Yield Percentage' ;
    rdfs:comment 'Expected yield percentage based on Bill of Materials (BOM) specifications and standard operating procedures. Baseline for variance analysis.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldLossReasonCode rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Reason Code' ;
    rdfs:comment 'Standardized code identifying the root cause of yield variance. Used for Pareto analysis and continuous improvement initiatives. Examples: EQUIP_FAIL, MAT_DEFECT, PROC_ERROR, QUAL_REJECT.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldLossReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Yield Loss Reason Description' ;
    rdfs:comment 'Detailed description of the yield loss root cause. Provides context for quality investigations and corrective action planning.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPct rdf:type rdf:Property ;
    rdfs:label 'Yield Pct' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldVarianceCostImpact rdf:type rdf:Property ;
    rdfs:label 'Yield Variance Cost Impact' ;
    rdfs:comment 'Financial impact of yield variance calculated as (theoretical_yield - actual_yield) * standard_cost_per_unit. Feeds into Cost of Goods Sold (COGS) variance reporting.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Variance Percentage' ;
    rdfs:comment 'Variance between actual and theoretical yield expressed as percentage. Calculated as (actual_yield_percentage - theoretical_yield_percentage). Negative values indicate yield loss.' ;
    rdfs:domain ind:YieldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpEventId rdf:type rdf:Property ;
    rdfs:label 'Gmp Event Id' ;
    rdfs:comment 'Unique surrogate identifier for the GMP compliance event record. Primary key for the gmp_event data product. Entity role: TRANSACTION_HEADER — represents a discrete GMP compliance business event with a clear lifecycle.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Reference to the quality manager or authorized person who reviewed and electronically signed off on the GMP event record. Required for 21 CFR Part 11 electronic signature compliance. Nullable until event reaches approval stage.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capaId rdf:type rdf:Property ;
    rdfs:label 'Capa Id' ;
    rdfs:comment 'Reference to the Corrective and Preventive Action (CAPA) record initiated in response to this GMP event. Nullable when no CAPA has been raised yet or when event severity does not require CAPA. Managed in Veeva Vault Quality module.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capa .

ind:equipmentId rdf:type rdf:Property ;
    rdfs:label 'Equipment Id' ;
    rdfs:comment 'Reference to the specific piece of manufacturing equipment involved in or associated with the GMP event. Particularly relevant for equipment_failure and process_parameter_breach event types. Links to equipment master in SAP PM (Plant Maintenance) module.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:gmpReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Gmp Reported By Employee Id' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryGmpDetectedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Gmp Detected By Employee Id' ;
    rdfs:comment 'Reference to the employee (operator, quality technician, or supervisor) who first detected and reported the GMP event. Links to Workday HCM employee master. Required for GMP accountability and electronic signature audit trail under 21 CFR Part 11.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priorEventGmpEventId rdf:type rdf:Property ;
    rdfs:label 'Prior Event Gmp Event Id' ;
    rdfs:comment 'Reference to the previous GMP event of the same type that this event is a recurrence of. Populated only when recurrence_flag is true. Enables recurrence trend analysis and CAPA effectiveness assessment across event lineage.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GmpEvent .

ind:affectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity' ;
    rdfs:comment 'Quantity of product (in the batch unit of measure) potentially affected by the GMP event. Used for impact assessment, recall scope estimation, and financial exposure calculation. Serves as the QUANTITATIVE_RESULT measurement for this non-monetary transaction.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity Uom' ;
    rdfs:comment 'Unit of measure for the affected batch quantity (e.g., KG for kilograms, L for liters, EA for each/units). Aligned with GS1 unit of measure codes and SAP S/4HANA base unit of measure configuration.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the authorized quality manager electronically signed and approved the GMP event record. Distinct from detection and creation timestamps. Required for regulatory audit trail and SLA compliance measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchDisposition rdf:type rdf:Property ;
    rdfs:label 'Batch Disposition' ;
    rdfs:comment 'Quality disposition decision for the affected batch resulting from the GMP event investigation. released: batch meets quality standards and is approved for distribution. quarantined: batch held pending investigation outcome. rejected: batch fails quality standards and cannot be released. reworked: batch underwent approved rework procedure. destroyed: batch disposed of due to quality failure.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpCode rdf:type rdf:Property ;
    rdfs:label 'Ccp Code' ;
    rdfs:comment 'Identifier of the Critical Control Point (CCP) in the manufacturing process where the GMP event was detected. Applicable for process_parameter_breach and environmental_monitoring_excursion event types. Aligned with HACCP and GMP process control frameworks.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closure Timestamp' ;
    rdfs:comment 'Date and time when the GMP event was formally closed after all required CAPA actions were completed and verified effective. Nullable for open or in-progress events. Used to calculate event resolution cycle time for quality KPI reporting.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containmentActionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Containment Action Timestamp' ;
    rdfs:comment 'Date and time when the immediate containment action was executed following GMP event detection (e.g., line stoppage, batch quarantine). Used to calculate detection-to-containment response time, a key GMP performance metric.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gmpEventDescription rdf:type rdf:Property ;
    rdfs:label 'Gmp Event Description' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the GMP compliance event was first detected or observed on the shop floor or in the laboratory. This is the principal real-world event time (BUSINESS_EVENT_TIMESTAMP category). Distinct from the record creation timestamp. Critical for regulatory timelines and investigation SLA tracking.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:electronicSignature rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature' ;
    rdfs:comment 'Electronic signature token or hash of the approver who reviewed and closed the GMP event record, as required by FDA 21 CFR Part 11. Captures the meaning of the signature (e.g., \'Reviewed and Approved\'), the signer identity reference, and timestamp encoded in the token. Managed by Veeva Vault e-signature module.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalZone rdf:type rdf:Property ;
    rdfs:label 'Environmental Zone' ;
    rdfs:comment 'ISO cleanroom classification zone or EU GMP environmental grade where the GMP event occurred. Relevant for environmental_monitoring_excursion event types. Grade A/B are highest cleanliness requirements; Grade C/D are controlled areas. Used for contamination risk assessment.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed narrative description of the GMP compliance event, including what was observed, where it occurred, and the immediate circumstances. Captured by the detecting operator or quality technician at time of detection. Serves as the QUANTITATIVE_RESULT (qualitative payload) category for non-monetary TRANSACTION_HEADER.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the GMP compliance event, used in regulatory submissions, CAPA tracking, and cross-system references. Format: GMP-{YYYY}-{NNNNNN}. Serves as the BUSINESS_IDENTIFIER category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSeverity rdf:type rdf:Property ;
    rdfs:label 'Event Severity' ;
    rdfs:comment 'Risk-based severity classification of the GMP event. Critical: potential impact on product safety or patient/consumer harm; requires immediate escalation and regulatory notification. Major: significant departure from GMP requirements with potential quality impact. Minor: low-risk deviation with minimal quality impact. Drives CAPA prioritization and regulatory reporting obligations.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the GMP compliance event. open: newly detected, investigation not yet started. under_investigation: root cause analysis in progress. pending_capa: investigation complete, awaiting CAPA closure. closed: all actions completed and verified effective. cancelled: event determined to be erroneous or duplicate. Serves as the LIFECYCLE_STATUS category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) when the consent status change event occurred. This is the authoritative business event time used for GDPR Article 7 and CCPA compliance audits, distinct from the record ingestion timestamp.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the GMP compliance event by its nature. Values: deviation (unplanned departure from approved procedure), oos_result (Out-of-Specification laboratory result), environmental_monitoring_excursion (EM limit breach), equipment_failure (critical equipment malfunction), process_parameter_breach (critical process parameter out of range), contamination_event (microbial or cross-contamination incident). [ENUM-REF-CANDIDATE: deviation|oos_result|environmental_monitoring_excursion|equipment_failure|process_parameter_breach|contamination_event — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpEventStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Event Status' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Description of the immediate containment or corrective action taken at the time of GMP event detection to prevent further impact (e.g., line stoppage, batch quarantine, equipment isolation). Distinct from the formal CAPA which addresses root cause prevention.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationDueDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Due Date' ;
    rdfs:comment 'Target date by which the root cause investigation must be completed, based on event severity and regulatory SLA requirements. Critical events typically require investigation within 3 business days; major within 10 days; minor within 30 days. Used for overdue investigation tracking.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isProductRecallTrigger rdf:type rdf:Property ;
    rdfs:label 'Is Product Recall Trigger' ;
    rdfs:comment 'Indicates whether this GMP event has been assessed as a potential trigger for a product recall or market withdrawal. True when the event involves a safety risk to consumers that may require removal of product from distribution channels. Activates recall management workflow.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processStep rdf:type rdf:Property ;
    rdfs:label 'Process Step' ;
    rdfs:comment 'Name or code of the specific manufacturing process step (e.g., mixing, filling, packaging, sterilization, labeling) during which the GMP event was detected. Sourced from Siemens Opcenter MES routing. Used for process-level failure mode analysis.' ;
    rdfs:domain ind:GmpEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this GMP event is a recurrence of a previously closed event of the same type at the same facility or production line. True when a similar event has occurred within the past 12 months. Triggers escalated investigation and CAPA effectiveness review.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulationReference rdf:type rdf:Property ;
    rdfs:label 'Regulation Reference' ;
    rdfs:comment 'Specific regulatory standard or clause that this GMP event relates to or potentially violates. Examples: \'ISO 22716:2007 Section 10.2\', \'FDA 21 CFR Part 211.113\', \'EU GMP Annex 1\'. Used for regulatory submission mapping and compliance gap analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date on which the regulatory authority was formally notified of this GMP event. Populated only when regulatory_notification_required is true and notification has been submitted. Used for regulatory compliance timeline tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether this GMP event requires formal notification to a regulatory authority (e.g., FDA, EU Competent Authority, CPSC). Typically true for critical events involving potential consumer safety risk, product recall triggers, or serious GMP failures. Drives regulatory affairs workflow.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Quantitative risk score assigned to the GMP event based on ICH Q9 risk assessment methodology, combining probability of occurrence, severity of impact, and detectability. Typically scored on a 1-100 scale. Used for risk-based prioritization of investigations and CAPA resources.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Categorized root cause of the GMP event as determined through investigation. Populated after investigation is complete. Used for trend analysis, systemic failure identification, and CAPA effectiveness measurement. [ENUM-REF-CANDIDATE: human_error|equipment_malfunction|raw_material|process_design|environmental|documentation|training — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapQmNotificationNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Qm Notification Number' ;
    rdfs:comment 'SAP S/4HANA Quality Management (QM) notification number associated with this GMP event. Quality notifications in SAP QM are the operational system of record for defect tracking and corrective actions. Enables reconciliation between the lakehouse and SAP QM.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity classification of the quality event based on impact to product safety, efficacy, and regulatory compliance. Critical: immediate risk to consumer safety or regulatory violation; Major: significant quality impact requiring containment; Minor: low impact quality issue.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Production Confirmation Id' ;
    rdfs:comment 'Unique identifier for the production confirmation record. Primary key for shop floor execution tracking.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProductionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Production Employee Id' ;
    rdfs:comment 'Reference to the shop floor operator or employee who executed and confirmed this manufacturing operation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:productionConfirmedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Production Confirmed By Employee Id' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:productionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Production Employee Id' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'SAP CO activity type code representing the type of work performed (e.g., machine hours, labor hours, setup hours) for cost allocation purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual date and time when the operation was completed and confirmed by the operator. Used for OEE calculation and production order settlement.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLaborTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Time Minutes' ;
    rdfs:comment 'Actual operator labor time spent on this operation including manual work, monitoring, and quality checks. Measured in minutes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMachineTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Machine Time Minutes' ;
    rdfs:comment 'Actual time the machine or equipment was actively running during this operation. Excludes setup and downtime. Measured in minutes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSetupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Setup Time Minutes' ;
    rdfs:comment 'Actual time spent on machine setup, changeover, and preparation activities before production began. Measured in minutes.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual date and time when the operator began executing this operation on the shop floor. Captured from MES or manual confirmation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationNotes rdf:type rdf:Property ;
    rdfs:label 'Confirmation Notes' ;
    rdfs:comment 'Free-text notes or comments entered by the operator or supervisor regarding this operation execution, including any issues or observations.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Unique confirmation number assigned by the supplier to this order acknowledgement. Used for supplier reference and tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'System timestamp when this confirmation record was created and submitted to the ERP or MES system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationType rdf:type rdf:Property ;
    rdfs:label 'Confirmation Type' ;
    rdfs:comment 'Classification of the confirmation event indicating whether this is a partial progress update, final completion, milestone checkpoint, rework confirmation, or cancellation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedScrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Scrap Quantity' ;
    rdfs:comment 'Actual quantity of defective or waste material generated during this operation. Used for yield variance analysis and quality tracking.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedYieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Yield Quantity' ;
    rdfs:comment 'Actual quantity of good output produced and confirmed for this operation. Measured in the base unit of measure for the material.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborHours rdf:type rdf:Property ;
    rdfs:label 'Labor Hours' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineHours rdf:type rdf:Property ;
    rdfs:label 'Machine Hours' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeAvailabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Availability Percent' ;
    rdfs:comment 'Calculated availability component of OEE for this operation, representing the percentage of scheduled time that equipment was available for production.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeePerformancePercent rdf:type rdf:Property ;
    rdfs:label 'Oee Performance Percent' ;
    rdfs:comment 'Calculated performance component of OEE for this operation, representing actual production speed versus ideal speed.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeQualityPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Quality Percent' ;
    rdfs:comment 'Calculated quality component of OEE for this operation, representing the percentage of good output versus total output produced.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationStatus rdf:type rdf:Property ;
    rdfs:label 'Operation Status' ;
    rdfs:comment 'Current lifecycle status of the manufacturing operation indicating its execution state in the production workflow.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'Financial posting date when this confirmation was recorded in the ERP system for inventory and cost accounting purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether this operation output requires quality inspection before release to inventory or next operation.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this confirmation has been reversed or cancelled due to error correction or process adjustment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Standardized code explaining why this confirmation was reversed, if applicable. Used for process improvement and error tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Flag' ;
    rdfs:comment 'Indicates whether this confirmation represents a rework operation to correct defects from a previous production run.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'Planned completion date and time for this operation as determined by production scheduling or MES system.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'Planned start date and time for this operation as determined by production scheduling or MES system.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Standardized code explaining any significant variance between planned and actual quantities or times. Used for root cause analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Business identifier for the work order assigned to this manufacturing operation. Externally visible reference used across shop floor systems.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Yield Quantity' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processParameterId rdf:type rdf:Property ;
    rdfs:label 'Process Parameter Id' ;
    rdfs:comment 'Unique identifier for the process parameter record. Primary key for in-process control and critical process parameter measurements.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specificationId rdf:type rdf:Property ;
    rdfs:label 'Specification Id' ;
    rdfs:comment 'Reference to the product specification or process specification document that defines the control limits for this parameter.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'The actual measured value of the process parameter recorded during manufacturing operations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Boolean indicator whether the measurement result requires corrective action or investigation (True = action required, False = no action needed).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationPercentage rdf:type rdf:Property ;
    rdfs:label 'Deviation Percentage' ;
    rdfs:comment 'Calculated percentage deviation of the actual value from the target value. Used for trend analysis and process capability assessment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inSpec rdf:type rdf:Property ;
    rdfs:label 'In Spec' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inSpecFlag rdf:type rdf:Property ;
    rdfs:label 'In Spec Flag' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowerControlLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Control Limit' ;
    rdfs:comment 'The lower acceptable boundary for the parameter value. Values below this threshold trigger out-of-specification alerts.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Limit' ;
    rdfs:comment 'Lower Limit value for the Specification record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Spec Limit' ;
    rdfs:comment 'Lower Spec Limit value for the Inspection Result record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measured Timestamp' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'The actual quantitative measurement or test result value recorded during inspection. For qualitative characteristics, this may be encoded numerically or stored as a code.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'The method used to capture the parameter measurement: manual entry by operator, automated sensor reading, inline PAT sensor, or laboratory analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oosFlag rdf:type rdf:Property ;
    rdfs:label 'Oos Flag' ;
    rdfs:comment 'Boolean indicator whether the measured value falls outside the defined control limits (True = out of specification, False = within specification).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parameterCode rdf:type rdf:Property ;
    rdfs:label 'Parameter Code' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterName rdf:type rdf:Property ;
    rdfs:label 'Parameter Name' ;
    rdfs:comment 'Name of the process parameter being measured (e.g., temperature, pH, viscosity, fill weight, torque, pressure, mixing speed, dwell time).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterType rdf:type rdf:Property ;
    rdfs:label 'Parameter Type' ;
    rdfs:comment 'Classification of the parameter: CPP (Critical Process Parameter), CQA (Critical Quality Attribute), IPC (In-Process Control), PAT (Process Analytical Technology).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterValue rdf:type rdf:Property ;
    rdfs:label 'Parameter Value' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processStage rdf:type rdf:Property ;
    rdfs:label 'Process Stage' ;
    rdfs:comment 'The manufacturing process stage or operation step during which the parameter was measured (e.g., mixing, heating, filling, cooling, packaging).' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLine rdf:type rdf:Property ;
    rdfs:label 'Production Line' ;
    rdfs:comment 'Identifier of the specific production line within the work center where the parameter was measured. Enables line-level performance analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable' ;
    rdfs:comment 'Boolean indicator whether this parameter measurement must be included in regulatory submissions or audit documentation (True = reportable, False = internal only).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleCode rdf:type rdf:Property ;
    rdfs:label 'Sample Code' ;
    rdfs:comment 'Identifier of the physical sample taken for measurement, if applicable. Links to laboratory information management system (LIMS).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Code' ;
    rdfs:comment 'Identifier of the specific sensor or probe that captured the measurement, if applicable. Used for sensor calibration tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The target or setpoint value for the process parameter as defined in the batch master recipe or process specification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperControlLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Control Limit' ;
    rdfs:comment 'The upper acceptable boundary for the parameter value. Values above this threshold trigger out-of-specification alerts.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Limit' ;
    rdfs:comment 'Upper Limit value for the Specification record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Spec Limit' ;
    rdfs:comment 'Upper Spec Limit value for the Inspection Result record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'The date and time when the parameter measurement was verified by quality assurance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Identifier of the quality assurance personnel who verified or approved the parameter measurement record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedOrderId rdf:type rdf:Property ;
    rdfs:label 'Planned Order Id' ;
    rdfs:comment 'Unique system-generated identifier for the planned order record. Primary key for the planned order entity.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:convertedProductionOrderId rdf:type rdf:Property ;
    rdfs:label 'Converted Production Order Id' ;
    rdfs:comment 'Reference to the production order that was created from this planned order upon conversion. Null if not yet converted.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:tradePromotionId rdf:type rdf:Property ;
    rdfs:label 'Trade Promotion Id' ;
    rdfs:comment 'Foreign key linking to promotion.trade_promotion. Business justification: Planned Promotional Production aligns MRP planned orders with upcoming trade promotions to ensure supply availability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradePromotion .

ind:availabilityDate rdf:type rdf:Property ;
    rdfs:label 'Availability Date' ;
    rdfs:comment 'The date when the produced or procured material from this planned order is expected to be available for consumption or shipment.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'The date when this planned order was converted to a production order. Null if not yet converted.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'Indicates whether this planned order has been converted to a production order: NOT_CONVERTED (still in planning), PARTIALLY_CONVERTED (split conversion), FULLY_CONVERTED (completely converted).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User ID or system identifier of the person or automated process that created this planned order.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSourceReference rdf:type rdf:Property ;
    rdfs:label 'Demand Source Reference' ;
    rdfs:comment 'Reference number or identifier of the originating demand document (sales order number, forecast ID, transfer request number, etc.).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSourceType rdf:type rdf:Property ;
    rdfs:label 'Demand Source Type' ;
    rdfs:comment 'Classification of the demand signal that triggered this planned order: FORECAST (demand planning), CUSTOMER_ORDER (firm sales order), STOCK_TRANSFER (inter-plant), SAFETY_STOCK (replenishment), PROMOTION (trade promotion demand).' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionMessageCode rdf:type rdf:Property ;
    rdfs:label 'Exception Message Code' ;
    rdfs:comment 'Code representing MRP exception conditions (e.g., EX01 = reschedule in, EX02 = reschedule out, EX03 = cancel, EX10 = expedite). Empty if no exception.' ;
    rdfs:domain ind:PlannedOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionMessageText rdf:type rdf:Property ;
