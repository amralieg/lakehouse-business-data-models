    rdfs:range xsd:string .

ind:submissionDescription rdf:type rdf:Property ;
    rdfs:label 'Submission Description' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feePaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Status' ;
    rdfs:comment 'Payment status of the regulatory filing fee (paid, pending, waived, refunded).' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDescription rdf:type rdf:Property ;
    rdfs:label 'Hazard Description' ;
    rdfs:comment 'Detailed description of the hazard, incident, or safety concern that prompted the submission (applicable for CPSC Section 15(b) reports, SaferProducts.gov filings, and post-market surveillance submissions).' ;
