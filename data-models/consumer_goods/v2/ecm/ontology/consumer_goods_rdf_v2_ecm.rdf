    rdfs:domain ind:RdProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyPerformanceIndicators rdf:type rdf:Property ;
    rdfs:label 'Key Performance Indicators' ;
    rdfs:comment 'List of key performance indicators defined in the innovation brief to measure project success (e.g., consumer acceptance score, margin target, time-to-market).' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned' ;
