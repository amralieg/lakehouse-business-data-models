ind:intransitShipmentId rdf:type rdf:Property ;
    rdfs:label 'Intransit Shipment Id' ;
    rdfs:comment 'Foreign key linking to inventory.intransit_shipment. Business justification: SHIPMENT HAND-OFF: Distribution shipment creates an In-Transit Shipment record to track movement from DC to destination.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntransitShipment .

ind:loadedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Loaded By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Needed for Load Execution Log to record which warehouse employee performed the loading of each shipment, supporting OTIF compliance and labor costing.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:distributionShipmentCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Shipment Code' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionShipmentDescription rdf:type rdf:Property ;
    rdfs:label 'Distribution Shipment Description' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionShipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Shipment Status' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Total planned or actual freight cost for this route in the operating currency. Used for transportation cost tracking, carrier invoice reconciliation, and freight audit processes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionShipmentName rdf:type rdf:Property ;
    rdfs:label 'Distribution Shipment Name' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'The warehouse management system shipment number or bill of lading number. External business identifier for the shipment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment. Drives OTIF (On Time In Full) measurement, exception management, and track-and-trace visibility. [ENUM-REF-CANDIDATE: planned|tendered|confirmed|in_transit|out_for_delivery|delivered|cancelled|exception — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCartons rdf:type rdf:Property ;
    rdfs:label 'Total Cartons' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryPositionId rdf:type rdf:Property ;
    rdfs:label 'Inventory Position Id' ;
    rdfs:comment 'Primary key for inventory_position' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inventory Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Supports Inventory Ownership Dashboard, assigning a responsible employee for each DC inventory position for accountability and cycle-count oversight.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualWeight rdf:type rdf:Property ;
    rdfs:label 'Actual Weight' ;
    rdfs:comment 'The actual measured weight of the inventory for catch weight items. Used for billing and compliance when item weight varies.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:catchWeightFlag rdf:type rdf:Property ;
    rdfs:label 'Catch Weight Flag' ;
    rdfs:comment 'Indicates whether the SKU is a catch weight item requiring actual weight capture at transaction time (true) or standard weight (false).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryPositionCode rdf:type rdf:Property ;
    rdfs:label 'Inventory Position Code' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOnHand rdf:type rdf:Property ;
    rdfs:label 'Days On Hand' ;
    rdfs:comment 'The number of days the inventory has been on hand since receipt. Calculated as current date minus receipt date. Used for aging analysis.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysToExpiry rdf:type rdf:Property ;
    rdfs:label 'Days To Expiry' ;
    rdfs:comment 'The number of days remaining until the inventory lot expires. Calculated as expiry date minus current date. Critical for FEFO rotation and markdown decisions.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryPositionDescription rdf:type rdf:Property ;
    rdfs:label 'Inventory Position Description' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inTransitQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Quantity' ;
    rdfs:comment 'Quantity of stock currently in transit between locations (plant-to-warehouse, warehouse-to-store, etc.) and not yet received at destination.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryCondition rdf:type rdf:Property ;
    rdfs:label 'Inventory Condition' ;
    rdfs:comment 'The physical condition classification of the inventory. Used for disposition decisions and channel restrictions.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryPositionStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Position Status' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'The current operational status of the inventory position. Determines availability for picking and order fulfillment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'The date when this inventory position was last physically counted during a cycle count operation. Used to schedule next count and assess inventory accuracy.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'The date when inventory was last moved into or out of this storage location. Used for slow-moving inventory identification.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementType rdf:type rdf:Property ;
    rdfs:label 'Last Movement Type' ;
    rdfs:comment 'The type of the last inventory movement transaction that affected this position (receipt, putaway, pick, replenishment, transfer, adjustment, return). [ENUM-REF-CANDIDATE: receipt|putaway|pick|replenishment|transfer|adjustment|return — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensePlateNumber rdf:type rdf:Property ;
    rdfs:label 'License Plate Number' ;
    rdfs:comment 'The warehouse management system license plate number assigned to the handling unit. Used for tracking and automated material handling.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryPositionName rdf:type rdf:Property ;
    rdfs:label 'Inventory Position Name' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onHoldQuantity rdf:type rdf:Property ;
    rdfs:label 'On Hold Quantity' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Indicates the ownership model of the inventory (owned by company, consignment from supplier, customer-owned for returns, vendor-managed inventory).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickFaceFlag rdf:type rdf:Property ;
    rdfs:label 'Pick Face Flag' ;
    rdfs:comment 'Indicates whether this inventory position is in a primary pick face location (true) or reserve storage (false). Pick face locations are optimized for order picking efficiency.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:putawayDate rdf:type rdf:Property ;
    rdfs:label 'Putaway Date' ;
    rdfs:comment 'The date when the inventory was put away into this storage location after receiving. Used for aging analysis and FEFO compliance.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityAllocated rdf:type rdf:Property ;
    rdfs:label 'Quantity Allocated' ;
    rdfs:comment 'The quantity of on-hand inventory that has been allocated to outbound orders or reservations but not yet picked. Reduces available-to-pick quantity.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDamaged rdf:type rdf:Property ;
    rdfs:label 'Quantity Damaged' ;
    rdfs:comment 'The quantity of inventory identified as damaged and not suitable for sale or distribution. Typically awaiting disposal or return to supplier.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityHold rdf:type rdf:Property ;
    rdfs:label 'Quantity Hold' ;
    rdfs:comment 'The quantity of inventory placed on hold due to quality issues, customer complaints, or pending investigation. Not available for picking.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'The total physical quantity of the SKU-lot currently present in the storage location. Measured in the SKU\'s base unit of measure.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityQuarantine rdf:type rdf:Property ;
    rdfs:label 'Quantity Quarantine' ;
    rdfs:comment 'The quantity of inventory placed in quarantine status pending quality inspection or regulatory clearance. Not available for picking.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'The quantity of inventory reserved for specific customers, channels, or promotional programs. Subset of allocated quantity with additional business constraints.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentFlag rdf:type rdf:Property ;
    rdfs:label 'Replenishment Flag' ;
    rdfs:comment 'Indicates whether this inventory position requires replenishment from reserve to pick face (true) or not (false). Triggers automated replenishment tasks.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stockStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Status' ;
    rdfs:comment 'Current lifecycle status of the stock position. Active=available for operations; Inactive=temporarily unavailable; Pending Disposal=marked for write-off; Transferred=moved to another location; Consumed=used in production or sold.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageZone rdf:type rdf:Property ;
    rdfs:label 'Storage Zone' ;
    rdfs:comment 'The logical zone within the distribution center where the inventory is stored (e.g., ambient, refrigerated, frozen, hazmat, high-velocity, reserve).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalInventoryValue rdf:type rdf:Property ;
    rdfs:label 'Total Inventory Value' ;
    rdfs:comment 'The total financial value of the inventory position calculated as quantity_on_hand multiplied by cost_per_unit. Used for balance sheet reporting. Business confidential financial data.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Weight Unit Of Measure' ;
    rdfs:comment 'The unit of measure for actual weight (Pound, Kilogram, Ounce, Gram). Applicable for catch weight items.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionCycleCountId rdf:type rdf:Property ;
    rdfs:label 'Distribution Cycle Count Id' ;
    rdfs:comment 'Unique identifier for the cycle count event record. Primary key for the distribution cycle count entity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionCountedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Distribution Counted By Employee Id' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:inventoryCycleCountId rdf:type rdf:Property ;
    rdfs:label 'Inventory Cycle Count Id' ;
    rdfs:comment 'FK to authoritative SSOT table inventory.inventory_cycle_count (cross-domain duplicate resolution).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryCycleCount .

ind:primaryDistributionCounterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Counter Employee Id' ;
    rdfs:comment 'Identifier of the warehouse associate who performed the physical count.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:distributionCycleCountCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Cycle Count Code' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countDate rdf:type rdf:Property ;
    rdfs:label 'Count Date' ;
    rdfs:comment 'The calendar date on which the physical cycle count was performed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countNumber rdf:type rdf:Property ;
    rdfs:label 'Count Number' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the cycle count event. Planned = scheduled but not started, in_progress = counting underway, confirmed = count verified, posted = variance adjusted in system, cancelled = count voided, recount_required = variance exceeds threshold.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'The actual physical quantity counted by the warehouse associate during the cycle count event. Measured in the SKU\'s unit of measure.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionCycleCountDescription rdf:type rdf:Property ;
    rdfs:label 'Distribution Cycle Count Description' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionCycleCountStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Cycle Count Status' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionCycleCountName rdf:type rdf:Property ;
    rdfs:label 'Distribution Cycle Count Name' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemQuantity rdf:type rdf:Property ;
    rdfs:label 'System Quantity' ;
    rdfs:comment 'The quantity recorded in the WMS (Warehouse Management System) or ERP (Enterprise Resource Planning) system at the time of the count. Used to calculate variance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'The difference between counted quantity and system quantity (counted minus system). Positive values indicate overage, negative values indicate shortage.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceValue rdf:type rdf:Property ;
    rdfs:label 'Variance Value' ;
    rdfs:comment 'The monetary value of the variance (variance_quantity * unit_cost). Represents the financial impact of the inventory discrepancy. Used for shrinkage reporting and P&L (Profit and Loss) impact analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionDriverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Distribution Driver Employee Id' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryDistributionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Employee Id' ;
    rdfs:comment 'Identifier of the driver or sales representative permanently or primarily assigned to this route. May be null for unassigned or pool routes.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:averageOrderValue rdf:type rdf:Property ;
    rdfs:label 'Average Order Value' ;
    rdfs:comment 'Historical average order value per stop on this route in local currency. Used for revenue forecasting and route profitability analysis.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionDsdRouteCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Dsd Route Code' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionDsdRouteDescription rdf:type rdf:Property ;
    rdfs:label 'Distribution Dsd Route Description' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionDsdRouteStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Dsd Route Status' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDriveTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Drive Time Minutes' ;
    rdfs:comment 'Estimated total driving time for the route in minutes, excluding stop service time. Used for driver shift planning and OTIF performance targets.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedServiceTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Service Time Minutes' ;
    rdfs:comment 'Estimated total time spent at customer stops for unloading, merchandising, and order processing in minutes. Combined with drive time for total route duration.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastOptimizationDate rdf:type rdf:Property ;
    rdfs:label 'Last Optimization Date' ;
    rdfs:comment 'Date when this route was last reviewed and optimized for efficiency. Used to identify routes due for re-evaluation.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:merchandisingRequired rdf:type rdf:Property ;
    rdfs:label 'Merchandising Required' ;
    rdfs:comment 'Boolean flag indicating whether this route includes merchandising activities (shelf stocking, display setup, POG compliance) in addition to delivery. True if merchandising is part of the service.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionDsdRouteName rdf:type rdf:Property ;
    rdfs:label 'Distribution Dsd Route Name' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfStops rdf:type rdf:Property ;
    rdfs:label 'Number Of Stops' ;
    rdfs:comment 'Total count of retail store or customer locations included in this route. Used for route capacity planning and driver workload estimation.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:osaTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Osa Target Percentage' ;
    rdfs:comment 'Target OSA percentage for stores on this route, representing the expected in-stock rate at point of sale. Used for DSD execution quality and replenishment effectiveness tracking.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Time' ;
    rdfs:comment 'Standard departure time from the DC for this route in HH:MM format (24-hour clock). Used for driver scheduling and DC loading dock coordination.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Planned Distance Km' ;
    rdfs:comment 'Total planned driving distance for the route in kilometers, as calculated by the route optimization algorithm. Used for fuel cost estimation, carbon footprint calculation, and driver pay.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReturnTime rdf:type rdf:Property ;
    rdfs:label 'Planned Return Time' ;
    rdfs:comment 'Expected return time to the DC for this route in HH:MM format (24-hour clock). Used for driver shift planning and vehicle turnaround scheduling.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStops rdf:type rdf:Property ;
    rdfs:label 'Planned Stops' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresColdChain rdf:type rdf:Property ;
    rdfs:label 'Requires Cold Chain' ;
    rdfs:comment 'Boolean flag indicating whether this route requires temperature-controlled (refrigerated or frozen) transportation for product integrity. True if cold chain is required.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresHazmatCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Hazmat Certification' ;
    rdfs:comment 'Boolean flag indicating whether the driver assigned to this route must hold hazmat certification due to regulated products (e.g., aerosols, flammables). True if certification is required.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeName rdf:type rdf:Property ;
    rdfs:label 'Route Name' ;
    rdfs:comment 'Human-readable name or description of the DSD route, often including geographic or customer identifiers (e.g., \'Downtown Metro Route A\', \'North Region Convenience Stores\').' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeOptimizationScore rdf:type rdf:Property ;
    rdfs:label 'Route Optimization Score' ;
    rdfs:comment 'Calculated efficiency score for this route based on distance, time, stops, and revenue, typically ranging from 0-100. Higher scores indicate more optimized routes. Used for continuous improvement initiatives.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current operational status of the DSD route. Active routes are in regular service; inactive routes are permanently discontinued; suspended routes are temporarily paused; under_review routes are being optimized; seasonal_closed routes are off-season.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the DSD route based on service model: standard (regular scheduled delivery), express (same-day or expedited), bulk (high-volume customers), emergency (unplanned replenishment), seasonal (temporary routes for peak demand).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDayPattern rdf:type rdf:Property ;
    rdfs:label 'Service Day Pattern' ;
    rdfs:comment 'Comma-separated list of days of the week this route is scheduled to run (e.g., \'Mon,Wed,Fri\' for a three-day-per-week route). Supports recurring schedule planning.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Start Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the route start point (typically the DC or depot). Used for route optimization and GPS tracking.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Start Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the route start point (typically the DC or depot). Used for route optimization and GPS tracking.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stopCount rdf:type rdf:Property ;
    rdfs:label 'Stop Count' ;
    rdfs:comment 'Total number of delivery stops planned for this load, used for multi-stop route optimization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Total Distance Km' ;
    rdfs:comment 'Total driving distance for the complete route in kilometers, from DC departure through all stops and return. Used for fuel cost estimation and vehicle range planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleCapacityRequiredUnits rdf:type rdf:Property ;
    rdfs:label 'Vehicle Capacity Required Units' ;
    rdfs:comment 'Minimum vehicle cargo capacity required in standard units (cases, pallets, or cubic meters) to fulfill typical route demand. Used for vehicle assignment.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type Required' ;
    rdfs:comment 'Type of vehicle required to service this route based on cargo volume, weight, and product requirements (e.g., refrigerated for cold chain products).' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Distribution Employee Id' ;
    rdfs:comment 'Reference to the DSD driver who executed this delivery. Links to workforce employee master data.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Time' ;
    rdfs:comment 'The actual timestamp when the driver arrived at the retail store location. Used for On Time In Full (OTIF) performance measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distributionDsdDeliveryCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Dsd Delivery Code' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivered Timestamp' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Exception Code' ;
    rdfs:comment 'Code indicating any exception or issue encountered during the delivery attempt. Used for root cause analysis of delivery failures. [ENUM-REF-CANDIDATE: store_closed|access_denied|incomplete_order|damaged_product|wrong_address|weather_delay|traffic_delay|vehicle_breakdown|none — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes captured by the driver regarding delivery conditions, store feedback, or special circumstances encountered during the visit.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Business identifier for the DSD delivery transaction. Externally visible delivery document number used for tracking and proof of delivery reference.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the DSD delivery transaction. Tracks progression from scheduled visit through completion or failure. [ENUM-REF-CANDIDATE: scheduled|in_transit|arrived|in_progress|completed|failed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryValueAmount rdf:type rdf:Property ;
    rdfs:label 'Delivery Value Amount' ;
    rdfs:comment 'The total monetary value of products delivered during this visit, calculated at invoice price. Represents gross delivery value before returns and credits.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End' ;
    rdfs:comment 'The end of the agreed delivery time window with the retail store. Part of Service Level Agreement (SLA) for OTIF measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start' ;
    rdfs:comment 'The beginning of the agreed delivery time window with the retail store. Part of Service Level Agreement (SLA) for OTIF measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:departureTime rdf:type rdf:Property ;
    rdfs:label 'Departure Time' ;
    rdfs:comment 'The timestamp when the driver departed from the retail store after completing delivery and merchandising activities.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distributionDsdDeliveryDescription rdf:type rdf:Property ;
    rdfs:label 'Distribution Dsd Delivery Description' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionDsdDeliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Dsd Delivery Status' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'Geographic latitude coordinate captured at delivery location for route verification and geospatial analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'Geographic longitude coordinate captured at delivery location for route verification and geospatial analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inFullFlag rdf:type rdf:Property ;
    rdfs:label 'In Full Flag' ;
    rdfs:comment 'Indicates whether the complete ordered quantity was delivered without shortages. Component of OTIF performance measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Amount' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchandisingActivityType rdf:type rdf:Property ;
    rdfs:label 'Merchandising Activity Type' ;
    rdfs:comment 'The type of in-store merchandising activity performed during the delivery visit. Supports retail execution and On Shelf Availability (OSA) objectives.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandisingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Merchandising Duration Minutes' ;
    rdfs:comment 'The total time in minutes spent on merchandising activities during the store visit. Used for labor productivity analysis.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:merchandisingPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Merchandising Performed Flag' ;
    rdfs:comment 'Indicates whether in-store merchandising activities (shelf stocking, rotation, display setup) were performed during this delivery visit.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionDsdDeliveryName rdf:type rdf:Property ;
    rdfs:label 'Distribution Dsd Delivery Name' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netDeliveryAmount rdf:type rdf:Property ;
    rdfs:label 'Net Delivery Amount' ;
    rdfs:comment 'The net monetary value of the delivery after subtracting return credits from gross delivery value. Represents actual secondary sales value.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Flag' ;
    rdfs:comment 'Indicates whether the delivery arrived within the agreed delivery time window. Component of OTIF performance measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Compliance Flag' ;
    rdfs:comment 'Indicates whether this delivery met On Time In Full (OTIF) performance criteria: arrived within delivery window and delivered complete order quantity.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Timestamp' ;
    rdfs:comment 'Scheduled date and time at which the shipment leg is expected to arrive at the destination node. Used for receiving planning, dock scheduling, and OTIF target setting.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:podCaptureMethod rdf:type rdf:Property ;
    rdfs:label 'Pod Capture Method' ;
    rdfs:comment 'The method used to capture proof of delivery from the store recipient. Electronic signature and photo are preferred for audit trail.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podPhotoUrl rdf:type rdf:Property ;
    rdfs:label 'Pod Photo Url' ;
    rdfs:comment 'URL reference to the photo evidence of delivery captured at the store. Links to document management system for audit purposes.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSignatureImageUrl rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Image Url' ;
    rdfs:comment 'URL reference to the stored electronic signature image captured as proof of delivery. Links to document management system.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'The name of the store employee who received and acknowledged the delivery. Captured for proof of delivery and accountability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Return Credit Amount' ;
    rdfs:comment 'The total monetary value of product returns credited to the store during this visit. Reduces net delivery value.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Time' ;
    rdfs:comment 'The planned arrival timestamp at the retail store based on route optimization and store delivery window requirements.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stopSequence rdf:type rdf:Property ;
    rdfs:label 'Stop Sequence' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCasesDelivered rdf:type rdf:Property ;
    rdfs:label 'Total Cases Delivered' ;
    rdfs:comment 'The total quantity of product cases delivered to the store during this visit. Aggregate measure across all SKUs (Stock Keeping Units) delivered.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCasesReturned rdf:type rdf:Property ;
    rdfs:label 'Total Cases Returned' ;
    rdfs:comment 'The total quantity of product cases returned from the store during this visit due to damage, expiration, or other quality issues.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnitsDelivered rdf:type rdf:Property ;
    rdfs:label 'Total Units Delivered' ;
    rdfs:comment 'The total quantity of individual product units delivered to the store during this visit. Aggregate measure across all SKUs delivered.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnitsReturned rdf:type rdf:Property ;
    rdfs:label 'Total Units Returned' ;
    rdfs:comment 'The total quantity of individual product units returned from the store during this visit due to damage, expiration, or other quality issues.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Total monetary value of this schedule line, calculated as confirmed quantity multiplied by unit price.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Code' ;
    rdfs:comment 'Reference to the delivery vehicle used for this DSD delivery. Links to fleet asset master data.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitDate rdf:type rdf:Property ;
    rdfs:label 'Visit Date' ;
    rdfs:comment 'The calendar date on which the DSD delivery visit to the retail store occurred. Business event date for reporting and analytics.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dsdDeliveryLineId rdf:type rdf:Property ;
    rdfs:label 'Dsd Delivery Line Id' ;
    rdfs:comment 'Unique identifier for the DSD delivery line item. Primary key for this product.' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dsdDeliveryLineCode rdf:type rdf:Property ;
    rdfs:label 'Dsd Delivery Line Code' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Compliant Flag' ;
    rdfs:comment 'Indicates whether cold chain temperature requirements were maintained throughout delivery. True if compliant, False if temperature excursion occurred.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'Actual quantity of the SKU delivered to the store during this visit. Used for secondary sales capture and inventory replenishment tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Date and time when this specific line item was delivered or processed at the store. Used for OTIF performance tracking and delivery window compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dsdDeliveryLineDescription rdf:type rdf:Property ;
    rdfs:label 'Dsd Delivery Line Description' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdDeliveryLineStatus rdf:type rdf:Property ;
    rdfs:label 'Dsd Delivery Line Status' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineValue rdf:type rdf:Property ;
    rdfs:label 'Line Value' ;
    rdfs:comment 'Total declared value of this shipment line item (shipped_quantity × unit_cost), used for customs valuation, cargo insurance, and financial reporting. Expressed in the shipment currency.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsdDeliveryLineName rdf:type rdf:Property ;
    rdfs:label 'Dsd Delivery Line Name' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Planogram Compliance Flag' ;
    rdfs:comment 'Indicates whether the product was placed according to the store planogram. True if compliant, False if deviation occurred.' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating why the delivery line was rejected by the store. Values: DAMAGED, WRONG_PRODUCT, QUALITY, UNAUTHORIZED, EXPIRED, OTHER.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfPlacementConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Shelf Placement Confirmed Flag' ;
    rdfs:comment 'Indicates whether the DSD driver confirmed proper shelf placement and merchandising of the delivered product. True if confirmed, False otherwise.' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Selling Price' ;
    rdfs:comment 'Selling price per unit for this SKU at the time of delivery. Used for revenue calculation and pricing analysis.' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifEventId rdf:type rdf:Property ;
    rdfs:label 'Otif Event Id' ;
    rdfs:comment 'Unique identifier for the OTIF performance measurement event. Primary key for the OTIF event record.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryId rdf:type rdf:Property ;
    rdfs:label 'Delivery Id' ;
    rdfs:comment 'Reference to the delivery execution record for Direct Store Delivery (DSD) or carrier delivery. Links to the actual delivery event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Delivery .

ind:responsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Enables OTIF Incident Management report to identify the employee responsible for resolving each OTIF event, meeting internal SLA tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'The precise timestamp when delivery was completed and proof of delivery was captured. Used for time-window OTIF compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:otifEventCode rdf:type rdf:Property ;
    rdfs:label 'Otif Event Code' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Date' ;
    rdfs:comment 'The delivery date committed to the customer per the Service Level Agreement (SLA) or purchase order terms. Baseline for on-time performance measurement.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:committedDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Timestamp' ;
    rdfs:comment 'The precise delivery date and time committed to the customer, including time window for time-sensitive deliveries. Used for precise OTIF measurement when time windows apply.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveredDate rdf:type rdf:Property ;
    rdfs:label 'Delivered Date' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Variance Days' ;
    rdfs:comment 'The number of days variance between committed and actual delivery date. Negative values indicate early delivery, positive values indicate late delivery, zero indicates on-time.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otifEventDescription rdf:type rdf:Property ;
    rdfs:label 'Otif Event Description' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Explanation of why the OTIF measurement is disputed. Captures customer or internal objections to the performance assessment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCategory rdf:type rdf:Property ;
    rdfs:label 'Failure Category' ;
    rdfs:comment 'The primary root cause category for OTIF failures. Used for operational improvement analysis and accountability assignment. Values include DC pick error, inventory shortage, dock delay, carrier issue, customer refused, weather delay, system error, quality hold, damaged product, address issue, or no failure for successful deliveries. [ENUM-REF-CANDIDATE: dc_pick_error|inventory_shortage|dock_delay|carrier_issue|customer_refused|weather_delay|system_error|quality_hold|damaged_product|address_issue|no_failure — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Reason code or description explaining why a delivery stop was not completed successfully (e.g., consignee closed, refused delivery, access denied, vehicle breakdown). Required for failed or skipped stop status. [ENUM-REF-CANDIDATE: consignee_closed|refused_delivery|access_denied|vehicle_breakdown|incorrect_address|no_dock_available|weather — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Code' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Detail' ;
    rdfs:comment 'Detailed explanation of the root cause for OTIF failure. Free-text field capturing specific circumstances, corrective actions, and accountability notes.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRatePct rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Pct' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inFullTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'In Full Tolerance Percent' ;
    rdfs:comment 'The acceptable variance percentage per customer SLA or business policy. Deliveries within this tolerance are considered in-full compliant.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifEventName rdf:type rdf:Property ;
    rdfs:label 'Otif Event Name' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifEventStatus rdf:type rdf:Property ;
    rdfs:label 'Otif Event Status' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Flag' ;
    rdfs:comment 'Indicates whether this delivery met the OTIF (On Time In Full) KPI criteria — True if delivered on or before the scheduled date AND at 100% of ordered quantity. Core retail compliance metric for major retailers (e.g., Walmart OTIF penalty program).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifScore rdf:type rdf:Property ;
    rdfs:label 'Otif Score' ;
    rdfs:comment 'Composite OTIF performance indicator. True only when both on_time_flag and in_full_flag are True. Primary KPI for DC operations accountability and retailer scorecard compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the retailer penalty amount. Standard currency codes such as USD, EUR, GBP.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Captured Flag' ;
    rdfs:comment 'Indicates whether an electronic or physical signature was captured at delivery. True indicates signature obtained, False indicates delivery without signature capture.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'The difference between delivered quantity and committed quantity. Negative values indicate short shipment, positive values indicate over shipment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariancePercent rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance Percent' ;
    rdfs:comment 'The percentage variance between delivered and committed quantity, calculated as (delivered - committed) / committed * 100. Used to assess severity of in-full failures.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'The organizational function or external party accountable for the OTIF failure. Used for performance accountability and continuous improvement initiatives.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Retailer Penalty Amount' ;
    rdfs:comment 'The financial penalty or chargeback amount assessed by the retailer for OTIF non-compliance per the customer contract or retailer compliance program. Zero for compliant deliveries.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCaseCount rdf:type rdf:Property ;
    rdfs:label 'Actual Case Count' ;
    rdfs:comment 'Actual number of cases handled during the appointment. Used for variance analysis and operational performance tracking.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Actual timestamp when loading or unloading operations were completed and the truck departed. Used to calculate dock turnaround time and throughput metrics.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualPalletCount rdf:type rdf:Property ;
    rdfs:label 'Actual Pallet Count' ;
    rdfs:comment 'Actual number of pallets loaded or unloaded during the appointment. Compared against expected count to identify discrepancies.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualWeightKg rdf:type rdf:Property ;
    rdfs:label 'Actual Weight Kg' ;
    rdfs:comment 'Actual total weight of goods handled in kilograms. Verified through weigh station or scale integration.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appointmentNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Number' ;
    rdfs:comment 'Business-facing unique appointment reference number used for scheduling and tracking. Externally visible identifier shared with carriers and suppliers.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle status of the dock appointment: scheduled (initial booking), confirmed (carrier acknowledged), checked_in (truck arrived at gate), in_progress (loading/unloading active), completed (finished), cancelled (appointment voided), no_show (carrier missed appointment). [ENUM-REF-CANDIDATE: scheduled|confirmed|checked_in|in_progress|completed|cancelled|no_show — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentType rdf:type rdf:Property ;
    rdfs:label 'Appointment Type' ;
    rdfs:comment 'Classification of the dock appointment purpose: inbound receipt (supplier delivery), outbound load (customer shipment), inter-DC transfer (internal movement), cross-dock (direct transfer), returns processing, or emergency delivery.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockAppointmentCode rdf:type rdf:Property ;
    rdfs:label 'Dock Appointment Code' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDockFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Flag' ;
    rdfs:comment 'Indicates whether this is a cross-dock appointment where goods are transferred directly from inbound to outbound without storage. True for cross-dock operations.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dockAppointmentDescription rdf:type rdf:Property ;
    rdfs:label 'Dock Appointment Description' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detentionMinutes rdf:type rdf:Property ;
    rdfs:label 'Detention Minutes' ;
    rdfs:comment 'Total time in minutes that the carrier was detained beyond the scheduled appointment window. Used to calculate detention charges and identify operational bottlenecks.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dockAppointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Dock Appointment Status' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'Name of the driver assigned to this appointment. Used for gate check-in verification and security purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverPhone rdf:type rdf:Property ;
    rdfs:label 'Driver Phone' ;
    rdfs:comment 'Contact phone number for the driver. Used for real-time communication regarding delays, gate instructions, or operational issues.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCaseCount rdf:type rdf:Property ;
    rdfs:label 'Expected Case Count' ;
    rdfs:comment 'Anticipated number of cases to be handled during this appointment. Supports detailed capacity and labor planning for case-level operations.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedPalletCount rdf:type rdf:Property ;
    rdfs:label 'Expected Pallet Count' ;
    rdfs:comment 'Anticipated number of pallets to be loaded or unloaded during this appointment. Used for dock capacity planning and labor scheduling.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Expected Weight Kg' ;
    rdfs:comment 'Total expected weight of goods in kilograms for this appointment. Used for equipment planning and safety compliance.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'UN hazard classification code for hazardous materials (e.g., 3 for flammable liquids, 8 for corrosives). Required for HAZMAT compliance and safety protocols.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockAppointmentName rdf:type rdf:Property ;
    rdfs:label 'Dock Appointment Name' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Number' ;
    rdfs:comment 'Sales order number associated with outbound load appointments. Links the dock appointment to customer orders being shipped.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Date' ;
    rdfs:comment 'Planned date for the carrier to arrive at the dock door. Used for day-level appointment planning and capacity management.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Precise timestamp when the appointment window closes. Carrier should complete loading/unloading by this time to maintain schedule compliance.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Precise timestamp when the appointment window begins. Carrier is expected to arrive at or after this time.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadPlanId rdf:type rdf:Property ;
    rdfs:label 'Load Plan Id' ;
    rdfs:comment 'Unique identifier for the outbound load plan record. Primary key.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadPlannedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Load Planned By Employee Id' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryLoadingSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Loading Supervisor Employee Id' ;
    rdfs:comment 'Identifier of the warehouse supervisor who verified and approved the completed load before dispatch.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Datetime' ;
    rdfs:comment 'Actual date and time when the loaded trailer departed the distribution center, used for OTIF performance measurement.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Level' ;
    rdfs:comment 'Service level agreement tier for this shipment, determining transit time and handling requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPlanCode rdf:type rdf:Property ;
    rdfs:label 'Load Plan Code' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPlanDescription rdf:type rdf:Property ;
    rdfs:label 'Load Plan Description' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFreightCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Freight Cost' ;
    rdfs:comment 'Estimated transportation cost for this load based on carrier rates, distance, and service level.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated freight cost.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadNumber rdf:type rdf:Property ;
    rdfs:label 'Load Number' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Load Plan Number' ;
    rdfs:comment 'Business-facing unique identifier for the load plan, typically generated by the WMS. Used for operational tracking and communication with carriers and warehouse staff.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Load Plan Status' ;
    rdfs:comment 'Current lifecycle status of the load plan, tracking progression from planning through dispatch. [ENUM-REF-CANDIDATE: draft|confirmed|in_progress|loaded|sealed|dispatched|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadSequenceStrategy rdf:type rdf:Property ;
    rdfs:label 'Load Sequence Strategy' ;
    rdfs:comment 'Strategy used to determine the order in which pallets are loaded into the trailer, typically aligned with delivery stop sequence.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadStatus rdf:type rdf:Property ;
    rdfs:label 'Load Status' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadType rdf:type rdf:Property ;
    rdfs:label 'Load Type' ;
    rdfs:comment 'Classification of the load based on shipment mode and delivery strategy. DSD indicates Direct Store Delivery.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingCompletionDatetime rdf:type rdf:Property ;
    rdfs:label 'Loading Completion Datetime' ;
    rdfs:comment 'Date and time when physical loading of the trailer was completed and verified.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadingStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Loading Start Datetime' ;
    rdfs:comment 'Date and time when physical loading of the trailer began at the dock door.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadPlanName rdf:type rdf:Property ;
    rdfs:label 'Load Plan Name' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderCount rdf:type rdf:Property ;
    rdfs:label 'Order Count' ;
    rdfs:comment 'Total number of distinct outbound orders consolidated into this load plan.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otifTargetDeliveryDatetime rdf:type rdf:Property ;
    rdfs:label 'Otif Target Delivery Datetime' ;
    rdfs:comment 'Target delivery date and time committed to the customer, used for OTIF performance measurement.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:palletConfiguration rdf:type rdf:Property ;
    rdfs:label 'Pallet Configuration' ;
    rdfs:comment 'Description of how pallets are arranged and stacked within the trailer, supporting optimal space utilization and load stability.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDate rdf:type rdf:Property ;
    rdfs:label 'Plan Date' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedDeparture rdf:type rdf:Property ;
    rdfs:label 'Planned Departure' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Datetime' ;
    rdfs:comment 'Scheduled date and time when the loaded trailer is planned to depart the distribution center.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureRangeMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max Celsius' ;
    rdfs:comment 'Maximum acceptable temperature in Celsius for temperature-controlled loads during transit.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min Celsius' ;
    rdfs:comment 'Minimum acceptable temperature in Celsius for temperature-controlled loads during transit.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeCubicM rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cubic M' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cubic Meters' ;
    rdfs:comment 'Total cubic volume of the load in cubic meters, used for trailer utilization analysis and capacity planning.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'Total cubic volume of the shipment in cubic meters. Used for dimensional weight calculation, trailer utilization, and freight cost optimization.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trailerCode rdf:type rdf:Property ;
    rdfs:label 'Trailer Code' ;
    rdfs:comment 'Unique identifier of the trailer or vehicle assigned to this load. May be a license plate, fleet number, or container number.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerType rdf:type rdf:Property ;
    rdfs:label 'Trailer Type' ;
    rdfs:comment 'Type of trailer or vehicle used for this load, determining capacity and product compatibility.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Trailer Utilization Percentage' ;
    rdfs:comment 'Percentage of trailer capacity utilized by this load, calculated based on weight, volume, or pallet positions.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationPct rdf:type rdf:Property ;
    rdfs:label 'Utilization Pct' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleType rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type' ;
    rdfs:comment 'Category of the vehicle based on body style and purpose.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Returns Receipt Id' ;
    rdfs:comment 'Unique identifier for the returns receipt record. Primary key.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryReturnsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Returns Employee Id' ;
    rdfs:comment 'Identifier of the quality assurance employee who performed the condition inspection of the returned goods.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:recallEventId rdf:type rdf:Property ;
    rdfs:label 'Recall Event Id' ;
    rdfs:comment 'Identifier of the recall event if this return is recall-driven, linking to the recall management record.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecallEvent .

ind:returnsProcessedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Returns Processed By Employee Id' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:returnsReceiptCode rdf:type rdf:Property ;
    rdfs:label 'Returns Receipt Code' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAssessment rdf:type rdf:Property ;
    rdfs:label 'Condition Assessment' ;
    rdfs:comment 'Quality inspection result indicating the physical and salability condition of the returned goods: resalable, damaged, expired, defective, or contaminated.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionGrade rdf:type rdf:Property ;
    rdfs:label 'Condition Grade' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Total monetary credit amount issued to the customer for the returned goods.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnsReceiptDescription rdf:type rdf:Property ;
    rdfs:label 'Returns Receipt Description' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destroyQuantity rdf:type rdf:Property ;
    rdfs:label 'Destroy Quantity' ;
    rdfs:comment 'Quantity of returned units that must be destroyed due to damage, contamination, or recall requirements.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispositionCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Completion Timestamp' ;
    rdfs:comment 'Date and time when the final disposition decision was executed (resale, destroy, rework, etc.).' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Completion Timestamp' ;
    rdfs:comment 'Date and time when the quality and condition inspection of returned goods was completed.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnsReceiptName rdf:type rdf:Property ;
    rdfs:label 'Returns Receipt Name' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReturned rdf:type rdf:Property ;
    rdfs:label 'Quantity Returned' ;
    rdfs:comment 'Total quantity of units returned in this receipt.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Date and time when the returned goods were physically received at the distribution center. Principal business event timestamp.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resalableQuantity rdf:type rdf:Property ;
    rdfs:label 'Resalable Quantity' ;
    rdfs:comment 'Quantity of returned units deemed resalable and eligible to be returned to inventory.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnType rdf:type rdf:Property ;
    rdfs:label 'Return Type' ;
    rdfs:comment 'Classification of the return source: retailer return, DSD (Direct Store Delivery) customer return, consumer return, recall-driven return, or internal transfer.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnsReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Returns Receipt Status' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Wms Transaction Code' ;
    rdfs:comment 'Transaction identifier from the Blue Yonder WMS system that processed this return receipt.' ;
    rdfs:domain ind:ReturnsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionOffsetAllocationId rdf:type rdf:Property ;
    rdfs:label 'Distribution Offset Allocation Id' ;
    rdfs:comment 'Primary key for the offset_allocation association' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedCo2eTonnes rdf:type rdf:Property ;
    rdfs:label 'Allocated Co2e Tonnes' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedEmissionsTonnes rdf:type rdf:Property ;
    rdfs:label 'Allocated Emissions Tonnes' ;
    rdfs:domain ind:DistributionOffsetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationAmount rdf:type rdf:Property ;
    rdfs:label 'Allocation Amount' ;
    rdfs:comment 'Monetary or volume amount allocated.' ;
    rdfs:domain ind:ConsumerGoods ;
