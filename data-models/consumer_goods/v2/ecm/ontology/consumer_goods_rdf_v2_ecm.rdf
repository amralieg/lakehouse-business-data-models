ind:findingClassification rdf:type rdf:Property ;
    rdfs:label 'Finding Classification' ;
    rdfs:comment 'Severity classification of the audit finding. Critical: immediate risk to product safety or regulatory compliance; Major: significant deviation from GMP requiring prompt correction; Minor: isolated deviation with low impact; Observation: opportunity for improvement without regulatory breach.' ;
    rdfs:domain ind:AuditFinding ;
