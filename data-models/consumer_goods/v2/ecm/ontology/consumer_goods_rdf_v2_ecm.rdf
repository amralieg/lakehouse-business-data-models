    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Registration Status' ;
    rdfs:domain ind:RegulatoryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Sds Document Reference' ;
    rdfs:comment 'Reference identifier or document number for the Safety Data Sheet (SDS) or Material Safety Data Sheet (MSDS) associated with this registered product. Links to safety documentation repository.' ;
    rdfs:domain ind:RegulatoryRegistration ;
