ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of minor findings representing opportunities for improvement without immediate compliance risk.' ;
    rdfs:domain ind:ConsumerGoods ;
