ind:pickDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Pick Distribution Storage Location Id' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:primaryPickDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Pick Distribution Storage Location Id' ;
    rdfs:comment 'Reference to the warehouse storage location (bin, shelf, pallet position) from which inventory is picked.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:primaryPickEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Pick Employee Id' ;
    rdfs:comment 'Reference to the warehouse operator or picker assigned to execute this task.' ;
