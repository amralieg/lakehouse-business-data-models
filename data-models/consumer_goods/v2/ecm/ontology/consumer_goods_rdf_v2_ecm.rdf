ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit: scheduled (planned but not started), in_progress (fieldwork underway), report_draft (findings being documented), report_issued (final report delivered), closed (all findings resolved), cancelled (audit did not proceed).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTeamMembers rdf:type rdf:Property ;
