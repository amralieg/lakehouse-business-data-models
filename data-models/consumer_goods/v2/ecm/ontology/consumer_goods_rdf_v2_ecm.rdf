ind:sourcingEventId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Event Id' ;
    rdfs:comment 'Foreign key linking to procurement.sourcing_event. Business justification: A supplier contract is the primary deliverable of a sourcing event. Linking supplier_contract to sourcing_event enables end-to-end sourcing lifecycle tracking — from event initiation through RFQ, awar' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingEvent .

ind:supplierContractCode rdf:type rdf:Property ;
