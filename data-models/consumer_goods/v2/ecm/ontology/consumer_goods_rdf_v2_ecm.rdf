    rdfs:comment 'Method by which prices are determined: fixed price for static rates, cost plus for markup on supplier costs, market indexed for commodity-linked pricing, volume tiered for quantity-based discounts, or rebate based for retrospective incentives.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
