    rdfs:range xsd:string .

ind:authoringChemist rdf:type rdf:Property ;
    rdfs:label 'Authoring Chemist' ;
    rdfs:comment 'Name of the qualified chemist or toxicologist who authored or reviewed this SDS for technical accuracy.' ;
    rdfs:domain ind:Sds ;
