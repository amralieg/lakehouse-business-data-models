    rdfs:comment 'Code identifying the destination distribution center, retail store, or customer facility for the packed shipment.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelPrintedTimestamp rdf:type rdf:Property ;
