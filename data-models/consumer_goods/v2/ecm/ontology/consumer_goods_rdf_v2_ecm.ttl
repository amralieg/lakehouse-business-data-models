    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryAffinity rdf:type rdf:Property ;
    rdfs:label 'Category Affinity' ;
    rdfs:comment 'Product categories that this segment shows high purchase propensity or engagement with.' ;
