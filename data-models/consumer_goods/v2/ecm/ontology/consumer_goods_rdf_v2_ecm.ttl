    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:v2AddedFlag rdf:type rdf:Property ;
    rdfs:label 'V2 Added Flag' ;
