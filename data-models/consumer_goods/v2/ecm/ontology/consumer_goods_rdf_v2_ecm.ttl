    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyCode rdf:type rdf:Property ;
    rdfs:label 'Survey Code' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCcpa rdf:type rdf:Property ;
    rdfs:label 'Compliance Ccpa' ;
    rdfs:comment 'True if the survey complies with CCPA requirements.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceGdpr rdf:type rdf:Property ;
    rdfs:label 'Compliance Gdpr' ;
    rdfs:comment 'True if the survey complies with GDPR requirements.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
