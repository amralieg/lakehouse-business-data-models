    rdfs:comment 'Consumer perception score for brand innovation attribute on a scale of 1-10.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSentimentScore rdf:type rdf:Property ;
    rdfs:label 'Net Sentiment Score' ;
    rdfs:comment 'Net sentiment score calculated as positive percentage minus negative percentage, ranging from -100 to +100.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferencePct rdf:type rdf:Property ;
    rdfs:label 'Preference Pct' ;
    rdfs:comment 'Percentage of consumers who prefer this brand over competitors in the category.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferenceScore rdf:type rdf:Property ;
    rdfs:label 'Preference Score' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseIntentPct rdf:type rdf:Property ;
    rdfs:label 'Purchase Intent Pct' ;
    rdfs:comment 'Percentage of consumers who intend to purchase the brand in the next purchase cycle.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseIntentScore rdf:type rdf:Property ;
    rdfs:label 'Purchase Intent Score' ;
    rdfs:comment 'Consumer purchase intent rating indicating likelihood to buy the product after testing, typically on a standardized scale.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Quality Perception Score' ;
    rdfs:comment 'Consumer perception score for product quality attribute on a scale of 1-10.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shareOfConversationPct rdf:type rdf:Property ;
    rdfs:label 'Share Of Conversation Pct' ;
    rdfs:comment 'Brand share of total social media conversation volume within the category.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialMentionVolume rdf:type rdf:Property ;
    rdfs:label 'Social Mention Volume' ;
    rdfs:comment 'Total number of social media mentions for the brand during the tracking period.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialSentimentNegativePct rdf:type rdf:Property ;
    rdfs:label 'Social Sentiment Negative Pct' ;
    rdfs:comment 'Percentage of social media mentions with negative sentiment during the tracking period.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSentimentNeutralPct rdf:type rdf:Property ;
    rdfs:label 'Social Sentiment Neutral Pct' ;
    rdfs:comment 'Percentage of social media mentions with neutral sentiment during the tracking period.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSentimentPositivePct rdf:type rdf:Property ;
    rdfs:label 'Social Sentiment Positive Pct' ;
    rdfs:comment 'Percentage of social media mentions with positive sentiment during the tracking period.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:somValuePct rdf:type rdf:Property ;
    rdfs:label 'Som Value Pct' ;
    rdfs:comment 'Brand share of total category sales measured by value (revenue) for the period and geography.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:somVolumePct rdf:type rdf:Property ;
    rdfs:label 'Som Volume Pct' ;
    rdfs:comment 'Brand share of total category sales measured by volume (units) for the period and geography.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovDigitalPct rdf:type rdf:Property ;
    rdfs:label 'Sov Digital Pct' ;
    rdfs:comment 'Share of voice for digital advertising (display, search, video) as percentage of total category digital spend.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovOohPct rdf:type rdf:Property ;
    rdfs:label 'Sov Ooh Pct' ;
    rdfs:comment 'Share of voice for out-of-home advertising (billboards, transit, etc.) as percentage of total category OOH spend.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovSocialPct rdf:type rdf:Property ;
    rdfs:label 'Sov Social Pct' ;
    rdfs:comment 'Share of voice for social media advertising as percentage of total category social spend.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovTotalPct rdf:type rdf:Property ;
    rdfs:label 'Sov Total Pct' ;
    rdfs:comment 'Total share of voice across all media channels as percentage of total category advertising spend.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovTvPct rdf:type rdf:Property ;
    rdfs:label 'Sov Tv Pct' ;
    rdfs:comment 'Share of voice for television advertising as percentage of total category TV spend.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spontaneousAwarenessPct rdf:type rdf:Property ;
    rdfs:label 'Spontaneous Awareness Pct' ;
    rdfs:comment 'Percentage of consumers who mention the brand unprompted when asked about the category.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Perception Score' ;
    rdfs:comment 'Consumer perception score for environmental and social responsibility attribute on a scale of 1-10.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCategorySpendAmount rdf:type rdf:Property ;
    rdfs:label 'Total Category Spend Amount' ;
    rdfs:comment 'Total advertising spend across all brands in the category for the measurement period.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Tracking Period End Date' ;
    rdfs:comment 'End date of the brand health measurement period.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trackingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Tracking Period Start Date' ;
    rdfs:comment 'Start date of the brand health measurement period.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trustPerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Trust Perception Score' ;
    rdfs:comment 'Consumer perception score for brand trust and reliability attribute on a scale of 1-10.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuePerceptionScore rdf:type rdf:Property ;
    rdfs:label 'Value Perception Score' ;
    rdfs:comment 'Consumer perception score for value-for-money attribute on a scale of 1-10.' ;
    rdfs:domain ind:BrandHealthTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Sov Measurement Id' ;
    rdfs:comment 'Unique identifier for the Share of Voice measurement record.' ;
    rdfs:domain ind:SovMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandRank rdf:type rdf:Property ;
    rdfs:label 'Brand Rank' ;
    rdfs:comment 'Rank of the brand by Share of Voice within the category (1 = highest SOV).' ;
    rdfs:domain ind:SovMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandSomPercentage rdf:type rdf:Property ;
    rdfs:label 'Brand Som Percentage' ;
    rdfs:comment 'The brand\'s Share of Market (sales-based market share) during the same measurement period, used for SOV vs. SOM gap analysis.' ;
    rdfs:domain ind:SovMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandSovPercentage rdf:type rdf:Property ;
    rdfs:label 'Brand Sov Percentage' ;
    rdfs:comment 'The brand\'s Share of Voice as a percentage of total category advertising spend during the measurement period.' ;
    rdfs:domain ind:SovMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovMeasurementCategory rdf:type rdf:Property ;
    rdfs:label 'Sov Measurement Category' ;
    rdfs:domain ind:SovMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorBrand rdf:type rdf:Property ;
    rdfs:label 'Competitor Brand' ;
    rdfs:domain ind:SovMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorCount rdf:type rdf:Property ;
    rdfs:label 'Competitor Count' ;
    rdfs:comment 'Number of competitor brands included in the category Share of Voice calculation.' ;
    rdfs:domain ind:SovMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impressionsCount rdf:type rdf:Property ;
    rdfs:label 'Impressions Count' ;
    rdfs:comment 'Total number of advertising impressions delivered by the brand during the measurement period.' ;
    rdfs:domain ind:SovMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reachPercentage rdf:type rdf:Property ;
    rdfs:label 'Reach Percentage' ;
    rdfs:comment 'Percentage of the target audience reached by the brand\'s advertising during the measurement period.' ;
    rdfs:domain ind:SovMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovPercentage rdf:type rdf:Property ;
    rdfs:label 'Sov Percentage' ;
    rdfs:domain ind:SovMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sovSomGap rdf:type rdf:Property ;
    rdfs:label 'Sov Som Gap' ;
    rdfs:comment 'Difference between brand SOV percentage and brand SOM percentage (SOV - SOM). Positive gap indicates over-investment; negative gap indicates under-investment.' ;
    rdfs:domain ind:SovMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:topCompetitorBrandName rdf:type rdf:Property ;
    rdfs:label 'Top Competitor Brand Name' ;
    rdfs:comment 'Name of the competitor brand with the highest Share of Voice in the category during the measurement period.' ;
    rdfs:domain ind:SovMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topCompetitorSovPercentage rdf:type rdf:Property ;
    rdfs:label 'Top Competitor Sov Percentage' ;
    rdfs:comment 'Share of Voice percentage of the top competitor brand in the category.' ;
    rdfs:domain ind:SovMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Digital Performance Id' ;
    rdfs:comment 'Unique identifier for the digital campaign performance record. Primary key for this transactional performance measurement entity.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adFormat rdf:type rdf:Property ;
    rdfs:label 'Ad Format' ;
    rdfs:comment 'The specific creative format of the digital ad (e.g., carousel, single image, video, story, banner, interstitial, native). Describes the presentation style of the creative asset.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Attribution Window Days' ;
    rdfs:comment 'The number of days after ad interaction during which conversions are attributed to this campaign. Defines the lookback period for conversion tracking.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clickThroughRate rdf:type rdf:Property ;
    rdfs:label 'Click Through Rate' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpm rdf:type rdf:Property ;
    rdfs:label 'Cpm' ;
    rdfs:comment 'Cost per thousand impressions (total cost divided by impressions, multiplied by 1000). Standard metric for awareness campaigns.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctrPercent rdf:type rdf:Property ;
    rdfs:label 'Ctr Percent' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geography rdf:type rdf:Property ;
    rdfs:label 'Geography' ;
    rdfs:comment 'Three-letter ISO country code representing the geographic market where the ad was served. Enables market-level performance analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'Timestamp when this performance record was ingested into the lakehouse from the source platform API. Supports data freshness monitoring and audit trail.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revenueAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Amount' ;
    rdfs:comment 'Total revenue attributed to conversions from this campaign on this date and channel. Used to calculate ROAS and campaign profitability.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueAttributed rdf:type rdf:Property ;
    rdfs:label 'Revenue Attributed' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spend rdf:type rdf:Property ;
    rdfs:label 'Spend' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoQuartile25Pct rdf:type rdf:Property ;
    rdfs:label 'Video Quartile 25 Pct' ;
    rdfs:comment 'Percentage of video views that reached the 25% completion point. Expressed as a decimal. Tracks early engagement drop-off.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoQuartile50Pct rdf:type rdf:Property ;
    rdfs:label 'Video Quartile 50 Pct' ;
    rdfs:comment 'Percentage of video views that reached the 50% completion point (midpoint). Expressed as a decimal. Measures sustained viewer interest.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoQuartile75Pct rdf:type rdf:Property ;
    rdfs:label 'Video Quartile 75 Pct' ;
    rdfs:comment 'Percentage of video views that reached the 75% completion point. Expressed as a decimal. Indicates strong creative engagement.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewThroughConversions rdf:type rdf:Property ;
    rdfs:label 'View Through Conversions' ;
    rdfs:comment 'Number of conversions attributed to users who viewed but did not click the ad, then converted within the attribution window. Measures passive ad influence.' ;
    rdfs:domain ind:DigitalPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionId rdf:type rdf:Property ;
    rdfs:label 'Attribution Id' ;
    rdfs:comment 'Primary key for attribution' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionProductSkuId rdf:type rdf:Property ;
    rdfs:label 'Attribution Product Sku Id' ;
    rdfs:comment 'Identifier of the product purchased or converted in the attributed event.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:attributionSkuId rdf:type rdf:Property ;
    rdfs:label 'Attribution Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Attribution models assign conversion revenue to specific SKUs; FK ensures accurate SKU-level performance metrics.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:attributedClicks rdf:type rdf:Property ;
    rdfs:label 'Attributed Clicks' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributedConversions rdf:type rdf:Property ;
    rdfs:label 'Attributed Conversions' ;
    rdfs:comment 'Fractional conversion count credited to this touchpoint (e.g., 0.25 conversions for 25% attribution weight).' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributedImpressions rdf:type rdf:Property ;
    rdfs:label 'Attributed Impressions' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributedRevenue rdf:type rdf:Property ;
    rdfs:label 'Attributed Revenue' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Attributed Revenue Amount' ;
    rdfs:comment 'Revenue amount credited to this touchpoint based on the attribution weight.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributionStatus rdf:type rdf:Property ;
    rdfs:label 'Attribution Status' ;
    rdfs:comment 'Status of the attribution record (final, provisional, recalculated, voided).' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionEventCode rdf:type rdf:Property ;
    rdfs:label 'Conversion Event Code' ;
    rdfs:comment 'Identifier of the conversion event (purchase, sign-up, download) being attributed.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Conversion Timestamp' ;
    rdfs:comment 'Date and time when the conversion event occurred.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conversionType rdf:type rdf:Property ;
    rdfs:label 'Conversion Type' ;
    rdfs:comment 'Type of conversion event being attributed (purchase, add-to-cart, sign-up, download, lead, subscription, trial, engagement). [ENUM-REF-CANDIDATE: purchase|add_to_cart|sign_up|download|lead|subscription|trial|engagement — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerAcquisition rdf:type rdf:Property ;
    rdfs:label 'Cost Per Acquisition' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDirectConversion rdf:type rdf:Property ;
    rdfs:label 'Is Direct Conversion' ;
    rdfs:comment 'Flag indicating whether this was a direct conversion with no prior touchpoints (True/False).' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isViewThrough rdf:type rdf:Property ;
    rdfs:label 'Is View Through' ;
    rdfs:comment 'Flag indicating whether this touchpoint was a view-through impression (ad viewed but not clicked) (True/False).' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lookbackWindowDays rdf:type rdf:Property ;
    rdfs:label 'Lookback Window Days' ;
    rdfs:comment 'Number of days in the attribution lookback window used to identify contributing touchpoints.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End' ;
    rdfs:comment 'Measurement period end' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start' ;
    rdfs:comment 'Measurement period start' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mediaSpendAttributedAmount rdf:type rdf:Property ;
    rdfs:label 'Media Spend Attributed Amount' ;
    rdfs:comment 'Portion of media spend allocated to this touchpoint based on attribution weight.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Model' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelType rdf:type rdf:Property ;
    rdfs:label 'Model Type' ;
    rdfs:comment 'Type of attribution model applied to assign credit (last-touch, first-touch, linear, time-decay, position-based, data-driven MTA).' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Stock Keeping Unit code of the product involved in the conversion event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToConversionHours rdf:type rdf:Property ;
    rdfs:label 'Time To Conversion Hours' ;
    rdfs:comment 'Number of hours elapsed between this touchpoint and the final conversion event.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTouchpoints rdf:type rdf:Property ;
    rdfs:label 'Total Touchpoints' ;
    rdfs:comment 'Total number of marketing touchpoints in the consumer journey leading to this conversion.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:touchpointSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Sequence Number' ;
    rdfs:comment 'Position of this touchpoint in the consumer journey sequence (1 = first touch, N = last touch).' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:touchpointTimestamp rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Timestamp' ;
    rdfs:comment 'Date and time when this specific marketing touchpoint occurred.' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:weight rdf:type rdf:Property ;
    rdfs:label 'Weight' ;
    rdfs:comment 'Fractional credit assigned to this touchpoint by the attribution model (0.0000 to 1.0000, sum across all touchpoints = 1.0).' ;
    rdfs:domain ind:Attribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialListeningRecordId rdf:type rdf:Property ;
    rdfs:label 'Social Listening Record Id' ;
    rdfs:comment 'Unique identifier for the social listening record.' ;
    rdfs:domain ind:SocialListeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitiveBrandMentionFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Brand Mention Flag' ;
    rdfs:comment 'Indicates whether competitive brands were mentioned alongside the monitored brand.' ;
    rdfs:domain ind:SocialListeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crisisAlertFlag rdf:type rdf:Property ;
    rdfs:label 'Crisis Alert Flag' ;
    rdfs:comment 'Indicates whether the mention volume or sentiment triggered a brand crisis alert threshold.' ;
    rdfs:domain ind:SocialListeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataCollectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Collection Timestamp' ;
    rdfs:comment 'Timestamp when the social listening data was collected from the source platform.' ;
    rdfs:domain ind:SocialListeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataSourceProvider rdf:type rdf:Property ;
    rdfs:label 'Data Source Provider' ;
    rdfs:comment 'Name of the social listening platform or vendor that provided the data (e.g., Brandwatch, Sprinklr, Talkwalker).' ;
    rdfs:domain ind:SocialListeningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementCount rdf:type rdf:Property ;
    rdfs:label 'Engagement Count' ;
    rdfs:comment 'Total engagement actions (likes, shares, comments, retweets) across all mentions.' ;
    rdfs:domain ind:SocialListeningRecord ;
    rdf:type owl:DatatypeProperty ;
