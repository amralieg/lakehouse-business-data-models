ind:productLcaId rdf:type rdf:Property ;
    rdfs:label 'Product Lca Id' ;
    rdfs:comment 'Foreign key linking to sustainability.product_lca. Business justification: Revenue recognition reports include product LCA data to meet sustainability disclosure requirements.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
