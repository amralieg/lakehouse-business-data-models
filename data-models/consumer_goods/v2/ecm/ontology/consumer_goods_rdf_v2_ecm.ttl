    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Constraint Applied Flag' ;
    rdfs:comment 'Indicates whether a constraint was applied to the variable consideration estimate to prevent revenue reversal in future periods.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cumulativeCatchUpAdjustment rdf:type rdf:Property ;
    rdfs:label 'Cumulative Catch Up Adjustment' ;
    rdfs:comment 'Cumulative catch-up adjustment to revenue recognized in prior periods due to changes in estimates of variable consideration or performance obligation satisfaction.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeRecognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Recognized Amount' ;
