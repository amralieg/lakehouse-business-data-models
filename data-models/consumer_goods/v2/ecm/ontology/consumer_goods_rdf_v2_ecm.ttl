    rdfs:comment 'Scheduled frequency for cycle counting inventory at this location to maintain inventory accuracy and compliance.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStorageLocationLevel rdf:type rdf:Property ;
    rdfs:label 'Distribution Storage Location Level' ;
    rdfs:comment 'Vertical level or shelf position within the bay for height-based slotting and equipment compatibility.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Eligible Flag' ;
    rdfs:comment 'Indicates whether the location is designated for DSD operations where products bypass the DC and are delivered directly to retail stores.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Required' ;
    rdfs:comment 'Type of material handling equipment required to access this storage location for put-away and picking operations.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fefo Eligible Flag' ;
    rdfs:comment 'Indicates whether the location supports FEFO inventory rotation logic for expiry-sensitive products (pharmaceuticals, food, cosmetics).' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fifoEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fifo Eligible Flag' ;
    rdfs:comment 'Indicates whether the location supports FIFO inventory rotation logic for age-based stock management.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date when the most recent cycle count was performed at this storage location.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name or description of the storage location for operational reference.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational status of the storage location indicating availability for inventory placement and retrieval.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the storage location by operational function: bulk storage, active pick face, reserve inventory, staging area, dock door, or cross-dock zone.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mixedLotAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Mixed Lot Allowed Flag' ;
    rdfs:comment 'Indicates whether the location permits storage of multiple lot or batch numbers for the same SKU or requires lot segregation.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mixedSkuAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Mixed Sku Allowed Flag' ;
    rdfs:comment 'Indicates whether the location permits storage of multiple SKUs simultaneously or requires single-SKU dedication.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickFaceFlag rdf:type rdf:Property ;
    rdfs:label 'Pick Face Flag' ;
    rdfs:comment 'Indicates whether this location is designated as an active pick face for order fulfillment operations.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickingStrategy rdf:type rdf:Property ;
    rdfs:label 'Picking Strategy' ;
    rdfs:comment 'Order fulfillment picking method supported by this location: batch picking, wave picking, zone picking, discrete (single-order), or cluster picking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayStrategy rdf:type rdf:Property ;
    rdfs:label 'Putaway Strategy' ;
    rdfs:comment 'Algorithm used to assign incoming inventory to this location: directed (system-assigned), random, fixed (dedicated SKU), or dynamic (velocity-based).' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentPriority rdf:type rdf:Property ;
    rdfs:label 'Replenishment Priority' ;
    rdfs:comment 'Priority ranking for automated replenishment from reserve to pick locations, with lower numbers indicating higher priority.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionStorageLocationStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Storage Location Status' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Temperature control classification for the storage location to ensure product integrity and regulatory compliance (ambient, refrigerated 2-8°C, frozen <-18°C, controlled room temperature).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Volume Capacity M3' ;
    rdfs:comment 'Maximum volume capacity of the storage location in cubic meters for space utilization and slotting algorithms.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Kg' ;
    rdfs:comment 'Maximum weight capacity of the storage location in kilograms for safe load management and slotting optimization.' ;
    rdfs:domain ind:DistributionStorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Logical zone classification within the distribution center for grouping locations by product category, velocity, or operational workflow (e.g., FAST-PICK, SLOW-MOVE, HAZMAT).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundReceiptId rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Id' ;
    rdfs:comment 'Unique identifier for the inbound receipt transaction. Primary key for this entity.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundReceipt .

ind:inboundDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Inbound Distribution Facility Id' ;
    rdfs:comment 'Identifier of the distribution center facility where the goods were received.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:inboundWarehouseDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Inbound Warehouse Distribution Facility Id' ;
    rdfs:comment 'Identifier of the specific warehouse or storage facility within the distribution center where goods were received.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:primaryInboundEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inbound Employee Id' ;
    rdfs:comment 'Identifier of the quality control personnel who performed the inspection, used for accountability and audit trail.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:receivingClerkEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Clerk Employee Id' ;
    rdfs:comment 'Identifier of the warehouse employee who processed the inbound receipt, used for labor tracking and accountability.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Timestamp' ;
    rdfs:comment 'Precise date and time when the physical goods arrived and were checked in at the receiving dock, representing the principal business event for this transaction.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'Reference to the Advanced Shipping Notice document sent by the supplier prior to shipment arrival, enabling pre-receipt planning and dock scheduling.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseCount rdf:type rdf:Property ;
    rdfs:label 'Case Count' ;
    rdfs:comment 'Number of cases or cartons received in this inbound shipment.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'ISO standard container identifier for ocean freight shipments, following the BIC (Bureau International des Containers) format.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicator of whether any discrepancies (quantity, quality, or documentation) were identified during the receiving process.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text description providing additional details about any discrepancies identified during the receiving process.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyReason rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Reason' ;
    rdfs:comment 'Classification of the type of discrepancy identified during receiving, used for root cause analysis and supplier performance management.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorNumber rdf:type rdf:Property ;
    rdfs:label 'Dock Door Number' ;
    rdfs:comment 'Physical dock door location where the inbound shipment was unloaded, used for labor planning and dock utilization tracking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity' ;
    rdfs:comment 'Total quantity of goods expected to be received based on the ASN or purchase order, used for discrepancy detection.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Document Number' ;
    rdfs:comment 'SAP Material Management (MM) goods receipt document number generated upon posting the receipt to inventory, linking WMS to ERP.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Compliant Flag' ;
    rdfs:comment 'Indicator of whether this receipt met both on-time delivery and complete quantity requirements, key supplier performance metric.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Number of pallets received in this inbound shipment, used for dock capacity planning and labor allocation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:putawayCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Putaway Completion Timestamp' ;
    rdfs:comment 'Date and time when all received goods were moved from the receiving dock to their designated storage locations, completing the inbound process.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Current status of the quality inspection process for this receipt, tracking progression through quality control workflow.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Completion Timestamp' ;
    rdfs:comment 'Date and time when all receiving activities (unloading, inspection, put-away) were completed and the receipt was closed in the WMS.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The date when the inventory lot was received into the distribution center. Used for inventory aging and supplier performance tracking.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Externally-known business identifier for the inbound receipt, used for tracking and reference across systems and with suppliers.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the inbound receipt transaction, tracking progression from scheduling through completion or exception handling.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptType rdf:type rdf:Property ;
    rdfs:label 'Receipt Type' ;
    rdfs:comment 'Classification of the inbound receipt based on the source and nature of the goods being received.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Receipt Date' ;
    rdfs:comment 'Planned date for the inbound shipment to arrive at the distribution center, based on ASN or supplier commitment.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Indicator of whether the security seal was found intact upon arrival, critical for quality control and loss prevention.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Security seal identifier applied to the trailer or container, verified upon receipt to ensure shipment integrity and prevent tampering.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Status' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Check Required Flag' ;
    rdfs:comment 'Indicator of whether temperature verification was required for this receipt due to cold chain or temperature-sensitive product requirements.' ;
    rdfs:domain ind:InboundReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Compliant Flag' ;
    rdfs:comment 'Indicator of whether the recorded temperature was within acceptable range per product specifications and cold chain requirements.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureReadingCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Reading Celsius' ;
    rdfs:comment 'Actual temperature reading in Celsius recorded during receipt inspection for temperature-sensitive products, critical for cold chain compliance.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'Aggregate quantity of units to be picked in the wave.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Number' ;
    rdfs:comment 'Unique identifier of the trailer or truck that delivered the shipment, used for tracking and carrier performance analysis.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundReceiptLineId rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Line Id' ;
    rdfs:comment 'Unique identifier for the inbound receipt line. Primary key for this entity.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundReceiptLine .

ind:asnLineNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Line Number' ;
    rdfs:comment 'Line number within the ASN document corresponding to this receipt line. Enables automated matching between ASN and physical receipt.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionCode rdf:type rdf:Property ;
    rdfs:label 'Condition Code' ;
    rdfs:comment 'Quality condition assessment of the received goods. Determines whether product can be put away into available inventory or requires special handling.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Free-text description of any damage, defects, or quality issues observed during receipt inspection. Used for claims and supplier performance tracking.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedQuantityCases rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity Cases' ;
    rdfs:comment 'Expected quantity in cases as specified in the Advanced Shipping Notice (ASN) or purchase order. Used for variance detection.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedQuantityEaches rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity Eaches' ;
    rdfs:comment 'Expected quantity in eaches as specified in the Advanced Shipping Notice (ASN) or purchase order. Used for variance detection.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedCost rdf:type rdf:Property ;
    rdfs:label 'Extended Cost' ;
    rdfs:comment 'Total cost for this receipt line calculated as unit cost multiplied by received quantity. Used for inventory valuation and financial reconciliation.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:palletCode rdf:type rdf:Property ;
    rdfs:label 'Pallet Code' ;
    rdfs:comment 'Unique identifier for the pallet or handling unit containing this receipt line. Used for put-away and storage location assignment.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderLineNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Line Number' ;
    rdfs:comment 'Line number on the purchase order corresponding to this receipt line. Enables three-way matching between PO, receipt, and invoice.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Purchase order number authorizing the receipt of these goods. Links the receipt to the original procurement transaction.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putAwayTimestamp rdf:type rdf:Property ;
    rdfs:label 'Put Away Timestamp' ;
    rdfs:comment 'Date and time when the goods were put away into their assigned storage location. Used for warehouse productivity and cycle time measurement.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivedQuantityCases rdf:type rdf:Property ;
    rdfs:label 'Received Quantity Cases' ;
    rdfs:comment 'Quantity of product received measured in cases. Represents the outer packaging unit typically used for warehouse handling.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedQuantityEaches rdf:type rdf:Property ;
    rdfs:label 'Received Quantity Eaches' ;
    rdfs:comment 'Quantity of product received measured in individual units (eaches). Represents the consumer-facing unit count.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time when the goods were physically received at the warehouse dock. Critical for OTIF performance measurement and cycle time analytics.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sscc rdf:type rdf:Property ;
    rdfs:label 'Sscc' ;
    rdfs:comment '18-digit Serial Shipping Container Code identifying the logistics unit. Global standard for tracking pallets and containers in the supply chain.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundReceiptLineStatus rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Line Status' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Warehouse storage location code where the received goods were put away. Identifies the bin, rack, or zone within the distribution center.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtReceiptCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature At Receipt Celsius' ;
    rdfs:comment 'Temperature measurement in Celsius recorded at the time of receipt. Critical for cold chain compliance and product quality verification.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantityCases rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity Cases' ;
    rdfs:comment 'Difference between expected and received quantity in cases. Positive values indicate overages, negative values indicate shortages.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantityEaches rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity Eaches' ;
    rdfs:comment 'Difference between expected and received quantity in eaches. Positive values indicate overages, negative values indicate shortages.' ;
    rdfs:domain ind:InboundReceiptLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Code' ;
    rdfs:comment 'Code identifying the distribution center or warehouse facility where the receipt occurred. Used for multi-site inventory management.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayTaskId rdf:type rdf:Property ;
    rdfs:label 'Putaway Task Id' ;
    rdfs:comment 'Unique identifier for the putaway task record generated by the WMS. Primary key for the putaway task entity.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionShipmentId rdf:type rdf:Property ;
    rdfs:label 'Distribution Shipment Id' ;
    rdfs:comment 'Identifier of the inbound shipment or receipt that triggered this putaway task, linking the task back to the receiving process for traceability.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionShipment .

ind:inventoryReplenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Inventory Replenishment Order Id' ;
    rdfs:comment 'Identifier of the replenishment order that generated this putaway task, applicable when the task type is replenishment from reserve to pick face.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryReplenishmentOrder .

ind:primaryPutawayDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Putaway Distribution Storage Location Id' ;
    rdfs:comment 'Identifier of the warehouse location from which the goods are being moved (e.g., receiving dock, staging area, reserve storage).' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:putawayAssignedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Putaway Assigned Employee Id' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:putawayDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Putaway Distribution Storage Location Id' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:putawayEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Putaway Employee Id' ;
    rdfs:comment 'Identifier of the warehouse associate or operator assigned to execute this putaway task, used for labor tracking and productivity measurement.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetLocationDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Target Location Distribution Storage Location Id' ;
    rdfs:comment 'Identifier of the warehouse location to which the goods are being moved (e.g., reserve storage bin, pick face slot, cross-dock staging).' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Confirmation Method' ;
    rdfs:comment 'The method used by the warehouse operator to confirm task completion: barcode scan, RFID tag read, manual entry, voice-directed picking system, or vision-based verification.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cubeCubicFeet rdf:type rdf:Property ;
    rdfs:label 'Cube Cubic Feet' ;
    rdfs:comment 'The total volume in cubic feet of the goods being moved, used for space utilization analysis and slotting optimization.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Minutes' ;
    rdfs:comment 'The elapsed time in minutes from task start to task completion, a key labor productivity KPI used to measure warehouse associate efficiency and identify process bottlenecks.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Free-text description of the exception or issue encountered during putaway execution, providing additional context for operational review and corrective action.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStrategy rdf:type rdf:Property ;
    rdfs:label 'Movement Strategy' ;
    rdfs:comment 'The inventory rotation or replenishment strategy applied to this putaway task: FEFO (First Expired First Out), FIFO (First In First Out), min/max threshold-based, kanban pull signal, wave-driven batch, zone-based slotting, or ABC classification velocity-based. [ENUM-REF-CANDIDATE: FEFO|FIFO|min_max|kanban|wave_driven|zone_based|ABC_classification — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Check Completed Flag' ;
    rdfs:comment 'Boolean flag indicating whether the required quality inspection has been completed and passed, enabling downstream processes to proceed.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Check Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether a quality inspection is required before or after putaway completion, typically for high-value items, temperature-sensitive goods, or regulatory compliance.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceLocationCode rdf:type rdf:Property ;
    rdfs:label 'Source Location Code' ;
    rdfs:comment 'Human-readable code of the source location (e.g., DOCK-A-01, STAGE-B-05) used by warehouse operators for navigation and scanning.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayTaskStatus rdf:type rdf:Property ;
    rdfs:label 'Putaway Task Status' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'The source system or module that generated this putaway task record (e.g., BLUE_YONDER_WMS, SAP_EWM, MANHATTAN_WMS), used for data lineage and integration troubleshooting.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLocationCode rdf:type rdf:Property ;
    rdfs:label 'Target Location Code' ;
    rdfs:comment 'Human-readable code of the target location (e.g., A-12-03-B, PICK-C-22) used by warehouse operators for navigation and scanning.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskAssignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Assigned Timestamp' ;
    rdfs:comment 'The date and time when the putaway task was assigned to a warehouse operator, used to measure assignment latency and labor allocation efficiency.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Cancelled Timestamp' ;
    rdfs:comment 'The date and time when the putaway task was cancelled, applicable when the task is aborted due to inventory discrepancies, system errors, or operational changes.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Completed Timestamp' ;
    rdfs:comment 'The date and time when the putaway task was completed (e.g., goods confirmed in target location), marking the end of the task lifecycle and enabling cycle time KPI calculation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Created Timestamp' ;
    rdfs:comment 'The date and time when the putaway task was created by the WMS, marking the start of the task lifecycle and used for cycle time calculation.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'Human-readable business identifier for the putaway task, typically generated by Blue Yonder WMS for tracking and operator reference.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Started Timestamp' ;
    rdfs:comment 'The date and time when the warehouse operator began executing the putaway task (e.g., scanned the source location or pallet), used for labor productivity tracking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the putaway task indicating its execution state within the warehouse workflow.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the putaway task based on the movement purpose: inbound putaway (receiving dock to storage), replenishment (reserve to pick face), cross-dock (dock to dock), returns putaway (returns area to storage), or internal transfer.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDistanceFeet rdf:type rdf:Property ;
    rdfs:label 'Travel Distance Feet' ;
    rdfs:comment 'The physical distance in feet traveled by the warehouse operator from source to target location, used for slotting optimization and labor efficiency analysis.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waveCode rdf:type rdf:Property ;
    rdfs:label 'Wave Code' ;
    rdfs:comment 'Identifier of the wave or batch of tasks to which this putaway task belongs, used for wave-driven replenishment and coordinated task execution.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightLbs rdf:type rdf:Property ;
    rdfs:label 'Weight Lbs' ;
    rdfs:comment 'The total weight in pounds of the goods being moved in this putaway task, used for equipment selection, labor safety, and capacity planning.' ;
    rdfs:domain ind:PutawayTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundOrderId rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Id' ;
    rdfs:comment 'Unique identifier for the outbound fulfillment order. Primary key for the outbound order entity.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundOrder .

ind:freightOrderId rdf:type rdf:Property ;
    rdfs:label 'Freight Order Id' ;
    rdfs:comment 'Foreign key linking to logistics.freight_order. Business justification: Freight order creation for every outbound order manages carrier tendering, freight cost tracking, and audit.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightOrder .

ind:outboundDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Outbound Distribution Facility Id' ;
    rdfs:comment 'Identifier of the distribution center fulfilling the outbound order. Determines inventory source and warehouse operations responsible for order execution.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:outboundSalesOrderId rdf:type rdf:Property ;
    rdfs:label 'Outbound Sales Order Id' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:outboundShipToLocationDistributionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Outbound Ship To Location Distribution Facility Id' ;
    rdfs:comment 'Identifier of the destination location where the order will be delivered. May reference retail store, warehouse, or customer facility.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionFacility .

ind:routeId rdf:type rdf:Property ;
    rdfs:label 'Route Id' ;
    rdfs:comment 'Identifier of the delivery route assigned to the outbound order. Used for DSD (Direct Store Delivery) route optimization and multi-stop delivery planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:backorderFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Flag' ;
    rdfs:comment 'Indicates whether any line items on the order are backordered due to insufficient inventory. True when ordered quantity exceeds available stock.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Carrier-issued document number serving as receipt of goods and contract of carriage. Required for freight claims and proof of delivery.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Date and time when the order was cancelled. Null for active orders. Used for cancellation rate analysis and order lifecycle reporting.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fillRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Percentage' ;
    rdfs:comment 'Percentage of ordered quantity that was fulfilled from available inventory. Calculated as (shipped quantity / ordered quantity) * 100. Key metric for inventory availability and customer service.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'International Commercial Terms defining the division of costs and risks between buyer and seller. Critical for export orders and freight responsibility determination. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Commitment Flag' ;
    rdfs:comment 'Indicates whether this order is subject to formal OTIF performance measurement and customer scorecard reporting. True for orders with contractual delivery commitments.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packingSlipNumber rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Number' ;
    rdfs:comment 'Document number for the packing slip accompanying the shipment. Used for customer receiving and invoice reconciliation.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Pick Ticket Number' ;
    rdfs:comment 'Warehouse document number used to direct picking operations for this order. Generated by WMS when order is released to the warehouse floor.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Timestamp' ;
    rdfs:comment 'Date and time when delivery was confirmed by the recipient. Captured from carrier POD or customer signature. Used for OTIF measurement and freight audit.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'Date when the customer or system requests the order to be shipped from the distribution center. Used for warehouse planning and scheduling.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the order must be delivered to the customer destination. Critical for OTIF (On Time In Full) performance measurement and SLA compliance.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Delivery speed commitment for the outbound order. Determines carrier selection, freight cost, and OTIF measurement criteria.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Transportation mode used for order delivery. Ground for truck, air for expedited freight, ocean for international, rail for bulk, parcel for small packages, LTL (Less Than Truckload) for partial loads, FTL (Full Truckload) for full loads. [ENUM-REF-CANDIDATE: ground|air|ocean|rail|parcel|ltl|ftl — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text instructions for warehouse and logistics teams regarding special handling requirements. May include temperature control, fragile handling, hazmat procedures, or customer-specific delivery instructions.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Status' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Order Quantity' ;
    rdfs:comment 'Total quantity of units across all line items in the outbound order. Used for warehouse capacity planning and OTIF fill rate calculation.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Total monetary value of the outbound order before taxes and freight charges. Used for order prioritization, credit limit checks, and revenue forecasting.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Order Volume M3' ;
    rdfs:comment 'Total volume of the outbound order in cubic meters. Used for warehouse space planning, truck cube utilization, and pallet configuration.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Order Weight Kg' ;
    rdfs:comment 'Total weight of the outbound order in kilograms. Used for freight cost calculation, carrier capacity planning, and vehicle loading optimization.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Line Id' ;
    rdfs:comment 'Unique identifier for the outbound order line item.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundOrderLine .

ind:labelVersionId rdf:type rdf:Property ;
    rdfs:label 'Label Version Id' ;
    rdfs:comment 'Foreign key linking to regulatory.label_version. Business justification: Label version compliance check before order fulfillment guarantees the label used for the SKU is approved for the destination market.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabelVersion .

ind:baseUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Unit Quantity' ;
    rdfs:comment 'Quantity converted to base unit of measure for standardized reporting and inventory tracking.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerPoLineNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Po Line Number' ;
    rdfs:comment 'Customer\'s purchase order line number for cross-reference and reconciliation.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Flag' ;
    rdfs:comment 'Indicates whether this line is part of a direct store delivery order bypassing retailer distribution centers.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediLineReference rdf:type rdf:Property ;
    rdfs:label 'Edi Line Reference' ;
    rdfs:comment 'EDI transaction line reference number for electronic order processing and ASN generation.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingUnitCode rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Code' ;
    rdfs:comment 'Serial shipping container code (SSCC) or handling unit identifier for the container holding this line item.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Line Volume M3' ;
    rdfs:comment 'Total volume of the shipped quantity for this line in cubic meters.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineWeightKg rdf:type rdf:Property ;
    rdfs:label 'Line Weight Kg' ;
    rdfs:comment 'Total weight of the shipped quantity for this line in kilograms.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'Quantity of the SKU originally requested by the customer in the order.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifStatus rdf:type rdf:Property ;
    rdfs:label 'Otif Status' ;
    rdfs:comment 'Line-level OTIF performance status indicating whether the line was delivered on time and in full quantity.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Timestamp' ;
    rdfs:comment 'Date and time when the line item was packed into shipping containers.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packedQuantity rdf:type rdf:Property ;
    rdfs:label 'Packed Quantity' ;
    rdfs:comment 'Quantity packed into shipping containers and ready for dispatch.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Timestamp' ;
    rdfs:comment 'Date and time when the line item was picked from warehouse inventory.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickZone rdf:type rdf:Property ;
    rdfs:label 'Pick Zone' ;
    rdfs:comment 'Warehouse pick zone designation for labor management and routing optimization.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickedQuantity rdf:type rdf:Property ;
    rdfs:label 'Picked Quantity' ;
    rdfs:comment 'Quantity physically picked from warehouse storage locations during fulfillment.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumbers rdf:type rdf:Property ;
    rdfs:label 'Serial Numbers' ;
    rdfs:comment 'Comma-separated list of serial numbers for serialized inventory items shipped on this line.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ship Timestamp' ;
    rdfs:comment 'Date and time when the line item was shipped from the distribution center.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shortShipFlag rdf:type rdf:Property ;
    rdfs:label 'Short Ship Flag' ;
    rdfs:comment 'Indicates whether this line was short-shipped (shipped quantity less than ordered quantity).' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortShipReasonCode rdf:type rdf:Property ;
    rdfs:label 'Short Ship Reason Code' ;
    rdfs:comment 'Reason code for short shipment (OOS=Out of Stock, DAMAGE=Damaged Inventory, RECALL=Product Recall, EXPIRED=Expired Product, ALLOCATION=Allocation Constraint).' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundOrderLineStatus rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Line Status' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Unit Volume M3' ;
    rdfs:comment 'Volume per unit of the SKU in cubic meters for space utilization and load planning.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitWeightKg rdf:type rdf:Property ;
    rdfs:label 'Unit Weight Kg' ;
    rdfs:comment 'Weight per unit of the SKU in kilograms for freight calculation and capacity planning.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseLocationCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Code' ;
    rdfs:comment 'Distribution center or warehouse location code from which this line was fulfilled.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickTaskId rdf:type rdf:Property ;
    rdfs:label 'Pick Task Id' ;
    rdfs:comment 'Unique identifier for the pick task record. Primary key for the pick_task data product.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PickTask .

ind:destinationLocationDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Distribution Storage Location Id' ;
    rdfs:comment 'Reference to the target location where picked items are staged or packed (e.g., pack station, staging lane, loading dock).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:pickAssignedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Pick Assigned Employee Id' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:pickDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Pick Distribution Storage Location Id' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:primaryPickDistributionStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Pick Distribution Storage Location Id' ;
    rdfs:comment 'Reference to the warehouse storage location (bin, shelf, pallet position) from which inventory is picked.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionStorageLocation .

ind:primaryPickEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Pick Employee Id' ;
    rdfs:comment 'Reference to the warehouse operator or picker assigned to execute this task.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cartonCode rdf:type rdf:Property ;
    rdfs:label 'Carton Code' ;
    rdfs:comment 'Unique identifier for the carton or shipping container into which items are packed. May be a license plate number (LPN) or SSCC (Serial Shipping Container Code).' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gs1128Label rdf:type rdf:Property ;
    rdfs:label 'Gs1 128 Label' ;
    rdfs:comment 'The GS1-128 barcode label data applied to the carton or pallet, encoding SSCC, GTIN, lot, expiry, and other supply chain attributes.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otifEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether this pick task is subject to OTIF (On Time In Full) performance measurement (true = OTIF tracked, false = not tracked).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packStationCode rdf:type rdf:Property ;
    rdfs:label 'Pack Station Code' ;
    rdfs:comment 'Reference to the packing station where the packing operation is performed. Applicable when task_type includes packing.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingMaterialCode rdf:type rdf:Property ;
    rdfs:label 'Packaging Material Code' ;
    rdfs:comment 'Code identifying the type of packaging material used (e.g., corrugated box, poly bag, shrink wrap). Used for cartonization and sustainability tracking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickAccuracyFlag rdf:type rdf:Property ;
    rdfs:label 'Pick Accuracy Flag' ;
    rdfs:comment 'Boolean indicator of whether the pick was accurate (true = picked quantity matches requested quantity and correct SKU/lot; false = discrepancy detected).' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickListNumber rdf:type rdf:Property ;
    rdfs:label 'Pick List Number' ;
    rdfs:comment 'Human-readable pick list reference number assigned by the WMS for operator identification and tracking.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickQuantity rdf:type rdf:Property ;
    rdfs:label 'Pick Quantity' ;
    rdfs:comment 'The quantity of SKU units to be picked for this task, measured in the SKU\'s base unit of measure.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickTaskStatus rdf:type rdf:Property ;
    rdfs:label 'Pick Task Status' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Task Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from task start to completion. Used for labor productivity analysis and standard time calculation.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packTaskId rdf:type rdf:Property ;
    rdfs:label 'Pack Task Id' ;
    rdfs:comment 'Unique identifier for the packing task record. Primary key.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packAssignedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Pack Assigned Employee Id' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryPackEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Pack Employee Id' ;
    rdfs:comment 'Identifier of the warehouse operator who performed the packing task.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cartonCount rdf:type rdf:Property ;
    rdfs:label 'Carton Count' ;
    rdfs:comment 'Total number of cartons or cases included in the shipment. Used for piece-level tracking and receiving verification.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cartonizationRuleCode rdf:type rdf:Property ;
    rdfs:label 'Cartonization Rule Code' ;
    rdfs:comment 'Reference to the cartonization algorithm or business rule used to determine optimal packing configuration.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Code' ;
    rdfs:comment 'Code identifying the destination distribution center, retail store, or customer facility for the packed shipment.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelPrintedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Label Printed Timestamp' ;
    rdfs:comment 'Timestamp when the shipping label was printed for the packed container.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:otifTargetShipDate rdf:type rdf:Property ;
    rdfs:label 'Otif Target Ship Date' ;
    rdfs:comment 'Target ship date for OTIF performance measurement and customer service level compliance.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Completion Timestamp' ;
    rdfs:comment 'Timestamp when the packing task was completed and sealed for dispatch.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Pack Duration Minutes' ;
    rdfs:comment 'Total time in minutes taken to complete the packing task, used for labor productivity analysis.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Start Timestamp' ;
    rdfs:comment 'Timestamp when the packing task was initiated by the operator.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packStatus rdf:type rdf:Property ;
    rdfs:label 'Pack Status' ;
    rdfs:comment 'Current lifecycle status of the packing task.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packType rdf:type rdf:Property ;
    rdfs:label 'Pack Type' ;
    rdfs:comment 'Type of packing configuration used for the task.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Check Status' ;
    rdfs:comment 'Status of quality verification performed on the packed container before dispatch.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityPacked rdf:type rdf:Property ;
    rdfs:label 'Quantity Packed' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packTaskStatus rdf:type rdf:Property ;
    rdfs:label 'Pack Task Status' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSkuCount rdf:type rdf:Property ;
    rdfs:label 'Total Sku Count' ;
    rdfs:comment 'Total number of distinct SKUs packed into the container.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Unit Quantity' ;
    rdfs:comment 'Total quantity of units packed across all SKUs in the container.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Meters' ;
    rdfs:comment 'Total volumetric capacity of the packed container in cubic meters, used for transportation planning.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intransitShipmentId rdf:type rdf:Property ;
    rdfs:label 'Intransit Shipment Id' ;
    rdfs:comment 'Foreign key linking to inventory.intransit_shipment. Business justification: SHIPMENT HAND-OFF: Distribution shipment creates an In-Transit Shipment record to track movement from DC to destination.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntransitShipment .

ind:loadedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Loaded By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Needed for Load Execution Log to record which warehouse employee performed the loading of each shipment, supporting OTIF compliance and labor costing.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Actual date and time when the shipment was delivered and received at the destination. Used for final OTIF calculation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual date and time when the shipment departed the DC. Critical for OTIF calculation and carrier performance tracking.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Level' ;
    rdfs:comment 'Service tier selected for this shipment defining speed and handling requirements.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Destination Address Line1' ;
    rdfs:comment 'Primary street address line of the shipment destination. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCity rdf:type rdf:Property ;
    rdfs:label 'Destination City' ;
    rdfs:comment 'City name of the shipment destination address.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Code' ;
    rdfs:comment 'Business identifier of the destination location (store number, DC code, customer account number) where goods are being delivered.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the shipment destination for customs and routing purposes.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationName rdf:type rdf:Property ;
    rdfs:label 'Destination Name' ;
    rdfs:comment 'Human-readable name of the destination location for display and confirmation purposes.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the shipment destination. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStateProvince rdf:type rdf:Property ;
    rdfs:label 'Destination State Province' ;
    rdfs:comment 'State or province code of the shipment destination address.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationType rdf:type rdf:Property ;
    rdfs:label 'Destination Type' ;
    rdfs:comment 'Classification of the shipment destination entity type for routing and handling purposes.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Timestamp' ;
    rdfs:comment 'Current estimated delivery date and time based on real-time tracking and carrier updates. Updated dynamically during transit.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Amount' ;
    rdfs:comment 'Total freight cost charged for this shipment in the transaction currency. Used for logistics cost analysis and freight audit.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the freight charge amount.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Terms defining which party is responsible for freight payment and at what point ownership transfers. Critical for cost allocation.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Document Number' ;
    rdfs:comment 'SAP SD goods issue document number linking the physical shipment to the ERP inventory transaction. Critical for inventory accuracy.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inFullFlag rdf:type rdf:Property ;
    rdfs:label 'In Full Flag' ;
    rdfs:comment 'Boolean indicator of whether the shipment was delivered complete with all ordered quantities. Component of OTIF calculation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemCount rdf:type rdf:Property ;
    rdfs:label 'Line Item Count' ;
    rdfs:comment 'Total number of distinct SKU line items included in the shipment. Used for picking complexity and receiving planning.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadNumber rdf:type rdf:Property ;
    rdfs:label 'Load Number' ;
    rdfs:comment 'Identifier of the load plan that consolidated multiple orders or shipments into this trailer. Used for load optimization tracking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Flag' ;
    rdfs:comment 'Boolean indicator of whether the shipment was delivered within the committed delivery window. Component of OTIF calculation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Carrier-assigned progressive number used for tracking and tracing the shipment in the carriers system.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'Planned date for the shipment to arrive at the destination. Used for customer commitment and OTIF measurement.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Timestamp' ;
    rdfs:comment 'Planned date and time for the shipment to arrive at the destination. Precision timestamp for delivery window commitments.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Timestamp' ;
    rdfs:comment 'Planned date and time for the shipment to depart from the DC dock. Precision timestamp for appointment scheduling and carrier coordination.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledShipDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Ship Date' ;
    rdfs:comment 'Planned date for the shipment to depart from the distribution center. Used for OTIF performance measurement baseline.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally-known unique business identifier for the shipment assigned by the WMS. Used for tracking and reference across systems and with carriers.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment in the outbound fulfillment workflow. Tracks progression from planning through final delivery. [ENUM-REF-CANDIDATE: planned|staged|loading|loaded|departed|in_transit|delivered|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Classification of the shipment based on delivery method and business purpose. DSD indicates Direct Store Delivery channel.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionShipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Shipment Status' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUnits rdf:type rdf:Property ;
    rdfs:label 'Total Units' ;
    rdfs:comment 'Total quantity of individual sellable units (eaches) included in the shipment across all SKUs.' ;
    rdfs:domain ind:DistributionShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cubic Meters' ;
    rdfs:comment 'Total cube or volume of the shipment in cubic meters. Critical for trailer utilization and dimensional weight calculations.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waveNumber rdf:type rdf:Property ;
    rdfs:label 'Wave Number' ;
    rdfs:comment 'Identifier of the warehouse picking wave that generated the orders included in this shipment. Links shipment to WMS wave planning.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryPositionId rdf:type rdf:Property ;
    rdfs:label 'Inventory Position Id' ;
    rdfs:comment 'Primary key for inventory_position' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inventory Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Supports Inventory Ownership Dashboard, assigning a responsible employee for each DC inventory position for accountability and cycle-count oversight.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualWeight rdf:type rdf:Property ;
    rdfs:label 'Actual Weight' ;
    rdfs:comment 'The actual measured weight of the inventory for catch weight items. Used for billing and compliance when item weight varies.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asOfDate rdf:type rdf:Property ;
    rdfs:label 'As Of Date' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:catchWeightFlag rdf:type rdf:Property ;
    rdfs:label 'Catch Weight Flag' ;
    rdfs:comment 'Indicates whether the SKU is a catch weight item requiring actual weight capture at transaction time (true) or standard weight (false).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysOnHand rdf:type rdf:Property ;
    rdfs:label 'Days On Hand' ;
    rdfs:comment 'The number of days the inventory has been on hand since receipt. Calculated as current date minus receipt date. Used for aging analysis.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysToExpiry rdf:type rdf:Property ;
    rdfs:label 'Days To Expiry' ;
    rdfs:comment 'The number of days remaining until the inventory lot expires. Calculated as expiry date minus current date. Critical for FEFO rotation and markdown decisions.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryCondition rdf:type rdf:Property ;
    rdfs:label 'Inventory Condition' ;
    rdfs:comment 'The physical condition classification of the inventory. Used for disposition decisions and channel restrictions.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'The current operational status of the inventory position. Determines availability for picking and order fulfillment.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'The date when inventory was last moved into or out of this storage location. Used for slow-moving inventory identification.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementType rdf:type rdf:Property ;
    rdfs:label 'Last Movement Type' ;
    rdfs:comment 'The type of the last inventory movement transaction that affected this position (receipt, putaway, pick, replenishment, transfer, adjustment, return). [ENUM-REF-CANDIDATE: receipt|putaway|pick|replenishment|transfer|adjustment|return — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensePlateNumber rdf:type rdf:Property ;
    rdfs:label 'License Plate Number' ;
    rdfs:comment 'The warehouse management system license plate number assigned to the handling unit. Used for tracking and automated material handling.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onHandQuantity rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Indicates the ownership model of the inventory (owned by company, consignment from supplier, customer-owned for returns, vendor-managed inventory).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayDate rdf:type rdf:Property ;
    rdfs:label 'Putaway Date' ;
    rdfs:comment 'The date when the inventory was put away into this storage location after receiving. Used for aging analysis and FEFO compliance.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityAllocated rdf:type rdf:Property ;
    rdfs:label 'Quantity Allocated' ;
    rdfs:comment 'The quantity of on-hand inventory that has been allocated to outbound orders or reservations but not yet picked. Reduces available-to-pick quantity.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDamaged rdf:type rdf:Property ;
    rdfs:label 'Quantity Damaged' ;
    rdfs:comment 'The quantity of inventory identified as damaged and not suitable for sale or distribution. Typically awaiting disposal or return to supplier.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityHold rdf:type rdf:Property ;
    rdfs:label 'Quantity Hold' ;
    rdfs:comment 'The quantity of inventory placed on hold due to quality issues, customer complaints, or pending investigation. Not available for picking.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'The total physical quantity of the SKU-lot currently present in the storage location. Measured in the SKU\'s base unit of measure.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityQuarantine rdf:type rdf:Property ;
    rdfs:label 'Quantity Quarantine' ;
    rdfs:comment 'The quantity of inventory placed in quarantine status pending quality inspection or regulatory clearance. Not available for picking.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'The quantity of inventory reserved for specific customers, channels, or promotional programs. Subset of allocated quantity with additional business constraints.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentFlag rdf:type rdf:Property ;
    rdfs:label 'Replenishment Flag' ;
    rdfs:comment 'Indicates whether this inventory position requires replenishment from reserve to pick face (true) or not (false). Triggers automated replenishment tasks.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'The timestamp when this inventory position snapshot was captured. Used for point-in-time inventory reporting and trend analysis.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:storageZone rdf:type rdf:Property ;
    rdfs:label 'Storage Zone' ;
    rdfs:comment 'The logical zone within the distribution center where the inventory is stored (e.g., ambient, refrigerated, frozen, hazmat, high-velocity, reserve).' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalInventoryValue rdf:type rdf:Property ;
    rdfs:label 'Total Inventory Value' ;
    rdfs:comment 'The total financial value of the inventory position calculated as quantity_on_hand multiplied by cost_per_unit. Used for balance sheet reporting. Business confidential financial data.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Weight Unit Of Measure' ;
    rdfs:comment 'The unit of measure for actual weight (Pound, Kilogram, Ounce, Gram). Applicable for catch weight items.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionCycleCountId rdf:type rdf:Property ;
    rdfs:label 'Distribution Cycle Count Id' ;
    rdfs:comment 'Unique identifier for the cycle count event record. Primary key for the distribution cycle count entity.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionCountedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Distribution Counted By Employee Id' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:inventoryCycleCountId rdf:type rdf:Property ;
    rdfs:label 'Inventory Cycle Count Id' ;
    rdfs:comment 'FK to inventory cycle count' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryCycleCount .

ind:inventoryStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Inventory Storage Location Id' ;
    rdfs:comment 'Identifier of the specific storage location (bin, rack, aisle) within the DC where the count was performed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryStorageLocation .

ind:primaryDistributionCounterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Counter Employee Id' ;
    rdfs:comment 'Identifier of the warehouse associate who performed the physical count.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Approved Flag' ;
    rdfs:comment 'Indicates whether the inventory adjustment has been approved by a supervisor or manager.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Required Flag' ;
    rdfs:comment 'Indicates whether an inventory adjustment is required based on the variance exceeding tolerance thresholds.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countDate rdf:type rdf:Property ;
    rdfs:label 'Count Date' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count End Timestamp' ;
    rdfs:comment 'The date and time when the physical counting activity was completed.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'The method used to perform the physical count: manual (paper-based), RF scanner (handheld device), voice picking (voice-directed), or automated (RFID/sensor).' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNumber rdf:type rdf:Property ;
    rdfs:label 'Count Number' ;
    rdfs:comment 'Business identifier for the cycle count event, typically generated by the WMS. Format: CC-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countReasonCode rdf:type rdf:Property ;
    rdfs:label 'Count Reason Code' ;
    rdfs:comment 'The business reason triggering this cycle count: routine (scheduled ABC cycle), discrepancy (prior variance), audit (compliance), quality (QC hold), recall (product recall), transfer (location move).' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'The date and time when the physical counting activity began.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the cycle count event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the cycle count event: scheduled (routine ABC cycle), ad-hoc (unplanned), exception (triggered by discrepancy), blind (counter does not see system quantity), or targeted (specific SKU/lot focus).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'The actual physical quantity counted by the warehouse associate during the cycle count event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryValueVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Inventory Value Variance Amount' ;
    rdfs:comment 'The financial impact of the variance, calculated as variance_quantity multiplied by the standard cost of the SKU. Expressed in the DC\'s functional currency.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recountNumber rdf:type rdf:Property ;
    rdfs:label 'Recount Number' ;
    rdfs:comment 'Sequential number indicating which recount iteration this represents (1 for first recount, 2 for second, etc.). Null if no recount performed.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recountRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Required Flag' ;
    rdfs:comment 'Indicates whether a recount is required due to significant variance or quality control procedures.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The date on which the cycle count was scheduled to be performed.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionCycleCountStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Cycle Count Status' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Status' ;
    rdfs:comment 'The inventory status of the counted stock: available (unrestricted), hold (QC hold), quarantine (quality review), damaged, expired, or reserved (allocated to orders).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemQuantity rdf:type rdf:Property ;
    rdfs:label 'System Quantity' ;
    rdfs:comment 'The quantity of the SKU/lot recorded in the WMS at the time of the cycle count.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold Percentage' ;
    rdfs:comment 'The acceptable variance percentage threshold. Variances within this percentage may not require adjustment.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceThresholdQuantity rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold Quantity' ;
    rdfs:comment 'The acceptable variance quantity threshold defined for this SKU/location combination. Variances within this threshold may not require adjustment.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceNotes rdf:type rdf:Property ;
    rdfs:label 'Variance Notes' ;
    rdfs:comment 'Free-text notes providing additional context or explanation for the variance observed during the cycle count.' ;
    rdfs:domain ind:DistributionCycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'The difference between counted quantity and system quantity (counted minus system). Positive indicates overage, negative indicates shortage.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Wms Transaction Code' ;
    rdfs:comment 'The unique transaction identifier generated by the WMS for this cycle count event, used for audit trail and system reconciliation.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionDsdRouteId rdf:type rdf:Property ;
    rdfs:label 'Distribution Dsd Route Id' ;
    rdfs:comment 'Unique identifier for the DSD route record. Primary key.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionDsdRoute .

ind:primaryDistributionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Employee Id' ;
    rdfs:comment 'Identifier of the driver or sales representative permanently or primarily assigned to this route. May be null for unassigned or pool routes.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:averageOrderValue rdf:type rdf:Property ;
    rdfs:label 'Average Order Value' ;
    rdfs:comment 'Historical average order value per stop on this route in local currency. Used for revenue forecasting and route profitability analysis.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Day Of Week' ;
    rdfs:comment 'Day of week (1=Mon)' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Delivery Day Of Week' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDriveTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Drive Time Minutes' ;
    rdfs:comment 'Estimated total driving time for the route in minutes, excluding stop service time. Used for driver shift planning and OTIF performance targets.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedServiceTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Service Time Minutes' ;
    rdfs:comment 'Estimated total time spent at customer stops for unloading, merchandising, and order processing in minutes. Combined with drive time for total route duration.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastOptimizationDate rdf:type rdf:Property ;
    rdfs:label 'Last Optimization Date' ;
    rdfs:comment 'Date when this route was last reviewed and optimized for efficiency. Used to identify routes due for re-evaluation.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:merchandisingRequired rdf:type rdf:Property ;
    rdfs:label 'Merchandising Required' ;
    rdfs:comment 'Boolean flag indicating whether this route includes merchandising activities (shelf stocking, display setup, POG compliance) in addition to delivery. True if merchandising is part of the service.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfStops rdf:type rdf:Property ;
    rdfs:label 'Number Of Stops' ;
    rdfs:comment 'Total count of retail store or customer locations included in this route. Used for route capacity planning and driver workload estimation.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Time' ;
    rdfs:comment 'Standard departure time from the DC for this route in HH:MM format (24-hour clock). Used for driver scheduling and DC loading dock coordination.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedReturnTime rdf:type rdf:Property ;
    rdfs:label 'Planned Return Time' ;
    rdfs:comment 'Expected return time to the DC for this route in HH:MM format (24-hour clock). Used for driver shift planning and vehicle turnaround scheduling.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiresColdChain rdf:type rdf:Property ;
    rdfs:label 'Requires Cold Chain' ;
    rdfs:comment 'Boolean flag indicating whether this route requires temperature-controlled (refrigerated or frozen) transportation for product integrity. True if cold chain is required.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresHazmatCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Hazmat Certification' ;
    rdfs:comment 'Boolean flag indicating whether the driver assigned to this route must hold hazmat certification due to regulated products (e.g., aerosols, flammables). True if certification is required.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeOptimizationScore rdf:type rdf:Property ;
    rdfs:label 'Route Optimization Score' ;
    rdfs:comment 'Calculated efficiency score for this route based on distance, time, stops, and revenue, typically ranging from 0-100. Higher scores indicate more optimized routes. Used for continuous improvement initiatives.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the DSD route based on service model: standard (regular scheduled delivery), express (same-day or expedited), bulk (high-volume customers), emergency (unplanned replenishment), seasonal (temporary routes for peak demand).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDayPattern rdf:type rdf:Property ;
    rdfs:label 'Service Day Pattern' ;
    rdfs:comment 'Comma-separated list of days of the week this route is scheduled to run (e.g., \'Mon,Wed,Fri\' for a three-day-per-week route). Supports recurring schedule planning.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Start Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the route start point (typically the DC or depot). Used for route optimization and GPS tracking.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Start Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the route start point (typically the DC or depot). Used for route optimization and GPS tracking.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionDsdRouteStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Dsd Route Status' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopCount rdf:type rdf:Property ;
    rdfs:label 'Stop Count' ;
    rdfs:comment 'Total number of delivery stops planned for this load, used for multi-stop route optimization.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Total Distance Km' ;
    rdfs:comment 'Total driving distance for the complete route in kilometers, from DC departure through all stops and return. Used for fuel cost estimation and vehicle range planning.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleCapacityRequiredUnits rdf:type rdf:Property ;
    rdfs:label 'Vehicle Capacity Required Units' ;
    rdfs:comment 'Minimum vehicle cargo capacity required in standard units (cases, pallets, or cubic meters) to fulfill typical route demand. Used for vehicle assignment.' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type Required' ;
    rdfs:comment 'Type of vehicle required to service this route based on cargo volume, weight, and product requirements (e.g., refrigerated for cold chain products).' ;
    rdfs:domain ind:DistributionDsdRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionDsdDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Distribution Dsd Delivery Id' ;
    rdfs:comment 'Unique identifier for the DSD delivery transaction. Primary key for the distribution_dsd_delivery product.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionDsdDelivery .

ind:actualArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Time' ;
    rdfs:comment 'The actual timestamp when the driver arrived at the retail store location. Used for On Time In Full (OTIF) performance measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Exception Code' ;
    rdfs:comment 'Code indicating any exception or issue encountered during the delivery attempt. Used for root cause analysis of delivery failures. [ENUM-REF-CANDIDATE: store_closed|access_denied|incomplete_order|damaged_product|wrong_address|weather_delay|traffic_delay|vehicle_breakdown|none — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes captured by the driver regarding delivery conditions, store feedback, or special circumstances encountered during the visit.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryValueAmount rdf:type rdf:Property ;
    rdfs:label 'Delivery Value Amount' ;
    rdfs:comment 'The total monetary value of products delivered during this visit, calculated at invoice price. Represents gross delivery value before returns and credits.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End' ;
    rdfs:comment 'The end of the agreed delivery time window with the retail store. Part of Service Level Agreement (SLA) for OTIF measurement.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start' ;
    rdfs:comment 'The beginning of the agreed delivery time window with the retail store. Part of Service Level Agreement (SLA) for OTIF measurement.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:departureTime rdf:type rdf:Property ;
    rdfs:label 'Departure Time' ;
    rdfs:comment 'The timestamp when the driver departed from the retail store after completing delivery and merchandising activities.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'Geographic latitude coordinate captured at delivery location for route verification and geospatial analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'Geographic longitude coordinate captured at delivery location for route verification and geospatial analytics.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchandisingActivityType rdf:type rdf:Property ;
    rdfs:label 'Merchandising Activity Type' ;
    rdfs:comment 'The type of in-store merchandising activity performed during the delivery visit. Supports retail execution and On Shelf Availability (OSA) objectives.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandisingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Merchandising Duration Minutes' ;
    rdfs:comment 'The total time in minutes spent on merchandising activities during the store visit. Used for labor productivity analysis.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:merchandisingPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Merchandising Performed Flag' ;
    rdfs:comment 'Indicates whether in-store merchandising activities (shelf stocking, rotation, display setup) were performed during this delivery visit.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netDeliveryAmount rdf:type rdf:Property ;
    rdfs:label 'Net Delivery Amount' ;
    rdfs:comment 'The net monetary value of the delivery after subtracting return credits from gross delivery value. Represents actual secondary sales value.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Compliance Flag' ;
    rdfs:comment 'Indicates whether this delivery met On Time In Full (OTIF) performance criteria: arrived within delivery window and delivered complete order quantity.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:podCaptureMethod rdf:type rdf:Property ;
    rdfs:label 'Pod Capture Method' ;
    rdfs:comment 'The method used to capture proof of delivery from the store recipient. Electronic signature and photo are preferred for audit trail.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podPhotoUrl rdf:type rdf:Property ;
    rdfs:label 'Pod Photo Url' ;
    rdfs:comment 'URL reference to the photo evidence of delivery captured at the store. Links to document management system for audit purposes.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSignatureImageUrl rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Image Url' ;
    rdfs:comment 'URL reference to the stored electronic signature image captured as proof of delivery. Links to document management system.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Flag' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'The name of the store employee who received and acknowledged the delivery. Captured for proof of delivery and accountability.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Return Credit Amount' ;
    rdfs:comment 'The total monetary value of product returns credited to the store during this visit. Reduces net delivery value.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Time' ;
    rdfs:comment 'The planned arrival timestamp at the retail store based on route optimization and store delivery window requirements.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distributionDsdDeliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Dsd Delivery Status' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCases rdf:type rdf:Property ;
    rdfs:label 'Total Cases' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCasesDelivered rdf:type rdf:Property ;
    rdfs:label 'Total Cases Delivered' ;
    rdfs:comment 'The total quantity of product cases delivered to the store during this visit. Aggregate measure across all SKUs (Stock Keeping Units) delivered.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCasesReturned rdf:type rdf:Property ;
    rdfs:label 'Total Cases Returned' ;
    rdfs:comment 'The total quantity of product cases returned from the store during this visit due to damage, expiration, or other quality issues.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnitsDelivered rdf:type rdf:Property ;
    rdfs:label 'Total Units Delivered' ;
    rdfs:comment 'The total quantity of individual product units delivered to the store during this visit. Aggregate measure across all SKUs delivered.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnitsReturned rdf:type rdf:Property ;
    rdfs:label 'Total Units Returned' ;
    rdfs:comment 'The total quantity of individual product units returned from the store during this visit due to damage, expiration, or other quality issues.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Code' ;
    rdfs:comment 'Reference to the delivery vehicle used for this DSD delivery. Links to fleet asset master data.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitDate rdf:type rdf:Property ;
    rdfs:label 'Visit Date' ;
    rdfs:comment 'The calendar date on which the DSD delivery visit to the retail store occurred. Business event date for reporting and analytics.' ;
    rdfs:domain ind:DistributionDsdDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dsdDeliveryLineId rdf:type rdf:Property ;
    rdfs:label 'Dsd Delivery Line Id' ;
    rdfs:comment 'Unique identifier for the DSD delivery line item. Primary key for this product.' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coldChainCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Compliant Flag' ;
    rdfs:comment 'Indicates whether cold chain temperature requirements were maintained throughout delivery. True if compliant, False if temperature excursion occurred.' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'Actual quantity of the SKU delivered to the store during this visit. Used for secondary sales capture and inventory replenishment tracking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Date and time when this specific line item was delivered or processed at the store. Used for OTIF performance tracking and delivery window compliance.' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'Line total' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net monetary value for this line after discounts and taxes (line_total_amount - discount_amount + tax_amount). Represents final revenue for this line.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planogramComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Planogram Compliance Flag' ;
    rdfs:comment 'Indicates whether the product was placed according to the store planogram. True if compliant, False if deviation occurred.' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating why the delivery line was rejected by the store. Values: DAMAGED, WRONG_PRODUCT, QUALITY, UNAUTHORIZED, EXPIRED, OTHER.' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Quantity of the SKU returned from the store during this visit. Includes damaged goods, expired products, and unsold inventory.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfPlacementConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Shelf Placement Confirmed Flag' ;
    rdfs:comment 'Indicates whether the DSD driver confirmed proper shelf placement and merchandising of the delivered product. True if confirmed, False otherwise.' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Selling Price' ;
    rdfs:comment 'Selling price per unit for this SKU at the time of delivery. Used for revenue calculation and pricing analysis.' ;
    rdfs:domain ind:DsdDeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifEventId rdf:type rdf:Property ;
    rdfs:label 'Otif Event Id' ;
    rdfs:comment 'Unique identifier for the OTIF performance measurement event. Primary key for the OTIF event record.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryId rdf:type rdf:Property ;
    rdfs:label 'Delivery Id' ;
    rdfs:comment 'Reference to the delivery execution record for Direct Store Delivery (DSD) or carrier delivery. Links to the actual delivery event.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Delivery .

ind:committedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Date' ;
    rdfs:comment 'The delivery date committed to the customer per the Service Level Agreement (SLA) or purchase order terms. Baseline for on-time performance measurement.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:committedDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Timestamp' ;
    rdfs:comment 'The precise delivery date and time committed to the customer, including time window for time-sensitive deliveries. Used for precise OTIF measurement when time windows apply.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:committedQuantity rdf:type rdf:Property ;
    rdfs:label 'Committed Quantity' ;
    rdfs:comment 'The total quantity committed to the customer per the sales order or purchase order. Baseline for in-full performance measurement. Measured in order unit of measure.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Variance Days' ;
    rdfs:comment 'The number of days variance between committed and actual delivery date. Negative values indicate early delivery, positive values indicate late delivery, zero indicates on-time.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether the OTIF measurement is under dispute by the customer or internal stakeholders. True indicates active dispute, False indicates accepted measurement.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Explanation of why the OTIF measurement is disputed. Captures customer or internal objections to the performance assessment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCategory rdf:type rdf:Property ;
    rdfs:label 'Failure Category' ;
    rdfs:comment 'The primary root cause category for OTIF failures. Used for operational improvement analysis and accountability assignment. Values include DC pick error, inventory shortage, dock delay, carrier issue, customer refused, weather delay, system error, quality hold, damaged product, address issue, or no failure for successful deliveries. [ENUM-REF-CANDIDATE: dc_pick_error|inventory_shortage|dock_delay|carrier_issue|customer_refused|weather_delay|system_error|quality_hold|damaged_product|address_issue|no_failure — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Code' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Detail' ;
    rdfs:comment 'Detailed explanation of the root cause for OTIF failure. Free-text field capturing specific circumstances, corrective actions, and accountability notes.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inFullTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'In Full Tolerance Percent' ;
    rdfs:comment 'The acceptable variance percentage per customer SLA or business policy. Deliveries within this tolerance are considered in-full compliant.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateDays rdf:type rdf:Property ;
    rdfs:label 'Late Days' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The date when the OTIF performance was measured and recorded. Used for reporting period assignment and trend analysis.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:otifFlag rdf:type rdf:Property ;
    rdfs:label 'Otif Flag' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otifScore rdf:type rdf:Property ;
    rdfs:label 'Otif Score' ;
    rdfs:comment 'Composite OTIF performance indicator. True only when both on_time_flag and in_full_flag are True. Primary KPI for DC operations accountability and retailer scorecard compliance.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the retailer penalty amount. Standard currency codes such as USD, EUR, GBP.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Captured Flag' ;
    rdfs:comment 'Indicates whether an electronic or physical signature was captured at delivery. True indicates signature obtained, False indicates delivery without signature capture.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'The difference between delivered quantity and committed quantity. Negative values indicate short shipment, positive values indicate over shipment.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariancePercent rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance Percent' ;
    rdfs:comment 'The percentage variance between delivered and committed quantity, calculated as (delivered - committed) / committed * 100. Used to assess severity of in-full failures.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'The organizational function or external party accountable for the OTIF failure. Used for performance accountability and continuous improvement initiatives.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailerPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Retailer Penalty Amount' ;
    rdfs:comment 'The financial penalty or chargeback amount assessed by the retailer for OTIF non-compliance per the customer contract or retailer compliance program. Zero for compliant deliveries.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortQuantity rdf:type rdf:Property ;
    rdfs:label 'Short Quantity' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'The service level tier committed to the customer. Defines the delivery speed and OTIF performance expectations per the customer agreement.' ;
    rdfs:domain ind:OtifEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Dock Appointment Id' ;
    rdfs:comment 'Unique identifier for the dock appointment record. Primary key for the dock appointment entity.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual timestamp when the carrier truck checked in at the distribution center gate. Used to calculate on-time arrival performance and carrier compliance.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualCaseCount rdf:type rdf:Property ;
    rdfs:label 'Actual Case Count' ;
    rdfs:comment 'Actual number of cases handled during the appointment. Used for variance analysis and operational performance tracking.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Actual timestamp when loading or unloading operations were completed and the truck departed. Used to calculate dock turnaround time and throughput metrics.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualPalletCount rdf:type rdf:Property ;
    rdfs:label 'Actual Pallet Count' ;
    rdfs:comment 'Actual number of pallets loaded or unloaded during the appointment. Compared against expected count to identify discrepancies.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualWeightKg rdf:type rdf:Property ;
    rdfs:label 'Actual Weight Kg' ;
    rdfs:comment 'Actual total weight of goods handled in kilograms. Verified through weigh station or scale integration.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appointmentNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Number' ;
    rdfs:comment 'Business-facing unique appointment reference number used for scheduling and tracking. Externally visible identifier shared with carriers and suppliers.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle status of the dock appointment: scheduled (initial booking), confirmed (carrier acknowledged), checked_in (truck arrived at gate), in_progress (loading/unloading active), completed (finished), cancelled (appointment voided), no_show (carrier missed appointment). [ENUM-REF-CANDIDATE: scheduled|confirmed|checked_in|in_progress|completed|cancelled|no_show — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentType rdf:type rdf:Property ;
    rdfs:label 'Appointment Type' ;
    rdfs:comment 'Classification of the dock appointment purpose: inbound receipt (supplier delivery), outbound load (customer shipment), inter-DC transfer (internal movement), cross-dock (direct transfer), returns processing, or emergency delivery.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDockFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Flag' ;
    rdfs:comment 'Indicates whether this is a cross-dock appointment where goods are transferred directly from inbound to outbound without storage. True for cross-dock operations.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detentionMinutes rdf:type rdf:Property ;
    rdfs:label 'Detention Minutes' ;
    rdfs:comment 'Total time in minutes that the carrier was detained beyond the scheduled appointment window. Used to calculate detention charges and identify operational bottlenecks.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dockDoor rdf:type rdf:Property ;
    rdfs:label 'Dock Door' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'Name of the driver assigned to this appointment. Used for gate check-in verification and security purposes.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverPhone rdf:type rdf:Property ;
    rdfs:label 'Driver Phone' ;
    rdfs:comment 'Contact phone number for the driver. Used for real-time communication regarding delays, gate instructions, or operational issues.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCaseCount rdf:type rdf:Property ;
    rdfs:label 'Expected Case Count' ;
    rdfs:comment 'Anticipated number of cases to be handled during this appointment. Supports detailed capacity and labor planning for case-level operations.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedPalletCount rdf:type rdf:Property ;
    rdfs:label 'Expected Pallet Count' ;
    rdfs:comment 'Anticipated number of pallets to be loaded or unloaded during this appointment. Used for dock capacity planning and labor scheduling.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Expected Weight Kg' ;
    rdfs:comment 'Total expected weight of goods in kilograms for this appointment. Used for equipment planning and safety compliance.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'UN hazard classification code for hazardous materials (e.g., 3 for flammable liquids, 8 for corrosives). Required for HAZMAT compliance and safety protocols.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Number' ;
    rdfs:comment 'Sales order number associated with outbound load appointments. Links the dock appointment to customer orders being shipped.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Date' ;
    rdfs:comment 'Planned date for the carrier to arrive at the dock door. Used for day-level appointment planning and capacity management.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Precise timestamp when the appointment window closes. Carrier should complete loading/unloading by this time to maintain schedule compliance.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Precise timestamp when the appointment window begins. Carrier is expected to arrive at or after this time.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Timestamp' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dockAppointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Dock Appointment Status' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPlanId rdf:type rdf:Property ;
    rdfs:label 'Load Plan Id' ;
    rdfs:comment 'Unique identifier for the outbound load plan record. Primary key.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLoadingSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Loading Supervisor Employee Id' ;
    rdfs:comment 'Identifier of the warehouse supervisor who verified and approved the completed load before dispatch.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:waveId rdf:type rdf:Property ;
    rdfs:label 'Wave Id' ;
    rdfs:comment 'Identifier of the picking wave that generated the orders included in this load plan. Links load planning to upstream warehouse execution.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wave .

ind:actualDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Datetime' ;
    rdfs:comment 'Actual date and time when the loaded trailer departed the distribution center, used for OTIF performance measurement.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedFreightCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Freight Cost' ;
    rdfs:comment 'Estimated transportation cost for this load based on carrier rates, distance, and service level.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated freight cost.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Load Plan Number' ;
    rdfs:comment 'Business-facing unique identifier for the load plan, typically generated by the WMS. Used for operational tracking and communication with carriers and warehouse staff.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Load Plan Status' ;
    rdfs:comment 'Current lifecycle status of the load plan, tracking progression from planning through dispatch. [ENUM-REF-CANDIDATE: draft|confirmed|in_progress|loaded|sealed|dispatched|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadSequenceStrategy rdf:type rdf:Property ;
    rdfs:label 'Load Sequence Strategy' ;
    rdfs:comment 'Strategy used to determine the order in which pallets are loaded into the trailer, typically aligned with delivery stop sequence.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadType rdf:type rdf:Property ;
    rdfs:label 'Load Type' ;
    rdfs:comment 'Classification of the load based on shipment mode and delivery strategy. DSD indicates Direct Store Delivery.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingCompletionDatetime rdf:type rdf:Property ;
    rdfs:label 'Loading Completion Datetime' ;
