    rdfs:range xsd:string .

ind:strategicPriorityTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Tier' ;
    rdfs:comment 'Strategic importance ranking of this segment for marketing investment and campaign focus (tier 1 being highest priority).' ;
