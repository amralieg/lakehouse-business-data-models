ind:innovationAdoptionProfile rdf:type rdf:Property ;
    rdfs:label 'Innovation Adoption Profile' ;
    rdfs:comment 'Consumer adoption curve classification for new product launches and innovations (based on Rogers Diffusion of Innovations theory).' ;
