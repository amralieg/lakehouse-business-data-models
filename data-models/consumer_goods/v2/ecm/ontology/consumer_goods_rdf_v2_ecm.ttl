    rdfs:range xsd:string .

ind:allergenType rdf:type rdf:Property ;
    rdfs:label 'Allergen Type' ;
    rdfs:comment 'Classification of the allergen type if allergen_flag is true. Used for consumer safety labeling and regulatory compliance.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commonName rdf:type rdf:Property ;
    rdfs:label 'Common Name' ;
    rdfs:comment 'Common or trade name of the ingredient used for internal reference and non-regulated communications.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Concentration Max Percent' ;
    rdfs:comment 'Maximum concentration of the ingredient in the finished product, expressed as a percentage by weight. Used for regulatory submissions and formulation specifications.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationMinPercent rdf:type rdf:Property ;
    rdfs:label 'Concentration Min Percent' ;
    rdfs:comment 'Minimum concentration of the ingredient in the finished product, expressed as a percentage by weight. Used for regulatory submissions and formulation specifications.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationTypicalPercent rdf:type rdf:Property ;
    rdfs:label 'Concentration Typical Percent' ;
    rdfs:comment 'Typical or target concentration of the ingredient in the finished product, expressed as a percentage by weight. Used for quality control and manufacturing guidance.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declarationNameOverride rdf:type rdf:Property ;
    rdfs:label 'Declaration Name Override' ;
    rdfs:comment 'Alternative name to be used on the product label if different from INCI name, as permitted by jurisdiction-specific regulations (e.g., trade name, common name).' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declarationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Declaration Required Flag' ;
    rdfs:comment 'Indicates whether this ingredient must be declared on the product label per regulatory requirements. Some processing aids or trace contaminants may be exempt.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:declarationStatus rdf:type rdf:Property ;
    rdfs:label 'Declaration Status' ;
    rdfs:comment 'Current lifecycle status of the ingredient declaration record in the regulatory documentation workflow.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:descendingOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Descending Order Flag' ;
    rdfs:comment 'Descending order flag' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifraAmendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Ifra Amendment Number' ;
    rdfs:comment 'IFRA (International Fragrance Association) amendment number that governs the use restrictions for this ingredient if IFRA restricted.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Ifra Restricted Flag' ;
    rdfs:comment 'Indicates whether this ingredient is subject to IFRA (International Fragrance Association) restrictions or standards for use in fragrance compounds.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingredientSequence rdf:type rdf:Property ;
    rdfs:label 'Ingredient Sequence' ;
    rdfs:comment 'Order in which this ingredient appears on the product label declaration. Typically sorted by descending concentration per regulatory requirements (FDA 21 CFR, EU Cosmetics Regulation).' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:listType rdf:type rdf:Property ;
    rdfs:label 'List Type' ;
    rdfs:comment 'Type (INCI, common name)' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listVersion rdf:type rdf:Property ;
    rdfs:label 'List Version' ;
    rdfs:comment 'Version' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nanomaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Nanomaterial Flag' ;
    rdfs:comment 'Indicates whether the ingredient is in nanomaterial form, requiring special labeling per EU Cosmetics Regulation (nano) designation.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedSubstanceFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Substance Flag' ;
    rdfs:comment 'Indicates whether this ingredient is subject to regulatory restrictions, concentration limits, or prohibited use conditions in certain jurisdictions.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictionJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Restriction Jurisdiction' ;
    rdfs:comment 'Comma-separated list of jurisdictions or regulatory bodies where restrictions apply (e.g., EU, USA, CAN, JPN). Used for multi-jurisdictional compliance management.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Type of regulatory restriction applied to this ingredient if restricted_substance_flag is true. Defines the nature of the regulatory control.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rspoCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Rspo Certified Flag' ;
    rdfs:comment 'Indicates whether palm-derived ingredients are RSPO (Roundtable on Sustainable Palm Oil) certified for sustainable sourcing.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'Unique identifier of this record in the source system, used for data lineage and reconciliation.' ;
    rdfs:domain ind:IngredientList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelApprovalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Label Approval Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Label approvals are signed off by a regulatory employee; FK records who approved each label version.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:labelApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Label Approved By Employee Id' ;
    rdfs:comment 'Approver' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:previousVersionLabelVersionId rdf:type rdf:Property ;
    rdfs:label 'Previous Version Label Version Id' ;
    rdfs:comment 'Reference to the immediately preceding label version that this version supersedes, enabling version lineage tracking.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabelVersion .

ind:allergenDeclarations rdf:type rdf:Property ;
    rdfs:label 'Allergen Declarations' ;
    rdfs:comment 'Allergen declarations required on the label (e.g., \'Contains: milk, soy, tree nuts\'). Applicable for food and cosmetic products.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiry Date' ;
    rdfs:comment 'Date when the regulatory approval expires and the label version can no longer be used, if applicable.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Reference Number' ;
    rdfs:comment 'Official reference or registration number assigned by the regulatory authority for this label approval.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name of the regulatory body or authority that approved this label version (e.g., FDA, EPA, EU Commission, Health Canada).' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artworkChecksum rdf:type rdf:Property ;
    rdfs:label 'Artwork Checksum' ;
    rdfs:comment 'SHA-256 checksum hash of the artwork file to ensure file integrity and detect unauthorized modifications.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artworkFileName rdf:type rdf:Property ;
    rdfs:label 'Artwork File Name' ;
    rdfs:comment 'File name of the approved label artwork file (e.g., PDF, AI, or other format) stored in the document management system.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeValue rdf:type rdf:Property ;
    rdfs:label 'Barcode Value' ;
    rdfs:comment 'The encoded value of the barcode printed on this label version (e.g., UPC number, GTIN, serialized data).' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contactInformation rdf:type rdf:Property ;
    rdfs:label 'Contact Information' ;
    rdfs:comment 'Consumer contact information displayed on the label (phone number, website, email) for inquiries and customer service.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDateFormat rdf:type rdf:Property ;
    rdfs:label 'Expiry Date Format' ;
    rdfs:comment 'Format specification for how the expiry or best-before date will be printed on the label (e.g., \'MM/YYYY\', \'DD-MMM-YYYY\', \'EXP: YYYY-MM-DD\').' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientDeclaration rdf:type rdf:Property ;
    rdfs:label 'Ingredient Declaration' ;
    rdfs:comment 'Ingredient list' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientList rdf:type rdf:Property ;
    rdfs:label 'Ingredient List' ;
    rdfs:comment 'Full ingredient list as declared on the label in descending order of predominance, following regulatory naming conventions (INCI for cosmetics, common names for food).' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentVersion rdf:type rdf:Property ;
    rdfs:label 'Is Current Version' ;
    rdfs:comment 'Boolean flag indicating whether this is the currently active label version for the SKU in the specified market. True if current, False if historical.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelClaims rdf:type rdf:Property ;
    rdfs:label 'Label Claims' ;
    rdfs:comment 'Marketing claims and statements appearing on the label (e.g., \'organic\', \'hypoallergenic\', \'dermatologist tested\', \'cruelty-free\'). Pipe-separated list if multiple.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netContentQuantity rdf:type rdf:Property ;
    rdfs:label 'Net Content Quantity' ;
    rdfs:comment 'Numeric value of the net content quantity declared on the label.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netContentUnit rdf:type rdf:Property ;
    rdfs:label 'Net Content Unit' ;
    rdfs:comment 'Unit of measure for the net content quantity (e.g., ml, g, oz, fl_oz, count). [ENUM-REF-CANDIDATE: ml|l|g|kg|oz|lb|fl_oz|gal|count|each — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productNameOnLabel rdf:type rdf:Property ;
    rdfs:label 'Product Name On Label' ;
    rdfs:comment 'The exact product name as it appears on the label artwork, which may differ from internal product names due to marketing or regulatory requirements.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclingSymbols rdf:type rdf:Property ;
    rdfs:label 'Recycling Symbols' ;
    rdfs:comment 'Recycling symbols and sustainability marks displayed on the label (e.g., \'Recyclable\', \'FSC Certified\', \'Green Dot\', resin identification codes).' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Code' ;
    rdfs:comment 'Reference identifier to the label artwork document stored in Veeva Vault regulatory document management system.' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningText rdf:type rdf:Property ;
    rdfs:label 'Warning Text' ;
    rdfs:comment 'Warnings' ;
    rdfs:domain ind:LabelVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceResponsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compliance Responsible Employee Id' ;
    rdfs:comment 'Responsible person' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complianceResponsibleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compliance Responsible Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Each compliance obligation is owned by a specific employee; linking enables ownership tracking and audit.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:advanceNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Advance Notice Period Days' ;
    rdfs:comment 'The number of days in advance that the business must be notified or begin preparation to meet this compliance obligation.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableProductCategory rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Category' ;
    rdfs:comment 'The product category or categories to which this compliance obligation applies (e.g., cosmetics, household cleaners, personal care, food contact materials).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'The date by which the compliance obligation must be fulfilled to avoid regulatory penalties or non-compliance.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedComplianceCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Compliance Cost' ;
    rdfs:comment 'The estimated financial cost to fulfill this compliance obligation, including registration fees, testing costs, documentation, and labor.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingBody rdf:type rdf:Property ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'The regulatory authority or governing body that enforces this obligation (e.g., FDA, EPA, CPSC, EU Commission).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingRegulation rdf:type rdf:Property ;
    rdfs:label 'Governing Regulation' ;
    rdfs:comment 'The specific regulation, directive, or legal framework that mandates this obligation (e.g., CFR 21 Part 701, EU Directive 2009/48/EC, REACH Article 33).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Date' ;
    rdfs:comment 'Last assessment' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastComplianceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Verification Date' ;
    rdfs:comment 'The date when compliance with this obligation was last verified or audited.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReference rdf:type rdf:Property ;
    rdfs:label 'Legal Reference' ;
    rdfs:comment 'Legal reference' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Date' ;
    rdfs:comment 'Next assessment' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'The date when the compliance deadline notification was sent to the responsible owner.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Obligation code' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyForNonCompliance rdf:type rdf:Property ;
    rdfs:label 'Penalty For Non Compliance' ;
    rdfs:comment 'Penalty description' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequency rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency' ;
    rdfs:comment 'The frequency at which this compliance obligation must be renewed or re-certified.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDocumentation rdf:type rdf:Property ;
    rdfs:label 'Required Documentation' ;
    rdfs:comment 'List or description of the documentation required to fulfill this compliance obligation (e.g., Safety Data Sheet (SDS), ingredient declaration, test reports, certificates of analysis).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'The method by which compliance documentation or filings must be submitted to the governing body.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionPortalUrl rdf:type rdf:Property ;
    rdfs:label 'Submission Portal Url' ;
    rdfs:comment 'The web address of the electronic portal or system where compliance submissions must be filed, if applicable.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingRequirement rdf:type rdf:Property ;
    rdfs:label 'Testing Requirement' ;
    rdfs:comment 'Description of any laboratory testing or analytical work required to demonstrate compliance (e.g., stability testing, microbial testing, heavy metals analysis, allergen testing).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Compliance Assessment Id' ;
    rdfs:comment 'Primary key' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceAssessment .

ind:complianceAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compliance Assessor Employee Id' ;
    rdfs:comment 'Assessor' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryComplianceAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Compliance Assessor Employee Id' ;
    rdfs:comment 'Employee identifier for the individual who conducted the compliance assessment.' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentResult rdf:type rdf:Property ;
    rdfs:label 'Assessment Result' ;
    rdfs:comment 'Result (pass, fail, conditional)' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Score' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationIssued rdf:type rdf:Property ;
    rdfs:label 'Certification Issued' ;
    rdfs:comment 'Certification flag' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFinding rdf:type rdf:Property ;
    rdfs:label 'Compliance Finding' ;
    rdfs:comment 'Detailed narrative of the compliance assessment finding, including observations, test results, and rationale for the compliance determination.' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target date by which the corrective action must be completed to achieve compliance.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionOwner rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Owner' ;
    rdfs:comment 'Name of the individual or department responsible for implementing the corrective action.' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current status of the corrective action implementation (not started, in progress, completed, verified, overdue).' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Reference' ;
    rdfs:comment 'Reference identifier or URI to the supporting documentation, test reports, certificates, or dossiers that substantiate the compliance assessment finding.' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findings rdf:type rdf:Property ;
    rdfs:label 'Findings' ;
    rdfs:comment 'Findings' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Follow-up date' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonConformancesCount rdf:type rdf:Property ;
    rdfs:label 'Non Conformances Count' ;
    rdfs:comment 'Non-conformances' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requirementDescription rdf:type rdf:Property ;
    rdfs:label 'Requirement Description' ;
    rdfs:comment 'Detailed description of the specific regulatory requirement being assessed for compliance.' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportNumber rdf:type rdf:Property ;
    rdfs:label 'Test Report Number' ;
    rdfs:comment 'Unique identifier for the laboratory test report or analytical certificate supporting the compliance assessment, if applicable.' ;
    rdfs:domain ind:ComplianceAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachSubstanceId rdf:type rdf:Property ;
    rdfs:label 'Reach Substance Id' ;
    rdfs:comment 'Primary key' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Expiry Date' ;
    rdfs:comment 'Date when the granted authorization expires and the substance can no longer be used unless renewed.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Number' ;
    rdfs:comment 'Unique authorization number granted by the European Commission for use of an Annex XIV substance.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Authorization Required' ;
    rdfs:comment 'Authorization required' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Authorization Required Flag' ;
    rdfs:comment 'Indicates whether the substance is subject to authorization requirements under REACH Annex XIV before it can be placed on the market or used.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmrClassification rdf:type rdf:Property ;
    rdfs:label 'Cmr Classification' ;
    rdfs:comment 'Classification indicating whether the substance is carcinogenic, mutagenic, or toxic for reproduction, and its category level. [ENUM-REF-CANDIDATE: carcinogenic|mutagenic|reprotoxic|cmr_category_1a|cmr_category_1b|cmr_category_2|not_cmr — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dnelUnit rdf:type rdf:Property ;
    rdfs:label 'Dnel Unit' ;
    rdfs:comment 'Unit of measure for the DNEL value.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dnelValue rdf:type rdf:Property ;
    rdfs:label 'Dnel Value' ;
    rdfs:comment 'The level of exposure to the substance above which humans should not be exposed, expressed in mg/kg body weight/day or mg/m³.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downstreamUserNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Downstream User Notification Required Flag' ;
    rdfs:comment 'Indicates whether downstream users must be notified of specific obligations or restrictions related to this substance.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endocrineDisruptorFlag rdf:type rdf:Property ;
    rdfs:label 'Endocrine Disruptor Flag' ;
    rdfs:comment 'Indicates whether the substance is identified as an endocrine disruptor under EU criteria.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exposureScenarioRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Exposure Scenario Required Flag' ;
    rdfs:comment 'Indicates whether exposure scenarios must be developed and communicated in the extended Safety Data Sheet for this substance.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ghsPictogramCodes rdf:type rdf:Property ;
    rdfs:label 'Ghs Pictogram Codes' ;
    rdfs:comment 'Comma-separated list of GHS pictogram codes required on labels (e.g., GHS02, GHS05, GHS07, GHS09).' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hStatements rdf:type rdf:Property ;
    rdfs:label 'H Statements' ;
    rdfs:comment 'Comma-separated list of standardized hazard statement codes describing the nature of hazards (e.g., H302, H315, H400).' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEvaluationDate rdf:type rdf:Property ;
    rdfs:label 'Last Evaluation Date' ;
    rdfs:comment 'Date when the substance was last evaluated by ECHA or competent authorities for compliance or risk assessment purposes.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadRegistrant rdf:type rdf:Property ;
    rdfs:label 'Lead Registrant' ;
    rdfs:comment 'Lead registrant' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketAccessStatusEu rdf:type rdf:Property ;
    rdfs:label 'Market Access Status Eu' ;
    rdfs:comment 'Current market access status for placing the substance on the EU market.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pStatements rdf:type rdf:Property ;
    rdfs:label 'P Statements' ;
    rdfs:comment 'Comma-separated list of standardized precautionary statement codes describing recommended measures to minimize or prevent adverse effects (e.g., P264, P280, P301+P312).' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pbtAssessment rdf:type rdf:Property ;
    rdfs:label 'Pbt Assessment' ;
    rdfs:comment 'Assessment result indicating whether the substance meets the criteria for being Persistent, Bioaccumulative and Toxic (PBT) or very Persistent and very Bioaccumulative (vPvB).' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pnecUnit rdf:type rdf:Property ;
    rdfs:label 'Pnec Unit' ;
    rdfs:comment 'Unit of measure for the PNEC value.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pnecValue rdf:type rdf:Property ;
    rdfs:label 'Pnec Value' ;
    rdfs:comment 'The concentration of the substance below which adverse effects in the environmental sphere of concern are not expected to occur.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Registration Expiry Date' ;
    rdfs:comment 'Date when the current REACH registration expires and renewal is required.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionApplicable rdf:type rdf:Property ;
    rdfs:label 'Restriction Applicable' ;
    rdfs:comment 'Restriction applicable' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictionConditions rdf:type rdf:Property ;
    rdfs:label 'Restriction Conditions' ;
    rdfs:comment 'Detailed description of the specific conditions, limitations, or prohibitions applied to the substance under REACH Annex XVII restrictions.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Restriction Entry Number' ;
    rdfs:comment 'The entry number in REACH Annex XVII that specifies the restriction applicable to this substance.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionReference rdf:type rdf:Property ;
    rdfs:label 'Restriction Reference' ;
    rdfs:comment 'Restriction reference' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionStatus rdf:type rdf:Property ;
    rdfs:label 'Restriction Status' ;
    rdfs:comment 'Indicates whether the substance is subject to restrictions under REACH Annex XVII limiting or prohibiting its manufacture, use, or placing on the market.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sds Required Flag' ;
    rdfs:comment 'Indicates whether a Safety Data Sheet must be provided for this substance under REACH Article 31.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdsRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Sds Revision Date' ;
    rdfs:comment 'Date of the most recent revision of the Safety Data Sheet.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siefMembership rdf:type rdf:Property ;
    rdfs:label 'Sief Membership' ;
    rdfs:comment 'SIEF membership' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceName rdf:type rdf:Property ;
    rdfs:label 'Substance Name' ;
    rdfs:comment 'Substance name' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceOriginCountryCode rdf:type rdf:Property ;
    rdfs:label 'Substance Origin Country Code' ;
    rdfs:comment 'Three-letter ISO country code indicating the primary country of origin or manufacture for this substance.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Reference Number' ;
    rdfs:comment 'Internal reference number or code used by the supplier to identify this substance in their catalog or system.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:svhcInclusionDate rdf:type rdf:Property ;
    rdfs:label 'Svhc Inclusion Date' ;
    rdfs:comment 'Date when the substance was added to the SVHC Candidate List by ECHA.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:svhcListDate rdf:type rdf:Property ;
    rdfs:label 'Svhc List Date' ;
    rdfs:comment 'SVHC list date' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:svhcStatus rdf:type rdf:Property ;
    rdfs:label 'Svhc Status' ;
    rdfs:comment 'Classification status indicating whether the substance is identified as a Substance of Very High Concern under REACH Article 57, requiring special authorization or restriction.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tonnageBand rdf:type rdf:Property ;
    rdfs:label 'Tonnage Band' ;
    rdfs:comment 'Tonnage band' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useDescriptorCodes rdf:type rdf:Property ;
    rdfs:label 'Use Descriptor Codes' ;
    rdfs:comment 'Comma-separated list of standardized use descriptor codes (SU, PC, PROC, ERC, AC) describing identified uses of the substance.' ;
    rdfs:domain ind:ReachSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraComplianceRecordId rdf:type rdf:Property ;
    rdfs:label 'Ifra Compliance Record Id' ;
    rdfs:comment 'Primary key' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualFormulatedUsageLevel rdf:type rdf:Property ;
    rdfs:label 'Actual Formulated Usage Level' ;
    rdfs:comment 'Actual concentration of the fragrance ingredient in the finished product formulation. Expressed in the same unit as maximum_permitted_usage_level. Used to determine compliance status.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allergenDeclarationRequired rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration Required' ;
    rdfs:comment 'Indicates whether the fragrance ingredient is a recognized allergen requiring declaration on product labeling per EU Cosmetics Regulation or other jurisdictional requirements.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenThresholdExceeded rdf:type rdf:Property ;
    rdfs:label 'Allergen Threshold Exceeded' ;
    rdfs:comment 'Indicates whether the fragrance ingredient concentration exceeds the allergen labeling threshold (0.001% for leave-on, 0.01% for rinse-off products per EU regulation).' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Due Date' ;
    rdfs:comment 'Date by which the next IFRA compliance reassessment is required. Triggered by IFRA standard updates or product reformulation. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'Certificate expiry' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'Certificate issue date' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exemptionJustification rdf:type rdf:Property ;
    rdfs:label 'Exemption Justification' ;
    rdfs:comment 'Detailed justification text if an exemption or deviation from IFRA standard is claimed. Must include scientific rationale and risk assessment summary.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fragranceAllergenDeclaration rdf:type rdf:Property ;
    rdfs:label 'Fragrance Allergen Declaration' ;
    rdfs:comment 'Allergen declaration' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fragranceIngredientName rdf:type rdf:Property ;
    rdfs:label 'Fragrance Ingredient Name' ;
    rdfs:comment 'Name of the specific fragrance ingredient being assessed for IFRA compliance. May be a chemical name, INCI name, or proprietary fragrance component identifier.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Ifra Certificate Number' ;
    rdfs:comment 'Certificate number issued by fragrance supplier confirming IFRA compliance of the fragrance compound. Required for audit and regulatory submissions.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraProductCategory rdf:type rdf:Property ;
    rdfs:label 'Ifra Product Category' ;
    rdfs:comment 'IFRA product category classification determining usage restrictions. Categories range from 1 (toys) to 12 (air fresheners), with subcategories for leave-on vs rinse-off products. Each category has specific maximum permitted usage levels. [ENUM-REF-CANDIDATE: Category 1|Category 2|Category 3|Category 4|Category 5A|Category 5B|Category 5C|Category 5D|Category 6|Category 7A|Category 7B|Category 8|Category 9|Category 10A|Category 10B|Category 11A|Category 11B|Category 12 — 18 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraStandardReference rdf:type rdf:Property ;
    rdfs:label 'Ifra Standard Reference' ;
    rdfs:comment 'Reference to the applicable IFRA Standard number and amendment that governs the use of this substance in fragrance compounds.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifraStandardVersion rdf:type rdf:Property ;
    rdfs:label 'Ifra Standard Version' ;
    rdfs:comment 'IFRA standard version' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Max Concentration Pct' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumPermittedUsageLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Permitted Usage Level' ;
    rdfs:comment 'Maximum permitted concentration of the fragrance ingredient as defined by IFRA standard for the specified product category. Expressed as percentage (e.g., 0.5 = 0.5%). Null if no restriction applies.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'High-level product type classification determining IFRA category assignment and usage restrictions. Leave-on products have stricter limits than rinse-off products.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qraReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Qra Reference Number' ;
    rdfs:comment 'Reference number to the Quantitative Risk Assessment document supporting the safety substantiation of this fragrance ingredient usage. Required for regulatory defense.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedSubstancesPresent rdf:type rdf:Property ;
    rdfs:label 'Restricted Substances Present' ;
    rdfs:comment 'Restricted substances flag' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAssessmentReference rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Reference' ;
    rdfs:comment 'Reference number to the detailed risk assessment document or safety dossier supporting this IFRA compliance determination. Links to document management system.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Safety Margin Percentage' ;
    rdfs:comment 'Calculated safety margin between actual usage level and maximum permitted level, expressed as percentage. Positive values indicate compliance buffer; negative values indicate non-compliance.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageLevelUnit rdf:type rdf:Property ;
    rdfs:label 'Usage Level Unit' ;
    rdfs:comment 'Unit of measure for usage levels. Typically percentage (%) for most fragrance ingredients, or ppm/mg/kg for trace components.' ;
    rdfs:domain ind:IfraComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveillanceEventId rdf:type rdf:Property ;
    rdfs:label 'Surveillance Event Id' ;
    rdfs:comment 'Primary key' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SurveillanceEvent .

ind:surveillanceInvestigationAssignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Surveillance Investigation Assigned To Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Post-market surveillance investigations are assigned to an employee; FK enables investigation tracking.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:surveillanceResponsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Surveillance Responsible Employee Id' ;
    rdfs:comment 'Responsible person' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:consumerComplaintDescription rdf:type rdf:Property ;
    rdfs:label 'Consumer Complaint Description' ;
    rdfs:comment 'Detailed narrative description of the consumer complaint or adverse event as reported, capturing symptoms, circumstances, and product usage context.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'Date when the corrective action was fully implemented and verified for effectiveness.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Indicates whether corrective action is required based on the investigation findings and risk assessment.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveillanceEventDescription rdf:type rdf:Property ;
    rdfs:label 'Surveillance Event Description' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventOccurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Event Occurrence Date' ;
    rdfs:comment 'Date when the adverse event or product issue actually occurred or was first observed by the consumer or reporter.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Received Timestamp' ;
    rdfs:comment 'Date and time when the surveillance signal was first received by the organization, marking the start of the regulatory clock for reporting obligations.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:financialImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Estimate' ;
    rdfs:comment 'Estimated financial impact of the surveillance event including investigation costs, corrective actions, potential recall costs, and liability exposure in USD.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'Three-letter ISO country codes indicating the geographic markets where the affected product was distributed, pipe-separated for multiple countries.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryDescription rdf:type rdf:Property ;
    rdfs:label 'Injury Description' ;
    rdfs:comment 'Detailed description of the injury or adverse health effect reported by the consumer or healthcare provider.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Injury Reported Flag' ;
    rdfs:comment 'Indicates whether the surveillance event involved a reported consumer injury or adverse health effect.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completion Date' ;
    rdfs:comment 'Date when the investigation was completed and root cause determination was finalized.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date when the formal investigation of the surveillance event was initiated.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Investigation status' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalTreatmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Treatment Required Flag' ;
    rdfs:comment 'Indicates whether the reported injury required medical treatment or healthcare intervention.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallClassification rdf:type rdf:Property ;
    rdfs:label 'Recall Classification' ;
    rdfs:comment 'FDA recall classification (Class I, II, III) or equivalent regulatory classification indicating the level of health hazard.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallInitiated rdf:type rdf:Property ;
    rdfs:label 'Recall Initiated' ;
    rdfs:comment 'Recall flag' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallInitiatedFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Initiated Flag' ;
    rdfs:comment 'Indicates whether the surveillance event resulted in a product recall or market withdrawal action.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Report date' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Reference Number' ;
    rdfs:comment 'Official reference or tracking number assigned by the regulatory authority upon submission of the surveillance report.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submission Date' ;
    rdfs:comment 'Date when the mandatory regulatory report was submitted to the applicable authority.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Reporting required flag' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Indicates whether the surveillance event triggers a mandatory regulatory reporting obligation to FDA, CPSC, EPA, or other authorities.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reporterContactEmail rdf:type rdf:Property ;
    rdfs:label 'Reporter Contact Email' ;
    rdfs:comment 'Email address of the reporter for written communication and documentation exchange.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterContactPhone rdf:type rdf:Property ;
    rdfs:label 'Reporter Contact Phone' ;
    rdfs:comment 'Primary phone number of the reporter for follow-up investigation and clarification.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterName rdf:type rdf:Property ;
    rdfs:label 'Reporter Name' ;
    rdfs:comment 'Full name of the individual who reported the surveillance event, required for follow-up and regulatory submissions.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterType rdf:type rdf:Property ;
    rdfs:label 'Reporter Type' ;
    rdfs:comment 'Reporter type (consumer, healthcare, regulator)' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseIdentified rdf:type rdf:Property ;
    rdfs:label 'Root Cause Identified' ;
    rdfs:comment 'Documented root cause of the surveillance event as determined through investigation, including manufacturing defect, formulation issue, packaging failure, or misuse.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityClassification rdf:type rdf:Property ;
    rdfs:label 'Severity Classification' ;
    rdfs:comment 'Risk-based severity rating of the surveillance event based on potential harm to consumers and regulatory impact.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalSource rdf:type rdf:Property ;
    rdfs:label 'Signal Source' ;
    rdfs:comment 'Origin channel through which the post-market surveillance signal was received. [ENUM-REF-CANDIDATE: consumer_direct|call_center|retailer|distributor|regulatory_authority|social_media|healthcare_provider|internal_audit — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveillanceEventStatus rdf:type rdf:Property ;
    rdfs:label 'Surveillance Event Status' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveillanceNumber rdf:type rdf:Property ;
    rdfs:label 'Surveillance Number' ;
    rdfs:comment 'Business identifier for the surveillance event, externally referenced in regulatory submissions and internal tracking systems.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsAffectedEstimate rdf:type rdf:Property ;
    rdfs:label 'Units Affected Estimate' ;
    rdfs:comment 'Estimated number of product units potentially affected by the surveillance event, used for recall scope and risk assessment.' ;
    rdfs:domain ind:SurveillanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Product Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Recall coordination is managed by a specific employee; FK supports recall project management.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:productRecallCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Product Recall Coordinator Employee Id' ;
    rdfs:comment 'Coordinator' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedChannels rdf:type rdf:Property ;
    rdfs:label 'Affected Channels' ;
    rdfs:comment 'Comma-separated list of distribution channels impacted by recall (e.g., Retail, E-commerce, Wholesale, DSD, DTC). Defines which go-to-market channels received affected product.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedCountries rdf:type rdf:Property ;
    rdfs:label 'Affected Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where recalled products were distributed (e.g., USA, CAN, MEX, GBR, DEU).' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedGtinList rdf:type rdf:Property ;
    rdfs:label 'Affected Gtin List' ;
    rdfs:comment 'Comma-separated list of GTIN/UPC/EAN codes for recalled products. Enables point-of-sale and supply chain identification of affected items.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedLotBatchNumbers rdf:type rdf:Property ;
    rdfs:label 'Affected Lot Batch Numbers' ;
    rdfs:comment 'Comma-separated list of manufacturing lot or batch numbers included in the recall. Enables traceability to specific production runs.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedLotNumbers rdf:type rdf:Property ;
    rdfs:label 'Affected Lot Numbers' ;
    rdfs:comment 'Affected lots' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProductionDateRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Affected Production Date Range End' ;
    rdfs:comment 'End date of the production date range for affected products. Used when recall spans multiple production dates.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedProductionDateRangeStart rdf:type rdf:Property ;
    rdfs:label 'Affected Production Date Range Start' ;
    rdfs:comment 'Start date of the production date range for affected products. Used when recall spans multiple production dates.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedStatesProvinces rdf:type rdf:Property ;
    rdfs:label 'Affected States Provinces' ;
    rdfs:comment 'Comma-separated list of state or province codes where recalled products were distributed within countries. Used for regional recalls.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Authority Notification Date' ;
    rdfs:comment 'Date when the company notified the relevant regulatory authority of the recall. FDA requires notification within 24 hours of recall initiation.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consumerHotlineNumber rdf:type rdf:Property ;
    rdfs:label 'Consumer Hotline Number' ;
    rdfs:comment 'Toll-free or dedicated phone number for consumers to call with questions about the recall or to request remedies.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerRemedyInstructions rdf:type rdf:Property ;
    rdfs:label 'Consumer Remedy Instructions' ;
    rdfs:comment 'Detailed instructions for consumers on how to return, dispose of, or obtain remedy for recalled products. Includes contact information and process steps.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerRemedyType rdf:type rdf:Property ;
    rdfs:label 'Consumer Remedy Type' ;
    rdfs:comment 'Type of corrective action or compensation offered to consumers who purchased recalled products. Defines how consumers are made whole.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Reference' ;
    rdfs:comment 'Reference to the Corrective and Preventive Action (CAPA) plan implemented to prevent recurrence of the issue that caused the recall.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckResult rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Result' ;
    rdfs:comment 'Result of the recall effectiveness check. Effective: recall objectives met. Partially Effective: some objectives met. Ineffective: recall objectives not met. Pending: check in progress.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFinancialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact Amount' ;
    rdfs:comment 'Estimated total financial cost of the recall including product value, logistics, disposal, consumer remedies, and administrative costs. Reported in company reporting currency.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthHazardEvaluation rdf:type rdf:Property ;
    rdfs:label 'Health Hazard Evaluation' ;
    rdfs:comment 'Assessment of the health risk posed by the recalled product. Describes potential adverse health consequences and likelihood of occurrence. Used to determine recall classification.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pressReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Press Release Date' ;
    rdfs:comment 'Press release date' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pressReleaseReference rdf:type rdf:Property ;
    rdfs:label 'Press Release Reference' ;
    rdfs:comment 'Reference number, URL, or document identifier for the official press release or public announcement of the recall.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Public Notification Date' ;
    rdfs:comment 'Date when the recall was publicly announced through press release, media, or regulatory agency posting.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicNotificationIssued rdf:type rdf:Property ;
    rdfs:label 'Public Notification Issued' ;
    rdfs:comment 'Public notification' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityRecalledUnits rdf:type rdf:Property ;
    rdfs:label 'Quantity Recalled Units' ;
    rdfs:comment 'Total number of product units subject to recall. Represents the volume of affected inventory across all distribution levels.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRecoveredUnits rdf:type rdf:Property ;
    rdfs:label 'Quantity Recovered Units' ;
    rdfs:comment 'Number of recalled product units successfully recovered and removed from distribution. Used to calculate recall effectiveness.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallClass rdf:type rdf:Property ;
    rdfs:label 'Recall Class' ;
    rdfs:comment 'Class (I, II, III)' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallCoordinatorEmail rdf:type rdf:Property ;
    rdfs:label 'Recall Coordinator Email' ;
    rdfs:comment 'Email address of the recall coordinator for internal and external communications regarding the recall event.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallCoordinatorPhone rdf:type rdf:Property ;
    rdfs:label 'Recall Coordinator Phone' ;
    rdfs:comment 'Phone number of the recall coordinator for urgent communications regarding the recall event.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallEffectivenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Recall Effectiveness Percentage' ;
    rdfs:comment 'Percentage of recalled units successfully recovered (quantity_recovered_units / quantity_recalled_units * 100). FDA requires effectiveness checks to verify recall completion.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallInitiationDate rdf:type rdf:Property ;
    rdfs:label 'Recall Initiation Date' ;
    rdfs:comment 'Initiation date' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallReasonCode rdf:type rdf:Property ;
    rdfs:label 'Recall Reason Code' ;
    rdfs:comment 'Standardized code categorizing the root cause of the recall (e.g., contamination, mislabeling, undeclared allergen, packaging defect, microbial contamination, foreign material).' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Recall Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the defect, hazard, or violation that triggered the recall. Includes specific product issue, potential health risk, and circumstances of discovery.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallScope rdf:type rdf:Property ;
    rdfs:label 'Recall Scope' ;
    rdfs:comment 'Geographic scope of the recall action. Defines the market territories affected by the recall.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Recall Website Url' ;
    rdfs:comment 'URL of the dedicated webpage providing detailed recall information, consumer instructions, and remedy request forms.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryRatePct rdf:type rdf:Property ;
    rdfs:label 'Recovery Rate Pct' ;
    rdfs:comment 'Recovery rate' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryAuthorityNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notified' ;
    rdfs:comment 'Authority notified' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Indicates whether the recall was mandated by a regulatory authority (True) or initiated voluntarily by the company (False).' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseAnalysisReference rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Reference' ;
    rdfs:comment 'Reference to the formal root cause analysis document or investigation report that identified the underlying cause of the product defect or contamination.' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsAffected rdf:type rdf:Property ;
    rdfs:label 'Units Affected' ;
    rdfs:comment 'Units affected' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsRecovered rdf:type rdf:Property ;
    rdfs:label 'Units Recovered' ;
    rdfs:comment 'Units recovered' ;
    rdfs:domain ind:ProductRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Parent Jurisdiction Id' ;
    rdfs:comment 'Foreign key reference to a parent jurisdiction if this jurisdiction is a sub-jurisdiction (e.g., a state within a country, or a country within a regional bloc). Null for top-level jurisdictions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:animalTestingBan rdf:type rdf:Property ;
    rdfs:label 'Animal Testing Ban' ;
    rdfs:comment 'Animal testing ban' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:animalTestingBanFlag rdf:type rdf:Property ;
    rdfs:label 'Animal Testing Ban Flag' ;
    rdfs:comment 'Indicates whether the jurisdiction prohibits the sale of products tested on animals (True) or allows it (False).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Gmp Certification Required' ;
    rdfs:comment 'GMP required' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Required Flag' ;
    rdfs:comment 'Indicates whether Good Manufacturing Practice (GMP) certification or compliance is mandatory for products sold in this jurisdiction (True) or not (False).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifraComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ifra Compliance Required Flag' ;
    rdfs:comment 'Indicates whether compliance with IFRA standards for fragrance ingredients is required (True) or not (False).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingredientDeclarationFormat rdf:type rdf:Property ;
    rdfs:label 'Ingredient Declaration Format' ;
    rdfs:comment 'The required format for ingredient listing on labels: INCI (International Nomenclature of Cosmetic Ingredients), CAS (Chemical Abstracts Service number), common name, or proprietary (brand-specific naming).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdictionStatus rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Status' ;
    rdfs:comment 'Current lifecycle status of the jurisdiction record: active (in use), inactive (no longer applicable), pending (awaiting activation), superseded (replaced by newer version).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionType rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Type' ;
    rdfs:comment 'Type (country, region, state)' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingLanguagePrimary rdf:type rdf:Property ;
    rdfs:label 'Labeling Language Primary' ;
    rdfs:comment 'ISO 639 two- or three-letter code for the primary language required on product labels in this jurisdiction (e.g., en, fr, de, zh).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingLanguageSecondary rdf:type rdf:Property ;
    rdfs:label 'Labeling Language Secondary' ;
    rdfs:comment 'Comma-separated list of ISO 639 language codes for additional languages required or recommended on labels (e.g., fr,nl for Belgium).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketEntryRequirementType rdf:type rdf:Property ;
    rdfs:label 'Market Entry Requirement Type' ;
    rdfs:comment 'The type of regulatory requirement for market entry: notification (simple filing), registration (formal registration), pre-market approval (full dossier review before sale), post-market surveillance (monitoring after launch), or voluntary (no mandatory requirement).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Name' ;
    rdfs:comment 'Jurisdiction name' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Required Flag' ;
    rdfs:comment 'Indicates whether a formal notification to the regulatory authority is required before product launch (True) or not (False).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postMarketSurveillanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Post Market Surveillance Required Flag' ;
    rdfs:comment 'Indicates whether ongoing post-market surveillance (adverse event reporting, product monitoring) is mandatory (True) or not (False).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preMarketApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Market Approval Required Flag' ;
    rdfs:comment 'Indicates whether pre-market approval (full dossier review and authorization before sale) is required (True) or not (False).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productInformationFileRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Product Information File Required Flag' ;
    rdfs:comment 'Indicates whether a Product Information File (PIF) or dossier must be maintained and made available to authorities (True) or not (False).' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Product Notification Required' ;
    rdfs:comment 'Notification required' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachRegistrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Required Flag' ;
    rdfs:comment 'Indicates whether REACH registration for chemical substances is required for this jurisdiction (True) or not (False). Primarily applicable to EU and EEA jurisdictions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationRequired rdf:type rdf:Property ;
    rdfs:label 'Registration Required' ;
    rdfs:comment 'Registration required' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsiblePersonRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Required Flag' ;
    rdfs:comment 'Indicates whether a designated Responsible Person (RP) within the jurisdiction is required for regulatory compliance (True) or not (False). Common in EU jurisdictions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedSubstanceId rdf:type rdf:Property ;
    rdfs:label 'Restricted Substance Id' ;
    rdfs:comment 'Primary key' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedProductCategories rdf:type rdf:Property ;
    rdfs:label 'Affected Product Categories' ;
    rdfs:comment 'Comma-separated list of product categories or SKU families in which this substance is restricted or prohibited (e.g., cosmetics, household cleaners, food contact materials, children\'s products).' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeSubstanceRecommendations rdf:type rdf:Property ;
    rdfs:label 'Alternative Substance Recommendations' ;
    rdfs:comment 'Comma-separated list of CAS numbers or substance names recommended as safer alternatives for formulation substitution.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegulations rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulations' ;
    rdfs:comment 'Comma-separated list of all regulations, directives, or legal frameworks under which this substance is restricted (e.g., EU REACH, California Prop 65, FDA 21 CFR 700, EPA FIFRA, CPSC regulations).' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current status of regulatory authorization for use of the substance in specific applications or markets.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationUnit rdf:type rdf:Property ;
    rdfs:label 'Concentration Unit' ;
    rdfs:comment 'Unit of measure for the maximum permitted concentration: percent by weight, percent by volume, parts per million (ppm), parts per billion (ppb), or milligrams per kilogram.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downstreamNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Downstream Notification Required' ;
    rdfs:comment 'Indicates whether manufacturers and importers must notify downstream users (formulators, distributors, retailers) of the presence of this substance in articles or mixtures.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Epa Restricted Flag' ;
    rdfs:comment 'Indicates whether the substance is subject to EPA restrictions under TSCA, FIFRA, or other environmental regulations.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptions rdf:type rdf:Property ;
    rdfs:label 'Exemptions' ;
    rdfs:comment 'Exemptions' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaProhibitedFlag rdf:type rdf:Property ;
    rdfs:label 'Fda Prohibited Flag' ;
    rdfs:comment 'Indicates whether the substance is explicitly prohibited by the FDA for use in cosmetics, drugs, or food contact materials under CFR Title 21.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifraProhibitionCategory rdf:type rdf:Property ;
    rdfs:label 'Ifra Prohibition Category' ;
    rdfs:comment 'IFRA product category (1-11) in which the substance is prohibited or restricted, ranging from Category 1 (lip products) to Category 11 (non-skin contact products).' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAllowedConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Max Allowed Concentration Pct' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Maximum Concentration Pct' ;
    rdfs:comment 'Max concentration' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumPermittedConcentration rdf:type rdf:Property ;
    rdfs:label 'Maximum Permitted Concentration' ;
    rdfs:comment 'Maximum allowable concentration of the substance in finished products, expressed as a percentage by weight or volume, as defined by applicable regulations.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productCategoryApplicability rdf:type rdf:Property ;
    rdfs:label 'Product Category Applicability' ;
    rdfs:comment 'Applicable categories' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prop65Listing rdf:type rdf:Property ;
    rdfs:label 'Prop 65 Listing' ;
    rdfs:comment 'Indicates whether the substance is listed under California Proposition 65 as known to cause cancer, birth defects, or reproductive harm, requiring warning labels for California sales.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictionDescription rdf:type rdf:Property ;
    rdfs:label 'Restriction Description' ;
    rdfs:comment 'Description' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rspoComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Rspo Compliance Flag' ;
    rdfs:comment 'Indicates whether the substance (if palm-derived) meets RSPO certification requirements for sustainable sourcing.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdsRequired rdf:type rdf:Property ;
    rdfs:label 'Sds Required' ;
    rdfs:comment 'Indicates whether a Safety Data Sheet (formerly MSDS) must be maintained and provided to downstream users for this substance.' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sunsetDate rdf:type rdf:Property ;
    rdfs:label 'Sunset Date' ;
    rdfs:comment 'Sunset date' ;
    rdfs:domain ind:RestrictedSubstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compliance Reviewer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Claims are reviewed by a designated employee; FK supports claim review audit and reporting.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adverseEventReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Reporting Required' ;
    rdfs:comment 'Indicates whether adverse events related to the claim must be reported to regulatory authorities. True if reporting is required, False otherwise.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedMarkets rdf:type rdf:Property ;
    rdfs:label 'Approved Markets' ;
    rdfs:comment 'Comma-separated list of market codes or regions where the claim is approved for use (e.g., USA, EU, LATAM, APAC). Enables market-specific claim deployment.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Business identifier for the regulatory claim, formatted as RC- followed by 8 digits. Used for external reference and tracking.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'Date when the internal compliance review was completed. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Outcome' ;
    rdfs:comment 'Result of internal FTC/FDA compliance review: compliant (meets all requirements), non-compliant (violates regulations), requires modification (needs changes before use), pending review (under evaluation), or not reviewed (not yet assessed).' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclaimerRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Disclaimer Required Flag' ;
    rdfs:comment 'Indicates whether a disclaimer statement must accompany the claim on labels or marketing materials. True if disclaimer is required, False otherwise.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disclaimerText rdf:type rdf:Property ;
    rdfs:label 'Disclaimer Text' ;
    rdfs:comment 'Full text of the required disclaimer that must accompany the claim. Null if no disclaimer is required. Must be displayed in accordance with regulatory guidelines.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euRegulationReference rdf:type rdf:Property ;
    rdfs:label 'Eu Regulation Reference' ;
    rdfs:comment 'Specific EU regulation or directive that governs the claim (e.g., Regulation 1223/2009 for cosmetics, Regulation 1924/2006 for nutrition and health claims). Null if not applicable to EU markets.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Review frequency' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substantiationDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Substantiation Document Reference' ;
    rdfs:comment 'Document reference' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingStudyReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Study Reference' ;
    rdfs:comment 'Reference identifier or citation for the study, test report, or documentation that substantiates the claim. May include internal study IDs, published journal citations, or third-party certification numbers.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyCertification rdf:type rdf:Property ;
    rdfs:label 'Third Party Certification' ;
    rdfs:comment 'Name of third-party certification body or seal that validates the claim (e.g., USDA Organic, Leaping Bunny, EcoCert, NSF, Rainforest Alliance). Null if no third-party certification applies.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRestriction rdf:type rdf:Property ;
    rdfs:label 'Usage Restriction' ;
    rdfs:comment 'Any restrictions or conditions on the use of the claim, such as required disclaimers, context limitations, or co-claim requirements. Free text field for detailed restriction documentation.' ;
    rdfs:domain ind:RegulatoryClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionId rdf:type rdf:Property ;
    rdfs:label 'Action Id' ;
    rdfs:comment 'Primary key' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionResponsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Action Responsible Employee Id' ;
    rdfs:comment 'Responsible person' ;
    rdfs:domain ind:Action ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryRegulatoryActionResponsiblePartyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Action Responsible Party Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory actions assign a responsible employee for follow-up; FK enables tracking of accountability.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionDate rdf:type rdf:Property ;
    rdfs:label 'Action Date' ;
    rdfs:comment 'Action date' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Official reference number assigned by the regulatory authority to this enforcement action (e.g., warning letter number, import alert number, consent decree docket number).' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory action. Tracks progression from initial receipt through company response, corrective action implementation, and final resolution or closure by the authority. [ENUM-REF-CANDIDATE: received|under_review|response_submitted|corrective_action_in_progress|resolved|closed|appealed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedFacilityList rdf:type rdf:Property ;
    rdfs:label 'Affected Facility List' ;
    rdfs:comment 'Comma-separated list of facility names or codes affected by this regulatory action when multiple sites are involved. Used for multi-site enforcement actions or consent decrees covering multiple locations.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProductList rdf:type rdf:Property ;
    rdfs:label 'Affected Product List' ;
    rdfs:comment 'Comma-separated list of product names, SKUs (Stock Keeping Units), or GTINs (Global Trade Item Numbers) affected by this regulatory action when multiple products are involved. Used when action spans multiple products or product families.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Audit Completion Date' ;
    rdfs:comment 'Date the mandated external audit was completed and final audit report submitted to the regulatory authority. Null if no external audit is required or if audit is still in progress.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Board Notification Date' ;
    rdfs:comment 'Date the Board of Directors was formally notified of this regulatory action. Required for material enforcement actions that could impact financial statements, stock price, or corporate reputation. Null if board notification was not required.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:citationReference rdf:type rdf:Property ;
    rdfs:label 'Citation Reference' ;
    rdfs:comment 'Specific legal or regulatory code sections cited in the enforcement action (e.g., 21 CFR 211.110 for GMP violations, 40 CFR 261 for hazardous waste, 16 CFR Part 1500 for CPSC). Provides the legal basis for the action.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Description' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'External Audit Required Flag' ;
    rdfs:comment 'Indicates whether the regulatory action mandates an independent third-party audit or inspection to verify corrective actions. True when authority requires external verification; False when internal verification is sufficient.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalAuditorName rdf:type rdf:Property ;
    rdfs:label 'External Auditor Name' ;
    rdfs:comment 'Name of the independent third-party auditing firm or consultant engaged to verify corrective actions as required by the regulatory authority. Null if no external audit is required.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Penalty Amount' ;
    rdfs:comment 'Monetary fine or civil penalty assessed by the regulatory authority as part of the enforcement action. Expressed in the currency specified in penalty_currency_code. Null if no financial penalty was imposed.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceClaimReference rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Reference' ;
    rdfs:comment 'Reference number for any insurance claim filed to recover costs associated with this regulatory action (e.g., recall expenses, legal fees, penalties). Links to the insurance claims management system. Null if no claim was filed.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselAssigned rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Assigned' ;
    rdfs:comment 'Name of the internal or external legal counsel assigned to advise on this regulatory action. Critical for consent decrees, injunctions, civil penalties, and criminal prosecutions where legal strategy is required.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousActionReference rdf:type rdf:Property ;
    rdfs:label 'Previous Action Reference' ;
    rdfs:comment 'Reference to the earlier regulatory action that cited the same or related violations. Used to track repeat violations and enforcement escalation patterns. Null if this is a first-time violation.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosure rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure' ;
    rdfs:comment 'Public disclosure flag' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Flag' ;
    rdfs:comment 'Indicates whether the regulatory action has been publicly disclosed by the authority (e.g., published on FDA warning letters database, EPA enforcement actions website). True if publicly available; False if confidential or under seal.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicDisclosureUrl rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Url' ;
    rdfs:comment 'Web address where the regulatory action is publicly published by the issuing authority. Typically links to FDA warning letters database, EPA enforcement actions, CPSC recall notices, or equivalent public registries. Null if not publicly disclosed.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Required Flag' ;
    rdfs:comment 'Indicates whether the regulatory action mandates a product recall. True for mandatory recalls ordered by the authority; False for actions that do not require recall or for voluntary recalls initiated by the company.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Violation Flag' ;
    rdfs:comment 'Indicates whether this regulatory action cites violations that were previously identified in earlier inspections or enforcement actions. True for repeat violations, which typically result in escalated enforcement and higher penalties; False for first-time violations.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Response submitted' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsiblePartyEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Email' ;
    rdfs:comment 'Corporate email address of the internal executive or department head accountable for this regulatory action. Used for escalation and executive reporting.' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCategory rdf:type rdf:Property ;
    rdfs:label 'Violation Category' ;
    rdfs:comment 'Primary classification of the regulatory violation cited in the action. GMP (Good Manufacturing Practice) violations relate to production standards; labeling violations involve packaging claims or ingredient declarations; safety violations concern product hazards; environmental violations address EPA compliance; advertising violations involve FTC rules; ingredient violations relate to prohibited or undeclared substances; quality system violations concern QMS (Quality Management System) deficiencies; record-keeping violations involve documentation failures; reporting violations concern mandatory disclosure failures. [ENUM-REF-CANDIDATE: gmp_violation|labeling_violation|safety_violation|environmental_violation|advertising_violation|ingredient_violation|quality_system_violation|record_keeping_violation|reporting_violation — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Action ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscFilingId rdf:type rdf:Property ;
    rdfs:label 'Cpsc Filing Id' ;
    rdfs:comment 'Primary key' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpscResponsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cpsc Responsible Employee Id' ;
    rdfs:comment 'Responsible person' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cpscSubmittedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cpsc Submitted By Employee Id' ;
    rdfs:comment 'Employee identifier of the person who submitted the filing. Links to HR system for accountability.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:correctiveActionType rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Type' ;
    rdfs:comment 'Type of corrective action proposed or implemented to address the product hazard. May include multiple remedies. [ENUM-REF-CANDIDATE: recall|repair|replacement|refund|warning|product_modification|none_proposed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Cpsc Case Number' ;
    rdfs:comment 'Official case number assigned by CPSC upon receipt and acceptance of the filing. Used for all subsequent correspondence and tracking.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscResponseDescription rdf:type rdf:Property ;
    rdfs:label 'Cpsc Response Description' ;
    rdfs:comment 'Detailed description of CPSC response, including any requirements, recommendations, or determinations made by the agency.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscResponseReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Cpsc Response Received Date' ;
    rdfs:comment 'Date CPSC provided official response to the filing, including acceptance, request for additional information, or determination.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cpscResponseType rdf:type rdf:Property ;
    rdfs:label 'Cpsc Response Type' ;
    rdfs:comment 'Type of response received from CPSC regarding the filing. Indicates regulatory action required or determination made.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Technical description of the product defect or failure mode that creates the hazard. Includes root cause analysis when known.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatalityCount rdf:type rdf:Property ;
    rdfs:label 'Fatality Count' ;
    rdfs:comment 'Number of deaths associated with the product hazard. Triggers immediate CPSC notification and investigation.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:filingNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Number' ;
    rdfs:comment 'Filing number' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Status' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'Type (initial, update, closure)' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardType rdf:type rdf:Property ;
    rdfs:label 'Hazard Type' ;
    rdfs:comment 'Primary type of hazard posed by the product defect. Categorizes the nature of risk to consumers. [ENUM-REF-CANDIDATE: fire|burn|laceration|choking|chemical_exposure|electrical_shock|fall|entrapment|suffocation|poisoning|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCount rdf:type rdf:Property ;
    rdfs:label 'Incident Count' ;
    rdfs:comment 'Total number of reported incidents involving the product hazard, including those without injury.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Incident description' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryCount rdf:type rdf:Property ;
    rdfs:label 'Injury Count' ;
    rdfs:comment 'Number of reported injuries associated with the product hazard. Includes both confirmed and alleged injuries.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:injurySeverity rdf:type rdf:Property ;
    rdfs:label 'Injury Severity' ;
    rdfs:comment 'Highest severity level of injuries reported. Used to assess risk level and prioritize regulatory response.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryType rdf:type rdf:Property ;
    rdfs:label 'Injury Type' ;
    rdfs:comment 'Injury type' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knowledgeDate rdf:type rdf:Property ;
    rdfs:label 'Knowledge Date' ;
    rdfs:comment 'Date the company first obtained information reasonably supporting the conclusion that a product contains a defect which could create a substantial product hazard. Triggers 24-hour reporting obligation under Section 15(b).' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completed Flag' ;
    rdfs:comment 'Indicates whether legal counsel has reviewed and approved the filing before submission. Required for Section 15(b) reports.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewerName rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer Name' ;
    rdfs:comment 'Name of the legal counsel who reviewed the filing.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Number' ;
    rdfs:comment 'Manufacturing lot or batch number of the affected product units. Essential for determining scope of hazard and recall.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingDateRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date Range End' ;
    rdfs:comment 'End date of the manufacturing period for affected product units.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingDateRangeStart rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date Range Start' ;
    rdfs:comment 'Start date of the manufacturing period for affected product units.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productDefectDescription rdf:type rdf:Property ;
    rdfs:label 'Product Defect Description' ;
    rdfs:comment 'Defect description' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productModelNumber rdf:type rdf:Property ;
    rdfs:label 'Product Model Number' ;
    rdfs:comment 'Specific model or SKU number of the product involved in the incident. Critical for identifying affected units.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallAnnouncedFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Announced Flag' ;
    rdfs:comment 'Indicates whether a public recall has been announced in conjunction with this filing. True if recall press release issued.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallAnnouncementDate rdf:type rdf:Property ;
    rdfs:label 'Recall Announcement Date' ;
    rdfs:comment 'Date the product recall was publicly announced via CPSC press release and website posting.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:saferproductsReportNumber rdf:type rdf:Property ;
    rdfs:label 'Saferproducts Report Number' ;
    rdfs:comment 'Unique identifier assigned to the report in the SaferProducts.gov public database if the filing resulted in a public posting.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedByEmail rdf:type rdf:Property ;
    rdfs:label 'Submitted By Email' ;
    rdfs:comment 'Email address of the submitter for CPSC correspondence and follow-up communications.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedByName rdf:type rdf:Property ;
    rdfs:label 'Submitted By Name' ;
    rdfs:comment 'Name of the individual who submitted the filing to CPSC on behalf of the company.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingLabelRequired rdf:type rdf:Property ;
    rdfs:label 'Tracking Label Required' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitsSold rdf:type rdf:Property ;
    rdfs:label 'Units Sold' ;
    rdfs:comment 'Total number of units of the affected product sold to consumers. Helps determine recall scope and consumer notification requirements.' ;
    rdfs:domain ind:CpscFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:epaRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Epa Registration Id' ;
    rdfs:comment 'Primary key' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeIngredientList rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient List' ;
    rdfs:comment 'Comma-separated list of active ingredient(s) in the registered product. Each active ingredient is the chemical substance responsible for the pesticidal or antimicrobial effect. Format: Chemical Name (CAS Number); Chemical Name (CAS Number).' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeIngredientPercentage rdf:type rdf:Property ;
    rdfs:label 'Active Ingredient Percentage' ;
    rdfs:comment 'Active ingredient %' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Annual Reporting Required' ;
    rdfs:comment 'Annual reporting flag' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:companyNumber rdf:type rdf:Property ;
    rdfs:label 'Company Number' ;
    rdfs:comment 'Five-digit EPA company number assigned to the registrant. This is the first component of the EPA registration number and identifies the company holding the registration.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCallInDueDate rdf:type rdf:Property ;
    rdfs:label 'Data Call In Due Date' ;
    rdfs:comment 'Date by which the registrant must submit data or studies in response to an EPA data call-in. Failure to meet this deadline may result in registration cancellation.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataCallInRequirement rdf:type rdf:Property ;
    rdfs:label 'Data Call In Requirement' ;
    rdfs:comment 'Description of any outstanding data call-in requirements issued by EPA. Data call-ins require registrants to submit additional studies or data to support continued registration. Includes requirement reference number and due date.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaEstablishmentNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Establishment Number' ;
    rdfs:comment 'EPA establishment number identifying the facility where the product is manufactured. Format: Company Number-State Code-Facility Number (e.g., 12345-CA-001). Required on product labels.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Registration Number' ;
    rdfs:comment 'EPA registration number' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Label Approval Status' ;
    rdfs:comment 'Current status of the EPA-approved product label. The label must be approved before the product can be marketed. Approved = label accepted by EPA, Pending Review = submitted awaiting EPA review, Conditionally Approved = approved with minor changes required, Rejected = label not acceptable, Revision Required = EPA requested changes.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelApproved rdf:type rdf:Property ;
    rdfs:label 'Label Approved' ;
    rdfs:comment 'Label approved' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAnnualReportDate rdf:type rdf:Property ;
    rdfs:label 'Last Annual Report Date' ;
    rdfs:comment 'Last report date' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'Date of the most recent renewal action for this EPA registration. Used to track renewal history and calculate next renewal due date.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextRenewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Due Date' ;
    rdfs:comment 'Date by which the next renewal application must be submitted to EPA to maintain continuous registration status. Critical for compliance planning.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productBrandName rdf:type rdf:Property ;
    rdfs:label 'Product Brand Name' ;
    rdfs:comment 'Commercial brand name under which the product is marketed to consumers. May differ from the registered product name.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productUseCategory rdf:type rdf:Property ;
    rdfs:label 'Product Use Category' ;
    rdfs:comment 'Use category' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrantName rdf:type rdf:Property ;
    rdfs:label 'Registrant Name' ;
    rdfs:comment 'Registrant name' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrantNumber rdf:type rdf:Property ;
    rdfs:label 'Registrant Number' ;
    rdfs:comment 'Registrant number' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationReviewCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Review Case Number' ;
    rdfs:comment 'EPA case number for the periodic registration review process. EPA reviews all pesticide registrations on a 15-year cycle to ensure they continue to meet safety standards.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationReviewDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Registration Review Decision Date' ;
    rdfs:comment 'Date when EPA issued the most recent registration review decision for this product. Used to track compliance with periodic review requirements.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reregistrationEligibilityDecision rdf:type rdf:Property ;
    rdfs:label 'Reregistration Eligibility Decision' ;
    rdfs:comment 'EPA determination of whether the product is eligible for reregistration under updated safety and environmental standards. Eligible = meets current standards, Ineligible = does not meet standards and requires reformulation or cancellation, Pending = under EPA review, Not Applicable = not subject to reregistration.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPestList rdf:type rdf:Property ;
    rdfs:label 'Target Pest List' ;
    rdfs:comment 'List of target pests, pathogens, or organisms that the product is registered to control (e.g., bacteria, viruses, mold, ants, cockroaches). Defines the approved efficacy claims.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useSiteDescription rdf:type rdf:Property ;
    rdfs:label 'Use Site Description' ;
    rdfs:comment 'Description of approved use sites and application locations for the registered product (e.g., household surfaces, food contact surfaces, hospitals, schools, outdoor residential). Defines where the product may legally be applied.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Vault Document Reference' ;
    rdfs:comment 'Reference identifier to the EPA registration documents stored in the regulatory document vault system (e.g., Veeva Vault). Links to approved labels, safety data sheets, and registration correspondence.' ;
    rdfs:domain ind:EpaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

