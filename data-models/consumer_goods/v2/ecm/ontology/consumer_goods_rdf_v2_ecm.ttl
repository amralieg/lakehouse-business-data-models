    rdfs:comment 'Primary key' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
