    rdfs:comment 'Name of the CPG brand being evaluated in this NPS survey response. Stored denormalized for direct use in brand health reporting and consumer sentiment dashboards without requiring a join to the brand master.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandOwnerGln rdf:type rdf:Property ;
