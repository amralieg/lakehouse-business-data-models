    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Human-readable name of the loyalty tier (e.g., Gold, Platinum).' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierRank rdf:type rdf:Property ;
    rdfs:label 'Tier Rank' ;
    rdfs:comment 'Numeric rank used to order tiers from lowest to highest.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierType rdf:type rdf:Property ;
    rdfs:label 'Tier Type' ;
    rdfs:comment 'Classification of the tier based on the underlying qualification model.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedSurveyId rdf:type rdf:Property ;
