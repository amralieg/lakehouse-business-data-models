    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cltvEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Cltv Estimate Usd' ;
    rdfs:comment 'Estimated Customer Lifetime Value in USD for consumers in this segment, used for prioritization and investment decisions.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentPreference rdf:type rdf:Property ;
    rdfs:label 'Content Preference' ;
    rdfs:comment 'Types of marketing content that resonate with this segment (e.g., educational, promotional, user-generated, influencer, video).' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerSegmentDescription rdf:type rdf:Property ;
    rdfs:label 'Consumer Segment Description' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalEngagementLevel rdf:type rdf:Property ;
    rdfs:label 'Digital Engagement Level' ;
    rdfs:comment 'Level of digital channel engagement and activity for consumers in this segment (social media, email, mobile app, e-commerce).' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeBracket rdf:type rdf:Property ;
    rdfs:label 'Income Bracket' ;
    rdfs:comment 'Income level classification for consumers in this segment, used for targeting and media planning.' ;
