    rdfs:range ind:RevenueContract .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier for the audit trail or approval workflow associated with this revenue recognition event.' ;
