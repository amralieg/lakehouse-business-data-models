    rdfs:comment 'Marketing segment classification for the consumer. [ENUM-REF-CANDIDATE: value_seeker|brand_loyalist|price_sensitive|premium|occasional|new_customer — promote to reference product]' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:state rdf:type rdf:Property ;
    rdfs:label 'State' ;
    rdfs:comment 'State or province of the consumer\'s residence.' ;
    rdfs:domain ind:ConsumerGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelStatus rdf:type rdf:Property ;
    rdfs:label 'Panel Status' ;
    rdfs:comment 'Current lifecycle status of the consumer record.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSize rdf:type rdf:Property ;
    rdfs:label 'Target Size' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Amount' ;
    rdfs:comment 'Cumulative monetary value of all purchases made by the consumer.' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextLoyaltyTierId rdf:type rdf:Property ;
    rdfs:label 'Next Loyalty Tier Id' ;
    rdfs:comment 'Self-referencing FK on loyalty_tier (next_loyalty_tier_id)' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyTier .

ind:benefitsDescription rdf:type rdf:Property ;
    rdfs:label 'Benefits Description' ;
    rdfs:comment 'Narrative description of the benefits associated with the tier.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercent rdf:type rdf:Property ;
    rdfs:label 'Discount Percent' ;
    rdfs:comment 'Standard discount percentage applied to purchases for members in this tier.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Detailed rules that define how members qualify for the tier beyond points/spend thresholds.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveOffers rdf:type rdf:Property ;
    rdfs:label 'Exclusive Offers' ;
    rdfs:comment 'Indicates whether the tier grants access to exclusive promotions.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expirationPolicy rdf:type rdf:Property ;
    rdfs:label 'Expiration Policy' ;
    rdfs:comment 'Policy governing how tier status expires or rolls over.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeShipping rdf:type rdf:Property ;
    rdfs:label 'Free Shipping' ;
    rdfs:comment 'Indicates whether the tier includes complimentary shipping.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxPointsPerYear rdf:type rdf:Property ;
    rdfs:label 'Max Points Per Year' ;
    rdfs:comment 'Cap on the number of points a member can earn in a calendar year while in this tier.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxPointsThreshold rdf:type rdf:Property ;
    rdfs:label 'Max Points Threshold' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minPointsThreshold rdf:type rdf:Property ;
    rdfs:label 'Min Points Threshold' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minSpendThreshold rdf:type rdf:Property ;
    rdfs:label 'Min Spend Threshold' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsMultiplier rdf:type rdf:Property ;
    rdfs:label 'Points Multiplier' ;
    rdfs:comment 'Multiplier applied to earned points for members in this tier.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prioritySupport rdf:type rdf:Property ;
    rdfs:label 'Priority Support' ;
    rdfs:comment 'Indicates whether members receive priority customer support.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalCode rdf:type rdf:Property ;
    rdfs:label 'Promotional Code' ;
    rdfs:comment 'Optional code used in marketing campaigns to reference the tier.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredPoints rdf:type rdf:Property ;
    rdfs:label 'Required Points' ;
    rdfs:comment 'Number of loyalty points a member must accumulate to qualify for this tier.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Required Spend Usd' ;
    rdfs:comment 'Monetary spend threshold (in USD) required to reach the tier.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
