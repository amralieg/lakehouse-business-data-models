    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyTierStatus rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Status' ;
    rdfs:comment 'Current lifecycle state of the tier.' ;
    rdfs:domain ind:LoyaltyTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'External code used to reference the loyalty tier in marketing and systems.' ;
