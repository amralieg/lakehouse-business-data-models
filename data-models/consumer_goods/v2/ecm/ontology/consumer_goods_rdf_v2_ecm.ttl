    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyCharacteristics rdf:type rdf:Property ;
    rdfs:label 'Key Characteristics' ;
    rdfs:comment 'Defining behavioral, demographic, or psychographic characteristics that distinguish this segment from others.' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messagingTonePreference rdf:type rdf:Property ;
    rdfs:label 'Messaging Tone Preference' ;
    rdfs:comment 'Preferred messaging tone and style for communications to this segment (e.g., aspirational, practical, humorous, authoritative).' ;
    rdfs:domain ind:ConsumerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScoreAverage rdf:type rdf:Property ;
    rdfs:label 'Nps Score Average' ;
    rdfs:comment 'Average Net Promoter Score for consumers in this segment, indicating brand loyalty and advocacy potential.' ;
