ind:householdId rdf:type rdf:Property ;
    rdfs:label 'Household Id' ;
    rdfs:comment 'Foreign key linking subscriber to their household group. Multiple subscribers may share a household for family plans and concurrent stream management. | Column household_id (BIGINT) in subscriber.subscriber' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the subscriber account. Determines access entitlements and billing state. Active subscribers have full access; suspended accounts are temporarily blocked; cancelled accounts are terminated; trial accounts are in promotional period; churned accounts have completed cancellation. | Column account_status (STRING) in subscriber.subscriber' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adobeProfileReference rdf:type rdf:Property ;
    rdfs:label 'Adobe Profile Reference' ;
    rdfs:comment 'External identifier linking this subscriber to their unified profile in Adobe Experience Platform. Used for personalization, segmentation, and journey orchestration. | Column adobe_profile_reference (STRING) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Frequency of subscription billing. Monthly, quarterly, and annual are recurring; lifetime is one-time payment; pay-per-view is transactional. | Column billing_cycle (STRING) in subscriber.subscriber' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Flag' ;
    rdfs:comment 'Indicates whether California subscriber has opted out of personal data sale. Required for CCPA compliance. | Column ccpa_opt_out_flag (BOOLEAN) in subscriber.subscriber' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccpaOptOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Timestamp' ;
    rdfs:comment 'Date and time when CCPA opt-out was recorded. Required for audit trail and compliance reporting. | Column ccpa_opt_out_timestamp (TIMESTAMP) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:churnRiskScore rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Score' ;
    rdfs:comment 'Predictive score (0.0000 to 1.0000) indicating likelihood of subscriber cancellation within next billing cycle. Generated by machine learning model based on engagement, payment history, and behavioral signals. | Column churn_risk_score (DECIMAL(5,4)) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coppaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Coppa Compliant Flag' ;
    rdfs:comment 'Indicates whether this subscriber account is subject to COPPA restrictions (under 13 years old). When true, data collection and advertising are restricted. | Column coppa_compliant_flag (BOOLEAN) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing subscriber\'s primary geographic location. Used for content rights windowing, regional pricing, and regulatory compliance. | Column country_code (STRING) in subscriber.subscriber' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Subscriber\'s date of birth. Used for age verification, parental controls, COPPA compliance, and demographic segmentation. | Column date_of_birth (DATE) in subscriber.subscriber' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for subscriber communication, authentication, and personalization. Used as primary contact channel and login credential. | Column email_address (STRING) in subscriber.subscriber' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'External business identifier for the subscriber, typically used for integration with Zuora billing and Adobe Experience Platform. May be customer-facing account number or external system key. | Column external_reference_code (STRING) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Subscriber\'s given name as provided during registration. Used for personalization and customer service interactions. | Column first_name (STRING) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether subscriber has provided explicit consent for data processing under GDPR. Required for EU subscribers. | Column gdpr_consent_flag (BOOLEAN) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprConsentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Timestamp' ;
    rdfs:comment 'Date and time when GDPR consent was obtained. Required for audit trail and consent management. | Column gdpr_consent_timestamp (TIMESTAMP) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Subscriber\'s self-identified gender. Used for demographic analytics and content personalization. Optional field respecting subscriber privacy preferences. | Column gender (STRING) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastLoginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Login Timestamp' ;
    rdfs:comment 'Date and time of subscriber\'s most recent authentication. Used for engagement tracking and churn prediction. | Column last_login_timestamp (TIMESTAMP) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Subscriber\'s family name as provided during registration. Used for personalization and customer service interactions. | Column last_name (STRING) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastViewingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Viewing Timestamp' ;
    rdfs:comment 'Date and time of subscriber\'s most recent content viewing session. Used for engagement analysis and retention modeling. | Column last_viewing_timestamp (TIMESTAMP) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ltv rdf:type rdf:Property ;
    rdfs:label 'Ltv' ;
    rdfs:comment 'Predicted total revenue this subscriber will generate over their entire relationship with the service. Used for acquisition cost justification and retention prioritization. | Column ltv (DECIMAL(12,2)) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether subscriber has consented to receive marketing communications. Required for GDPR and CCPA compliance. | Column marketing_opt_in (BOOLEAN) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxRegisteredDevices rdf:type rdf:Property ;
    rdfs:label 'Max Registered Devices' ;
    rdfs:comment 'Maximum number of devices that can be registered to this subscriber account. Used for device management and anti-piracy enforcement. | Column max_registered_devices (INT) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentalControlPin rdf:type rdf:Property ;
    rdfs:label 'Parental Control Pin' ;
    rdfs:comment 'Encrypted PIN code required to access age-restricted content when parental controls are enabled. Stored in hashed format for security. | Column parental_control_pin (STRING) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for subscriber support and account recovery. May be used for two-factor authentication. | Column phone_number (STRING) in subscriber.subscriber' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Subscriber\'s postal or ZIP code. Used for geographic segmentation, local content recommendations, and blackout enforcement. | Column postal_code (STRING) in subscriber.subscriber' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'Two-letter ISO language code representing subscriber\'s preferred interface and content language. Used for UI localization and content recommendations. | Column preferred_language (STRING) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationSource rdf:type rdf:Property ;
    rdfs:label 'Registration Source' ;
    rdfs:comment 'Channel through which the subscriber originally registered. Used for acquisition analytics and channel effectiveness measurement. | Column registration_source (STRING) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Timestamp' ;
    rdfs:comment 'Date and time when the subscriber account was first created. Used for cohort analysis, LTV calculation, and subscriber lifecycle tracking. | Column registration_timestamp (TIMESTAMP) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subscriptionEndDate rdf:type rdf:Property ;
    rdfs:label 'Subscription End Date' ;
    rdfs:comment 'Date when the current subscription is scheduled to end or renew. Null for active recurring subscriptions. Used for churn prediction and retention campaigns. | Column subscription_end_date (DATE) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionStartDate rdf:type rdf:Property ;
    rdfs:label 'Subscription Start Date' ;
    rdfs:comment 'Date when the current subscription tier became effective. Used for billing cycle calculation and tenure analysis. | Column subscription_start_date (DATE) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalViewingHours rdf:type rdf:Property ;
    rdfs:label 'Total Viewing Hours' ;
    rdfs:comment 'Cumulative hours of content viewed by this subscriber since registration. Key engagement metric for LTV calculation and content recommendation. | Column total_viewing_hours (DECIMAL(12,2)) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zuoraAccountReference rdf:type rdf:Property ;
    rdfs:label 'Zuora Account Reference' ;
    rdfs:comment 'External identifier linking this subscriber to their billing account in Zuora subscription management system. Used for payment processing and revenue recognition integration. | Column zuora_account_reference (STRING) in subscriber.subscriber' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Account Created Date' ;
    rdfs:comment 'Date when the household account was first created in the system. Used for tenure analysis and customer lifetime value (LTV) calculations. | Column account_created_date (DATE) in subscriber.household' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line for the household\'s service location. Used for geographic market assignment and service delivery. | Column address_line_1 (STRING) in subscriber.household' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for apartment, suite, or unit number. Optional field for additional address detail. | Column address_line_2 (STRING) in subscriber.household' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Enabled' ;
    rdfs:comment 'Indicates whether the household subscription automatically renews at the end of each billing period. When false, subscription expires unless manually renewed. | Column auto_renew_enabled (BOOLEAN) in subscriber.household' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageRevenuePerUser rdf:type rdf:Property ;
    rdfs:label 'Average Revenue Per User' ;
    rdfs:comment 'Average monthly revenue generated by this household, calculated as total revenue divided by number of active months. Key metric for household value assessment. | Column average_revenue_per_user (DECIMAL(10,2)) in subscriber.household' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCycleDay rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Day' ;
    rdfs:comment 'Day of the month when the household\'s recurring subscription charge is processed. Typically set at initial subscription and remains consistent. | Column billing_cycle_day (INT) in subscriber.household' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the household is located. Used for geographic segmentation and local content availability. | Column city (STRING) in subscriber.household' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the household has consented to sharing their viewing data with third parties for analytics and advertising purposes. Required for privacy compliance. | Column data_sharing_consent (BOOLEAN) in subscriber.household' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dmaCode rdf:type rdf:Property ;
    rdfs:label 'Dma Code' ;
    rdfs:comment 'Nielsen Designated Market Area code identifying the geographic television market for this household. Used for local content availability, blackout enforcement, and advertising targeting. | Column dma_code (STRING) in subscriber.household' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdStatus rdf:type rdf:Property ;
    rdfs:label 'Household Status' ;
    rdfs:comment 'Current lifecycle status of the household account. Determines access rights and billing state. | Column household_status (STRING) in subscriber.household' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdType rdf:type rdf:Property ;
    rdfs:label 'Household Type' ;
    rdfs:comment 'Classification of the household based on its composition and purpose. Determines applicable service tier rules and entitlement models. | Column household_type (STRING) in subscriber.household' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Two-letter ISO 639-1 language code representing the household\'s preferred content and interface language. Used for content recommendations and UI localization. | Column language_preference (STRING) in subscriber.household' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent successful payment received from this household. Used for delinquency tracking and churn prediction. | Column last_payment_date (DATE) in subscriber.household' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimeValue rdf:type rdf:Property ;
    rdfs:label 'Lifetime Value' ;
    rdfs:comment 'Total revenue generated by this household since account creation, including subscription fees, transactional purchases (TVOD), and advertising revenue attribution. Used for customer segmentation and retention investment decisions. | Column lifetime_value (DECIMAL(12,2)) in subscriber.household' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mvpdAffiliation rdf:type rdf:Property ;
    rdfs:label 'Mvpd Affiliation' ;
    rdfs:comment 'Name of the MVPD or vMVPD provider if this household accesses content through a cable/satellite/virtual provider authentication. Used for TV Everywhere entitlement validation. | Column mvpd_affiliation (STRING) in subscriber.household' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Payment Method Type' ;
    rdfs:comment 'Type of payment instrument on file for this household\'s subscription billing. Determines payment processing flow and retry logic. [ENUM-REF-CANDIDATE: credit_card|debit_card|paypal|bank_transfer|gift_card|carrier_billing|app_store — 7 candidates stripped; promote to reference product] | Column payment_method_type (STRING) in subscriber.household' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySubscriberCode rdf:type rdf:Property ;
    rdfs:label 'Primary Subscriber Code' ;
    rdfs:comment 'Reference to the primary account holder or subscriber who owns this household account. This subscriber has administrative privileges for the household. | Column primary_subscriber_id (BIGINT) in subscriber.household' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Number of registered members or subscribers within this household. Used for family plan eligibility and simultaneous stream limit enforcement. | Column size (INT) in subscriber.household' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or region code for the household address. Used for regulatory compliance and regional content licensing. | Column state_province (STRING) in subscriber.household' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the household location. Used for scheduling, program guide display, and live event timing. | Column time_zone (STRING) in subscriber.household' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify the household\'s identity and location. Multiple methods may be used in combination for higher confidence. | Column verification_method (STRING) in subscriber.household' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adSupported rdf:type rdf:Property ;
    rdfs:label 'Ad Supported' ;
    rdfs:comment 'Indicates whether this subscription plan includes advertising (AVOD/FAST model) or is ad-free (SVOD model). | Column ad_supported (BOOLEAN) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addonEligible rdf:type rdf:Property ;
    rdfs:label 'Addon Eligible' ;
    rdfs:comment 'Indicates whether this plan can be purchased as an add-on to another base subscription plan (e.g., premium sports channel add-on). | Column addon_eligible (BOOLEAN) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioQualityMax rdf:type rdf:Property ;
    rdfs:label 'Audio Quality Max' ;
    rdfs:comment 'Maximum audio quality format available under this subscription plan (e.g., stereo, surround 5.1, Dolby Atmos, DTS:X). | Column audio_quality_max (STRING) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether subscriptions under this plan automatically renew at the end of each billing period by default. | Column auto_renewal_enabled (BOOLEAN) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'Standard recurring price for the subscription plan before any discounts, promotions, or taxes. Expressed in the default currency. | Column base_price (DECIMAL(12,2)) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Frequency at which subscribers are billed for this plan (e.g., monthly, quarterly, annual, biannual, one-time, usage-based). | Column billing_frequency (STRING) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundledPlan rdf:type rdf:Property ;
    rdfs:label 'Bundled Plan' ;
    rdfs:comment 'Indicates whether this is a bundled subscription plan that combines multiple services or content packages (e.g., streaming + live TV + music). | Column bundled_plan (BOOLEAN) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationPolicy rdf:type rdf:Property ;
    rdfs:label 'Cancellation Policy' ;
    rdfs:comment 'Policy governing subscriber cancellation: anytime (immediate), end of billing period, no refund, or prorated refund. | Column cancellation_policy (STRING) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:churnRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Category' ;
    rdfs:comment 'Assessed churn risk category for subscribers on this plan based on historical churn rate analysis (low, medium, high). | Column churn_risk_category (STRING) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concurrentStreamLimit rdf:type rdf:Property ;
    rdfs:label 'Concurrent Stream Limit' ;
    rdfs:comment 'Maximum number of simultaneous video streams allowed under this subscription plan. Null indicates unlimited concurrent streams. | Column concurrent_stream_limit (INT) in subscriber.subscription_plan' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentLibraryScope rdf:type rdf:Property ;
    rdfs:label 'Content Library Scope' ;
    rdfs:comment 'Defines the scope of content library access granted by this plan (e.g., full catalog, limited selection, premium content only, sports only, news only, kids only). | Column content_library_scope (STRING) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Minimum contract commitment period in months for this subscription plan. Null indicates month-to-month with no minimum commitment. | Column contract_term_months (INT) in subscriber.subscription_plan' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceRegistrationLimit rdf:type rdf:Property ;
    rdfs:label 'Device Registration Limit' ;
    rdfs:comment 'Maximum number of devices that can be registered to a subscriber account under this plan. Null indicates unlimited device registrations. | Column device_registration_limit (INT) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downloadEnabled rdf:type rdf:Property ;
    rdfs:label 'Download Enabled' ;
    rdfs:comment 'Indicates whether offline download of content is permitted under this subscription plan. | Column download_enabled (BOOLEAN) in subscriber.subscription_plan' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downloadLimit rdf:type rdf:Property ;
    rdfs:label 'Download Limit' ;
    rdfs:comment 'Maximum number of titles that can be downloaded for offline viewing at any given time. Null if download_enabled is false or unlimited. | Column download_limit (INT) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyTerminationFee rdf:type rdf:Property ;
    rdfs:label 'Early Termination Fee' ;
    rdfs:comment 'Fee charged to subscribers who cancel before the end of the contract term. Null if no early termination fee applies. | Column early_termination_fee (DECIMAL(12,2)) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicAvailability rdf:type rdf:Property ;
    rdfs:label 'Geographic Availability' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this subscription plan is available for purchase (e.g., USA,CAN,GBR,AUS). Empty indicates global availability. | Column geographic_availability (STRING) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known unique business identifier for the subscription plan used in billing systems and customer communications. Managed in Zuora product catalog. | Column plan_code (STRING) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the subscription plan features, benefits, and included content for subscriber-facing materials and internal reference. | Column plan_description (STRING) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable marketing name of the subscription plan displayed to subscribers (e.g., Premium Plus, Family Bundle, Sports Add-On). | Column plan_name (STRING) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the subscription plan: active (available for new subscriptions), inactive (temporarily unavailable), deprecated (no longer offered but existing subscriptions continue), sunset (being phased out), coming soon (announced but not yet available). | Column plan_status (STRING) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Business model classification: SVOD (Subscription Video On Demand), AVOD (Advertising-Supported Video On Demand), TVOD (Transactional Video On Demand), FAST (Free Ad-Supported Streaming Television), hybrid, or add-on plan. | Column plan_type (STRING) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalPlan rdf:type rdf:Property ;
    rdfs:label 'Promotional Plan' ;
    rdfs:comment 'Indicates whether this is a limited-time promotional subscription plan offered at a special price or with enhanced features. | Column promotional_plan (BOOLEAN) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetArpu rdf:type rdf:Property ;
    rdfs:label 'Target Arpu' ;
    rdfs:comment 'Target average revenue per user (ARPU) metric for financial planning and performance tracking of this subscription plan. | Column target_arpu (DECIMAL(12,2)) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLtv rdf:type rdf:Property ;
    rdfs:label 'Target Ltv' ;
    rdfs:comment 'Target lifetime value (LTV) metric representing the projected total revenue from a subscriber over the duration of their subscription to this plan. | Column target_ltv (DECIMAL(12,2)) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trialDurationDays rdf:type rdf:Property ;
    rdfs:label 'Trial Duration Days' ;
    rdfs:comment 'Number of days for the free trial period if trial_eligible is true. Null if no trial is offered. | Column trial_duration_days (INT) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trialEligible rdf:type rdf:Property ;
    rdfs:label 'Trial Eligible' ;
    rdfs:comment 'Indicates whether this subscription plan is eligible for a free trial period for new subscribers. | Column trial_eligible (BOOLEAN) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:videoQualityMax rdf:type rdf:Property ;
    rdfs:label 'Video Quality Max' ;
    rdfs:comment 'Maximum video resolution quality available under this subscription plan (e.g., SD, HD, Full HD, 4K, 8K). | Column video_quality_max (STRING) in subscriber.subscription_plan' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'Marketing channel or source through which the subscriber acquired this subscription (e.g., web, mobile app, partner referral, promotional campaign). | Column acquisition_channel (STRING) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when the subscription was activated and service delivery began. May differ from enrollment date if there was a pending period. | Column activation_date (DATE) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether the subscription will automatically renew at the end of the current term. True = auto-renew enabled, False = manual renewal required. | Column auto_renew_flag (BOOLEAN) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRateAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rate Amount' ;
    rdfs:comment 'The standard subscription rate amount per billing cycle, in the billing currency, before any discounts or promotions. | Column base_rate_amount (DECIMAL(15,2)) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date when the subscription was cancelled by the subscriber or system. Null for active subscriptions. | Column cancellation_date (DATE) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationInitiatedBy rdf:type rdf:Property ;
    rdfs:label 'Cancellation Initiated By' ;
    rdfs:comment 'Entity that initiated the cancellation: subscriber (voluntary), system (automated), admin (manual intervention), payment_failure (billing issue), fraud_detection (security). Null for active subscriptions. | Column cancellation_initiated_by (STRING) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Primary reason for subscription cancellation, used for churn analysis and retention strategy. Null for active subscriptions. [ENUM-REF-CANDIDATE: voluntary|payment_failure|fraud|service_quality|price|content_selection|technical_issues — 7 candidates stripped; promote to reference product] | Column cancellation_reason (STRING) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentTermEndDate rdf:type rdf:Property ;
    rdfs:label 'Current Term End Date' ;
    rdfs:comment 'End date of the current billing term or subscription period. Represents the next renewal or expiration date. | Column current_term_end_date (DATE) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentTermStartDate rdf:type rdf:Property ;
    rdfs:label 'Current Term Start Date' ;
    rdfs:comment 'Start date of the current billing term or subscription period. | Column current_term_start_date (DATE) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date when the subscriber first enrolled in this subscription plan. Represents the start of the contractual relationship. | Column enrollment_date (DATE) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gracePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Grace Period End Date' ;
    rdfs:comment 'Date when the grace period ends after a payment failure or cancellation, after which access is fully revoked. Null if no grace period applies. | Column grace_period_end_date (DATE) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotional End Date' ;
    rdfs:comment 'Date when the promotional rate expires and standard pricing resumes. Null if no promotion is active. | Column promotional_end_date (DATE) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalRateAmount rdf:type rdf:Property ;
    rdfs:label 'Promotional Rate Amount' ;
    rdfs:comment 'The discounted subscription rate amount during the promotional period, in the billing currency. Null if no promotion is active. | Column promotional_rate_amount (DECIMAL(15,2)) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalRateFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Rate Flag' ;
    rdfs:comment 'Indicates whether the subscription is currently on a promotional or discounted rate. True = promotional pricing active, False = standard pricing. | Column promotional_rate_flag (BOOLEAN) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Date when the subscription is scheduled to renew for the next billing cycle. | Column renewal_date (DATE) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Subscription Number' ;
    rdfs:comment 'Human-readable business identifier for the subscription, displayed to subscribers and customer service representatives. | Column subscription_number (STRING) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Status' ;
    rdfs:comment 'Current lifecycle state of the subscription: active (in service), suspended (temporarily paused), cancelled (terminated by subscriber or system), expired (end date reached), trialing (in trial period), pending (awaiting activation). | Column subscription_status (STRING) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionType rdf:type rdf:Property ;
    rdfs:label 'Subscription Type' ;
    rdfs:comment 'Classification of subscription model: SVOD (Subscription Video On Demand), AVOD (Advertising-Supported Video On Demand), TVOD (Transactional Video On Demand), bundle, premium add-on, or trial. | Column subscription_type (STRING) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Free-text explanation for why the subscription was suspended (e.g., payment failure, subscriber request, fraud investigation). Null for non-suspended subscriptions. | Column suspension_reason (STRING) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date when the subscription service was fully terminated and access was revoked. May differ from cancellation date if there is a grace period. | Column termination_date (DATE) in subscriber.subscription' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialEndDate rdf:type rdf:Property ;
    rdfs:label 'Trial End Date' ;
    rdfs:comment 'Date when the trial period ends and billing begins, if applicable. Null for non-trial subscriptions. | Column trial_end_date (DATE) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialStartDate rdf:type rdf:Property ;
    rdfs:label 'Trial Start Date' ;
    rdfs:comment 'Date when the trial period began, if applicable. Null for non-trial subscriptions. | Column trial_start_date (DATE) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:zuoraSubscriptionReference rdf:type rdf:Property ;
    rdfs:label 'Zuora Subscription Reference' ;
    rdfs:comment 'External subscription identifier from Zuora billing system for revenue recognition and invoicing integration. | Column zuora_subscription_reference (STRING) in subscriber.subscription' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adTrackingConsent rdf:type rdf:Property ;
    rdfs:label 'Ad Tracking Consent' ;
    rdfs:comment 'Indicates whether the user has consented to advertising tracking on this device. Required for GDPR and CCPA compliance. | Column ad_tracking_consent (BOOLEAN) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:advertisingDeviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Advertising Device Identifier' ;
    rdfs:comment 'Device advertising identifier (IDFA for iOS, AAID for Android). Used for targeted advertising and attribution tracking. Subject to user consent per GDPR and CCPA. | Column advertising_device_identifier (STRING) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioCodecSupport rdf:type rdf:Property ;
    rdfs:label 'Audio Codec Support' ;
    rdfs:comment 'Comma-separated list of audio codecs supported by the device (e.g., AAC, Dolby Digital, Dolby Atmos, DTS). Determines audio track selection. | Column audio_codec_support (STRING) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deregistrationReason rdf:type rdf:Property ;
    rdfs:label 'Deregistration Reason' ;
    rdfs:comment 'Reason why the device was deregistered. Used for churn analysis and fraud investigation. [ENUM-REF-CANDIDATE: user_initiated|account_closure|fraud_detected|device_limit_exceeded|inactivity|admin_action|device_lost_stolen — 7 candidates stripped; promote to reference product] | Column deregistration_reason (STRING) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deregistrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deregistration Timestamp' ;
    rdfs:comment 'Date and time when the device was deregistered or removed from the subscriber account. Null if device is still registered. | Column deregistration_timestamp (TIMESTAMP) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviceFingerprint rdf:type rdf:Property ;
    rdfs:label 'Device Fingerprint' ;
    rdfs:comment 'Unique cryptographic hash or identifier that uniquely identifies the physical device. Used for device authentication and fraud prevention. | Column device_fingerprint (STRING) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceLimitEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Device Limit Enforcement Flag' ;
    rdfs:comment 'Indicates whether this device counts toward the subscribers per-account device limit. Used to exempt customer service test devices or promotional devices. | Column device_limit_enforcement_flag (BOOLEAN) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceNickname rdf:type rdf:Property ;
    rdfs:label 'Device Nickname' ;
    rdfs:comment 'User-assigned friendly name for the device (e.g., Living Room TV, Johns iPhone). Improves device management user experience. | Column device_nickname (STRING) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Drm Certificate Reference' ;
    rdfs:comment 'Reference to the DRM device certificate used for secure content decryption. Required for protected content playback. | Column drm_certificate_reference (STRING) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmSecurityLevel rdf:type rdf:Property ;
    rdfs:label 'Drm Security Level' ;
    rdfs:comment 'Security level of the DRM implementation on the device. Determines maximum content quality and protection level (e.g., Widevine L1 for HD, L3 for SD). | Column drm_security_level (STRING) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Calculated fraud risk score for this device registration (0.00 to 100.00). Higher scores indicate higher likelihood of fraudulent activity. | Column fraud_score (DECIMAL(5,2)) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicLocation rdf:type rdf:Property ;
    rdfs:label 'Geographic Location' ;
    rdfs:comment 'Geographic location derived from IP address or device GPS (country, region, city). Used for content windowing and blackout restrictions. | Column geographic_location (STRING) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdrSupport rdf:type rdf:Property ;
    rdfs:label 'Hdr Support' ;
    rdfs:comment 'Indicates whether the device supports HDR video playback (HDR10, Dolby Vision, HLG). Enables premium content delivery. | Column hdr_support (BOOLEAN) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address from which the device was registered. Used for geolocation, fraud detection, and blackout enforcement. | Column ip_address (STRING) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Active Timestamp' ;
    rdfs:comment 'Date and time of the most recent authenticated activity from this device. Used to identify inactive devices and enforce inactivity policies. | Column last_active_timestamp (TIMESTAMP) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxDownloadCount rdf:type rdf:Property ;
    rdfs:label 'Max Download Count' ;
    rdfs:comment 'Maximum number of titles that can be downloaded for offline viewing on this device. Enforced per subscription plan terms. | Column max_download_count (INT) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxResolutionSupported rdf:type rdf:Property ;
    rdfs:label 'Max Resolution Supported' ;
    rdfs:comment 'Highest video resolution the device can decode and display. Used for adaptive bitrate streaming (ABR) profile selection. | Column max_resolution_supported (STRING) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offlineDownloadEnabled rdf:type rdf:Property ;
    rdfs:label 'Offline Download Enabled' ;
    rdfs:comment 'Indicates whether this device is authorized for offline content downloads. Subject to plan entitlements and DRM restrictions. | Column offline_download_enabled (BOOLEAN) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalControlPinHash rdf:type rdf:Property ;
    rdfs:label 'Parental Control Pin Hash' ;
    rdfs:comment 'Cryptographic hash of the parental control PIN. Used to authenticate access to restricted content without storing the PIN in plaintext. | Column parental_control_pin_hash (STRING) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationToken rdf:type rdf:Property ;
    rdfs:label 'Push Notification Token' ;
    rdfs:comment 'Device-specific token for sending push notifications (APNS for iOS, FCM for Android). Used for engagement campaigns and service alerts. | Column push_notification_token (STRING) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the device registration. Determines whether the device is authorized for playback. | Column registration_status (STRING) in subscriber.device_registration' ;
    rdfs:domain ind:DeviceRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementId rdf:type rdf:Property ;
    rdfs:label 'Entitlement Id' ;
    rdfs:comment 'Unique identifier for the entitlement record. Primary key. | Column entitlement_id (BIGINT) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelPackageId rdf:type rdf:Property ;
    rdfs:label 'Channel Package Id' ;
    rdfs:comment 'Reference to the channel package or bundle that this entitlement provides access to. | Column channel_package_id (BIGINT) in content.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:accessLevel rdf:type rdf:Property ;
    rdfs:label 'Access Level' ;
    rdfs:comment 'Degree of access granted by this entitlement: full (complete access), preview (sample or trailer only), limited (restricted features or duration), or premium (enhanced quality or early access). | Column access_level (STRING) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adFree rdf:type rdf:Property ;
    rdfs:label 'Ad Free' ;
    rdfs:comment 'Indicates whether this entitlement provides ad-free viewing experience. False indicates AVOD (Advertising-Supported Video On Demand) model applies. | Column ad_free (BOOLEAN) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationCount rdf:type rdf:Property ;
    rdfs:label 'Authorization Count' ;
    rdfs:comment 'Total number of playback authorization requests processed for this entitlement since activation. | Column authorization_count (INT) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenew rdf:type rdf:Property ;
    rdfs:label 'Auto Renew' ;
    rdfs:comment 'Indicates whether this entitlement will automatically renew upon expiration based on the underlying subscription plan. | Column auto_renew (BOOLEAN) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutExempt rdf:type rdf:Property ;
    rdfs:label 'Blackout Exempt' ;
    rdfs:comment 'Indicates whether this entitlement is exempt from geographic blackout restrictions typically applied to live sports or regional content. | Column blackout_exempt (BOOLEAN) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFlags rdf:type rdf:Property ;
    rdfs:label 'Compliance Flags' ;
    rdfs:comment 'Comma-separated list of compliance requirements applicable to this entitlement (e.g., \'GDPR\', \'CCPA\', \'COPPA\'). Used to enforce data privacy and regulatory obligations. | Column compliance_flags (STRING) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceLimit rdf:type rdf:Property ;
    rdfs:label 'Device Limit' ;
    rdfs:comment 'Maximum number of concurrent devices that can use this entitlement. Null indicates no device limit. | Column device_limit (INT) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyAccessEnabled rdf:type rdf:Property ;
    rdfs:label 'Early Access Enabled' ;
    rdfs:comment 'Indicates whether this entitlement grants early access to content before general release. | Column early_access_enabled (BOOLEAN) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementStatus rdf:type rdf:Property ;
    rdfs:label 'Entitlement Status' ;
    rdfs:comment 'Current lifecycle status of the entitlement: active (currently valid), suspended (temporarily disabled), expired (past end date), revoked (administratively cancelled), or pending (awaiting activation). | Column entitlement_status (STRING) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementType rdf:type rdf:Property ;
    rdfs:label 'Entitlement Type' ;
    rdfs:comment 'Classification of the entitlement based on how it was granted: subscription (standard plan), promotional (marketing grant), bundle (package deal), addon (premium add-on), mvpd_carriage (Multichannel Video Programming Distributor carriage agreement), or trial (free trial period). | Column entitlement_type (STRING) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalEntitlementReference rdf:type rdf:Property ;
    rdfs:label 'External Entitlement Reference' ;
    rdfs:comment 'Unique identifier for this entitlement in the originating external system (e.g., Zuora subscription ID, MVPD authorization token). | Column external_entitlement_reference (STRING) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this entitlement is valid. Empty indicates no geographic restriction. | Column geographic_restriction (STRING) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantReason rdf:type rdf:Property ;
    rdfs:label 'Grant Reason' ;
    rdfs:comment 'Business justification or reason code for why this entitlement was granted (e.g., \'Annual Subscription\', \'Promotional Campaign Q4-2024\', \'Customer Retention Offer\', \'MVPD Carriage Agreement\'). | Column grant_reason (STRING) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuthorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Authorization Timestamp' ;
    rdfs:comment 'Timestamp of the most recent playback authorization request that validated this entitlement at the CDN/DRM layer. | Column last_authorization_timestamp (TIMESTAMP) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parentalControlLevel rdf:type rdf:Property ;
    rdfs:label 'Parental Control Level' ;
    rdfs:comment 'Maximum content rating level accessible under this entitlement based on parental control settings. Follows Motion Picture Association (MPA) and TV Parental Guidelines ratings. [ENUM-REF-CANDIDATE: none|g|pg|pg13|r|nc17|tv_y|tv_y7|tv_g|tv_pg|tv_14|tv_ma — 12 candidates stripped; promote to reference product] | Column parental_control_level (STRING) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityTier rdf:type rdf:Property ;
    rdfs:label 'Quality Tier' ;
    rdfs:comment 'Maximum video quality level allowed by this entitlement: sd (standard definition), hd (high definition 1080p), 4k (ultra high definition), or 8k (8K resolution). | Column quality_tier (STRING) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Reason why the entitlement was revoked or suspended, if applicable (e.g., \'Payment Failure\', \'Terms of Service Violation\', \'Subscriber Request\', \'Rights Expiration\'). | Column revocation_reason (STRING) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revokedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Revoked Timestamp' ;
    rdfs:comment 'Timestamp when the entitlement was permanently revoked, if applicable. | Column revoked_timestamp (TIMESTAMP) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:suspendedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Suspended Timestamp' ;
    rdfs:comment 'Timestamp when the entitlement was suspended, if applicable. | Column suspended_timestamp (TIMESTAMP) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trialEntitlement rdf:type rdf:Property ;
    rdfs:label 'Trial Entitlement' ;
    rdfs:comment 'Indicates whether this is a trial entitlement granted as part of a free trial period. | Column trial_entitlement (BOOLEAN) in subscriber.entitlement' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:viewerProfileId rdf:type rdf:Property ;
    rdfs:label 'Viewer Profile Id' ;
    rdfs:comment 'Unique identifier for the viewer profile within a subscriber account or household. Primary key. | Column viewer_profile_id (BIGINT) in subscriber.viewer_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ViewerProfile .

ind:favoriteGenreId rdf:type rdf:Property ;
    rdfs:label 'Favorite Genre Id' ;
    rdfs:comment 'Foreign key linking to content.genre. Business justification: Personalization and recommendation engines require explicit genre preferences. Drives content discovery, homepage curation, and email marketing. Complements behavioral signals with declared preference | Column favorite_genre_id (BIGINT) in content.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Genre .

ind:aepSegmentIds rdf:type rdf:Property ;
    rdfs:label 'Aep Segment Ids' ;
    rdfs:comment 'Comma-separated list of Adobe Experience Platform segment IDs that this viewer profile belongs to. Used for personalized content recommendations, targeted advertising, and dynamic user experience customization. | Column aep_segment_ids (STRING) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoplayEnabled rdf:type rdf:Property ;
    rdfs:label 'Autoplay Enabled' ;
    rdfs:comment 'Boolean flag indicating whether autoplay of next episode or content is enabled for this profile. True enables automatic playback; false requires manual selection. | Column autoplay_enabled (BOOLEAN) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoplayPreviewsEnabled rdf:type rdf:Property ;
    rdfs:label 'Autoplay Previews Enabled' ;
    rdfs:comment 'Boolean flag indicating whether automatic preview playback is enabled when browsing content. True enables preview autoplay; false disables previews. | Column autoplay_previews_enabled (BOOLEAN) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:avatarUrl rdf:type rdf:Property ;
    rdfs:label 'Avatar Url' ;
    rdfs:comment 'URL reference to the profile avatar image stored in the Media Asset Management (MAM) system or Content Delivery Network (CDN). Used for visual identification in profile selection interfaces. | Column avatar_url (STRING) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSaverMode rdf:type rdf:Property ;
    rdfs:label 'Data Saver Mode' ;
    rdfs:comment 'Boolean flag indicating whether data saver mode is enabled to reduce bandwidth consumption. True limits video quality and disables high-bandwidth features; false allows full quality streaming. | Column data_saver_mode (BOOLEAN) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genrePreferences rdf:type rdf:Property ;
    rdfs:label 'Genre Preferences' ;
    rdfs:comment 'Comma-separated list of preferred content genre identifiers for personalization and recommendation algorithms. Derived from viewing history and explicit user selections. Used by Adobe Experience Platform for segment targeting. | Column genre_preferences (STRING) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultProfile rdf:type rdf:Property ;
    rdfs:label 'Is Default Profile' ;
    rdfs:comment 'Boolean flag indicating whether this is the default profile that is automatically selected when the subscriber logs in. True for default profile; false for secondary profiles. Only one profile per subscriber should be marked as default. | Column is_default_profile (BOOLEAN) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKidsProfile rdf:type rdf:Property ;
    rdfs:label 'Is Kids Profile' ;
    rdfs:comment 'Boolean flag indicating whether this is a dedicated kids profile with enhanced parental controls, age-appropriate content filtering, and COPPA (Children\'s Online Privacy Protection Act) compliance enforcement. True for kids profiles; false for adult/general profiles. | Column is_kids_profile (BOOLEAN) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingConsent rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent' ;
    rdfs:comment 'Boolean flag indicating whether the viewer profile has consented to receive marketing communications and promotional content. True allows marketing; false opts out. Required for GDPR (General Data Protection Regulation) and CCPA (California Consumer Privacy Act) compliance. | Column marketing_consent (BOOLEAN) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxDownloads rdf:type rdf:Property ;
    rdfs:label 'Max Downloads' ;
    rdfs:comment 'Maximum number of content titles that can be downloaded for offline viewing on this profile. Enforces subscription tier limits and storage management policies. | Column max_downloads (INT) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personalizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Personalization Enabled' ;
    rdfs:comment 'Boolean flag indicating whether personalized content recommendations and user experience customization are enabled for this profile. True enables Adobe Experience Platform personalization; false provides generic content discovery. Impacts GDPR (General Data Protection Regulation) and CCPA (California Consumer Privacy Act) consent requirements. | Column personalization_enabled (BOOLEAN) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pinCodeHash rdf:type rdf:Property ;
    rdfs:label 'Pin Code Hash' ;
    rdfs:comment 'Hashed PIN code for profile access control and parental lock enforcement. Used to restrict access to mature content or prevent unauthorized profile switching. Stored as cryptographic hash for security. | Column pin_code_hash (STRING) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinEnabled rdf:type rdf:Property ;
    rdfs:label 'Pin Enabled' ;
    rdfs:comment 'Boolean flag indicating whether PIN protection is enabled for this profile. True requires PIN entry for profile access; false allows unrestricted access. | Column pin_enabled (BOOLEAN) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable display name for the viewer profile (e.g., \'Dad\', \'Kids\', \'Guest\'). Used for profile selection and personalization. | Column profile_name (STRING) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileSortOrder rdf:type rdf:Property ;
    rdfs:label 'Profile Sort Order' ;
    rdfs:comment 'Integer value determining the display order of this profile in the profile selection interface. Lower values appear first. Used for user experience optimization. | Column profile_sort_order (INT) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle state of the viewer profile. Active profiles can access content; inactive profiles are temporarily disabled; suspended profiles are blocked due to policy violations; deleted profiles are soft-deleted and retained for compliance. | Column profile_status (STRING) in subscriber.viewer_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileType rdf:type rdf:Property ;
    rdfs:label 'Profile Type' ;
    rdfs:comment 'Classification of the viewer profile within the household. Primary profiles have full account privileges; secondary profiles may have restricted access; kids profiles enforce parental controls; guest profiles are temporary. | Column profile_type (STRING) in subscriber.viewer_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitlePreference rdf:type rdf:Property ;
    rdfs:label 'Subtitle Preference' ;
    rdfs:comment 'Default subtitle display preference for this viewer profile. Off disables subtitles; on always displays subtitles; auto displays subtitles based on content language and user language mismatch. | Column subtitle_preference (STRING) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoQualityPreference rdf:type rdf:Property ;
    rdfs:label 'Video Quality Preference' ;
    rdfs:comment 'Preferred video streaming quality for this profile. Auto uses Adaptive Bitrate Streaming (ABR) based on bandwidth; low/medium/high/ultra_hd enforce specific quality tiers. Impacts Content Delivery Network (CDN) delivery and bandwidth consumption. | Column video_quality_preference (STRING) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewingHistoryEnabled rdf:type rdf:Property ;
    rdfs:label 'Viewing History Enabled' ;
    rdfs:comment 'Boolean flag indicating whether viewing history is tracked and stored for this profile. True enables history tracking for recommendations and resume playback; false disables tracking for privacy. Impacts GDPR (General Data Protection Regulation) and CCPA (California Consumer Privacy Act) compliance. | Column viewing_history_enabled (BOOLEAN) in subscriber.viewer_profile' ;
    rdfs:domain ind:ViewerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:churnEventId rdf:type rdf:Property ;
    rdfs:label 'Churn Event Id' ;
    rdfs:comment 'Unique identifier for the subscriber churn event record. | Column churn_event_id (BIGINT) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastViewedTitleId rdf:type rdf:Property ;
    rdfs:label 'Last Viewed Title Id' ;
    rdfs:comment 'Foreign key linking to content.title. Business justification: Churn analysis tracks last content engagement to identify content gaps and inform win-back campaigns. Critical for retention analytics, content investment decisions, and personalized re-engagement off | Column last_viewed_title_id (BIGINT) in content.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:autoRenewDisabledDate rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Disabled Date' ;
    rdfs:comment 'The date when the subscriber disabled auto-renewal for their subscription. Null if auto-renewal was never disabled. Used to identify planned churn versus reactive churn. | Column auto_renew_disabled_date (DATE) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationChannel rdf:type rdf:Property ;
    rdfs:label 'Cancellation Channel' ;
    rdfs:comment 'The interface or channel through which the cancellation was initiated. Supports analysis of churn patterns by customer touchpoint. [ENUM-REF-CANDIDATE: web_self_service|mobile_app|customer_care|email|chat|ivr|mvpd_drop|system_automated — 8 candidates stripped; promote to reference product] | Column cancellation_channel (STRING) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Standardized code representing the stated reason for cancellation. Used for churn analytics and product improvement initiatives. Empty value_regex indicates reference to external reason code lookup table with more than 6 values. | Column cancellation_reason_code (STRING) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Description' ;
    rdfs:comment 'Free-text description or additional details provided by the subscriber explaining the reason for cancellation. Supports qualitative churn analysis. | Column cancellation_reason_description (STRING) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:churnPredictionScore rdf:type rdf:Property ;
    rdfs:label 'Churn Prediction Score' ;
    rdfs:comment 'The machine learning model-generated churn risk score that was assigned to the subscriber prior to the churn event. Range 0.0000 to 1.0000, where higher values indicate higher churn risk. Used for model validation and predictive accuracy assessment. | Column churn_prediction_score (DECIMAL(5,4)) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:churnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Churn Timestamp' ;
    rdfs:comment 'The exact date and time when the subscriber cancellation or lapse event occurred. This is the business event timestamp representing when the subscriber relationship ended. | Column churn_timestamp (TIMESTAMP) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:churnType rdf:type rdf:Property ;
    rdfs:label 'Churn Type' ;
    rdfs:comment 'Classification of the churn event based on the nature of cancellation. Voluntary indicates subscriber-initiated cancellation, involuntary indicates business-initiated termination, payment failure indicates cancellation due to billing issues. | Column churn_type (STRING) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorServiceMentionedFlag rdf:type rdf:Property ;
    rdfs:label 'Competitor Service Mentioned Flag' ;
    rdfs:comment 'Boolean indicator of whether the subscriber mentioned switching to a competitor service during the cancellation process. Used for competitive intelligence and market positioning analysis. | Column competitor_service_mentioned_flag (BOOLEAN) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerCareContactCount rdf:type rdf:Property ;
    rdfs:label 'Customer Care Contact Count' ;
    rdfs:comment 'The number of customer care interactions the subscriber had in the 30 days prior to churn. Used to identify service quality issues and early warning signals. | Column customer_care_contact_count (INT) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysSinceLastViewing rdf:type rdf:Property ;
    rdfs:label 'Days Since Last Viewing' ;
    rdfs:comment 'The number of days between the last viewing activity and the churn event. Used for engagement-based churn prediction models. | Column days_since_last_viewing (INT) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceCountAtChurn rdf:type rdf:Property ;
    rdfs:label 'Device Count At Churn' ;
    rdfs:comment 'The number of registered devices associated with the subscriber at the time of churn. Used for multi-device engagement analysis. | Column device_count_at_churn (INT) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalAccessDate rdf:type rdf:Property ;
    rdfs:label 'Final Access Date' ;
    rdfs:comment 'The last date the subscriber had active access to content and services. May differ from churn_timestamp due to grace periods or paid-through dates. | Column final_access_date (DATE) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprDataDeletionRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Deletion Requested Flag' ;
    rdfs:comment 'Boolean indicator of whether the subscriber requested deletion of their personal data under GDPR right to erasure at the time of churn. Used for privacy compliance tracking. | Column gdpr_data_deletion_requested_flag (BOOLEAN) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'The monetary value of the last successful payment received from the subscriber before churn. Used for ARPU (Average Revenue Per User) and revenue impact analysis. | Column last_payment_amount (DECIMAL(15,2)) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastViewingDate rdf:type rdf:Property ;
    rdfs:label 'Last Viewing Date' ;
    rdfs:comment 'The date of the subscribers last content viewing activity before churn. Used to identify engagement drop-off patterns and at-risk subscriber signals. | Column last_viewing_date (DATE) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentalControlEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Control Enabled Flag' ;
    rdfs:comment 'Boolean indicator of whether parental controls were enabled on the subscription at the time of churn. Used for family-oriented subscriber segmentation and churn analysis. | Column parental_control_enabled_flag (BOOLEAN) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentFailureCount rdf:type rdf:Property ;
    rdfs:label 'Payment Failure Count' ;
    rdfs:comment 'The number of consecutive payment failures that occurred before the churn event. Used to identify involuntary churn patterns and dunning effectiveness. | Column payment_failure_count (INT) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalDiscountActiveFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Discount Active Flag' ;
    rdfs:comment 'Boolean indicator of whether the subscriber had an active promotional discount at the time of churn. Used to analyze price sensitivity and promotional effectiveness. | Column promotional_discount_active_flag (BOOLEAN) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reactivationEligibilityDate rdf:type rdf:Property ;
    rdfs:label 'Reactivation Eligibility Date' ;
    rdfs:comment 'The date when the churned subscriber becomes eligible for reactivation campaigns or promotional offers. Used for win-back campaign targeting and timing. | Column reactivation_eligibility_date (DATE) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionTenureMonths rdf:type rdf:Property ;
    rdfs:label 'Subscription Tenure Months' ;
    rdfs:comment 'The total number of months the subscriber maintained an active subscription before churning. Used for cohort analysis and LTV (Lifetime Value) calculations. | Column subscription_tenure_months (INT) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLifetimeRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Lifetime Revenue' ;
    rdfs:comment 'The cumulative revenue generated from this subscriber across their entire subscription tenure. Used for LTV (Lifetime Value) analysis and churn impact assessment. | Column total_lifetime_revenue (DECIMAL(15,2)) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:winBackOfferAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Win Back Offer Accepted Flag' ;
    rdfs:comment 'Boolean indicator of whether the subscriber accepted the win-back offer. True indicates acceptance and retention, False indicates rejection and churn completion. Null if no offer was presented. | Column win_back_offer_accepted_flag (BOOLEAN) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:winBackOfferPresentedFlag rdf:type rdf:Property ;
    rdfs:label 'Win Back Offer Presented Flag' ;
    rdfs:comment 'Boolean indicator of whether a retention or win-back offer was presented to the subscriber during the cancellation process. True indicates an offer was made, False indicates no offer was presented. | Column win_back_offer_presented_flag (BOOLEAN) in subscriber.churn_event' ;
    rdfs:domain ind:ChurnEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Payment Instrument Id' ;
    rdfs:comment 'Unique identifier for the payment instrument record. Primary key. | Column payment_instrument_id (BIGINT) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankAccountType rdf:type rdf:Property ;
    rdfs:label 'Bank Account Type' ;
    rdfs:comment 'Type of bank account for direct debit or ACH payment methods. Null for card-based payment methods. | Column bank_account_type (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the billing address associated with the payment instrument. Used for address verification and fraud prevention. | Column billing_address_line1 (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of the billing address (apartment, suite, unit number). Optional field for additional address details. | Column billing_address_line2 (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City of the billing address associated with the payment instrument. | Column billing_city (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the billing address (e.g., USA, GBR, CAN). | Column billing_country_code (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the billing address. Used for address verification service (AVS) fraud checks. | Column billing_postal_code (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province of the billing address. Format varies by country (e.g., two-letter state code for USA). | Column billing_state_province (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardBrand rdf:type rdf:Property ;
    rdfs:label 'Card Brand' ;
    rdfs:comment 'The brand of the credit or debit card (Visa, Mastercard, American Express, Discover, JCB, Diners Club). Null for non-card payment methods. | Column card_brand (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'Name of the cardholder as it appears on the payment instrument. Required for card-based payment methods. | Column cardholder_name (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'Reason why the payment instrument was deactivated. Used for churn analysis and payment method lifecycle management. | Column deactivation_reason (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryMonth rdf:type rdf:Property ;
    rdfs:label 'Expiry Month' ;
    rdfs:comment 'The month (1-12) when the payment instrument expires. Used for card expiration validation and renewal reminders. | Column expiry_month (INT) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryYear rdf:type rdf:Property ;
    rdfs:label 'Expiry Year' ;
    rdfs:comment 'The four-digit year when the payment instrument expires. Used for card expiration validation and renewal reminders. | Column expiry_year (INT) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failedTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Failed Transaction Count' ;
    rdfs:comment 'Cumulative count of failed transaction attempts using this payment instrument. Used for fraud detection and payment method health monitoring. | Column failed_transaction_count (INT) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gatewayReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Gateway Reference Code' ;
    rdfs:comment 'External reference identifier assigned by the payment gateway for this payment instrument. Used for gateway-specific operations and reconciliation. | Column gateway_reference_code (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftCardBalance rdf:type rdf:Property ;
    rdfs:label 'Gift Card Balance' ;
    rdfs:comment 'Remaining balance on the gift card or prepaid card. Updated after each transaction. Null for non-gift-card payment methods. | Column gift_card_balance (DECIMAL(10,2)) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftCardCode rdf:type rdf:Property ;
    rdfs:label 'Gift Card Code' ;
    rdfs:comment 'Masked gift card or prepaid card code. Full code is tokenized per PCI DSS requirements. | Column gift_card_code (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Flag indicating whether this is the default payment instrument for the subscriber. Used for automatic billing and subscription renewals. | Column is_default (BOOLEAN) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'Date of the most recent successful transaction using this payment instrument. Used for activity tracking and dormancy detection. | Column last_transaction_date (DATE) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandateAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Mandate Acceptance Date' ;
    rdfs:comment 'Date when the subscriber accepted the direct debit mandate. Required for regulatory compliance and dispute resolution. | Column mandate_acceptance_date (DATE) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandateReference rdf:type rdf:Property ;
    rdfs:label 'Mandate Reference' ;
    rdfs:comment 'Unique identifier for the direct debit mandate or authorization. Required for SEPA and other direct debit payment methods to comply with banking regulations. | Column mandate_reference (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskedAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Masked Account Number' ;
    rdfs:comment 'Masked representation of the card or account number showing only the last 4 digits (e.g., ****1234). Full number is tokenized and stored securely per PCI DSS requirements. | Column masked_account_number (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentGateway rdf:type rdf:Property ;
    rdfs:label 'Payment Gateway' ;
    rdfs:comment 'Name of the payment gateway or processor used for this payment instrument (e.g., Stripe, Braintree, Authorize.Net, Zuora Gateway). | Column payment_gateway (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentInstrumentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Instrument Status' ;
    rdfs:comment 'Current lifecycle status of the payment instrument. Active instruments can be charged; expired or suspended instruments require update or replacement. | Column payment_instrument_status (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentToken rdf:type rdf:Property ;
    rdfs:label 'Payment Token' ;
    rdfs:comment 'PCI DSS compliant tokenization reference for the actual payment instrument details. Used to process transactions without exposing sensitive cardholder data. | Column payment_token (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paypalEmail rdf:type rdf:Property ;
    rdfs:label 'Paypal Email' ;
    rdfs:comment 'Email address associated with the PayPal account. Used for PayPal payment method identification and processing. | Column paypal_email (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paypalPayerReference rdf:type rdf:Property ;
    rdfs:label 'Paypal Payer Reference' ;
    rdfs:comment 'Unique PayPal payer identifier for the linked PayPal account. Used for PayPal billing agreement reference. | Column paypal_payer_reference (STRING) in subscriber.payment_instrument' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when the payment instrument was successfully verified. Used for compliance tracking and fraud prevention. | Column verification_date (DATE) in subscriber.payment_instrument' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:airDate rdf:type rdf:Property ;
    rdfs:label 'Air Date' ;
    rdfs:comment 'The calendar date on which the program episode aired on the specified channel and market. Used as the principal business event date for this measurement record. | Column air_date (DATE) in audience.nielsen_rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:airEndTime rdf:type rdf:Property ;
    rdfs:label 'Air End Time' ;
    rdfs:comment 'The precise date and time at which the program finished airing. Combined with air_start_time to derive program duration for audience measurement calculations. | Column air_end_time (TIMESTAMP) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:airStartTime rdf:type rdf:Property ;
    rdfs:label 'Air Start Time' ;
    rdfs:comment 'The precise date and time (including timezone offset) at which the program began airing. Used for exact scheduling alignment and daypart classification. | Column air_start_time (TIMESTAMP) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:audienceCompositionPct rdf:type rdf:Property ;
    rdfs:label 'Audience Composition Pct' ;
    rdfs:comment 'The percentage of the program\'s total audience represented by the primary target demographic (typically A18-49). Indicates how well the program indexes against its target audience and is used in ad sales proposals and programming strategy. | Column audience_composition_pct (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageAudience rdf:type rdf:Property ;
    rdfs:label 'Average Audience' ;
    rdfs:comment 'The average number of persons or households tuned to the program during an average minute of the telecast. Expressed in thousands (000s). AA is the primary audience volume metric used in GRP and CPM calculations for ad sales. | Column average_audience (DECIMAL(14,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumeAudience rdf:type rdf:Property ;
    rdfs:label 'Cume Audience' ;
    rdfs:comment 'The unduplicated number of different persons or households that tuned to the program for at least one minute across all airings within a defined period. Expressed in thousands (000s). Cume measures total reach and is critical for frequency management in ad campaign planning. | Column cume_audience (DECIMAL(14,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoA1849Rating rdf:type rdf:Property ;
    rdfs:label 'Demo A18 49 Rating' ;
    rdfs:comment 'The percentage of Adults aged 18-49 in the measured universe who were tuned to this program. A18-49 is the most commercially valuable and widely traded demographic in US television advertising, serving as the primary currency for primetime ad sales. | Column demo_a18_49_rating (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoA2554Rating rdf:type rdf:Property ;
    rdfs:label 'Demo A25 54 Rating' ;
    rdfs:comment 'The percentage of Adults aged 25-54 in the measured universe who were tuned to this program. A25-54 is a key secondary demographic used in news programming, cable networks, and certain advertiser categories. | Column demo_a25_54_rating (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoK211Rating rdf:type rdf:Property ;
    rdfs:label 'Demo K2 11 Rating' ;
    rdfs:comment 'The percentage of Children aged 2-11 in the measured universe who were tuned to this program. K2-11 is the primary demographic for children\'s programming and toy/food advertisers. Subject to COPPA compliance requirements for data handling. | Column demo_k2_11_rating (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoM1849Rating rdf:type rdf:Property ;
    rdfs:label 'Demo M18 49 Rating' ;
    rdfs:comment 'The percentage of Men aged 18-49 in the measured universe who were tuned to this program. M18-49 is a primary demographic for sports, automotive, and technology advertisers. | Column demo_m18_49_rating (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demoW1849Rating rdf:type rdf:Property ;
    rdfs:label 'Demo W18 49 Rating' ;
    rdfs:comment 'The percentage of Women aged 18-49 in the measured universe who were tuned to this program. W18-49 is a primary demographic for lifestyle, beauty, and household product advertisers. | Column demo_w18_49_rating (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'The average number of times a unique person or household was exposed to the program within the measurement period. Frequency = GRP / Reach. Used with reach for ad campaign effectiveness analysis and makegoods calculations. | Column frequency (DECIMAL(7,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grp rdf:type rdf:Property ;
    rdfs:label 'Grp' ;
    rdfs:comment 'The sum of all ratings delivered by an advertising schedule or program, representing total audience delivery without deduplication. GRP = Reach × Frequency. A fundamental currency metric in ad sales negotiations, upfront deals, and scatter market transactions. | Column grp (DECIMAL(10,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdRating rdf:type rdf:Property ;
    rdfs:label 'Household Rating' ;
    rdfs:comment 'The percentage of all television households in the measured universe that were tuned to this program during the measurement period. Expressed as a decimal percentage (e.g., 5.2 = 5.2%). The foundational Nielsen rating metric used for ad pricing and programming evaluation. | Column household_rating (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdShare rdf:type rdf:Property ;
    rdfs:label 'Household Share' ;
    rdfs:comment 'The percentage of households using television (HUT) that were tuned to this program. Share = (Program Audience / HUT) × 100. Measures competitive performance relative to active TV viewers at the same time. | Column household_share (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressions rdf:type rdf:Property ;
    rdfs:label 'Impressions' ;
    rdfs:comment 'The total number of person-level exposures to the program, calculated as average audience multiplied by the number of airings. Expressed in absolute numbers (not thousands). Impressions are the transactional currency for digital and cross-platform ad sales. | Column impressions (DECIMAL(18,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingested Timestamp' ;
    rdfs:comment 'The timestamp at which this Nielsen rating record was ingested into the Databricks Lakehouse Silver layer from the Nielsen Media Research Platform. Used for data freshness monitoring, SLA tracking, and audit trail. | Column ingested_timestamp (TIMESTAMP) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nielsenReportDate rdf:type rdf:Property ;
    rdfs:label 'Nielsen Report Date' ;
    rdfs:comment 'The date on which Nielsen Media Research officially published or delivered this rating record to the broadcaster. Distinguishes the measurement air date from the data delivery date, which is critical for tracking preliminary vs. final rating release cycles. | Column nielsen_report_date (DATE) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nielsenReportWeek rdf:type rdf:Property ;
    rdfs:label 'Nielsen Report Week' ;
    rdfs:comment 'The ISO 8601 week identifier (e.g., 2024-W23) of the Nielsen measurement week in which this rating was reported. Nielsen measurement weeks run Monday through Sunday. Used for weekly ratings aggregation and trend analysis. | Column nielsen_report_week (STRING) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putLevel rdf:type rdf:Property ;
    rdfs:label 'Put Level' ;
    rdfs:comment 'The percentage of all persons in the measured universe who were watching television during the measurement period. PUT is the denominator for persons share calculations and complements HUT for demographic audience analysis. | Column put_level (DECIMAL(7,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingStatus rdf:type rdf:Property ;
    rdfs:label 'Rating Status' ;
    rdfs:comment 'Lifecycle status of this Nielsen rating record indicating whether the data is preliminary (fast nationals), final, or has been revised. Ad sales and programming decisions must distinguish preliminary from final ratings. Preliminary ratings are typically released within 24 hours; final ratings follow within days. | Column rating_status (STRING) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reach rdf:type rdf:Property ;
    rdfs:label 'Reach' ;
    rdfs:comment 'The unduplicated number of unique persons or households exposed to the program at least once within the measurement period. Expressed in thousands (000s). Reach is a core metric for ad campaign planning and audience delivery reporting. | Column reach (DECIMAL(14,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The native record identifier assigned by the Nielsen Media Research Platform for this rating record. Preserved in the Silver layer for data lineage, reconciliation, and re-ingestion traceability back to the authoritative source system. | Column source_system_record_code (STRING) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeSpentViewingMin rdf:type rdf:Property ;
    rdfs:label 'Time Spent Viewing Min' ;
    rdfs:comment 'The average number of minutes that viewers in the measured audience spent watching the program. A key engagement metric used in programming decisions and content performance analysis. Expressed in minutes. | Column time_spent_viewing_min (DECIMAL(10,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAudience rdf:type rdf:Property ;
    rdfs:label 'Total Audience' ;
    rdfs:comment 'The total number of persons or households that tuned to the program for at least six consecutive minutes. Expressed in thousands (000s). TA provides a broader reach measure than AA and is used for program promotion and scheduling decisions. | Column total_audience (DECIMAL(14,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trp rdf:type rdf:Property ;
    rdfs:label 'Trp' ;
    rdfs:comment 'Rating points delivered specifically to a defined target demographic audience (e.g., Adults 18-49). TRP = (Target Audience Impressions / Target Universe) × 100. Used by advertisers to evaluate efficiency of reaching their specific target demographic. | Column trp (DECIMAL(10,4)) in audience.nielsen_rating' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:universeEstimateHh rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate Hh' ;
    rdfs:comment 'The total estimated number of television households in the measured market or national universe used as the denominator for household rating calculations. Expressed in thousands (000s). Nielsen updates universe estimates annually based on census data. | Column universe_estimate_hh (DECIMAL(14,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:universeEstimatePersons rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate Persons' ;
    rdfs:comment 'The total estimated number of persons in the measured market or national universe used as the denominator for persons rating calculations. Expressed in thousands (000s). Segmented by demographic group for TRP calculations. | Column universe_estimate_persons (DECIMAL(14,2)) in audience.nielsen_rating' ;
    rdfs:domain ind:NielsenRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adobeSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Adobe Segment Code' ;
    rdfs:comment 'The corresponding segment identifier in Adobe Experience Platform (AEP) for digital audience activation. Enables cross-system reconciliation between Nielsen linear audience measurement and AEP digital audience profiles for cross-platform campaign targeting and DAI (Dynamic Ad Insertion) on OTT/streaming platforms. | Column adobe_segment_code (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageRangeMax rdf:type rdf:Property ;
    rdfs:label 'Age Range Max' ;
    rdfs:comment 'Upper bound (inclusive) of the age range defining this demographic cell, expressed in years. For example, 49 for the A18-49 cell. A null value indicates an open-ended upper bound (e.g., Adults 55+). Null for non-age-based segments. | Column age_range_max (INT) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeMin rdf:type rdf:Property ;
    rdfs:label 'Age Range Min' ;
    rdfs:comment 'Lower bound (inclusive) of the age range defining this demographic cell, expressed in years. For example, 18 for the A18-49 cell. Null for non-age-based segments such as psychographic or income quintile segments. | Column age_range_min (INT) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpmIndex rdf:type rdf:Property ;
    rdfs:label 'Cpm Index' ;
    rdfs:comment 'Relative CPM (Cost Per Mille) pricing index for this demographic segment compared to the baseline segment (index = 100). Premium segments such as A18-49 or W25-54 carry higher indices reflecting advertiser demand. Used in Salesforce Media Cloud ad sales proposals and upfront/scatter market pricing negotiations. Confidential commercial pricing data. | Column cpm_index (DECIMAL(10,4)) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daypartRelevance rdf:type rdf:Property ;
    rdfs:label 'Daypart Relevance' ;
    rdfs:comment 'Comma-separated list of broadcast dayparts (e.g., \'Prime Time, Late Fringe, Daytime\') for which this demographic segment has primary relevance in programming and ad sales strategy. Informs Ericsson MediaFirst scheduling decisions and Wide Orbit daypart-based ad pod targeting. Null if the segment applies across all dayparts. | Column daypart_relevance (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethnicityClassification rdf:type rdf:Property ;
    rdfs:label 'Ethnicity Classification' ;
    rdfs:comment 'Standardized ethnicity classification label for ethnicity-based demographic segments (e.g., \'Hispanic/Latino\', \'African American\', \'Asian American\', \'Non-Hispanic White\'). Populated only for ethnicity segment types. Aligned with Nielsen multicultural audience measurement standards and used in targeted content programming and ad sales. [ENUM-REF-CANDIDATE: hispanic_latino|african_american|asian_american|non_hispanic_white|native_american|multiracial|other — promote to reference product] | Column ethnicity_classification (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprSpecialCategory rdf:type rdf:Property ;
    rdfs:label 'Gdpr Special Category' ;
    rdfs:comment 'Indicates whether this demographic segment is based on GDPR Article 9 special category data (e.g., ethnicity, health status). When true, enhanced consent and data processing controls are required for EU audience data associated with this segment. Relevant for pan-European distribution platforms and Ofcom-regulated services. | Column gdpr_special_category (BOOLEAN) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderQualifier rdf:type rdf:Property ;
    rdfs:label 'Gender Qualifier' ;
    rdfs:comment 'Gender dimension of the demographic cell. \'All\' denotes combined-gender segments (e.g., Adults 18-49, Persons 2+). Aligns with Nielsen standard gender breakdowns used in GRP/TRP calculations and ad sales targeting. | Column gender_qualifier (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic level at which this demographic segment definition is applied. National segments are used for network-level ratings and upfront sales; DMA (Designated Market Area) segments apply to local market measurement; local applies to individual station markets; international for global distribution platforms. | Column geographic_scope (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpWeightFactor rdf:type rdf:Property ;
    rdfs:label 'Grp Weight Factor' ;
    rdfs:comment 'Weighting factor applied to this demographic segment when calculating Gross Rating Points (GRP) and Target Rating Points (TRP) in audience measurement reports. Reflects the relative population size and measurement panel representation of the segment. Sourced from the Nielsen Media Research Platform and used in Wide Orbit ad scheduling and campaign delivery calculations. | Column grp_weight_factor (DECIMAL(10,6)) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdComposition rdf:type rdf:Property ;
    rdfs:label 'Household Composition' ;
    rdfs:comment 'Classification of household structure for household-based demographic segments. Used in HUT (Homes Using Television) and PUT (Persons Using Television) audience measurement reporting and in family-oriented programming and advertising targeting strategies. | Column household_composition (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iabAudienceCode rdf:type rdf:Property ;
    rdfs:label 'Iab Audience Code' ;
    rdfs:comment 'The IAB Audience Taxonomy 2.0 standardized code corresponding to this demographic segment. Enables cross-platform audience targeting alignment between linear broadcast, OTT/AVOD/SVOD digital campaigns, and programmatic advertising systems. Used in Salesforce Media Cloud ad proposals and Adobe Experience Platform segment mapping. | Column iab_audience_code (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeQuintile rdf:type rdf:Property ;
    rdfs:label 'Income Quintile' ;
    rdfs:comment 'Household income quintile ranking (1=lowest 20%, 5=highest 20%) for income-based demographic segments. Populated only for income quintile segment types. Used in premium CPM pricing tiers and upfront ad sales targeting for high-value audience packages. | Column income_quintile (INT) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isChildrenSegment rdf:type rdf:Property ;
    rdfs:label 'Is Children Segment' ;
    rdfs:comment 'Indicates whether this demographic segment includes individuals under 13 years of age (e.g., K2-11, K2-5). Triggers COPPA compliance controls on data collection, ad targeting restrictions, and content rating enforcement. Critical for regulatory compliance in digital and broadcast advertising. | Column is_children_segment (BOOLEAN) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKeyDemo rdf:type rdf:Property ;
    rdfs:label 'Is Key Demo' ;
    rdfs:comment 'Flags whether this segment is designated as a key demographic (key demo) for the organization\'s primary ad sales and programming strategy. Key demos (typically A18-49, W25-54) command premium CPM rates and are the primary currency in upfront and scatter market negotiations. | Column is_key_demo (BOOLEAN) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNielsenStandardCell rdf:type rdf:Property ;
    rdfs:label 'Is Nielsen Standard Cell' ;
    rdfs:comment 'Indicates whether this demographic segment corresponds to an official Nielsen standard demographic cell (e.g., A18-49, W25-54). True for Nielsen-defined cells used in GRP/TRP/HUT/PUT ratings calculations; False for custom or proprietary segments defined internally or via Adobe Experience Platform. | Column is_nielsen_standard_cell (BOOLEAN) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'The audience measurement methodology used to quantify this demographic segment. Panel-based measurement uses Nielsen People Meter panels; census-based uses set-top box or streaming data; hybrid combines both; modeled uses statistical projection. Determines data quality, confidence intervals, and applicability for regulatory reporting. | Column measurement_methodology (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenCellLabel rdf:type rdf:Property ;
    rdfs:label 'Nielsen Cell Label' ;
    rdfs:comment 'The exact Nielsen Media Research standard cell label for this demographic segment (e.g., \'A18-49\', \'W25-54\', \'M18-34\', \'K2-11\', \'P2+\'). Used as the authoritative cross-reference when ingesting Nielsen ratings data and reconciling audience measurement reports from the Nielsen Media Research Platform. | Column nielsen_cell_label (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Segment Code' ;
    rdfs:comment 'The native segment identifier assigned by the Nielsen Media Research Platform for this demographic cell. Used for direct API integration with Nielsen ratings data feeds, ensuring accurate mapping of audience measurement data to internal segment definitions. | Column nielsen_segment_code (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformApplicability rdf:type rdf:Property ;
    rdfs:label 'Platform Applicability' ;
    rdfs:comment 'Indicates the distribution platforms for which this demographic segment definition is applicable. Linear segments apply to traditional broadcast/cable measurement; digital applies to OTT/streaming (SVOD, AVOD, FAST); cross-platform spans both; all applies universally. Drives segment availability in Wide Orbit (linear) vs. Adobe Experience Platform (digital) targeting. | Column platform_applicability (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psychographicProfile rdf:type rdf:Property ;
    rdfs:label 'Psychographic Profile' ;
    rdfs:comment 'Descriptive label for psychographic segment classification (e.g., \'Early Adopters\', \'Value Seekers\', \'Sports Enthusiasts\', \'News Junkies\'). Populated only for psychographic segment types. Derived from Adobe Experience Platform audience profiling and used in premium ad sales targeting and programming strategy. | Column psychographic_profile (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachPotentialPct rdf:type rdf:Property ;
    rdfs:label 'Reach Potential Pct' ;
    rdfs:comment 'Estimated maximum reach potential expressed as a percentage of the segment universe achievable across the organization\'s full distribution footprint. Used in media planning to set realistic reach targets for ad campaigns and programming strategies. Sourced from Nielsen reach and frequency models. | Column reach_potential_pct (DECIMAL(5,2)) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Restriction Flag' ;
    rdfs:comment 'Indicates whether this demographic segment is subject to regulatory restrictions on data collection, targeting, or advertising. True for segments including minors (COPPA), sensitive demographic categories under GDPR Article 9, or segments subject to FCC advertising restrictions. Triggers compliance workflow in Adobe Experience Platform and Wide Orbit. | Column regulatory_restriction_flag (BOOLEAN) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the demographic segment, aligned with Nielsen and IAB standard cell codes (e.g., A18-49, W25-54, M18-34, K2-11, P2+). Used as the business-facing identifier in ad sales proposals, ratings reports, and audience targeting systems. | Column segment_code (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Full narrative description of the demographic segment\'s defining characteristics, measurement criteria, and intended use cases. Provides context for business users in ad sales, programming, and analytics teams on how to correctly apply and interpret the segment in audience measurement and targeting workflows. | Column segment_description (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable label for the demographic segment (e.g., \'Adults 18-49\', \'Women 25-54\', \'Men 18-34\', \'Kids 2-11\'). Used in reporting dashboards, ad sales presentations, and EPG audience targeting configurations. | Column segment_name (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle state of the demographic segment definition. Active segments are available for audience targeting, ad sales proposals, and ratings reporting. Deprecated segments are retained for historical continuity but no longer used in new campaigns or programming decisions. | Column segment_status (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segment by its primary defining dimension. Distinguishes age/gender cells (Nielsen standard cells such as A18-49) from psychographic profiles, income quintiles, ethnicity classifications, behavioral clusters, and household composition segments. Drives which measurement methodology and data source applies. | Column segment_type (STRING) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepsPriority rdf:type rdf:Property ;
    rdfs:label 'Sweeps Priority' ;
    rdfs:comment 'Indicates whether this demographic segment is a priority measurement target during Nielsen sweeps periods (February, May, July, November). Priority segments receive enhanced panel measurement and are the primary basis for affiliate compensation and ad rate card negotiations during sweeps. | Column sweeps_priority (BOOLEAN) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:universeEstimate rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate' ;
    rdfs:comment 'Total estimated population count (universe) for this demographic segment in the measurement geography, as defined by Nielsen. Used as the denominator in ratings calculations (rating = audience / universe × 100). Updated periodically from Nielsen universe estimates and used in GRP, TRP, reach, and frequency reporting. | Column universe_estimate (BIGINT) in audience.demographic_segment' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:universeEstimateYear rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate Year' ;
    rdfs:comment 'The calendar year for which the universe estimate is valid. Nielsen updates universe estimates annually; this field identifies the vintage of the estimate to ensure correct ratings calculations and year-over-year audience trend analysis. | Column universe_estimate_year (INT) in audience.demographic_segment' ;
    rdfs:domain ind:DemographicSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cooperationRate rdf:type rdf:Property ;
    rdfs:label 'Cooperation Rate' ;
    rdfs:comment 'Percentage of recruited panel households or individuals who are actively and consistently providing usable measurement data. A declining cooperation rate is an early indicator of panel quality degradation and may trigger MRC review. Expressed as a decimal (e.g., 0.8500 = 85%). | Column cooperation_rate (DECIMAL(6,4)) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Technical mechanism used to collect viewing data from panel members. Electronic meters (people meters) require active button-pressing; set-top-box (STB) and smart TV ACR (Automatic Content Recognition) are passive; diary is self-reported. Determines the granularity and reliability of minute-by-minute audience data. | Column data_collection_method (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demographicComposition rdf:type rdf:Property ;
    rdfs:label 'Demographic Composition' ;
    rdfs:comment 'Narrative or structured description of the demographic breakdowns captured by this panel (e.g., \'Age 2+, Adults 18-49, Adults 25-54, Persons 2-17, Households by income quintile\'). Defines which demographic cuts are available for TRP (Target Rating Point) calculations and demographic audience guarantees in ad sales. | Column demographic_composition (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementCurrencyFlag rdf:type rdf:Property ;
    rdfs:label 'Measurement Currency Flag' ;
    rdfs:comment 'Indicates whether this panel is designated as the official currency measurement source for audience guarantees in advertising transactions. True = this panel\'s data is used as the contractual basis for GRP/TRP delivery and makegood calculations in upfront and scatter market deals. False = supplemental or research-only panel. | Column measurement_currency_flag (BOOLEAN) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minReportableRating rdf:type rdf:Property ;
    rdfs:label 'Min Reportable Rating' ;
    rdfs:comment 'The lowest audience rating value (expressed as a decimal fraction of the universe) that this panel can reliably report without exceeding acceptable statistical error thresholds. Ratings below this threshold are suppressed or flagged as unreliable. Typically expressed as a percentage (e.g., 0.0010 = 0.1%). Governed by MRC minimum cell size requirements. | Column min_reportable_rating (DECIMAL(6,4)) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrcAccreditationDate rdf:type rdf:Property ;
    rdfs:label 'Mrc Accreditation Date' ;
    rdfs:comment 'Date on which the MRC most recently granted or renewed accreditation for this panel. Used to track accreditation currency and schedule renewal audits. Panels must maintain continuous accreditation to support upfront and scatter market ad sales guarantees. | Column mrc_accreditation_date (DATE) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrcAccreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Mrc Accreditation Expiry Date' ;
    rdfs:comment 'Date on which the current MRC accreditation for this panel expires and must be renewed. Expiry triggers a mandatory re-audit process. Ad sales teams must be notified of impending expiry to manage risk on guaranteed audience delivery commitments. | Column mrc_accreditation_expiry_date (DATE) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrcAccreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Mrc Accreditation Status' ;
    rdfs:comment 'Current accreditation status granted by the Media Rating Council (MRC) for this panel. MRC accreditation is the industry standard for currency-grade audience measurement. Accredited panels are required for guaranteed ad buys and upfront sales commitments. Non-accredited panels cannot be used as primary currency. | Column mrc_accreditation_status (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenPanelCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Panel Code' ;
    rdfs:comment 'Nielsen\'s proprietary internal identifier for this panel as maintained in the Nielsen Media Research Platform. Used for direct API integration, data feed reconciliation, and cross-referencing Nielsen ratings reports. Distinct from the internal audience_panel_id surrogate key. | Column nielsen_panel_code (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfHomeMeasurementFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Home Measurement Flag' ;
    rdfs:comment 'Indicates whether this panel captures out-of-home (OOH) viewing, such as viewing in bars, hotels, airports, and other public venues. OOH measurement is captured via Portable People Meter (PPM) technology. OOH-inclusive panels produce higher total audience estimates than in-home-only panels. | Column out_of_home_measurement_flag (BOOLEAN) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:panelStatus rdf:type rdf:Property ;
    rdfs:label 'Panel Status' ;
    rdfs:comment 'Current lifecycle state of the audience panel. Active panels are used for currency-grade audience projections. Suspended panels are temporarily halted due to quality or compliance issues. Retired panels are decommissioned and replaced by newer vintages. | Column panel_status (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelType rdf:type rdf:Property ;
    rdfs:label 'Panel Type' ;
    rdfs:comment 'Classification of the audience measurement methodology used by this panel. National People Meter (NPM) and Local People Meter (LPM) are electronic metered panels; Portable People Meter (PPM) captures out-of-home exposure; Diary is self-reported; Return Path Data (RPD) is set-top-box passback data; Hybrid combines multiple methods. | Column panel_type (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruitmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Recruitment Methodology' ;
    rdfs:comment 'Statistical sampling approach used to recruit panel members. Probability-based sampling (address-based or random-digit-dial) is required for MRC-accredited currency panels. Opt-in panels are used for supplemental or proprietary measurement. Affects the projectability and accreditation status of the panel. | Column recruitment_methodology (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'Cadence at which panel membership is rotated or refreshed to prevent panel conditioning effects and maintain demographic representativeness. Annual and biennial refreshes are standard for people meter panels; continuous recruitment is used for large-scale return path data panels. | Column refresh_frequency (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingGranularity rdf:type rdf:Property ;
    rdfs:label 'Reporting Granularity' ;
    rdfs:comment 'Finest time interval at which this panel can produce reliable audience estimates. Minute-by-minute granularity is available from electronic people meter panels and supports DAI (Dynamic Ad Insertion) optimization. Quarter-hour is standard for diary panels. Determines compatibility with EPG-based program-level ratings reporting. | Column reporting_granularity (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingErrorPct rdf:type rdf:Property ;
    rdfs:label 'Sampling Error Pct' ;
    rdfs:comment 'Estimated margin of error (as a percentage) for audience projections derived from this panel at a 95% confidence interval. Smaller panels have higher sampling error. Used by ad sales teams to communicate measurement uncertainty to advertisers and to set makegood thresholds for audience delivery shortfalls. | Column sampling_error_pct (DECIMAL(6,4)) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeHouseholds rdf:type rdf:Property ;
    rdfs:label 'Size Households' ;
    rdfs:comment 'Total number of sample households actively participating in this panel at any given time. Drives the statistical reliability and margin of error of projected audience estimates. A larger panel size yields lower sampling error for low-rated programs. | Column size_households (INT) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sizeIndividuals rdf:type rdf:Property ;
    rdfs:label 'Size Individuals' ;
    rdfs:comment 'Total number of individual persons (panelists) actively measured within this panel. Distinct from household count because multiple individuals per household are measured for demographic breakdowns used in Target Rating Point (TRP) calculations. | Column size_individuals (INT) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:streamingMeasurementFlag rdf:type rdf:Property ;
    rdfs:label 'Streaming Measurement Flag' ;
    rdfs:comment 'Indicates whether this panel captures streaming and OTT (Over-The-Top) viewing in addition to linear broadcast. Streaming-enabled panels support cross-platform audience measurement combining linear TV, SVOD, AVOD, and FAST channel viewing for total audience reporting. | Column streaming_measurement_flag (BOOLEAN) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sweepsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Sweeps Eligible Flag' ;
    rdfs:comment 'Indicates whether this panel is used during Nielsen Sweeps periods (February, May, July, November) for local market ratings measurement. Sweeps data drives local ad rates and program scheduling decisions. Only MRC-accredited panels with sufficient local market sample sizes are sweeps-eligible. | Column sweeps_eligible_flag (BOOLEAN) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:universeEstimateType rdf:type rdf:Property ;
    rdfs:label 'Universe Estimate Type' ;
    rdfs:comment 'Specifies whether the universe_estimate represents total households, total persons, or TV households (HUT-eligible). TV households are the standard denominator for HUT (Homes Using Television) calculations in broadcast ratings. | Column universe_estimate_type (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vintageYear rdf:type rdf:Property ;
    rdfs:label 'Vintage Year' ;
    rdfs:comment 'Calendar year in which this panel sample was designed and recruited. Panels are periodically refreshed to maintain demographic representativeness as the population changes. Vintage year is used to track panel age and schedule mandatory refreshes per MRC accreditation requirements. | Column vintage_year (INT) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightingFactor rdf:type rdf:Property ;
    rdfs:label 'Weighting Factor' ;
    rdfs:comment 'Numeric multiplier applied to this panel\'s raw viewing data to project sample observations to the total universe estimate. A weighting factor greater than 1.0 indicates the panel under-represents a demographic segment relative to the population. Used in GRP and TRP calculations. | Column weighting_factor (DECIMAL(10,6)) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightingMethodology rdf:type rdf:Property ;
    rdfs:label 'Weighting Methodology' ;
    rdfs:comment 'Description of the statistical weighting approach applied to panel data to correct for demographic imbalances and non-response bias (e.g., \'Iterative Proportional Fitting / Raking\', \'Post-stratification weighting by age/sex/race/income\'). Critical for ensuring projected audience estimates are representative of the total population. | Column weighting_methodology (STRING) in audience.panel' ;
    rdfs:domain ind:Panel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acrSource rdf:type rdf:Property ;
    rdfs:label 'Acr Source' ;
    rdfs:comment 'The data collection methodology or source system that generated this viewership record. ACR = Automatic Content Recognition from smart TV; set_top_box = return-path data from cable/satellite STB; streaming_telemetry = OTT platform event stream via Adobe Experience Platform; panel = Nielsen People Meter panel; return_path = MVPD return-path data. | Column acr_source (STRING) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adBreakCount rdf:type rdf:Property ;
    rdfs:label 'Ad Break Count' ;
    rdfs:comment 'Number of ad breaks (ad pods) encountered by the viewer during this viewing session. Used for DAI (Dynamic Ad Insertion) reconciliation, Wide Orbit affidavit verification, and advertiser delivery reporting. | Column ad_break_count (INT) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adsViewedCount rdf:type rdf:Property ;
    rdfs:label 'Ads Viewed Count' ;
    rdfs:comment 'Total number of individual advertisement spots viewed (not skipped) by the viewer during this session. Used for AVOD monetization reporting, CPM impression counting, and advertiser campaign delivery verification against Wide Orbit schedules. | Column ads_viewed_count (INT) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audienceShare rdf:type rdf:Property ;
    rdfs:label 'Audience Share' ;
    rdfs:comment 'The percentage of HUT (Homes Using Television) or PUT (Persons Using Television) tuned to this channel/program at the time of viewing, as reported by Nielsen. Share differs from rating in that it measures the proportion of active viewers rather than the total universe. Used for competitive programming analysis. | Column audience_share (DECIMAL(6,4)) in audience.viewership_record' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blackoutApplied rdf:type rdf:Property ;
    rdfs:label 'Blackout Applied' ;
    rdfs:comment 'Indicates whether a geographic blackout restriction was applied to this viewing session, preventing delivery of specific content in the viewer\'s DMA or region per rights agreements. Used for blackout compliance auditing and retransmission consent reporting. | Column blackout_applied (BOOLEAN) in audience.viewership_record' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdnEdgeNode rdf:type rdf:Property ;
    rdfs:label 'Cdn Edge Node' ;
    rdfs:comment 'Identifier of the Akamai CDN edge node or point-of-presence (PoP) that served the streaming content for this session. Used for CDN performance analysis, SLA compliance monitoring, and geographic delivery optimization. | Column cdn_edge_node (STRING) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionRate rdf:type rdf:Property ;
    rdfs:label 'Completion Rate' ;
    rdfs:comment 'Proportion of the content asset viewed during this session, expressed as a decimal between 0.0000 and 1.0000 (e.g., 0.7500 = 75% viewed). Sourced directly from platform telemetry; not derived within this product. Used for engagement scoring, programming decisions, and advertiser reporting. | Column completion_rate (DECIMAL(5,4)) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this viewership record was ingested into the Silver Layer. Used for data lineage tracking, quality auditing, and source-system reconciliation. | Column data_source_system (STRING) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypart rdf:type rdf:Property ;
    rdfs:label 'Daypart' ;
    rdfs:comment 'The broadcast daypart time segment during which the tune-in occurred, as defined by industry standard time blocks. Daypart is a fundamental dimension for advertising sales (CPM pricing, GRP/TRP calculations), programming strategy, and Nielsen ratings reporting. [ENUM-REF-CANDIDATE: early_morning|daytime|early_fringe|prime_access|primetime|late_news|late_fringe|overnight — promote to reference product] | Column daypart (STRING) in audience.viewership_record' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmProtected rdf:type rdf:Property ;
    rdfs:label 'Drm Protected' ;
    rdfs:comment 'Indicates whether the content stream was delivered with DRM (Digital Rights Management) encryption active during this session. Used for rights compliance auditing, anti-piracy reporting to MPA, and content protection SLA verification. | Column drm_protected (BOOLEAN) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationViewedSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Viewed Seconds' ;
    rdfs:comment 'Total number of seconds the viewer actively watched the content during this session, as reported by the source telemetry system. Accounts for pauses and buffering exclusions per platform telemetry rules. Used for TSR (Time Spent Reading/Viewing) calculations and completion rate derivation. | Column duration_viewed_seconds (INT) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'The date and time when this viewership record was first loaded into the Databricks Silver Layer lakehouse. Used for data freshness monitoring, SLA compliance, and audit trail purposes. Distinct from tune_in_timestamp (business event time). | Column ingestion_timestamp (TIMESTAMP) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAuthenticated rdf:type rdf:Property ;
    rdfs:label 'Is Authenticated' ;
    rdfs:comment 'Indicates whether the viewer was authenticated (logged in) at the time of viewing. Authenticated sessions enable individual-level audience measurement and subscriber-linked analytics. Unauthenticated sessions rely on household or device-level inference. | Column is_authenticated (BOOLEAN) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSweepsPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Sweeps Period' ;
    rdfs:comment 'Flag indicating whether this viewership record falls within a Nielsen sweeps measurement period (February, May, July, November). Sweeps data is used for setting advertising rates and programming decisions. Critical for isolating sweeps vs. non-sweeps audience behavior. | Column is_sweeps_period (BOOLEAN) in audience.viewership_record' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformType rdf:type rdf:Property ;
    rdfs:label 'Platform Type' ;
    rdfs:comment 'The distribution platform category through which the content was delivered. Used for multi-platform audience aggregation, MVPD/vMVPD carriage reporting, and OTT vs. linear audience segmentation. [ENUM-REF-CANDIDATE: broadcast|cable|satellite|ott|mvpd|vmvpd|web|mobile|podcast|social — promote to reference product] | Column platform_type (STRING) in audience.viewership_record' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playbackPositionSeconds rdf:type rdf:Property ;
    rdfs:label 'Playback Position Seconds' ;
    rdfs:comment 'The content offset position in seconds at which the viewer stopped watching (tune-out position within the asset). For linear broadcast, this reflects the offset from the scheduled start of the program. Used for resume-point analytics and mid-roll ad delivery attribution. | Column playback_position_seconds (INT) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:streamQuality rdf:type rdf:Property ;
    rdfs:label 'Stream Quality' ;
    rdfs:comment 'The video quality level at which the content was delivered during this session, as reported by the ABR (Adaptive Bitrate Streaming) player or CDN telemetry from Akamai. Used for quality-of-experience reporting, CDN SLA compliance, and premium content delivery analytics. | Column stream_quality (STRING) in audience.viewership_record' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tuneInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tune In Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) when the viewer began watching the content or tuned to the channel. This is the principal business event timestamp for the viewership record. Used for daypart analysis, time-spent calculations, and sweeps period attribution. | Column tune_in_timestamp (TIMESTAMP) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tuneOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tune Out Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) when the viewer stopped watching, changed channel, or the session ended. Used in conjunction with tune_in_timestamp to calculate duration_viewed_seconds. | Column tune_out_timestamp (TIMESTAMP) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:viewingStatus rdf:type rdf:Property ;
    rdfs:label 'Viewing Status' ;
    rdfs:comment 'Current lifecycle status of the viewing session record. \'completed\' = viewer watched to end or tune-out cleanly; \'in_progress\' = session still active at ingestion time; \'abandoned\' = viewer left before 10% completion; \'interrupted\' = session ended due to technical failure; \'error\' = telemetry data quality issue flagged. | Column viewing_status (STRING) in audience.viewership_record' ;
    rdfs:domain ind:ViewershipRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSharePct rdf:type rdf:Property ;
    rdfs:label 'Audience Share Pct' ;
    rdfs:comment 'The percentage of the total viewing audience (persons using television) that was watching the specific network or program during the measurement period. Calculated as the program\'s audience divided by the total HUT/PUT audience. Used for competitive programming analysis and ad sales positioning. | Column audience_share_pct (DECIMAL(7,4)) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageFrequency rdf:type rdf:Property ;
    rdfs:label 'Average Frequency' ;
    rdfs:comment 'The average number of times a unique viewer within the target demographic was exposed to the content or campaign during the measurement period. Calculated as total impressions divided by unduplicated reach. Core metric for evaluating campaign saturation and makegoods calculation. | Column average_frequency (DECIMAL(8,4)) in audience.reach_frequency_report' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpm rdf:type rdf:Property ;
    rdfs:label 'Cpm' ;
    rdfs:comment 'The cost per one thousand audience impressions for the campaign or programming block, expressed in USD. Used by ad sales for post-campaign delivery validation, scatter market pricing justification, and makegood valuation. Confidential as it reflects negotiated commercial pricing. | Column cpm (DECIMAL(10,4)) in audience.reach_frequency_report' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cprp rdf:type rdf:Property ;
    rdfs:label 'Cprp' ;
    rdfs:comment 'The cost per one rating point delivered against the target demographic segment, expressed in USD. The primary pricing metric for linear TV advertising transactions. Used for upfront guarantee reconciliation, makegood valuation, and scatter market pricing. Confidential as it reflects negotiated commercial pricing. | Column cprp (DECIMAL(10,4)) in audience.reach_frequency_report' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryVariancePct rdf:type rdf:Property ;
    rdfs:label 'Delivery Variance Pct' ;
    rdfs:comment 'The percentage difference between the guaranteed audience delivery (GRP or TRP) and the actual delivered audience for the campaign flight. A negative value indicates under-delivery triggering makegood obligations; a positive value indicates over-delivery. Used for upfront guarantee reconciliation and scatter market adjustments. | Column delivery_variance_pct (DECIMAL(7,4)) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveReach1plus rdf:type rdf:Property ;
    rdfs:label 'Effective Reach 1plus' ;
    rdfs:comment 'The count of unique persons exposed to the content or campaign at least one time (1+) during the measurement period. Equivalent to reach_persons; included as an explicit effective reach threshold field for consistency with N+ reporting framework used in post-campaign analysis. | Column effective_reach_1plus (BIGINT) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveReach3plus rdf:type rdf:Property ;
    rdfs:label 'Effective Reach 3plus' ;
    rdfs:comment 'The count of unique persons exposed to the content or campaign at least three times (3+) during the measurement period. The industry-standard effective reach threshold used to assess whether sufficient frequency was achieved for advertising message recall. Critical for makegoods determination and campaign effectiveness evaluation. | Column effective_reach_3plus (BIGINT) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveReachNplus rdf:type rdf:Property ;
    rdfs:label 'Effective Reach Nplus' ;
    rdfs:comment 'The count of unique persons exposed to the content or campaign at least N times (as defined by effective_reach_threshold) during the measurement period. Provides a configurable effective reach metric for custom campaign guarantee structures and advanced frequency analysis. | Column effective_reach_nplus (BIGINT) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveReachThreshold rdf:type rdf:Property ;
    rdfs:label 'Effective Reach Threshold' ;
    rdfs:comment 'The minimum number of exposures (N) used to define effective reach for this specific report. Configurable per campaign or client agreement (e.g., 3 for standard campaigns, 5 for high-frequency campaigns). Determines the N+ threshold applied in effective reach calculations beyond the standard 1+ and 3+ fields. | Column effective_reach_threshold (INT) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hutRating rdf:type rdf:Property ;
    rdfs:label 'Hut Rating' ;
    rdfs:comment 'The percentage of all television households in the market that had their television sets in use during the measurement period. Sourced from Nielsen Media Research Platform. Used as a contextual benchmark for evaluating audience share and competitive programming performance. | Column hut_rating (DECIMAL(7,4)) in audience.reach_frequency_report' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isMakegoodRequired rdf:type rdf:Property ;
    rdfs:label 'Is Makegood Required' ;
    rdfs:comment 'Indicates whether this reach and frequency report has identified an audience delivery shortfall that requires a makegood (compensatory ad spot) to be issued to the advertiser. Triggers the makegood workflow in Wide Orbit and Salesforce Media Cloud when set to True. | Column is_makegood_required (BOOLEAN) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'The last date of the measurement window for which reach and frequency metrics are computed. Defines the end boundary of the campaign flight, programming block, or sweeps period being analyzed. | Column measurement_period_end_date (DATE) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'The first date of the measurement window for which reach and frequency metrics are computed. Defines the start boundary of the campaign flight, programming block, or sweeps period being analyzed. Used in conjunction with measurement_period_end_date to bound the audience measurement interval. | Column measurement_period_start_date (DATE) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'Classifies the type of measurement window for which this report was generated. \'campaign_flight\' covers a defined ad campaign run; \'programming_block\' covers a scheduled content block; \'daypart_window\' covers a standard broadcast daypart; \'sweeps_period\' covers an intensive Nielsen ratings measurement period; \'custom_window\' covers an ad hoc analysis window. | Column measurement_type (STRING) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenReportCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Report Code' ;
    rdfs:comment 'The native report identifier assigned by the Nielsen Media Research Platform for this reach and frequency dataset. Used for source system traceability, data lineage, and reconciliation between the lakehouse Silver Layer and the Nielsen source system. | Column nielsen_report_code (STRING) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putRating rdf:type rdf:Property ;
    rdfs:label 'Put Rating' ;
    rdfs:comment 'The percentage of all persons in the target demographic who were watching television during the measurement period. Sourced from Nielsen Media Research Platform. Used alongside HUT to assess total available audience and calculate audience share for programming decisions. | Column put_rating (DECIMAL(7,4)) in audience.reach_frequency_report' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachPct rdf:type rdf:Property ;
    rdfs:label 'Reach Pct' ;
    rdfs:comment 'The percentage of the target demographic universe reached at least once during the measurement period, calculated as (reach_persons / universe_estimate) × 100. Expressed as a decimal percentage (e.g., 45.2500 = 45.25%). Used by ad sales for post-campaign delivery reporting and scatter market pricing justification. | Column reach_pct (DECIMAL(7,4)) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachPersons rdf:type rdf:Property ;
    rdfs:label 'Reach Persons' ;
    rdfs:comment 'The unduplicated count of unique persons within the target demographic segment who were exposed to the content or campaign at least once during the measurement period. The primary reach metric sourced from Nielsen Media Research Platform. Used for post-campaign delivery validation and upfront guarantee reconciliation. | Column reach_persons (BIGINT) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Generated Timestamp' ;
    rdfs:comment 'The principal real-world event timestamp when this reach and frequency report was generated and delivered by the Nielsen Media Research Platform. Represents the business event time, distinct from audit timestamps. Used to track Nielsen data delivery SLAs and post-campaign reporting timeliness. | Column report_generated_timestamp (TIMESTAMP) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known business identifier for this reach and frequency report, sourced from the Nielsen Media Research Platform. Used by ad sales teams to reference specific post-campaign delivery reports in client communications, makegoods negotiations, and upfront guarantee reconciliation. | Column report_number (STRING) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle state of the reach and frequency report. \'draft\' indicates in-progress computation; \'preliminary\' indicates initial Nielsen delivery pending validation; \'final\' indicates validated and approved for client delivery; \'revised\' indicates a corrected reissue; \'superseded\' indicates replaced by a newer version; \'archived\' indicates retired from active use. | Column report_status (STRING) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportVersion rdf:type rdf:Property ;
    rdfs:label 'Report Version' ;
    rdfs:comment 'The version number of this reach and frequency report, incremented each time a revised or corrected report is issued by Nielsen or reprocessed in the lakehouse. Version 1 represents the initial delivery; subsequent versions represent corrections or revisions. Used to ensure ad sales teams are working with the most current data. | Column report_version (INT) in audience.reach_frequency_report' ;
    rdfs:domain ind:ReachFrequencyReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalImpressions rdf:type rdf:Property ;
    rdfs:label 'Total Impressions' ;
    rdfs:comment 'The total number of audience exposures (duplicated) to the content or campaign during the measurement period. Equals reach_persons multiplied by average_frequency. Used as the gross delivery metric for CPM-based advertising transactions and campaign pacing analysis. | Column total_impressions (BIGINT) in audience.reach_frequency_report' ;
    rdfs:domain ind:Audience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementEventId rdf:type rdf:Property ;
    rdfs:label 'Engagement Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each discrete digital audience engagement action captured on OTT/streaming platforms. Primary key for this product in the Databricks Silver Layer. | Column engagement_event_id (BIGINT) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appVersion rdf:type rdf:Property ;
    rdfs:label 'App Version' ;
    rdfs:comment 'Version string of the OTT/streaming application that captured the engagement event (e.g., 4.2.1). Used to correlate engagement behaviour with app release cycles and identify version-specific anomalies in audience interaction patterns. | Column app_version (STRING) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bufferingDurationMs rdf:type rdf:Property ;
    rdfs:label 'Buffering Duration Ms' ;
    rdfs:comment 'Total duration of buffering experienced by the viewer immediately preceding or during this engagement event, in milliseconds. Sourced from Adobe Experience Platform quality-of-experience telemetry. Used to correlate buffering events with pause and abandonment engagement actions. | Column buffering_duration_ms (INT) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentDurationMs rdf:type rdf:Property ;
    rdfs:label 'Content Duration Ms' ;
    rdfs:comment 'Total duration of the content asset in milliseconds at the time of the engagement event. Used in conjunction with content_position_ms to compute completion percentage and engagement depth score. Sourced from Dalet Galaxy asset metadata. | Column content_duration_ms (BIGINT) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentPositionMs rdf:type rdf:Property ;
    rdfs:label 'Content Position Ms' ;
    rdfs:comment 'Playback position within the content asset at the moment the engagement event was triggered, expressed in milliseconds from the start of the content. Core EVENT_PAYLOAD_OR_VALUE for this event log. Enables precise engagement depth analysis, completion rate calculation, and identification of drop-off points. | Column content_position_ms (BIGINT) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataPrivacyConsent rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Consent' ;
    rdfs:comment 'Viewer\'s data privacy consent status at the time of the engagement event, governing permissible use of this record for analytics, personalisation, and ad targeting. Sourced from Adobe Experience Platform consent management. Mandatory for GDPR Article 6 lawful basis determination and CCPA opt-out compliance. | Column data_privacy_consent (STRING) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceOs rdf:type rdf:Property ;
    rdfs:label 'Device Os' ;
    rdfs:comment 'Operating system of the device that generated the engagement event (e.g., iOS, Android, tvOS, Roku OS, Fire OS, Windows, macOS). Sourced from Adobe Experience Platform device context. Supports technical platform compatibility analysis and audience reach reporting. | Column device_os (STRING) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmScheme rdf:type rdf:Property ;
    rdfs:label 'Drm Scheme' ;
    rdfs:comment 'DRM (Digital Rights Management) protection scheme active on the content stream at the time of the engagement event. Used for rights compliance verification and to ensure content is consumed within licensed windows and territories. Supports Rightsline rights enforcement reporting. | Column drm_scheme (STRING) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementDepthScore rdf:type rdf:Property ;
    rdfs:label 'Engagement Depth Score' ;
    rdfs:comment 'Normalised score (0.00–100.00) representing the depth of audience engagement at the time of the event, calculated by Adobe Experience Platform based on playback position relative to content duration, interaction frequency, and event type weighting. Key metric for non-linear audience behaviour analysis and ad targeting propensity modelling. | Column engagement_depth_score (DECIMAL(5,2)) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Processing lifecycle status of the engagement event record in the Silver Layer. \'valid\' indicates the event passed all quality checks; \'invalid\' indicates a data quality failure; \'duplicate\' indicates a repeated event suppressed from analytics; \'quarantined\' indicates the event is held pending investigation. | Column event_status (STRING) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geo Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the viewer\'s geographic location at the time of the engagement event, derived from IP geolocation. Used for territorial rights compliance (blackout enforcement, holdback windows), audience reach reporting by geography, and regulatory jurisdiction determination. | Column geo_country_code (STRING) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geo Region Code' ;
    rdfs:comment 'ISO 3166-2 subdivision code (state, province, or region) of the viewer\'s location at the time of the engagement event. Used for sub-national blackout enforcement, regional audience measurement, and daypart-adjusted analytics. | Column geo_region_code (STRING) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdEvent rdf:type rdf:Property ;
    rdfs:label 'Is Ad Event' ;
    rdfs:comment 'Indicates whether this engagement event occurred during an advertisement (True) or during editorial content (False). Critical for separating content engagement metrics from ad engagement metrics in AVOD and DAI (Dynamic Ad Insertion) analytics. | Column is_ad_event (BOOLEAN) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConcurrentStream rdf:type rdf:Property ;
    rdfs:label 'Is Concurrent Stream' ;
    rdfs:comment 'Indicates whether this engagement event occurred on a stream that was running concurrently with another active stream on the same viewer account (True) or not (False). Used for concurrent stream limit enforcement per subscription terms and HUT (Homes Using Television) measurement. | Column is_concurrent_stream (BOOLEAN) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'UTC timestamp when the engagement event was received and ingested by Adobe Experience Platform. Distinct from event_timestamp (client-side occurrence time). Used to measure event latency, detect clock skew, and support data quality auditing in the Silver Layer pipeline. | Column received_timestamp (TIMESTAMP) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'Channel or mechanism through which the viewer arrived at the content that triggered this engagement event. Used for audience acquisition attribution, marketing campaign effectiveness analysis, and content discovery optimisation. [ENUM-REF-CANDIDATE: direct|search|social|email|push_notification|in_app|external_link — promote to reference product] | Column referral_source (STRING) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seekFromPositionMs rdf:type rdf:Property ;
    rdfs:label 'Seek From Position Ms' ;
    rdfs:comment 'Playback position in milliseconds from which the viewer initiated a seek or rewind action. Populated only when event_type is \'seek\' or \'rewind\'. Combined with content_position_ms (seek-to position) to measure skip behaviour and identify content segments that audiences skip or revisit. | Column seek_from_position_ms (BIGINT) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemEventCode rdf:type rdf:Property ;
    rdfs:label 'Source System Event Code' ;
    rdfs:comment 'Original event identifier assigned by Adobe Experience Platform at the point of capture, before Silver Layer surrogate key assignment. Used for data lineage tracing, deduplication, and reconciliation between the Silver Layer and the Adobe Experience Platform source system. | Column source_system_event_code (STRING) in audience.engagement_event' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenPanelId rdf:type rdf:Property ;
    rdfs:label 'Nielsen Panel Id' ;
    rdfs:comment 'Pseudonymized identifier assigned by Nielsen Media Research to link this audience profile to a Nielsen panel household or individual. Enables direct integration of Nielsen ratings, GRP/TRP, and demographic data. Null for non-panel profiles. | Column nielsen_panel_id (BIGINT) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Panel .

ind:adReceptivityScore rdf:type rdf:Property ;
    rdfs:label 'Ad Receptivity Score' ;
    rdfs:comment 'Propensity score (0.00–100.00) indicating this audience member\'s likelihood to engage with advertising content, derived from behavioral signals in Adobe AEP and viewing pattern analysis. Used by ad sales teams for premium audience packaging and CPM pricing optimization. | Column ad_receptivity_score (DECIMAL(5,2)) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aepProfileCode rdf:type rdf:Property ;
    rdfs:label 'Aep Profile Code' ;
    rdfs:comment 'Unique profile identifier from Adobe Experience Platform (AEP) used to link behavioral engagement data, segment memberships, and journey analytics to this audience profile. Enables personalization and digital engagement enrichment. | Column aep_profile_code (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aepSegmentMembership rdf:type rdf:Property ;
    rdfs:label 'Aep Segment Membership' ;
    rdfs:comment 'Comma-delimited list of Adobe Experience Platform (AEP) audience segment IDs to which this profile currently belongs. Segments represent behavioral, demographic, or propensity-based audience groups used for personalization, ad targeting, and journey activation. | Column aep_segment_membership (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avgSessionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Avg Session Duration Minutes' ;
    rdfs:comment 'Average duration in minutes of a single viewing session for this audience member, derived from set-top box or streaming platform telemetry. Represents Time Spent Viewing (TSV) at the individual level. Used for engagement scoring and content performance analytics. | Column avg_session_duration_minutes (DECIMAL(8,2)) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccpaOptOut rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out' ;
    rdfs:comment 'Indicates whether this California-resident audience member has exercised their CCPA right to opt out of the sale or sharing of their personal information. When TRUE, this profile must be excluded from data sharing with third-party ad networks and data clean rooms. | Column ccpa_opt_out (BOOLEAN) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent change to any consent or privacy flag (GDPR consent status, CCPA opt-out, COPPA flag) for this audience profile. Critical for regulatory audit trails demonstrating timely consent management and data processing compliance. | Column consent_last_updated_timestamp (TIMESTAMP) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contentAffinityGenre rdf:type rdf:Property ;
    rdfs:label 'Content Affinity Genre' ;
    rdfs:comment 'Top inferred content genre affinity for this audience member (e.g., \'news\', \'sports\', \'drama\', \'reality\', \'documentary\'), derived from viewing history and behavioral signals in Adobe AEP. Used for content recommendation, programming decisions, and audience-targeted ad sales. [ENUM-REF-CANDIDATE: news|sports|drama|comedy|reality|documentary|entertainment|kids|lifestyle|sci_fi — promote to reference product] | Column content_affinity_genre (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaProtected rdf:type rdf:Property ;
    rdfs:label 'Coppa Protected' ;
    rdfs:comment 'Indicates whether this audience profile is subject to COPPA (Children\'s Online Privacy Protection Act) protections, meaning the inferred or declared age is under 13. When TRUE, ad targeting, data sharing, and behavioral tracking are strictly restricted per COPPA compliance requirements. | Column coppa_protected (BOOLEAN) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataCleanRoomEligible rdf:type rdf:Property ;
    rdfs:label 'Data Clean Room Eligible' ;
    rdfs:comment 'Indicates whether this audience profile is eligible for inclusion in data clean room matching operations with advertising partners. Eligibility is determined by consent status, CCPA opt-out flag, COPPA protection status, and contractual data sharing agreements. | Column data_clean_room_eligible (BOOLEAN) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceGraphCode rdf:type rdf:Property ;
    rdfs:label 'Device Graph Code' ;
    rdfs:comment 'Cross-device graph linkage identifier that associates this audience profile with a cluster of known devices (smart TV, mobile, desktop, STB). Sourced from identity resolution providers or Adobe AEP device graph. Enables multi-screen reach and frequency measurement. | Column device_graph_code (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrichmentSourceVersion rdf:type rdf:Property ;
    rdfs:label 'Enrichment Source Version' ;
    rdfs:comment 'Version identifier of the third-party enrichment data package (e.g., Nielsen demographic file version, Adobe AEP segment refresh batch ID) used to populate inferred attributes on this profile. Enables data lineage tracing and reproducibility of audience segment definitions. | Column enrichment_source_version (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Status' ;
    rdfs:comment 'Current GDPR consent status for processing this audience member\'s personal data for audience measurement and advertising purposes. \'granted\' permits processing; \'denied\' or \'withdrawn\' restricts processing; \'not_applicable\' for non-EU audience members. Drives data processing eligibility. | Column gdpr_consent_status (STRING) in audience.audience_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdSize rdf:type rdf:Property ;
    rdfs:label 'Household Size' ;
    rdfs:comment 'Estimated number of persons in the audience household, derived from Nielsen panel data or set-top box signals. Used in HUT (Homes Using Television) and PUT (Persons Using Television) calculations for audience measurement reporting. | Column household_size (INT) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hutEligible rdf:type rdf:Property ;
    rdfs:label 'Hut Eligible' ;
    rdfs:comment 'Indicates whether this household-level audience profile is eligible to be counted in HUT (Homes Using Television) calculations. HUT measures the percentage of TV-equipped homes actively watching television during a given time period, a foundational metric for broadcast ratings. | Column hut_eligible (BOOLEAN) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identityConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Identity Confidence Score' ;
    rdfs:comment 'Confidence score (0.00–100.00) representing the reliability of the identity resolution that constructed this audience profile. Higher scores indicate stronger deterministic matching (e.g., authenticated login); lower scores indicate probabilistic device-graph inference. Used to qualify profiles for premium ad targeting. | Column identity_confidence_score (DECIMAL(5,2)) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:identityHash rdf:type rdf:Property ;
    rdfs:label 'Identity Hash' ;
    rdfs:comment 'SHA-256 pseudonymized hash of the audience member\'s primary identity (e.g., email or subscriber ID) used for cross-platform identity resolution without exposing raw PII. Enables privacy-safe linkage across Nielsen, Adobe AEP, and first-party data sources. | Column identity_hash (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identitySource rdf:type rdf:Property ;
    rdfs:label 'Identity Source' ;
    rdfs:comment 'Originating source of the audience identity construction: \'first_party\' (subscriber or app registration data), \'nielsen\' (Nielsen Media Research panel linkage), \'adobe_aep\' (Adobe Experience Platform profile), \'set_top_box\' (STB device-level data), \'clean_room\' (data clean room match), or \'modeled\' (probabilistic inference). | Column identity_source (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeBand rdf:type rdf:Property ;
    rdfs:label 'Income Band' ;
    rdfs:comment 'Inferred household income band derived from third-party demographic enrichment (Nielsen, data clean rooms). Used for premium audience segmentation in upfront and scatter market ad sales, enabling CPM pricing differentiation by audience affluence. | Column income_band (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferredAgeBand rdf:type rdf:Property ;
    rdfs:label 'Inferred Age Band' ;
    rdfs:comment 'Inferred age demographic band for the audience member, derived from Nielsen panel data, set-top box signals, or modeled enrichment. Used for GRP/TRP demographic targeting and ad sales audience guarantees. Not directly collected from the individual. | Column inferred_age_band (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferredGender rdf:type rdf:Property ;
    rdfs:label 'Inferred Gender' ;
    rdfs:comment 'Inferred gender of the audience member derived from panel data or modeled signals. Used for demographic audience targeting in ad sales (GRP/TRP calculations) and programming decisions. Not directly collected. | Column inferred_gender (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSeenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Seen Timestamp' ;
    rdfs:comment 'Timestamp of the most recent observed audience activity event (viewing session, app interaction, or platform login) for this profile. Used to determine audience recency, drive re-engagement campaigns, and calculate viewing recency metrics. | Column last_seen_timestamp (TIMESTAMP) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nielsenGrpIndex rdf:type rdf:Property ;
    rdfs:label 'Nielsen Grp Index' ;
    rdfs:comment 'Indexed GRP (Gross Rating Point) score for this audience profile relative to the total population, sourced from Nielsen Media Research. A GRP index above 100 indicates above-average exposure to rated content. Used in ad sales audience guarantees and upfront negotiations. | Column nielsen_grp_index (DECIMAL(8,4)) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:panelWeightFactor rdf:type rdf:Property ;
    rdfs:label 'Panel Weight Factor' ;
    rdfs:comment 'Statistical weighting factor assigned by Nielsen to this panel member profile to project panel observations to the total population. Applied in GRP, TRP, HUT, and PUT calculations. Null for non-panel (modeled or first-party only) profiles. | Column panel_weight_factor (DECIMAL(10,6)) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryDeviceType rdf:type rdf:Property ;
    rdfs:label 'Primary Device Type' ;
    rdfs:comment 'The primary device type through which this audience member most frequently consumes content, derived from device graph and behavioral data. Used for CDN delivery optimization, ad format targeting, and platform analytics. | Column primary_device_type (STRING) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trpIndex rdf:type rdf:Property ;
    rdfs:label 'Trp Index' ;
    rdfs:comment 'Indexed TRP (Target Rating Point) score representing this audience member\'s contribution to a specific demographic target group\'s rating. Distinct from GRP in that it measures reach within a defined target demographic. Used for demographic-specific ad campaign planning and post-campaign analysis. | Column trp_index (DECIMAL(8,4)) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewingRecencyDays rdf:type rdf:Property ;
    rdfs:label 'Viewing Recency Days' ;
    rdfs:comment 'Number of days since this audience member last engaged with any content on any tracked platform. Used for audience recency segmentation, churn prediction, and re-engagement campaign targeting. Lower values indicate more recently active audiences. | Column viewing_recency_days (INT) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weeklyViewingFrequency rdf:type rdf:Property ;
    rdfs:label 'Weekly Viewing Frequency' ;
    rdfs:comment 'Average number of distinct viewing sessions per week for this audience member, calculated over a rolling 4-week window. Represents the Frequency dimension of audience measurement (average exposures per viewer). Used in reach and frequency reporting for ad campaign delivery. | Column weekly_viewing_frequency (INT) in audience.audience_profile' ;
    rdfs:domain ind:AudienceProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crossPlatformMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Measurement Id' ;
    rdfs:comment 'Unique surrogate identifier for each cross-platform audience measurement record in the Silver layer lakehouse. Primary key for this transactional entity. | Column cross_platform_measurement_id (BIGINT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentTitleId rdf:type rdf:Property ;
    rdfs:label 'Content Title Id' ;
    rdfs:comment 'Reference to the content title or program for which this cross-platform audience measurement is recorded. Links to the content master data product in the Content domain. | Column content_title_id (BIGINT) in content.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:upfrontDealId rdf:type rdf:Property ;
    rdfs:label 'Upfront Deal Id' ;
    rdfs:comment 'Foreign key linking to sales.upfront_deal. Business justification: Upfront audience guarantee reconciliation across linear and digital: cross-platform measurement is the primary instrument for validating upfront GRP/impression guarantees spanning broadcast and stream' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UpfrontDeal .

ind:coViewingAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Co Viewing Adjustment Factor' ;
    rdfs:comment 'Multiplicative adjustment factor applied to account for co-viewing behavior (multiple persons watching on a single device/screen), particularly relevant for connected TV and OTT platforms. Values greater than 1.0 indicate upward adjustment for co-viewing. Sourced from Nielsen co-viewing methodology. | Column co_viewing_adjustment_factor (DECIMAL(8,6)) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossPlatformGrp rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Grp' ;
    rdfs:comment 'Gross Rating Point (GRP) calculated across all measured platforms, representing the sum of ratings for all platform exposures within the target universe. Equals total impressions divided by the target universe population, multiplied by 100. Primary audience currency for converged TV ad buying. | Column cross_platform_grp (DECIMAL(10,4)) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossPlatformTrp rdf:type rdf:Property ;
    rdfs:label 'Cross Platform Trp' ;
    rdfs:comment 'Target Rating Point (TRP) calculated across all measured platforms for the specified target demographic segment. Measures GRP within the defined target audience, used for demographic-specific ad buying and campaign performance evaluation. | Column cross_platform_trp (DECIMAL(10,4)) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyVersion rdf:type rdf:Property ;
    rdfs:label 'Currency Version' ;
    rdfs:comment 'Version identifier of the audience measurement currency standard applied to this record (e.g., \'Nielsen ONE v2.1\', \'Comscore Campaign Ratings v3.0\'). Supports multi-currency and currency transition tracking as the industry evolves from legacy Nielsen C3/C7 to cross-platform currencies. | Column currency_version (STRING) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystems rdf:type rdf:Property ;
    rdfs:label 'Data Source Systems' ;
    rdfs:comment 'Pipe-delimited list of operational source systems that contributed data to this cross-platform measurement record (e.g., \'Nielsen Media Research Platform|Adobe Experience Platform\'). Supports data lineage, audit, and methodology transparency requirements. | Column data_source_systems (STRING) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deduplicatedReach rdf:type rdf:Property ;
    rdfs:label 'Deduplicated Reach' ;
    rdfs:comment 'Total count of unique, unduplicated individuals (persons) who were exposed to the content or campaign across all measured platforms within the measurement period. Core audience currency metric for converged TV buying. Expressed as absolute person count. | Column deduplicated_reach (BIGINT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionType rdf:type rdf:Property ;
    rdfs:label 'Distribution Type' ;
    rdfs:comment 'Primary distribution model classification for the content being measured: \'linear\' for traditional scheduled broadcast; \'vod\' for generic on-demand; \'svod\' for subscription streaming; \'avod\' for ad-supported streaming; \'tvod\' for transactional on-demand; \'fast\' for free ad-supported streaming TV; \'social\' for social video platforms. [ENUM-REF-CANDIDATE: linear|vod|svod|avod|tvod|fast|social — 7 candidates stripped; promote to reference product] | Column distribution_type (STRING) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastChannelImpressions rdf:type rdf:Property ;
    rdfs:label 'Fast Channel Impressions' ;
    rdfs:comment 'Audience impressions attributed to Free Ad-Supported Streaming Television (FAST) channels within the measurement period. Represents the growing ad-supported streaming audience segment. | Column fast_channel_impressions (BIGINT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDataSuppressed rdf:type rdf:Property ;
    rdfs:label 'Is Data Suppressed' ;
    rdfs:comment 'Indicates whether this measurement record has been suppressed from reporting due to insufficient panel sample size, MRC minimum reporting thresholds, or privacy regulations (GDPR/CCPA). Suppressed records are retained for audit but excluded from audience currency reporting. | Column is_data_suppressed (BOOLEAN) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMrcAccredited rdf:type rdf:Property ;
    rdfs:label 'Is Mrc Accredited' ;
    rdfs:comment 'Indicates whether this measurement was produced using a methodology that holds current Media Rating Council (MRC) accreditation for cross-platform measurement. MRC accreditation is required for use as official audience currency in upfront and scatter market ad transactions. | Column is_mrc_accredited (BOOLEAN) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linearImpressions rdf:type rdf:Property ;
    rdfs:label 'Linear Impressions' ;
    rdfs:comment 'Audience impressions attributed to traditional linear broadcast television (over-the-air, cable, satellite) within the measurement period. Component of the platform-level audience breakdown. | Column linear_impressions (BIGINT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End' ;
    rdfs:comment 'The last date of the audience measurement observation window, aligned to the content airing schedule or campaign flight end. | Column measurement_period_end (DATE) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start' ;
    rdfs:comment 'The first date of the audience measurement observation window, aligned to the content airing schedule or campaign flight start. Used for sweeps period identification and daypart analysis. | Column measurement_period_start (DATE) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Measurement Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this cross-platform measurement record, used in reporting, ad sales proposals, and audience currency reconciliation. Sourced from Nielsen Media Research Platform or internal measurement workflow. | Column measurement_reference_number (STRING) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Current lifecycle state of the cross-platform measurement record. \'draft\' indicates data is being assembled; \'preliminary\' indicates initial estimate released; \'certified\' indicates MRC-audited final figure; \'revised\' indicates a post-certification correction; \'archived\' indicates superseded by a newer measurement. | Column measurement_status (STRING) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The principal real-world timestamp representing when the audience measurement observation period was captured or the measurement run was executed. Distinct from record audit timestamps. | Column measurement_timestamp (TIMESTAMP) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mvpdImpressions rdf:type rdf:Property ;
    rdfs:label 'Mvpd Impressions' ;
    rdfs:comment 'Audience impressions attributed to Multichannel Video Programming Distributor (MVPD) and virtual MVPD (vMVPD) platforms, including cable, satellite, and virtual pay-TV providers within the measurement period. | Column mvpd_impressions (BIGINT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nielsenRating rdf:type rdf:Property ;
    rdfs:label 'Nielsen Rating' ;
    rdfs:comment 'The Nielsen Rating for the content or program within the measurement period, representing the percentage of all television households or persons in the universe tuned to the program. The foundational audience currency metric for linear broadcast. | Column nielsen_rating (DECIMAL(8,4)) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ottStreamingImpressions rdf:type rdf:Property ;
    rdfs:label 'Ott Streaming Impressions' ;
    rdfs:comment 'Audience impressions attributed to Over-The-Top (OTT) and Subscription Video On Demand (SVOD) streaming platforms within the measurement period. Includes authenticated streaming on connected TV, mobile, and desktop devices. | Column ott_streaming_impressions (BIGINT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:panelSampleSize rdf:type rdf:Property ;
    rdfs:label 'Panel Sample Size' ;
    rdfs:comment 'Number of panel households or persons in the Nielsen (or equivalent vendor) measurement panel that contributed to this cross-platform measurement. Indicates statistical reliability; low sample sizes may trigger data suppression per MRC minimum reporting standards. | Column panel_sample_size (INT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialVideoImpressions rdf:type rdf:Property ;
    rdfs:label 'Social Video Impressions' ;
    rdfs:comment 'Audience impressions attributed to social video platforms (e.g., YouTube, Facebook Video, TikTok, Instagram Reels) within the measurement period. Enables full cross-platform audience aggregation. | Column social_video_impressions (BIGINT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetUniverseSize rdf:type rdf:Property ;
    rdfs:label 'Target Universe Size' ;
    rdfs:comment 'The estimated total population size of the target demographic universe used as the denominator for GRP and TRP calculations. Sourced from Nielsen universe estimates updated annually. | Column target_universe_size (BIGINT) in audience.cross_platform_measurement' ;
    rdfs:domain ind:CrossPlatformMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demoReelMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Demo Reel Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: In media broadcasting, talent profiles reference a demo reel or sizzle reel stored as a managed media asset. Casting directors and production teams access these reels directly from the talent profile ' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:talentAgencyId rdf:type rdf:Property ;
    rdfs:label 'Talent Agency Id' ;
    rdfs:comment 'FK to talent.talent_agency | Column talent_agency_id (BIGINT) in talent.talent_profile' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentAgency .

ind:biometricConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Biometric Consent Flag' ;
    rdfs:comment 'Indicates whether the talent has provided consent for collection and use of biometric data (facial recognition, voice prints) for digital effects, deepfake prevention, and AI training. Required for GDPR and CCPA compliance. | Column biometric_consent_flag (BOOLEAN) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Expiration Date' ;
    rdfs:comment 'The date when the talent\'s current clearance status expires and requires renewal. Used for compliance tracking and production eligibility verification. | Column clearance_expiration_date (DATE) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Clause Flag' ;
    rdfs:comment 'Indicates whether the talent is currently bound by an exclusivity clause that restricts their ability to work with competing networks, studios, or brands. Used for conflict checking during casting and booking. | Column exclusivity_clause_flag (BOOLEAN) in talent.talent_profile' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderIdentity rdf:type rdf:Property ;
    rdfs:label 'Gender Identity' ;
    rdfs:comment 'The talent\'s self-identified gender. Used for diversity reporting, casting analytics, and compliance with equal opportunity regulations. | Column gender_identity (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdbIdentifier rdf:type rdf:Property ;
    rdfs:label 'Imdb Identifier' ;
    rdfs:comment 'The talent\'s unique identifier in the Internet Movie Database (IMDb). Used for cross-referencing filmography, public profile linking, and industry data integration. | Column imdb_identifier (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Flag' ;
    rdfs:comment 'Indicates whether the talent is currently covered by production insurance (liability, workers compensation, errors and omissions). Required for on-set work authorization. | Column insurance_coverage_flag (BOOLEAN) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'The policy number for the talent\'s production insurance coverage. Used for claims processing and certificate of insurance verification. | Column insurance_policy_number (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isniCode rdf:type rdf:Property ;
    rdfs:label 'Isni Code' ;
    rdfs:comment 'The International Standard Name Identifier (ISNI) for the talent. A globally unique identifier for creators used in rights management and royalty distribution systems. | Column isni_code (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The full legal name of the talent as it appears on official documents and contracts. Used for contract execution, payroll, and legal compliance. | Column legal_name (STRING) in talent.talent_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'The talent\'s nationality represented as a 3-letter ISO country code. Used for work authorization, tax treaty eligibility, and international co-production compliance. | Column nationality (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Eligibility Flag' ;
    rdfs:comment 'Indicates whether the talent is eligible to receive residual payments for reuse of their work in syndication, streaming, or international distribution. Determined by union status and contract terms. | Column residual_eligibility_flag (BOOLEAN) in talent.talent_profile' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stageName rdf:type rdf:Property ;
    rdfs:label 'Stage Name' ;
    rdfs:comment 'The professional or stage name used by the talent for public appearances, credits, and marketing materials. May differ from legal name. | Column stage_name (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentTier rdf:type rdf:Property ;
    rdfs:label 'Talent Tier' ;
    rdfs:comment 'The classification tier of the talent based on industry recognition, box office draw, and compensation level. Used for budgeting, marketing strategy, and billing rate determination. | Column talent_tier (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentType rdf:type rdf:Property ;
    rdfs:label 'Talent Type' ;
    rdfs:comment 'The primary professional category or role type of the talent. Determines applicable guild rules, contract templates, and credit attribution standards. [ENUM-REF-CANDIDATE: actor|director|writer|producer|host|correspondent|crew|voice_artist|composer|cinematographer — 10 candidates stripped; promote to reference product] | Column talent_type (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'The talent\'s tax identification number (SSN, EIN, or international equivalent). Required for payroll processing, tax withholding, and IRS 1099 reporting. | Column tax_id_number (STRING) in talent.talent_profile' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionAffiliation rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation' ;
    rdfs:comment 'The primary labor union or guild affiliation of the talent. Determines contract terms, minimum compensation, residual eligibility, and working conditions. | Column union_affiliation (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMemberNumber rdf:type rdf:Property ;
    rdfs:label 'Union Member Number' ;
    rdfs:comment 'The talent\'s membership identifier within their primary union or guild. Required for residual payment processing and contract compliance verification. | Column union_member_number (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Status' ;
    rdfs:comment 'The talent\'s current work authorization status in the primary production jurisdiction. Determines eligibility for employment and production participation. | Column work_authorization_status (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workVisaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Work Visa Expiration Date' ;
    rdfs:comment 'The expiration date of the talent\'s work visa. Critical for production scheduling and compliance with immigration regulations. | Column work_visa_expiration_date (DATE) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workVisaType rdf:type rdf:Property ;
    rdfs:label 'Work Visa Type' ;
    rdfs:comment 'The specific type of work visa held by the talent (e.g., O-1, P-1, H-1B). Used for compliance tracking and production planning for international talent. | Column work_visa_type (STRING) in talent.talent_profile' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Representation Agreement Id' ;
    rdfs:comment 'Foreign key linking to talent.representation_agreement. Business justification: contract currently stores denormalized talent_representative_agency (STRING) and talent_representative_name (STRING) to identify the agency and agent involved in the contract negotiation. The represen' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RepresentationAgreement .

ind:adjustedGrossParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Adjusted Gross Participation Flag' ;
    rdfs:comment 'Indicates if talent has adjusted gross participation' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'The total number of formal amendments made to this contract since initial execution. Tracks contract modification history. | Column amendment_count (INT) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backendParticipationPercentage rdf:type rdf:Property ;
    rdfs:label 'Backend Participation Percentage' ;
    rdfs:comment 'The percentage of net profits, adjusted gross, or other revenue streams the talent is entitled to receive after recoupment of production costs. Common for above-the-line talent. | Column backend_participation_percentage (DECIMAL(5,2)) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backendParticipationType rdf:type rdf:Property ;
    rdfs:label 'Backend Participation Type' ;
    rdfs:comment 'The revenue calculation basis for backend participation. Net profits are after all costs; adjusted gross is after specific deductions; gross receipts are from first dollar. None indicates no backend participation. | Column backend_participation_type (STRING) in talent.contract' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Base Compensation Amount' ;
    rdfs:comment 'The guaranteed base fee or salary payable to the talent for services rendered under this contract, excluding bonuses, backend participation, and residuals. | Column base_compensation_amount (DECIMAL(18,2)) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCreditPosition rdf:type rdf:Property ;
    rdfs:label 'Billing Credit Position' ;
    rdfs:comment 'The contractually specified position and format of the talent\'s on-screen credit (e.g., \'First Position Main Title\', \'Shared Card\', \'Single Card\', \'Above the Title\'). Critical for talent reputation and guild compliance. | Column billing_credit_position (STRING) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationCurrency rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the base compensation amount (e.g., USD, GBP, EUR). | Column compensation_currency (STRING) in talent.contract' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationStructure rdf:type rdf:Property ;
    rdfs:label 'Compensation Structure' ;
    rdfs:comment 'The payment model for the base compensation. Flat fee is a single lump sum; per-episode is paid per episode produced; weekly/annual/day/hourly rates define periodic payment schedules. | Column compensation_structure (STRING) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingentCompensationFlag rdf:type rdf:Property ;
    rdfs:label 'Contingent Compensation Flag' ;
    rdfs:comment 'Indicates if contract includes contingent compensation terms' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Business identifier for the contract, typically assigned by legal or business affairs. Used for external reference and tracking. | Column contract_number (STRING) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current stage of the contract in its lifecycle. Deal memo represents initial short-form agreement; countersigned indicates mutual acceptance; long-form executed is the final detailed contract; amended reflects modifications; suspended indicates temporary hold; terminated is early cancellation; expired is natural end. [ENUM-REF-CANDIDATE: deal_memo|countersigned|long_form_executed|amended|suspended|terminated|expired — 7 candidates stripped; promote to reference product] | Column contract_status (STRING) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the talent engagement type. Series regular deals cover multi-episode commitments; episodic guest agreements are single or limited appearances; overall deals provide exclusive services across multiple projects; first-look deals grant priority rights to talent-developed content; crew contracts cover technical and production staff; talent holding deals reserve talent availability; development deals fund content creation. [ENUM-REF-CANDIDATE: series_regular|episodic_guest|overall_deal|first_look_deal|crew_contract|talent_holding_deal|development_deal — 7 candidates stripped; promote to reference product] | Column contract_type (STRING) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditPlacementRequirements rdf:type rdf:Property ;
    rdfs:label 'Credit Placement Requirements' ;
    rdfs:comment 'Detailed contractual requirements for credit placement, including main title vs end credits, paid advertising inclusion, promotional materials, and any special formatting or adjacency requirements. | Column credit_placement_requirements (STRING) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditSizePercentage rdf:type rdf:Property ;
    rdfs:label 'Credit Size Percentage' ;
    rdfs:comment 'The minimum size of the talent\'s on-screen credit as a percentage of the title or other reference credit size. Null if not contractually specified. | Column credit_size_percentage (DECIMAL(5,2)) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentReferenceUri rdf:type rdf:Property ;
    rdfs:label 'Document Reference Uri' ;
    rdfs:comment 'The storage location or document management system URI for the executed contract document and all amendments. Used for legal reference and audit. | Column document_reference_uri (STRING) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementRole rdf:type rdf:Property ;
    rdfs:label 'Engagement Role' ;
    rdfs:comment 'The specific role or position the talent is contracted to perform (e.g., Lead Actor, Director, Showrunner, Writer, Executive Producer, Director of Photography, Host). | Column engagement_role (STRING) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingCba rdf:type rdf:Property ;
    rdfs:label 'Governing Cba' ;
    rdfs:comment 'The specific collective bargaining agreement that governs this contract, including version and effective date (e.g., SAG-AFTRA Television Agreement 2020-2023). Defines minimum compensation, working conditions, and residual structures. | Column governing_cba (STRING) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Gross Participation Flag' ;
    rdfs:comment 'Indicates if talent has gross participation in revenues' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guaranteedEpisodes rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Episodes' ;
    rdfs:comment 'The minimum number of episodes for which the talent is guaranteed compensation, regardless of actual production. Common in series regular deals. Null for non-episodic contracts. | Column guaranteed_episodes (INT) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Net Participation Flag' ;
    rdfs:comment 'Indicates if talent has net participation in revenues' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optionExerciseDeadline rdf:type rdf:Property ;
    rdfs:label 'Option Exercise Deadline' ;
    rdfs:comment 'The date by which the company must notify the talent of its decision to exercise or decline the next option period. Null if no active option exists. | Column option_exercise_deadline (DATE) in talent.contract' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optionExerciseStatus rdf:type rdf:Property ;
    rdfs:label 'Option Exercise Status' ;
    rdfs:comment 'Current status of the most recent option period. Not applicable if no options exist; pending if decision deadline has not passed; exercised if company extended; declined if company chose not to extend; expired if deadline passed without action. | Column option_exercise_status (STRING) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionPeriodsCount rdf:type rdf:Property ;
    rdfs:label 'Option Periods Count' ;
    rdfs:comment 'The number of option periods (typically annual) the company holds to extend the contract beyond the initial term. Common in series regular and overall deals. | Column option_periods_count (INT) in talent.contract' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payOrPlayFlag rdf:type rdf:Property ;
    rdfs:label 'Pay Or Play Flag' ;
    rdfs:comment 'Indicates whether the contract includes a pay-or-play provision, guaranteeing full compensation even if the talent services are not ultimately used or the production is cancelled. | Column pay_or_play_flag (BOOLEAN) in talent.contract' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepUpAmount rdf:type rdf:Property ;
    rdfs:label 'Step Up Amount' ;
    rdfs:comment 'The incremental increase in base compensation for each exercised option period or season renewal. Null if no step-up provision exists. | Column step_up_amount (DECIMAL(18,2)) in talent.contract' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'The primary reason for early contract termination. Null if contract was not terminated early. [ENUM-REF-CANDIDATE: mutual_agreement|breach_of_contract|force_majeure|production_cancellation|talent_unavailability|company_convenience|talent_request|other — 8 candidates stripped; promote to reference product] | Column termination_reason (STRING) in talent.contract' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationStructureId rdf:type rdf:Property ;
    rdfs:label 'Compensation Structure Id' ;
    rdfs:comment 'Unique identifier for the compensation structure record. Primary key. | Column compensation_structure_id (BIGINT) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backendGrossParticipationPct rdf:type rdf:Property ;
    rdfs:label 'Backend Gross Participation Pct' ;
    rdfs:comment 'The percentage of adjusted gross receipts or backend profits the talent is entitled to receive (e.g., 0.05 for 5% backend participation). Null if no backend participation is granted. | Column backend_gross_participation_pct (DECIMAL(5,4)) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseEpisodeFee rdf:type rdf:Property ;
    rdfs:label 'Base Episode Fee' ;
    rdfs:comment 'The guaranteed compensation amount per episode for episodic talent (actors, writers, directors). Expressed in the contract currency. | Column base_episode_fee (DECIMAL(15,2)) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'The fixed or maximum bonus amount payable when the bonus threshold is met. Expressed in the contract currency. Null if no bonus provision exists. | Column bonus_amount (DECIMAL(15,2)) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusThresholdDescription rdf:type rdf:Property ;
    rdfs:label 'Bonus Threshold Description' ;
    rdfs:comment 'Textual description of the performance or milestone thresholds that trigger bonus payments (e.g., \'Nielsen rating above 2.0 in key demo\', \'box office exceeds $100M domestic\'). | Column bonus_threshold_description (STRING) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakevenDefinition rdf:type rdf:Property ;
    rdfs:label 'Breakeven Definition' ;
    rdfs:comment 'Definition of breakeven point for net participation calculations' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationType rdf:type rdf:Property ;
    rdfs:label 'Compensation Type' ;
    rdfs:comment 'Classification of the compensation arrangement: union scale (SAG-AFTRA, WGA, DGA minimum), over-scale (above union minimum), flat fee, episodic rate, weekly guarantee, daily rate, backend gross participation, deferred compensation, or residual-only deal. [ENUM-REF-CANDIDATE: union_scale|over_scale|flat_fee|episodic|weekly|daily|backend_participation|deferred|residual_only — 9 candidates stripped; promote to reference product] | Column compensation_type (STRING) in talent.compensation_structure' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyRate rdf:type rdf:Property ;
    rdfs:label 'Daily Rate' ;
    rdfs:comment 'The guaranteed daily compensation amount for talent engaged on a day-player or daily basis. Expressed in the contract currency. | Column daily_rate (DECIMAL(15,2)) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Compensation Amount' ;
    rdfs:comment 'The total amount of compensation deferred to a future payment date or contingent event (e.g., series pickup, profitability milestone). Expressed in the contract currency. | Column deferred_compensation_amount (DECIMAL(15,2)) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredPaymentTrigger rdf:type rdf:Property ;
    rdfs:label 'Deferred Payment Trigger' ;
    rdfs:comment 'The business event or milestone that triggers payment of deferred compensation (e.g., \'series_pickup\', \'profitability_threshold_met\', \'syndication_sale\', \'specific_date\'). | Column deferred_payment_trigger (STRING) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Multiplier' ;
    rdfs:comment 'The multiplier applied to the base rate for overtime hours worked (e.g., 1.5 for time-and-a-half, 2.0 for double-time). Null if overtime is not applicable. | Column overtime_multiplier (DECIMAL(5,2)) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationCeilingAmount rdf:type rdf:Property ;
    rdfs:label 'Participation Ceiling Amount' ;
    rdfs:comment 'Maximum participation amount cap' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationDefinitionType rdf:type rdf:Property ;
    rdfs:label 'Participation Definition Type' ;
    rdfs:comment 'Type of participation: gross, adjusted_gross, net' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationFloorAmount rdf:type rdf:Property ;
    rdfs:label 'Participation Floor Amount' ;
    rdfs:comment 'Minimum participation amount guaranteed' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationPercentage rdf:type rdf:Property ;
    rdfs:label 'Participation Percentage' ;
    rdfs:comment 'Percentage of participation in revenues' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pensionHealthRate rdf:type rdf:Property ;
    rdfs:label 'Pension Health Rate' ;
    rdfs:comment 'The percentage rate of gross compensation contributed to the guild pension and health plan (e.g., 0.185 for 18.5% SAG-AFTRA P&H). Used to calculate employer contributions. | Column pension_health_rate (DECIMAL(5,4)) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualBaseFormula rdf:type rdf:Property ;
    rdfs:label 'Residual Base Formula' ;
    rdfs:comment 'The formula or method used to calculate the residual base for reuse payments (e.g., \'initial_compensation\', \'applicable_minimum\', \'pro_rata_share\'). Defines how residuals are computed per guild rules. | Column residual_base_formula (STRING) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepUpTrigger rdf:type rdf:Property ;
    rdfs:label 'Step Up Trigger' ;
    rdfs:comment 'The condition or event that triggers an automatic increase in compensation (e.g., \'season_2_pickup\', \'episode_13_renewal\', \'ratings_threshold\'). Null if no step-up provision exists. | Column step_up_trigger (STRING) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureName rdf:type rdf:Property ;
    rdfs:label 'Structure Name' ;
    rdfs:comment 'Business-friendly name or label for this compensation structure (e.g., \'Series Regular Season 1\', \'Guest Star Rate Card\'). | Column structure_name (STRING) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureStatus rdf:type rdf:Property ;
    rdfs:label 'Structure Status' ;
    rdfs:comment 'Current lifecycle status of the compensation structure: draft (under negotiation), active (in force), amended (modified after execution), superseded (replaced by a newer structure), or terminated (no longer applicable). | Column structure_status (STRING) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsScope rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Scope' ;
    rdfs:comment 'Description of the media usage rights covered by this compensation structure (e.g., \'initial broadcast only\', \'all media in perpetuity\', \'theatrical and SVOD\', \'domestic free television\'). Defines what exploitation is covered by the base compensation. | Column usage_rights_scope (STRING) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeklyGuarantee rdf:type rdf:Property ;
    rdfs:label 'Weekly Guarantee' ;
    rdfs:comment 'The guaranteed weekly compensation amount for talent engaged on a weekly basis (e.g., series regulars, production staff). Expressed in the contract currency. | Column weekly_guarantee (DECIMAL(15,2)) in talent.compensation_structure' ;
    rdfs:domain ind:CompensationStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualEligibilityId rdf:type rdf:Property ;
    rdfs:label 'Residual Eligibility Id' ;
    rdfs:comment 'Unique identifier for the residual eligibility record. | Column residual_eligibility_id (BIGINT) in talent.residual_eligibility' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResidualEligibility .

ind:buyoutAmount rdf:type rdf:Property ;
    rdfs:label 'Buyout Amount' ;
    rdfs:comment 'The one-time payment amount paid to the talent in lieu of ongoing residual payments for specified uses, if a buyout was applied. | Column buyout_amount (DECIMAL(15,2)) in talent.residual_eligibility' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyoutApplied rdf:type rdf:Property ;
    rdfs:label 'Buyout Applied' ;
    rdfs:comment 'Indicates whether a residual buyout was negotiated and applied, eliminating ongoing residual payment obligations for specified uses. | Column buyout_applied (BOOLEAN) in talent.residual_eligibility' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Determination Date' ;
    rdfs:comment 'The date on which residual eligibility was determined and recorded for this talent and content asset. | Column eligibility_determination_date (DATE) in talent.residual_eligibility' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Status' ;
    rdfs:comment 'Current status of the residual eligibility determination for this talent-content-use combination. | Column eligibility_status (STRING) in talent.residual_eligibility' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityClauseApplies rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Clause Applies' ;
    rdfs:comment 'Indicates whether an exclusivity clause in the talent contract affects residual eligibility or payment terms for this content asset. | Column exclusivity_clause_applies (BOOLEAN) in talent.residual_eligibility' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthContributionApplicable rdf:type rdf:Property ;
    rdfs:label 'Health Contribution Applicable' ;
    rdfs:comment 'Indicates whether health and welfare contributions are required to be calculated and remitted based on this residual payment per guild agreement. | Column health_contribution_applicable (BOOLEAN) in talent.residual_eligibility' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthContributionRate rdf:type rdf:Property ;
    rdfs:label 'Health Contribution Rate' ;
    rdfs:comment 'The percentage rate applied to the residual payment for health and welfare fund contribution calculation. | Column health_contribution_rate (DECIMAL(5,2)) in talent.residual_eligibility' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumResidualThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Residual Threshold' ;
    rdfs:comment 'The minimum payment amount below which residuals are not processed or paid, as defined by guild rules or contract terms. | Column minimum_residual_threshold (DECIMAL(15,2)) in talent.residual_eligibility' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Participation Eligible Flag' ;
    rdfs:comment 'Indicates if talent is eligible for participation beyond residuals' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pensionContributionApplicable rdf:type rdf:Property ;
    rdfs:label 'Pension Contribution Applicable' ;
    rdfs:comment 'Indicates whether pension contributions are required to be calculated and remitted based on this residual payment per guild agreement. | Column pension_contribution_applicable (BOOLEAN) in talent.residual_eligibility' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pensionContributionRate rdf:type rdf:Property ;
    rdfs:label 'Pension Contribution Rate' ;
    rdfs:comment 'The percentage rate applied to the residual payment for pension fund contribution calculation. | Column pension_contribution_rate (DECIMAL(5,2)) in talent.residual_eligibility' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Residual Base Amount' ;
    rdfs:comment 'The base monetary amount used as the foundation for residual calculation, typically derived from the original compensation or a guild-defined minimum. | Column residual_base_amount (DECIMAL(15,2)) in talent.residual_eligibility' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualFormulaType rdf:type rdf:Property ;
    rdfs:label 'Residual Formula Type' ;
    rdfs:comment 'The specific residual calculation formula applicable to this eligibility record, determined by guild agreement, content type, and distribution channel. | Column residual_formula_type (STRING) in talent.residual_eligibility' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualPercentage rdf:type rdf:Property ;
    rdfs:label 'Residual Percentage' ;
    rdfs:comment 'The percentage of the base amount payable as residual for this specific use, as defined by guild agreement or contract negotiation. | Column residual_percentage (DECIMAL(5,2)) in talent.residual_eligibility' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rightslineIntegrationCode rdf:type rdf:Property ;
    rdfs:label 'Rightsline Integration Code' ;
    rdfs:comment 'External identifier used to link this residual eligibility record to the Rightsline rights and royalties management system for automated royalty calculation workflow. | Column rightsline_integration_code (STRING) in talent.residual_eligibility' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPayablesReference rdf:type rdf:Property ;
    rdfs:label 'Sap Payables Reference' ;
    rdfs:comment 'Reference identifier linking this residual eligibility to SAP S/4HANA accounts payable processing for payment execution. | Column sap_payables_reference (STRING) in talent.residual_eligibility' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'The user or system identifier of the person or process that last updated this residual eligibility record. | Column updated_by (STRING) in talent.residual_eligibility' ;
    rdfs:domain ind:ResidualEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useType rdf:type rdf:Property ;
    rdfs:label 'Use Type' ;
    rdfs:comment 'The type of content usage that triggers residual payment eligibility (Rerun, Foreign Broadcast, Home Video, Subscription Video On Demand, Advertising-Supported Video On Demand, Transactional Video On Demand, Free Ad-Supported Streaming Television, Theatrical, Syndication, or Clip Use). [ENUM-REF-CANDIDATE: Rerun|Foreign Broadcast|Home Video|SVOD|AVOD|TVOD|FAST|Theatrical|Syndication|Clip Use — 10 candidates stripped; promote to reference product] | Column use_type (STRING) in talent.residual_eligibility' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualPaymentId rdf:type rdf:Property ;
    rdfs:label 'Residual Payment Id' ;
    rdfs:comment 'Unique identifier for the residual payment transaction. | Column residual_payment_id (BIGINT) in talent.residual_payment' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:achTraceNumber rdf:type rdf:Property ;
    rdfs:label 'Ach Trace Number' ;
    rdfs:comment 'The ACH trace number if the payment method is ACH or direct deposit, used for reconciliation and audit. | Column ach_trace_number (STRING) in talent.residual_payment' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Agent Commission Amount' ;
    rdfs:comment 'The agent or manager commission amount deducted from the residual payment, if applicable. | Column agent_commission_amount (DECIMAL(15,2)) in talent.residual_payment' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditReportDate rdf:type rdf:Property ;
    rdfs:label 'Audit Report Date' ;
    rdfs:comment 'The date on which this residual payment was included in a guild audit report. | Column audit_report_date (DATE) in talent.residual_payment' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditReportFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Report Flag' ;
    rdfs:comment 'Indicates whether this residual payment has been included in a guild audit report (SAG-AFTRA, WGA, DGA). | Column audit_report_flag (BOOLEAN) in talent.residual_payment' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'The check number if the payment method is check, used for reconciliation and audit. | Column check_number (STRING) in talent.residual_payment' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exhibitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Exhibition End Date' ;
    rdfs:comment 'The end date of the exhibition period for which this residual is calculated. | Column exhibition_end_date (DATE) in talent.residual_payment' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exhibitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Exhibition Start Date' ;
    rdfs:comment 'The start date of the exhibition period for which this residual is calculated. | Column exhibition_start_date (DATE) in talent.residual_payment' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossResidualAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Residual Amount' ;
    rdfs:comment 'The gross residual amount calculated before deductions, in the payment currency. | Column gross_residual_amount (DECIMAL(15,2)) in talent.residual_payment' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the residual payment (e.g., USD, GBP, EUR). | Column payment_currency_code (STRING) in talent.residual_payment' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNotes rdf:type rdf:Property ;
    rdfs:label 'Payment Notes' ;
    rdfs:comment 'Free-text notes or comments related to this residual payment, including special circumstances, adjustments, or exceptions. | Column payment_notes (STRING) in talent.residual_payment' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Business identifier for the residual payment, used for external reference and reconciliation. | Column payment_number (STRING) in talent.residual_payment' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pensionHealthAmount rdf:type rdf:Property ;
    rdfs:label 'Pension Health Amount' ;
    rdfs:comment 'The pension and health contribution amount deducted from the gross residual, as required by guild agreements. | Column pension_health_amount (DECIMAL(15,2)) in talent.residual_payment' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceAdviceSentDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Sent Date' ;
    rdfs:comment 'The date on which the remittance advice was sent to the talent. | Column remittance_advice_sent_date (DATE) in talent.residual_payment' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remittanceAdviceSentFlag rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Sent Flag' ;
    rdfs:comment 'Indicates whether a remittance advice document was sent to the talent for this payment. | Column remittance_advice_sent_flag (BOOLEAN) in talent.residual_payment' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wireReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Wire Reference Number' ;
    rdfs:comment 'The wire transfer reference number if the payment method is wire transfer, used for reconciliation and audit. | Column wire_reference_number (STRING) in talent.residual_payment' ;
    rdfs:domain ind:ResidualPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longFormContractId rdf:type rdf:Property ;
    rdfs:label 'Long Form Contract Id' ;
    rdfs:comment 'Reference to the executed long-form talent contract that supersedes this deal memo. Null if the long-form contract has not yet been executed. | Column long_form_contract_id (BIGINT) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:productionTitleId rdf:type rdf:Property ;
    rdfs:label 'Production Title Id' ;
    rdfs:comment 'Reference to the production title (series, episode, film, special) for which the talent is engaged. | Column production_title_id (BIGINT) in content.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:sourceOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Source Opportunity Id' ;
    rdfs:comment 'The Salesforce Media Cloud opportunity or proposal record identifier from which this deal memo was generated. | Column source_opportunity_id (BIGINT) in sales.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:compensationAmount rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount' ;
    rdfs:comment 'The primary monetary compensation amount agreed in the deal memo (e.g., total fee, per-episode rate, or guaranteed minimum). | Column compensation_amount (DECIMAL(15,2)) in talent.deal_memo' ;
    rdfs:domain ind:Talent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationSummary rdf:type rdf:Property ;
    rdfs:label 'Compensation Summary' ;
    rdfs:comment 'High-level summary of the compensation structure agreed in the deal memo (e.g., per-episode fee, flat fee, day rate, backend participation). Detailed breakdowns are captured in the long-form contract. | Column compensation_summary (STRING) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countersignedDate rdf:type rdf:Property ;
    rdfs:label 'Countersigned Date' ;
    rdfs:comment 'The date on which the deal memo was countersigned by both the talent (or agent) and the production company, making it a binding interim agreement. Null if not yet countersigned. | Column countersigned_date (DATE) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealDate rdf:type rdf:Property ;
    rdfs:label 'Deal Date' ;
    rdfs:comment 'The date on which the deal terms were verbally agreed or the deal memo was initially drafted. | Column deal_date (DATE) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Deal Memo Number' ;
    rdfs:comment 'Externally-known unique business identifier for the deal memo, typically generated by the CRM or legal system. | Column deal_memo_number (STRING) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealMemoStatus rdf:type rdf:Property ;
    rdfs:label 'Deal Memo Status' ;
    rdfs:comment 'Current lifecycle status of the deal memo: draft (under negotiation), countersigned (binding interim agreement), superseded_by_long_form (replaced by executed contract), expired (lapsed without execution), cancelled (deal fell through). | Column deal_memo_status (STRING) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementEndDate rdf:type rdf:Property ;
    rdfs:label 'Engagement End Date' ;
    rdfs:comment 'The date on which the talent engagement is scheduled to end. Null for open-ended or option-based engagements. | Column engagement_end_date (DATE) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementStartDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Date' ;
    rdfs:comment 'The date on which the talent engagement is scheduled to begin (first day of work, rehearsal, or availability). | Column engagement_start_date (DATE) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivitySummary rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Summary' ;
    rdfs:comment 'High-level summary of exclusivity terms (e.g., exclusive to network during production, non-exclusive, first-look, holdback period). Detailed clauses are in the long-form contract. | Column exclusivity_summary (STRING) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'Username or identifier of the user who last modified the deal memo record. | Column last_modified_by_user (STRING) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionTerms rdf:type rdf:Property ;
    rdfs:label 'Option Terms' ;
    rdfs:comment 'Summary of any option clauses (e.g., network option for additional seasons, talent option to extend, mutual option). Null if no options are included. | Column option_terms (STRING) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleFunction rdf:type rdf:Property ;
    rdfs:label 'Role Function' ;
    rdfs:comment 'The specific role or function the talent will perform (e.g., Lead Actor, Director, Writer, Executive Producer, Host, Correspondent, Camera Operator). | Column role_function (STRING) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededDate rdf:type rdf:Property ;
    rdfs:label 'Superseded Date' ;
    rdfs:comment 'The date on which the deal memo was superseded by the execution of a long-form contract. Null if not yet superseded. | Column superseded_date (DATE) in talent.deal_memo' ;
    rdfs:domain ind:DealMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aboveTheLineFlag rdf:type rdf:Property ;
    rdfs:label 'Above The Line Flag' ;
    rdfs:comment 'Indicates whether this role is classified as above-the-line (creative principals: actors, directors, writers, producers) or below-the-line (technical crew and support staff). Impacts budget allocation and residual calculations. | Column above_the_line_flag (BOOLEAN) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appearanceCount rdf:type rdf:Property ;
    rdfs:label 'Appearance Count' ;
    rdfs:comment 'Total number of episodes, segments, or appearances in which this talent role is featured. Used for episodic and recurring roles. | Column appearance_count (INT) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:category rdf:type rdf:Property ;
    rdfs:label 'Category' ;
    rdfs:comment 'Classification of the role type indicating the nature and scope of the talent\'s engagement. Determines compensation structure, credit placement, and residual eligibility. [ENUM-REF-CANDIDATE: series_regular|recurring|guest_star|day_player|featured_extra|host|correspondent|narrator|voice_artist|director|writer|showrunner|executive_producer|line_producer|cinematographer|editor|composer|production_designer|costume_designer|makeup_artist|stunt_coordinator|other — promote to reference product] | Column role_category (STRING) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characterName rdf:type rdf:Property ;
    rdfs:label 'Character Name' ;
    rdfs:comment 'The name of the character portrayed by the talent for on-screen roles. Null for off-screen roles such as crew, directors, or producers. | Column character_name (STRING) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditText rdf:type rdf:Property ;
    rdfs:label 'Credit Text' ;
    rdfs:comment 'The exact text of the credit as it appears on-screen or in marketing materials, including any special formatting or possessory credits (e.g., \'A Film By\', \'Created By\'). | Column credit_text (STRING) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeScopeEnd rdf:type rdf:Property ;
    rdfs:label 'Episode Scope End' ;
    rdfs:comment 'The last episode number in which this talent role appears. Null indicates ongoing engagement or single-episode appearance. | Column episode_scope_end (INT) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeScopeStart rdf:type rdf:Property ;
    rdfs:label 'Episode Scope Start' ;
    rdfs:comment 'The first episode number in which this talent role appears. Used for episodic content to define the scope of the talent\'s engagement. | Column episode_scope_start (INT) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Eligible Flag' ;
    rdfs:comment 'Indicates whether this role is eligible for residual payments based on subsequent distribution, reuse, or syndication of the content. Determined by guild agreements and contract terms. | Column residual_eligible_flag (BOOLEAN) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualRateCode rdf:type rdf:Property ;
    rdfs:label 'Residual Rate Code' ;
    rdfs:comment 'Code identifying the residual payment rate schedule applicable to this role based on guild agreements, role category, and distribution windows. | Column residual_rate_code (STRING) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleStatus rdf:type rdf:Property ;
    rdfs:label 'Role Status' ;
    rdfs:comment 'Current lifecycle status of the talent role assignment indicating the stage of engagement from negotiation through completion. [ENUM-REF-CANDIDATE: confirmed|tentative|in_negotiation|contracted|active|completed|cancelled|suspended — 8 candidates stripped; promote to reference product] | Column role_status (STRING) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Screen Time Minutes' ;
    rdfs:comment 'Total on-screen time in minutes for this talent role across all appearances. Used for on-screen talent to measure prominence and for residual calculations. | Column screen_time_minutes (DECIMAL(8,2)) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stuntDoubleFlag rdf:type rdf:Property ;
    rdfs:label 'Stunt Double Flag' ;
    rdfs:comment 'Indicates whether this role involves stunt work or if a stunt double is used for this character. Impacts insurance, safety protocols, and credit attribution. | Column stunt_double_flag (BOOLEAN) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageRightsDurationYears rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Duration Years' ;
    rdfs:comment 'Number of years for which usage rights are granted. Null indicates perpetual rights. | Column usage_rights_duration_years (INT) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageRightsMedia rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Media' ;
    rdfs:comment 'Media platforms and formats for which usage rights are granted (e.g., \'Theatrical, Home Video, Streaming, Broadcast TV\'). | Column usage_rights_media (STRING) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsTerritory rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Territory' ;
    rdfs:comment 'Geographic territories in which the content featuring this talent role may be distributed and exploited (e.g., \'Worldwide\', \'North America\', \'USA and Canada\'). | Column usage_rights_territory (STRING) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voiceOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Voice Only Flag' ;
    rdfs:comment 'Indicates whether this is a voice-only role (voice-over, narration, animation, ADR) with no on-screen physical appearance by the talent. | Column voice_only_flag (BOOLEAN) in talent.role' ;
    rdfs:domain ind:Role ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Classification of the representation entity: talent agency (licensed to procure employment), literary agency (represents writers), management company (career guidance), law firm (legal representation), publicity firm (public relations), or hybrid (multiple services). | Column agency_type (STRING) in talent.talent_agency' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'The trade name or doing-business-as name under which the agency operates, if different from the legal name. | Column dba_name (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'The date on which the talent agency was originally established or incorporated. | Column established_date (DATE) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'The fax number for the agency, used for contract transmission and official correspondence in jurisdictions where fax is still required. | Column fax_number (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Effective Date' ;
    rdfs:comment 'The date on which the SAG-AFTRA franchise agreement became effective for this agency. | Column franchise_effective_date (DATE) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:franchiseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Expiration Date' ;
    rdfs:comment 'The date on which the current SAG-AFTRA franchise agreement expires and must be renewed. | Column franchise_expiration_date (DATE) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:franchiseNumber rdf:type rdf:Property ;
    rdfs:label 'Franchise Number' ;
    rdfs:comment 'The unique franchise identification number issued by SAG-AFTRA to franchised talent agencies. | Column franchise_number (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseStatus rdf:type rdf:Property ;
    rdfs:label 'Franchise Status' ;
    rdfs:comment 'Indicates whether the agency holds a valid SAG-AFTRA franchise agreement, which authorizes the agency to represent union talent. Franchised agencies agree to standard commission rates and contract terms. | Column franchise_status (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'License Effective Date' ;
    rdfs:comment 'The date on which the state talent agency license became effective. | Column license_effective_date (DATE) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'License Expiration Date' ;
    rdfs:comment 'The date on which the state talent agency license expires and must be renewed. | Column license_expiration_date (DATE) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseState rdf:type rdf:Property ;
    rdfs:label 'License State' ;
    rdfs:comment 'The state or province that issued the talent agency license. Use standard two-letter state/province codes. | Column license_state (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'The job title or role of the primary contact person (e.g., President, Partner, Agent, Business Affairs Manager). | Column primary_contact_title (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'The primary email address for official correspondence, contract delivery, and residual payment notifications. | Column primary_email (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'The primary telephone number for the agency, including country and area codes. | Column primary_phone (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterSize rdf:type rdf:Property ;
    rdfs:label 'Roster Size' ;
    rdfs:comment 'The approximate number of talent clients currently represented by the agency. Used for agency scale assessment and negotiation context. | Column roster_size (INT) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialization rdf:type rdf:Property ;
    rdfs:label 'Specialization' ;
    rdfs:comment 'The primary area of talent specialization or focus for the agency (e.g., film and television actors, commercial talent, voice-over artists, writers, directors, below-the-line crew, music artists). Free-text field to accommodate multiple specializations. | Column specialization (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Standard Commission Rate' ;
    rdfs:comment 'The standard commission rate percentage that the agency charges for talent representation, typically 10% for franchised agencies under SAG-AFTRA rules. Expressed as a percentage (e.g., 10.00 for 10%). | Column standard_commission_rate (DECIMAL(5,2)) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statusEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Status Effective Date' ;
    rdfs:comment 'The date on which the current status became effective. | Column status_effective_date (DATE) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:talentAgencyStatus rdf:type rdf:Property ;
    rdfs:label 'Talent Agency Status' ;
    rdfs:comment 'The current operational status of the talent agency: active (currently representing talent), inactive (not currently operating), suspended (temporarily not authorized), pending_verification (under review), or dissolved (permanently closed). | Column talent_agency_status (STRING) in talent.talent_agency' ;
    rdfs:domain ind:TalentAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'The tax identification number (EIN in the US, VAT number in EU) for the agency, used for tax reporting and residual payment processing. | Column tax_identifier (STRING) in talent.talent_agency' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'The primary website URL for the talent agency, used for public information and talent roster visibility. | Column website_url (STRING) in talent.talent_agency' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentContactEmail rdf:type rdf:Property ;
    rdfs:label 'Agent Contact Email' ;
    rdfs:comment 'Primary email address for the agent or representative, used for deal negotiation and residual routing communications. | Column agent_contact_email (STRING) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentContactPhone rdf:type rdf:Property ;
    rdfs:label 'Agent Contact Phone' ;
    rdfs:comment 'Primary phone number for the agent or representative. | Column agent_contact_phone (STRING) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentName rdf:type rdf:Property ;
    rdfs:label 'Agent Name' ;
    rdfs:comment 'Full name of the individual agent, manager, or attorney assigned as primary contact for this representation. | Column agent_name (STRING) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionCapAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Cap Amount' ;
    rdfs:comment 'Maximum commission amount per engagement or per year, if a cap is specified in the agreement. Null if no cap applies. | Column commission_cap_amount (DECIMAL(15,2)) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionPercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Percentage' ;
    rdfs:comment 'Percentage of talent earnings paid to the representative as commission (typically 10% for agents, 15% for managers per industry standards). | Column commission_percentage (DECIMAL(5,2)) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDocumentUri rdf:type rdf:Property ;
    rdfs:label 'Contract Document Uri' ;
    rdfs:comment 'URI or file path to the signed representation agreement contract document stored in the Media Asset Management (MAM) system or document repository. | Column contract_document_uri (STRING) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildFranchiseFlag rdf:type rdf:Property ;
    rdfs:label 'Guild Franchise Flag' ;
    rdfs:comment 'Indicates whether the agency or representative is franchised by a talent guild (SAG-AFTRA, WGA, DGA). Franchised agents must comply with guild-mandated commission caps and contract terms. | Column guild_franchise_flag (BOOLEAN) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether the agreement includes an automatic renewal option or requires explicit renegotiation at expiration. | Column renewal_option_flag (BOOLEAN) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:representationAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Representation Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the representation agreement: active (in force), expired (end date reached), terminated (ended early by either party), suspended (temporarily inactive), or pending (signed but not yet effective). | Column representation_agreement_status (STRING) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representationType rdf:type rdf:Property ;
    rdfs:label 'Representation Type' ;
    rdfs:comment 'Classification of the representation relationship: exclusive agent (sole representation), co-agent (shared representation), manager (career management), entertainment attorney (legal counsel), business manager (financial management), or publicist (public relations). | Column representation_type (STRING) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRoutingFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Routing Flag' ;
    rdfs:comment 'Indicates whether residual payments for work performed during this representation period should be routed through this representative for commission deduction. | Column residual_routing_flag (BOOLEAN) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeOfServices rdf:type rdf:Property ;
    rdfs:label 'Scope Of Services' ;
    rdfs:comment 'Detailed description of services the representative will provide: deal negotiation, career guidance, audition scheduling, contract review, brand partnerships, etc. | Column scope_of_services (STRING) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingDate rdf:type rdf:Property ;
    rdfs:label 'Signing Date' ;
    rdfs:comment 'Date when the representation agreement was signed by both parties. | Column signing_date (DATE) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the representation agreement (commonly 30, 60, or 90 days). | Column termination_notice_period_days (INT) in talent.representation_agreement' ;
    rdfs:domain ind:RepresentationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearedMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Cleared Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Talent clearances are often asset-specific (theatrical cut vs TV edit, domestic vs international versions, trailer vs feature). Different assets may require separate clearances based on usage rights,  | Column cleared_media_asset_id (BIGINT) in mediaasset.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:clearedSeasonId rdf:type rdf:Property ;
    rdfs:label 'Cleared Season Id' ;
    rdfs:comment 'Foreign key linking to content.season. Business justification: Season-level talent clearance for broadcast scheduling and international distribution — clearance teams track whether talent is cleared for each season\'s broadcast window separately, particularly for ' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Season .

ind:clearanceType rdf:type rdf:Property ;
    rdfs:label 'Clearance Type' ;
    rdfs:comment 'Category of clearance being requested based on the intended usage channel and distribution method. | Column clearance_type (STRING) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalTerms rdf:type rdf:Property ;
    rdfs:label 'Conditional Terms' ;
    rdfs:comment 'Specific conditions, restrictions, or requirements that must be met for the clearance to remain valid. | Column conditional_terms (STRING) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityConflictFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Conflict Flag' ;
    rdfs:comment 'Indicates whether the requested usage conflicts with existing exclusivity clauses in the talent contract. | Column exclusivity_conflict_flag (BOOLEAN) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantedBy rdf:type rdf:Property ;
    rdfs:label 'Granted By' ;
    rdfs:comment 'Name or identifier of the individual or department who authorized the clearance. | Column granted_by (STRING) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantedDate rdf:type rdf:Property ;
    rdfs:label 'Granted Date' ;
    rdfs:comment 'Date when the clearance was officially approved and granted for the specified usage. | Column granted_date (DATE) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guildClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Guild Clearance Required Flag' ;
    rdfs:comment 'Indicates whether guild or union clearance is required based on collective bargaining agreement terms. | Column guild_clearance_required_flag (BOOLEAN) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guildClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Guild Clearance Status' ;
    rdfs:comment 'Current status of guild or union clearance verification for this usage. | Column guild_clearance_status (STRING) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Guild Reference Number' ;
    rdfs:comment 'Reference or tracking number provided by the guild or union for this clearance request. | Column guild_reference_number (STRING) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Date' ;
    rdfs:comment 'Date when the legal department completed their review of the clearance request. | Column legal_review_date (DATE) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:likenessUsageFlag rdf:type rdf:Property ;
    rdfs:label 'Likeness Usage Flag' ;
    rdfs:comment 'Indicates whether the clearance includes usage of the talent\'s physical likeness or image. | Column likeness_usage_flag (BOOLEAN) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nameUsageFlag rdf:type rdf:Property ;
    rdfs:label 'Name Usage Flag' ;
    rdfs:comment 'Indicates whether the clearance includes usage of the talent\'s name in promotional or marketing materials. | Column name_usage_flag (BOOLEAN) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceUsageFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Usage Flag' ;
    rdfs:comment 'Indicates whether the clearance includes usage of the talent\'s recorded performance or voice. | Column performance_usage_flag (BOOLEAN) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date when the clearance request was initiated by the production or rights team. | Column request_date (DATE) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residualPaymentTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Payment Triggered Flag' ;
    rdfs:comment 'Indicates whether this clearance triggers residual payment obligations under guild agreements. | Column residual_payment_triggered_flag (BOOLEAN) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewedByLegalFlag rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Legal Flag' ;
    rdfs:comment 'Indicates whether the clearance request has been reviewed and approved by the legal department. | Column reviewed_by_legal_flag (BOOLEAN) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:talentApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Talent Approval Date' ;
    rdfs:comment 'Date when the talent provided their explicit approval or consent for the specified usage. | Column talent_approval_date (DATE) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:talentApprovalReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Talent Approval Received Flag' ;
    rdfs:comment 'Indicates whether the required talent approval has been obtained and documented. | Column talent_approval_received_flag (BOOLEAN) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:talentApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Talent Approval Required Flag' ;
    rdfs:comment 'Indicates whether explicit talent consent or approval is required before usage can proceed. | Column talent_approval_required_flag (BOOLEAN) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageCategory rdf:type rdf:Property ;
    rdfs:label 'Usage Category' ;
    rdfs:comment 'Classification of the intended usage based on broadcast and distribution business models. | Column usage_category (STRING) in talent.talent_clearance' ;
    rdfs:domain ind:Clearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingProposalId rdf:type rdf:Property ;
    rdfs:label 'Originating Proposal Id' ;
    rdfs:comment 'Foreign key linking to sales.proposal. Business justification: An ad_order is the execution artifact created when a proposal is accepted and signed. Linking ad_order back to its originating proposal enables full deal lifecycle traceability: opportunity → proposal' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Proposal .

ind:salesAgencyId rdf:type rdf:Property ;
    rdfs:label 'Sales Agency Id' ;
    rdfs:comment 'Reference to the advertising agency representing the advertiser. Nullable if direct advertiser purchase. Links to agency master record. | Column sales_agency_id (BIGINT) in sales.ad_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesAgency .

ind:salesforceOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Id' ;
    rdfs:comment 'External reference to the originating sales opportunity in Salesforce Media Cloud CRM. 15 or 18 character Salesforce record ID. | Column salesforce_opportunity_id (BIGINT) in sales.ad_order' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:affidavitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Affidavit Required Flag' ;
    rdfs:comment 'Indicates whether proof of broadcast affidavits must be provided to the advertiser. True = affidavits required; False = not required. Affidavits document actual air times and are often required for political advertising. | Column affidavit_required_flag (BOOLEAN) in sales.ad_order' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'Agency commission rate as a percentage of gross order value. Standard industry rate is 15%. Applied to calculate net revenue. | Column commission_rate (DECIMAL(5,2)) in sales.ad_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the advertising order was confirmed by the advertiser or agency. Marks transition from pending to confirmed status. | Column confirmed_timestamp (TIMESTAMP) in sales.ad_order' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contractedCpm rdf:type rdf:Property ;
    rdfs:label 'Contracted Cpm' ;
    rdfs:comment 'Contracted Cost Per Mille (cost per thousand impressions) for this advertising order. Key pricing metric for media buying. | Column contracted_cpm (DECIMAL(10,2)) in sales.ad_order' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedCprp rdf:type rdf:Property ;
    rdfs:label 'Contracted Cprp' ;
    rdfs:comment 'Contracted Cost Per Rating Point. Pricing metric calculated as total cost divided by GRP. Used for market efficiency comparison. | Column contracted_cprp (DECIMAL(10,2)) in sales.ad_order' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daypartMix rdf:type rdf:Property ;
    rdfs:label 'Daypart Mix' ;
    rdfs:comment 'Distribution of advertising spots across broadcast dayparts (time segments of broadcast day). Examples: Prime (8pm-11pm), Early Morning (6am-9am), Late Night (11pm-2am). Stored as comma-separated daypart allocations. | Column daypart_mix (STRING) in sales.ad_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Total discount percentage applied to this order. May include volume discounts, promotional discounts, or negotiated rate reductions. | Column discount_percentage (DECIMAL(5,2)) in sales.ad_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flightEndDate rdf:type rdf:Property ;
    rdfs:label 'Flight End Date' ;
    rdfs:comment 'Last date the advertising campaign is scheduled to air. End of the contracted broadcast period. | Column flight_end_date (DATE) in sales.ad_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flightStartDate rdf:type rdf:Property ;
    rdfs:label 'Flight Start Date' ;
    rdfs:comment 'First date the advertising campaign is scheduled to air. Beginning of the contracted broadcast period. | Column flight_start_date (DATE) in sales.ad_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'Designated Market Area (DMA) or geographic market code where the advertising will air. Used for Nielsen ratings alignment and regional pricing. | Column market_code (STRING) in sales.ad_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mmmAdstockDecayRate rdf:type rdf:Property ;
    rdfs:label 'Mmm Adstock Decay Rate' ;
    rdfs:comment 'Rate at which advertising effect decays over time for MMM calculations' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mmmChannelContribution rdf:type rdf:Property ;
    rdfs:label 'Mmm Channel Contribution' ;
    rdfs:comment 'Marketing Mix Model estimated contribution of this channel to conversions' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mmmSaturationPoint rdf:type rdf:Property ;
    rdfs:label 'Mmm Saturation Point' ;
    rdfs:comment 'Estimated spend level at which diminishing returns begin for this channel' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Net revenue value after agency commissions, discounts, and adjustments. Amount recognized for revenue reporting. | Column net_order_value (DECIMAL(18,2)) in sales.ad_order' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Free-text notes and special instructions for this advertising order. May include trafficking instructions, creative specifications, or client preferences. | Column order_notes (STRING) in sales.ad_order' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:politicalAdFlag rdf:type rdf:Property ;
    rdfs:label 'Political Ad Flag' ;
    rdfs:comment 'Indicates whether this order contains political advertising content. True = political advertising; False = commercial advertising. Political ads have special FCC disclosure and equal-time requirements. | Column political_ad_flag (BOOLEAN) in sales.ad_order' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'Industry classification of the advertised product or service (e.g., automotive, pharmaceutical, retail, financial services). Used for content clearance and regulatory compliance. | Column product_category (STRING) in sales.ad_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGrp rdf:type rdf:Property ;
    rdfs:label 'Target Grp' ;
    rdfs:comment 'Target Gross Rating Points contracted for this order. GRP = Reach × Frequency, measuring total audience delivery weight. Used for campaign performance evaluation. | Column target_grp (DECIMAL(10,2)) in sales.ad_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTrp rdf:type rdf:Property ;
    rdfs:label 'Target Trp' ;
    rdfs:comment 'Target Rating Points for specific demographic audience. TRP measures delivery against a defined target audience segment rather than total audience. | Column target_trp (DECIMAL(10,2)) in sales.ad_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalContractedValue rdf:type rdf:Property ;
    rdfs:label 'Total Contracted Value' ;
    rdfs:comment 'Total monetary value of the advertising order across all spots and placements. Gross revenue before agency commissions and discounts. | Column total_contracted_value (DECIMAL(18,2)) in sales.ad_order' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSpotCount rdf:type rdf:Property ;
    rdfs:label 'Total Spot Count' ;
    rdfs:comment 'Total number of advertising spots (commercial airings) contracted in this order across all placements and dayparts. | Column total_spot_count (INT) in sales.ad_order' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wideOrbitOrderReference rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Order Reference' ;
    rdfs:comment 'External reference to the corresponding order record in Wide Orbit traffic and billing system. Used for cross-system reconciliation and affidavit generation. | Column wide_orbit_order_reference (STRING) in sales.ad_order' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makegoodForLineAdOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Makegood For Line Ad Order Line Id' ;
    rdfs:comment 'Reference to the original ad order line that this line is compensating for (if this is a makegood spot). Null if not a makegood. | Column makegood_for_line_id (BIGINT) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdOrderLine .

ind:actualGrpDelivered rdf:type rdf:Property ;
    rdfs:label 'Actual Grp Delivered' ;
    rdfs:comment 'Actual Gross Rating Points (GRP) delivered based on Nielsen measurement. Used for campaign performance analysis and makegood calculation. | Column actual_grp_delivered (DECIMAL(10,2)) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualImpressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Actual Impressions Delivered' ;
    rdfs:comment 'Actual number of impressions delivered for this line. Sourced from DAI (Dynamic Ad Insertion) systems or CDN (Content Delivery Network) logs for digital campaigns. | Column actual_impressions_delivered (BIGINT) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSpotsAired rdf:type rdf:Property ;
    rdfs:label 'Actual Spots Aired' ;
    rdfs:comment 'Actual number of spots that successfully aired for this line. Populated from affidavit reconciliation. Used for billing and makegood determination. | Column actual_spots_aired (INT) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionModelType rdf:type rdf:Property ;
    rdfs:label 'Attribution Model Type' ;
    rdfs:comment 'Type of attribution model applied (first-touch, last-touch, linear, time-decay, position-based, data-driven)' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionWeight rdf:type rdf:Property ;
    rdfs:label 'Attribution Weight' ;
    rdfs:comment 'Fractional credit assigned to this touchpoint in multi-touch attribution' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveSeparationCategory rdf:type rdf:Property ;
    rdfs:label 'Competitive Separation Category' ;
    rdfs:comment 'Product or industry category for competitive adjacency restrictions. Prevents competing advertisers from airing in the same pod. | Column competitive_separation_category (STRING) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedGrp rdf:type rdf:Property ;
    rdfs:label 'Contracted Grp' ;
    rdfs:comment 'Target Gross Rating Points (GRP) contracted for this line. GRP measures total audience reach multiplied by frequency. | Column contracted_grp (DECIMAL(10,2)) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedImpressions rdf:type rdf:Property ;
    rdfs:label 'Contracted Impressions' ;
    rdfs:comment 'Total number of impressions (individual ad views) contracted for this line item. Used for digital and OTT (Over-The-Top) campaigns. | Column contracted_impressions (BIGINT) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedSpots rdf:type rdf:Property ;
    rdfs:label 'Contracted Spots' ;
    rdfs:comment 'Total number of ad spots contracted for this line item. Represents the quantity commitment. | Column contracted_spots (INT) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedTrp rdf:type rdf:Property ;
    rdfs:label 'Contracted Trp' ;
    rdfs:comment 'Target Rating Points (TRP) contracted for this line. TRP measures reach within a specific demographic target. | Column contracted_trp (DECIMAL(10,2)) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionPathPosition rdf:type rdf:Property ;
    rdfs:label 'Conversion Path Position' ;
    rdfs:comment 'Position of this touchpoint in the customer conversion path' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:copySplitRule rdf:type rdf:Property ;
    rdfs:label 'Copy Split Rule' ;
    rdfs:comment 'Rules defining how multiple creative versions should be split across the contracted spots (e.g., 50/50, 70/30). Used for A/B testing or creative variation. | Column copy_split_rule (STRING) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Total revenue amount for this line item (unit rate × contracted spots). Base amount before discounts or adjustments. | Column line_total_amount (DECIMAL(15,2)) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionPreference rdf:type rdf:Property ;
    rdfs:label 'Position Preference' ;
    rdfs:comment 'Preferred position within the ad pod (group of ads in a break). Premium positions command higher rates. | Column position_preference (STRING) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue for this line is recognized for financial reporting. Typically aligned with air date or campaign completion. | Column revenue_recognition_date (DATE) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rotationInstructions rdf:type rdf:Property ;
    rdfs:label 'Rotation Instructions' ;
    rdfs:comment 'Instructions for rotating multiple creatives within this line (e.g., even rotation, weighted rotation, sequential). Guides playout system behavior. | Column rotation_instructions (STRING) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingNotes rdf:type rdf:Property ;
    rdfs:label 'Special Handling Notes' ;
    rdfs:comment 'Free-text instructions for special handling requirements (e.g., live read, sponsorship billboard, product integration). Communicated to playout operators. | Column special_handling_notes (STRING) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchpointSequenceCode rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Sequence Code' ;
    rdfs:comment 'Identifier linking touchpoints in a conversion path for attribution analysis' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traffickingNotes rdf:type rdf:Property ;
    rdfs:label 'Trafficking Notes' ;
    rdfs:comment 'Internal notes for trafficking team regarding execution details, creative delivery status, or special coordination requirements. | Column trafficking_notes (STRING) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makegoodEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Makegood Eligible Flag' ;
    rdfs:comment 'Indicates whether this campaign is eligible for makegood compensatory ad spots if contracted delivery targets are not met. | Column makegood_eligible_flag (BOOLEAN) in sales.campaign' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketType rdf:type rdf:Property ;
    rdfs:label 'Market Type' ;
    rdfs:comment 'Geographic market scope classification for the campaign. | Column market_type (STRING) in sales.campaign' ;
    rdfs:domain ind:SalesCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productBrand rdf:type rdf:Property ;
    rdfs:label 'Product Brand' ;
    rdfs:comment 'The product, service, or brand being advertised in this campaign. | Column product_brand (STRING) in sales.campaign' ;
    rdfs:domain ind:SalesCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Programmatic Enabled Flag' ;
    rdfs:comment 'Flag indicating programmatic campaign' ;
    rdfs:domain ind:SalesCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'The sales channel through which the campaign was sold (upfront advance sales, scatter last-minute, programmatic automated, direct negotiated, or sponsorship). | Column sales_channel (STRING) in sales.campaign' ;
    rdfs:domain ind:SalesCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceCampaignReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Campaign Reference' ;
    rdfs:comment 'External reference identifier linking to the campaign record in Salesforce Media Cloud CRM system. | Column salesforce_campaign_reference (STRING) in sales.campaign' ;
    rdfs:domain ind:SalesCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCprp rdf:type rdf:Property ;
    rdfs:label 'Target Cprp' ;
    rdfs:comment 'Contracted target Cost Per Rating Point representing the cost to achieve one rating point. | Column target_cprp (DECIMAL(10,2)) in sales.campaign' ;
    rdfs:domain ind:SalesCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetFrequency rdf:type rdf:Property ;
    rdfs:label 'Target Frequency' ;
    rdfs:comment 'Contracted average number of times each unique audience member should be exposed to the campaign. | Column target_frequency (DECIMAL(5,2)) in sales.campaign' ;
    rdfs:domain ind:SalesCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetReachPercent rdf:type rdf:Property ;
    rdfs:label 'Target Reach Percent' ;
    rdfs:comment 'Contracted percentage of unique audience members to be reached by the campaign. | Column target_reach_percent (DECIMAL(5,2)) in sales.campaign' ;
    rdfs:domain ind:SalesCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSovPercent rdf:type rdf:Property ;
    rdfs:label 'Target Sov Percent' ;
    rdfs:comment 'Contracted target Share of Voice representing the percentage of total advertising impressions in the category or daypart. | Column target_sov_percent (DECIMAL(5,2)) in sales.campaign' ;
    rdfs:domain ind:SalesCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualSpendTier rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Tier' ;
    rdfs:comment 'The classification tier based on annual advertising spend volume, used for pricing, service level, and upfront negotiation priority. | Column annual_spend_tier (STRING) in sales.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'The credit approval status indicating whether the advertiser is authorized to purchase advertising on credit terms. | Column credit_status (STRING) in sales.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryCategory rdf:type rdf:Property ;
    rdfs:label 'Industry Category' ;
    rdfs:comment 'The Interactive Advertising Bureau (IAB) taxonomy category classifying the advertiser\'s primary business vertical (e.g., Automotive, Financial Services, Consumer Packaged Goods). | Column industry_category (STRING) in sales.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPoliticalAdvertiser rdf:type rdf:Property ;
    rdfs:label 'Is Political Advertiser' ;
    rdfs:comment 'Boolean flag indicating whether this advertiser is a political candidate, party, or issue advocacy group subject to FCC political advertising disclosure requirements. | Column is_political_advertiser (BOOLEAN) in sales.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentCompanyName rdf:type rdf:Property ;
    rdfs:label 'Parent Company Name' ;
    rdfs:comment 'The name of the parent or holding company if the advertiser is a subsidiary or brand within a larger corporate structure. | Column parent_company_name (STRING) in sales.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAdClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Ad Clearance' ;
    rdfs:comment 'Boolean flag indicating whether this advertiser\'s creative content requires pre-broadcast clearance review due to industry category (e.g., pharmaceuticals, alcohol, financial services). | Column requires_ad_clearance (BOOLEAN) in sales.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'The doing-business-as (DBA) or brand name used in advertising campaigns and public-facing materials. | Column trade_name (STRING) in sales.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideOrbitAdvertiserCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Advertiser Code' ;
    rdfs:comment 'The unique advertiser identifier in the Wide Orbit traffic and billing system, used for ad scheduling, sales orders, and invoicing. | Column wide_orbit_advertiser_code (STRING) in sales.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Date' ;
    rdfs:comment 'Date when the agency was granted accreditation status by the broadcaster or industry body. | Column accreditation_date (DATE) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiry Date' ;
    rdfs:comment 'Date when the current accreditation status expires and requires renewal. Nullable for indefinite accreditation. | Column accreditation_expiry_date (DATE) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Current accreditation status of the agency with industry bodies or the broadcaster, indicating creditworthiness and eligibility for commission-based billing. | Column accreditation_status (STRING) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingModel rdf:type rdf:Property ;
    rdfs:label 'Billing Model' ;
    rdfs:comment 'Billing methodology used for this agency. Gross: agency bills advertiser full amount and remits net to broadcaster. Net: broadcaster bills agency net amount. Hybrid: mixed approach. | Column billing_model (STRING) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum credit amount (in base currency) extended to the agency for outstanding ad orders before payment is required. Used for credit risk management. | Column credit_limit (DECIMAL(15,2)) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingCompanyGroup rdf:type rdf:Property ;
    rdfs:label 'Holding Company Group' ;
    rdfs:comment 'Name of the parent holding company or agency network to which this agency belongs (e.g., WPP, Omnicom, Publicis, IPG, Dentsu). Null if independent. | Column holding_company_group (STRING) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date when the agency was first onboarded and approved to place advertising orders with the broadcaster. | Column onboarding_date (DATE) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesAgencyStatus rdf:type rdf:Property ;
    rdfs:label 'Sales Agency Status' ;
    rdfs:comment 'Current operational status of the agency relationship. Active agencies can place orders; inactive/suspended/terminated agencies cannot. | Column sales_agency_status (STRING) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusReason rdf:type rdf:Property ;
    rdfs:label 'Status Reason' ;
    rdfs:comment 'Explanation or business reason for the current status, particularly for inactive, suspended, or terminated statuses (e.g., credit issues, contract expiration, voluntary closure). | Column status_reason (STRING) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideOrbitAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Agency Code' ;
    rdfs:comment 'Unique agency identifier code used in the Wide Orbit traffic and billing system for ad scheduling, sales orders, and invoicing. | Column wide_orbit_agency_code (STRING) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalSpotAdSpotId rdf:type rdf:Property ;
    rdfs:label 'Original Spot Ad Spot Id' ;
    rdfs:comment 'Reference to the original ad spot that this makegood spot is compensating for. Populated only when makegood_flag is true. | Column original_spot_ad_spot_id (BIGINT) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdSpot .

ind:actualAirTime rdf:type rdf:Property ;
    rdfs:label 'Actual Air Time' ;
    rdfs:comment 'The actual date and time when this ad spot aired, as recorded in the broadcast affidavit. Used for proof of performance and billing reconciliation. | Column actual_air_time (TIMESTAMP) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:affidavitReference rdf:type rdf:Property ;
    rdfs:label 'Affidavit Reference' ;
    rdfs:comment 'Reference to the broadcast affidavit (proof of performance document) that certifies this spot aired as scheduled. Required for billing and advertiser verification. | Column affidavit_reference (STRING) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current billing status of this spot. Tracks the spot through the billing lifecycle from unbilled through payment or dispute resolution. | Column billing_status (STRING) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusSpotFlag rdf:type rdf:Property ;
    rdfs:label 'Bonus Spot Flag' ;
    rdfs:comment 'Indicates whether this spot was provided as a bonus (added value) to the advertiser at no additional charge. Used for revenue recognition and campaign value calculation. | Column bonus_spot_flag (BOOLEAN) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpmAmount rdf:type rdf:Property ;
    rdfs:label 'Cpm Amount' ;
    rdfs:comment 'Cost per thousand impressions for this spot. Key pricing metric in advertising sales used to compare efficiency across different placements. | Column cpm_amount (DECIMAL(10,2)) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daiFlag rdf:type rdf:Property ;
    rdfs:label 'Dai Flag' ;
    rdfs:comment 'Indicates whether this spot was delivered via Dynamic Ad Insertion technology, allowing personalized ad delivery to different viewers or platforms. | Column dai_flag (BOOLEAN) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grpValue rdf:type rdf:Property ;
    rdfs:label 'Grp Value' ;
    rdfs:comment 'Gross Rating Point value delivered by this spot. Measures the size of the audience reached relative to the total market population. Sum of all rating points across the campaign. | Column grp_value (DECIMAL(8,2)) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Impressions Delivered' ;
    rdfs:comment 'Total number of impressions (views) delivered by this spot. Used for performance measurement and billing reconciliation. | Column impressions_delivered (BIGINT) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:makegoodFlag rdf:type rdf:Property ;
    rdfs:label 'Makegood Flag' ;
    rdfs:comment 'Indicates whether this spot is a makegood (compensatory ad spot provided to an advertiser due to a previous preemption or underdelivery). | Column makegood_flag (BOOLEAN) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preemptedFlag rdf:type rdf:Property ;
    rdfs:label 'Preempted Flag' ;
    rdfs:comment 'Indicates whether this spot was preempted (bumped from its scheduled time slot). Preempted spots typically require makegood compensation. | Column preempted_flag (BOOLEAN) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rotationPattern rdf:type rdf:Property ;
    rdfs:label 'Rotation Pattern' ;
    rdfs:comment 'Describes the rotation or sequencing pattern for this spot within the campaign (e.g., ROS - Run of Schedule, fixed position, alternating). Used for inventory management and fulfillment. | Column rotation_pattern (STRING) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledAirDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Air Date' ;
    rdfs:comment 'The date on which this ad spot was scheduled to air. Used for planning and inventory management. | Column scheduled_air_date (DATE) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledAirTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Air Time' ;
    rdfs:comment 'The precise date and time when this ad spot was scheduled to air. Includes timezone information for accurate cross-platform scheduling. | Column scheduled_air_time (TIMESTAMP) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:separationRequirement rdf:type rdf:Property ;
    rdfs:label 'Separation Requirement' ;
    rdfs:comment 'Specifies any separation rules for this spot (e.g., competitive separation, minimum time between airings). Ensures advertiser requirements are met. | Column separation_requirement (STRING) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotRateAmount rdf:type rdf:Property ;
    rdfs:label 'Spot Rate Amount' ;
    rdfs:comment 'The rate charged for this individual spot placement. May differ from the order line rate due to daypart, program, or inventory adjustments. | Column spot_rate_amount (DECIMAL(15,2)) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spotRateCurrency rdf:type rdf:Property ;
    rdfs:label 'Spot Rate Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the spot rate amount (e.g., USD, GBP, EUR). | Column spot_rate_currency (STRING) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotStatus rdf:type rdf:Property ;
    rdfs:label 'Spot Status' ;
    rdfs:comment 'Current lifecycle status of the ad spot. Tracks whether the spot was scheduled, successfully aired, preempted, cancelled, or requires makegood processing. | Column spot_status (STRING) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficLogReference rdf:type rdf:Property ;
    rdfs:label 'Traffic Log Reference' ;
    rdfs:comment 'Reference identifier to the Wide Orbit traffic log entry that scheduled and tracked this spot. Used for audit trail and reconciliation. | Column traffic_log_reference (STRING) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trpValue rdf:type rdf:Property ;
    rdfs:label 'Trp Value' ;
    rdfs:comment 'Target Rating Point value delivered by this spot. Measures audience reach within a specific demographic target segment, more precise than GRP. | Column trp_value (DECIMAL(8,2)) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audienceGuaranteeGrp rdf:type rdf:Property ;
    rdfs:label 'Audience Guarantee Grp' ;
    rdfs:comment 'Total Gross Rating Points (GRP) guaranteed to the advertiser across all flights and dayparts in this deal. GRP = Reach × Frequency, representing the total audience delivery commitment. | Column audience_guarantee_grp (DECIMAL(10,2)) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audienceGuaranteeImpressions rdf:type rdf:Property ;
    rdfs:label 'Audience Guarantee Impressions' ;
    rdfs:comment 'Total number of ad impressions guaranteed to the advertiser. Alternative or complementary metric to GRP, especially for digital and cross-platform deals. | Column audience_guarantee_impressions (BIGINT) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationOptionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Cancellation Option Window Days' ;
    rdfs:comment 'Number of days before flight start date within which the advertiser may cancel or reduce the commitment without penalty. Common in upfront deals to provide flexibility. | Column cancellation_option_window_days (INT) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelMix rdf:type rdf:Property ;
    rdfs:label 'Channel Mix' ;
    rdfs:comment 'Comma-separated list or description of broadcast channels, networks, or platforms included in this deal (e.g., Network Prime, Cable Bundle, OTT Streaming). Defines the inventory scope. | Column channel_mix (STRING) in sales.upfront_deal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Date' ;
    rdfs:comment 'Date when the advertiser or agency verbally or formally committed to the deal terms. Nullable until commitment is secured. | Column commitment_date (DATE) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cpmRate rdf:type rdf:Property ;
    rdfs:label 'Cpm Rate' ;
    rdfs:comment 'Cost per thousand impressions for CPM-based deals. Nullable if pricing basis is not CPM. Represents the unit price for audience delivery. | Column cpm_rate (DECIMAL(10,2)) in sales.upfront_deal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cprpRate rdf:type rdf:Property ;
    rdfs:label 'Cprp Rate' ;
    rdfs:comment 'Cost per rating point for CPRP-based deals. Nullable if pricing basis is not CPRP. Represents the unit price per GRP delivered. | Column cprp_rate (DECIMAL(10,2)) in sales.upfront_deal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealYear rdf:type rdf:Property ;
    rdfs:label 'Deal Year' ;
    rdfs:comment 'Broadcast year for which this upfront deal applies, typically representing the September-to-August broadcast season (e.g., 2024 for 2024-2025 season). Critical for upfront planning and inventory allocation. | Column deal_year (INT) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date when the deal contract was fully executed (signed by all parties). Nullable until contract is finalized. | Column execution_date (DATE) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:makegoodProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Makegood Provision Flag' ;
    rdfs:comment 'Indicates whether the deal includes makegood provisions for audience delivery shortfalls. True = makegoods required if guaranteed audience is not delivered; False = no makegood obligation. | Column makegood_provision_flag (BOOLEAN) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiationRoundCount rdf:type rdf:Property ;
    rdfs:label 'Negotiation Round Count' ;
    rdfs:comment 'Number of formal negotiation rounds or proposal revisions submitted during the deal lifecycle. Tracks negotiation complexity and sales effort. | Column negotiation_round_count (INT) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingBasis rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis' ;
    rdfs:comment 'Pricing model used for this deal. CPM (Cost Per Mille) = cost per thousand impressions; CPRP (Cost Per Rating Point) = cost per GRP point; Flat Rate = fixed fee regardless of delivery; Performance = outcome-based pricing. | Column pricing_basis (STRING) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalDate rdf:type rdf:Property ;
    rdfs:label 'Proposal Date' ;
    rdfs:comment 'Date when the initial deal proposal was formally submitted to the advertiser or agency. Marks the start of the negotiation lifecycle. | Column proposal_date (DATE) in sales.upfront_deal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesforceOpportunityReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Reference' ;
    rdfs:comment 'External reference to the corresponding Salesforce Media Cloud Opportunity record. Enables cross-system traceability between the deal negotiation (Salesforce) and trafficking/billing (Wide Orbit). | Column salesforce_opportunity_reference (STRING) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scatterConversionRights rdf:type rdf:Property ;
    rdfs:label 'Scatter Conversion Rights' ;
    rdfs:comment 'Indicates whether the advertiser has the right to convert unused upfront commitment into scatter market inventory at preferential rates. True = conversion allowed; False = no conversion rights. | Column scatter_conversion_rights (BOOLEAN) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCommittedSpend rdf:type rdf:Property ;
    rdfs:label 'Total Committed Spend' ;
    rdfs:comment 'Total dollar value of advertising spend committed by the advertiser after negotiation. Nullable until commitment is secured. This is the final agreed revenue amount. | Column total_committed_spend (DECIMAL(18,2)) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProposedSpend rdf:type rdf:Property ;
    rdfs:label 'Total Proposed Spend' ;
    rdfs:comment 'Total dollar value of advertising spend proposed in the initial deal submission. Represents the gross revenue opportunity before negotiation adjustments. | Column total_proposed_spend (DECIMAL(18,2)) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentAccountSalesAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Sales Account Id' ;
    rdfs:comment 'Reference to the parent sales account in a hierarchical account structure. Used to model agency networks, holding company subsidiaries, and multi-location advertiser organizations. | Column parent_account_sales_account_id (BIGINT) in sales.sales_account' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the sales account based on its commercial relationship with Media Broadcasting. Agency represents advertising agencies; direct_advertiser represents brands buying media directly; MVPD (Multichannel Video Programming Distributor) and vMVPD (Virtual Multichannel Video Programming Distributor) represent distribution partners; syndicator represents content resale partners; content_licensee represents organizations licensing content rights. | Column account_type (STRING) in sales.sales_account' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Agency Commission Rate' ;
    rdfs:comment 'The commission percentage paid to advertising agencies for media buys placed on behalf of their clients. Typically expressed as a decimal (e.g., 0.1500 for 15%). Null for non-agency accounts. | Column agency_commission_rate (DECIMAL(5,4)) in sales.sales_account' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenuePotential rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Potential' ;
    rdfs:comment 'The estimated annual revenue opportunity from this account based on historical spend, market share, and sales forecasts. Used for territory planning and quota allocation. | Column annual_revenue_potential (DECIMAL(18,2)) in sales.sales_account' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Email' ;
    rdfs:comment 'The email address of the primary billing contact for invoice delivery and payment correspondence. | Column billing_contact_email (STRING) in sales.sales_account' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactName rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Name' ;
    rdfs:comment 'The full name of the primary billing contact at the account organization who handles invoices, payment processing, and financial inquiries. | Column billing_contact_name (STRING) in sales.sales_account' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactPhone rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Phone' ;
    rdfs:comment 'The phone number of the primary billing contact for urgent payment or invoice inquiries. | Column billing_contact_phone (STRING) in sales.sales_account' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'The credit rating assigned to this account based on payment history, financial stability, and risk assessment. Used to determine payment terms, credit limits, and whether prepayment is required. NR indicates not rated. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D|NR — 11 candidates stripped; promote to reference product] | Column credit_rating (STRING) in sales.sales_account' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdingCompanyName rdf:type rdf:Property ;
    rdfs:label 'Holding Company Name' ;
    rdfs:comment 'The name of the parent holding company or corporate group to which this account belongs. Used to aggregate spend and manage relationships at the holding company level (e.g., WPP, Omnicom, Publicis Groupe for agencies). | Column holding_company_name (STRING) in sales.sales_account' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVertical rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical' ;
    rdfs:comment 'The primary industry vertical or business sector of the account (e.g., Automotive, Financial Services, Retail, Pharmaceutical, Technology). Used for competitive separation and industry-specific rate cards. | Column industry_vertical (STRING) in sales.sales_account' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'The date of the most recent sales activity, campaign, or transaction associated with this account. Used to identify dormant accounts and trigger re-engagement campaigns. | Column last_activity_date (DATE) in sales.sales_account' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesforceAccountReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Reference' ;
    rdfs:comment 'The source system identifier from Salesforce Media Cloud CRM. This is the external key used to synchronize account data between the lakehouse and the operational CRM system. | Column salesforce_account_reference (STRING) in sales.sales_account' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignObjective rdf:type rdf:Property ;
    rdfs:label 'Campaign Objective' ;
    rdfs:comment 'Primary marketing objective the advertiser aims to achieve with this campaign. Influences creative strategy, placement selection, and success metrics. [ENUM-REF-CANDIDATE: brand_awareness|product_launch|direct_response|lead_generation|traffic|engagement|video_views|app_installs — 8 candidates stripped; promote to reference product] | Column campaign_objective (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Target date by which the sales team expects to close this opportunity (win or lose). Used for pipeline forecasting and sales velocity tracking. Updated as negotiations progress. | Column close_date (DATE) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Actual date when the opportunity was marked as closed-won or closed-lost. Null for open opportunities. Used for sales cycle analysis and win rate calculation. | Column closed_date (DATE) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitiveDisplacement rdf:type rdf:Property ;
    rdfs:label 'Competitive Displacement' ;
    rdfs:comment 'Free-text notes capturing competitive intelligence about which competitor this deal may displace or compete against. Used for win/loss analysis and competitive strategy. | Column competitive_displacement (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demographicTarget rdf:type rdf:Property ;
    rdfs:label 'Demographic Target' ;
    rdfs:comment 'Primary demographic audience segment targeted by this campaign (e.g., \'Adults 18-49\', \'Women 25-54\', \'Men 18-34\'). Used for audience guarantee and measurement alignment. | Column demographic_target (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Value' ;
    rdfs:comment 'Total estimated revenue value of the opportunity in USD. For advertising deals, represents total campaign spend; for content licensing, represents license fee. Used for revenue forecasting and quota tracking. | Column estimated_value (DECIMAL(15,2)) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastCategory rdf:type rdf:Property ;
    rdfs:label 'Forecast Category' ;
    rdfs:comment 'Sales forecast category indicating confidence level for revenue recognition. Pipeline = early stage; Best Case = likely but not committed; Commit = high confidence; Closed = won. Used for revenue forecasting rollups. | Column forecast_category (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isUpfront rdf:type rdf:Property ;
    rdfs:label 'Is Upfront' ;
    rdfs:comment 'Boolean flag indicating whether this opportunity is part of the annual upfront sales season. True = upfront commitment; False = scatter market or other deal type. Used for upfront tracking and reporting. | Column is_upfront (BOOLEAN) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Origin channel of this sales opportunity. Tracks how the lead was generated for marketing attribution and lead source ROI analysis. [ENUM-REF-CANDIDATE: inbound|outbound|referral|event|partner|renewal|upsell — 7 candidates stripped; promote to reference product] | Column lead_source (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossNotes rdf:type rdf:Property ;
    rdfs:label 'Loss Notes' ;
    rdfs:comment 'Free-text detailed explanation of why the opportunity was lost. Captures competitive intelligence, pricing feedback, and strategic insights for future deals. | Column loss_notes (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Primary reason for losing the opportunity if stage is closed-lost. Used for loss analysis, competitive intelligence, and sales process improvement. Null for won or open opportunities. | Column loss_reason (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStep rdf:type rdf:Property ;
    rdfs:label 'Next Step' ;
    rdfs:comment 'Description of the next action or milestone required to advance this opportunity. Used for sales activity tracking and pipeline hygiene. Updated regularly by sales executive. | Column next_step (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Opportunity Number' ;
    rdfs:comment 'Human-readable business identifier for the opportunity, typically auto-generated in format OPP-YYYYNNNN. Used in sales communications and reporting. | Column opportunity_number (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probability rdf:type rdf:Property ;
    rdfs:label 'Probability' ;
    rdfs:comment 'Estimated likelihood of closing this opportunity as a percentage (0.00 to 100.00). Typically aligned with stage (e.g., Proposal = 40%, Negotiation = 60%). Used for weighted pipeline forecasting. | Column probability (DECIMAL(5,2)) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresMakegood rdf:type rdf:Property ;
    rdfs:label 'Requires Makegood' ;
    rdfs:comment 'Boolean flag indicating whether this opportunity includes makegood provisions for audience delivery shortfalls. True = makegoods may be required if audience guarantees are not met. Used for inventory planning. | Column requires_makegood (BOOLEAN) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage in the sales pipeline lifecycle. Tracks progression from initial prospecting through closure. Used for pipeline forecasting and sales funnel analysis. | Column stage (STRING) in sales.opportunity' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalId rdf:type rdf:Property ;
    rdfs:label 'Proposal Id' ;
    rdfs:comment 'Primary key for proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Proposal .

ind:approvedAt rdf:type rdf:Property ;
    rdfs:label 'Approved At' ;
    rdfs:comment 'Timestamp when proposal was approved' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discountPercent rdf:type rdf:Property ;
    rdfs:label 'Discount Percent' ;
    rdfs:comment 'Discount percentage applied to proposal' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netProposedValue rdf:type rdf:Property ;
    rdfs:label 'Net Proposed Value' ;
    rdfs:comment 'Net value after discounts' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposalNumber rdf:type rdf:Property ;
    rdfs:label 'Proposal Number' ;
    rdfs:comment 'Unique proposal reference number' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalStatus rdf:type rdf:Property ;
    rdfs:label 'Proposal Status' ;
    rdfs:comment 'Current status of the proposal (draft, submitted, approved, rejected)' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalType rdf:type rdf:Property ;
    rdfs:label 'Proposal Type' ;
    rdfs:comment 'Type of proposal (upfront, scatter, sponsorship)' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedGrp rdf:type rdf:Property ;
    rdfs:label 'Proposed Grp' ;
    rdfs:comment 'Proposed gross rating points' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedImpressions rdf:type rdf:Property ;
    rdfs:label 'Proposed Impressions' ;
    rdfs:comment 'Proposed impression delivery' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectedAt rdf:type rdf:Property ;
    rdfs:label 'Rejected At' ;
    rdfs:comment 'Timestamp when proposal was rejected' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:salesAgencyId2 rdf:type rdf:Property ;
    rdfs:label 'Sales Agency Id 2' ;
    rdfs:comment 'FK to sales agency' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
