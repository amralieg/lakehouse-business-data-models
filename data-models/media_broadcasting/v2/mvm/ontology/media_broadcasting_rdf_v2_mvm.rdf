    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords and tags describing content themes, subjects, and topics. Used for search optimization, content discovery, and recommendation algorithms. | Column keywords (STRING) in content.title' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'Primary display name of the content title. The human-readable identifier used across all systems and customer-facing platforms. | Column title_name (STRING) in content.title' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalLanguage rdf:type rdf:Property ;
    rdfs:label 'Original Language' ;
    rdfs:comment 'ISO 639-2 three-letter code representing the original language of the content production. Used for localization planning, dubbing, and subtitle workflows. | Column original_language (STRING) in content.title' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTitle rdf:type rdf:Property ;
    rdfs:label 'Original Title' ;
    rdfs:comment 'Original title name in the native language of production. Preserved for rights management, archival, and international distribution purposes. | Column original_title (STRING) in content.title' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalAdvisoryFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Advisory Flag' ;
    rdfs:comment 'Indicates whether the content carries a parental advisory warning for explicit content, violence, or mature themes. Used for compliance with broadcast standards and platform content policies. | Column parental_advisory_flag (BOOLEAN) in content.title' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:premiereFlag rdf:type rdf:Property ;
    rdfs:label 'Premiere Flag' ;
    rdfs:comment 'Indicates whether the content is a premiere or first-run broadcast. Used for promotional scheduling, advertising premium pricing, and audience measurement reporting. | Column premiere_flag (BOOLEAN) in content.title' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionYear rdf:type rdf:Property ;
    rdfs:label 'Production Year' ;
    rdfs:comment 'Calendar year in which the content was originally produced or completed. Used for catalog organization, rights windowing calculations, and archival classification. | Column production_year (INT) in content.title' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the content was first released to the public or premiered. Used for rights availability calculations, windowing strategies, and anniversary programming. | Column release_date (DATE) in content.title' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Status' ;
    rdfs:comment 'Current rights availability status indicating whether the content can be legally broadcast or distributed. Drives scheduling decisions and geographic blackout enforcement. | Column rights_status (STRING) in content.title' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runtimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Runtime Seconds' ;
    rdfs:comment 'Total duration of the content in seconds. Used for program scheduling, ad pod allocation, playout automation, and Electronic Program Guide (EPG) generation. | Column runtime_seconds (INT) in content.title' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonNumber rdf:type rdf:Property ;
    rdfs:label 'Season Number' ;
    rdfs:comment 'Season number within the parent series for episodic content. Null for non-episodic content. Used for catalog organization and Electronic Program Guide (EPG) display. | Column season_number (INT) in content.title' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceCode rdf:type rdf:Property ;
    rdfs:label 'Source Code' ;
    rdfs:comment 'Medallion lineage tracking column for bronze->silver->gold tracing | Column source_id (STRING) in content.title' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studioName rdf:type rdf:Property ;
    rdfs:label 'Studio Name' ;
    rdfs:comment 'Name of the studio or production company that produced the content. Used for rights attribution, royalty calculations, and catalog organization. | Column studio_name (STRING) in content.title' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subGenre rdf:type rdf:Property ;
    rdfs:label 'Sub Genre' ;
    rdfs:comment 'Secondary or more granular genre classification providing additional content categorization for advanced audience segmentation and personalization. | Column sub_genre (STRING) in content.title' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synopsisLong rdf:type rdf:Property ;
    rdfs:label 'Synopsis Long' ;
    rdfs:comment 'Detailed narrative description of the content. Used for promotional materials, streaming platform detail pages, and comprehensive program guides. | Column synopsis_long (STRING) in content.title' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synopsisShort rdf:type rdf:Property ;
    rdfs:label 'Synopsis Short' ;
    rdfs:comment 'Brief summary of the content, typically 50-100 characters. Used for Electronic Program Guide (EPG) listings, mobile applications, and quick reference displays. | Column synopsis_short (STRING) in content.title' ;
