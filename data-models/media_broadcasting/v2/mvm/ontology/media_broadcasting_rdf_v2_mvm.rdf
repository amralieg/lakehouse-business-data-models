ind:winProbabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Win Probability Percent' ;
    rdfs:comment 'Estimated probability of winning the deal' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposalLineId rdf:type rdf:Property ;
    rdfs:label 'Proposal Line Id' ;
    rdfs:comment 'Unique identifier for the proposal line item. Primary key. | Column proposal_line_id (BIGINT) in sales.proposal_line' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licensedMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Licensed Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Individual proposal lines in content licensing proposals specify which media assets are included in each license grant. This enables line-level asset availability checking, format specification matchi | Column licensed_media_asset_id (BIGINT) in mediaasset.proposal_line' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:agencyCommissionPercentage rdf:type rdf:Property ;
    rdfs:label 'Agency Commission Percentage' ;
    rdfs:comment 'Percentage commission allocated to the advertising agency for this line item. | Column agency_commission_percentage (DECIMAL(5,2)) in sales.proposal_line' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audienceGuaranteeFlag rdf:type rdf:Property ;
    rdfs:label 'Audience Guarantee Flag' ;
    rdfs:comment 'Indicates whether this line includes an audience delivery guarantee requiring makegoods if underdelivered. | Column audience_guarantee_flag (BOOLEAN) in sales.proposal_line' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Absolute dollar amount of discount applied to this line item. | Column discount_amount (DECIMAL(15,2)) in sales.proposal_line' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total gross value of this proposal line before any discounts or adjustments. | Column gross_amount (DECIMAL(15,2)) in sales.proposal_line' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedImpressions rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Impressions' ;
    rdfs:comment 'Minimum number of impressions guaranteed to be delivered for this line item if audience guarantee applies. | Column guaranteed_impressions (BIGINT) in sales.proposal_line' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposedTrp rdf:type rdf:Property ;
    rdfs:label 'Proposed Trp' ;
    rdfs:comment 'Estimated Target Rating Points for the specific demographic audience being targeted. | Column proposed_trp (DECIMAL(10,2)) in sales.proposal_line' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Unit Length Seconds' ;
    rdfs:comment 'Duration of each advertising unit in seconds (e.g., 15, 30, 60 seconds for spots). | Column unit_length_seconds (INT) in sales.proposal_line' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitQuantity rdf:type rdf:Property ;
    rdfs:label 'Unit Quantity' ;
    rdfs:comment 'Number of advertising units or spots being proposed in this line (e.g., 30 spots, 5 sponsorships). | Column unit_quantity (INT) in sales.proposal_line' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageTitleId rdf:type rdf:Property ;
    rdfs:label 'Package Title Id' ;
    rdfs:comment 'Primary key for the package_title association' ;
    rdfs:domain ind:PackageTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inclusionDate rdf:type rdf:Property ;
    rdfs:label 'Inclusion Date' ;
    rdfs:comment 'The date on which this title was formally added to the package. Used for rights tracking, royalty calculation start points, and inclusion history auditing. Belongs to the relationship, not to either parent entity.' ;
    rdfs:domain ind:PackageTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inclusionStatus rdf:type rdf:Property ;
    rdfs:label 'Inclusion Status' ;
    rdfs:comment 'Current lifecycle status of this title\'s inclusion in the package. Tracks whether the inclusion is active, pending rights clearance, suspended, or expired. Enables distribution teams to manage partial package availability when individual titles have rights issues.' ;
    rdfs:domain ind:PackageTitle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
