    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theatricalReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Theatrical Release Flag' ;
    rdfs:comment 'Indicates whether the content had a theatrical release. Used for windowing strategy, rights holdback periods, and marketing classification. | Column theatrical_release_flag (BOOLEAN) in content.title' ;
    rdfs:domain ind:Title ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uhd4kAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Uhd 4k Available Flag' ;
    rdfs:comment 'Indicates whether an Ultra HD 4K version of the content is available. Used for premium streaming tiers and next-generation broadcast services. | Column uhd_4k_available_flag (BOOLEAN) in content.title' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedAt rdf:type rdf:Property ;
    rdfs:label 'Updated At' ;
    rdfs:comment 'Medallion lineage tracking column for bronze->silver->gold tracing | Column updated_at (TIMESTAMP) in content.title' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp when the title record was last modified. Used for change tracking, data synchronization, and audit compliance. | Column updated_timestamp (TIMESTAMP) in content.title' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:demographicSegmentId rdf:type rdf:Property ;
    rdfs:label 'Demographic Segment Id' ;
    rdfs:comment 'Foreign key linking to audience.demographic_segment. Business justification: audience.series.target_demographic is a denormalized plain-text column. Normalizing to audience.demographic_segment enables proper series-to-audience targeting for ad sales, scheduling decisions, and N' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemographicSegment .

ind:showrunnerTalentProfileId rdf:type rdf:Property ;
    rdfs:label 'Showrunner Talent Profile Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_profile. Business justification: Showrunner/creator identification for WGA credits and series-level backend participation deals — series backend participation calculations and WGA separated rights determinations require the primary c' ;
    rdfs:domain ind:Series ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:archiveLocation rdf:type rdf:Property ;
    rdfs:label 'Archive Location' ;
    rdfs:comment 'Physical or logical location identifier where the series master content and metadata are archived. Used for Digital Asset Management (DAM) and Media Asset Management (MAM) retrieval. | Column archive_location (STRING) in content.series' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioDescriptionAvailable rdf:type rdf:Property ;
    rdfs:label 'Audio Description Available' ;
    rdfs:comment 'Indicates whether audio description track is available for visually impaired viewers. Required for accessibility compliance in many jurisdictions. | Column audio_description_available (BOOLEAN) in content.series' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audioFormat rdf:type rdf:Property ;
    rdfs:label 'Audio Format' ;
    rdfs:comment 'Standard audio format and channel configuration for the series. Determines audio encoding requirements for distribution and playout. | Column audio_format (STRING) in content.series' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionAvailable rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Available' ;
    rdfs:comment 'Indicates whether closed captioning is available for the series. Required for regulatory compliance under FCC accessibility rules and international broadcasting standards. | Column closed_caption_available (BOOLEAN) in content.series' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributor rdf:type rdf:Property ;
    rdfs:label 'Distributor' ;
    rdfs:comment 'Name of the distribution company responsible for licensing and distributing the series to secondary markets and platforms. | Column distributor (STRING) in content.series' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeRuntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Episode Runtime Minutes' ;
    rdfs:comment 'Standard runtime duration in minutes for a typical episode of the series, excluding commercials. Used for scheduling, ad pod planning, and playout automation. | Column episode_runtime_minutes (INT) in content.series' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finaleDate rdf:type rdf:Property ;
    rdfs:label 'Finale Date' ;
    rdfs:comment 'Date when the final episode of the series aired or was released. Null for ongoing series. Used for syndication eligibility and rights holdback period calculations. | Column finale_date (DATE) in content.series' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:franchiseName rdf:type rdf:Property ;
    rdfs:label 'Franchise Name' ;
    rdfs:comment 'Brand name of the content franchise or show brand. Used for grouping related series, spin-offs, and reboots under a common brand umbrella. | Column franchise_name (STRING) in content.series' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdrFormat rdf:type rdf:Property ;
    rdfs:label 'Hdr Format' ;
    rdfs:comment 'High Dynamic Range format specification for the series. Impacts content delivery network configuration and device compatibility. | Column hdr_format (STRING) in content.series' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isanCode rdf:type rdf:Property ;
    rdfs:label 'Isan Code' ;
    rdfs:comment 'International standard audiovisual number for the series. Used for audiovisual work identification in rights management and distribution. | Column isan_code (STRING) in content.series' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageOriginal rdf:type rdf:Property ;
    rdfs:label 'Language Original' ;
    rdfs:comment 'ISO 639-3 three-letter code for the original production language of the series. Used for localization planning and international distribution. | Column language_original (STRING) in content.series' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when the series record was last modified. Used for change tracking, audit compliance, and data synchronization across systems. | Column modified_timestamp (TIMESTAMP) in content.series' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:newsWireSource rdf:type rdf:Property ;
    rdfs:label 'News Wire Source' ;
    rdfs:comment 'Wire agency source code for news series per VREQ-019' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalNetwork rdf:type rdf:Property ;
    rdfs:label 'Original Network' ;
    rdfs:comment 'Name of the original broadcast network or streaming platform that first aired or released the series. Critical for rights management and syndication deals. | Column original_network (STRING) in content.series' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiereDate rdf:type rdf:Property ;
    rdfs:label 'Premiere Date' ;
    rdfs:comment 'Date when the first episode of the series originally aired or was released. Marks the beginning of the series lifecycle and is used for rights windowing calculations. | Column premiere_date (DATE) in content.series' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionCompany rdf:type rdf:Property ;
    rdfs:label 'Production Company' ;
    rdfs:comment 'Name of the primary production company or studio that produced the series. Critical for rights ownership, residuals calculations, and syndication negotiations. | Column production_company (STRING) in content.series' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionStandard rdf:type rdf:Property ;
    rdfs:label 'Resolution Standard' ;
    rdfs:comment 'Standard video resolution for the series master content. Determines transcoding requirements and Adaptive Bitrate (ABR) streaming profile generation. | Column resolution_standard (STRING) in content.series' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesStatus rdf:type rdf:Property ;
    rdfs:label 'Series Status' ;
    rdfs:comment 'Current lifecycle status of the series. Indicates whether the series is actively producing new content, has concluded, or is temporarily paused. | Column series_status (STRING) in content.series' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesType rdf:type rdf:Property ;
    rdfs:label 'Series Type' ;
    rdfs:comment 'Classification of the series format and production style. Determines scheduling strategy, audience targeting, and production workflow. [ENUM-REF-CANDIDATE: scripted|unscripted|documentary|news|sports|reality|talk_show|game_show|variety|animated|miniseries|anthology — 12 candidates stripped; promote to reference product] | Column series_type (STRING) in content.series' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationEligible rdf:type rdf:Property ;
    rdfs:label 'Syndication Eligible' ;
    rdfs:comment 'Indicates whether the series meets the minimum episode threshold and rights clearance requirements for syndication to secondary markets and broadcast stations. | Column syndication_eligible (BOOLEAN) in content.series' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Official title of the series as registered and marketed. Primary human-readable identifier for the content franchise. | Column title (STRING) in content.series' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleOriginal rdf:type rdf:Property ;
    rdfs:label 'Title Original' ;
    rdfs:comment 'Original title of the series in its native language and market before localization or translation. | Column title_original (STRING) in content.series' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEpisodeCount rdf:type rdf:Property ;
    rdfs:label 'Total Episode Count' ;
    rdfs:comment 'Cumulative count of all episodes produced across all seasons. Includes specials and pilot episodes. | Column total_episode_count (INT) in content.series' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSeasonCount rdf:type rdf:Property ;
    rdfs:label 'Total Season Count' ;
    rdfs:comment 'Total number of seasons produced for the series to date. Updated as new seasons are commissioned and produced. | Column total_season_count (INT) in content.series' ;
    rdfs:domain ind:Series ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonId rdf:type rdf:Property ;
    rdfs:label 'Season Id' ;
    rdfs:comment 'Unique identifier for the season record. Primary key. | Column season_id (BIGINT) in content.season' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Season .

ind:mediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Media Asset Id' ;
    rdfs:comment 'Reference to the season trailer asset in the MAM system. Used for promotional campaigns and platform previews. | Column media_asset_id (BIGINT) in mediaasset.season' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:awardsNominated rdf:type rdf:Property ;
    rdfs:label 'Awards Nominated' ;
    rdfs:comment 'Comma-separated list of major award nominations received by the season. Supports promotional messaging and content valuation. | Column awards_nominated (STRING) in content.season' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardsWon rdf:type rdf:Property ;
    rdfs:label 'Awards Won' ;
    rdfs:comment 'Comma-separated list of major awards won by the season (e.g., Emmy, Golden Globe). Used for marketing and promotional value enhancement. | Column awards_won (STRING) in content.season' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bannerArtworkUrl rdf:type rdf:Property ;
    rdfs:label 'Banner Artwork Url' ;
    rdfs:comment 'URL reference to the season\'s banner or hero image for wide-format displays on streaming platforms and websites. | Column banner_artwork_url (STRING) in content.season' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eidr rdf:type rdf:Property ;
    rdfs:label 'Eidr' ;
    rdfs:comment 'Globally unique EIDR identifier for the season, enabling cross-platform content identification and rights management. | Column eidr (STRING) in content.season' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeCountAired rdf:type rdf:Property ;
    rdfs:label 'Episode Count Aired' ;
    rdfs:comment 'Number of episodes that have been broadcast or released to audiences. Used for tracking release progress. | Column episode_count_aired (INT) in content.season' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeCountOrdered rdf:type rdf:Property ;
    rdfs:label 'Episode Count Ordered' ;
    rdfs:comment 'Number of episodes originally ordered or commissioned for this season by the network or platform. | Column episode_count_ordered (INT) in content.season' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeCountProduced rdf:type rdf:Property ;
    rdfs:label 'Episode Count Produced' ;
    rdfs:comment 'Actual number of episodes produced and delivered for this season. May differ from ordered count due to production changes. | Column episode_count_produced (INT) in content.season' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkOriginal rdf:type rdf:Property ;
    rdfs:label 'Network Original' ;
    rdfs:comment 'Name of the network or platform that originally commissioned or first aired the season. Used for windowing and exclusivity tracking. | Column network_original (STRING) in content.season' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalAirDate rdf:type rdf:Property ;
    rdfs:label 'Original Air Date' ;
    rdfs:comment 'Date when the first episode of the season was originally broadcast or released. Key for windowing and rights calculations. | Column original_air_date (DATE) in content.season' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:posterArtworkUrl rdf:type rdf:Property ;
    rdfs:label 'Poster Artwork Url' ;
    rdfs:comment 'URL reference to the season\'s primary poster artwork stored in the Media Asset Management (MAM) system. Used for EPG, VOD, and promotional displays. | Column poster_artwork_url (STRING) in content.season' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Rights Expiry Date' ;
    rdfs:comment 'Date when current distribution rights for the season expire. Triggers rights renewal workflows and availability restrictions. | Column rights_expiry_date (DATE) in content.season' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsHolder rdf:type rdf:Property ;
    rdfs:label 'Rights Holder' ;
    rdfs:comment 'Name of the entity holding primary distribution and exploitation rights for the season. Essential for clearance and licensing. | Column rights_holder (STRING) in content.season' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsTerritory rdf:type rdf:Property ;
    rdfs:label 'Rights Territory' ;
    rdfs:comment 'Geographic territories where distribution rights are held, using ISO 3166-1 alpha-3 country codes or regional groupings. Critical for windowing and blackout enforcement. | Column rights_territory (STRING) in content.season' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonStatus rdf:type rdf:Property ;
    rdfs:label 'Season Status' ;
    rdfs:comment 'Current lifecycle status of the season. Tracks progression from development through archival or cancellation. [ENUM-REF-CANDIDATE: in-development|in-production|post-production|completed|airing|aired|archived|cancelled — 8 candidates stripped; promote to reference product] | Column season_status (STRING) in content.season' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRuntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Runtime Minutes' ;
    rdfs:comment 'Cumulative runtime of all episodes in the season, measured in minutes. Used for scheduling blocks and VOD packaging. | Column total_runtime_minutes (INT) in content.season' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentEpisodeId rdf:type rdf:Property ;
    rdfs:label 'Content Episode Id' ;
    rdfs:comment 'Unique identifier for the episode within the content management system. Primary key for the content episode entity. | Column content_episode_id (BIGINT) in content.content_episode' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContentEpisode .

ind:contentSeasonId rdf:type rdf:Property ;
    rdfs:label 'Content Season Id' ;
    rdfs:comment 'Reference to the specific season within the series to which this episode belongs. Enables season-level grouping and rights management. | Column content_season_id (BIGINT) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Season .

ind:contentSeriesId rdf:type rdf:Property ;
    rdfs:label 'Content Series Id' ;
    rdfs:comment 'Reference to the parent series to which this episode belongs. Links episode to its series container. | Column content_series_id (BIGINT) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Series .

ind:breakingNewsFlag rdf:type rdf:Property ;
    rdfs:label 'Breaking News Flag' ;
    rdfs:comment 'Indicates if episode is breaking news content per VREQ-019' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastCount rdf:type rdf:Property ;
    rdfs:label 'Broadcast Count' ;
    rdfs:comment 'Total number of times this episode has been broadcast on linear television. Used for residuals calculation and syndication rights management. | Column broadcast_count (INT) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentAdvisory rdf:type rdf:Property ;
    rdfs:label 'Content Advisory' ;
    rdfs:comment 'Specific content warnings or advisories for viewer guidance (e.g., violence, language, adult themes). Displayed in Electronic Program Guide (EPG) and Video On Demand (VOD) interfaces. | Column content_advisory (STRING) in content.content_episode' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eidrIdentifier rdf:type rdf:Property ;
    rdfs:label 'Eidr Identifier' ;
    rdfs:comment 'Globally unique identifier for the episode registered with the Entertainment Identifier Registry. Enables universal content identification across distribution platforms and rights management systems. | Column eidr_identifier (STRING) in content.content_episode' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeStatus rdf:type rdf:Property ;
    rdfs:label 'Episode Status' ;
    rdfs:comment 'Current lifecycle state of the episode. Determines availability for scheduling, playout automation, and distribution to Over-The-Top (OTT) platforms. | Column episode_status (STRING) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeType rdf:type rdf:Property ;
    rdfs:label 'Episode Type' ;
    rdfs:comment 'Classification of the episode format and purpose within the series. Affects scheduling strategy, promotional treatment, and rights valuation. [ENUM-REF-CANDIDATE: standard|special|pilot|finale|recap|bonus|behind_the_scenes — 7 candidates stripped; promote to reference product] | Column episode_type (STRING) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicCueSheetSubmitted rdf:type rdf:Property ;
    rdfs:label 'Music Cue Sheet Submitted' ;
    rdfs:comment 'Indicates whether the music cue sheet has been submitted for royalty collection. Required for music rights compliance and royalty distribution. | Column music_cue_sheet_submitted (BOOLEAN) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'ISO 639-3 three-letter code for the primary audio language of the episode. Used for content cataloging, rights clearance, and distribution targeting. | Column primary_language (STRING) in content.content_episode' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCode rdf:type rdf:Property ;
    rdfs:label 'Production Code' ;
    rdfs:comment 'Internal production identifier assigned during content creation. Used for tracking production workflow, post-production tasks, and archival reference. | Column production_code (STRING) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rerunFlag rdf:type rdf:Property ;
    rdfs:label 'Rerun Flag' ;
    rdfs:comment 'Indicates whether this broadcast is a rerun. Affects advertising rates, Cost Per Rating Point (CPRP) calculations, and residuals payments to talent. | Column rerun_flag (BOOLEAN) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Clearance Status' ;
    rdfs:comment 'Current status of rights clearance for broadcast and distribution. Determines whether episode can be scheduled for playout or made available on Over-The-Top (OTT) platforms. | Column rights_clearance_status (STRING) in content.content_episode' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runtimeWithAdsSeconds rdf:type rdf:Property ;
    rdfs:label 'Runtime With Ads Seconds' ;
    rdfs:comment 'Total broadcast duration including commercial ad breaks. Used for linear scheduling and daypart planning. | Column runtime_with_ads_seconds (INT) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subtitlesAvailable rdf:type rdf:Property ;
    rdfs:label 'Subtitles Available' ;
    rdfs:comment 'Indicates whether subtitle tracks are available for this episode. Supports international distribution and localization strategies. | Column subtitles_available (BOOLEAN) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:videoResolution rdf:type rdf:Property ;
    rdfs:label 'Video Resolution' ;
    rdfs:comment 'Maximum video resolution available for this episode. Determines distribution channel eligibility and Adaptive Bitrate Streaming (ABR) profile selection. | Column video_resolution (STRING) in content.content_episode' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vodAvailableFromDate rdf:type rdf:Property ;
    rdfs:label 'Vod Available From Date' ;
    rdfs:comment 'Date when the episode becomes available on Video On Demand (VOD) platforms. Part of windowing strategy and rights holdback management. | Column vod_available_from_date (DATE) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vodAvailableUntilDate rdf:type rdf:Property ;
    rdfs:label 'Vod Available Until Date' ;
    rdfs:comment 'Date when the episode is removed from Video On Demand (VOD) platforms. Enforces rights windows and exclusivity periods. | Column vod_available_until_date (DATE) in content.content_episode' ;
    rdfs:domain ind:ContentEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:versionId rdf:type rdf:Property ;
    rdfs:label 'Version Id' ;
    rdfs:comment 'Primary key for version | Column version_id (BIGINT) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ottPlatformId rdf:type rdf:Property ;
    rdfs:label 'Ott Platform Id' ;
    rdfs:comment 'Foreign key linking to distribution.ott_platform. Business justification: Content versions are encoded with platform-specific DRM, codec, and resolution requirements. Linking version to ott_platform enables platform-specific versioning workflows, QC sign-off per platform, a' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OttPlatform .

ind:productionEpisodeId rdf:type rdf:Property ;
    rdfs:label 'Production Episode Id' ;
    rdfs:comment 'Foreign key linking to production.production_episode. Business justification: A content version corresponds to a specific production episode\'s output (e.g., director\'s cut, broadcast master). Direct FK enables episode-level version lineage for delivery, archive, and QC traceabi' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionEpisode .

ind:productionProjectId rdf:type rdf:Property ;
    rdfs:label 'Production Project Id' ;
    rdfs:comment 'Foreign key linking to production.project. Business justification: For original productions, a content version is created by a specific production project. Linking version to project enables production cost allocation to specific deliverable versions, QC workflow ini' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Timestamp when this version was approved for distribution and playout. | Column approved_timestamp (TIMESTAMP) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'Timestamp when this version was moved to long-term archive storage. | Column archived_timestamp (TIMESTAMP) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:audioCodec rdf:type rdf:Property ;
    rdfs:label 'Audio Codec' ;
    rdfs:comment 'Audio compression codec used for this version (e.g., \'AAC\', \'AC-3\', \'E-AC-3\', \'Dolby Atmos\', \'DTS\'). | Column audio_codec (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioTrackConfiguration rdf:type rdf:Property ;
    rdfs:label 'Audio Track Configuration' ;
    rdfs:comment 'Comma-separated list of audio track languages and types available in this version (e.g., \'en:stereo,es:5.1,fr:stereo,en:descriptive\'). | Column audio_track_configuration (STRING) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastSafe rdf:type rdf:Property ;
    rdfs:label 'Broadcast Safe' ;
    rdfs:comment 'Indicates whether this version has been certified as broadcast-safe, meeting technical standards for linear transmission (audio levels, video levels, closed captioning). | Column broadcast_safe (BOOLEAN) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checksumMd5 rdf:type rdf:Property ;
    rdfs:label 'Checksum Md5' ;
    rdfs:comment 'MD5 hash checksum of the version file, used for integrity verification during transfer and archival. | Column checksum_md5 (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorSpace rdf:type rdf:Property ;
    rdfs:label 'Color Space' ;
    rdfs:comment 'Color space standard used for this version (Rec. 709, Rec. 2020, DCI-P3, sRGB). | Column color_space (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editorialWorkflowState rdf:type rdf:Property ;
    rdfs:label 'Editorial Workflow State' ;
    rdfs:comment 'Current editorial workflow state (draft/assigned/filed/edited/cleared/published) per VREQ-019' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Container file format for this version (e.g., \'MP4\', \'MXF\', \'MOV\', \'TS\', \'WebM\'). | Column file_format (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Total file size of this version in bytes, used for storage planning and delivery bandwidth estimation. | Column file_size_bytes (BIGINT) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frameRate rdf:type rdf:Property ;
    rdfs:label 'Frame Rate' ;
    rdfs:comment 'Frame rate of this version in frames per second (e.g., 23.98, 24.00, 25.00, 29.97, 30.00, 50.00, 59.94, 60.00). | Column frame_rate (DECIMAL(5,2)) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isrcCode rdf:type rdf:Property ;
    rdfs:label 'Isrc Code' ;
    rdfs:comment 'International Standard Recording Code for music or audio content versions, enabling tracking and royalty distribution. | Column isrc_code (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Human-readable label identifying this version (e.g., \'Theatrical Cut\', \'Director\'s Cut\', \'Broadcast Safe\', \'Spanish Dub\', \'UK Censored\'). | Column label (STRING) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Primary Language Code' ;
    rdfs:comment 'ISO 639 two or three-letter code for the primary audio language of this version (e.g., \'en\', \'es\', \'fr\'). | Column primary_language_code (STRING) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Qc Completed Date' ;
    rdfs:comment 'Date when quality control review was completed for this version. | Column qc_completed_date (DATE) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Status' ;
    rdfs:comment 'Quality control review status for this version, indicating whether it has passed technical and content quality checks. | Column qc_status (STRING) in content.version' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolution rdf:type rdf:Property ;
    rdfs:label 'Resolution' ;
    rdfs:comment 'Video resolution classification for this version (SD, HD 720p, HD 1080p, UHD 4K, UHD 8K). | Column resolution (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runtimeDeltaSeconds rdf:type rdf:Property ;
    rdfs:label 'Runtime Delta Seconds' ;
    rdfs:comment 'Difference in runtime (in seconds) between this version and the master version. Positive values indicate longer runtime, negative indicate shorter. | Column runtime_delta_seconds (INT) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical or logical storage location identifier where this version is archived (e.g., tape library ID, cloud bucket path, MAM archive reference). | Column storage_location (STRING) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitleLanguages rdf:type rdf:Property ;
    rdfs:label 'Subtitle Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639 language codes for subtitle tracks included in this version (e.g., \'en,es,fr,de\'). | Column subtitle_languages (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTerritory rdf:type rdf:Property ;
    rdfs:label 'Target Territory' ;
    rdfs:comment 'Three-letter ISO country code indicating the primary geographic territory this version is intended for (e.g., USA, GBR, FRA). | Column target_territory (STRING) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of the version indicating its readiness for distribution and playout. [ENUM-REF-CANDIDATE: draft|in_production|qc_pending|approved|active|archived|deprecated|rejected — 8 candidates stripped; promote to reference product] | Column version_status (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionType rdf:type rdf:Property ;
    rdfs:label 'Version Type' ;
    rdfs:comment 'Classification of the version type indicating the nature of the edit or adaptation. [ENUM-REF-CANDIDATE: theatrical|broadcast|director|extended|unrated|censored|dubbed|subtitled|localized|preview|trailer — 11 candidates stripped; promote to reference product] | Column version_type (STRING) in content.version' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCodec rdf:type rdf:Property ;
    rdfs:label 'Video Codec' ;
    rdfs:comment 'Video compression codec used for this version (e.g., \'H.264\', \'H.265/HEVC\', \'VP9\', \'AV1\', \'MPEG-2\'). | Column video_codec (STRING) in content.version' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentGenreId rdf:type rdf:Property ;
    rdfs:label 'Parent Genre Id' ;
    rdfs:comment 'Reference to the parent genre in the hierarchical taxonomy, enabling multi-level classification such as Drama > Legal Drama or Sports > Football. Null for top-level genres. | Column parent_genre_id (BIGINT) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Genre .

ind:adPodCompatibility rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Compatibility' ;
    rdfs:comment 'Indicates whether content in this genre is compatible with Dynamic Ad Insertion (DAI) and ad pod placement. False for genres requiring uninterrupted viewing (e.g., live sports critical moments, news breaking coverage). | Column ad_pod_compatibility (BOOLEAN) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableContentTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Content Types' ;
    rdfs:comment 'Comma-separated list of content types to which this genre applies (e.g., series, film, clip, live_event, news_segment, music_video). Enables content-type-specific genre filtering. | Column applicable_content_types (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveRetentionPolicy rdf:type rdf:Property ;
    rdfs:label 'Archive Retention Policy' ;
    rdfs:comment 'Digital asset archival retention policy for content in this genre. Permanent retention for high-value evergreen genres; short-term for time-sensitive news and event content. | Column archive_retention_policy (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avodMonetizationPotential rdf:type rdf:Property ;
    rdfs:label 'Avod Monetization Potential' ;
    rdfs:comment 'Revenue generation potential for this genre on Advertising-Supported Video On Demand (AVOD) platforms, based on Cost Per Mille (CPM) rates and advertiser demand. High-potential genres command premium ad rates. | Column avod_monetization_potential (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:code rdf:type rdf:Property ;
    rdfs:label 'Code' ;
    rdfs:comment 'Short alphanumeric code representing the genre for system integration and Electronic Program Guide (EPG) feeds. Used as a business key across scheduling, distribution, and metadata systems. | Column genre_code (STRING) in content.genre' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartAffinity rdf:type rdf:Property ;
    rdfs:label 'Daypart Affinity' ;
    rdfs:comment 'Comma-separated list of broadcast dayparts where this genre typically performs best (e.g., prime_time, late_night, early_morning, daytime, weekend). Informs program scheduling and playout automation strategies. | Column daypart_affinity (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed textual description of the genre, including defining characteristics, typical content examples, and audience expectations. Used for editorial guidance and content acquisition briefings. | Column genre_description (STRING) in content.genre' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when this genre classification was retired or superseded. Null for currently active genres. Used for historical content classification and reporting continuity. | Column effective_end_date (DATE) in content.genre' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when this genre classification became effective and available for use in content metadata and scheduling systems. | Column effective_start_date (DATE) in content.genre' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eidrGenreMapping rdf:type rdf:Property ;
    rdfs:label 'Eidr Genre Mapping' ;
    rdfs:comment 'Mapping to Entertainment Identifier Registry (EIDR) genre taxonomy for cross-industry content identification and rights management interoperability. | Column eidr_genre_mapping (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastChannelApplicability rdf:type rdf:Property ;
    rdfs:label 'Fast Channel Applicability' ;
    rdfs:comment 'Indicates whether this genre is suitable for Free Ad-Supported Streaming Television (FAST) linear channel programming. FAST channels require genres with deep catalog availability and consistent audience appeal. | Column fast_channel_applicability (BOOLEAN) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRestrictionApplicability rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction Applicability' ;
    rdfs:comment 'Indicates whether content in this genre is subject to geographic blackout restrictions or regional licensing constraints. Common for sports genres with territorial rights and retransmission consent agreements. | Column geographic_restriction_applicability (BOOLEAN) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iabContentCategory rdf:type rdf:Property ;
    rdfs:label 'Iab Content Category' ;
    rdfs:comment 'Mapping to Interactive Advertising Bureau (IAB) content taxonomy for programmatic advertising and contextual ad targeting. Enables Share of Voice (SOV) optimization and Cost Per Mille (CPM) rate alignment. | Column iab_content_category (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this genre is currently active and available for content classification. Inactive genres are retained for historical content but not used for new acquisitions. | Column is_active (BOOLEAN) in content.genre' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp when this genre record was last updated. Used for change tracking and metadata synchronization across Electronic Program Guide (EPG), Media Asset Management (MAM), and distribution systems. | Column last_modified_timestamp (TIMESTAMP) in content.genre' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linearBroadcastSuitability rdf:type rdf:Property ;
    rdfs:label 'Linear Broadcast Suitability' ;
    rdfs:comment 'Indicates whether this genre is suitable for traditional linear scheduled broadcasting. Some genres (e.g., interactive, choose-your-own-adventure) are non-linear only. | Column linear_broadcast_suitability (BOOLEAN) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localizationPriority rdf:type rdf:Property ;
    rdfs:label 'Localization Priority' ;
    rdfs:comment 'Priority level for content localization (dubbing, subtitling, cultural adaptation) for this genre. High-priority genres justify investment in multi-language versions for international distribution. | Column localization_priority (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataEnrichmentPriority rdf:type rdf:Property ;
    rdfs:label 'Metadata Enrichment Priority' ;
    rdfs:comment 'Priority level for metadata enrichment and tagging in Media Asset Management (MAM) systems. Critical genres require comprehensive metadata for content discovery and personalization. | Column metadata_enrichment_priority (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpaRatingApplicability rdf:type rdf:Property ;
    rdfs:label 'Mpa Rating Applicability' ;
    rdfs:comment 'Comma-separated list of Motion Picture Association (MPA) ratings typically associated with this genre (e.g., G, PG, PG-13, R, NC-17). Used for content clearance and daypart scheduling compliance. | Column mpa_rating_applicability (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenGenreCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Genre Code' ;
    rdfs:comment 'Nielsen Media Research genre classification code used for audience measurement, ratings analysis, and Gross Rating Point (GRP) reporting alignment. | Column nielsen_genre_code (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ottPlatformPriority rdf:type rdf:Property ;
    rdfs:label 'Ott Platform Priority' ;
    rdfs:comment 'Priority level for featuring this genre on Over-The-Top (OTT) streaming platforms and Video On Demand (VOD) services. High priority genres receive prominent placement in content discovery and recommendation engines. | Column ott_platform_priority (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalGuidanceFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Guidance Flag' ;
    rdfs:comment 'Indicates whether content in this genre typically requires parental guidance warnings or viewer discretion advisories. Used for compliance with Federal Communications Commission (FCC) broadcast standards and Children\'s Online Privacy Protection Act (COPPA) requirements. | Column parental_guidance_flag (BOOLEAN) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:svodPerformanceTier rdf:type rdf:Property ;
    rdfs:label 'Svod Performance Tier' ;
    rdfs:comment 'Performance classification for this genre on Subscription Video On Demand (SVOD) platforms. Premium genres drive subscriber acquisition and reduce churn rate; catalog genres provide library depth. | Column svod_performance_tier (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationEligibility rdf:type rdf:Property ;
    rdfs:label 'Syndication Eligibility' ;
    rdfs:comment 'Indicates whether content in this genre is typically eligible for syndication to multiple outlets and resale. Used in rights and royalties management and windowing strategy planning. | Column syndication_eligibility (BOOLEAN) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetDemographic rdf:type rdf:Property ;
    rdfs:label 'Target Demographic' ;
    rdfs:comment 'Primary audience demographic segment targeted by this genre, expressed in Nielsen demographic notation (e.g., A18-49, M25-54, W18-34). Used for Target Rating Point (TRP) and Gross Rating Point (GRP) planning. | Column target_demographic (STRING) in content.genre' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Hierarchical level of the genre within the taxonomy. Primary represents top-level genres, secondary represents sub-genres, and tertiary represents granular classifications. | Column genre_tier (STRING) in content.genre' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Notes' ;
    rdfs:comment 'Internal notes and guidelines for content producers, schedulers, and metadata specialists on proper application of this genre classification. Includes edge cases and disambiguation rules. | Column usage_notes (STRING) in content.genre' ;
    rdfs:domain ind:Genre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingId rdf:type rdf:Property ;
    rdfs:label 'Rating Id' ;
    rdfs:comment 'Primary key for rating | Column rating_id (BIGINT) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'The current status of any appeal filed by the content producer or distributor to challenge or modify the assigned rating classification. | Column appeal_status (STRING) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:body rdf:type rdf:Property ;
    rdfs:label 'Body' ;
    rdfs:comment 'The official name of the regulatory or industry body that issued the rating (e.g., Motion Picture Association, TV Parental Guidelines Monitoring Board, British Board of Film Classification, Freiwillige Selbstkontrolle der Filmwirtschaft). | Column body (STRING) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'The unique certificate or reference number issued by the rating body upon classification approval. Used for audit and compliance verification. | Column certificate_number (STRING) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDescriptorDrugUse rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Drug Use' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for drug use or substance abuse. | Column content_descriptor_drug_use (BOOLEAN) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorFear rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Fear' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for frightening or intense scenes that may be unsuitable for younger audiences. | Column content_descriptor_fear (BOOLEAN) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorLanguage rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Language' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for strong or offensive language. | Column content_descriptor_language (BOOLEAN) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorNudity rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Nudity' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for nudity or sexual content. | Column content_descriptor_nudity (BOOLEAN) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentDescriptorViolence rdf:type rdf:Property ;
    rdfs:label 'Content Descriptor Violence' ;
    rdfs:comment 'Boolean flag indicating whether the rating includes a content descriptor for violence or intense action. | Column content_descriptor_violence (BOOLEAN) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date on which this rating classification became effective and applicable to the content asset. | Column effective_date (DATE) in content.rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date on which this rating classification expires or is no longer valid. Null if the rating does not expire. | Column expiration_date (DATE) in content.rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumAge rdf:type rdf:Property ;
    rdfs:label 'Minimum Age' ;
    rdfs:comment 'The minimum recommended or legally mandated age (in years) for viewers of content with this rating. Null if no specific age restriction applies. | Column minimum_age (INT) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Additional internal notes or comments regarding the rating classification, including any special considerations, conditional approvals, or compliance requirements. | Column notes (STRING) in content.rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalControlEnabled rdf:type rdf:Property ;
    rdfs:label 'Parental Control Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this rating is used to enforce parental control features on linear broadcast, OTT (Over-The-Top), or MVPD (Multichannel Video Programming Distributor) platforms. | Column parental_control_enabled (BOOLEAN) in content.rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Boolean flag indicating whether the rating is legally mandated by a regulatory body (e.g., FCC, Ofcom) or is a voluntary industry classification. | Column regulatory_mandate_flag (BOOLEAN) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The date on which the content was submitted to the rating body for classification review. | Column submission_date (DATE) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:system rdf:type rdf:Property ;
    rdfs:label 'System' ;
    rdfs:comment 'The rating system or classification framework under which the rating was assigned (e.g., MPA for Motion Picture Association, TVPG for TV Parental Guidelines, BBFC for British Board of Film Classification, FSK for Freiwillige Selbstkontrolle der Filmwirtschaft, OFLC for Australian Classification Board, CBFC for Central Board of Film Certification India). | Column system (STRING) in content.rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country or territory code indicating the geographic jurisdiction where this rating applies (e.g., USA, GBR, DEU, AUS, IND). | Column territory_code (STRING) in content.rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the rating record, incremented when the rating is re-evaluated or updated due to content edits, appeals, or regulatory changes. | Column version (INT) in content.rating' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentCreditId rdf:type rdf:Property ;
    rdfs:label 'Talent Credit Id' ;
    rdfs:comment 'Unique identifier for the talent credit record. Primary key for the talent credit association entity. | Column talent_credit_id (BIGINT) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_contract. Business justification: Credits must link to contracts for residual calculation, compensation verification, guild compliance reporting, and billing position validation. Fundamental to talent payment and rights management pro | Column contract_id (BIGINT) in talent.talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:crewAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Crew Assignment Id' ;
    rdfs:comment 'Foreign key linking to production.crew_assignment. Business justification: Reconciling on-screen credits with production crew assignments is required for SAG-AFTRA compliance and residuals audits. Both records reference the same talent; linking them enables automated credit ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrewAssignment .

ind:roleId rdf:type rdf:Property ;
    rdfs:label 'Role Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_role. Business justification: Credits reference specific roles for character attribution, billing position validation, and role-specific residual eligibility. Eliminates denormalized role/character data and ensures single source o | Column role_id (BIGINT) in talent.talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Role .

ind:talentProfileId rdf:type rdf:Property ;
    rdfs:label 'Talent Profile Id' ;
    rdfs:comment 'Reference to the talent master record in the talent domain. Links to the individual or entity receiving credit for their contribution to the content. | Column talent_profile_id (BIGINT) in talent.talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:billingPosition rdf:type rdf:Property ;
    rdfs:label 'Billing Position' ;
    rdfs:comment 'The ordinal position of the talent in the credit sequence, determining the order in which credits are displayed. Lower numbers indicate higher prominence (e.g., 1 = top billing). Used for EPG display and contractual compliance. | Column billing_position (INT) in content.talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bylineText rdf:type rdf:Property ;
    rdfs:label 'Byline Text' ;
    rdfs:comment 'Byline credit text for news reporter/photographer per VREQ-019' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Credit Approval Date' ;
    rdfs:comment 'The date on which the credit was officially approved for publication. Used for audit trails and compliance with guild credit determination timelines. | Column credit_approval_date (DATE) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Approval Status' ;
    rdfs:comment 'Current approval state of the credit. Pending indicates awaiting review; Approved indicates credit is finalized and ready for publication; Disputed indicates a challenge has been raised; Rejected indicates credit was not approved; Arbitration indicates the credit is under formal guild arbitration process. | Column credit_approval_status (STRING) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCategory rdf:type rdf:Property ;
    rdfs:label 'Credit Category' ;
    rdfs:comment 'High-level categorization of the credit by functional area or department. Used for grouping credits in EPG displays, streaming platform interfaces, and analytics. [ENUM-REF-CANDIDATE: cast|director|producer|writer|cinematography|editing|music|sound|production_design|costume|makeup|visual_effects|executive|other — 14 candidates stripped; promote to reference product] | Column credit_category (STRING) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditDisplayName rdf:type rdf:Property ;
    rdfs:label 'Credit Display Name' ;
    rdfs:comment 'The exact name as it should appear in credits, EPG metadata, and streaming platform displays. May differ from the talents legal name if a pseudonym or stage name is used. This is the authoritative display value for all public-facing credit presentations. | Column credit_display_name (STRING) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditDisplayOrder rdf:type rdf:Property ;
    rdfs:label 'Credit Display Order' ;
    rdfs:comment 'The sequence number for displaying this credit within its credit type or section (e.g., within the cast section or crew section). Used for rendering credits in EPG, streaming platforms, and promotional materials. | Column credit_display_order (INT) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Credit End Timestamp' ;
    rdfs:comment 'The timestamp marking when this credit ceases to be effective or visible. Nullable for credits that remain active indefinitely. Used for managing credit corrections, disputes, or contractual credit windows. | Column credit_end_timestamp (TIMESTAMP) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditNotes rdf:type rdf:Property ;
    rdfs:label 'Credit Notes' ;
    rdfs:comment 'Free-text field for additional context, special credit requirements, contractual stipulations, or notes related to credit disputes, arbitration outcomes, or special billing arrangements. | Column credit_notes (STRING) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Credit Start Timestamp' ;
    rdfs:comment 'The timestamp marking when this credit becomes effective or visible in EPG and streaming platform metadata. Used for managing credit changes over time and versioning. | Column credit_start_timestamp (TIMESTAMP) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditType rdf:type rdf:Property ;
    rdfs:label 'Credit Type' ;
    rdfs:comment 'Classification of the credit based on how the talent contribution is presented. On-screen credits appear in the visual content; off-screen credits appear in end titles or metadata only; voice credits are for voice-over or dubbing; stunt credits are for stunt performers; archive credits are for archival footage appearances. | Column credit_type (STRING) in content.talent_credit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pseudonymFlag rdf:type rdf:Property ;
    rdfs:label 'Pseudonym Flag' ;
    rdfs:comment 'Indicates whether the talent is credited under a pseudonym or stage name rather than their legal name. True if pseudonym is used; False if legal name is used. Relevant for guild compliance and contractual credit requirements. | Column pseudonym_flag (BOOLEAN) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualsEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Residuals Eligibility Flag' ;
    rdfs:comment 'Indicates whether this credit qualifies the talent for residual payments based on content reuse, syndication, or secondary distribution. True if eligible; False otherwise. Triggers residuals calculation workflows in the rights and royalties domain. | Column residuals_eligibility_flag (BOOLEAN) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionAffiliationFlag rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation Flag' ;
    rdfs:comment 'Indicates whether the talent is affiliated with a recognized industry union (SAG-AFTRA, DGA, WGA, IATSE) for this credit. True if union-affiliated; False otherwise. Used for residuals eligibility determination and compliance reporting. | Column union_affiliation_flag (BOOLEAN) in content.talent_credit' ;
    rdfs:domain ind:TalentCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acquisitionId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Id' ;
    rdfs:comment 'Primary key for acquisition | Column acquisition_id (BIGINT) in content.acquisition' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentVersionId rdf:type rdf:Property ;
    rdfs:label 'Content Version Id' ;
    rdfs:comment 'Foreign key linking to content.version. Business justification: Acquisitions often specify which version was acquired (theatrical vs broadcast cut, localized version). This FK allows tracking version-specific acquisition terms and rights. | Column content_version_id (BIGINT) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:dealId rdf:type rdf:Property ;
    rdfs:label 'Deal Id' ;
    rdfs:comment 'Foreign key linking to distribution.deal. Business justification: Content acquisitions are executed under distribution deals that define commercial terms, revenue share, and exclusivity. Linking acquisition to deal enables deal-level cost tracking, minimum guarantee' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deal .

ind:ingestJobId rdf:type rdf:Property ;
    rdfs:label 'Ingest Job Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.ingest_job. Business justification: Content acquisition results in a physical media delivery that must be ingested. Procurement and operations teams need to verify acquired titles were successfully ingested by linking the acquisition re' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IngestJob .

ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Foreign key linking to sales.opportunity. Business justification: Content acquisitions in broadcasting are directly triggered by sales opportunities — a broadcaster acquires a title because a distribution or licensing deal is in the pipeline. Linking acquisition to ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:acquisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Acquisition Status' ;
    rdfs:comment 'Current lifecycle state of the acquisition. Negotiating = deal in discussion; Committed = contract signed but content not yet delivered; Delivered = content received and ingested; Active = content in use; Cancelled = deal terminated before delivery; Expired = license period ended. | Column acquisition_status (STRING) in content.acquisition' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionType rdf:type rdf:Property ;
    rdfs:label 'Acquisition Type' ;
    rdfs:comment 'Classification of the acquisition method. Purchase = outright ownership transfer; License = time-limited rights; Co-production = joint production investment; Commission = original content commissioned from producer; Barter = content exchanged for advertising inventory; Syndication = content licensed from syndicator for regional broadcast. | Column acquisition_type (STRING) in content.acquisition' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ancillaryRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Ancillary Rights Flag' ;
    rdfs:comment 'Indicates whether ancillary rights (merchandising, soundtrack, publishing, remake, sequel, spin-off, clip licensing) are included in the acquisition (True) or retained by the supplier (False). | Column ancillary_rights_flag (BOOLEAN) in content.acquisition' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Status' ;
    rdfs:comment 'Rights verification status confirming that all necessary clearances (music rights, talent rights, third-party content, trademarks) have been obtained for broadcast or distribution. Pending = verification in progress; Cleared = all rights confirmed; Restricted = partial clearance with limitations; Failed = clearance issues prevent exploitation. | Column clearance_status (STRING) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentWindowType rdf:type rdf:Property ;
    rdfs:label 'Content Window Type' ;
    rdfs:comment 'The distribution window or rights category acquired. Windowing refers to the sequential release strategy where content is made available through different channels over time. Theatrical = cinema release; Home Video = physical/digital sell-through; SVOD = Subscription Video On Demand; AVOD = Advertising-Supported Video On Demand; TVOD = Transactional Video On Demand; Linear Broadcast = traditional scheduled TV; Syndication = resale to multiple outlets; All Rights = comprehensive rights across all windows. [ENUM-REF-CANDIDATE: theatrical|home_video|svod|avod|tvod|linear_broadcast|syndication|all_rights — 8 candidates stripped; promote to reference product] | Column content_window_type (STRING) in content.acquisition' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'The total monetary value paid or committed for acquiring the content rights. Represents the base acquisition cost before taxes, fees, or adjustments. For licenses, this is the total license fee; for purchases, the purchase price; for commissions, the production budget committed. | Column cost_amount (DECIMAL(18,2)) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the acquisition cost amount (e.g., USD, GBP, EUR, JPY). | Column cost_currency (STRING) in content.acquisition' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The date on which the content master files and associated materials (metadata, artwork, closed captions, promotional assets) were delivered by the supplier and ingested into the enterprise Media Asset Management (MAM) system. | Column delivery_date (DATE) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryFormat rdf:type rdf:Property ;
    rdfs:label 'Delivery Format' ;
    rdfs:comment 'The technical format and delivery method used by the supplier to provide the content. Examples: ProRes 422 HQ via FTP, IMF package via Aspera, DCP hard drive, MPEG-4 via CDN, tape (legacy). | Column delivery_format (STRING) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the acquired rights are exclusive (True) or non-exclusive (False) within the specified territory and window. Exclusive rights prevent the supplier from licensing the same content to competitors in the same territory/window. | Column exclusivity_flag (BOOLEAN) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formatRights rdf:type rdf:Property ;
    rdfs:label 'Format Rights' ;
    rdfs:comment 'The technical formats or delivery specifications covered by the acquisition. May include SD, HD, 4K, HDR, theatrical DCP, broadcast master, streaming-optimized, etc. Defines the quality and format tiers the enterprise is authorized to distribute. | Column format_rights (STRING) in content.acquisition' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Holdback Period Days' ;
    rdfs:comment 'The number of days during which the content cannot be exploited in certain windows or territories as stipulated by the acquisition agreement. Holdback periods protect prior windows (e.g., theatrical holdback prevents SVOD release for 90 days post-theatrical). | Column holdback_period_days (INT) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageRights rdf:type rdf:Property ;
    rdfs:label 'Language Rights' ;
    rdfs:comment 'The languages or language versions for which rights were acquired. May specify original language only, dubbed versions, subtitled versions, or all language adaptations. Examples: English, Spanish, French; All Languages; Original + Subtitles. | Column language_rights (STRING) in content.acquisition' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseEndDate rdf:type rdf:Property ;
    rdfs:label 'License End Date' ;
    rdfs:comment 'The date on which the acquired content rights expire and the enterprise must cease exploitation. Null for perpetual purchases. For time-limited licenses, this defines the end of the license term. | Column license_end_date (DATE) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseStartDate rdf:type rdf:Property ;
    rdfs:label 'License Start Date' ;
    rdfs:comment 'The date from which the enterprise is authorized to begin exploiting the acquired content rights. For licenses, this is the effective start of the license term; for purchases, typically the acquisition date. | Column license_start_date (DATE) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumGuaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Amount' ;
    rdfs:comment 'The minimum guaranteed payment to the supplier regardless of actual revenue performance. Common in revenue-sharing deals where the enterprise commits to a floor payment even if royalties do not reach this threshold. | Column minimum_guarantee_amount (DECIMAL(18,2)) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Contractual payment schedule and conditions for the acquisition cost. May include milestone-based payments, installment schedules, advance payments, or revenue-sharing arrangements. | Column payment_terms (STRING) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'External business identifier for this acquisition transaction. May be a purchase order number, deal reference, or contract line item identifier used in communications with the supplier. | Column reference_number (STRING) in content.acquisition' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualsObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Residuals Obligation Flag' ;
    rdfs:comment 'Indicates whether the enterprise has an obligation to pay residuals (talent reuse payments) to performers, writers, directors, or other rights holders each time the content is rebroadcast or redistributed (True) or if residuals are the supplier\'s responsibility (False). | Column residuals_obligation_flag (BOOLEAN) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percent' ;
    rdfs:comment 'The percentage of revenue or receipts that must be paid to the supplier as ongoing royalties under a revenue-sharing acquisition model. Null if the acquisition is a flat-fee structure with no revenue share. | Column royalty_rate_percent (DECIMAL(5,2)) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runsAllowed rdf:type rdf:Property ;
    rdfs:label 'Runs Allowed' ;
    rdfs:comment 'The maximum number of times the content may be broadcast or streamed under the acquisition agreement. Common in linear broadcast licenses (e.g., 3 runs over 2 years). Null indicates unlimited runs within the license period. | Column runs_allowed (INT) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runsConsumed rdf:type rdf:Property ;
    rdfs:label 'Runs Consumed' ;
    rdfs:comment 'The number of runs (broadcasts or streams) that have been executed to date against the runs_allowed limit. Tracked to ensure compliance with contractual run restrictions. | Column runs_consumed (INT) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sublicensingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Allowed Flag' ;
    rdfs:comment 'Indicates whether the enterprise is permitted to sublicense the acquired content to third parties (True) or must exploit the content directly only (False). Sublicensing enables syndication and secondary distribution deals. | Column sublicensing_allowed_flag (BOOLEAN) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryScope rdf:type rdf:Property ;
    rdfs:label 'Territory Scope' ;
    rdfs:comment 'Geographic territories or markets for which the content rights were acquired. May be specified as country codes (ISO 3166), regional groupings, or worldwide. Examples: USA, GBR, North America, EMEA, Worldwide. | Column territory_scope (STRING) in content.acquisition' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Event Id' ;
    rdfs:comment 'Primary key for lifecycle_event | Column lifecycle_event_id (BIGINT) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:automatedFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Flag' ;
    rdfs:comment 'Indicates whether this lifecycle transition was triggered automatically by the workflow system (True) or manually by a user (False). | Column automated_flag (BOOLEAN) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockingCondition rdf:type rdf:Property ;
    rdfs:label 'Blocking Condition' ;
    rdfs:comment 'Any condition, issue, or dependency that is blocking or delaying the content from progressing to the next lifecycle stage (e.g., pending rights clearance, QC failure, missing metadata, technical issue). Null if no blocking condition exists. | Column blocking_condition (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingResolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Blocking Resolved Flag' ;
    rdfs:comment 'Indicates whether any previously identified blocking condition has been resolved. True if resolved, False if still blocking, Null if no blocking condition was present. | Column blocking_resolved_flag (BOOLEAN) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCheckpointPassed rdf:type rdf:Property ;
    rdfs:label 'Compliance Checkpoint Passed' ;
    rdfs:comment 'Indicates whether all regulatory and compliance checkpoints required for this lifecycle stage were successfully passed (e.g., content rating verification, rights clearance, broadcast standards review). True if passed, False if failed, Null if not applicable. | Column compliance_checkpoint_passed (BOOLEAN) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryPlatform rdf:type rdf:Property ;
    rdfs:label 'Delivery Platform' ;
    rdfs:comment 'The target delivery platform or distribution channel for which this lifecycle stage is being prepared (e.g., Linear Broadcast, OTT, VOD, SVOD, AVOD, Theatrical, Syndication). Applicable primarily for distribution-related lifecycle stages. | Column delivery_platform (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'The sequential order of this lifecycle event within the complete lifecycle history of the content asset. Used to reconstruct the chronological audit trail. | Column event_sequence_number (INT) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'The operational lifecycle stage of the content asset at the time of this event. Represents the major phase in the content workflow from acquisition through archival. [ENUM-REF-CANDIDATE: acquisition|commission|development|pre_production|production|post_production|clearance|mastering|distribution|archival|retired — 11 candidates stripped; promote to reference product] | Column lifecycle_stage (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The status of the content asset immediately after this lifecycle transition. Represents the current state following the event. | Column new_status (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The status of the content asset immediately before this lifecycle transition. Captures the prior state for audit trail and provenance. | Column previous_status (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleTeam rdf:type rdf:Property ;
    rdfs:label 'Responsible Team' ;
    rdfs:comment 'The business unit, department, or team responsible for executing or approving this lifecycle transition (e.g., Production, Post-Production, Rights Management, Quality Control, Distribution). | Column responsible_team (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollbackFlag rdf:type rdf:Property ;
    rdfs:label 'Rollback Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event represents a rollback to a previous stage due to failure, rejection, or rework requirement. True if rollback, False for forward progression. | Column rollback_flag (BOOLEAN) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollbackReason rdf:type rdf:Property ;
    rdfs:label 'Rollback Reason' ;
    rdfs:comment 'The reason or justification for rolling back the content to a previous lifecycle stage. Null if rollback_flag is False. | Column rollback_reason (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaActualDate rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Date' ;
    rdfs:comment 'The actual date when this lifecycle stage was completed. Used to measure SLA compliance by comparing against sla_target_date. | Column sla_actual_date (DATE) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether this lifecycle transition breached the defined SLA target. True if actual date exceeded target date, False otherwise. | Column sla_breach_flag (BOOLEAN) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetDate rdf:type rdf:Property ;
    rdfs:label 'Sla Target Date' ;
    rdfs:comment 'The target date by which this lifecycle stage should be completed, as defined by internal SLA or contractual delivery commitment. Used for SLA monitoring and performance tracking. | Column sla_target_date (DATE) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'The name of the source system or module that generated this lifecycle event record (e.g., Dalet Galaxy, Ericsson MediaFirst, Rightsline, manual entry). | Column system_source (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionDurationHours rdf:type rdf:Property ;
    rdfs:label 'Transition Duration Hours' ;
    rdfs:comment 'The elapsed time in hours between the previous lifecycle event and this event. Measures the duration spent in the previous stage. Used for operational efficiency analysis. | Column transition_duration_hours (DECIMAL(10,2)) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'The precise date and time when the lifecycle stage transition occurred. This is the business event timestamp, distinct from audit timestamps. | Column transition_timestamp (TIMESTAMP) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:triggeredByEvent rdf:type rdf:Property ;
    rdfs:label 'Triggered By Event' ;
    rdfs:comment 'The specific event or action that triggered this lifecycle transition (e.g., QC approval, rights clearance, ingest completion, delivery confirmation, manual override). | Column triggered_by_event (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'The version identifier of the content asset at the time of this lifecycle event. Tracks iterations, edits, and revisions through the production and post-production workflow. | Column version_number (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowInstanceCode rdf:type rdf:Property ;
    rdfs:label 'Workflow Instance Code' ;
    rdfs:comment 'The unique identifier of the workflow instance in the Media Asset Management (MAM) system that orchestrated this lifecycle transition. Links to Dalet Galaxy workflow execution. | Column workflow_instance_code (STRING) in content.lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artworkId rdf:type rdf:Property ;
    rdfs:label 'Artwork Id' ;
    rdfs:comment 'Unique identifier for the artwork asset record. Primary key for the artwork catalog. | Column artwork_id (BIGINT) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:featuredTalentProfileId rdf:type rdf:Property ;
    rdfs:label 'Featured Talent Profile Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_profile. Business justification: Talent likeness approval workflow — talent contracts require explicit approval before a talent\'s likeness is used in promotional artwork. Legal/clearance teams must trace key art and promotional image' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the artwork received final approval for distribution and use. Marks the transition from draft/review to production-ready status. Format: yyyy-MM-dd. | Column approval_date (DATE) in content.artwork' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedForUseFlag rdf:type rdf:Property ;
    rdfs:label 'Approved For Use Flag' ;
    rdfs:comment 'Boolean indicator of whether the artwork has passed legal, brand, and creative approval processes and is authorized for public distribution. True indicates approved and ready for use, False indicates pending approval or rejected. | Column approved_for_use_flag (BOOLEAN) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:artworkType rdf:type rdf:Property ;
    rdfs:label 'Artwork Type' ;
    rdfs:comment 'Classification of the artwork asset by its intended use and format. Key-art is primary promotional image, thumbnail for Electronic Program Guide (EPG) and streaming UI, banner for web headers, poster for theatrical/retail, logo for branding, still for scene captures. | Column artwork_type (STRING) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorProfile rdf:type rdf:Property ;
    rdfs:label 'Color Profile' ;
    rdfs:comment 'Color space standard applied to the artwork for accurate color reproduction across devices and platforms. sRGB for web/digital, Adobe RGB for professional photography, CMYK for print, Rec. 709 for HD broadcast, Rec. 2020 for Ultra HD (UHD) broadcast. | Column color_profile (STRING) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingDisplayedFlag rdf:type rdf:Property ;
    rdfs:label 'Content Rating Displayed Flag' ;
    rdfs:comment 'Boolean indicator of whether the artwork includes a visible Motion Picture Association (MPA) or equivalent content rating badge (G, PG, PG-13, R, NC-17, TV-Y, TV-PG, TV-14, TV-MA). True indicates rating is burned into the image, False indicates clean artwork without rating overlay. | Column content_rating_displayed_flag (BOOLEAN) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copyrightHolder rdf:type rdf:Property ;
    rdfs:label 'Copyright Holder' ;
    rdfs:comment 'Legal entity or organization that owns the copyright to the artwork asset. May be the production company, studio, distributor, or external agency. Critical for rights clearance and syndication. | Column copyright_holder (STRING) in content.artwork' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copyrightYear rdf:type rdf:Property ;
    rdfs:label 'Copyright Year' ;
    rdfs:comment 'Year in which the artwork was created and copyright was established. Used for copyright notice display and rights duration calculation. | Column copyright_year (INT) in content.artwork' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which the artwork rights or usage authorization expires and the asset should no longer be used for promotional or distribution purposes. Supports rights management and holdback compliance. Nullable for perpetual-use artwork. Format: yyyy-MM-dd. | Column expiry_date (DATE) in content.artwork' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:heightPixels rdf:type rdf:Property ;
    rdfs:label 'Height Pixels' ;
    rdfs:comment 'Vertical dimension of the artwork image measured in pixels. Used to determine display suitability and resolution quality for various distribution channels. | Column height_pixels (INT) in content.artwork' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language of any text overlay or localization present in the artwork. Used for multi-territory distribution and localization workflows. | Column language_code (STRING) in content.artwork' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageOverlayFlag rdf:type rdf:Property ;
    rdfs:label 'Language Overlay Flag' ;
    rdfs:comment 'Boolean indicator of whether the artwork contains burned-in text, titles, or language-specific graphic elements. True indicates localized artwork requiring territory-specific versions, False indicates language-neutral artwork suitable for all markets. | Column language_overlay_flag (BOOLEAN) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photographerCredit rdf:type rdf:Property ;
    rdfs:label 'Photographer Credit' ;
    rdfs:comment 'Name or attribution of the photographer, artist, or creative agency responsible for creating the artwork. Used for copyright attribution, residuals tracking, and legal compliance with talent agreements. | Column photographer_credit (STRING) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric ranking indicating the preferred display order or priority of this artwork when multiple artwork assets exist for the same title and type. Lower numbers indicate higher priority. Used by Electronic Program Guide (EPG) and streaming platform UI to select the primary artwork. | Column priority_rank (INT) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionDpi rdf:type rdf:Property ;
    rdfs:label 'Resolution Dpi' ;
    rdfs:comment 'Image resolution measured in dots per inch. 72 DPI for web/screen display, 300 DPI for high-quality print, 150 DPI for standard print. Critical for determining print suitability and image quality. | Column resolution_dpi (INT) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Unique identifier or reference key for the artwork asset in the originating source system. Enables traceability and synchronization with upstream Digital Asset Management (DAM) or creative management platforms. | Column source_system_code (STRING) in content.artwork' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRights rdf:type rdf:Property ;
    rdfs:label 'Usage Rights' ;
    rdfs:comment 'Scope of authorized usage channels and media types for the artwork. All-media for unrestricted use, digital-only for Over-The-Top (OTT) and web, print-only for press kits and retail, broadcast-only for linear television, theatrical-only for cinema, promotional-only for advertising and marketing campaigns. | Column usage_rights (STRING) in content.artwork' ;
    rdfs:domain ind:Artwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthPixels rdf:type rdf:Property ;
    rdfs:label 'Width Pixels' ;
    rdfs:comment 'Horizontal dimension of the artwork image measured in pixels. Used to determine display suitability and resolution quality for various distribution channels. | Column width_pixels (INT) in content.artwork' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageId rdf:type rdf:Property ;
    rdfs:label 'Package Id' ;
    rdfs:comment 'Primary key for package | Column package_id (BIGINT) in content.package' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:deliveryChannelId rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel Id' ;
    rdfs:comment 'Foreign key linking to distribution.delivery_channel. Business justification: Content packages are assigned to specific delivery channels (FAST channels, linear feeds, VOD storefronts). This link enables channel-level package inventory management, FAST channel programming, and ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryChannel .

ind:partnerId rdf:type rdf:Property ;
    rdfs:label 'Partner Id' ;
    rdfs:comment 'Foreign key linking to distribution.distribution_partner. Business justification: Packages are sold to distribution partners (cable operators, MVPD aggregators, international distributors). Package-level licensing agreements and carriage fees are negotiated at partner level for bul | Column distribution_partner_id (BIGINT) in distribution.package' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:commercialContext rdf:type rdf:Property ;
    rdfs:label 'Commercial Context' ;
    rdfs:comment 'Free-text description of the business purpose or deal context for which the package was assembled, such as upfront sales event, scatter market offering, MVPD (Multichannel Video Programming Distributor) carriage negotiation, or international syndication deal. | Column commercial_context (STRING) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Drm Required Flag' ;
    rdfs:comment 'Indicates whether Digital Rights Management (DRM) protection is required for distribution of this package (True/False). Critical for rights enforcement and anti-piracy compliance. | Column drm_required_flag (BOOLEAN) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagePrimary rdf:type rdf:Property ;
    rdfs:label 'Language Primary' ;
    rdfs:comment 'The primary language of the content in the package, expressed as ISO 639-2 three-letter language code (e.g., eng, spa, fra). Critical for localization and international distribution. | Column language_primary (STRING) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'The username or identifier of the user or system that last modified the package record. Used for change accountability and audit trail. | Column modified_by (STRING) in content.package' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the package: draft (under construction), active (available for distribution), suspended (temporarily unavailable), expired (past effective period), terminated (cancelled before expiry), or archived (historical record). | Column package_status (STRING) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'The classification of the package based on its commercial or distribution purpose: syndication (content resale to multiple outlets), SVOD (Subscription Video On Demand) library (subscription-based catalog), AVOD (Advertising-Supported Video On Demand) catalog (ad-supported offering), FAST (Free Ad-Supported Streaming Television) channel (linear streaming channel), educational (academic or training content bundle), or international (cross-border distribution bundle). | Column package_type (STRING) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'The URL or path to the thumbnail image representing the package in catalogs, EPG (Electronic Program Guide) listings, and user interfaces. | Column thumbnail_url (STRING) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRuntimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Runtime Hours' ;
    rdfs:comment 'The aggregate runtime of all content in the package, expressed in hours. Used for programming and scheduling calculations. | Column total_runtime_hours (DECIMAL(10,2)) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTitleCount rdf:type rdf:Property ;
    rdfs:label 'Total Title Count' ;
    rdfs:comment 'The total number of distinct titles (episodes, films, clips, or other content assets) included in the package. Used for inventory reporting and deal valuation. | Column total_title_count (INT) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valueUsd rdf:type rdf:Property ;
    rdfs:label 'Value Usd' ;
    rdfs:comment 'The estimated or contracted commercial value of the package in United States Dollars (USD). Used for revenue forecasting, deal valuation, and financial reporting. | Column value_usd (DECIMAL(15,2)) in content.package' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Primary key for project | Column project_id (BIGINT) in production.project' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Foreign key linking to scheduling.channel. Business justification: Projects are commissioned for specific broadcast channels/networks. Network commissioning process requires tracking which channel ordered the content. Essential for content planning, budget allocation | Column channel_id (BIGINT) in scheduling.project' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:masterLicenseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Master License Agreement Id' ;
    rdfs:comment 'Foreign key linking to rights.license_agreement. Business justification: Projects often have master license agreements governing distribution rights (co-production deals, pre-sales, output deals). Real business need: tracking which license agreements fund or govern a produ | Column master_license_agreement_id (BIGINT) in rights.project' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAgreement .

ind:productionSeasonId rdf:type rdf:Property ;
    rdfs:label 'Production Season Id' ;
    rdfs:comment 'Foreign key linking to content.season. Business justification: A production project maps to a specific season for season-level budget approval, greenlight reporting, and rights clearance. project.season_number is a denormalized plain attribute; replacing with FK ' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Season .

ind:targetDemographicSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Demographic Segment Id' ;
    rdfs:comment 'Foreign key linking to audience.demographic_segment. Business justification: Greenlight and development decisions in media broadcasting explicitly target a demographic segment (e.g., A18-49, W25-54). This FK enables greenlight committee reporting, sales alignment, and content ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemographicSegment .

ind:targetOttPlatformId rdf:type rdf:Property ;
    rdfs:label 'Target Ott Platform Id' ;
    rdfs:comment 'Foreign key linking to distribution.ott_platform. Business justification: Productions are commissioned for specific streaming platforms (Netflix Originals, HBO Max Exclusives). Platform determines technical specs, content ratings, delivery windows. Real business process: pl | Column target_ott_platform_id (BIGINT) in distribution.project' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OttPlatform .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Date on which the final deliverable was actually delivered to the distribution or broadcast platform. Compared against target_delivery_date to measure on-time delivery performance and SLA compliance. | Column actual_delivery_date (DATE) in production.project' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Usd' ;
    rdfs:comment 'Cumulative actual expenditure incurred against this production project to date, denominated in US Dollars. Sourced from SAP S/4HANA cost postings. Compared against approved_budget_usd for variance and financial reconciliation reporting. | Column actual_spend_usd (DECIMAL(18,2)) in production.project' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Usd' ;
    rdfs:comment 'Total production budget formally approved at greenlight, denominated in US Dollars. Represents the authorized spend ceiling for the project. Used for financial controlling, variance analysis, and EBITDA reporting in SAP S/4HANA. | Column approved_budget_usd (DECIMAL(18,2)) in production.project' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coProductionFlag rdf:type rdf:Property ;
    rdfs:label 'Co Production Flag' ;
    rdfs:comment 'Indicates whether this production project is a co-production involving one or more external production partners. Triggers co-production agreement workflows, shared rights structures, and split budget reporting in SAP S/4HANA. | Column co_production_flag (BOOLEAN) in production.project' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentGenre rdf:type rdf:Property ;
    rdfs:label 'Content Genre' ;
    rdfs:comment 'Primary genre classification of the content being produced (e.g., drama, comedy, thriller, sports, news, reality). Used for audience targeting, scheduling, advertising sales, and rights windowing strategies. [ENUM-REF-CANDIDATE: drama|comedy|thriller|action|documentary|news|reality|sports|animation|horror — promote to reference product] | Column content_genre (STRING) in production.project' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRating rdf:type rdf:Property ;
    rdfs:label 'Content Rating' ;
    rdfs:comment 'Official content rating assigned by the Motion Picture Association (MPA) or TV Parental Guidelines system. Governs broadcast scheduling, advertising eligibility, and platform distribution restrictions including COPPA compliance for children\'s content. [ENUM-REF-CANDIDATE: G|PG|PG-13|R|NC-17|TV-Y|TV-Y7|TV-G|TV-PG|TV-14|TV-MA — 11 candidates stripped; promote to reference product] | Column content_rating (STRING) in production.project' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaApplicable rdf:type rdf:Property ;
    rdfs:label 'Coppa Applicable' ;
    rdfs:comment 'Indicates whether this production is directed at children under 13 and therefore subject to COPPA compliance requirements. Affects data collection practices, advertising eligibility, and platform distribution restrictions. | Column coppa_applicable (BOOLEAN) in production.project' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the budget and spend amounts recorded on this project (e.g., USD, GBP, EUR). Supports multi-currency production environments for international co-productions. | Column currency_code (STRING) in production.project' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletWorkflowReference rdf:type rdf:Property ;
    rdfs:label 'Dalet Workflow Reference' ;
    rdfs:comment 'Integration reference identifier linking this production project to its corresponding workflow instance in Dalet Galaxy Media Asset Management and Workflow Orchestration system. Enables cross-system traceability for ingest, metadata, archive, and workflow operations. | Column dalet_workflow_reference (STRING) in production.project' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmRequired rdf:type rdf:Property ;
    rdfs:label 'Drm Required' ;
    rdfs:comment 'Indicates whether Digital Rights Management (DRM) protection must be applied to the delivered content assets. Drives technical delivery specifications for CDN, streaming platform configuration, and Akamai CDN security settings. | Column drm_required (BOOLEAN) in production.project' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:episodeCount rdf:type rdf:Property ;
    rdfs:label 'Episode Count' ;
    rdfs:comment 'Total number of episodes commissioned for this production project. Applicable to scripted and unscripted series. Used for budget modeling, scheduling, and rights licensing calculations. Null for single-title formats such as feature films. | Column episode_count (INT) in production.project' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fccLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Fcc License Required' ;
    rdfs:comment 'Indicates whether this production requires FCC broadcast licensing compliance review prior to linear broadcast distribution. Applicable to content intended for over-the-air or cable transmission in the United States. | Column fcc_license_required (BOOLEAN) in production.project' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:greenlightDate rdf:type rdf:Property ;
    rdfs:label 'Greenlight Date' ;
    rdfs:comment 'Calendar date on which the production project received formal executive greenlight approval. Marks the official start of the production lifecycle and triggers budget release and resource mobilization. | Column greenlight_date (DATE) in production.project' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:greenlightStatus rdf:type rdf:Property ;
    rdfs:label 'Greenlight Status' ;
    rdfs:comment 'Executive approval status of the production project. Indicates whether the project has received formal greenlight authorization to proceed, is pending approval, is on hold, or has been cancelled. Controls budget release and resource mobilization. | Column greenlight_status (STRING) in production.project' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalIpFlag rdf:type rdf:Property ;
    rdfs:label 'Original Ip Flag' ;
    rdfs:comment 'Indicates whether this production is based on original intellectual property owned by the organization, as opposed to licensed or adapted IP. Affects rights ownership, residuals obligations, and long-term asset valuation. | Column original_ip_flag (BOOLEAN) in production.project' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postProductionStartDate rdf:type rdf:Property ;
    rdfs:label 'Post Production Start Date' ;
    rdfs:comment 'Scheduled or actual date on which post-production activities commenced, including editing, VFX, color grading, audio mixing, and transcoding. Used for facility booking and deliverable milestone planning. | Column post_production_start_date (DATE) in production.project' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preProductionStartDate rdf:type rdf:Property ;
    rdfs:label 'Pre Production Start Date' ;
    rdfs:comment 'Scheduled or actual date on which pre-production activities commenced, including casting, location scouting, script breakdown, and crew hiring. Used for production planning and milestone tracking. | Column pre_production_start_date (DATE) in production.project' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:principalPhotographyEndDate rdf:type rdf:Property ;
    rdfs:label 'Principal Photography End Date' ;
    rdfs:comment 'Scheduled or actual date on which principal photography concluded (picture wrap). Triggers transition to post-production phase and initiates post-production resource scheduling. | Column principal_photography_end_date (DATE) in production.project' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:principalPhotographyStartDate rdf:type rdf:Property ;
    rdfs:label 'Principal Photography Start Date' ;
    rdfs:comment 'Scheduled or actual date on which principal photography (primary filming) commenced. A key production milestone used for crew scheduling, facility booking, and insurance activation. | Column principal_photography_start_date (DATE) in production.project' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionCountry rdf:type rdf:Property ;
    rdfs:label 'Production Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the primary country in which the production is being executed. Determines applicable regulatory frameworks, tax incentive eligibility, and co-production treaty benefits. | Column production_country (STRING) in production.project' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionFormat rdf:type rdf:Property ;
    rdfs:label 'Production Format' ;
    rdfs:comment 'Primary technical production format and resolution specification (e.g., 4K UHD, HD 1080p, HDR10). Determines post-production pipeline, transcoding requirements, and delivery specifications for broadcast and streaming platforms. [ENUM-REF-CANDIDATE: 4K_UHD|HD_1080p|HD_720p|SD|HDR10|Dolby_Vision|IMAX — 7 candidates stripped; promote to reference product] | Column production_format (STRING) in production.project' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionPhase rdf:type rdf:Property ;
    rdfs:label 'Production Phase' ;
    rdfs:comment 'Current phase of the content production lifecycle. Tracks the project\'s progression from development through delivery. Used to gate workflow steps, resource allocation, and financial milestone releases. | Column production_phase (STRING) in production.project' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the content production project by format and genre category. Drives production workflow templates, budget models, rights structures, and scheduling logic. [ENUM-REF-CANDIDATE: scripted_series|feature_film|documentary|live_event|news_segment|unscripted_series|short_form — promote to reference product] | Column project_type (STRING) in production.project' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'SAP S/4HANA Work Breakdown Structure element code that maps this production project to the enterprise financial controlling hierarchy for budget tracking, cost allocation, and financial reconciliation. | Column sap_wbs_element (STRING) in production.project' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synopsis rdf:type rdf:Property ;
    rdfs:label 'Synopsis' ;
    rdfs:comment 'Short narrative description of the content production project\'s story, subject matter, or editorial concept. Used for internal greenlight documentation, sales pitches, EPG metadata, and Dalet Galaxy asset metadata. | Column synopsis (STRING) in production.project' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Target Delivery Date' ;
    rdfs:comment 'Contractually committed or internally planned date by which the finished content must be delivered to distribution, broadcast, or streaming platforms. Drives post-production scheduling, windowing strategy, and SLA compliance. | Column target_delivery_date (DATE) in production.project' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Primary key for budget | Column budget_id (BIGINT) in production.budget' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Cumulative actual costs incurred to date for this cost category, sourced from SAP S/4HANA FI/CO actual postings. Represents real expenditure against the approved budget. | Column actual_cost_amount (DECIMAL(18,2)) in production.budget' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current workflow approval status of this budget record. DRAFT = in preparation; PENDING_APPROVAL = submitted for sign-off; APPROVED = formally authorized; REJECTED = returned for revision; LOCKED = frozen for actuals comparison; CLOSED = production complete. | Column approval_status (STRING) in production.budget' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'The formally approved budget amount for this cost category and version, representing the financial control baseline authorized by the production greenlight committee. | Column approved_amount (DECIMAL(18,2)) in production.budget' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Free-text narrative explaining the business justification for a budget revision (e.g., \'Schedule extension due to weather delays\', \'Additional VFX shots approved by director\'). Mandatory for revised versions. | Column change_reason (STRING) in production.budget' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRequestReference rdf:type rdf:Property ;
    rdfs:label 'Change Request Reference' ;
    rdfs:comment 'Reference number of the formal budget change request (BCR) document that authorized a revision to this budget line, traceable in the production finance approval workflow. | Column change_request_reference (STRING) in production.budget' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'Total value of open purchase order commitments (obligations) for this cost category that have been raised but not yet invoiced. Represents encumbered funds in the SAP MM/CO commitment ledger. | Column committed_amount (DECIMAL(18,2)) in production.budget' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyAmount rdf:type rdf:Property ;
    rdfs:label 'Contingency Amount' ;
    rdfs:comment 'The absolute monetary value of the contingency reserve allocated for this cost category, derived from the contingency percentage applied to the approved budget amount. | Column contingency_amount (DECIMAL(18,2)) in production.budget' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyPercentage rdf:type rdf:Property ;
    rdfs:label 'Contingency Percentage' ;
    rdfs:comment 'The percentage of the approved budget allocated as contingency reserve for this cost category, representing the risk buffer approved by the production finance committee. | Column contingency_percentage (DECIMAL(5,2)) in production.budget' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Cost Category Code' ;
    rdfs:comment 'SAP cost element or cost category code classifying the type of production expenditure (e.g., ATL-TALENT, BTL-CREW, BTL-EQUIPMENT, POST-VFX, POST-AUDIO). [ENUM-REF-CANDIDATE: ATL-TALENT|ATL-RIGHTS|BTL-CREW|BTL-EQUIPMENT|BTL-FACILITIES|BTL-TRAVEL|POST-VFX|POST-AUDIO|POST-COLOR|CONTINGENCY — promote to reference product] | Column cost_category_code (STRING) in production.budget' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCategoryName rdf:type rdf:Property ;
    rdfs:label 'Cost Category Name' ;
    rdfs:comment 'Human-readable name of the production cost category (e.g., \'Above-the-Line Talent\', \'Below-the-Line Crew\', \'Visual Effects\', \'Audio Post-Production\'). | Column cost_category_name (STRING) in production.budget' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costLineType rdf:type rdf:Property ;
    rdfs:label 'Cost Line Type' ;
    rdfs:comment 'High-level classification of the cost line distinguishing above-the-line (ATL) creative costs (writers, directors, producers, talent) from below-the-line (BTL) technical and crew costs, post-production, contingency, and overhead. | Column cost_line_type (STRING) in production.budget' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign exchange rate applied to convert this budget record\'s currency to the production\'s reporting currency at the time of budget approval or revision. | Column exchange_rate (DECIMAL(12,6)) in production.budget' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month number 1–12 or 1–16 for special periods) within the fiscal year to which this budget line is assigned in SAP CO. | Column fiscal_period (INT) in production.budget' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The four-digit fiscal year to which this budget record belongs in the SAP S/4HANA CO controlling area, used for annual financial planning and SOX reporting. | Column fiscal_year (INT) in production.budget' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastAmount rdf:type rdf:Property ;
    rdfs:label 'Forecast Amount' ;
    rdfs:comment 'Latest estimate of the total cost expected to be incurred for this cost category by production completion, incorporating actuals to date and projected remaining spend. | Column forecast_amount (DECIMAL(18,2)) in production.budget' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGreenlightBudget rdf:type rdf:Property ;
    rdfs:label 'Is Greenlight Budget' ;
    rdfs:comment 'Indicates whether this budget record represents the original greenlight-approved budget for the production, as distinct from subsequent revisions. The greenlight budget is the primary financial authorization baseline. | Column is_greenlight_budget (BOOLEAN) in production.budget' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether this budget version has been locked and is no longer open for modification. A locked budget serves as the immutable financial baseline for variance reporting. | Column is_locked (BOOLEAN) in production.budget' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The end date of the fiscal or production period covered by this budget record. Defines the temporal boundary for cost accumulation and variance measurement. | Column period_end_date (DATE) in production.budget' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The start date of the fiscal or production period covered by this budget record, aligning to the SAP fiscal year/period structure. | Column period_start_date (DATE) in production.budget' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the group reporting currency to which all amounts are translated for consolidated financial reporting (e.g., USD for a US-headquartered broadcaster). | Column reporting_currency_code (STRING) in production.budget' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Amount' ;
    rdfs:comment 'The most recently revised budget amount for this cost category following a formal budget change request. Null if no revision has been approved since the original budget. | Column revised_amount (DECIMAL(18,2)) in production.budget' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapCostObjectCode rdf:type rdf:Property ;
    rdfs:label 'Sap Cost Object Code' ;
    rdfs:comment 'The SAP S/4HANA CO cost object identifier (Internal Order number or WBS Element ID) that anchors this budget record to the controlling module for financial reconciliation. | Column sap_cost_object_code (STRING) in production.budget' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The difference between the approved (or revised) budget amount and the sum of actual costs plus commitments. A negative value indicates an over-budget condition; positive indicates underspend. | Column variance_amount (DECIMAL(18,2)) in production.budget' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual budget line item within a production budget. Primary key for this entity. | Column budget_line_id (BIGINT) in production.budget_line' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetLine .

ind:salesCampaignId rdf:type rdf:Property ;
    rdfs:label 'Sales Campaign Id' ;
    rdfs:comment 'Foreign key linking to sales.campaign. Business justification: Budget lines track advertiser-funded production costs for branded content and product integrations. Business process: advertiser co-production cost allocation, campaign-funded production expense track | Column campaign_id (BIGINT) in sales.budget_line' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesCampaign .

ind:accountCode rdf:type rdf:Property ;
    rdfs:label 'Account Code' ;
    rdfs:comment 'Industry-standard production account code identifying the cost category within the budget (e.g., 1100 for Above-the-Line Talent, 2200 for Camera Equipment). Follows standard production accounting chart of accounts (e.g., AICP, Producers Guild). | Column account_code (STRING) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accruedAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Amount' ;
    rdfs:comment 'Costs accrued for work performed or services received but not yet invoiced or formally committed. Supports period-end financial close and accurate cost-to-complete reporting. | Column accrued_amount (DECIMAL(18,2)) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'Total actual costs incurred and posted against this budget line to date, sourced from SAP FI invoice postings and payroll actuals. Used for variance analysis against budgeted and committed amounts. | Column actual_amount (DECIMAL(18,2)) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedAmount rdf:type rdf:Property ;
    rdfs:label 'Budgeted Amount' ;
    rdfs:comment 'Original approved budget amount for this line item as established at greenlight or budget approval. Represents the planned cost baseline against which actuals and commitments are measured. | Column budgeted_amount (DECIMAL(18,2)) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyPct rdf:type rdf:Property ;
    rdfs:label 'Contingency Pct' ;
    rdfs:comment 'Contingency percentage applied to this budget line to cover unforeseen cost overruns. Typically 5–15% for production lines. Contributes to the overall production contingency reserve. | Column contingency_pct (DECIMAL(7,4)) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'High-level cost category classifying the budget line within the production budget structure. Above-the-line covers creative talent (writers, directors, producers, cast); below-the-line covers crew, equipment, locations, and production services. [ENUM-REF-CANDIDATE: above_the_line|below_the_line|post_production|music_licensing|vfx|marketing|overhead|contingency|insurance|legal — promote to reference product] | Column cost_category (STRING) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSubCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Sub Category' ;
    rdfs:comment 'Granular sub-classification within the cost category (e.g., \'Cast Fees\', \'Location Fees\', \'Equipment Rental\', \'VFX Compositing\', \'Music Synchronization License\', \'Post-Production Labor\'). Enables detailed variance analysis at the sub-category level. | Column cost_sub_category (STRING) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fringeRatePct rdf:type rdf:Property ;
    rdfs:label 'Fringe Rate Pct' ;
    rdfs:comment 'Percentage applied to labor costs on this line to account for employer fringe benefits (payroll taxes, pension contributions, health insurance, residuals). Standard production accounting practice for above-the-line and below-the-line labor lines. | Column fringe_rate_pct (DECIMAL(7,4)) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'SAP S/4HANA General Ledger account number to which this budget line maps for financial reporting and cost center allocation. Enables reconciliation between production budgets and enterprise financial statements. | Column gl_account_code (STRING) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAboveTheLine rdf:type rdf:Property ;
    rdfs:label 'Is Above The Line' ;
    rdfs:comment 'Flag indicating whether this budget line is classified as above-the-line (ATL) cost, covering creative talent such as writers, directors, producers, and principal cast. False indicates below-the-line (BTL) cost. | Column is_above_the_line (BOOLEAN) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnionLabor rdf:type rdf:Property ;
    rdfs:label 'Is Union Labor' ;
    rdfs:comment 'Flag indicating whether this budget line involves union or guild labor subject to collective bargaining agreements (DGA, SAG-AFTRA, WGA, IATSE). Drives fringe rate calculations and residuals obligations. | Column is_union_labor (BOOLEAN) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Free-text description of the specific cost item represented by this budget line (e.g., \'Lead Actor Day Rate — Week 3\', \'Steadicam Rental — Principal Photography\', \'Dolby Atmos Mix — Episode 4\'). | Column line_description (STRING) in production.budget_line' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the parent budget document, used for ordering and referencing individual line items in budget reports and purchase orders. | Column line_number (INT) in production.budget_line' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current lifecycle status of the budget line item, tracking its progression from initial draft through approval, commitment, invoicing, and payment. Drives workflow routing and financial reporting. [ENUM-REF-CANDIDATE: draft|approved|committed|invoiced|paid|cancelled|on_hold — 7 candidates stripped; promote to reference product] | Column line_status (STRING) in production.budget_line' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'SAP purchase order number raised against this budget line for vendor commitments. Links the budget line to the formal procurement document and enables three-way matching (PO, goods receipt, invoice). | Column purchase_order_number (STRING) in production.budget_line' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of units associated with this budget line (e.g., number of shoot days, number of crew members, number of VFX shots, hours of post-production labor). Combined with unit_rate to derive budgeted amount. | Column quantity (DECIMAL(12,4)) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedBudgetedAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Budgeted Amount' ;
    rdfs:comment 'Most recent approved revision to the budgeted amount, reflecting approved change orders, scope changes, or budget transfers. Null if no revision has been approved since original budget. | Column revised_budgeted_amount (DECIMAL(18,2)) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shootDateEnd rdf:type rdf:Property ;
    rdfs:label 'Shoot Date End' ;
    rdfs:comment 'Planned or actual end date for the activity or service associated with this budget line. Used for scheduling, resource allocation, and cost accrual period determination. | Column shoot_date_end (DATE) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shootDateStart rdf:type rdf:Property ;
    rdfs:label 'Shoot Date Start' ;
    rdfs:comment 'Planned or actual start date for the activity or service associated with this budget line (e.g., first day of location shoot, start of VFX work, commencement of post-production labor). | Column shoot_date_start (DATE) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxCreditEligible rdf:type rdf:Property ;
    rdfs:label 'Tax Credit Eligible' ;
    rdfs:comment 'Flag indicating whether this budget line qualifies for production tax credits or incentives (e.g., UK High-End TV Tax Relief, US state film tax credits). Enables automated calculation of eligible spend for tax credit claims. | Column tax_credit_eligible (BOOLEAN) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the quantity field (e.g., day, hour, week, flat_fee, shot, reel, license). Defines how the quantity is counted for rate-based cost calculations. [ENUM-REF-CANDIDATE: day|hour|week|flat_fee|shot|reel|license|unit — 8 candidates stripped; promote to reference product] | Column unit_of_measure (STRING) in production.budget_line' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitRate rdf:type rdf:Property ;
    rdfs:label 'Unit Rate' ;
    rdfs:comment 'Rate per unit of measure for this budget line (e.g., daily rate for a crew member, hourly rate for facility hire, per-shot rate for VFX). Multiplied by quantity to derive the budgeted amount. | Column unit_rate (DECIMAL(18,4)) in production.budget_line' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'SAP Work Breakdown Structure element code that hierarchically positions this budget line within the production project plan (e.g., PRD-2024-001.3.2.1 for a specific post-production task). | Column wbs_element (STRING) in production.budget_line' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealMemoId rdf:type rdf:Property ;
    rdfs:label 'Deal Memo Id' ;
    rdfs:comment 'Foreign key linking to talent.deal_memo. Business justification: In episodic production, crew assignments are frequently executed under a deal memo before the long-form contract is finalized. Production coordinators need this link to confirm deal memo coverage for ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DealMemo .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Externally-known business identifier for this crew assignment, used in deal memos, call sheets, and payroll processing. Format: CA-{YEAR}-{SEQUENCE}. | Column assignment_number (STRING) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle state of the crew assignment. Drives payroll eligibility, call sheet inclusion, and production roster reporting. Values: pending (offer extended, not yet accepted), confirmed (deal memo signed), active (currently on set/in production), on_hold (temporarily suspended), completed (assignment concluded), cancelled (assignment terminated before start). | Column assignment_status (STRING) in production.crew_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Status of the crew member\'s background check for this production assignment. Required for productions involving minors (COPPA compliance) or access to secure facilities. Values: not_required, pending, cleared, failed, expired. | Column background_check_status (STRING) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boxRentalRate rdf:type rdf:Property ;
    rdfs:label 'Box Rental Rate' ;
    rdfs:comment 'Daily or weekly rate paid to the crew member for the rental of their personal tool box or specialized equipment package (e.g., makeup artist\'s kit, wardrobe supervisor\'s supplies). Distinct from kit_rental_rate which covers technical equipment. | Column box_rental_rate (DECIMAL(18,4)) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedRate rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate' ;
    rdfs:comment 'The agreed compensation rate for this crew assignment, expressed in the applicable deal_type unit (per day, per week, or flat total). Stored in the production\'s base currency. Used for budget tracking and payroll processing in SAP S/4HANA. | Column contracted_rate (DECIMAL(18,4)) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditName rdf:type rdf:Property ;
    rdfs:label 'Credit Name' ;
    rdfs:comment 'The name as it should appear in the production\'s end credits, which may differ from the crew member\'s legal name (e.g., stage name, preferred professional name). Sourced from the deal memo credit clause. | Column credit_name (STRING) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditPosition rdf:type rdf:Property ;
    rdfs:label 'Credit Position' ;
    rdfs:comment 'Specifies where the crew member\'s credit appears in the production: main_title (opening credits), end_title (closing credits), both, or none (no contractual credit obligation). Drives post-production credit sequence assembly. | Column credit_position (STRING) in production.crew_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealType rdf:type rdf:Property ;
    rdfs:label 'Deal Type' ;
    rdfs:comment 'The compensation structure type for this crew assignment. Daily = per-day rate; Weekly = per-week rate with guaranteed days; Flat = fixed total fee for the engagement; Run of Show = engaged for the full production duration; Episodic = per-episode rate for series production. | Column deal_type (STRING) in production.crew_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'The production department to which the crew member belongs for this assignment (e.g., camera, grip, electric, art, wardrobe, hair/makeup, post-production, sound, VFX). Drives crew call sheet grouping and budget cost center allocation. [ENUM-REF-CANDIDATE: camera|grip|electric|art|wardrobe|hair_makeup|post_production|sound|vfx|production — 10 candidates stripped; promote to reference product] | Column department (STRING) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The contractually agreed last day of work for this crew assignment. Nullable for open-ended or rolling assignments. Used for wrap scheduling and final payroll processing. | Column end_date (DATE) in production.crew_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filmingLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Filming Location Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the primary filming location where this crew member will work. Determines applicable labor laws, tax treaties, work permit requirements, and per diem rates. | Column filming_location_country (STRING) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteedDays rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Days' ;
    rdfs:comment 'The minimum number of work days guaranteed to the crew member under this assignment deal, regardless of actual production schedule. Relevant for weekly and episodic deal types. Used for take-or-pay liability calculation. | Column guaranteed_days (INT) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kitRentalRate rdf:type rdf:Property ;
    rdfs:label 'Kit Rental Rate' ;
    rdfs:comment 'Daily or weekly rate paid to the crew member for the rental of their personal professional equipment (kit) used on the production (e.g., camera operator\'s lens kit, sound mixer\'s equipment package). Common in below-the-line crew deals. | Column kit_rental_rate (DECIMAL(18,4)) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The date and time when this crew assignment record was most recently modified. Used for change data capture (CDC), audit trail, and Silver layer incremental processing in the Databricks Lakehouse. | Column last_updated_timestamp (TIMESTAMP) in production.crew_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mealPenaltyEligible rdf:type rdf:Property ;
    rdfs:label 'Meal Penalty Eligible' ;
    rdfs:comment 'Indicates whether this crew member is entitled to meal penalty payments if the production fails to provide a meal break within the contractually required interval (typically 6 hours under IATSE/DGA agreements). Drives production scheduling compliance. | Column meal_penalty_eligible (BOOLEAN) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeEligible rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible' ;
    rdfs:comment 'Indicates whether this crew member is eligible for overtime pay under their union/guild agreement or applicable labor law. True = eligible for overtime; False = flat deal or exempt classification. Drives payroll calculation logic. | Column overtime_eligible (BOOLEAN) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Rate Multiplier' ;
    rdfs:comment 'The multiplier applied to the base contracted_rate for overtime hours (e.g., 1.5 for time-and-a-half, 2.0 for double-time). Applicable only when overtime_eligible is True. Sourced from the applicable union/guild agreement. | Column overtime_rate_multiplier (DECIMAL(5,2)) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perDiemRate rdf:type rdf:Property ;
    rdfs:label 'Per Diem Rate' ;
    rdfs:comment 'Daily allowance paid to the crew member for meals and incidental expenses when working away from their home base location. Rate varies by filming location and union agreement. Used for production cost budgeting. | Column per_diem_rate (DECIMAL(18,4)) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualsEligible rdf:type rdf:Property ;
    rdfs:label 'Residuals Eligible' ;
    rdfs:comment 'Indicates whether this crew member is entitled to residual payments when the production is reused, syndicated, or distributed on additional platforms (e.g., streaming, international broadcast). Residuals are governed by DGA, IATSE, and SAG-AFTRA agreements. | Column residuals_eligible (BOOLEAN) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleTitle rdf:type rdf:Property ;
    rdfs:label 'Role Title' ;
    rdfs:comment 'The specific production role or job title assigned to the crew member (e.g., Director, Director of Photography, Gaffer, Script Supervisor, Editor, Colorist, VFX Supervisor, Sound Mixer, Key Grip, Best Boy). [ENUM-REF-CANDIDATE: director|director_of_photography|gaffer|script_supervisor|editor|colorist|vfx_supervisor|sound_mixer|key_grip|best_boy|production_designer|costume_designer — promote to reference product] | Column role_title (STRING) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyTrainingCertified rdf:type rdf:Property ;
    rdfs:label 'Safety Training Certified' ;
    rdfs:comment 'Indicates whether the crew member has completed the required on-set safety training certification for this production (e.g., OSHA safety, COVID-19 protocols, stunt safety). Required for insurance compliance and production liability management. | Column safety_training_certified (BOOLEAN) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapPersonnelActionCode rdf:type rdf:Property ;
    rdfs:label 'Sap Personnel Action Code' ;
    rdfs:comment 'The personnel action number in SAP S/4HANA HR that corresponds to this crew assignment. Used for payroll processing, benefits enrollment, and HR compliance reporting. Enables reconciliation between the production data product and the ERP system of record. | Column sap_personnel_action_code (STRING) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDays rdf:type rdf:Property ;
    rdfs:label 'Scheduled Days' ;
    rdfs:comment 'The total number of work days currently scheduled for this crew member on the production, as reflected in the current production schedule. May differ from guaranteed_days if the schedule changes. | Column scheduled_days (INT) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The contractually agreed first day of work for this crew assignment. Used for payroll calculation, permit verification, and production schedule alignment. | Column start_date (DATE) in production.crew_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:travelAllowance rdf:type rdf:Property ;
    rdfs:label 'Travel Allowance' ;
    rdfs:comment 'Fixed or estimated travel reimbursement amount for this crew assignment, covering transportation costs to and from the filming location. Distinct from per_diem_rate which covers daily living expenses. | Column travel_allowance (DECIMAL(18,4)) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turnaroundHours rdf:type rdf:Property ;
    rdfs:label 'Turnaround Hours' ;
    rdfs:comment 'The minimum number of hours required between the end of one work day and the start of the next for this crew member, as stipulated by their union/guild agreement (e.g., 10 hours for IATSE, 12 hours for DGA). Violation triggers turnaround penalty payments. | Column turnaround_hours (DECIMAL(5,2)) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionGuildAffiliation rdf:type rdf:Property ;
    rdfs:label 'Union Guild Affiliation' ;
    rdfs:comment 'The labor union or guild to which the crew member belongs for this assignment. Determines applicable minimum rates, working conditions, residuals obligations, and benefit fund contributions. DGA = Directors Guild of America; IATSE = International Alliance of Theatrical Stage Employees; SAG-AFTRA = Screen Actors Guild–American Federation of Television and Radio Artists; WGA = Writers Guild of America; NABET = National Association of Broadcast Employees and Technicians; Teamsters = International Brotherhood of Teamsters. [ENUM-REF-CANDIDATE: DGA|IATSE|SAG-AFTRA|WGA|NABET|Teamsters|non_union — 7 candidates stripped; promote to reference product] | Column union_guild_affiliation (STRING) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPermitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Work Permit Expiry Date' ;
    rdfs:comment 'The expiration date of the crew member\'s work permit or visa authorization. Used to trigger renewal alerts and ensure continuous legal work authorization throughout the assignment period. | Column work_permit_expiry_date (DATE) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Work Permit Number' ;
    rdfs:comment 'The official government-issued work permit or visa authorization number for the crew member in the production jurisdiction. Nullable when work_permit_required is False. Required for compliance audits and production insurance. | Column work_permit_number (STRING) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPermitRequired rdf:type rdf:Property ;
    rdfs:label 'Work Permit Required' ;
    rdfs:comment 'Indicates whether a work permit or visa authorization is required for this crew member to legally work on this production in the filming jurisdiction. True = permit required; False = no permit required (domestic/citizen crew). Triggers compliance workflow in HR. | Column work_permit_required (BOOLEAN) in production.crew_assignment' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programScheduleId rdf:type rdf:Property ;
    rdfs:label 'Program Schedule Id' ;
    rdfs:comment 'Foreign key linking to scheduling.program_schedule. Business justification: Production delivery deadlines are set against a committed program schedule (broadcast date/channel). Operations teams track episode readiness — QC pass, rights clearance, picture lock — relative to th' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramSchedule .

ind:scriptId rdf:type rdf:Property ;
    rdfs:label 'Script Id' ;
    rdfs:comment 'Foreign key linking to production.script. Business justification: Episodes are based on specific scripts. Strong content relationship — script is the source document for episode production. FK links episode to the locked script version used for production. | Column script_id (BIGINT) in production.production_episode' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Script .

ind:syndicationLicenseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Syndication License Agreement Id' ;
    rdfs:comment 'Foreign key linking to rights.license_agreement. Business justification: Individual episodes may have separate syndication or international license agreements distinct from the series-level agreement. Real business need: episode-level rights tracking for syndication deals, | Column syndication_license_agreement_id (BIGINT) in rights.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseAgreement .

ind:actualCostUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Usd' ;
    rdfs:comment 'Total actual production cost incurred for this episode in US dollars, as recorded in SAP S/4HANA. Used for budget variance analysis, EBITDA reporting, and production cost per minute calculations. | Column actual_cost_usd (DECIMAL(18,2)) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualRunningTimeSec rdf:type rdf:Property ;
    rdfs:label 'Actual Running Time Sec' ;
    rdfs:comment 'Final delivered running time of the episode in seconds as measured from the completed master file. May differ from target due to editorial decisions made during post-production. Used for playout scheduling reconciliation and delivery compliance verification. | Column actual_running_time_sec (INT) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Audio Language Code' ;
    rdfs:comment 'ISO 639-2 three-letter language code for the primary audio track of this episode. Used for distribution rights matching, subtitle/dubbing workflow triggering, and EPG metadata population. | Column audio_language_code (STRING) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioMixCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Audio Mix Completion Date' ;
    rdfs:comment 'Date on which the final audio mix (including dialogue, music, and effects) was completed and approved. Prerequisite for final mastering and delivery. Tracked as a post-production milestone in Dalet Galaxy. | Column audio_mix_completion_date (DATE) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedCaptioningCompliant rdf:type rdf:Property ;
    rdfs:label 'Closed Captioning Compliant' ;
    rdfs:comment 'Indicates whether this episode meets FCC closed captioning requirements (47 CFR Part 79) and Ofcom subtitling standards. Required for broadcast clearance and regulatory compliance reporting. | Column closed_captioning_compliant (BOOLEAN) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:colorGradeCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Color Grade Completion Date' ;
    rdfs:comment 'Date on which color grading (digital color correction and finishing) was completed and approved. Required before final mastering and transcode for delivery. Tracked as a post-production milestone in Dalet Galaxy. | Column color_grade_completion_date (DATE) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:directorName rdf:type rdf:Property ;
    rdfs:label 'Director Name' ;
    rdfs:comment 'Full name of the credited director for this episode. Used for DGA residuals calculation, talent contract compliance, and creative attribution in production records. | Column director_name (STRING) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeCode rdf:type rdf:Property ;
    rdfs:label 'Episode Code' ;
    rdfs:comment 'Internal production code assigned by the production team to uniquely identify this episode within the production management system (e.g., Dalet Galaxy asset code). Used for workflow routing, asset tagging, and facility booking references. | Column episode_code (STRING) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstAirDate rdf:type rdf:Property ;
    rdfs:label 'First Air Date' ;
    rdfs:comment 'Date on which this episode first aired or was made available to audiences on any platform (linear broadcast, VOD, OTT). Marks the start of the content windowing lifecycle and triggers residuals calculation in Rightsline. | Column first_air_date (DATE) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:masterFormat rdf:type rdf:Property ;
    rdfs:label 'Master Format' ;
    rdfs:comment 'Technical format specification of the delivered episode master file (e.g., UHD HDR, HD 1080p). Determines transcode profiles required for multi-platform distribution and CDN delivery via Akamai. | Column master_format (STRING) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pictureLockDate rdf:type rdf:Property ;
    rdfs:label 'Picture Lock Date' ;
    rdfs:comment 'Date on which the final edited picture was locked, freezing all visual edits. Triggers downstream post-production workflows including VFX, color grading, and audio mixing. Critical milestone for delivery scheduling. | Column picture_lock_date (DATE) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionStatus rdf:type rdf:Property ;
    rdfs:label 'Production Status' ;
    rdfs:comment 'Current lifecycle stage of the episode within the end-to-end production workflow. Drives workflow routing in Dalet Galaxy and milestone reporting to production management. [ENUM-REF-CANDIDATE: development|pre_production|principal_photography|post_production|picture_lock|delivered|archived — promote to reference product] | Column production_status (STRING) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scriptLockDate rdf:type rdf:Property ;
    rdfs:label 'Script Lock Date' ;
    rdfs:comment 'Date on which the final shooting script was locked, freezing all creative changes. Triggers pre-production scheduling, crew assignments, and facility bookings. Key milestone for production planning. | Column script_lock_date (DATE) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shootCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shoot Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the primary country where principal photography was conducted. Used for production tax credit eligibility, co-production treaty compliance, and content origin classification. | Column shoot_country_code (STRING) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shootEndDate rdf:type rdf:Property ;
    rdfs:label 'Shoot End Date' ;
    rdfs:comment 'Scheduled or actual end date of principal photography (picture wrap) for this episode. Used to confirm transition to post-production and trigger post-production workflow initiation in Dalet Galaxy. | Column shoot_end_date (DATE) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shootLocation rdf:type rdf:Property ;
    rdfs:label 'Shoot Location' ;
    rdfs:comment 'Primary geographic location where principal photography for this episode was conducted. Used for production tax credit eligibility, location permit compliance, and production logistics reporting. | Column shoot_location (STRING) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shootStartDate rdf:type rdf:Property ;
    rdfs:label 'Shoot Start Date' ;
    rdfs:comment 'Scheduled or actual start date of principal photography for this episode. Used for crew scheduling, facility booking, and production budget burn-rate tracking in SAP S/4HANA. | Column shoot_start_date (DATE) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:showrunnerName rdf:type rdf:Property ;
    rdfs:label 'Showrunner Name' ;
    rdfs:comment 'Full name of the showrunner (executive producer with creative oversight) responsible for this episode. Key accountability reference for production governance and editorial decisions. | Column showrunner_name (STRING) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRunningTimeSec rdf:type rdf:Property ;
    rdfs:label 'Target Running Time Sec' ;
    rdfs:comment 'Planned editorial running time of the episode in seconds, excluding commercial breaks. Used for scheduling slot allocation, playout automation configuration in Ericsson MediaFirst, and delivery specification compliance. | Column target_running_time_sec (INT) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vfxCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Vfx Completion Date' ;
    rdfs:comment 'Date on which all visual effects shots were completed and approved for integration into the picture lock. Tracked as a post-production milestone. Null if the episode contains no VFX work. | Column vfx_completion_date (DATE) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writerName rdf:type rdf:Property ;
    rdfs:label 'Writer Name' ;
    rdfs:comment 'Full name of the credited writer(s) for this episode. Used for residuals calculation, WGA/guild compliance reporting, and rights attribution in Rightsline. | Column writer_name (STRING) in production.production_episode' ;
    rdfs:domain ind:ProductionEpisode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underlyingRightsHolderId rdf:type rdf:Property ;
    rdfs:label 'Underlying Rights Holder Id' ;
    rdfs:comment 'Foreign key linking to rights.rights_holder. Business justification: Scripts are often based on underlying IP owned by rights holders (novels, plays, life rights, true stories, existing franchises). Real business need: tracking the rights holder of the underlying IP be | Column underlying_rights_holder_id (BIGINT) in rights.script' ;
    rdfs:domain ind:Script ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:writerContractId rdf:type rdf:Property ;
    rdfs:label 'Writer Contract Id' ;
    rdfs:comment 'Foreign key linking to talent.contract. Business justification: Writer contracts govern script delivery schedules, revision obligations, WGA minimums, and separation-of-rights provisions. Linking each script to its governing writer contract enables contractual del' ;
    rdfs:domain ind:Script ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:writerTalentProfileId rdf:type rdf:Property ;
    rdfs:label 'Writer Talent Profile Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_profile. Business justification: Scripts are authored by writers who are registered talent. WGA compliance, residual eligibility determination, and writer credit management require linking each script to the writer\'s talent_profile. ' ;
    rdfs:domain ind:Script ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentProfile .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'The name or identifier of the individual or role who approved the script for production. | Column approved_by (STRING) in production.script' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'The confidentiality classification of the script document (public, internal, confidential, restricted). | Column confidentiality_level (STRING) in production.script' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Dalet Document Reference' ;
    rdfs:comment 'The unique document identifier or reference in the Dalet Galaxy Media Asset Management (MAM) system linking this script record to the digital script file. | Column dalet_document_reference (STRING) in production.script' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionRestriction rdf:type rdf:Property ;
    rdfs:label 'Distribution Restriction' ;
    rdfs:comment 'Any restrictions or limitations on the distribution or sharing of the script (e.g., internal use only, NDA required). | Column distribution_restriction (STRING) in production.script' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftType rdf:type rdf:Property ;
    rdfs:label 'Draft Type' ;
    rdfs:comment 'The classification of the script draft stage (outline, first draft, revised draft, shooting script, post-production script, final draft). | Column draft_type (STRING) in production.script' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRuntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Runtime Minutes' ;
    rdfs:comment 'The estimated runtime of the production in minutes based on the script length and pacing. | Column estimated_runtime_minutes (INT) in production.script' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'The size of the script file in megabytes. | Column file_size_mb (DECIMAL(10,2)) in production.script' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'The production format for which the script is intended (feature film, television episode, miniseries, web series, documentary, commercial, short film). [ENUM-REF-CANDIDATE: feature film|television episode|miniseries|web series|documentary|commercial|short film — 7 candidates stripped; promote to reference product] | Column format (STRING) in production.script' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genre rdf:type rdf:Property ;
    rdfs:label 'Genre' ;
    rdfs:comment 'The genre or category of the script (e.g., drama, comedy, thriller, documentary). | Column genre (STRING) in production.script' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'The primary language in which the script is written (e.g., English, Spanish, French). | Column language (STRING) in production.script' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockDate rdf:type rdf:Property ;
    rdfs:label 'Lock Date' ;
    rdfs:comment 'The date on which the script was locked and finalized for production. | Column lock_date (DATE) in production.script' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockStatus rdf:type rdf:Property ;
    rdfs:label 'Lock Status' ;
    rdfs:comment 'Indicates whether the script is locked for production (true) or still open for revisions (false). | Column lock_status (BOOLEAN) in production.script' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'The total number of pages in the script document. | Column page_count (INT) in production.script' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'The date of the most recent revision or update to the script. | Column revision_date (DATE) in production.script' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionNotes rdf:type rdf:Property ;
    rdfs:label 'Revision Notes' ;
    rdfs:comment 'Notes or comments describing the changes made in the current revision of the script. | Column revision_notes (STRING) in production.script' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sceneCount rdf:type rdf:Property ;
    rdfs:label 'Scene Count' ;
    rdfs:comment 'The total number of scenes defined in the script. | Column scene_count (INT) in production.script' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scriptNumber rdf:type rdf:Property ;
    rdfs:label 'Script Number' ;
    rdfs:comment 'The externally-known unique identifier or code assigned to this script for production tracking and reference purposes. | Column script_number (STRING) in production.script' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scriptStatus rdf:type rdf:Property ;
    rdfs:label 'Script Status' ;
    rdfs:comment 'Current lifecycle status of the script (draft, in review, approved, locked, archived, rejected). | Column script_status (STRING) in production.script' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wgaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Wga Registration Number' ;
    rdfs:comment 'The WGA registration number assigned to this script for copyright and intellectual property protection. | Column wga_registration_number (STRING) in production.script' ;
    rdfs:domain ind:Script ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableId rdf:type rdf:Property ;
    rdfs:label 'Deliverable Id' ;
    rdfs:comment 'Unique identifier for the production deliverable. Primary key. | Column deliverable_id (BIGINT) in production.deliverable' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deliverable .

ind:adOrderId rdf:type rdf:Property ;
    rdfs:label 'Ad Order Id' ;
    rdfs:comment 'Foreign key linking to sales.ad_order. Business justification: Branded content fulfillment tracking: ad orders for sponsored/branded content contractually require specific production deliverables. Operations and finance teams reconcile deliverable completion agai' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdOrder .

ind:carriageAgreementId rdf:type rdf:Property ;
    rdfs:label 'Carriage Agreement Id' ;
    rdfs:comment 'Foreign key linking to distribution.carriage_agreement. Business justification: Carriage agreements specify exact technical delivery requirements that production deliverables must satisfy. Linking deliverable to carriage_agreement enables carriage compliance reporting, technical ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarriageAgreement .

ind:clearanceId rdf:type rdf:Property ;
    rdfs:label 'Clearance Id' ;
    rdfs:comment 'Foreign key linking to talent.talent_clearance. Business justification: Deliverables cannot be released without confirmed talent clearance (likeness, name, performance rights). Distribution operations require a clearance-gated delivery workflow where each deliverable refe' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Clearance .

ind:creativeId rdf:type rdf:Property ;
    rdfs:label 'Creative Id' ;
    rdfs:comment 'Foreign key linking to advertising.creative. Business justification: Ad trafficking workflow: a QC-approved production deliverable (finished ad spot or branded content unit) is registered as an advertising creative for campaign trafficking. Broadcast operations teams n' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Creative .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Actual date and time when the deliverable was successfully delivered or handed off. | Column actual_delivery_timestamp (TIMESTAMP) in production.deliverable' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:audioChannels rdf:type rdf:Property ;
    rdfs:label 'Audio Channels' ;
    rdfs:comment 'Audio channel configuration for the deliverable (e.g., \'Stereo\', \'5.1 Surround\', \'7.1 Surround\', \'Mono\', \'Dolby Atmos\'). Null for non-audio deliverables. | Column audio_channels (STRING) in production.deliverable' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioDescriptionFlag rdf:type rdf:Property ;
    rdfs:label 'Audio Description Flag' ;
    rdfs:comment 'Indicates whether an audio description track for visually impaired viewers is included. True = audio description present; False = no audio description. | Column audio_description_flag (BOOLEAN) in production.deliverable' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedCaptionFlag rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Flag' ;
    rdfs:comment 'Indicates whether closed captions for accessibility are included in this deliverable. True = closed captions present; False = no closed captions. | Column closed_caption_flag (BOOLEAN) in production.deliverable' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCertificateFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certificate Flag' ;
    rdfs:comment 'Indicates whether a regulatory compliance certificate (e.g., FCC, Ofcom, content rating) accompanies this deliverable. True = certificate included; False = no certificate. | Column compliance_certificate_flag (BOOLEAN) in production.deliverable' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference number or identifier of the contract or agreement that mandates this deliverable. | Column contract_reference (STRING) in production.deliverable' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableType rdf:type rdf:Property ;
    rdfs:label 'Deliverable Type' ;
    rdfs:comment 'Category of deliverable output. Broadcast master = final linear transmission file; streaming master = OTT/VOD optimized file; promo cut = promotional excerpt; trailer = marketing preview; EPK = Electronic Press Kit; closed caption file = accessibility text; audio description track = visually impaired narration; subtitle file = translation text; M&E track = Music and Effects (no dialogue); textless version = graphics-free master; compliance certificate = regulatory approval document; QC report = Quality Control validation; as-run log = actual playout record. [ENUM-REF-CANDIDATE: broadcast_master|streaming_master|promo_cut|trailer|epk|closed_caption_file|audio_description_track|subtitle_file|me_track|textless_version|compliance_certificate|qc_report|as_run_log|other — 14 candidates stripped; promote to reference product] | Column deliverable_type (STRING) in production.deliverable' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Physical address, URL, FTP path, or cloud storage location where the deliverable was sent or made available. | Column delivery_location (STRING) in production.deliverable' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method or protocol used to deliver the deliverable to the recipient. Physical media = hard drive/tape shipment; FTP = File Transfer Protocol; Aspera = high-speed file transfer; Signiant = media transfer platform; AWS S3 = Amazon cloud storage; Akamai NetStorage = CDN storage; Google Drive/Dropbox = cloud file sharing. [ENUM-REF-CANDIDATE: physical_media|ftp|aspera|signiant|aws_s3|akamai_netstorage|google_drive|dropbox|other — 9 candidates stripped; promote to reference product] | Column delivery_method (STRING) in production.deliverable' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle state of the deliverable. Not started = work has not begun; in progress = actively being produced; QC pending = awaiting quality control review; QC failed = did not pass quality checks; QC passed = approved for delivery; ready for delivery = prepared and awaiting handoff; delivered = sent to recipient; accepted = recipient confirmed receipt and approval; rejected = recipient declined or returned; cancelled = deliverable no longer required. [ENUM-REF-CANDIDATE: not_started|in_progress|qc_pending|qc_failed|qc_passed|ready_for_delivery|delivered|accepted|rejected|cancelled — 10 candidates stripped; promote to reference product] | Column delivery_status (STRING) in production.deliverable' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Contractually or operationally required date by which this deliverable must be completed and handed off. | Column due_date (DATE) in production.deliverable' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Total runtime duration of the deliverable in seconds (for video/audio deliverables). Null for non-time-based deliverables like documents or images. | Column duration_seconds (DECIMAL(10,3)) in production.deliverable' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcNotes rdf:type rdf:Property ;
    rdfs:label 'Qc Notes' ;
    rdfs:comment 'Detailed notes from the quality control review, including any issues found, corrective actions taken, or validation comments. | Column qc_notes (STRING) in production.deliverable' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcOperatorName rdf:type rdf:Property ;
    rdfs:label 'Qc Operator Name' ;
    rdfs:comment 'Name of the quality control technician or automated system that performed the QC validation. | Column qc_operator_name (STRING) in production.deliverable' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcPassFlag rdf:type rdf:Property ;
    rdfs:label 'Qc Pass Flag' ;
    rdfs:comment 'Indicates whether the deliverable passed quality control validation. True = passed QC; False = failed QC or not yet tested. | Column qc_pass_flag (BOOLEAN) in production.deliverable' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcPerformedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qc Performed Timestamp' ;
    rdfs:comment 'Date and time when quality control validation was completed for this deliverable. | Column qc_performed_timestamp (TIMESTAMP) in production.deliverable' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Version or revision number of this deliverable. Increments when the deliverable is updated or redelivered after corrections. | Column revision_number (INT) in production.deliverable' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Timestamp' ;
    rdfs:comment 'Planned date and time for delivery of this deliverable to the recipient or platform. | Column scheduled_delivery_timestamp (TIMESTAMP) in production.deliverable' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qcReviewId rdf:type rdf:Property ;
    rdfs:label 'Qc Review Id' ;
    rdfs:comment 'Unique identifier for the quality control review record. Primary key. | Column qc_review_id (BIGINT) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetVersionId rdf:type rdf:Property ;
    rdfs:label 'Asset Version Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.asset_version. Business justification: Production QC reviews target a specific asset version (e.g., a particular transcode rendition). Without this FK, QC results cannot be tied to the exact version reviewed — critical for compliance repor' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:audioChannelConfiguration rdf:type rdf:Property ;
    rdfs:label 'Audio Channel Configuration' ;
    rdfs:comment 'Audio channel layout (e.g., stereo, 5.1 surround, 7.1 surround, mono). | Column audio_channel_configuration (STRING) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioDescriptionComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Audio Description Compliance Flag' ;
    rdfs:comment 'Indicates whether audio description track meets accessibility standards. True if compliant, False if missing or non-compliant. | Column audio_description_compliance_flag (BOOLEAN) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedCaptionComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Compliance Flag' ;
    rdfs:comment 'Indicates whether closed captions meet accessibility and regulatory standards (FCC, CVAA). True if compliant, False if violations detected. | Column closed_caption_compliance_flag (BOOLEAN) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:errorCodes rdf:type rdf:Property ;
    rdfs:label 'Error Codes' ;
    rdfs:comment 'Comma-separated list of specific error codes identified during the review, aligned with EBU R128, ATSC A/85, and ITU-R BT.1788 standards (e.g., V001 for video freeze, A002 for loudness violation, C003 for closed caption sync error). | Column error_codes (STRING) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Final Approval Date' ;
    rdfs:comment 'Date when the deliverable received final approval for distribution. Null if not yet approved. | Column final_approval_date (DATE) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Final Approval Status' ;
    rdfs:comment 'Final approval status of the deliverable after QC review and any remediation: approved (ready for distribution), rejected (does not meet standards), pending approval (awaiting sign-off), or conditional approval (approved with minor caveats). | Column final_approval_status (STRING) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loudnessComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Loudness Compliance Flag' ;
    rdfs:comment 'Indicates whether the deliverable meets loudness standards (EBU R128 or ATSC A/85). True if compliant, False if violations detected. | Column loudness_compliance_flag (BOOLEAN) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loudnessLufs rdf:type rdf:Property ;
    rdfs:label 'Loudness Lufs' ;
    rdfs:comment 'Measured integrated loudness level in LUFS (Loudness Units relative to Full Scale) per EBU R128 or ATSC A/85 standards. Target is typically -23 LUFS for broadcast. | Column loudness_lufs (DECIMAL(6,2)) in production.qc_review' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:p1CriticalErrorCount rdf:type rdf:Property ;
    rdfs:label 'P1 Critical Error Count' ;
    rdfs:comment 'Number of P1 critical errors that prevent broadcast or distribution (e.g., audio dropout, video corruption, missing segments). | Column p1_critical_error_count (INT) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:p2MajorErrorCount rdf:type rdf:Property ;
    rdfs:label 'P2 Major Error Count' ;
    rdfs:comment 'Number of P2 major errors that significantly impact quality but may not prevent distribution (e.g., color grading inconsistencies, audio sync issues). | Column p2_major_error_count (INT) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:p3MinorErrorCount rdf:type rdf:Property ;
    rdfs:label 'P3 Minor Error Count' ;
    rdfs:comment 'Number of P3 minor errors that have minimal impact on viewer experience (e.g., minor subtitle timing issues, cosmetic artifacts). | Column p3_minor_error_count (INT) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcPlatform rdf:type rdf:Property ;
    rdfs:label 'Qc Platform' ;
    rdfs:comment 'Name of the QC platform or tool used to perform the review (e.g., Dalet Galaxy QC module, Tektronix Sentry, Interra Baton). | Column qc_platform (STRING) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcResult rdf:type rdf:Property ;
    rdfs:label 'Qc Result' ;
    rdfs:comment 'Overall result of the QC review: pass (no issues), fail (critical issues preventing distribution), conditional pass (minor issues requiring remediation), or pending review (awaiting final approval). | Column qc_result (STRING) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcType rdf:type rdf:Property ;
    rdfs:label 'Qc Type' ;
    rdfs:comment 'Type of quality control review performed: technical QC (video/audio quality), editorial QC (content accuracy), compliance QC (regulatory standards), accessibility QC (closed captions, audio description), loudness QC (EBU R128/ATSC A/85), or format QC (file format and codec validation). | Column qc_type (STRING) in production.qc_review' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reQcDate rdf:type rdf:Property ;
    rdfs:label 'Re Qc Date' ;
    rdfs:comment 'Date when the deliverable was re-reviewed after remediation. Null if no re-QC has been performed. | Column re_qc_date (DATE) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationNotes rdf:type rdf:Property ;
    rdfs:label 'Remediation Notes' ;
    rdfs:comment 'Detailed notes describing the remediation actions required to address identified errors and bring the deliverable into compliance. | Column remediation_notes (STRING) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Required Flag' ;
    rdfs:comment 'Indicates whether the deliverable requires remediation or correction before final approval. True if remediation needed, False if no action required. | Column remediation_required_flag (BOOLEAN) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date when the QC review was performed. | Column review_date (DATE) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Review Duration Minutes' ;
    rdfs:comment 'Total duration of the QC review session in minutes. | Column review_duration_minutes (DECIMAL(10,2)) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review End Timestamp' ;
    rdfs:comment 'Timestamp when the QC operator completed the review session. | Column review_end_timestamp (TIMESTAMP) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Business identifier for the QC review, typically formatted as a human-readable reference code. | Column review_number (STRING) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Start Timestamp' ;
    rdfs:comment 'Timestamp when the QC operator began the review session. | Column review_start_timestamp (TIMESTAMP) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle status of the QC review process. | Column review_status (STRING) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalErrorCount rdf:type rdf:Property ;
    rdfs:label 'Total Error Count' ;
    rdfs:comment 'Total number of errors identified across all severity levels during the QC review. | Column total_error_count (INT) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:videoFrameRate rdf:type rdf:Property ;
    rdfs:label 'Video Frame Rate' ;
    rdfs:comment 'Measured video frame rate (e.g., 23.976, 25, 29.97, 50, 59.94 fps). | Column video_frame_rate (DECIMAL(18,2)) in production.qc_review' ;
    rdfs:domain ind:QcReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestoneId rdf:type rdf:Property ;
    rdfs:label 'Milestone Id' ;
    rdfs:comment 'Primary key for milestone | Column milestone_id (BIGINT) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearanceRequestId rdf:type rdf:Property ;
    rdfs:label 'Clearance Request Id' ;
    rdfs:comment 'Foreign key linking to rights.clearance_request. Business justification: Production milestones (script lock, picture lock, delivery) are gated on rights clearance completion. Production scheduling and greenlight reporting require tracking which clearance_request must be re' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClearanceRequest .

ind:predecessorMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Milestone Id' ;
    rdfs:comment 'Reference to another milestone that must be completed before this milestone can begin or be achieved. | Column predecessor_milestone_id (BIGINT) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Milestone .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'The date on which the milestone was actually achieved or completed. Null if milestone has not yet been reached. | Column actual_date (DATE) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or role of the individual or committee authorized to approve this milestone (e.g., Executive Producer, Network Executive, Showrunner). | Column approval_authority (STRING) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether formal approval or sign-off is required before this milestone can be marked as achieved. | Column approval_required_flag (BOOLEAN) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Approved baseline date for the milestone after initial project approval, used for variance tracking and performance measurement. | Column baseline_date (DATE) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Usd' ;
    rdfs:comment 'Estimated financial impact or cost associated with achieving this milestone, or cost of delay if milestone is missed. | Column budget_impact_usd (DECIMAL(15,2)) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalPathFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Path Flag' ;
    rdfs:comment 'Indicates whether this milestone is on the critical path of the production schedule, meaning any delay directly impacts final delivery date. | Column critical_path_flag (BOOLEAN) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dependencyCount rdf:type rdf:Property ;
    rdfs:label 'Dependency Count' ;
    rdfs:comment 'Number of other milestones or tasks that are dependent on the completion of this milestone. | Column dependency_count (INT) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'Current projected or estimated date for milestone completion based on latest production progress and risk assessment. | Column forecast_date (DATE) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current lifecycle status of the milestone indicating whether it is pending, on track, delayed, completed, or no longer applicable. | Column milestone_status (STRING) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Categorical classification of the milestone within the production lifecycle. Defines the phase or gate this milestone represents. [ENUM-REF-CANDIDATE: greenlight|pre_production_start|principal_photography_start|principal_photography_end|picture_lock|audio_mix_complete|vfx_complete|color_grading_complete|final_qc_pass|delivery_to_broadcaster|archive_complete|post_production_start|rough_cut_complete|final_cut_complete|mastering_complete — promote to reference product] | Column milestone_type (STRING) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Mitigation Plan' ;
    rdfs:comment 'Description of actions or contingency plans in place to address identified risks and ensure milestone is achieved. | Column mitigation_plan (STRING) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'Originally scheduled or target date for achieving this milestone as defined during production planning. | Column planned_date (DATE) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'The production department or functional area responsible for delivering this milestone. [ENUM-REF-CANDIDATE: production|post_production|vfx|audio|editorial|color|qc|delivery|archive|legal|finance — 11 candidates stripped; promote to reference product] | Column responsible_department (STRING) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed explanation of identified risks, issues, or blockers that may prevent timely achievement of this milestone. | Column risk_description (STRING) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Assessment of the risk that this milestone will not be achieved on time, based on current production status and known issues. | Column risk_level (STRING) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Notification Flag' ;
    rdfs:comment 'Indicates whether stakeholders (network executives, distributors, talent) must be notified when this milestone is achieved or at risk. | Column stakeholder_notification_flag (BOOLEAN) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceDays rdf:type rdf:Property ;
    rdfs:label 'Variance Days' ;
    rdfs:comment 'Number of days difference between planned date and actual date (positive indicates delay, negative indicates early completion). Calculated field for reporting purposes. | Column variance_days (INT) in production.milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costTransactionId rdf:type rdf:Property ;
    rdfs:label 'Cost Transaction Id' ;
    rdfs:comment 'Primary key for cost_transaction | Column cost_transaction_id (BIGINT) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionBudgetId rdf:type rdf:Property ;
    rdfs:label 'Production Budget Id' ;
    rdfs:comment 'Reference to the specific budget line or cost object this transaction is charged against. | Column production_budget_id (BIGINT) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date on the vendor invoice or billing document. | Column invoice_date (DATE) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Vendor invoice number or billing reference for this transaction. | Column invoice_number (STRING) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net transaction amount excluding taxes and other adjustments. | Column net_amount (DECIMAL(18,2)) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payeeName rdf:type rdf:Property ;
    rdfs:label 'Payee Name' ;
    rdfs:comment 'Name of the individual or entity receiving payment for this transaction (e.g., crew member, contractor, petty cash recipient). | Column payee_name (STRING) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Date on which payment was made or is scheduled to be made for this transaction. | Column payment_date (DATE) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Method used for payment: wire transfer, check, credit card, petty cash, ACH, or payroll. | Column payment_method (STRING) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current payment status of the transaction: pending, approved, paid, cancelled, on hold, or rejected. | Column payment_status (STRING) in production.cost_transaction' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the transaction was posted to the general ledger in SAP. | Column posting_date (DATE) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Amount' ;
    rdfs:comment 'Transaction amount converted to the standard reporting currency (typically USD) for consolidated financial reporting. | Column reporting_currency_amount (DECIMAL(18,2)) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'SAP S/4HANA financial document number (FI/CO posting document) associated with this transaction. | Column sap_document_number (STRING) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Line Item Number' ;
    rdfs:comment 'Line item number within the SAP document for granular traceability. | Column sap_line_item_number (STRING) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Tax amount associated with this transaction, if applicable. | Column tax_amount (DECIMAL(18,2)) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The monetary amount of the cost transaction in the original transaction currency. | Column transaction_amount (DECIMAL(18,2)) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The date on which the cost transaction was incurred or posted in the financial system. | Column transaction_date (DATE) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Business-facing unique transaction number or document reference for this cost entry. | Column transaction_number (STRING) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the cost transaction: purchase order, vendor invoice, petty cash disbursement, payroll charge, inter-company cost allocation, or credit memo. | Column transaction_type (STRING) in production.cost_transaction' ;
    rdfs:domain ind:CostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adBreakDurationSec rdf:type rdf:Property ;
    rdfs:label 'Ad Break Duration Sec' ;
    rdfs:comment 'Default duration in seconds of a standard ad pod (ad break) for this channel. Used by Wide Orbit traffic system for ad scheduling, inventory management, and avail calculation. Typical values are 120 (2 minutes) or 180 (3 minutes). | Column ad_break_duration_sec (INT) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affiliateNetworkCode rdf:type rdf:Property ;
    rdfs:label 'Affiliate Network Code' ;
    rdfs:comment 'Code identifying the parent broadcast network or affiliate group this channel belongs to (e.g., NBC, CBS, ABC, FOX). Used for network affiliation reporting, retransmission consent negotiations, and carriage fee calculations. | Column affiliate_network_code (STRING) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutEnabled rdf:type rdf:Property ;
    rdfs:label 'Blackout Enabled' ;
    rdfs:comment 'Indicates whether geographic broadcast blackout restrictions are applicable to this channel. When true, blackout rules must be enforced during playout and OTT delivery to restrict content in specific geographic markets per rights agreements. | Column blackout_enabled (BOOLEAN) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastTimezone rdf:type rdf:Property ;
    rdfs:label 'Broadcast Timezone' ;
    rdfs:comment 'IANA timezone identifier for the channel\'s primary broadcast timezone (e.g., America/New_York, Europe/London). Governs daypart definitions, schedule generation, and EPG time display for the channel\'s primary market. | Column broadcast_timezone (STRING) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callSign rdf:type rdf:Property ;
    rdfs:label 'Call Sign' ;
    rdfs:comment 'Officially assigned broadcast call sign (e.g., WABC, KNBC) that uniquely identifies the station with the regulatory authority. Serves as the primary external business identifier for the channel as registered with the FCC or Ofcom. | Column call_sign (STRING) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Usd' ;
    rdfs:comment 'The per-subscriber monthly carriage fee in US dollars charged to MVPDs and vMVPDs for distributing this channel. Commercially sensitive financial data used in revenue assurance, financial reconciliation in SAP S/4HANA, and EBITDA reporting. | Column carriage_fee_usd (DECIMAL(18,4)) in scheduling.channel' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdnOriginUrl rdf:type rdf:Property ;
    rdfs:label 'Cdn Origin Url' ;
    rdfs:comment 'The origin ingest URL configured in Akamai CDN for this channel\'s live stream delivery. Used for OTT/streaming distribution, ABR (Adaptive Bitrate Streaming) packaging, and CDN cache configuration. | Column cdn_origin_url (STRING) in scheduling.channel' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational lifecycle state of the channel. Drives playout automation eligibility, EPG publication, and scheduling availability in Ericsson MediaFirst. | Column channel_status (STRING) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Classification of the channel by its distribution and scheduling model. Linear indicates traditional scheduled broadcast; simulcast indicates simultaneous multi-platform broadcast; pop-up indicates temporary event channel; FAST (Free Ad-Supported Streaming Television) indicates ad-supported streaming linear channel; VOD indicates on-demand programming window channel. | Column channel_type (STRING) in scheduling.channel' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingSystem rdf:type rdf:Property ;
    rdfs:label 'Content Rating System' ;
    rdfs:comment 'Default content advisory rating applied to the channel\'s programming under the applicable rating system (e.g., US TV Parental Guidelines). Drives V-chip compliance, parental control enforcement, and COPPA-regulated children\'s content restrictions. | Column content_rating_system (STRING) in scheduling.channel' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daiEnabled rdf:type rdf:Property ;
    rdfs:label 'Dai Enabled' ;
    rdfs:comment 'Indicates whether Dynamic Ad Insertion (DAI) is active for this channel, enabling server-side ad replacement for OTT/streaming delivery. Drives ad operations workflow in Wide Orbit and integration with DAI platforms. | Column dai_enabled (BOOLEAN) in scheduling.channel' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daletChannelCode rdf:type rdf:Property ;
    rdfs:label 'Dalet Channel Code' ;
    rdfs:comment 'The channel identifier as configured in Dalet Galaxy Media Asset Management system. Used to link this channel to content ingest workflows, metadata management, archive operations, and rundown generation in Dalet. | Column dalet_channel_code (STRING) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'The date on which this channel was or is scheduled to be permanently decommissioned and removed from broadcast. Nullable for active channels. Used for lifecycle management, licence surrender, and EPG removal planning. | Column decommission_date (DATE) in scheduling.channel' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drmEnabled rdf:type rdf:Property ;
    rdfs:label 'Drm Enabled' ;
    rdfs:comment 'Indicates whether Digital Rights Management (DRM) encryption is applied to this channel\'s content stream for OTT/streaming delivery. Drives content protection configuration in Akamai CDN and subscriber entitlement enforcement in Zuora. | Column drm_enabled (BOOLEAN) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epgEnabled rdf:type rdf:Property ;
    rdfs:label 'Epg Enabled' ;
    rdfs:comment 'Indicates whether this channel is published to the Electronic Program Guide (EPG) for audience-facing schedule display. Channels under testing or decommissioned may be excluded from EPG publication. | Column epg_enabled (BOOLEAN) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hlsStreamUrl rdf:type rdf:Property ;
    rdfs:label 'Hls Stream Url' ;
    rdfs:comment 'The HLS (HTTP Live Streaming) manifest URL for this channel\'s live stream, used for Apple device and browser-based OTT delivery via Akamai CDN. Supports ABR (Adaptive Bitrate Streaming) for adaptive quality delivery. | Column hls_stream_url (STRING) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'The date on which this channel first went live and began broadcasting. Used for channel lifecycle tracking, anniversary reporting, regulatory licence history, and audience growth analytics. | Column launch_date (DATE) in scheduling.channel' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:logicalChannelNumber rdf:type rdf:Property ;
    rdfs:label 'Logical Channel Number' ;
    rdfs:comment 'The numeric channel position assigned to this channel in the Electronic Program Guide (EPG) and set-top box channel lineup. Used by MVPDs and vMVPDs for channel navigation and must-carry compliance reporting. | Column logical_channel_number (INT) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxAdLoadPct rdf:type rdf:Property ;
    rdfs:label 'Max Ad Load Pct' ;
    rdfs:comment 'Maximum percentage of total broadcast hour that may be allocated to advertising on this channel. Governs inventory capacity planning, FCC commercial limits compliance (children\'s programming), and upfront/scatter market sales commitments. | Column max_ad_load_pct (DECIMAL(5,2)) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediafirstChannelCode rdf:type rdf:Property ;
    rdfs:label 'Mediafirst Channel Code' ;
    rdfs:comment 'The channel identifier as configured in the Ericsson MediaFirst playout automation system. Used to link this master channel record to the playout engine for schedule execution, automation triggers, graphics insertion, and failover configuration. | Column mediafirst_channel_code (STRING) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpegDashStreamUrl rdf:type rdf:Property ;
    rdfs:label 'Mpeg Dash Stream Url' ;
    rdfs:comment 'The MPEG-DASH (Dynamic Adaptive Streaming over HTTP) manifest URL for this channel\'s live stream, used for Android, Smart TV, and cross-platform OTT delivery via Akamai CDN. | Column mpeg_dash_stream_url (STRING) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mustCarryStatus rdf:type rdf:Property ;
    rdfs:label 'Must Carry Status' ;
    rdfs:comment 'Indicates whether this channel is subject to must-carry obligations requiring MVPDs to include it in their channel lineup. Drives compliance reporting and carriage fee negotiations. | Column must_carry_status (BOOLEAN) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkName rdf:type rdf:Property ;
    rdfs:label 'Network Name' ;
    rdfs:comment 'Human-readable name of the broadcast network or channel brand (e.g., CNN, BBC One, ESPN). Used as the primary identity label for display in EPG, scheduling tools, and audience-facing interfaces. | Column network_name (STRING) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nielsenStationCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Station Code' ;
    rdfs:comment 'The unique station identifier assigned by Nielsen Media Research for audience measurement, ratings reporting, and GRP/TRP calculations. Links this channel to Nielsen ratings data for advertising sales and audience analytics. | Column nielsen_station_code (STRING) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutAutomationEnabled rdf:type rdf:Property ;
    rdfs:label 'Playout Automation Enabled' ;
    rdfs:comment 'Indicates whether the channel is configured for automated playout via Ericsson MediaFirst. When true, schedule execution, ad insertion cues, and failover are handled automatically. When false, manual playout operation is required. | Column playout_automation_enabled (BOOLEAN) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionProfile rdf:type rdf:Property ;
    rdfs:label 'Resolution Profile' ;
    rdfs:comment 'Video resolution classification of the channel output. SD (Standard Definition), HD (High Definition 1080i/720p), UHD (Ultra High Definition 4K/8K). Determines encoding profiles, CDN delivery tiers, and subscriber package eligibility. | Column resolution_profile (STRING) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Required' ;
    rdfs:comment 'Indicates whether this channel requires retransmission consent from MVPDs before rebroadcasting. Drives carriage fee negotiations and compliance with FCC retransmission consent rules. | Column retransmission_consent_required (BOOLEAN) in scheduling.channel' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scte35Enabled rdf:type rdf:Property ;
    rdfs:label 'Scte35 Enabled' ;
    rdfs:comment 'Indicates whether SCTE-35 digital program insertion cue markers are active on this channel for Dynamic Ad Insertion (DAI). SCTE-35 signals define ad pod boundaries and splice points used by Wide Orbit traffic system and DAI platforms. | Column scte35_enabled (BOOLEAN) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transmissionStandard rdf:type rdf:Property ;
    rdfs:label 'Transmission Standard' ;
    rdfs:comment 'Technical broadcast transmission standard used to deliver the channel signal. ATSC and ATSC 3.0 apply to North American over-the-air broadcast; DVB-T/T2 and DVB-S/S2 apply to European terrestrial and satellite; QAM applies to cable distribution; IP applies to OTT/streaming delivery. [ENUM-REF-CANDIDATE: ATSC|ATSC3|DVB-T|DVB-T2|DVB-S|DVB-S2|QAM|IP — promote to reference product] | Column transmission_standard (STRING) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideOrbitStationCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Station Code' ;
    rdfs:comment 'The station code as configured in the Wide Orbit traffic and billing system. Used to link this channel master record to ad scheduling, sales orders, affidavit generation, and invoicing workflows in Wide Orbit. | Column wide_orbit_station_code (STRING) in scheduling.channel' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartId rdf:type rdf:Property ;
    rdfs:label 'Daypart Id' ;
    rdfs:comment 'Primary key for daypart | Column daypart_id (BIGINT) in scheduling.daypart' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Daypart .

ind:adPodMaxCount rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Max Count' ;
    rdfs:comment 'The maximum number of ad pods (commercial breaks) permitted per hour within this daypart. Used by Wide Orbit for ad scheduling capacity planning and by Ericsson MediaFirst for playout rundown validation. Supports FCC commercial time compliance monitoring. | Column ad_pod_max_count (INT) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adPodMaxDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Max Duration Seconds' ;
    rdfs:comment 'The maximum allowable total duration in seconds for an ad pod (group of ads in a break) within this daypart. Governs commercial break length limits enforced by Ericsson MediaFirst playout automation and Wide Orbit ad scheduling. Aligns with FCC commercial time limits for children\'s programming dayparts. | Column ad_pod_max_duration_seconds (INT) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableDays rdf:type rdf:Property ;
    rdfs:label 'Applicable Days' ;
    rdfs:comment 'Pipe-delimited list of days of the week on which this daypart definition applies, using three-letter abbreviations (e.g., MON|TUE|WED|THU|FRI for weekday dayparts, SAT|SUN for weekend). Governs schedule generation in Ericsson MediaFirst and ad inventory availability in Wide Orbit. [ENUM-REF-CANDIDATE: MON|TUE|WED|THU|FRI|SAT|SUN — promote to reference product] | Column applicable_days (STRING) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avgAudience000 rdf:type rdf:Property ;
    rdfs:label 'Avg Audience 000' ;
    rdfs:comment 'The average audience size in thousands of viewers (000s) expected during this daypart, based on Nielsen Media Research Platform historical ratings data. Used as the principal quantitative measurement of daypart audience value for ad sales, GRP calculations, and content scheduling decisions. | Column avg_audience_000 (DECIMAL(12,2)) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCpmUsd rdf:type rdf:Property ;
    rdfs:label 'Base Cpm Usd' ;
    rdfs:comment 'The baseline CPM (Cost Per Mille) rate in US dollars for advertising inventory sold within this daypart, before application of the rate_multiplier or audience demographic adjustments. Represents the floor pricing reference used in Salesforce Media Cloud upfront and scatter market proposals. | Column base_cpm_usd (DECIMAL(10,4)) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blackoutEligible rdf:type rdf:Property ;
    rdfs:label 'Blackout Eligible' ;
    rdfs:comment 'Indicates whether geographic broadcast blackout restrictions can be applied to content scheduled within this daypart. When True, blackout rules (e.g., sports rights geographic exclusivity) may be enforced by the distribution platform. Aligns with must-carry and retransmission consent obligations. | Column blackout_eligible (BOOLEAN) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentRatingRestriction rdf:type rdf:Property ;
    rdfs:label 'Content Rating Restriction' ;
    rdfs:comment 'The maximum permissible TV content rating (per MPA/TV Parental Guidelines) for programming scheduled within this daypart. Enforces content appropriateness standards — e.g., Prime Time may allow up to TV-14, while Children\'s dayparts are restricted to TV-Y or TV-Y7. Used by Ericsson MediaFirst for schedule validation. | Column content_rating_restriction (STRING) in scheduling.daypart' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaRestricted rdf:type rdf:Property ;
    rdfs:label 'Coppa Restricted' ;
    rdfs:comment 'Indicates whether this daypart is subject to COPPA (Children\'s Online Privacy Protection Act) restrictions due to programming directed at children under 13. When True, audience data collection, behavioral targeting, and ad pod duration limits are governed by COPPA compliance rules and FCC children\'s television regulations. | Column coppa_restricted (BOOLEAN) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daiEligible rdf:type rdf:Property ;
    rdfs:label 'Dai Eligible' ;
    rdfs:comment 'Indicates whether this daypart is eligible for Dynamic Ad Insertion (DAI) on OTT and streaming platforms. When True, ad pods within this daypart can be dynamically replaced with targeted ads during streaming delivery through Akamai CDN, enabling addressable advertising revenue. | Column dai_eligible (BOOLEAN) in scheduling.daypart' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dayCategory rdf:type rdf:Property ;
    rdfs:label 'Day Category' ;
    rdfs:comment 'High-level classification of the day-of-week applicability for the daypart. \'weekday\' covers Monday–Friday, \'weekend\' covers Saturday–Sunday, \'all_week\' applies every day, and \'holiday\' applies on designated public holidays. Used for rate card segmentation and audience demographic profiling. | Column day_category (STRING) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartStatus rdf:type rdf:Property ;
    rdfs:label 'Daypart Status' ;
    rdfs:comment 'Current lifecycle state of the daypart definition. \'active\' indicates the daypart is in operational use for scheduling and ad sales. \'inactive\' means temporarily suspended. \'draft\' means under review before activation. \'deprecated\' means retired from use but retained for historical reference. | Column daypart_status (STRING) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartType rdf:type rdf:Property ;
    rdfs:label 'Daypart Type' ;
    rdfs:comment 'Classifies the daypart by broadcast delivery mode. \'linear\' applies to traditional scheduled broadcast, \'non_linear\' to on-demand programming windows, \'simulcast\' to simultaneous multi-platform broadcast segments, and \'vod_window\' to VOD availability windows governed by this daypart definition. | Column daypart_type (STRING) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total duration of the daypart window expressed in minutes. Derived from start_time and end_time boundaries but stored explicitly for scheduling calculations, ad inventory capacity planning, and rate card generation in Wide Orbit. | Column duration_minutes (INT) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'The calendar date from which this daypart definition becomes effective for scheduling and ad sales operations. Supports versioned daypart definitions where boundaries or rates change seasonally or following regulatory updates. Used in Wide Orbit and Ericsson MediaFirst schedule generation. | Column effective_from (DATE) in scheduling.daypart' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'The calendar date on which this daypart definition expires and is no longer applicable for scheduling and ad sales. Null indicates an open-ended definition with no planned expiry. Supports seasonal daypart adjustments (e.g., summer schedule changes) and regulatory compliance updates. | Column effective_until (DATE) in scheduling.daypart' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'The clock time (HH:mm:ss, 24-hour or extended broadcast-day format) at which the daypart ends. Supports broadcast day overflow notation (e.g., 25:59:59 for content airing past midnight within the same broadcast day). Paired with start_time to define the daypart boundary. | Column end_time (TIMESTAMP) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:epgDisplayOrder rdf:type rdf:Property ;
    rdfs:label 'Epg Display Order' ;
    rdfs:comment 'The sequential display order of this daypart within the Electronic Program Guide (EPG) channel grid, used by Ericsson MediaFirst for schedule presentation and by digital EPG distribution systems. Lower values appear earlier in the broadcast day display. | Column epg_display_order (INT) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grpIndex rdf:type rdf:Property ;
    rdfs:label 'Grp Index' ;
    rdfs:comment 'The GRP (Gross Rating Point) index value representing the expected audience delivery weight for this daypart relative to the total broadcast day. Used in media planning, upfront negotiations, and scatter market pricing. Sourced from Nielsen Media Research Platform ratings data. | Column grp_index (DECIMAL(8,4)) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hutLevel rdf:type rdf:Property ;
    rdfs:label 'Hut Level' ;
    rdfs:comment 'The HUT (Homes Using Television) percentage representing the proportion of TV households actively viewing during this daypart. A key audience measurement metric sourced from Nielsen Media Research Platform, used to benchmark daypart audience potential and inform ad pricing. | Column hut_level (DECIMAL(6,4)) in scheduling.daypart' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodEligible rdf:type rdf:Property ;
    rdfs:label 'Makegood Eligible' ;
    rdfs:comment 'Indicates whether compensatory ad spots (makegoods) can be scheduled within this daypart to fulfill underdelivered audience guarantees from other dayparts. Governs Wide Orbit makegood scheduling logic and Salesforce Media Cloud campaign reconciliation workflows. | Column makegood_eligible (BOOLEAN) in scheduling.daypart' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nielsenDaypartCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Daypart Code' ;
    rdfs:comment 'The standardized daypart code as defined by Nielsen Media Research taxonomy (e.g., PRIME, EARLY_NEWS, LATE_NEWS, DAYTIME, EARLY_FRINGE, LATE_FRINGE, OVERNIGHT). Used to align internal scheduling definitions with Nielsen audience measurement reports and ratings data ingested from the Nielsen Media Research Platform. | Column nielsen_daypart_code (STRING) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Rate Multiplier' ;
    rdfs:comment 'Pricing multiplier applied to the base CPM (Cost Per Mille) rate card for ad inventory sold within this daypart. A value of 1.0000 represents the base rate; Prime Time typically carries a multiplier greater than 1.0 (e.g., 2.5000), while Overnight may be below 1.0 (e.g., 0.3000). Used in Salesforce Media Cloud proposal generation and Wide Orbit billing. | Column rate_multiplier (DECIMAL(6,4)) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scatterEligible rdf:type rdf:Property ;
    rdfs:label 'Scatter Eligible' ;
    rdfs:comment 'Indicates whether unsold ad inventory within this daypart is available for scatter market (last-minute) sales. Governs Wide Orbit inventory availability rules for short-notice ad placement and makegood scheduling. | Column scatter_eligible (BOOLEAN) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scte35CueEnabled rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue Enabled' ;
    rdfs:comment 'Indicates whether SCTE-35 digital program insertion cue markers are enabled for ad break signaling within this daypart. When True, Ericsson MediaFirst playout automation inserts SCTE-35 splice_insert commands at ad pod boundaries, enabling Dynamic Ad Insertion (DAI) for OTT and streaming distribution via Akamai CDN. | Column scte35_cue_enabled (BOOLEAN) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:simulcastEligible rdf:type rdf:Property ;
    rdfs:label 'Simulcast Eligible' ;
    rdfs:comment 'Indicates whether content scheduled in this daypart is eligible for simultaneous multi-platform broadcast (simulcast) across linear, OTT, and digital channels. When True, Ericsson MediaFirst can trigger simulcast distribution workflows for this daypart\'s programming. | Column simulcast_eligible (BOOLEAN) in scheduling.daypart' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'The clock time (HH:mm:ss, 24-hour format) at which the daypart begins each applicable day. Used by Ericsson MediaFirst for automated playout boundary detection and by Wide Orbit for ad scheduling slot assignment. Stored as STRING to support broadcast day conventions (e.g., 25:00:00 for post-midnight). | Column start_time (TIMESTAMP) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sweepsPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Sweeps Period Flag' ;
    rdfs:comment 'Indicates whether this daypart definition has special audience measurement and programming rules applied during Nielsen sweeps periods (intensive ratings measurement periods in February, May, July, and November). When True, enhanced content scheduling and ad pricing rules may apply. | Column sweeps_period_flag (BOOLEAN) in scheduling.daypart' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timezoneCode rdf:type rdf:Property ;
    rdfs:label 'Timezone Code' ;
    rdfs:comment 'The IANA timezone identifier (e.g., America/New_York, America/Los_Angeles, Europe/London) governing the clock boundaries of this daypart. Critical for multi-market broadcast operations where the same daypart definition must be applied across different time zones for network affiliates and regional channels. | Column timezone_code (STRING) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upfrontEligible rdf:type rdf:Property ;
    rdfs:label 'Upfront Eligible' ;
    rdfs:comment 'Indicates whether ad inventory within this daypart is offered during the upfront advance advertising sales event. Prime Time and key dayparts are typically upfront-eligible. Drives Salesforce Media Cloud opportunity and proposal configuration for annual upfront sales cycles. | Column upfront_eligible (BOOLEAN) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wideOrbitDaypartCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Daypart Code' ;
    rdfs:comment 'The corresponding daypart identifier as configured in the Wide Orbit traffic and billing system. Used to reconcile internal daypart definitions with ad scheduling, sales orders, and affidavit records in Wide Orbit. Enables cross-system traceability for revenue assurance. | Column wide_orbit_daypart_code (STRING) in scheduling.daypart' ;
    rdfs:domain ind:Daypart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adPodCount rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Count' ;
    rdfs:comment 'Total number of ad pods (groups of ads in a break) planned in the schedule for this channel day. An ad pod is a contiguous block of commercial spots within a program break. Used for inventory planning and SCTE-35 cue marker validation. | Column ad_pod_count (INT) in scheduling.program_schedule' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:asRunConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'As Run Confirmed Timestamp' ;
    rdfs:comment 'Timestamp when the as-run log was confirmed and reconciled against the planned schedule. Marks the transition to \'as-run\' status. Used for Wide Orbit affidavit generation, Nielsen ratings reconciliation, and revenue assurance. | Column as_run_confirmed_timestamp (TIMESTAMP) in scheduling.program_schedule' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blackoutFlag rdf:type rdf:Property ;
    rdfs:label 'Blackout Flag' ;
    rdfs:comment 'Indicates whether any geographic broadcast blackout restriction applies to this schedule. True = one or more programs in this schedule are subject to blackout in specific markets (e.g., sports rights blackout). Triggers downstream blackout enforcement in distribution and CDN systems. | Column blackout_flag (BOOLEAN) in scheduling.program_schedule' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastDate rdf:type rdf:Property ;
    rdfs:label 'Broadcast Date' ;
    rdfs:comment 'The calendar date for which this program schedule is planned and transmitted. Represents the broadcast day (which may span midnight for overnight programming). Formatted as yyyy-MM-dd per enterprise date convention. | Column broadcast_date (DATE) in scheduling.program_schedule' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:broadcastStandard rdf:type rdf:Property ;
    rdfs:label 'Broadcast Standard' ;
    rdfs:comment 'The broadcast technical standard under which this schedule is transmitted. ATSC = Advanced Television Systems Committee (North America); DVB = Digital Video Broadcasting (Europe/international); ISDB = Integrated Services Digital Broadcasting (Japan/Brazil); NTSC/PAL = legacy analog standards. | Column broadcast_standard (STRING) in scheduling.program_schedule' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRatingAdvisory rdf:type rdf:Property ;
    rdfs:label 'Content Rating Advisory' ;
    rdfs:comment 'The highest content rating advisory applicable to any program in this schedule for the broadcast day. Used for parental control systems, V-chip compliance, and FCC content standards reporting. Ratings follow the TV Parental Guidelines system mandated by the FCC. | Column content_rating_advisory (STRING) in scheduling.program_schedule' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletWorkflowCode rdf:type rdf:Property ;
    rdfs:label 'Dalet Workflow Code' ;
    rdfs:comment 'Reference identifier for the Dalet Galaxy media asset management workflow instance associated with this schedule\'s content preparation and ingest activities. Links the schedule to the MAM workflow for asset readiness validation prior to playout. | Column dalet_workflow_code (STRING) in scheduling.program_schedule' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyAlertReady rdf:type rdf:Property ;
    rdfs:label 'Emergency Alert Ready' ;
    rdfs:comment 'Indicates whether the schedule has been configured with Emergency Alert System (EAS) interrupt capability for this broadcast date. True = EAS interrupt slots are provisioned in the Ericsson MediaFirst rundown. Required for FCC EAS compliance. | Column emergency_alert_ready (BOOLEAN) in scheduling.program_schedule' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epgGridCode rdf:type rdf:Property ;
    rdfs:label 'Epg Grid Code' ;
    rdfs:comment 'External identifier assigned to this schedule in the Electronic Program Guide (EPG) distribution system. Used by downstream EPG aggregators, set-top box providers, and digital guide services to reference the channel day grid. Aligns with DVB SI/EIT table identifiers. | Column epg_grid_code (STRING) in scheduling.program_schedule' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fccChildrenProgrammingCompliant rdf:type rdf:Property ;
    rdfs:label 'Fcc Children Programming Compliant' ;
    rdfs:comment 'Indicates whether this schedule meets FCC children\'s educational and informational (E/I) programming requirements for the broadcast date. True = minimum required hours of qualifying children\'s programming are scheduled. Required for FCC license renewal compliance reporting. | Column fcc_children_programming_compliant (BOOLEAN) in scheduling.program_schedule' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediafirstRundownCode rdf:type rdf:Property ;
    rdfs:label 'Mediafirst Rundown Code' ;
    rdfs:comment 'Reference identifier for the automation rundown object in Ericsson MediaFirst that corresponds to this program schedule. Used to reconcile the planned schedule with the playout automation system\'s rundown for failover and as-run log generation. | Column mediafirst_rundown_code (STRING) in scheduling.program_schedule' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mustCarryCompliant rdf:type rdf:Property ;
    rdfs:label 'Must Carry Compliant' ;
    rdfs:comment 'Indicates whether this schedule satisfies must-carry obligations for the channel on this broadcast date. Must-carry is the mandatory channel inclusion requirement imposed on cable and satellite MVPDs by the FCC. True = compliant; False = compliance issue requiring resolution. | Column must_carry_compliant (BOOLEAN) in scheduling.program_schedule' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playoutFailoverMode rdf:type rdf:Property ;
    rdfs:label 'Playout Failover Mode' ;
    rdfs:comment 'Indicates the Ericsson MediaFirst playout failover configuration active for this schedule. \'primary\' = normal automated playout; \'backup\' = failover to backup playout server; \'manual_override\' = operator has taken manual control of playout. Used for SLA and incident reporting. | Column playout_failover_mode (STRING) in scheduling.program_schedule' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleEndTime rdf:type rdf:Property ;
    rdfs:label 'Schedule End Time' ;
    rdfs:comment 'The planned end timestamp of the broadcast schedule for this channel day, including timezone offset. Typically 23:59:59 local broadcast time but may extend past midnight for overnight programming blocks. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX. | Column schedule_end_time (TIMESTAMP) in scheduling.program_schedule' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable label for the schedule, typically combining channel name and broadcast date (e.g., \'CNN-HD 2024-06-15 v2\'). Used by scheduling operations staff to identify and reference the schedule in Ericsson MediaFirst and Wide Orbit Traffic systems. | Column schedule_name (STRING) in scheduling.program_schedule' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNotes rdf:type rdf:Property ;
    rdfs:label 'Schedule Notes' ;
    rdfs:comment 'Free-text operational notes entered by scheduling staff regarding special instructions, exceptions, or context for this schedule (e.g., \'Breaking news override applied to 8PM slot\', \'Live sports event extends prime block by 30 min\'). Not used for automated processing. | Column schedule_notes (STRING) in scheduling.program_schedule' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleSource rdf:type rdf:Property ;
    rdfs:label 'Schedule Source' ;
    rdfs:comment 'Indicates how this schedule was generated. \'manual\' = built by scheduling staff; \'automated\' = generated by Ericsson MediaFirst automated schedule engine; \'imported\' = ingested from an external programming supplier or network feed; \'template\' = derived from a recurring schedule template. | Column schedule_source (STRING) in scheduling.program_schedule' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStartTime rdf:type rdf:Property ;
    rdfs:label 'Schedule Start Time' ;
    rdfs:comment 'The planned start timestamp of the broadcast schedule for this channel day, including timezone offset. Typically 00:00:00 local broadcast time but may differ for overnight schedules that begin at a non-midnight boundary. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX. | Column schedule_start_time (TIMESTAMP) in scheduling.program_schedule' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle state of the program schedule. \'draft\' = initial build in progress; \'approved\' = signed off by programming team; \'transmitted\' = sent to Ericsson MediaFirst playout automation; \'as-run\' = actual broadcast log confirmed; \'cancelled\' = schedule voided and replaced. | Column schedule_status (STRING) in scheduling.program_schedule' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the schedule by programming strategy type. \'standard\' = regular broadcast day; \'special_event\' = live event or breaking news override; \'holiday\' = holiday programming grid; \'sweeps\' = Nielsen sweeps period intensive ratings schedule; \'upfront_preview\' = advance advertising sales event programming. | Column schedule_type (STRING) in scheduling.program_schedule' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Monotonically incrementing version number for the schedule on a given channel and broadcast date. Enables tracking of schedule revisions from initial draft through final as-run. Version 1 is the initial draft; each approved revision increments the version. | Column schedule_version (INT) in scheduling.program_schedule' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scte35CueCount rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue Count' ;
    rdfs:comment 'Total number of SCTE-35 digital program insertion cue markers embedded in the schedule for this channel day. SCTE-35 cues signal ad break opportunities for Dynamic Ad Insertion (DAI) in both linear and OTT streams. Used to validate DAI readiness. | Column scte35_cue_count (INT) in scheduling.program_schedule' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:simulcastFlag rdf:type rdf:Property ;
    rdfs:label 'Simulcast Flag' ;
    rdfs:comment 'Indicates whether this schedule is configured for simultaneous multi-platform broadcast (simulcast). True = the schedule is transmitted concurrently across linear broadcast and one or more OTT/streaming platforms. Drives Ericsson MediaFirst simulcast automation configuration. | Column simulcast_flag (BOOLEAN) in scheduling.program_schedule' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:simulcastPlatformCount rdf:type rdf:Property ;
    rdfs:label 'Simulcast Platform Count' ;
    rdfs:comment 'Number of platforms on which this schedule is simultaneously broadcast when simulcast_flag is True. Used for multi-platform distribution planning and rights compliance verification across linear, OTT, and vMVPD delivery channels. | Column simulcast_platform_count (INT) in scheduling.program_schedule' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier for the broadcast timezone in which this schedule\'s times are expressed (e.g., \'America/New_York\', \'Europe/London\'). Critical for accurate EPG display, daypart classification, and regulatory compliance reporting across markets. | Column timezone (STRING) in scheduling.program_schedule' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAdTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Ad Time Seconds' ;
    rdfs:comment 'Total planned advertising airtime in seconds across all ad pods in the schedule for this channel day. Used for commercial inventory management, FCC commercial limits compliance, and revenue forecasting against Wide Orbit traffic orders. | Column total_ad_time_seconds (INT) in scheduling.program_schedule' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalProgramTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Program Time Seconds' ;
    rdfs:comment 'Total planned programming (non-commercial) airtime in seconds for this channel day schedule. Equals total_runtime_seconds minus total_ad_time_seconds. Used for content utilization reporting and rights compliance verification. | Column total_program_time_seconds (INT) in scheduling.program_schedule' ;
    rdfs:domain ind:ProgramSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRuntimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Runtime Seconds' ;
    rdfs:comment 'Total planned runtime of all program items in the schedule, expressed in seconds. Used to validate that the schedule fills the full broadcast day (86,400 seconds for a 24-hour schedule) and to detect gaps or overlaps in the rundown. | Column total_runtime_seconds (INT) in scheduling.program_schedule' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionType rdf:type rdf:Property ;
    rdfs:label 'Transmission Type' ;
    rdfs:comment 'Indicates the primary mode of content delivery for this schedule. \'linear\' = traditional scheduled broadcast; \'vod_window\' = on-demand programming window; \'fast_channel\' = Free Ad-Supported Streaming Television (FAST) channel; \'simulcast\' = simultaneous multi-platform broadcast. | Column transmission_type (STRING) in scheduling.program_schedule' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmitted Timestamp' ;
    rdfs:comment 'Timestamp when the approved schedule was transmitted to the Ericsson MediaFirst playout automation system. Marks the transition from \'approved\' to \'transmitted\' status. Used for playout readiness SLA monitoring and failover preparation. | Column transmitted_timestamp (TIMESTAMP) in scheduling.program_schedule' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wideOrbitLogCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Log Code' ;
    rdfs:comment 'Reference identifier for the corresponding traffic log in Wide Orbit Traffic and Billing system. Links the program schedule to the ad scheduling and affidavit records for commercial break reconciliation and proof-of-broadcast (affidavit) generation. | Column wide_orbit_log_code (STRING) in scheduling.program_schedule' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleSlotId rdf:type rdf:Property ;
    rdfs:label 'Schedule Slot Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual schedule slot record within the Electronic Program Guide (EPG) rundown. Primary key for the schedule_slot data product managed in Ericsson MediaFirst. | Column schedule_slot_id (BIGINT) in scheduling.schedule_slot' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleSlot .

ind:actualDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Seconds' ;
    rdfs:comment 'Real-world duration of the slot in seconds as recorded in the as-run log. Compared against planned_duration_seconds to identify overruns, underruns, and schedule compliance deviations. Used in affidavit reconciliation and makegoods processing. | Column actual_duration_seconds (INT) in scheduling.schedule_slot' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Real-world start time of the slot as recorded in the as-run log by Ericsson MediaFirst playout automation. May differ from planned_start_time due to live events, technical delays, or schedule overruns. Critical for affidavit generation in Wide Orbit and Nielsen audience measurement reconciliation. | Column actual_start_time (TIMESTAMP) in scheduling.schedule_slot' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:automationEventCode rdf:type rdf:Property ;
    rdfs:label 'Automation Event Code' ;
    rdfs:comment 'Ericsson MediaFirst playout automation system event identifier for this slot. The native key from the MediaFirst rundown used for as-run reconciliation, failover event tracking, and technical operations audit. | Column automation_event_code (STRING) in scheduling.schedule_slot' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easAlertType rdf:type rdf:Property ;
    rdfs:label 'Eas Alert Type' ;
    rdfs:comment 'Type of Emergency Alert System (EAS) message associated with this slot when slot_type is \'eas\' (e.g., EAN — Emergency Action Notification, NPT — National Periodic Test, RWT — Required Weekly Test). Null for non-EAS slots. Mandatory for FCC EAS compliance logging. [ENUM-REF-CANDIDATE: EAN|NPT|RWT|SVR|TOR|FFW|HUW|WSW — promote to reference product] | Column eas_alert_type (STRING) in scheduling.schedule_slot' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlackout rdf:type rdf:Property ;
    rdfs:label 'Is Blackout' ;
    rdfs:comment 'Indicates whether a geographic broadcast restriction (blackout) applies to this slot (True). Blackout rules are enforced at the distribution layer and must be flagged at the slot level for rights compliance and audience measurement exclusion. | Column is_blackout (BOOLEAN) in scheduling.schedule_slot' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLive rdf:type rdf:Property ;
    rdfs:label 'Is Live' ;
    rdfs:comment 'Indicates whether this slot carries a live broadcast event (True) or pre-recorded/taped content (False). Live slots require different playout automation handling, DAI configuration, and rights clearance verification in Rightsline. | Column is_live (BOOLEAN) in scheduling.schedule_slot' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeat rdf:type rdf:Property ;
    rdfs:label 'Is Repeat' ;
    rdfs:comment 'Indicates whether this slot is a repeat airing of previously broadcast content (True) rather than a first-run premiere (False). Affects talent residuals calculations in Rightsline and Nielsen audience measurement weighting. | Column is_repeat (BOOLEAN) in scheduling.schedule_slot' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSimulcast rdf:type rdf:Property ;
    rdfs:label 'Is Simulcast' ;
    rdfs:comment 'Indicates whether this slot is simultaneously broadcast across multiple platforms or channels (True). Simulcast slots require coordinated playout across linear and OTT/streaming distribution paths and may trigger additional rights obligations. | Column is_simulcast (BOOLEAN) in scheduling.schedule_slot' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isciCode rdf:type rdf:Property ;
    rdfs:label 'Isci Code' ;
    rdfs:comment 'Industry Standard Commercial Identification (ISCI) code for the commercial spot airing in this slot. An 8-character alphanumeric code used by Wide Orbit and ad agencies to uniquely identify a specific commercial creative. Null for non-commercial slot types. | Column isci_code (STRING) in scheduling.schedule_slot' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mustCarryFlag rdf:type rdf:Property ;
    rdfs:label 'Must Carry Flag' ;
    rdfs:comment 'Indicates whether this slot is subject to must-carry obligations requiring MVPDs to include this channel/content in their basic tier (True). Flags slots that cannot be blacked out or substituted under FCC must-carry rules. | Column must_carry_flag (BOOLEAN) in scheduling.schedule_slot' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nielsenProgramCode rdf:type rdf:Property ;
    rdfs:label 'Nielsen Program Code' ;
    rdfs:comment 'Nielsen Media Research proprietary program code assigned to the content in this slot. Used to match as-run schedule data with Nielsen ratings data for audience measurement, GRP/TRP calculation, and advertiser reporting. | Column nielsen_program_code (STRING) in scheduling.schedule_slot' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Seconds' ;
    rdfs:comment 'Intended duration of the slot in seconds as scheduled in the EPG rundown. Used for schedule integrity validation, ad pod capacity planning, and compliance with broadcast standards for minimum program duration. | Column planned_duration_seconds (INT) in scheduling.schedule_slot' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned End Time' ;
    rdfs:comment 'Scheduled end date and time for this slot as defined in the EPG rundown. Derived from planned_start_time plus planned_duration_seconds but stored explicitly to support EPG grid queries and boundary validation. | Column planned_end_time (TIMESTAMP) in scheduling.schedule_slot' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Time' ;
    rdfs:comment 'Scheduled start date and time for this slot as defined in the EPG rundown prior to broadcast. Expressed in ISO 8601 format with timezone offset. Used for EPG publication, audience measurement alignment, and ad trafficking in Wide Orbit. | Column planned_start_time (TIMESTAMP) in scheduling.schedule_slot' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:programTitle rdf:type rdf:Property ;
    rdfs:label 'Program Title' ;
    rdfs:comment 'Human-readable title of the program or content event airing in this slot as it appears in the published EPG. Used for audience-facing program guides, Nielsen ratings matching, and schedule reporting. | Column program_title (STRING) in scheduling.schedule_slot' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scte35CueInTime rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue In Time' ;
    rdfs:comment 'Timestamp of the SCTE-35 splice_insert cue-in signal marking the return to primary program content after an ad break. Paired with scte35_cue_out_time to define the exact ad avail window for DAI and Wide Orbit ad scheduling. | Column scte35_cue_in_time (TIMESTAMP) in scheduling.schedule_slot' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scte35CueOutTime rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue Out Time' ;
    rdfs:comment 'Timestamp of the SCTE-35 splice_insert cue-out signal marking the start of an ad break or content interruption within this slot. Used by Dynamic Ad Insertion (DAI) systems and downstream distribution platforms to trigger ad replacement. Null for non-break slot types. | Column scte35_cue_out_time (TIMESTAMP) in scheduling.schedule_slot' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slotSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Slot Sequence Number' ;
    rdfs:comment 'Ordinal position of this slot within the daily rundown for the channel. Determines the playout order in Ericsson MediaFirst automation. Sequence numbers are contiguous integers starting at 1 for each broadcast day. | Column slot_sequence_number (INT) in scheduling.schedule_slot' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slotStatus rdf:type rdf:Property ;
    rdfs:label 'Slot Status' ;
    rdfs:comment 'Current lifecycle state of the schedule slot within the EPG workflow. Values: scheduled (initial EPG entry), confirmed (locked for playout), on_air (currently broadcasting), completed (as-run recorded), cancelled (removed from schedule), replaced (substituted with alternate content). Drives Ericsson MediaFirst automation state machine. | Column slot_status (STRING) in scheduling.schedule_slot' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotType rdf:type rdf:Property ;
    rdfs:label 'Slot Type' ;
    rdfs:comment 'Classification of the schedule slot by content category. Values: program (primary editorial content), promo (promotional spot), commercial_break (paid advertising break), filler (interstitial padding content), psa (Public Service Announcement), eas (Emergency Alert System message). Drives playout automation logic and ad insertion rules in Ericsson MediaFirst. | Column slot_type (STRING) in scheduling.schedule_slot' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Traffic Order Number' ;
    rdfs:comment 'Wide Orbit traffic system order number associated with this slot when it carries a commercial or promotional spot. Links the EPG slot to the ad sales order for affidavit generation, billing reconciliation, and makegood processing. | Column traffic_order_number (STRING) in scheduling.schedule_slot' ;
    rdfs:domain ind:ScheduleSlot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgEntryId rdf:type rdf:Property ;
    rdfs:label 'Epg Entry Id' ;
    rdfs:comment 'Unique surrogate identifier for each Electronic Program Guide (EPG) entry record in the scheduling domain. Serves as the primary key for this Silver Layer data product. | Column epg_entry_id (BIGINT) in scheduling.epg_entry' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpgEntry .

ind:schedulingDaypartId rdf:type rdf:Property ;
    rdfs:label 'Scheduling Daypart Id' ;
    rdfs:comment 'Foreign key linking to scheduling.daypart. Business justification: EPG entries require daypart linkage for audience reach estimation, program discovery optimization, and daypart-based content recommendations. Creates new scheduling_daypart_id FK (role-prefixed to avo | Column scheduling_daypart_id (BIGINT) in scheduling.epg_entry' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Daypart .

ind:blackoutRegionCodes rdf:type rdf:Property ;
    rdfs:label 'Blackout Region Codes' ;
    rdfs:comment 'Comma-separated list of geographic region or market codes where this program is subject to broadcast blackout restrictions. Used by distribution systems to suppress EPG entry delivery in restricted markets. Populated only when is_blackout is True. | Column blackout_region_codes (STRING) in scheduling.epg_entry' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionWindow rdf:type rdf:Property ;
    rdfs:label 'Distribution Window' ;
    rdfs:comment 'The distribution window or release strategy under which this EPG entry is being broadcast, reflecting the windowing strategy for sequential content release. Determines rights availability and platform eligibility per Rightsline contract terms. | Column distribution_window (STRING) in scheduling.epg_entry' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'The current lifecycle status of this EPG entry within the scheduling workflow. \'draft\' indicates pending review; \'approved\' indicates cleared for distribution; \'published\' indicates actively distributed to EPG feeds; \'cancelled\' indicates removed from schedule; \'expired\' indicates the broadcast window has passed. | Column entry_status (STRING) in scheduling.epg_entry' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgFeedVersion rdf:type rdf:Property ;
    rdfs:label 'Epg Feed Version' ;
    rdfs:comment 'The version number of this EPG entry record as distributed in the EPG feed. Incremented each time the entry is updated and redistributed to MVPDs, vMVPDs, and digital platforms. Enables downstream systems to detect and apply updates. | Column epg_feed_version (INT) in scheduling.epg_entry' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:episodeTitle rdf:type rdf:Property ;
    rdfs:label 'Episode Title' ;
    rdfs:comment 'The title of the specific episode within a series, as displayed in the EPG. Null for non-episodic content such as feature films or standalone specials. | Column episode_title (STRING) in scheduling.epg_entry' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genrePrimary rdf:type rdf:Property ;
    rdfs:label 'Genre Primary' ;
    rdfs:comment 'The primary content genre classification for this EPG entry as distributed in the EPG feed (e.g., Drama, Comedy, News, Sports, Documentary, Reality). Used for viewer discovery, content filtering, and audience analytics. [ENUM-REF-CANDIDATE: drama|comedy|news|sports|documentary|reality|entertainment|children|film|music — promote to reference product] | Column genre_primary (STRING) in scheduling.epg_entry' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreSecondary rdf:type rdf:Property ;
    rdfs:label 'Genre Secondary' ;
    rdfs:comment 'An optional secondary genre sub-classification providing more granular content categorization for EPG discovery and audience targeting (e.g., Crime Drama, Political Comedy, Investigative Documentary). | Column genre_secondary (STRING) in scheduling.epg_entry' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isClosedCaption rdf:type rdf:Property ;
    rdfs:label 'Is Closed Caption' ;
    rdfs:comment 'Indicates whether closed captioning (CC) is available for this program (True). Distributed in EPG feeds for accessibility compliance and viewer information. Required for FCC closed captioning regulatory compliance. | Column is_closed_caption (BOOLEAN) in scheduling.epg_entry' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHdr rdf:type rdf:Property ;
    rdfs:label 'Is Hdr' ;
    rdfs:comment 'Indicates whether this program is available in High Dynamic Range (HDR) format (True). Distributed in EPG feeds to inform viewers and set-top boxes of enhanced picture quality availability. | Column is_hdr (BOOLEAN) in scheduling.epg_entry' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNewEpisode rdf:type rdf:Property ;
    rdfs:label 'Is New Episode' ;
    rdfs:comment 'Indicates whether this EPG entry represents a new, first-run episode (True) or a repeat/rerun broadcast (False). Distributed in EPG feeds for viewer-facing \'NEW\' indicators and drives audience measurement prioritization. | Column is_new_episode (BOOLEAN) in scheduling.epg_entry' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'The date and time when this EPG entry was first published and distributed to external EPG feeds (MVPDs, vMVPDs, set-top boxes, digital platforms). Serves as the record audit created timestamp for this data product. | Column published_timestamp (TIMESTAMP) in scheduling.epg_entry' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rightsWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Rights Window End' ;
    rdfs:comment 'The end date of the broadcast rights window during which this content is cleared for transmission on this channel. After this date, the content enters a holdback period and cannot be broadcast without rights renewal in Rightsline. | Column rights_window_end (DATE) in scheduling.epg_entry' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsWindowStart rdf:type rdf:Property ;
    rdfs:label 'Rights Window Start' ;
    rdfs:comment 'The start date of the broadcast rights window during which this content is cleared for transmission on this channel. Derived from Rightsline contract availabilities and used to validate schedule compliance. | Column rights_window_start (DATE) in scheduling.epg_entry' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'The precise date and time at which this program is scheduled to end broadcast on the channel. Used to calculate program duration and to sequence adjacent EPG entries in the linear channel grid. | Column scheduled_end_time (TIMESTAMP) in scheduling.epg_entry' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'The precise date and time at which this program is scheduled to begin broadcast on the channel, expressed in ISO 8601 format with timezone offset. This is the principal business event timestamp for the EPG entry and drives all downstream playout automation in Ericsson MediaFirst. | Column scheduled_start_time (TIMESTAMP) in scheduling.epg_entry' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:seriesName rdf:type rdf:Property ;
    rdfs:label 'Series Name' ;
    rdfs:comment 'The name of the parent series or franchise to which this episode belongs. Enables series-level grouping and discovery in EPG interfaces. Null for non-series content. | Column series_name (STRING) in scheduling.epg_entry' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAdBreakDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Ad Break Duration Seconds' ;
    rdfs:comment 'The total cumulative duration in seconds of all scheduled ad breaks within this program. Used for advertising inventory management, compliance with ad load regulations, and Wide Orbit traffic scheduling. | Column total_ad_break_duration_seconds (INT) in scheduling.epg_entry' ;
    rdfs:domain ind:EpgEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adBreakId rdf:type rdf:Property ;
    rdfs:label 'Ad Break Id' ;
    rdfs:comment 'Unique surrogate identifier for the ad break (ad pod) record within the scheduling domain. Primary key for this entity. | Column ad_break_id (BIGINT) in scheduling.ad_break' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdBreak .

ind:affidavitGenerated rdf:type rdf:Property ;
    rdfs:label 'Affidavit Generated' ;
    rdfs:comment 'Indicates whether a proof-of-broadcast affidavit has been generated for this ad break in the Wide Orbit traffic system following confirmed playout. Affidavits are required for advertiser billing reconciliation and regulatory compliance. | Column affidavit_generated (BOOLEAN) in scheduling.ad_break' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availCount rdf:type rdf:Property ;
    rdfs:label 'Avail Count' ;
    rdfs:comment 'The total number of individual advertising avail slots (unit positions) within this ad break pod. Each avail represents a discrete sellable unit (e.g., a 30-second spot position). Used for inventory capacity planning and traffic scheduling. | Column avail_count (INT) in scheduling.ad_break' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutRestricted rdf:type rdf:Property ;
    rdfs:label 'Blackout Restricted' ;
    rdfs:comment 'Indicates whether this ad break is subject to geographic blackout restrictions that prevent its broadcast or streaming in specific markets or regions. When true, downstream distribution systems must apply blackout logic per rights and regulatory obligations. | Column blackout_restricted (BOOLEAN) in scheduling.ad_break' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakPosition rdf:type rdf:Property ;
    rdfs:label 'Break Position' ;
    rdfs:comment 'Positional classification of the ad break relative to the surrounding program content. \'pre-roll\' = before program content begins; \'mid-roll\' = within program content; \'post-roll\' = after program content ends; \'interstitial\' = between programs in the schedule grid. | Column break_position (STRING) in scheduling.ad_break' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakStatus rdf:type rdf:Property ;
    rdfs:label 'Break Status' ;
    rdfs:comment 'Current lifecycle status of the ad break within the scheduling and playout workflow. \'scheduled\' = planned but not yet confirmed; \'confirmed\' = traffic-confirmed with sold inventory; \'aired\' = playout completed and affidavit-eligible; \'cancelled\' = removed from schedule; \'hold\' = temporarily suspended pending resolution. | Column break_status (STRING) in scheduling.ad_break' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakType rdf:type rdf:Property ;
    rdfs:label 'Break Type' ;
    rdfs:comment 'Classification of the ad break by inventory ownership and commercial purpose. \'local_avail\' = inventory sold by local affiliate; \'network_avail\' = inventory sold by the network; \'promotional\' = house promotional content; \'public_service\' = public service announcements; \'emergency\' = emergency alert system override. Drives revenue attribution and traffic scheduling rules. | Column break_type (STRING) in scheduling.ad_break' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRestrictionCode rdf:type rdf:Property ;
    rdfs:label 'Content Restriction Code' ;
    rdfs:comment 'A code indicating any content category restrictions applicable to advertising within this break (e.g., no alcohol ads during children\'s programming, no competitor ads). Enforced by the traffic system during ad assignment. [ENUM-REF-CANDIDATE: NO_ALCOHOL|NO_GAMBLING|NO_PHARMA|NO_COMPETITOR|CHILDREN_SAFE|NONE — promote to reference product] | Column content_restriction_code (STRING) in scheduling.ad_break' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgBreakLabel rdf:type rdf:Property ;
    rdfs:label 'Epg Break Label' ;
    rdfs:comment 'The human-readable label or descriptor for this ad break as it appears in the Electronic Program Guide (EPG) and scheduling rundown. Used by traffic coordinators and scheduling operators to identify breaks in the EPG interface. | Column epg_break_label (STRING) in scheduling.ad_break' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpTarget rdf:type rdf:Property ;
    rdfs:label 'Grp Target' ;
    rdfs:comment 'The target Gross Rating Point (GRP) value for this ad break, representing the expected total audience delivery as a percentage of the total target population. Used for audience guarantee tracking and campaign delivery reporting against Nielsen ratings. | Column grp_target (DECIMAL(8,4)) in scheduling.ad_break' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodRequired rdf:type rdf:Property ;
    rdfs:label 'Makegood Required' ;
    rdfs:comment 'Indicates whether a makegood (compensatory ad spot) is required for this break due to a failure to air as contracted — for example, due to preemption, technical failure, or underdelivery. Triggers makegood workflow in Wide Orbit. | Column makegood_required (BOOLEAN) in scheduling.ad_break' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Max Duration Seconds' ;
    rdfs:comment 'The maximum allowable duration of the ad break in seconds, representing the hard ceiling for total ad content that may be inserted. Exceeding this value would cause schedule overrun. May differ from planned duration when flex time is permitted. | Column max_duration_seconds (INT) in scheduling.ad_break' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nielsenProgramRating rdf:type rdf:Property ;
    rdfs:label 'Nielsen Program Rating' ;
    rdfs:comment 'The Nielsen audience rating for the program surrounding this ad break, representing the percentage of total TV households tuned in. Used for CPM calculation, audience guarantee assessment, and scatter market pricing. | Column nielsen_program_rating (DECIMAL(6,4)) in scheduling.ad_break' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podNumber rdf:type rdf:Property ;
    rdfs:label 'Pod Number' ;
    rdfs:comment 'The pod number identifying this ad break within the broadcast day for the channel. Distinct from sequence_number (which is relative to the program); pod_number is the channel-day-level ordinal used in traffic scheduling and affidavit reporting. | Column pod_number (INT) in scheduling.ad_break' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preemptionReason rdf:type rdf:Property ;
    rdfs:label 'Preemption Reason' ;
    rdfs:comment 'The reason code explaining why this ad break was preempted or cancelled if it did not air as scheduled. Used for makegood processing, revenue assurance, and operational reporting. \'none\' when the break aired as planned. | Column preemption_reason (STRING) in scheduling.ad_break' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardCpm rdf:type rdf:Property ;
    rdfs:label 'Rate Card Cpm' ;
    rdfs:comment 'The published rate card CPM (Cost Per Mille — cost per 1,000 audience impressions) for this ad break, expressed in the local currency. Represents the base pricing for inventory in this break before negotiated discounts. Used for revenue forecasting and yield management. | Column rate_card_cpm (DECIMAL(10,4)) in scheduling.ad_break' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordinal position of this ad break within the parent schedule slot or program. Used to order multiple breaks within a single program (e.g., break 1, break 2, break 3) for traffic scheduling and playout automation. | Column sequence_number (INT) in scheduling.ad_break' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soldAvailCount rdf:type rdf:Property ;
    rdfs:label 'Sold Avail Count' ;
    rdfs:comment 'The number of individual avail slots within this break that have been sold and assigned to advertiser spots in the Wide Orbit traffic system. Used with avail_count to compute sellout rate and unsold inventory. | Column sold_avail_count (INT) in scheduling.ad_break' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soldDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Sold Duration Seconds' ;
    rdfs:comment 'The total duration in seconds of ad inventory within this break that has been sold to advertisers via the Wide Orbit traffic system. Used to calculate unsold (remnant) inventory and sellout rate for revenue assurance reporting. | Column sold_duration_seconds (INT) in scheduling.ad_break' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wideOrbitBreakCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Break Code' ;
    rdfs:comment 'The externally-known break identifier assigned by the Wide Orbit traffic and billing system. Used to reconcile ad break inventory between the scheduling domain and the ad sales/traffic fulfillment workflow. This is the BUSINESS_IDENTIFIER for the break as known to the traffic system. | Column wide_orbit_break_code (STRING) in scheduling.ad_break' ;
    rdfs:domain ind:AdBreak ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutEventId rdf:type rdf:Property ;
    rdfs:label 'Playout Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each as-run playout event record in the Ericsson MediaFirst as-run log. Serves as the primary key for this table. | Column playout_event_id (BIGINT) in scheduling.playout_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayoutEvent .

ind:primaryPlayoutTitleId rdf:type rdf:Property ;
    rdfs:label 'Primary Playout Title Id' ;
    rdfs:comment 'Reference to the content asset (programme, advertisement, interstitial, or filler) that was transmitted in this playout event. Links to the content master in the Digital Asset Management system. | Column primary_playout_title_id (BIGINT) in content.playout_event' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:programRundownId rdf:type rdf:Property ;
    rdfs:label 'Program Rundown Id' ;
    rdfs:comment 'Foreign key linking to scheduling.program_rundown. Business justification: A playout event (as-run log record from Ericsson MediaFirst) executes against a specific program rundown. Linking playout_event to program_rundown enables reconciliation between the planned production' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramRundown .

ind:royaltyRuleId rdf:type rdf:Property ;
    rdfs:label 'Royalty Rule Id' ;
    rdfs:comment 'Foreign key linking to rights.royalty_rule. Business justification: Each playout event triggers royalty obligations calculated per the applicable royalty_rule (rate, basis, platform_type). As-run logs feed directly into royalty calculation workflows; the royalty_rule_' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyRule .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual transmission end time as recorded in the Ericsson MediaFirst as-run log. Used with actual_start_time to confirm full transmission and calculate actual duration. | Column actual_end_time (TIMESTAMP) in scheduling.playout_event' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:automationMode rdf:type rdf:Property ;
    rdfs:label 'Automation Mode' ;
    rdfs:comment 'Operational mode of the Ericsson MediaFirst playout automation at the time of this event. \'auto\' = fully automated playout; \'manual\' = operator-controlled; \'override\' = scheduled automation overridden by operator; \'failover\' = backup/failover system active. | Column automation_mode (STRING) in scheduling.playout_event' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletAssetCode rdf:type rdf:Property ;
    rdfs:label 'Dalet Asset Code' ;
    rdfs:comment 'Asset identifier in the Dalet Galaxy Media Asset Management system for the content transmitted in this playout event. Used for digital asset reconciliation and archive linkage. | Column dalet_asset_code (STRING) in scheduling.playout_event' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the playout event by content category. Determines applicable rights, billing rules, and regulatory requirements. [ENUM-REF-CANDIDATE: program|commercial|promo|interstitial|filler|ident|emergency_alert — promote to reference product] | Column event_type (STRING) in scheduling.playout_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failoverActivated rdf:type rdf:Property ;
    rdfs:label 'Failover Activated' ;
    rdfs:comment 'Indicates whether the Ericsson MediaFirst failover/backup playout system was active during this event. When true, the primary playout chain was unavailable and the backup system handled transmission. | Column failover_activated (BOOLEAN) in scheduling.playout_event' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediafirstEventCode rdf:type rdf:Property ;
    rdfs:label 'Mediafirst Event Code' ;
    rdfs:comment 'Native event identifier assigned by Ericsson MediaFirst automation system for this as-run log entry. Used for reconciliation with the source playout system. | Column mediafirst_event_code (STRING) in scheduling.playout_event' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoutStatus rdf:type rdf:Property ;
    rdfs:label 'Playout Status' ;
    rdfs:comment 'Outcome status of the playout event as recorded in the Ericsson MediaFirst as-run log. \'aired\' = transmitted as planned; \'skipped\' = omitted from transmission; \'substituted\' = replaced with alternate content; \'failed\' = transmission error; \'partial\' = incomplete transmission; \'delayed\' = transmitted late. | Column playout_status (STRING) in scheduling.playout_event' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Scheduled Duration Seconds' ;
    rdfs:comment 'Planned duration of the playout event in seconds as defined in the program schedule rundown. Used as the baseline for duration deviation analysis. | Column scheduled_duration_seconds (INT) in scheduling.playout_event' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:startDeviationSeconds rdf:type rdf:Property ;
    rdfs:label 'Start Deviation Seconds' ;
    rdfs:comment 'Difference in seconds between actual_start_time and scheduled_start_time. Positive values indicate late start; negative values indicate early start. Key metric for schedule adherence and SLA reporting. | Column start_deviation_seconds (INT) in scheduling.playout_event' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substitutionReason rdf:type rdf:Property ;
    rdfs:label 'Substitution Reason' ;
    rdfs:comment 'Reason code explaining why the originally scheduled content was substituted with alternate content. Populated only when playout_status is \'substituted\'. Used for rights compliance and editorial audit trails. | Column substitution_reason (STRING) in scheduling.playout_event' ;
    rdfs:domain ind:PlayoutEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletStoryCode rdf:type rdf:Property ;
    rdfs:label 'Dalet Story Code' ;
    rdfs:comment 'The story or rundown identifier in Dalet Galaxy Media Asset Management system. Enables traceability from the Silver Layer back to the MAM workflow for metadata, archive, and ingest operations. | Column dalet_story_code (STRING) in scheduling.program_rundown' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liveFlag rdf:type rdf:Property ;
    rdfs:label 'Live Flag' ;
    rdfs:comment 'Indicates whether the program is transmitted live (True) or is a pre-recorded/tape playback (False). Drives Ericsson MediaFirst live playout mode and affects DAI eligibility and failover configuration. | Column live_flag (BOOLEAN) in scheduling.program_rundown' ;
    rdfs:domain ind:Scheduling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programContentSeconds rdf:type rdf:Property ;
    rdfs:label 'Program Content Seconds' ;
    rdfs:comment 'Total planned duration of editorial/program content segments in seconds, excluding commercial breaks and credits. Used for content-to-ad ratio compliance reporting. | Column program_content_seconds (INT) in scheduling.program_rundown' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rundownCode rdf:type rdf:Property ;
    rdfs:label 'Rundown Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the rundown, used by production teams and Ericsson MediaFirst automation to reference the show rundown. Unique within a broadcast date and channel. | Column rundown_code (STRING) in scheduling.program_rundown' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rundownNotes rdf:type rdf:Property ;
    rdfs:label 'Rundown Notes' ;
    rdfs:comment 'Free-text production notes associated with the rundown, capturing special instructions, last-minute changes, talent notes, or technical advisories for the production and playout teams. | Column rundown_notes (STRING) in scheduling.program_rundown' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rundownStatus rdf:type rdf:Property ;
    rdfs:label 'Rundown Status' ;
    rdfs:comment 'Current lifecycle state of the rundown. \'draft\' = in preparation; \'approved\' = signed off by producer; \'locked\' = no further edits permitted; \'transmitted\' = playout completed; \'archived\' = retained for compliance. | Column rundown_status (STRING) in scheduling.program_rundown' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rundownType rdf:type rdf:Property ;
    rdfs:label 'Rundown Type' ;
    rdfs:comment 'Classification of the program rundown by genre or production format. Drives template selection in Ericsson MediaFirst and informs segment structure expectations. [ENUM-REF-CANDIDATE: news|sports|entertainment|talk_show|documentary|magazine|special — promote to reference product] | Column rundown_type (STRING) in scheduling.program_rundown' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rundownVersion rdf:type rdf:Property ;
    rdfs:label 'Rundown Version' ;
    rdfs:comment 'Incremental version number of the rundown, incremented each time the rundown is revised. Enables version tracking and rollback for production teams and playout automation. | Column rundown_version (INT) in scheduling.program_rundown' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentCount rdf:type rdf:Property ;
    rdfs:label 'Segment Count' ;
    rdfs:comment 'Total number of rundown items (segments) defined in this rundown, including news blocks, interviews, commercial breaks, tosses, and credits. Used for production planning and playout validation. | Column segment_count (INT) in scheduling.program_rundown' ;
    rdfs:domain ind:ProgramRundown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rundownItemId rdf:type rdf:Property ;
    rdfs:label 'Rundown Item Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual segment or item within a program rundown. Primary key for the rundown_item entity in the Databricks Silver Layer. | Column rundown_item_id (BIGINT) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:musicSyncLicenseId rdf:type rdf:Property ;
    rdfs:label 'Music Sync License Id' ;
    rdfs:comment 'Foreign key linking to rights.music_sync_license. Business justification: Rundown items containing music segments require music sync license verification before broadcast. Music clearance is a mandatory pre-air check in live and recorded production. Linking rundown_item to ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MusicSyncLicense .

ind:adPodDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Duration Seconds' ;
    rdfs:comment 'Total allocated duration in seconds for the ad pod break associated with this rundown item. Populated only when ad_pod_flag is true. Used for ad load compliance and Wide Orbit traffic scheduling. | Column ad_pod_duration_seconds (INT) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adPodFlag rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Flag' ;
    rdfs:comment 'Indicates whether this rundown item represents an Ad Pod (a group of commercial spots within a break). When true, triggers SCTE-35 cue marker insertion and Dynamic Ad Insertion (DAI) eligibility checks. | Column ad_pod_flag (BOOLEAN) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adPodSpotCount rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Spot Count' ;
    rdfs:comment 'Number of individual commercial spots scheduled within this ad pod break. Used for ad load monitoring, Wide Orbit traffic log validation, and FCC children\'s programming ad limit compliance. | Column ad_pod_spot_count (INT) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backtimeFlag rdf:type rdf:Property ;
    rdfs:label 'Backtime Flag' ;
    rdfs:comment 'Indicates whether this rundown item is backtimed — i.e., its start time is calculated backwards from a fixed end point (e.g., top-of-hour news break or programme end). Critical for live show timing control in Ericsson MediaFirst. | Column backtime_flag (BOOLEAN) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cueText rdf:type rdf:Property ;
    rdfs:label 'Cue Text' ;
    rdfs:comment 'Editorial cue or introduction text read by the presenter or director to introduce this rundown item. Stored as the production script reference for live show execution and post-broadcast archive. | Column cue_text (STRING) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartCode rdf:type rdf:Property ;
    rdfs:label 'Daypart Code' ;
    rdfs:comment 'Code identifying the broadcast daypart (time segment of the broadcast day) in which this rundown item falls. Links to scheduling.daypart for rate multiplier, demographic targeting, and Nielsen audience measurement context. | Column daypart_code (STRING) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationVarianceSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Variance Seconds' ;
    rdfs:comment 'Difference in seconds between actual_duration_seconds and planned_duration_seconds (actual minus planned). Positive values indicate overrun; negative values indicate underrun. Used for show timing analysis and rundown optimisation. | Column duration_variance_seconds (INT) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eomTimecode rdf:type rdf:Property ;
    rdfs:label 'Eom Timecode' ;
    rdfs:comment 'SMPTE timecode marking the End of Message (EOM) — the precise out-point of the media asset for this rundown item. Used alongside som_timecode for frame-accurate duration calculation and playout control. | Column eom_timecode (STRING) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgDescription rdf:type rdf:Property ;
    rdfs:label 'Epg Description' ;
    rdfs:comment 'Short editorial description of this rundown item for display in the Electronic Program Guide (EPG). Populated for story packages and feature segments; used by EPG aggregators and on-screen guide systems. | Column epg_description (STRING) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:graphicsTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Graphics Template Code' ;
    rdfs:comment 'Identifier for the graphics or lower-third template to be rendered by the Ericsson MediaFirst graphics engine for this rundown item. Applicable for graphic and lower_third segment formats. | Column graphics_template_code (STRING) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current production lifecycle state of the rundown item as managed in the live show production control system. Drives automation decisions in Ericsson MediaFirst and Dalet Galaxy workflow. | Column item_status (STRING) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemTitle rdf:type rdf:Property ;
    rdfs:label 'Item Title' ;
    rdfs:comment 'Human-readable editorial title or slug for the rundown item as displayed in the production control system and Electronic Program Guide (EPG). Used by producers and directors during live show execution. | Column item_title (STRING) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemType rdf:type rdf:Property ;
    rdfs:label 'Item Type' ;
    rdfs:comment 'Classification of the discrete production element represented by this rundown item. Determines playout behaviour, automation triggers, and ad pod eligibility. [ENUM-REF-CANDIDATE: story_package|live_shot|interview|commercial_break|graphic|music_bed|filler|open|close — promote to reference product] | Column item_type (STRING) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediafirstItemCode rdf:type rdf:Property ;
    rdfs:label 'Mediafirst Item Code' ;
    rdfs:comment 'Native item identifier assigned by the Ericsson MediaFirst playout automation system for this rundown element. Used for reconciliation between the Silver Layer data product and the operational playout system. | Column mediafirst_item_code (STRING) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentFormat rdf:type rdf:Property ;
    rdfs:label 'Segment Format' ;
    rdfs:comment 'Production format classification of the rundown item using broadcast newsroom terminology. Determines the technical playout configuration and graphics overlay requirements in Ericsson MediaFirst. [ENUM-REF-CANDIDATE: pkg|vo|vosot|sot|live|standup|anchor_read|graphic_full|lower_third — promote to reference product] | Column segment_format (STRING) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skipReason rdf:type rdf:Property ;
    rdfs:label 'Skip Reason' ;
    rdfs:comment 'Reason code explaining why this rundown item was skipped during playout. Populated only when item_status = skipped. Used for post-broadcast editorial review and rights compliance audit. | Column skip_reason (STRING) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:somTimecode rdf:type rdf:Property ;
    rdfs:label 'Som Timecode' ;
    rdfs:comment 'SMPTE timecode marking the Start of Message (SOM) — the precise in-point of the media asset to be played for this rundown item. Used by Ericsson MediaFirst for frame-accurate playout cueing. | Column som_timecode (STRING) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeNumber rdf:type rdf:Property ;
    rdfs:label 'Tape Number' ;
    rdfs:comment 'Physical or virtual media identifier (tape ID, clip ID, or server ID) for the pre-recorded asset associated with this rundown item in the Dalet Galaxy MAM system. Used for media retrieval and playout server cueing. | Column tape_number (STRING) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideOrbitSpotCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Spot Code' ;
    rdfs:comment 'Identifier from the Wide Orbit Traffic and Billing system for commercial spots or ad pod items within this rundown. Populated only for item_type = commercial_break; used for affidavit generation and billing reconciliation. | Column wide_orbit_spot_code (STRING) in scheduling.rundown_item' ;
    rdfs:domain ind:RundownItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelLicenseId rdf:type rdf:Property ;
    rdfs:label 'Channel License Id' ;
    rdfs:comment 'Unique surrogate identifier for each channel license record. Primary key for the association. | Column channel_license_id (BIGINT) in scheduling.channel_license' ;
    rdfs:domain ind:ChannelLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenseFeeUsd rdf:type rdf:Property ;
    rdfs:label 'License Fee Usd' ;
    rdfs:comment 'The total licensing fee paid by the channel to acquire broadcast rights for this title, denominated in US dollars. Used for rights cost allocation and profitability analysis. | Column license_fee_usd (DECIMAL(18,4)) in scheduling.channel_license' ;
    rdfs:domain ind:ChannelLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current operational status of the license. Active licenses are available for scheduling; expired licenses have passed their end date; suspended licenses are temporarily unavailable; pending licenses are awaiting activation. | Column license_status (STRING) in scheduling.channel_license' ;
    rdfs:domain ind:ChannelLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceCode rdf:type rdf:Property ;
    rdfs:label ' Source Code' ;
    rdfs:comment 'Medallion lineage column for _source_id | Column _source_id (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adobePropertyCode rdf:type rdf:Property ;
    rdfs:label 'Adobe Property Code' ;
    rdfs:comment 'The unique property identifier assigned to this OTT platform within Adobe Experience Platform (AEP) for audience data collection, segmentation, and personalization. Used to link platform-level engagement events to subscriber profiles and Nielsen cross-platform measurement. | Column adobe_property_code (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arpu rdf:type rdf:Property ;
    rdfs:label 'Arpu' ;
    rdfs:comment 'Average monthly revenue generated per active subscriber on this platform, expressed in the platform\'s billing currency. Calculated at the platform level for strategic pricing and investor reporting. Confidential as a key financial performance indicator. Sourced from Zuora revenue recognition data. | Column arpu (DECIMAL(10,4)) in distribution.ott_platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseSubscriptionPrice rdf:type rdf:Property ;
    rdfs:label 'Base Subscription Price' ;
    rdfs:comment 'The standard monthly subscription price for this platform in the billing currency. Applicable for SVOD and HYBRID tiers. Null for AVOD and FAST platforms with no subscription fee. Used in Zuora plan configuration and financial forecasting in SAP S/4HANA. | Column base_subscription_price (DECIMAL(10,2)) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCurrency rdf:type rdf:Property ;
    rdfs:label 'Billing Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the primary billing currency used on this platform (e.g., \'USD\', \'GBP\', \'EUR\'). Governs Zuora subscription plan pricing, SAP S/4HANA financial reconciliation, and multi-currency revenue reporting. | Column billing_currency (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnProvider rdf:type rdf:Property ;
    rdfs:label 'Cdn Provider' ;
    rdfs:comment 'The primary CDN provider contracted to deliver streaming content for this OTT platform. Drives SLA monitoring, peering agreements, and cost allocation. \'Multi-CDN\' indicates a load-balanced or failover configuration across multiple providers. Maps to Akamai CDN platform configuration records. | Column cdn_provider (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coppaCompliant rdf:type rdf:Property ;
    rdfs:label 'Coppa Compliant' ;
    rdfs:comment 'Indicates whether this platform is designated as COPPA-compliant, meaning it is directed at children under 13 and adheres to COPPA data collection restrictions. True = COPPA-compliant children\'s platform; False = general audience platform. Drives data collection policies in Adobe Experience Platform and ad targeting restrictions. | Column coppa_compliant (BOOLEAN) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daiProvider rdf:type rdf:Property ;
    rdfs:label 'Dai Provider' ;
    rdfs:comment 'The technology vendor or platform providing DAI services for this OTT platform (e.g., \'Google DAI\', \'FreeWheel\', \'Yospace\', \'Brightcove SSAI\'). Null if DAI is not enabled. Used for vendor management, SLA tracking, and ad revenue reconciliation. | Column dai_provider (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionVerified rdf:type rdf:Property ;
    rdfs:label 'Distribution Verified' ;
    rdfs:comment 'Flag indicating distribution verification' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmSystem rdf:type rdf:Property ;
    rdfs:label 'Drm System' ;
    rdfs:comment 'The DRM technology binding enforced on this platform for content protection. Widevine = Google DRM for Android/Chrome; FairPlay = Apple DRM for iOS/Safari; PlayReady = Microsoft DRM for Windows/Xbox; Multi-DRM = all three enforced simultaneously; NONE = no DRM (e.g., FAST free content). Directly linked to Rightsline rights window enforcement and content clearance workflows. | Column drm_system (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgFeedUrl rdf:type rdf:Property ;
    rdfs:label 'Epg Feed Url' ;
    rdfs:comment 'The URL of the Electronic Program Guide data feed for this platform, used by third-party EPG aggregators, smart TV manufacturers, and vMVPD partners to display scheduling information. Null for pure VOD platforms without a linear schedule. Sourced from Ericsson MediaFirst playout system. | Column epg_feed_url (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastChannelEnabled rdf:type rdf:Property ;
    rdfs:label 'Fast Channel Enabled' ;
    rdfs:comment 'Indicates whether this platform operates or hosts FAST channels — linear-style, ad-supported free streaming channels. True = FAST channel delivery active; False = no FAST channel. Relevant for FAST syndication partnerships and Wide Orbit ad scheduling. | Column fast_channel_enabled (BOOLEAN) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freeTrialDays rdf:type rdf:Property ;
    rdfs:label 'Free Trial Days' ;
    rdfs:comment 'Number of days in the free trial period offered to new subscribers on this platform. Zero or null if no free trial is offered. Configured in Zuora subscription plans and used in churn rate and LTV analysis. | Column free_trial_days (INT) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Indicates whether GDPR data protection obligations apply to this platform based on its geographic availability and subscriber base. True = GDPR applies (EU/EEA territories served); False = GDPR not applicable. Governs consent management, data subject rights workflows, and Adobe Experience Platform profile handling. | Column gdpr_applicable (BOOLEAN) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdrSupported rdf:type rdf:Property ;
    rdfs:label 'Hdr Supported' ;
    rdfs:comment 'Indicates whether the platform supports High Dynamic Range video delivery (HDR10, Dolby Vision, or HLG). True = HDR delivery supported; False = SDR only. Relevant for premium content licensing negotiations and CTV device compatibility. | Column hdr_supported (BOOLEAN) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxConcurrentStreams rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Streams' ;
    rdfs:comment 'The maximum number of simultaneous streams permitted per subscriber account on this platform. Enforced at the entitlement layer to prevent credential sharing and manage CDN bandwidth capacity. A key parameter in Zuora subscription plan configuration. | Column max_concurrent_streams (INT) in distribution.ott_platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxDownloadDevices rdf:type rdf:Property ;
    rdfs:label 'Max Download Devices' ;
    rdfs:comment 'The maximum number of devices on which a subscriber may store downloaded content for offline viewing on this platform. Null if offline downloads are not supported. Governed by DRM policy and Rightsline windowing rules. | Column max_download_devices (INT) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxVideoResolution rdf:type rdf:Property ;
    rdfs:label 'Max Video Resolution' ;
    rdfs:comment 'The highest video resolution tier supported for streaming on this platform. SD = Standard Definition (480p); HD = High Definition (720p); FHD = Full HD (1080p); 4K = Ultra HD (2160p); 8K = Super Hi-Vision (4320p). Drives ABR profile configuration, CDN bandwidth planning, and content ingest specifications in Dalet Galaxy. | Column max_video_resolution (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvpdCarriageEligible rdf:type rdf:Property ;
    rdfs:label 'Mvpd Carriage Eligible' ;
    rdfs:comment 'Indicates whether this OTT platform\'s content or channels are eligible for carriage by MVPD or vMVPD partners (cable, satellite, virtual pay-TV operators). True = eligible for carriage agreements; False = direct-to-consumer only. Governs retransmission consent and must-carry negotiations. | Column mvpd_carriage_eligible (BOOLEAN) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentBrand rdf:type rdf:Property ;
    rdfs:label 'Parent Brand' ;
    rdfs:comment 'The overarching corporate or media brand under which this OTT platform operates (e.g., \'Media Broadcasting Group\', \'MB Sports Network\'). Supports brand hierarchy reporting, consolidated audience measurement, and multi-brand advertising sales in Salesforce Media Cloud. | Column parent_brand (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformCode rdf:type rdf:Property ;
    rdfs:label 'Platform Code' ;
    rdfs:comment 'Externally-known, human-readable unique code assigned to the OTT platform (e.g., \'MB_SVOD_WEB\', \'MB_AVOD_CTV\'). Used in operational systems, contracts, and partner integrations as the canonical platform identifier. Maps to the platform identifier used in Zuora subscription plans and Akamai CDN configuration. | Column platform_code (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformDescription rdf:type rdf:Property ;
    rdfs:label 'Platform Description' ;
    rdfs:comment 'Detailed narrative description of the platform\'s content offering, target audience, and service proposition. Used in partner onboarding documentation, regulatory filings, and internal product catalogues. | Column platform_description (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformName rdf:type rdf:Property ;
    rdfs:label 'Platform Name' ;
    rdfs:comment 'Official commercial brand name of the OTT platform as presented to subscribers and partners (e.g., \'MediaBroadcast+\', \'MB Sports Live\'). Used in marketing materials, EPG listings, and subscriber-facing interfaces. | Column platform_name (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformStatus rdf:type rdf:Property ;
    rdfs:label 'Platform Status' ;
    rdfs:comment 'Current lifecycle state of the OTT platform. \'active\' = live and serving audiences; \'beta\' = limited release for testing; \'sunset\' = scheduled for decommission; \'suspended\' = temporarily offline; \'inactive\' = decommissioned. Governs whether the platform is eligible for new subscriber acquisition, ad campaign targeting, and CDN resource allocation. | Column platform_status (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryStreamingProtocol rdf:type rdf:Property ;
    rdfs:label 'Primary Streaming Protocol' ;
    rdfs:comment 'The primary adaptive bitrate streaming protocol used for content delivery on this platform. HLS = HTTP Live Streaming (Apple standard, widely supported); MPEG-DASH = Dynamic Adaptive Streaming over HTTP (ISO 23009 standard); RTMP = Real-Time Messaging Protocol (legacy live); SRT = Secure Reliable Transport (low-latency live). Drives CDN configuration in Akamai and player SDK selection. | Column primary_streaming_protocol (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticEnabled rdf:type rdf:Property ;
    rdfs:label 'Programmatic Enabled' ;
    rdfs:comment 'Flag indicating programmatic advertising support' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceTier rdf:type rdf:Property ;
    rdfs:label 'Service Tier' ;
    rdfs:comment 'Business model classification of the OTT platform. SVOD = Subscription Video On Demand (recurring fee, no ads); AVOD = Advertising-Supported Video On Demand (free with ads); TVOD = Transactional Video On Demand (pay-per-view); FAST = Free Ad-Supported Streaming Television (linear-style free channel); HYBRID = combination of tiers. Drives revenue recognition logic in Zuora and ad inventory management in Wide Orbit. | Column service_tier (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaUptimeTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Target Pct' ;
    rdfs:comment 'The contractually committed platform availability target expressed as a percentage (e.g., 99.95). Governs CDN SLA enforcement with Akamai, incident escalation thresholds, and operational reporting. Distinct from actual measured uptime. | Column sla_uptime_target_pct (DECIMAL(5,2)) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriberCount rdf:type rdf:Property ;
    rdfs:label 'Subscriber Count' ;
    rdfs:comment 'Current count of active paying or registered subscribers on this platform as of the last reconciliation cycle. A key operational metric for ARPU calculation, churn rate monitoring, and Zuora revenue reporting. Confidential as it represents commercially sensitive business performance data. | Column subscriber_count (BIGINT) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sunsetDate rdf:type rdf:Property ;
    rdfs:label 'Sunset Date' ;
    rdfs:comment 'Planned or actual date on which the OTT platform will be or was decommissioned. Null if the platform has no scheduled end-of-life. Used for subscriber migration planning, contract wind-down, and CDN resource deallocation. | Column sunset_date (DATE) in distribution.ott_platform' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportedDeviceClasses rdf:type rdf:Property ;
    rdfs:label 'Supported Device Classes' ;
    rdfs:comment 'Comma-separated list of device categories supported by this platform (e.g., \'web,mobile,ctv,stb,gaming_console\'). Drives device compatibility testing, app store distribution, and audience reach reporting. [ENUM-REF-CANDIDATE: web|mobile|ctv|stb|gaming_console|smart_tv|tablet — promote to reference product] | Column supported_device_classes (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStartBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Target Start Bitrate Kbps' ;
    rdfs:comment 'The minimum target bitrate in kilobits per second at which the ABR player should initiate playback on this platform. Drives ABR profile ladder configuration in Akamai CDN and QoS monitoring thresholds. Key parameter for streaming quality benchmarking. | Column target_start_bitrate_kbps (INT) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zuoraProductCode rdf:type rdf:Property ;
    rdfs:label 'Zuora Product Code' ;
    rdfs:comment 'The product identifier in Zuora\'s subscription billing platform corresponding to this OTT platform\'s subscription offering. Used for revenue recognition, invoice generation, and subscription lifecycle management. Links the platform master record to Zuora\'s billing product catalogue. | Column zuora_product_code (STRING) in distribution.ott_platform' ;
    rdfs:domain ind:OttPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamingEndpointId rdf:type rdf:Property ;
    rdfs:label 'Streaming Endpoint Id' ;
    rdfs:comment 'Unique identifier for the streaming endpoint. Primary key for the streaming endpoint master record. | Column streaming_endpoint_id (BIGINT) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StreamingEndpoint .

ind:failoverStreamingEndpointId rdf:type rdf:Property ;
    rdfs:label 'Failover Streaming Endpoint Id' ;
    rdfs:comment 'Reference to the backup streaming endpoint that should be used if this endpoint becomes unavailable. Supports high availability and disaster recovery. | Column failover_endpoint_id (BIGINT) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StreamingEndpoint .

ind:originStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Origin Storage Location Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.storage_location. Business justification: CDN origin routing configuration requires knowing which storage location backs each streaming endpoint. \'CDN origin pull configuration\' is a named infrastructure process; cdn_origin_url is a denormali' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:activatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activated Timestamp' ;
    rdfs:comment 'The date and time when this endpoint was first activated and began serving live traffic. | Column activated_timestamp (TIMESTAMP) in distribution.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bandwidthLimitGbps rdf:type rdf:Property ;
    rdfs:label 'Bandwidth Limit Gbps' ;
    rdfs:comment 'Maximum aggregate bandwidth capacity in gigabits per second allocated to this endpoint. Used for capacity planning and cost management. | Column bandwidth_limit_gbps (DECIMAL(10,2)) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cacheTtlSeconds rdf:type rdf:Property ;
    rdfs:label 'Cache Ttl Seconds' ;
    rdfs:comment 'The duration in seconds that content should be cached at edge locations before refreshing from origin. Balances freshness with CDN efficiency. | Column cache_ttl_seconds (INT) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPerGb rdf:type rdf:Property ;
    rdfs:label 'Cost Per Gb' ;
    rdfs:comment 'The CDN provider\'s charge per gigabyte of data transferred through this endpoint. Used for cost allocation and financial forecasting. | Column cost_per_gb (DECIMAL(10,4)) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deactivatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivated Timestamp' ;
    rdfs:comment 'The date and time when this endpoint was deactivated or taken out of service. Null if currently active. | Column deactivated_timestamp (TIMESTAMP) in distribution.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:drmLicenseServerUrl rdf:type rdf:Property ;
    rdfs:label 'Drm License Server Url' ;
    rdfs:comment 'URL of the DRM license server that provides decryption keys and enforces content protection policies for this endpoint. Critical for securing premium content. | Column drm_license_server_url (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointName rdf:type rdf:Property ;
    rdfs:label 'Endpoint Name' ;
    rdfs:comment 'Human-readable name or label for the streaming endpoint, used for identification and operational reference. | Column endpoint_name (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointType rdf:type rdf:Property ;
    rdfs:label 'Endpoint Type' ;
    rdfs:comment 'Classification of the endpoint role within the CDN architecture. Origin endpoints serve as the source, edge endpoints serve end users, and backup endpoints provide failover capability. | Column endpoint_type (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointUrl rdf:type rdf:Property ;
    rdfs:label 'Endpoint Url' ;
    rdfs:comment 'The full URL address of the streaming endpoint, including protocol, domain, and path. This is the technical delivery address for the stream. | Column endpoint_url (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRestrictionMode rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Mode' ;
    rdfs:comment 'Defines whether geo_restriction_rules represent an allow list (whitelist) or deny list (blacklist) for content delivery. | Column geo_restriction_mode (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRestrictionRules rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Rules' ;
    rdfs:comment 'Comma-separated list of ISO country codes or regions where content delivery is allowed or blocked. Enforces territorial licensing and rights management requirements. | Column geo_restriction_rules (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthCheckIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Health Check Interval Seconds' ;
    rdfs:comment 'Frequency in seconds at which automated health checks are performed against this endpoint. | Column health_check_interval_seconds (INT) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:healthCheckUrl rdf:type rdf:Property ;
    rdfs:label 'Health Check Url' ;
    rdfs:comment 'URL endpoint used for automated health monitoring and availability checks. Returns status codes indicating endpoint health. | Column health_check_url (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipv6Enabled rdf:type rdf:Property ;
    rdfs:label 'Ipv6 Enabled' ;
    rdfs:comment 'Indicates whether this endpoint supports IPv6 addressing in addition to IPv4, enabling delivery to modern network infrastructures. | Column ipv6_enabled (BOOLEAN) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastHealthCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Health Check Timestamp' ;
    rdfs:comment 'The date and time of the most recent successful health check performed on this endpoint. | Column last_health_check_timestamp (TIMESTAMP) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manifestFormat rdf:type rdf:Property ;
    rdfs:label 'Manifest Format' ;
    rdfs:comment 'The streaming manifest file format used by this endpoint. m3u8 for HLS, mpd for MPEG-DASH, ism for Smooth Streaming, f4m for Adobe HDS. | Column manifest_format (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxBitrateMbps rdf:type rdf:Property ;
    rdfs:label 'Max Bitrate Mbps' ;
    rdfs:comment 'The maximum streaming bitrate in megabits per second that this endpoint can deliver. Defines the upper quality limit for adaptive streaming. | Column max_bitrate_mbps (DECIMAL(10,2)) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the streaming endpoint. Active endpoints are serving traffic; inactive endpoints are provisioned but not in use; maintenance indicates scheduled downtime. | Column operational_status (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionedDate rdf:type rdf:Property ;
    rdfs:label 'Provisioned Date' ;
    rdfs:comment 'The date when this streaming endpoint was initially provisioned and configured in the CDN infrastructure. | Column provisioned_date (DATE) in distribution.streaming_endpoint' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaUptimeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Target Percent' ;
    rdfs:comment 'The contractual uptime percentage target for this endpoint (e.g., 99.99%). Used for SLA compliance monitoring and vendor accountability. | Column sla_uptime_target_percent (DECIMAL(5,2)) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sslCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Ssl Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the SSL/TLS certificate securing this endpoint. Critical for maintaining secure HTTPS delivery and avoiding service disruptions. | Column ssl_certificate_expiry_date (DATE) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:streamingProtocol rdf:type rdf:Property ;
    rdfs:label 'Streaming Protocol' ;
    rdfs:comment 'The streaming protocol used by this endpoint for content delivery. HLS (HTTP Live Streaming) and MPEG-DASH (Dynamic Adaptive Streaming over HTTP) are the most common adaptive bitrate protocols. | Column streaming_protocol (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedDevices rdf:type rdf:Property ;
    rdfs:label 'Supported Devices' ;
    rdfs:comment 'Comma-separated list of device types or platforms that this endpoint is optimized to serve (e.g., iOS, Android, Smart TV, Web Browser, Set-Top Box). | Column supported_devices (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenAuthenticationScheme rdf:type rdf:Property ;
    rdfs:label 'Token Authentication Scheme' ;
    rdfs:comment 'The authentication mechanism used to secure access to the endpoint. Prevents unauthorized access and hotlinking through cryptographic token validation. | Column token_authentication_scheme (STRING) in distribution.streaming_endpoint' ;
    rdfs:domain ind:StreamingEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playbackSessionId rdf:type rdf:Property ;
    rdfs:label 'Playback Session Id' ;
    rdfs:comment 'Unique identifier for each individual viewer playback session initiated on the OTT (Over-The-Top) platform. Primary key for the playback session record. | Column playback_session_id (BIGINT) in distribution.playback_session' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlaybackSession .

ind:subscriberId rdf:type rdf:Property ;
    rdfs:label 'Subscriber Id' ;
    rdfs:comment 'Reference to the subscriber who initiated this playback session. Links to the subscriber master record for audience measurement and personalization. | Column subscriber_id (BIGINT) in subscriber.playback_session' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:adBreaksServedCount rdf:type rdf:Property ;
    rdfs:label 'Ad Breaks Served Count' ;
    rdfs:comment 'Number of ad breaks (ad pods) served during this playback session. Used for advertising inventory management and revenue reconciliation. | Column ad_breaks_served_count (INT) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioLanguage rdf:type rdf:Property ;
    rdfs:label 'Audio Language' ;
    rdfs:comment 'ISO 639 language code for the audio track selected by the viewer. Supports multi-language content analytics and localization strategy. | Column audio_language (STRING) in distribution.playback_session' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageBitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Average Bitrate Kbps' ;
    rdfs:comment 'Average streaming bitrate in kilobits per second during the session. Indicates video quality delivered and network performance. | Column average_bitrate_kbps (INT) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdnPopLocation rdf:type rdf:Property ;
    rdfs:label 'Cdn Pop Location' ;
    rdfs:comment 'Geographic location identifier of the CDN point of presence that served this session. Critical for CDN performance optimization and SLA monitoring. | Column cdn_pop_location (STRING) in distribution.playback_session' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionsEnabled rdf:type rdf:Property ;
    rdfs:label 'Closed Captions Enabled' ;
    rdfs:comment 'Indicates whether closed captions were enabled during the session. Critical for accessibility compliance reporting and user preference analysis. | Column closed_captions_enabled (BOOLEAN) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of content watched relative to total content duration. Key engagement metric for content performance and recommendation algorithms. | Column completion_percentage (DECIMAL(5,2)) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Content Duration Seconds' ;
    rdfs:comment 'Total duration of the content asset in seconds. Used to calculate completion rate and identify partial vs. full viewing sessions. | Column content_duration_seconds (INT) in distribution.playback_session' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Technical error code if the session ended due to an error. Enables root cause analysis and platform stability monitoring. | Column error_code (STRING) in distribution.playback_session' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitReason rdf:type rdf:Property ;
    rdfs:label 'Exit Reason' ;
    rdfs:comment 'The reason the playback session ended. Critical for distinguishing intentional exits from technical failures and optimizing viewer experience. | Column exit_reason (STRING) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCity rdf:type rdf:Property ;
    rdfs:label 'Geographic City' ;
    rdfs:comment 'City where the viewer is located during playback. Enables hyper-local audience analytics and targeted advertising campaigns. | Column geographic_city (STRING) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicPostalCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Postal Code' ;
    rdfs:comment 'Postal code derived from viewer location. Used for demographic overlay and targeted advertising. Subject to privacy regulations. | Column geographic_postal_code (STRING) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialBufferingDurationMs rdf:type rdf:Property ;
    rdfs:label 'Initial Buffering Duration Ms' ;
    rdfs:comment 'Time in milliseconds from session start until playback began. Key QoS metric for measuring time-to-first-frame and viewer experience. | Column initial_buffering_duration_ms (INT) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playbackMode rdf:type rdf:Property ;
    rdfs:label 'Playback Mode' ;
    rdfs:comment 'The mode of content consumption: live linear broadcast, VOD (Video On Demand), DVR (time-shifted), or restart. Critical for audience measurement methodology and rights management. | Column playback_mode (STRING) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebufferingEventsCount rdf:type rdf:Property ;
    rdfs:label 'Rebuffering Events Count' ;
    rdfs:comment 'Number of rebuffering (stalling) events that occurred during the session. Critical QoS metric for viewer experience and churn prediction. | Column rebuffering_events_count (INT) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Created Timestamp' ;
    rdfs:comment 'Timestamp when this playback session record was created in the system. Used for data lineage and operational monitoring. | Column session_created_timestamp (TIMESTAMP) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session End Timestamp' ;
    rdfs:comment 'Precise timestamp when the playback session ended. Used to calculate total watch duration and session completion metrics. | Column session_end_timestamp (TIMESTAMP) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the viewer initiated the playback session. Critical for audience measurement, daypart analysis, and concurrent viewer calculations. | Column session_start_timestamp (TIMESTAMP) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Updated Timestamp' ;
    rdfs:comment 'Timestamp when this playback session record was last updated. Supports audit trail and data quality monitoring. | Column session_updated_timestamp (TIMESTAMP) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subtitleLanguage rdf:type rdf:Property ;
    rdfs:label 'Subtitle Language' ;
    rdfs:comment 'ISO 639 language code for subtitles displayed during the session. Null if no subtitles were enabled. Supports accessibility and localization analytics. | Column subtitle_language (STRING) in distribution.playback_session' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAdDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Ad Duration Seconds' ;
    rdfs:comment 'Cumulative duration of all advertisements served during the session. Essential for advertising billing and viewer experience analysis. | Column total_ad_duration_seconds (INT) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRebufferingDurationMs rdf:type rdf:Property ;
    rdfs:label 'Total Rebuffering Duration Ms' ;
    rdfs:comment 'Cumulative time in milliseconds spent in rebuffering state during the session. Complements rebuffering count for comprehensive QoS analysis. | Column total_rebuffering_duration_ms (INT) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalWatchDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Watch Duration Seconds' ;
    rdfs:comment 'Total time in seconds the viewer actively watched content during this session. Primary metric for audience measurement and content engagement analysis. | Column total_watch_duration_seconds (INT) in distribution.playback_session' ;
    rdfs:domain ind:PlaybackSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:viewerIpAddress rdf:type rdf:Property ;
    rdfs:label 'Viewer Ip Address' ;
    rdfs:comment 'IP address of the viewer during the playback session. Used for geographic analysis, fraud detection, and blackout enforcement. Subject to GDPR and CCPA privacy regulations. | Column viewer_ip_address (STRING) in distribution.playback_session' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_account. Business justification: Distribution partners (MVPDs, OTT aggregators, cable operators) are commercial entities managed as sales accounts for billing, contract management, and revenue tracking. A broadcast distribution exper' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:abrProfileSupport rdf:type rdf:Property ;
    rdfs:label 'Abr Profile Support' ;
    rdfs:comment 'Description of Adaptive Bitrate streaming profiles and quality tiers supported by the distribution partner for OTT and streaming delivery. Includes resolution ranges, bitrate ladders, and codec support. | Column abr_profile_support (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Blackout Capability Flag' ;
    rdfs:comment 'Indicates whether the distribution partner has technical capability to enforce geographic broadcast restrictions and content blackouts based on licensing and rights windows. | Column blackout_capability_flag (BOOLEAN) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageCapacityChannels rdf:type rdf:Property ;
    rdfs:label 'Carriage Capacity Channels' ;
    rdfs:comment 'Number of linear channels or content streams that the distribution partner has capacity to carry simultaneously. Relevant for MVPD, vMVPD, and cable operators. | Column carriage_capacity_channels (INT) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carriageFeeModel rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Model' ;
    rdfs:comment 'Commercial model for carriage fees paid by or to the distribution partner. Per Subscriber indicates fees based on subscriber count, Flat Rate indicates fixed periodic payment, Revenue Share indicates percentage of advertising or subscription revenue, Hybrid indicates combination of models. | Column carriage_fee_model (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Date when the current distribution agreement with the partner expires or is scheduled for renewal. Null indicates open-ended or evergreen agreement. | Column contract_end_date (DATE) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractRenewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Notice Days' ;
    rdfs:comment 'Number of days advance notice required for contract renewal or termination as specified in the distribution agreement. | Column contract_renewal_notice_days (INT) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Date when the current distribution agreement with the partner became effective. | Column contract_start_date (DATE) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daiSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Dai Support Flag' ;
    rdfs:comment 'Indicates whether the distribution partner supports Dynamic Ad Insertion technology for server-side ad stitching in streaming content. | Column dai_support_flag (BOOLEAN) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmCapability rdf:type rdf:Property ;
    rdfs:label 'Drm Capability' ;
    rdfs:comment 'Digital Rights Management systems and encryption standards supported by the distribution partner. May include Widevine, FairPlay, PlayReady, and other DRM technologies. | Column drm_capability (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicFootprint rdf:type rdf:Property ;
    rdfs:label 'Geographic Footprint' ;
    rdfs:comment 'Description of the geographic markets, regions, or territories served by this distribution partner. May include country codes, DMA (Designated Market Area) codes, or regional descriptors. | Column geographic_footprint (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Physical address of the distribution partner\'s corporate headquarters or primary business location. | Column headquarters_address (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the distribution partner\'s headquarters is located. | Column headquarters_city (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the country where the distribution partner\'s headquarters is located. | Column headquarters_country_code (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the distribution partner\'s headquarters location. | Column headquarters_postal_code (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State, province, or administrative region where the distribution partner\'s headquarters is located. | Column headquarters_state_province (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mustCarryObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Must Carry Obligation Flag' ;
    rdfs:comment 'Indicates whether the distribution partner has a must-carry obligation requiring mandatory inclusion of certain broadcast channels under FCC regulations. | Column must_carry_obligation_flag (BOOLEAN) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the distribution partner based on delivery model. MVPD (Multichannel Video Programming Distributor) includes traditional cable, satellite, and telco providers. vMVPD (Virtual MVPD) includes internet-based multichannel services. OTT Platform includes direct-to-consumer streaming services. FAST Aggregator includes Free Ad-Supported Streaming Television channel aggregators. Syndication Outlet includes broadcast stations and regional networks. | Column partner_type (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Standard payment terms in days for invoices related to carriage fees, revenue share, or other financial transactions with the distribution partner. | Column payment_terms_days (INT) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portalUrl rdf:type rdf:Property ;
    rdfs:label 'Portal Url' ;
    rdfs:comment 'Web URL for the distribution partner\'s business portal, technical documentation, or partner management system. | Column portal_url (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for financial transactions and reporting with this distribution partner. | Column preferred_currency_code (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary business contact for distribution operations, technical coordination, and business communications. | Column primary_contact_email (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact at the distribution partner organization for operational coordination and escalation. | Column primary_contact_name (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary telephone number for reaching the distribution partner contact for urgent operational matters and coordination. | Column primary_contact_phone (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosMonitoringEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Qos Monitoring Enabled Flag' ;
    rdfs:comment 'Indicates whether active Quality of Service monitoring and reporting is enabled for content delivery through this distribution partner. | Column qos_monitoring_enabled_flag (BOOLEAN) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current state of the commercial relationship and content distribution agreement with the partner. | Column relationship_status (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Status' ;
    rdfs:comment 'Status of retransmission consent authorization allowing the distribution partner to rebroadcast content. Relevant for MVPD and cable operators under FCC regulations. | Column retransmission_consent_status (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaLatencyTargetMs rdf:type rdf:Property ;
    rdfs:label 'Sla Latency Target Ms' ;
    rdfs:comment 'Maximum acceptable latency in milliseconds for content delivery as defined in the distribution Service Level Agreement. Critical for live streaming and low-latency applications. | Column sla_latency_target_ms (INT) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriberReachEstimate rdf:type rdf:Property ;
    rdfs:label 'Subscriber Reach Estimate' ;
    rdfs:comment 'Estimated number of subscribers, households, or unique users that can access content through this distribution partner. Used for reach analysis and revenue forecasting. | Column subscriber_reach_estimate (BIGINT) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalDeliveryStandards rdf:type rdf:Property ;
    rdfs:label 'Technical Delivery Standards' ;
    rdfs:comment 'Comma-separated list of technical broadcast and streaming standards supported by the partner. May include DVB (Digital Video Broadcasting), ATSC (Advanced Television Systems Committee), QAM (Quadrature Amplitude Modulation), HLS (HTTP Live Streaming), MPEG-DASH (Dynamic Adaptive Streaming over HTTP), and other delivery protocols. | Column technical_delivery_standards (STRING) in distribution.distribution_partner' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique identifier or contract number for this carriage agreement, used in business communications and legal references. | Column agreement_number (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the carriage agreement: draft (being prepared), active (in force), suspended (temporarily paused), expired (term ended), terminated (cancelled before expiry), or under negotiation (renewal or amendment in progress). | Column agreement_status (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the carriage agreement: retransmission consent (FCC-regulated authorization for MVPDs to rebroadcast OTA signals), must-carry (mandatory carriage under FCC rules), voluntary carriage (negotiated carriage without must-carry obligation), or platform carriage (OTT/vMVPD distribution agreement). | Column agreement_type (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the agreement automatically renews at the end of the term unless either party provides termination notice. | Column auto_renewal_flag (BOOLEAN) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutProvisions rdf:type rdf:Property ;
    rdfs:label 'Blackout Provisions' ;
    rdfs:comment 'Geographic or temporal restrictions on content availability, such as sports blackout rules, local market exclusions, or event-specific restrictions required by rights holders or league rules. | Column blackout_provisions (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Amount' ;
    rdfs:comment 'Monetary compensation paid by the distribution partner to the content provider for the right to carry the channel or content package. May be per-subscriber, flat fee, or tiered based on subscriber count. | Column carriage_fee_amount (DECIMAL(15,2)) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carriageFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the carriage fee amount (e.g., USD, GBP, EUR). | Column carriage_fee_currency (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carriageFeeStructure rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Structure' ;
    rdfs:comment 'Pricing model for the carriage fee: per-subscriber (fee per active subscriber), flat monthly (fixed monthly payment), tiered (rate varies by subscriber volume), revenue share (percentage of ad or subscription revenue), or barter (non-cash compensation such as promotional commitments or channel positioning). | Column carriage_fee_structure (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelNumberAssignment rdf:type rdf:Property ;
    rdfs:label 'Channel Number Assignment' ;
    rdfs:comment 'The channel number or dial position assigned to the channel on the distribution platform. May vary by market or headend. | Column channel_number_assignment (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelPositioningTier rdf:type rdf:Property ;
    rdfs:label 'Channel Positioning Tier' ;
    rdfs:comment 'The service tier or package in which the channel is positioned (e.g., basic, expanded basic, premium, sports tier). Affects channel visibility and subscriber reach. | Column channel_positioning_tier (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationTerms rdf:type rdf:Property ;
    rdfs:label 'Compensation Terms' ;
    rdfs:comment 'Detailed description of all compensation provided under the agreement, including cash payments, barter arrangements (e.g., promotional commitments, ad inventory exchange), channel carriage reciprocity, or other non-monetary considerations. | Column compensation_terms (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Agreed method for resolving disputes arising under the agreement: arbitration (binding third-party decision), mediation (facilitated negotiation), litigation (court proceedings), or negotiation (direct party-to-party resolution). | Column dispute_resolution_mechanism (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmRequirements rdf:type rdf:Property ;
    rdfs:label 'Drm Requirements' ;
    rdfs:comment 'DRM and content protection requirements mandated under the agreement, such as encryption standards, conditional access systems, watermarking, and anti-piracy measures. | Column drm_requirements (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityWindow rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Window' ;
    rdfs:comment 'Period during which the distribution partner has exclusive carriage rights within a defined geographic territory or platform category (e.g., exclusive MVPD rights in a DMA, exclusive vMVPD rights nationally). | Column exclusivity_window (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Geographic scope of the carriage agreement, typically expressed as authorized DMAs (Designated Market Areas), states, regions, or national coverage. Defines where the distribution partner is authorized to carry the content. | Column geographic_coverage (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction and governing law applicable to the agreement (e.g., State of New York, England and Wales). Determines which courts and laws apply in case of dispute. | Column governing_law_jurisdiction (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackRestrictions rdf:type rdf:Property ;
    rdfs:label 'Holdback Restrictions' ;
    rdfs:comment 'Restrictions on when or where content may be made available on other platforms or windows. Protects the distribution partners investment by limiting competing distribution during the agreement term. | Column holdback_restrictions (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or modification to the carriage agreement. | Column last_amendment_date (DATE) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumSubscriberGuarantee rdf:type rdf:Property ;
    rdfs:label 'Minimum Subscriber Guarantee' ;
    rdfs:comment 'Minimum number of subscribers the distribution partner guarantees to deliver for the channel. Used in per-subscriber fee calculations and performance commitments. | Column minimum_subscriber_guarantee (INT) in distribution.carriage_agreement' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mustCarryElection rdf:type rdf:Property ;
    rdfs:label 'Must Carry Election' ;
    rdfs:comment 'Indicates whether the broadcaster has elected must-carry status under FCC rules, requiring the MVPD to carry the signal without negotiation. Applicable to qualified broadcast stations. | Column must_carry_election (BOOLEAN) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiationHistory rdf:type rdf:Property ;
    rdfs:label 'Negotiation History' ;
    rdfs:comment 'Summary of key negotiation milestones, amendments, and material changes to the agreement over its lifecycle. Provides context for current terms and future renegotiations. | Column negotiation_history (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalCommitment rdf:type rdf:Property ;
    rdfs:label 'Promotional Commitment' ;
    rdfs:comment 'Marketing and promotional obligations agreed by either party, such as on-air promotion, co-marketing campaigns, EPG placement guarantees, or cross-platform promotion. | Column promotional_commitment (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Conditions and terms governing agreement renewal, including renewal period length, rate adjustments, renegotiation triggers, and notice requirements. | Column renewal_terms (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retransmissionConsentGranted rdf:type rdf:Property ;
    rdfs:label 'Retransmission Consent Granted' ;
    rdfs:comment 'Indicates whether retransmission consent has been granted under FCC regulations, authorizing the MVPD to rebroadcast over-the-air signals. Applicable only to retransmission consent agreement types. | Column retransmission_consent_granted (BOOLEAN) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'Performance commitments and service quality standards, including uptime guarantees, signal quality metrics, fault resolution times, and penalties for non-compliance. | Column service_level_agreement (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:CarriageAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalDeliveryRequirements rdf:type rdf:Property ;
    rdfs:label 'Technical Delivery Requirements' ;
    rdfs:comment 'Technical specifications for content delivery, including signal format (HD, 4K, HDR), encoding standards (MPEG-2, MPEG-4, HEVC), delivery method (satellite, fiber, IP), and quality parameters (bitrate, resolution, audio channels). | Column technical_delivery_requirements (STRING) in distribution.carriage_agreement' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the agreement. Protects both parties from abrupt service disruption. | Column termination_notice_days (INT) in distribution.carriage_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adInsertionMethod rdf:type rdf:Property ;
    rdfs:label 'Ad Insertion Method' ;
    rdfs:comment 'Technical method used for inserting advertisements into the content stream: server-side stitching, client-side insertion, DAI (Dynamic Ad Insertion), SCTE-35 marker-based, or none for ad-free channels. | Column ad_insertion_method (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutRulesEnabled rdf:type rdf:Property ;
    rdfs:label 'Blackout Rules Enabled' ;
    rdfs:comment 'Indicates whether geographic or rights-based blackout restrictions are enforced for this channel (true) or not (false). | Column blackout_rules_enabled (BOOLEAN) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentRefreshCadence rdf:type rdf:Property ;
    rdfs:label 'Content Refresh Cadence' ;
    rdfs:comment 'Frequency at which the channel programming lineup or content library is updated with new material. | Column content_refresh_cadence (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTechnology rdf:type rdf:Property ;
    rdfs:label 'Delivery Technology' ;
    rdfs:comment 'The technical transmission standard used for content delivery. DVB (Digital Video Broadcasting) variants for European broadcast, ATSC (Advanced Television Systems Committee) for North American broadcast, QAM (Quadrature Amplitude Modulation) for cable, HLS (HTTP Live Streaming) and MPEG-DASH for adaptive bitrate streaming. [ENUM-REF-CANDIDATE: dvb-t|dvb-s|dvb-c|atsc|qam|hls|mpeg-dash|smooth-streaming|rtmp|webrtc — 10 candidates stripped; promote to reference product] | Column delivery_technology (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastAggregatorPlatform rdf:type rdf:Property ;
    rdfs:label 'Fast Aggregator Platform' ;
    rdfs:comment 'Name of the FAST platform aggregator hosting the channel (e.g., \'Pluto TV\', \'Tubi\', \'Samsung TV Plus\', \'Roku Channel\', \'Xumo\'). Applicable only to FAST channel types. | Column fast_aggregator_platform (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastPlaylistType rdf:type rdf:Property ;
    rdfs:label 'Fast Playlist Type' ;
    rdfs:comment 'Content scheduling model for FAST channels: linear-loop (repeating content block), scheduled (traditional time-based EPG), dynamic (algorithm-driven), or hybrid. Applicable only to FAST channel types. | Column fast_playlist_type (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genreCategory rdf:type rdf:Property ;
    rdfs:label 'Genre Category' ;
    rdfs:comment 'Primary content genre or programming category of the channel. [ENUM-REF-CANDIDATE: news|sports|entertainment|kids|lifestyle|documentary|music|movies|drama|comedy — 10 candidates stripped; promote to reference product] | Column genre_category (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monetizationModel rdf:type rdf:Property ;
    rdfs:label 'Monetization Model' ;
    rdfs:comment 'Revenue model for the channel: AVOD (Advertising-Supported Video On Demand), SVOD (Subscription Video On Demand), TVOD (Transactional Video On Demand), hybrid (multiple models), or free (no monetization). | Column monetization_model (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentalControlRating rdf:type rdf:Property ;
    rdfs:label 'Parental Control Rating' ;
    rdfs:comment 'TV Parental Guidelines rating assigned to the channel for content filtering and parental control systems. | Column parental_control_rating (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosTier rdf:type rdf:Property ;
    rdfs:label 'Qos Tier' ;
    rdfs:comment 'Service level tier defining performance guarantees, uptime SLA, and priority for this channel (premium, standard, basic). | Column qos_tier (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionFormat rdf:type rdf:Property ;
    rdfs:label 'Resolution Format' ;
    rdfs:comment 'Video resolution tier supported by the channel: SD (standard definition 480p), HD (720p), Full HD (1080p), 4K UHD (2160p), 8K UHD (4320p). | Column resolution_format (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date when the channel ceased operations or was decommissioned. Null for active channels. | Column retirement_date (DATE) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaUptimePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percent' ;
    rdfs:comment 'Contractual uptime guarantee for the channel expressed as a percentage (e.g., 99.95 for \'four nines\' availability). | Column sla_uptime_percent (DECIMAL(5,2)) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarket rdf:type rdf:Property ;
    rdfs:label 'Target Market' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the primary geographic market for the channel (e.g., \'USA\', \'GBR\', \'CAN\'). | Column target_market (STRING) in distribution.delivery_channel' ;
    rdfs:domain ind:DeliveryChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryEventId rdf:type rdf:Property ;
    rdfs:label 'Delivery Event Id' ;
    rdfs:comment 'Unique identifier for the delivery event record. Primary key. | Column delivery_event_id (BIGINT) in distribution.delivery_event' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Ad Order Line Id' ;
    rdfs:comment 'Foreign key linking to sales.ad_order_line. Business justification: Delivery events record actual technical delivery of ad content. Linking to ad_order_line enables post-campaign delivery verification, affidavit generation, and billing reconciliation at the line level' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdOrderLine .

ind:adSpotId rdf:type rdf:Property ;
    rdfs:label 'Ad Spot Id' ;
    rdfs:comment 'Foreign key linking to sales.ad_spot. Business justification: A delivery event records the technical delivery of a specific ad spot. Linking delivery_event to ad_spot enables spot-level proof-of-performance, affidavit filing, and makegood adjudication — fundamen' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdSpot .

ind:adFillRatePercent rdf:type rdf:Property ;
    rdfs:label 'Ad Fill Rate Percent' ;
    rdfs:comment 'Percentage of available ad inventory that was successfully filled during this DAI event (0.00 to 100.00). | Column ad_fill_rate_percent (DECIMAL(5,2)) in distribution.delivery_event' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adPodPosition rdf:type rdf:Property ;
    rdfs:label 'Ad Pod Position' ;
    rdfs:comment 'Position of the ad pod within the content stream for DAI events (e.g., pre-roll=1, mid-roll=2, post-roll=3). | Column ad_pod_position (INT) in distribution.delivery_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Bitrate Kbps' ;
    rdfs:comment 'Stream bitrate in kilobits per second at the time of this delivery event. | Column bitrate_kbps (INT) in distribution.delivery_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bytesDelivered rdf:type rdf:Property ;
    rdfs:label 'Bytes Delivered' ;
    rdfs:comment 'Total number of bytes delivered to the viewer during this event. | Column bytes_delivered (BIGINT) in distribution.delivery_event' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdnCacheStatus rdf:type rdf:Property ;
    rdfs:label 'Cdn Cache Status' ;
    rdfs:comment 'CDN cache status for this delivery (hit, miss, stale, bypass). | Column cdn_cache_status (STRING) in distribution.delivery_event' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnNodeCode rdf:type rdf:Property ;
    rdfs:label 'Cdn Node Code' ;
    rdfs:comment 'Identifier of the CDN edge node that served the content for this delivery event. | Column cdn_node_code (STRING) in distribution.delivery_event' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Human-readable error message describing the delivery failure or issue. | Column error_message (STRING) in distribution.delivery_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Precise timestamp when the delivery event occurred (stream start, broadcast transmission, VOD delivery initiation). | Column event_timestamp (TIMESTAMP) in distribution.delivery_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:geographicCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the delivery occurred (e.g., USA, GBR, CAN). | Column geographic_country_code (STRING) in distribution.delivery_event' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region where the content was delivered (e.g., North America, EMEA, APAC, or specific country/state codes). | Column geographic_region (STRING) in distribution.delivery_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Network Latency Ms' ;
    rdfs:comment 'Network latency measured in milliseconds between CDN edge and viewer device. | Column network_latency_ms (INT) in distribution.delivery_event' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originServerResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Origin Server Response Time Ms' ;
    rdfs:comment 'Response time from origin server in milliseconds for cache-miss scenarios. | Column origin_server_response_time_ms (INT) in distribution.delivery_event' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scte35SignalType rdf:type rdf:Property ;
    rdfs:label 'Scte35 Signal Type' ;
    rdfs:comment 'Type of SCTE-35 signal that triggered the DAI event (e.g., splice_insert, time_signal). | Column scte35_signal_type (STRING) in distribution.delivery_event' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Session Duration Seconds' ;
    rdfs:comment 'Total duration of the delivery session in seconds for streaming events. | Column session_duration_seconds (INT) in distribution.delivery_event' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'SLA tier classification applicable to this delivery event (e.g., premium, standard, basic). | Column sla_tier (STRING) in distribution.delivery_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'User agent string from the viewer device identifying browser/app and operating system. | Column user_agent (STRING) in distribution.delivery_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticDealId rdf:type rdf:Property ;
    rdfs:label 'Programmatic Deal Id' ;
    rdfs:comment 'External programmatic deal ID for OpenRTB' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deal .

ind:contentScope rdf:type rdf:Property ;
    rdfs:label 'Content Scope' ;
    rdfs:comment 'Description of the content assets included in this deal. May reference specific titles, series, libraries, or content categories covered by the agreement. | Column content_scope (STRING) in distribution.deal' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealNumber rdf:type rdf:Property ;
    rdfs:label 'Deal Number' ;
    rdfs:comment 'Externally-known unique business identifier for the distribution deal, used in contracts and communications. | Column deal_number (STRING) in distribution.deal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealStatus rdf:type rdf:Property ;
    rdfs:label 'Deal Status' ;
    rdfs:comment 'Current lifecycle status of the distribution deal. Tracks progression from initial draft through negotiation, approval, active operation, and eventual closure or renewal. [ENUM-REF-CANDIDATE: draft|negotiation|pending approval|active|suspended|expired|terminated|renewed — 8 candidates stripped; promote to reference product] | Column deal_status (STRING) in distribution.deal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityWindowDays rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Window Days' ;
    rdfs:comment 'Duration in days of the exclusivity period or holdback window during which content cannot be distributed through competing channels. | Column exclusivity_window_days (INT) in distribution.deal' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flatFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Fee Amount' ;
    rdfs:comment 'Fixed payment amount for flat fee deal structures. Represents total or periodic payment value. | Column flat_fee_amount (DECIMAL(15,2)) in distribution.deal' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floorPriceCpm rdf:type rdf:Property ;
    rdfs:label 'Floor Price Cpm' ;
    rdfs:comment 'Floor price in CPM for programmatic' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiationStartDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Start Date' ;
    rdfs:comment 'Date when commercial negotiations for this deal commenced. | Column negotiation_start_date (DATE) in distribution.deal' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programmaticDealType rdf:type rdf:Property ;
    rdfs:label 'Programmatic Deal Type' ;
    rdfs:comment 'Programmatic deal type (PMP, PG, open auction)' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days advance notice required to exercise or decline renewal option before expiration. | Column renewal_notice_days (INT) in distribution.deal' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency at which the distribution partner must provide performance and revenue reports. | Column reporting_frequency (STRING) in distribution.deal' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Model' ;
    rdfs:comment 'Commercial structure defining how revenue is generated and shared. Flat fee = fixed payment; revenue share = percentage of platform revenue; minimum guarantee = MG against future royalties; hybrid = combination of models; cost per stream = per-view payment; cost per subscriber = per-subscriber payment. | Column revenue_model (STRING) in distribution.deal' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percentage' ;
    rdfs:comment 'Percentage of revenue allocated to the content owner under revenue share agreements. Expressed as a percentage (e.g., 65.00 represents 65%). | Column revenue_share_percentage (DECIMAL(5,2)) in distribution.deal' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when the distribution deal contract was executed by all parties. | Column signed_date (DATE) in distribution.deal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termMonths rdf:type rdf:Property ;
    rdfs:label 'Term Months' ;
    rdfs:comment 'Duration of the deal term expressed in months. Calculated from effective date to expiration date. | Column term_months (INT) in distribution.deal' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territory rdf:type rdf:Property ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Geographic territory or territories covered by this distribution deal. May be a single country code, multiple countries, or regional designation (e.g., USA, CAN|MEX, EMEA). | Column territory (STRING) in distribution.deal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDeliveryOrderId rdf:type rdf:Property ;
    rdfs:label 'Content Delivery Order Id' ;
    rdfs:comment 'Unique identifier for the content delivery order. Primary key for this transactional record representing a formal order to deliver content assets to distribution partners or platforms. | Column content_delivery_order_id (BIGINT) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'Username or identifier of the user who approved this delivery order for fulfillment. Tracks authorization and approval workflow. | Column approved_by_user (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioConfiguration rdf:type rdf:Property ;
    rdfs:label 'Audio Configuration' ;
    rdfs:comment 'Audio channel configuration and format for the delivered content. Defines the immersive audio capabilities and speaker layout. | Column audio_configuration (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioLanguages rdf:type rdf:Property ;
    rdfs:label 'Audio Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639-2 language codes for audio tracks included in the delivery. Supports multi-language distribution requirements. | Column audio_languages (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionsIncluded rdf:type rdf:Property ;
    rdfs:label 'Closed Captions Included' ;
    rdfs:comment 'Indicates whether closed captions are included in the delivered content. Required for FCC compliance and accessibility standards. | Column closed_captions_included (BOOLEAN) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'Username or identifier of the user who created this delivery order. Provides accountability and audit trail for order origination. | Column created_by_user (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Deadline Timestamp' ;
    rdfs:comment 'Precise deadline timestamp for content delivery. Used for Service Level Agreement (SLA) compliance tracking and penalty calculations. | Column delivery_deadline_timestamp (TIMESTAMP) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes and special instructions for the delivery order. Captures partner-specific requirements, technical considerations, or operational alerts. | Column delivery_notes (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Duration Minutes' ;
    rdfs:comment 'Estimated time required to complete the content delivery, measured in minutes. Based on file size, bandwidth, and delivery method. | Column estimated_delivery_duration_minutes (INT) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Description of the reason for delivery failure if order status is failed. Used for root cause analysis and process improvement. | Column failure_reason (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeGb rdf:type rdf:Property ;
    rdfs:label 'File Size Gb' ;
    rdfs:comment 'Total file size of the content package being delivered, measured in gigabytes. Used for bandwidth planning and cost estimation. | Column file_size_gb (DECIMAL(12,3)) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Confirmation Number' ;
    rdfs:comment 'Unique confirmation identifier provided upon successful delivery completion. Used for proof of delivery and reconciliation with distribution partners. | Column fulfillment_confirmation_number (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestrictions rdf:type rdf:Property ;
    rdfs:label 'Geographic Restrictions' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where content delivery is restricted or permitted. Enforces territorial rights and blackout rules. | Column geographic_restrictions (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Timestamp when the delivery order was created or placed. Represents the principal business event time for this transaction. | Column order_date (TIMESTAMP) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally-known unique business identifier for this delivery order. Used for tracking, communication, and reconciliation with distribution partners. | Column order_number (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the delivery order. Tracks the order through its workflow from creation to fulfillment or cancellation. [ENUM-REF-CANDIDATE: draft|pending|approved|in_progress|delivered|failed|cancelled — 7 candidates stripped; promote to reference product] | Column order_status (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the delivery order type. Indicates the nature and urgency of the content delivery request. | Column order_type (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to this delivery order. Determines resource allocation and scheduling precedence in the delivery queue. | Column priority_level (STRING) in distribution.content_delivery_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Target date by which the content must be delivered to the distribution partner. Drives scheduling and prioritization of delivery tasks. | Column requested_delivery_date (DATE) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of delivery attempts made for this order. Tracks resilience and reliability of the delivery process. | Column retry_count (INT) in distribution.content_delivery_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transcodeProfileCode rdf:type rdf:Property ;
    rdfs:label 'Transcode Profile Code' ;
    rdfs:comment 'Reference to the transcode profile specifying encoding parameters, bitrates, resolutions, and quality settings for content preparation. | Column transcode_profile_code (BIGINT) in distribution.content_delivery_order' ;
    rdfs:domain ind:ContentDeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holderId rdf:type rdf:Property ;
    rdfs:label 'Holder Id' ;
    rdfs:comment 'Foreign key linking to rights.holder. Business justification: Asset-level rights holder identification: asset managers and legal teams need to immediately identify the rights holder for legal hold decisions, clearance escalation, and licensing negotiations witho' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.storage_location. Business justification: media_asset.storage_location_uri is a free-text field capturing where the master asset file resides. storage_location is the authoritative master reference for all physical and logical storage locatio' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'Classification of the asset based on its production workflow stage and quality level. Raw=unprocessed camera footage, Mezzanine=high-quality intermediate, Proxy=low-res preview, Archive=long-term preservation, Master=final approved version. | Column asset_class (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTitle rdf:type rdf:Property ;
    rdfs:label 'Asset Title' ;
    rdfs:comment 'Primary human-readable title or name of the media asset. Used for search, cataloging, and display in MAM interfaces. | Column asset_title (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Primary media type classification of the digital object. Determines handling, playback, and workflow routing in the MAM system. [ENUM-REF-CANDIDATE: video|audio|image|graphics|document|subtitle|caption — 7 candidates stripped; promote to reference product] | Column asset_type (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioBitDepth rdf:type rdf:Property ;
    rdfs:label 'Audio Bit Depth' ;
    rdfs:comment 'Audio bit depth in bits per sample (e.g., 16, 24). Higher bit depth provides greater dynamic range and lower quantization noise. | Column audio_bit_depth (INT) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioSampleRateKhz rdf:type rdf:Property ;
    rdfs:label 'Audio Sample Rate Khz' ;
    rdfs:comment 'Audio sampling frequency in kilohertz (e.g., 48.000 for broadcast, 44.100 for CD quality). Indicates audio quality and broadcast compliance. | Column audio_sample_rate_khz (DECIMAL(6,3)) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bitRateMbps rdf:type rdf:Property ;
    rdfs:label 'Bit Rate Mbps' ;
    rdfs:comment 'Average bit rate of the encoded media in megabits per second. Indicates quality level and bandwidth requirements for streaming and playout. | Column bit_rate_mbps (DECIMAL(10,3)) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checksumSha256 rdf:type rdf:Property ;
    rdfs:label 'Checksum Sha256' ;
    rdfs:comment 'SHA-256 cryptographic hash for enhanced integrity verification and chain-of-custody audit trails. Required for regulatory compliance and legal hold. | Column checksum_sha256 (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codec rdf:type rdf:Property ;
    rdfs:label 'Codec' ;
    rdfs:comment 'Video or audio compression codec used for encoding (e.g., H.264, H.265/HEVC, ProRes, DNxHD, AAC, PCM). Critical for quality assessment and transcoding decisions. | Column codec (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentClassification rdf:type rdf:Property ;
    rdfs:label 'Content Classification' ;
    rdfs:comment 'Business classification tags for content categorization (e.g., news, sports, drama, documentary, commercial, promo). Supports search, rights management, and workflow routing. Pipe-separated list for multiple classifications. | Column content_classification (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingest Timestamp' ;
    rdfs:comment 'Date and time when the asset was first ingested into the MAM system. Marks the beginning of the assets lifecycle in the enterprise repository. | Column ingest_timestamp (TIMESTAMP) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastAccessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Accessed Timestamp' ;
    rdfs:comment 'Date and time of the most recent access or playback of the asset. Used for storage tier optimization and usage analytics. | Column last_accessed_timestamp (TIMESTAMP) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Indicates whether the asset is under legal hold and must not be modified or deleted. Overrides retention policies until hold is released. | Column legal_hold_flag (BOOLEAN) in mediaasset.media_asset' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the asset in its operational lifecycle. Tracks progression from ingest through quality control, active use, archival, and eventual purge. Drives workflow automation and access control. [ENUM-REF-CANDIDATE: ingest|qc_pending|qc_approved|qc_rejected|available|in_use|archived|purged|quarantined — 9 candidates stripped; promote to reference product] | Column lifecycle_status (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingSystem rdf:type rdf:Property ;
    rdfs:label 'Originating System' ;
    rdfs:comment 'Source system or device that created or ingested the asset (e.g., camera model, editing suite, ingest station, external vendor). Provides provenance for chain-of-custody tracking. | Column originating_system (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qc Completed Timestamp' ;
    rdfs:comment 'Date and time when quality control review was completed. Null if QC is pending or not required. | Column qc_completed_timestamp (TIMESTAMP) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qcOperator rdf:type rdf:Property ;
    rdfs:label 'Qc Operator' ;
    rdfs:comment 'User ID or name of the operator who performed quality control review. Used for accountability and audit trails. | Column qc_operator (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'Date when the asset becomes eligible for purge based on retention policy. Null indicates indefinite retention or active legal hold. | Column retention_expiry_date (DATE) in mediaasset.media_asset' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Code' ;
    rdfs:comment 'Code identifying the retention policy governing lifecycle and purge rules for this asset. Drives automated archival and deletion workflows per regulatory and business requirements. | Column retention_policy_code (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTier rdf:type rdf:Property ;
    rdfs:label 'Storage Tier' ;
    rdfs:comment 'Current storage tier assignment based on access frequency and retention policy. Hot=online high-performance, Warm=nearline, Cold=offline tape, Deep-archive=long-term preservation, Glacier=regulatory hold. | Column storage_tier (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timecodeStart rdf:type rdf:Property ;
    rdfs:label 'Timecode Start' ;
    rdfs:comment 'SMPTE timecode of the first frame in HH:MM:SS:FF format. Essential for frame-accurate editing and playout synchronization. | Column timecode_start (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:umid rdf:type rdf:Property ;
    rdfs:label 'Umid' ;
    rdfs:comment 'SMPTE 330M globally unique identifier for the media essence. 64-character hexadecimal string providing universal identification across systems and organizations. | Column umid (STRING) in mediaasset.media_asset' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abrLadderRung rdf:type rdf:Property ;
    rdfs:label 'Abr Ladder Rung' ;
    rdfs:comment 'Position in the ABR ladder for HLS or DASH streaming (e.g., 1 for lowest quality, 5 for highest). Enables adaptive streaming based on viewer bandwidth. Null if not part of an ABR ladder. | Column abr_ladder_rung (INT) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checksumAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Checksum Algorithm' ;
    rdfs:comment 'Algorithm used to generate the checksum value (MD5, SHA-256, SHA-512). Identifies the hashing method for integrity verification. | Column checksum_algorithm (STRING) in mediaasset.asset_version' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumValue rdf:type rdf:Property ;
    rdfs:label 'Checksum Value' ;
    rdfs:comment 'Cryptographic hash (MD5 or SHA-256) of the file content. Ensures integrity verification, detects corruption during transfer or storage, and supports chain-of-custody audit trails for legal hold and regulatory compliance. | Column checksum_value (DECIMAL(18,2)) in mediaasset.asset_version' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerFormat rdf:type rdf:Property ;
    rdfs:label 'Container Format' ;
    rdfs:comment 'File container format wrapping the audio and video streams (e.g., MP4, MOV, MXF, TS, WebM). Determines file compatibility and metadata support. | Column container_format (STRING) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmProtection rdf:type rdf:Property ;
    rdfs:label 'Drm Protection' ;
    rdfs:comment 'Indicates whether this version is protected by DRM encryption (True/False). DRM systems include Widevine, PlayReady, FairPlay. Supports content security and anti-piracy. | Column drm_protection (BOOLEAN) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proxyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Proxy Expiry Date' ;
    rdfs:comment 'Date when this proxy or preview version expires and should be purged from storage. Applicable only when rendition_purpose is proxy or preview. Supports storage cost optimization and compliance with retention policies. | Column proxy_expiry_date (DATE) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renditionPurpose rdf:type rdf:Property ;
    rdfs:label 'Rendition Purpose' ;
    rdfs:comment 'Business purpose or use case for this version: playout (broadcast transmission), distribution (delivery to platforms), archive (long-term preservation), preview (review/approval), proxy (low-res editing), watermark (forensic tracking), mezzanine (high-quality master), localized_dub (language variant), thumbnail (visual reference). [ENUM-REF-CANDIDATE: playout|distribution|archive|preview|proxy|watermark|mezzanine|localized_dub|thumbnail — 9 candidates stripped; promote to reference product] | Column rendition_purpose (STRING) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionHeight rdf:type rdf:Property ;
    rdfs:label 'Resolution Height' ;
    rdfs:comment 'Vertical resolution of the video frame in pixels (e.g., 1080 for 1080p, 2160 for 4K). Used for format classification and quality assessment. | Column resolution_height (INT) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionWidth rdf:type rdf:Property ;
    rdfs:label 'Resolution Width' ;
    rdfs:comment 'Horizontal resolution of the video frame in pixels (e.g., 1920 for 1080p, 3840 for 4K). Used for format classification and quality assessment. | Column resolution_width (INT) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageUri rdf:type rdf:Property ;
    rdfs:label 'Storage Uri' ;
    rdfs:comment 'Full storage path or URI where this version is physically stored (e.g., s3://bucket/path, file://nas/volume/path, https://cdn.example.com/asset). Supports multi-tier storage (hot/warm/cold/archive) and CDN distribution via Akamai. | Column storage_uri (STRING) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtitleTracks rdf:type rdf:Property ;
    rdfs:label 'Subtitle Tracks' ;
    rdfs:comment 'Comma-separated list of ISO 639-2 language codes for embedded subtitle or closed caption tracks (e.g., eng,spa,fra). Supports accessibility compliance (COPPA, FCC) and multi-language distribution. | Column subtitle_tracks (STRING) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validated Timestamp' ;
    rdfs:comment 'Timestamp when this version passed quality control (QC) validation and was approved for use. Null if validation is pending or failed. | Column validated_timestamp (TIMESTAMP) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:watermarkPayload rdf:type rdf:Property ;
    rdfs:label 'Watermark Payload' ;
    rdfs:comment 'Forensic watermark identifier or payload embedded in this version for anti-piracy tracking and content protection. Applicable only when rendition_purpose is watermark. Supports DRM (Digital Rights Management) and content security. | Column watermark_payload (STRING) in mediaasset.asset_version' ;
    rdfs:domain ind:AssetVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Created Asset Version Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.asset_version. Business justification: Ingest job creates a specific version (typically the mezzanine or raw master). This FK links the ingest job to the version it produced. Populated upon successful ingest completion. | Column created_asset_version_id (BIGINT) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:bytesTransferred rdf:type rdf:Property ;
    rdfs:label 'Bytes Transferred' ;
    rdfs:comment 'Total number of bytes successfully transferred during the ingest operation. Used for capacity planning and performance monitoring. | Column bytes_transferred (BIGINT) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedCaptionPresent rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Present' ;
    rdfs:comment 'Indicates whether closed captions or subtitles are embedded in the ingested media. Required for FCC accessibility compliance validation. | Column closed_caption_present (BOOLEAN) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingestEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingest End Timestamp' ;
    rdfs:comment 'Timestamp when the ingest job completed or terminated. Null for jobs still in progress. | Column ingest_end_timestamp (TIMESTAMP) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ingestSourceType rdf:type rdf:Property ;
    rdfs:label 'Ingest Source Type' ;
    rdfs:comment 'Classification of the media source from which content is being ingested. Determines handling protocols and validation rules. | Column ingest_source_type (STRING) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingest Start Timestamp' ;
    rdfs:comment 'Timestamp when the ingest job began processing. Represents the actual start of media transfer, not the queued time. | Column ingest_start_timestamp (TIMESTAMP) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:jobNumber rdf:type rdf:Property ;
    rdfs:label 'Job Number' ;
    rdfs:comment 'Human-readable business identifier for the ingest job, typically formatted as prefix-date-sequence (e.g., ING-20240115-0042). Used for operational tracking and reference. | Column job_number (STRING) in mediaasset.ingest_job' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobStatus rdf:type rdf:Property ;
    rdfs:label 'Job Status' ;
    rdfs:comment 'Current lifecycle status of the ingest job. Tracks progression from queued through execution to final disposition. | Column job_status (STRING) in mediaasset.ingest_job' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFormat rdf:type rdf:Property ;
    rdfs:label 'Source Format' ;
    rdfs:comment 'Technical format of the source media file or stream (e.g., MPEG-4, ProRes, MXF, H.264). Used for transcode planning and compatibility validation. | Column source_format (STRING) in mediaasset.ingest_job' ;
    rdfs:domain ind:Mediaasset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLocation rdf:type rdf:Property ;
    rdfs:label 'Source Location' ;
    rdfs:comment 'Physical or logical location of the source media. May be a tape ID, file path, URL, satellite transponder identifier, or cloud storage bucket path. | Column source_location (STRING) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFormat rdf:type rdf:Property ;
    rdfs:label 'Target Format' ;
    rdfs:comment 'Desired output format for the ingested media. May differ from source format if transcoding is required during ingest. | Column target_format (STRING) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferRateMbps rdf:type rdf:Property ;
    rdfs:label 'Transfer Rate Mbps' ;
    rdfs:comment 'Average data transfer rate achieved during ingest, measured in megabits per second. Key performance indicator for ingest infrastructure. | Column transfer_rate_mbps (DECIMAL(10,2)) in mediaasset.ingest_job' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transcodeJobId rdf:type rdf:Property ;
    rdfs:label 'Transcode Job Id' ;
    rdfs:comment 'Primary key for transcode_job | Column transcode_job_id (BIGINT) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outputStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Output Storage Location Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.storage_location. Business justification: transcode_job.output_storage_uri is a free-text URI capturing where the transcoded output file is written. storage_location is the authoritative master reference for all storage locations in the MAM. ' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:abrLadderConfiguration rdf:type rdf:Property ;
    rdfs:label 'Abr Ladder Configuration' ;
    rdfs:comment 'Configuration specification for ABR ladder generation, defining the set of bitrate/resolution variants to be created for adaptive streaming (e.g., 240p@400kbps, 360p@800kbps, 480p@1.2Mbps, 720p@2.5Mbps, 1080p@5Mbps). Applicable when job_type is abr_ladder_generation. | Column abr_ladder_configuration (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codecParameters rdf:type rdf:Property ;
    rdfs:label 'Codec Parameters' ;
    rdfs:comment 'Detailed codec encoding parameters including profile, level, GOP structure, B-frames, reference frames, and other encoder-specific settings (e.g., x264 preset=medium, crf=23, profile=high, level=4.1). | Column codec_parameters (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Usd' ;
    rdfs:comment 'Estimated processing cost in US dollars for this transcode job, based on compute time, storage, and resource utilization. Used for chargeback and budget tracking. | Column cost_estimate_usd (DECIMAL(10,2)) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobPriority rdf:type rdf:Property ;
    rdfs:label 'Job Priority' ;
    rdfs:comment 'Processing priority level for the transcode job, determining queue position and resource allocation. Critical jobs are processed immediately, batch jobs during off-peak hours. | Column job_priority (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobType rdf:type rdf:Property ;
    rdfs:label 'Job Type' ;
    rdfs:comment 'Classification of the transcode operation: standard transcode for routine format conversion, ABR (Adaptive Bitrate) ladder generation for streaming, proxy creation for editing workflows, delivery package preparation for distribution, or format migration for obsolescence-driven conversions. [ENUM-REF-CANDIDATE: standard_transcode|abr_ladder_generation|proxy_creation|delivery_package|format_migration|tape_digitization|analogue_to_digital — 7 candidates stripped; promote to reference product] | Column job_type (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationReason rdf:type rdf:Property ;
    rdfs:label 'Migration Reason' ;
    rdfs:comment 'Business justification for format migration jobs. Applicable only when job_type is format_migration, tape_digitization, or analogue_to_digital. Captures whether the conversion is driven by format obsolescence (e.g., MPEG-2 to H.265), storage optimization, distribution requirements, or regulatory compliance. [ENUM-REF-CANDIDATE: format_obsolescence|storage_optimization|distribution_requirement|quality_enhancement|compliance_mandate|archive_preservation|not_applicable — 7 candidates stripped; promote to reference product] | Column migration_reason (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputChecksum rdf:type rdf:Property ;
    rdfs:label 'Output Checksum' ;
    rdfs:comment 'Cryptographic checksum (MD5, SHA-256, or SHA-512) of the output file for integrity verification and chain-of-custody audit trails. | Column output_checksum (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputFileSizeGb rdf:type rdf:Property ;
    rdfs:label 'Output File Size Gb' ;
    rdfs:comment 'Total file size of the transcoded output in gigabytes. Populated upon job completion. | Column output_file_size_gb (DECIMAL(12,3)) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Processing Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from processing start to completion, used for performance monitoring and capacity planning. | Column processing_duration_seconds (INT) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing End Timestamp' ;
    rdfs:comment 'Date and time when the transcoding engine completed or terminated processing of this job. | Column processing_end_timestamp (TIMESTAMP) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Start Timestamp' ;
    rdfs:comment 'Date and time when the transcoding engine began processing this job. | Column processing_start_timestamp (TIMESTAMP) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityValidationResult rdf:type rdf:Property ;
    rdfs:label 'Quality Validation Result' ;
    rdfs:comment 'Outcome of automated quality validation checks performed on the transcoded output, including video integrity, audio sync, and compliance with target specifications. | Column quality_validation_result (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityValidationScore rdf:type rdf:Property ;
    rdfs:label 'Quality Validation Score' ;
    rdfs:comment 'Numeric quality score (0-100) assigned by automated validation tools, measuring output fidelity against source and target specifications. | Column quality_validation_score (DECIMAL(5,2)) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:queueEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Queue Entry Timestamp' ;
    rdfs:comment 'Date and time when the transcode job was submitted to the processing queue. | Column queue_entry_timestamp (TIMESTAMP) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceBitrateMbps rdf:type rdf:Property ;
    rdfs:label 'Source Bitrate Mbps' ;
    rdfs:comment 'Average bitrate of the source asset in megabits per second. | Column source_bitrate_mbps (DECIMAL(10,2)) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceCodec rdf:type rdf:Property ;
    rdfs:label 'Source Codec' ;
    rdfs:comment 'Video codec of the source asset (e.g., H.264, H.265/HEVC, MPEG-2, ProRes, DNxHD). | Column source_codec (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Source Duration Seconds' ;
    rdfs:comment 'Duration of the source media asset in seconds. | Column source_duration_seconds (INT) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceFileSizeGb rdf:type rdf:Property ;
    rdfs:label 'Source File Size Gb' ;
    rdfs:comment 'File size of the source asset in gigabytes. | Column source_file_size_gb (DECIMAL(12,3)) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceResolution rdf:type rdf:Property ;
    rdfs:label 'Source Resolution' ;
    rdfs:comment 'Video resolution of the source asset in pixels (e.g., 1920x1080, 3840x2160, 1280x720). | Column source_resolution (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transcodingEngine rdf:type rdf:Property ;
    rdfs:label 'Transcoding Engine' ;
    rdfs:comment 'Name and version of the transcoding engine or software used to perform the conversion (e.g., FFmpeg 5.1.2, AWS Elemental MediaConvert, Dalet Brio). | Column transcoding_engine (STRING) in mediaasset.transcode_job' ;
    rdfs:domain ind:TranscodeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcInspectionId rdf:type rdf:Property ;
    rdfs:label 'Qc Inspection Id' ;
    rdfs:comment 'Unique identifier for the quality control inspection record. Primary key. | Column qc_inspection_id (BIGINT) in mediaasset.qc_inspection' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QcInspection .

ind:mediaAssetVersionId rdf:type rdf:Property ;
    rdfs:label 'Media Asset Version Id' ;
    rdfs:comment 'Reference to the specific version of the media asset that underwent this quality control inspection. | Column media_asset_version_id (BIGINT) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetVersion .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the asset was approved for playout or distribution following QC inspection. Null if not yet approved. | Column approval_timestamp (TIMESTAMP) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aspectRatioComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Aspect Ratio Compliance Result' ;
    rdfs:comment 'Result of aspect ratio compliance check. Verifies that video aspect ratio (e.g., 16:9, 4:3, 21:9) matches expected format and Active Format Description (AFD) metadata is correct. | Column aspect_ratio_compliance_result (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioCodecComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Audio Codec Compliance Result' ;
    rdfs:comment 'Result of audio codec format compliance check. Verifies that audio encoding conforms to expected codec standard (e.g., AAC, Dolby Digital, Dolby Atmos, MPEG-1 Layer II). | Column audio_codec_compliance_result (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioSyncOffsetMs rdf:type rdf:Property ;
    rdfs:label 'Audio Sync Offset Ms' ;
    rdfs:comment 'Measured audio-to-video synchronization offset in milliseconds. Positive values indicate audio leads video; negative values indicate audio lags video. Null if sync check not performed. | Column audio_sync_offset_ms (INT) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioSyncResult rdf:type rdf:Property ;
    rdfs:label 'Audio Sync Result' ;
    rdfs:comment 'Result of audio-to-video synchronization check. Detects lip-sync errors or audio drift. | Column audio_sync_result (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackFrameCount rdf:type rdf:Property ;
    rdfs:label 'Black Frame Count' ;
    rdfs:comment 'Total number of black frames detected in the media asset. Zero if none detected. | Column black_frame_count (INT) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackFrameDetected rdf:type rdf:Property ;
    rdfs:label 'Black Frame Detected' ;
    rdfs:comment 'Indicates whether unintended black frames (video signal dropout or encoding error) were detected during inspection. | Column black_frame_detected (BOOLEAN) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:captionValidationResult rdf:type rdf:Property ;
    rdfs:label 'Caption Validation Result' ;
    rdfs:comment 'Result of closed caption (CEA-608, CEA-708) or subtitle validation check. Verifies presence, format compliance, and synchronization of captions. | Column caption_validation_result (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDefectCount rdf:type rdf:Property ;
    rdfs:label 'Critical Defect Count' ;
    rdfs:comment 'Number of critical-severity defects that block asset approval for playout or distribution. Critical defects require remediation. | Column critical_defect_count (INT) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of quality defects detected during inspection. Zero indicates no defects found. | Column defect_count (INT) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectSummary rdf:type rdf:Property ;
    rdfs:label 'Defect Summary' ;
    rdfs:comment 'Structured JSON or delimited text summary of all detected defects with timecode references, severity levels, and defect type codes. Detailed defect records may be stored in a separate qc_defect child table. | Column defect_summary (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedAspectRatio rdf:type rdf:Property ;
    rdfs:label 'Detected Aspect Ratio' ;
    rdfs:comment 'Actual aspect ratio detected in the video stream (e.g., 16:9, 4:3, 1.85:1, 2.39:1). Null if aspect ratio check not performed. | Column detected_aspect_ratio (NUMERIC) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freezeFrameCount rdf:type rdf:Property ;
    rdfs:label 'Freeze Frame Count' ;
    rdfs:comment 'Total number of freeze frame incidents detected in the media asset. Zero if none detected. | Column freeze_frame_count (INT) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freezeFrameDetected rdf:type rdf:Property ;
    rdfs:label 'Freeze Frame Detected' ;
    rdfs:comment 'Indicates whether freeze frames (static video for extended duration) were detected during inspection. | Column freeze_frame_detected (BOOLEAN) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdrMetadataValidationResult rdf:type rdf:Property ;
    rdfs:label 'Hdr Metadata Validation Result' ;
    rdfs:comment 'Result of High Dynamic Range (HDR) metadata validation check. Verifies presence and correctness of HDR10, HDR10+, Dolby Vision, or HLG metadata. Not applicable for Standard Dynamic Range (SDR) content. | Column hdr_metadata_validation_result (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Inspection Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds required to complete the quality control inspection process. | Column inspection_duration_seconds (INT) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Human-readable business identifier for the inspection record, formatted as QC-YYYYMMDD-NNNNNN. | Column inspection_number (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle state of the quality control inspection process. | Column inspection_status (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when the quality control inspection was performed or completed. Primary business event timestamp. | Column inspection_timestamp (TIMESTAMP) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loudnessComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Loudness Compliance Result' ;
    rdfs:comment 'Result of audio loudness compliance check against regulatory standards (EBU R128 for Europe, ATSC A/85 for North America, ITU-R BS.1770 globally). | Column loudness_compliance_result (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Final pass/fail determination for the quality control inspection. Conditional pass indicates minor issues that do not block playout. Review required indicates human escalation needed. | Column overall_result (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcToolName rdf:type rdf:Property ;
    rdfs:label 'Qc Tool Name' ;
    rdfs:comment 'Name and version of the automated quality control software or tool used for inspection (e.g., Baton, Interra, Venera, Dalet QC Module). | Column qc_tool_name (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed explanation of why the asset was rejected, including references to specific defects or compliance failures. Null if asset was approved. | Column rejection_reason (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCodecComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Video Codec Compliance Result' ;
    rdfs:comment 'Result of video codec format compliance check. Verifies that video encoding conforms to expected codec standard (e.g., H.264/AVC, H.265/HEVC, MPEG-2, AV1). | Column video_codec_compliance_result (STRING) in mediaasset.qc_inspection' ;
    rdfs:domain ind:QcInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessProtocol rdf:type rdf:Property ;
    rdfs:label 'Access Protocol' ;
    rdfs:comment 'Network protocol or interface used to access the storage location (NFS = Network File System, SMB = Server Message Block, S3 = Amazon S3 API, SFTP = Secure File Transfer Protocol, iSCSI = Internet Small Computer Systems Interface, Fibre_Channel = FC SAN protocol). [ENUM-REF-CANDIDATE: NFS|SMB|S3|SFTP|iSCSI|Fibre_Channel|HTTP|HTTPS — 8 candidates stripped; promote to reference product] | Column access_protocol (STRING) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCapacityTb rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Tb' ;
    rdfs:comment 'Remaining available storage capacity (total minus used), measured in terabytes (TB). Drives automated alerts and provisioning workflows. | Column available_capacity_tb (DECIMAL(18,3)) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checksumValidationEnabled rdf:type rdf:Property ;
    rdfs:label 'Checksum Validation Enabled' ;
    rdfs:comment 'Indicates whether automated checksum integrity validation is performed on assets stored at this location (True = enabled, False = disabled). Critical for ensuring asset integrity and detecting corruption. | Column checksum_validation_enabled (BOOLEAN) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for the technical or operational contact responsible for this storage location. Used for alerts, maintenance coordination, and incident response. | Column contact_email (STRING) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerTbPerMonth rdf:type rdf:Property ;
    rdfs:label 'Cost Per Tb Per Month' ;
    rdfs:comment 'Monthly cost per terabyte of storage at this location, used for cost allocation and financial reporting. Includes infrastructure, licensing, and operational costs. | Column cost_per_tb_per_month (DECIMAL(12,2)) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataCenterName rdf:type rdf:Property ;
    rdfs:label 'Data Center Name' ;
    rdfs:comment 'Name or identifier of the physical data center or facility housing the storage infrastructure (e.g., \'NYC-DC1\', \'AWS-US-East-1\', \'Azure-WestEurope\'). | Column data_center_name (STRING) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled' ;
    rdfs:comment 'Indicates whether data-at-rest encryption is enabled for this storage location (True = encrypted, False = not encrypted). Critical for compliance with data protection regulations. | Column encryption_enabled (BOOLEAN) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encryptionMethod rdf:type rdf:Property ;
    rdfs:label 'Encryption Method' ;
    rdfs:comment 'Encryption algorithm or method applied to data at rest (e.g., \'AES-256\', \'AES-128\', \'RSA-2048\'). Null if encryption is not enabled. | Column encryption_method (STRING) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCapacityCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Capacity Check Timestamp' ;
    rdfs:comment 'Timestamp of the most recent capacity measurement or audit for this storage location. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. | Column last_capacity_check_timestamp (TIMESTAMP) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalHoldCapable rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Capable' ;
    rdfs:comment 'Indicates whether this storage location supports legal hold functionality to prevent deletion or modification of assets under litigation or regulatory investigation (True = capable, False = not capable). | Column legal_hold_capable (BOOLEAN) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Short alphanumeric code or identifier used for operational reference and system integration (e.g., \'SAN-PROD-01\', \'LTO-ARCH-02\', \'S3-USEAST\'). | Column location_code (STRING) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name or label for the storage location (e.g., \'Production SAN Array 01\', \'Archive LTO Tape Library\', \'AWS S3 US-East Bucket\'). | Column location_name (STRING) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mountPoint rdf:type rdf:Property ;
    rdfs:label 'Mount Point' ;
    rdfs:comment 'File system mount point, UNC path, or object storage URI used by MAM systems to access the location (e.g., \'/mnt/production_san\', \'\\\\nas01\\media\', \'s3://bucket-name/prefix\'). | Column mount_point (STRING) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replicationEnabled rdf:type rdf:Property ;
    rdfs:label 'Replication Enabled' ;
    rdfs:comment 'Indicates whether this storage location is replicated to another location for redundancy and disaster recovery (True = replicated, False = not replicated). | Column replication_enabled (BOOLEAN) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restoreTimeObjectiveHours rdf:type rdf:Property ;
    rdfs:label 'Restore Time Objective Hours' ;
    rdfs:comment 'Maximum acceptable time to restore or retrieve assets from this storage location, measured in hours. Critical for disaster recovery and operational planning. | Column restore_time_objective_hours (DECIMAL(10,2)) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionPolicyDays rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Days' ;
    rdfs:comment 'Default retention period in days for assets stored at this location, after which assets may be migrated or purged per policy. Null if no default retention applies. | Column retention_policy_days (INT) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageType rdf:type rdf:Property ;
    rdfs:label 'Storage Type' ;
    rdfs:comment 'Classification of the physical or logical storage technology (SAN = Storage Area Network, NAS = Network Attached Storage, LTO_Tape = Linear Tape-Open, Cloud_Object_Storage = S3/Azure Blob/GCS, CDN_Origin = Content Delivery Network origin store, Deep_Archive = long-term cold storage vault). | Column storage_type (STRING) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageVendor rdf:type rdf:Property ;
    rdfs:label 'Storage Vendor' ;
    rdfs:comment 'Name of the storage hardware or cloud service provider (e.g., \'Dell EMC\', \'NetApp\', \'AWS\', \'Azure\', \'Google Cloud\', \'IBM Spectrum Archive\'). | Column storage_vendor (STRING) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapacityTb rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Tb' ;
    rdfs:comment 'Total storage capacity of the location measured in terabytes (TB). Used for capacity planning and allocation reporting. | Column total_capacity_tb (DECIMAL(18,3)) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usedCapacityTb rdf:type rdf:Property ;
    rdfs:label 'Used Capacity Tb' ;
    rdfs:comment 'Current amount of storage capacity consumed or allocated, measured in terabytes (TB). Updated periodically to reflect actual usage. | Column used_capacity_tb (DECIMAL(18,3)) in mediaasset.storage_location' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetStorageAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Asset Storage Assignment Id' ;
    rdfs:comment 'Unique identifier for the asset storage assignment record. Primary key for tracking storage placement history. | Column asset_storage_assignment_id (BIGINT) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessFrequency rdf:type rdf:Property ;
    rdfs:label 'Access Frequency' ;
    rdfs:comment 'Number of times this file has been accessed since assignment to this storage location. Used to inform tiering and migration decisions. | Column access_frequency (INT) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'Date when the asset file was migrated, purged, or removed from this storage location. Null if still active at this location. | Column assignment_end_date (DATE) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment End Timestamp' ;
    rdfs:comment 'Precise timestamp when the asset file was migrated, purged, or removed from this storage location. Null if still active. | Column assignment_end_timestamp (TIMESTAMP) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'Date when the asset file was placed at this storage location. Marks the beginning of the storage assignment period. | Column assignment_start_date (DATE) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the asset file was placed at this storage location. Provides exact time for chain-of-custody audit trails. | Column assignment_start_timestamp (TIMESTAMP) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Complete file system path or URI where the asset file is physically stored. Enables restore path resolution and file retrieval. | Column file_path (STRING) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAccessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Access Timestamp' ;
    rdfs:comment 'Timestamp of the most recent access to this file at this storage location. Used for tiering policy enforcement and usage analytics. | Column last_access_timestamp (TIMESTAMP) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:migrationTrigger rdf:type rdf:Property ;
    rdfs:label 'Migration Trigger' ;
    rdfs:comment 'Reason why the asset was moved to or from this storage location. Captures business or technical driver for storage placement decisions. | Column migration_trigger (STRING) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replicationCount rdf:type rdf:Property ;
    rdfs:label 'Replication Count' ;
    rdfs:comment 'Number of redundant copies of this file maintained at this storage location. Used for disaster recovery and high availability planning. | Column replication_count (INT) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageCostPerGb rdf:type rdf:Property ;
    rdfs:label 'Storage Cost Per Gb' ;
    rdfs:comment 'Cost per gigabyte for this storage tier at the time of assignment. Used for storage cost allocation and financial reporting. | Column storage_cost_per_gb (DECIMAL(10,4)) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of file integrity verification at this storage location. Indicates whether checksum validation has been performed and passed. | Column verification_status (STRING) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Timestamp of the most recent integrity verification check. Used to track compliance with periodic verification policies. | Column verification_timestamp (TIMESTAMP) in mediaasset.asset_storage_assignment' ;
    rdfs:domain ind:AssetStorageAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:archiveRecordId rdf:type rdf:Property ;
    rdfs:label 'Archive Record Id' ;
    rdfs:comment 'Primary key for archive_record | Column archive_record_id (BIGINT) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:archiveCostPerGb rdf:type rdf:Property ;
    rdfs:label 'Archive Cost Per Gb' ;
    rdfs:comment 'The cost per gigabyte for storing the asset in the archive destination, used for financial planning and cost allocation. | Column archive_cost_per_gb (DECIMAL(10,4)) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:archiveDestinationType rdf:type rdf:Property ;
    rdfs:label 'Archive Destination Type' ;
    rdfs:comment 'The type of long-term storage destination where the asset was archived. | Column archive_destination_type (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Archive File Size Bytes' ;
    rdfs:comment 'The size of the archived media file in bytes, used for storage capacity planning and billing. | Column archive_file_size_bytes (BIGINT) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:archiveFormat rdf:type rdf:Property ;
    rdfs:label 'Archive Format' ;
    rdfs:comment 'The file format or container format of the archived asset (e.g., MXF, MOV, MP4, ProRes, DNxHD) as stored in the archive. | Column archive_format (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveJobReference rdf:type rdf:Property ;
    rdfs:label 'Archive Job Reference' ;
    rdfs:comment 'Unique reference number assigned to the archival job or batch process that created this archive record. | Column archive_job_reference (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveNotes rdf:type rdf:Property ;
    rdfs:label 'Archive Notes' ;
    rdfs:comment 'Free-text notes or comments about the archival process, special handling instructions, or any issues encountered during archival. | Column archive_notes (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveStatus rdf:type rdf:Property ;
    rdfs:label 'Archive Status' ;
    rdfs:comment 'Current lifecycle status of the archived asset indicating its availability and operational state. [ENUM-REF-CANDIDATE: archived|restore_requested|restore_in_progress|restored|purge_pending|purged|failed — 7 candidates stripped; promote to reference product] | Column archive_status (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveSystemName rdf:type rdf:Property ;
    rdfs:label 'Archive System Name' ;
    rdfs:comment 'Name of the archival system or MAM module that performed the archival operation (e.g., Dalet Galaxy Archive, Spectra Logic). | Column archive_system_name (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archive Timestamp' ;
    rdfs:comment 'Precise timestamp when the archival process completed and the asset was committed to long-term storage. | Column archive_timestamp (TIMESTAMP) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cloudVaultIdentifier rdf:type rdf:Property ;
    rdfs:label 'Cloud Vault Identifier' ;
    rdfs:comment 'Unique identifier for the cloud deep-archive vault or bucket where the asset is stored (e.g., AWS Glacier vault ARN, Azure Archive Storage container). | Column cloud_vault_identifier (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionCodec rdf:type rdf:Property ;
    rdfs:label 'Compression Codec' ;
    rdfs:comment 'The compression codec applied to the media asset for archival storage (e.g., H.264, H.265, JPEG2000, uncompressed). | Column compression_codec (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltoTapeGeneration rdf:type rdf:Property ;
    rdfs:label 'Lto Tape Generation' ;
    rdfs:comment 'The LTO tape generation standard used for archival (e.g., LTO-8, LTO-9) if the destination is tape-based storage. | Column lto_tape_generation (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oaisComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Oais Compliance Flag' ;
    rdfs:comment 'Indicates whether this archive record complies with ISO 14721 OAIS reference model standards for long-term digital preservation. | Column oais_compliance_flag (BOOLEAN) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offsiteFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Offsite Facility Code' ;
    rdfs:comment 'Code identifying the physical off-site archival facility or vault location where the media is stored. | Column offsite_facility_code (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purgeApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Purge Approval Status' ;
    rdfs:comment 'Approval status for purging the archived asset, ensuring compliance with retention and legal hold requirements before deletion. | Column purge_approval_status (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purgeScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Purge Scheduled Date' ;
    rdfs:comment 'The scheduled date for purging or permanently deleting the archived asset, based on retention policy expiration. | Column purge_scheduled_date (DATE) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restoreCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Restore Completion Date' ;
    rdfs:comment 'The date when the restore operation was completed and the asset was made available for use. | Column restore_completion_date (DATE) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restoreRequestDate rdf:type rdf:Property ;
    rdfs:label 'Restore Request Date' ;
    rdfs:comment 'The date when a restore request was submitted for this archived asset, if applicable. | Column restore_request_date (DATE) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restoreSlaTier rdf:type rdf:Property ;
    rdfs:label 'Restore Sla Tier' ;
    rdfs:comment 'The service level tier defining the expected restore time for retrieving this archived asset (e.g., expedited within hours, standard within days, bulk within weeks). | Column restore_sla_tier (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restoreTestDate rdf:type rdf:Property ;
    rdfs:label 'Restore Test Date' ;
    rdfs:comment 'The date when the last restore test was performed to verify the integrity and retrievability of the archived asset. | Column restore_test_date (DATE) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restoreTestResult rdf:type rdf:Property ;
    rdfs:label 'Restore Test Result' ;
    rdfs:comment 'Outcome of the most recent restore test indicating whether the asset was successfully retrieved and validated. | Column restore_test_result (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapeBarcode rdf:type rdf:Property ;
    rdfs:label 'Tape Barcode' ;
    rdfs:comment 'Physical barcode identifier on the LTO tape cartridge used for archival, enabling physical inventory tracking. | Column tape_barcode (STRING) in mediaasset.archive_record' ;
    rdfs:domain ind:ArchiveRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseeSalesAccountId rdf:type rdf:Property ;
    rdfs:label 'Licensee Sales Account Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_account. Business justification: License agreements are negotiated with sales accounts (distributors, broadcasters, platforms). Real-world licensing operations require tracking which sales account is the licensee for revenue recognit | Column licensee_sales_account_id (BIGINT) in sales.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primaryLicenseHolderId rdf:type rdf:Property ;
    rdfs:label 'Primary License Holder Id' ;
    rdfs:comment 'Reference to the party granting rights under this agreement (studio, distributor, music publisher, talent guild, production company). | Column primary_license_holder_id (BIGINT) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:advancePaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Amount' ;
    rdfs:comment 'Upfront payment made upon execution of the agreement, typically recoupable against future royalties or license fees. | Column advance_payment_amount (DECIMAL(18,2)) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blackoutRestrictions rdf:type rdf:Property ;
    rdfs:label 'Blackout Restrictions' ;
    rdfs:comment 'Geographic or temporal restrictions on content availability (e.g., no broadcast in certain markets during specific events, sports blackout rules). Free-text description. | Column blackout_restrictions (STRING) in rights.license_agreement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Clearance Required Flag' ;
    rdfs:comment 'Indicates whether additional rights clearance verification is required before content can be broadcast or distributed under this agreement. True = clearance workflow required, False = no additional clearance needed. | Column clearance_required_flag (BOOLEAN) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaRightsGranted rdf:type rdf:Property ;
    rdfs:label 'Media Rights Granted' ;
    rdfs:comment 'Comma-separated list of media exploitation rights included in this agreement (e.g., linear broadcast, SVOD, AVOD, TVOD, theatrical, home video, digital download, mobile streaming). | Column media_rights_granted (STRING) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicSyncLicenseFlag rdf:type rdf:Property ;
    rdfs:label 'Music Sync License Flag' ;
    rdfs:comment 'Indicates whether this agreement includes music synchronization rights for use of musical compositions in audiovisual content. True = music sync rights included, False = no music sync rights. | Column music_sync_license_flag (BOOLEAN) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentScheduleType rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule Type' ;
    rdfs:comment 'Structure of the payment obligation. Determines how total_license_fee is disbursed over time. | Column payment_schedule_type (STRING) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perEpisodeFee rdf:type rdf:Property ;
    rdfs:label 'Per Episode Fee' ;
    rdfs:comment 'License fee charged per episode for episodic content. Applicable to syndication and first-run syndication agreements. | Column per_episode_fee (DECIMAL(18,2)) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months of each automatic renewal period if auto_renewal_flag is true. Null if agreement does not auto-renew. | Column renewal_term_months (INT) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:royaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Royalty Calculation Method' ;
    rdfs:comment 'Method used to calculate ongoing royalty payments to the licensor. Determines how revenue is shared or how usage is monetized. | Column royalty_calculation_method (STRING) in rights.license_agreement' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyPercentage rdf:type rdf:Property ;
    rdfs:label 'Royalty Percentage' ;
    rdfs:comment 'Percentage of revenue or receipts paid to the licensor as ongoing royalties. Applicable when royalty_calculation_method is percentage-based. | Column royalty_percentage (DECIMAL(5,2)) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runCountLimit rdf:type rdf:Property ;
    rdfs:label 'Run Count Limit' ;
    rdfs:comment 'Maximum number of times each episode or program may be broadcast or streamed under this agreement. Common in syndication deals. Null indicates unlimited runs. | Column run_count_limit (INT) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLicenseFee rdf:type rdf:Property ;
    rdfs:label 'Total License Fee' ;
    rdfs:comment 'Total contractual payment obligation for the license rights over the full term of the agreement. Sum of all payment milestones. | Column total_license_fee (DECIMAL(18,2)) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windowingStrategy rdf:type rdf:Property ;
    rdfs:label 'Windowing Strategy' ;
    rdfs:comment 'Sequential release strategy defining the order and timing of content availability across distribution channels (theatrical, SVOD, AVOD, TVOD, linear, syndication). Free-text description of the windowing plan. | Column windowing_strategy (STRING) in rights.license_agreement' ;
    rdfs:domain ind:LicenseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutApplicable rdf:type rdf:Property ;
    rdfs:label 'Blackout Applicable' ;
    rdfs:comment 'Indicates whether geographic or temporal blackout restrictions apply to this grant (e.g., sports blackouts, regional restrictions). | Column blackout_applicable (BOOLEAN) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Carriage Fee Applicable' ;
    rdfs:comment 'Indicates whether a carriage fee (distribution payment) is associated with this grant. | Column carriage_fee_applicable (BOOLEAN) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityIndicator rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Indicator' ;
    rdfs:comment 'Indicates whether the grant is exclusive (true) or non-exclusive (false). Exclusive grants prevent other parties from exploiting the same rights in the same territory and window. | Column exclusivity_indicator (BOOLEAN) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantNumber rdf:type rdf:Property ;
    rdfs:label 'Grant Number' ;
    rdfs:comment 'Business identifier for the rights grant, typically a human-readable code used in Rightsline and operational workflows. | Column grant_number (STRING) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantStatus rdf:type rdf:Property ;
    rdfs:label 'Grant Status' ;
    rdfs:comment 'Current lifecycle status of the rights grant. Reflects whether the grant is currently in force, expired, or otherwise inactive. | Column grant_status (STRING) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackApplicable rdf:type rdf:Property ;
    rdfs:label 'Holdback Applicable' ;
    rdfs:comment 'Indicates whether a holdback period applies to this grant. Holdbacks restrict exploitation during specific windows to protect other distribution channels. | Column holdback_applicable (BOOLEAN) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdbackEndDate rdf:type rdf:Property ;
    rdfs:label 'Holdback End Date' ;
    rdfs:comment 'The end date of the holdback period, after which exploitation may resume. Nullable if no holdback applies. | Column holdback_end_date (DATE) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdbackStartDate rdf:type rdf:Property ;
    rdfs:label 'Holdback Start Date' ;
    rdfs:comment 'The start date of any holdback period during which exploitation is restricted. Nullable if no holdback applies. | Column holdback_start_date (DATE) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:languageVersion rdf:type rdf:Property ;
    rdfs:label 'Language Version' ;
    rdfs:comment 'Language version of the content covered by this grant (e.g., English, Spanish, French). May reference dubbed, subtitled, or original language versions. | Column language_version (STRING) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaType rdf:type rdf:Property ;
    rdfs:label 'Media Type' ;
    rdfs:comment 'The media format or delivery mechanism covered by this grant (e.g., television, film, digital streaming, audio). | Column media_type (STRING) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicSyncLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Music Sync License Required' ;
    rdfs:comment 'Indicates whether a separate music synchronization license is required for the music tracks embedded in the content. | Column music_sync_license_required (BOOLEAN) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightType rdf:type rdf:Property ;
    rdfs:label 'Right Type' ;
    rdfs:comment 'Type of distribution or exploitation right granted. Defines the platform or medium for which the content may be used. [ENUM-REF-CANDIDATE: broadcast|svod|avod|tvod|theatrical|home_video|music_sync|podcast|linear|non_linear|vod — 11 candidates stripped; promote to reference product] | Column right_type (STRING) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensePermitted rdf:type rdf:Property ;
    rdfs:label 'Sublicense Permitted' ;
    rdfs:comment 'Indicates whether the licensee is permitted to sublicense the rights to third parties. | Column sublicense_permitted (BOOLEAN) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:talentResidualsApplicable rdf:type rdf:Property ;
    rdfs:label 'Talent Residuals Applicable' ;
    rdfs:comment 'Indicates whether talent residual payments (reuse payments to actors, directors, writers) are triggered by this grant. | Column talent_residuals_applicable (BOOLEAN) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windowName rdf:type rdf:Property ;
    rdfs:label 'Window Name' ;
    rdfs:comment 'Named distribution window (e.g., Theatrical, Premium VOD, Pay-TV, Free-TV) that this grant falls within. Used for windowing strategy enforcement. | Column window_name (STRING) in rights.grant' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdbackId rdf:type rdf:Property ;
    rdfs:label 'Holdback Id' ;
    rdfs:comment 'Unique identifier for the holdback restriction record. Primary key. | Column holdback_id (BIGINT) in rights.holdback' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holdback .

ind:restrictedOttPlatformId rdf:type rdf:Property ;
    rdfs:label 'Restricted Ott Platform Id' ;
    rdfs:comment 'Foreign key linking to distribution.ott_platform. Business justification: Rights teams enforce platform-specific holdbacks during content windowing. holdback.restricted_platform is a denormalized text field; normalizing it to ott_platform_id enables automated holdback enfor' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OttPlatform .

ind:automatedEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Enforcement Flag' ;
    rdfs:comment 'Indicates whether this holdback restriction is automatically enforced by scheduling and distribution systems or requires manual review. | Column automated_enforcement_flag (BOOLEAN) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carriageNegotiationReference rdf:type rdf:Property ;
    rdfs:label 'Carriage Negotiation Reference' ;
    rdfs:comment 'Reference identifier to the MVPD or vMVPD carriage negotiation that established this holdback restriction. | Column carriage_negotiation_reference (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Workflow Status' ;
    rdfs:comment 'Status of the clearance workflow process that validates whether content can be scheduled or distributed despite this holdback restriction. | Column clearance_workflow_status (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Conflict Resolution Notes' ;
    rdfs:comment 'Documentation of any conflicts with other rights, windows, or holdbacks and how they were resolved. | Column conflict_resolution_notes (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total number of days the holdback restriction is in effect, calculated from start to end date. | Column duration_days (INT) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcementStatus rdf:type rdf:Property ;
    rdfs:label 'Enforcement Status' ;
    rdfs:comment 'Current enforcement state of the holdback restriction, indicating whether it is actively blocking content exploitation or has been modified. | Column enforcement_status (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Scope of exclusivity granted by this holdback, defining whether the restriction is absolute or allows limited exploitation. | Column exclusivity_scope (STRING) in rights.holdback' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User or system identifier that last modified this holdback restriction record. | Column last_modified_by (STRING) in rights.holdback' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether notification of this holdback restriction has been sent to relevant scheduling, distribution, and operations teams. | Column notification_sent_flag (BOOLEAN) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedFormat rdf:type rdf:Property ;
    rdfs:label 'Restricted Format' ;
    rdfs:comment 'Distribution format or delivery method that is restricted during the holdback period, supporting windowing strategies. [ENUM-REF-CANDIDATE: theatrical|linear_tv|svod|avod|tvod|vod|physical_media|syndication|streaming|broadcast — 10 candidates stripped; promote to reference product] | Column restricted_format (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Classification of the holdback restriction type that defines the nature of the exclusivity period. | Column restriction_type (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringWindowType rdf:type rdf:Property ;
    rdfs:label 'Triggering Window Type' ;
    rdfs:comment 'Type of content window that triggers or activates this holdback restriction, defining the sequential release strategy. [ENUM-REF-CANDIDATE: theatrical|svod|avod|tvod|linear|syndication|home_video|pay_per_view|free_tv|premium_tv — 10 candidates stripped; promote to reference product] | Column triggering_window_type (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the person or role who authorized the waiver or override of the holdback restriction. | Column waiver_approved_by (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved Date' ;
    rdfs:comment 'Date when the waiver or override of the holdback restriction was officially approved. | Column waiver_approved_date (DATE) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Business justification or explanation for waiving or overriding the holdback restriction, if applicable. | Column waiver_reason (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowingStrategyNotes rdf:type rdf:Property ;
    rdfs:label 'Windowing Strategy Notes' ;
    rdfs:comment 'Additional notes or context explaining how this holdback fits into the overall content windowing and sequential release strategy. | Column windowing_strategy_notes (STRING) in rights.holdback' ;
    rdfs:domain ind:Holdback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User or system identifier that created this holdback restriction record. | Column created_by (STRING) in rights.holdback' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which this royalty rule was approved. Nullable if not yet approved. | Column approved_date (DATE) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Flag' ;
    rdfs:comment 'Indicates whether the rights holder has audit rights to verify royalty calculations under this rule. True if audit rights are granted, False otherwise. | Column audit_rights_flag (BOOLEAN) in rights.royalty_rule' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'The financial or usage metric upon which the royalty calculation is based (e.g., gross revenue, net revenue, subscriber count, stream count, GRP). [ENUM-REF-CANDIDATE: gross_revenue|net_revenue|subscriber_count|stream_count|grp|unit_sales|advertising_revenue — 7 candidates stripped; promote to reference product] | Column calculation_basis (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Deduction Allowed Flag' ;
    rdfs:comment 'Indicates whether deductions (e.g., distribution costs, marketing expenses) are allowed before calculating the royalty. True if deductions are permitted, False otherwise. | Column deduction_allowed_flag (BOOLEAN) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Deduction Percentage' ;
    rdfs:comment 'The percentage of revenue or basis that may be deducted before applying the royalty rate. Nullable if no deduction applies. | Column deduction_percentage (DECIMAL(5,2)) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumCapAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Cap Amount' ;
    rdfs:comment 'The maximum royalty payment cap for this rule. Royalty calculations will not exceed this amount. Nullable if no cap applies. | Column maximum_cap_amount (DECIMAL(18,2)) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'The frequency at which royalty payments calculated by this rule are made (e.g., monthly, quarterly, semi-annually, annually, per event, on demand). | Column payment_frequency (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTiming rdf:type rdf:Property ;
    rdfs:label 'Payment Timing' ;
    rdfs:comment 'The timing of royalty payments relative to the calculation period (e.g., advance, arrears, upon delivery, upon release, milestone-based). | Column payment_timing (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'The unit of measure for the rate value (e.g., percentage, per stream, per subscriber, per unit, per GRP, flat amount). | Column rate_unit (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateValue rdf:type rdf:Property ;
    rdfs:label 'Rate Value' ;
    rdfs:comment 'The numeric rate or percentage applied in the royalty calculation. For percentage-based royalties, this is the percentage (e.g., 15.5 for 15.5%). For per-unit rates, this is the amount per unit. | Column rate_value (DECIMAL(18,6)) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoupmentFlag rdf:type rdf:Property ;
    rdfs:label 'Recoupment Flag' ;
    rdfs:comment 'Indicates whether this royalty rule includes recoupment provisions (e.g., advance payments must be recouped before additional royalties are paid). True if recoupment applies, False otherwise. | Column recoupment_flag (BOOLEAN) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recoupmentThreshold rdf:type rdf:Property ;
    rdfs:label 'Recoupment Threshold' ;
    rdfs:comment 'The monetary threshold that must be recouped before additional royalty payments are made. Nullable if no recoupment applies. | Column recoupment_threshold (DECIMAL(18,2)) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualFormula rdf:type rdf:Property ;
    rdfs:label 'Residual Formula' ;
    rdfs:comment 'The formula or calculation logic for residual payments to talent (actors, directors, writers) based on reuse, reruns, or secondary exploitation. Nullable if not applicable. | Column residual_formula (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Royalty Rule Status' ;
    rdfs:comment 'Current lifecycle status of the royalty rule (e.g., draft, active, suspended, expired, terminated). | Column royalty_rule_status (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyType rdf:type rdf:Property ;
    rdfs:label 'Royalty Type' ;
    rdfs:comment 'The type of royalty calculation method applied by this rule. Determines how the royalty amount is computed. | Column royalty_type (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business-assigned unique code or identifier for this royalty rule, used for reference in contracts and reporting. | Column rule_code (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name or title of the royalty rule, describing its purpose or scope (e.g., \'SVOD Revenue Share - Tier 1\', \'Per-Stream Rate - Music Sync\'). | Column rule_name (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulePriority rdf:type rdf:Property ;
    rdfs:label 'Rule Priority' ;
    rdfs:comment 'The priority or precedence of this royalty rule when multiple rules may apply to the same content or transaction. Lower numbers indicate higher priority. | Column rule_priority (INT) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'The unit of measure for the threshold value (e.g., revenue, subscriber count, stream count, unit count, GRP). | Column threshold_unit (STRING) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'The threshold value that triggers a rate tier change or special calculation logic (e.g., revenue threshold for tiered royalty rates). | Column threshold_value (DECIMAL(18,2)) in rights.royalty_rule' ;
    rdfs:domain ind:RoyaltyRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyStatementId rdf:type rdf:Property ;
    rdfs:label 'Royalty Statement Id' ;
    rdfs:comment 'Unique identifier for the royalty statement. Primary key. | Column royalty_statement_id (BIGINT) in rights.royalty_statement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyStatement .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Net adjustment amount applied to this statement for corrections, credits, or debits from prior periods. | Column adjustment_amount (DECIMAL(18,2)) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advanceRecoupmentAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Recoupment Amount' ;
    rdfs:comment 'Amount deducted from gross royalties to recoup advances previously paid to the rights holder under the agreement. | Column advance_recoupment_amount (DECIMAL(18,2)) in rights.royalty_statement' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentTitleBreakdown rdf:type rdf:Property ;
    rdfs:label 'Content Title Breakdown' ;
    rdfs:comment 'Structured breakdown of royalties by content title or asset. Stored as JSON or delimited string for detailed reporting. | Column content_title_breakdown (STRING) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'The date on which the rights holder formally disputed this royalty statement. | Column dispute_date (DATE) in rights.royalty_statement' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Explanation or reason provided by the rights holder if the statement status is disputed. Captures objections to calculations, missing revenues, or contractual interpretation issues. | Column dispute_reason (STRING) in rights.royalty_statement' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exploitationTypeBreakdown rdf:type rdf:Property ;
    rdfs:label 'Exploitation Type Breakdown' ;
    rdfs:comment 'Structured breakdown of royalties by exploitation type (theatrical, SVOD, AVOD, TVOD, linear, syndication, home video, etc.). Stored as JSON or delimited string for detailed reporting. | Column exploitation_type_breakdown (STRING) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Royalty Amount' ;
    rdfs:comment 'Total royalty amount earned by the rights holder before any deductions, recoupments, or adjustments. | Column gross_royalty_amount (DECIMAL(18,2)) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumGuaranteeShortfall rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Shortfall' ;
    rdfs:comment 'The difference between the contractual minimum guarantee and actual royalties earned for the period. A positive value indicates the rights holder is entitled to a minimum guarantee payment. | Column minimum_guarantee_shortfall (DECIMAL(18,2)) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Net Royalty Amount' ;
    rdfs:comment 'Final royalty amount payable to the rights holder after all deductions, recoupments, taxes, and adjustments. This is the amount that will be paid. | Column net_royalty_amount (DECIMAL(18,2)) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Paid Timestamp' ;
    rdfs:comment 'Date and time when payment for this royalty statement was successfully processed and remitted to the rights holder. | Column paid_timestamp (TIMESTAMP) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Reference number or transaction identifier for the payment associated with this statement, once payment has been processed. | Column payment_reference_number (STRING) in rights.royalty_statement' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date on which a disputed statement was resolved and moved to approved or paid status. | Column resolution_date (DATE) in rights.royalty_statement' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementDueDate rdf:type rdf:Property ;
    rdfs:label 'Statement Due Date' ;
    rdfs:comment 'The date by which payment of the royalties on this statement is contractually due to the rights holder. | Column statement_due_date (DATE) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementFrequency rdf:type rdf:Property ;
    rdfs:label 'Statement Frequency' ;
    rdfs:comment 'The reporting frequency for this royalty statement as defined in the underlying rights agreement. | Column statement_frequency (STRING) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementIssueDate rdf:type rdf:Property ;
    rdfs:label 'Statement Issue Date' ;
    rdfs:comment 'The date on which this royalty statement was officially issued to the rights holder. | Column statement_issue_date (DATE) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementNotes rdf:type rdf:Property ;
    rdfs:label 'Statement Notes' ;
    rdfs:comment 'Free-text notes or comments related to this royalty statement, including explanations of unusual adjustments, special circumstances, or clarifications for the rights holder. | Column statement_notes (STRING) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'Externally-known unique business identifier for this royalty statement, used for reference in correspondence and payment processing. | Column statement_number (STRING) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period End Date' ;
    rdfs:comment 'The last date of the reporting period covered by this royalty statement. | Column statement_period_end_date (DATE) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period Start Date' ;
    rdfs:comment 'The first date of the reporting period covered by this royalty statement. | Column statement_period_start_date (DATE) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementStatus rdf:type rdf:Property ;
    rdfs:label 'Statement Status' ;
    rdfs:comment 'Current lifecycle status of the royalty statement. Draft statements are under review, approved statements are ready for payment, disputed statements have objections from rights holders, paid statements have been settled, and cancelled statements have been voided. | Column statement_status (STRING) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryBreakdown rdf:type rdf:Property ;
    rdfs:label 'Territory Breakdown' ;
    rdfs:comment 'Structured breakdown of royalties by geographic territory or market. Stored as JSON or delimited string for detailed reporting. | Column territory_breakdown (STRING) in rights.royalty_statement' ;
    rdfs:domain ind:RoyaltyStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Tax amount withheld from royalty payment as required by applicable tax treaties and regulations. | Column withholding_tax_amount (DECIMAL(18,2)) in rights.royalty_statement' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyStatementLineId rdf:type rdf:Property ;
    rdfs:label 'Royalty Statement Line Id' ;
    rdfs:comment 'Unique identifier for the royalty statement line item. Primary key for this entity. | Column royalty_statement_line_id (BIGINT) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentsAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustments Amount' ;
    rdfs:comment 'Additional adjustments applied to the royalty calculation, such as corrections from prior periods, contractual bonuses, penalties, or dispute resolutions. Can be positive or negative. | Column adjustments_amount (DECIMAL(18,2)) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking this royalty line to source exploitation data, usage reports, or billing records. Enables granular audit trail and dispute resolution. | Column audit_trail_reference (STRING) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculatedRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Calculated Royalty Amount' ;
    rdfs:comment 'Royalty amount calculated by applying the royalty rate to the net revenue. Represents the gross royalty obligation before advance recoupment or adjustments. | Column calculated_royalty_amount (DECIMAL(18,2)) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Deductions Amount' ;
    rdfs:comment 'Total deductions applied to gross revenue before calculating royalty base. May include distribution fees, marketing costs, platform fees, or other contractually allowed deductions. | Column deductions_amount (DECIMAL(18,2)) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current status of any dispute or query raised by the rights holder regarding this royalty line. Tracks the resolution workflow for contested royalty calculations. | Column dispute_status (STRING) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exploitationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Exploitation Period End Date' ;
    rdfs:comment 'End date of the period during which the exploitation activity occurred. Defines the end of the reporting window for this royalty line. | Column exploitation_period_end_date (DATE) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exploitationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Exploitation Period Start Date' ;
    rdfs:comment 'Start date of the period during which the exploitation activity occurred. Defines the beginning of the reporting window for this royalty line. | Column exploitation_period_start_date (DATE) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exploitationType rdf:type rdf:Property ;
    rdfs:label 'Exploitation Type' ;
    rdfs:comment 'Type of content exploitation that generated this royalty. Indicates the distribution channel or business model under which the content was used. [ENUM-REF-CANDIDATE: linear_broadcast|svod|avod|tvod|theatrical|syndication|home_video|digital_download — 8 candidates stripped; promote to reference product] | Column exploitation_type (STRING) in rights.royalty_statement_line' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Revenue Amount' ;
    rdfs:comment 'Total gross revenue generated from the exploitation activity before any deductions, adjustments, or royalty calculations. Represents the top-line revenue attributable to this content asset. | Column gross_revenue_amount (DECIMAL(18,2)) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdbackStatus rdf:type rdf:Property ;
    rdfs:label 'Holdback Status' ;
    rdfs:comment 'Status of any holdback or exclusivity period applicable to this exploitation. Indicates whether the content was exploited within or outside of contractual holdback restrictions. | Column holdback_status (STRING) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iswcCode rdf:type rdf:Property ;
    rdfs:label 'Iswc Code' ;
    rdfs:comment 'ISWC code for composition identification' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPayableAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payable Amount' ;
    rdfs:comment 'Final net amount payable to the rights holder for this line item after all deductions, advance recoupment, and adjustments. This is the amount that will be paid out. | Column net_payable_amount (DECIMAL(18,2)) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Net Revenue Amount' ;
    rdfs:comment 'Net revenue after deductions, serving as the base for royalty calculation. Calculated as gross_revenue_amount minus deductions_amount. | Column net_revenue_amount (DECIMAL(18,2)) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualType rdf:type rdf:Property ;
    rdfs:label 'Residual Type' ;
    rdfs:comment 'Classification of residual payment type for talent royalties. Indicates the nature of the reuse payment under guild agreements (SAG-AFTRA, WGA, DGA). [ENUM-REF-CANDIDATE: initial_use|rerun|foreign|supplemental|new_media|streaming|not_applicable — 7 candidates stripped; promote to reference product] | Column residual_type (STRING) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsHolderName rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Name' ;
    rdfs:comment 'Name of the rights holder receiving the royalty. Denormalized for reporting and audit trail purposes. | Column rights_holder_name (STRING) in rights.royalty_statement_line' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percentage' ;
    rdfs:comment 'Percentage rate applied to the royalty base to calculate the royalty amount. Derived from the underlying rights agreement and may vary by territory, platform, and exploitation type. | Column royalty_rate_percentage (DECIMAL(5,2)) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsExploited rdf:type rdf:Property ;
    rdfs:label 'Units Exploited' ;
    rdfs:comment 'Quantity of exploitation units for this line item. Interpretation depends on exploitation type: streams for SVOD/AVOD, broadcasts for linear, downloads for TVOD, tickets for theatrical. | Column units_exploited (DECIMAL(18,2)) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windowType rdf:type rdf:Property ;
    rdfs:label 'Window Type' ;
    rdfs:comment 'Distribution window classification under which this exploitation occurred. Reflects the sequential release strategy and holdback periods defined in the rights agreement. [ENUM-REF-CANDIDATE: theatrical|home_video|pay_per_view|premium_cable|basic_cable|broadcast|svod|avod|free_streaming — 9 candidates stripped; promote to reference product] | Column window_type (STRING) in rights.royalty_statement_line' ;
    rdfs:domain ind:RoyaltyStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualId rdf:type rdf:Property ;
    rdfs:label 'Residual Id' ;
    rdfs:comment 'Unique identifier for the residual payment obligation record. Primary key. | Column residual_id (BIGINT) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backendRevenueSource rdf:type rdf:Property ;
    rdfs:label 'Backend Revenue Source' ;
    rdfs:comment 'Source of backend revenue for participation calculation' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculatedResidualAmount rdf:type rdf:Property ;
    rdfs:label 'Calculated Residual Amount' ;
    rdfs:comment 'The computed residual payment amount owed to the talent based on the formula type, calculation basis, and applicable rates. | Column calculated_residual_amount (DECIMAL(18,2)) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationBasisAmount rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis Amount' ;
    rdfs:comment 'The base revenue or gross receipts amount used as the input to the residual formula calculation. | Column calculation_basis_amount (DECIMAL(18,2)) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationBasisCurrency rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the calculation basis amount (e.g., USD, GBP, CAD). | Column calculation_basis_currency (STRING) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'The date when the residual amount was calculated by the royalty system. | Column calculation_date (DATE) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractCycle rdf:type rdf:Property ;
    rdfs:label 'Contract Cycle' ;
    rdfs:comment 'The collective bargaining agreement cycle or contract period under which this residual is calculated (e.g., 2020-2023, 2023-2026). | Column contract_cycle (STRING) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the calculated residual amount (e.g., USD, GBP, CAD). | Column currency (STRING) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exhibitionCount rdf:type rdf:Property ;
    rdfs:label 'Exhibition Count' ;
    rdfs:comment 'The number of times the content was exhibited or broadcast during the residual calculation period, used for per-exhibition or tiered formulas. | Column exhibition_count (INT) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exploitationEndDate rdf:type rdf:Property ;
    rdfs:label 'Exploitation End Date' ;
    rdfs:comment 'The date when the content exploitation period that triggered this residual ended. Nullable for ongoing exploitation. | Column exploitation_end_date (DATE) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exploitationStartDate rdf:type rdf:Property ;
    rdfs:label 'Exploitation Start Date' ;
    rdfs:comment 'The date when the content exploitation period that triggered this residual began (e.g., first streaming availability date, first rerun air date). | Column exploitation_start_date (DATE) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formulaType rdf:type rdf:Property ;
    rdfs:label 'Formula Type' ;
    rdfs:comment 'The calculation method used to determine the residual amount (fixed amount, percentage of gross receipts, percentage of distributor gross, tiered scale based on exhibition count, per-exhibition fee, minimum guarantee). | Column formula_type (STRING) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Guild Report Submission Date' ;
    rdfs:comment 'The date when the residual payment was reported to the guild or union. Nullable if not yet reported. | Column guild_report_submission_date (DATE) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guildReportSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Guild Report Submitted Flag' ;
    rdfs:comment 'Indicates whether this residual payment has been included in the mandatory guild reporting submission (True/False). | Column guild_report_submitted_flag (BOOLEAN) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guildUnionCode rdf:type rdf:Property ;
    rdfs:label 'Guild Union Code' ;
    rdfs:comment 'The guild or union governing this residual obligation (SAG-AFTRA for actors, WGA for writers, DGA for directors, IATSE for crew, AFM for musicians, ACTRA for Canadian talent). [ENUM-REF-CANDIDATE: SAG-AFTRA|WGA|DGA|IATSE|AFM|ACTRA|OTHER — 7 candidates stripped; promote to reference product] | Column guild_union_code (STRING) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'The net residual payment amount disbursed to the talent after withholding taxes and any other deductions. | Column net_payment_amount (DECIMAL(18,2)) in rights.residual' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationLinkedFlag rdf:type rdf:Property ;
    rdfs:label 'Participation Linked Flag' ;
    rdfs:comment 'Indicates if residual is linked to a participation deal' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which the residual payment must be made to the talent or guild, per the collective bargaining agreement payment schedule. | Column payment_due_date (DATE) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'The percentage rate applied to the calculation basis when the formula type is percentage-based (e.g., 0.0350 for 3.5%). | Column percentage (DECIMAL(5,4)) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The financial or royalty reporting period to which this residual obligation belongs (e.g., Q1-2024, 2024-H1), used for guild reporting and financial reconciliation. | Column reporting_period (STRING) in rights.residual' ;
    rdfs:domain ind:Residual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'The user identifier or system account that last modified this residual payment record. | Column updated_by_user (STRING) in rights.residual' ;
    rdfs:domain ind:Rights ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Approved Date' ;
    rdfs:comment 'Date when the music synchronization license was officially cleared and approved for use. Nullable if not yet approved. | Column clearance_approved_date (DATE) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceNotes rdf:type rdf:Property ;
    rdfs:label 'Clearance Notes' ;
    rdfs:comment 'Free-text notes documenting clearance workflow details, restrictions, special conditions, or communications with rights holders during the licensing process. | Column clearance_notes (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceRequestedDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Requested Date' ;
    rdfs:comment 'Date when the music synchronization license clearance was initially requested from the rights holder or clearance team. | Column clearance_requested_date (DATE) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:composerName rdf:type rdf:Property ;
    rdfs:label 'Composer Name' ;
    rdfs:comment 'Name of the composer or songwriter who created the musical composition. | Column composer_name (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositionTitle rdf:type rdf:Property ;
    rdfs:label 'Composition Title' ;
    rdfs:comment 'The title of the musical composition or work being licensed for synchronization use. | Column composition_title (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cueSheetRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cue Sheet Required Flag' ;
    rdfs:comment 'Indicates whether a cue sheet (detailed music usage report) must be filed with performance rights organizations for this license, typically required for broadcast and public performance. | Column cue_sheet_required_flag (BOOLEAN) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'License Fee Amount' ;
    rdfs:comment 'One-time or upfront fee paid to the rights holder for the synchronization license. Does not include ongoing royalties. | Column license_fee_amount (DECIMAL(15,2)) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenseFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'License Fee Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the license fee amount (e.g., USD, GBP, EUR). | Column license_fee_currency (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Externally-known unique identifier or reference number for this music synchronization license, typically assigned by the rights management system or licensing authority. | Column license_number (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Classification of the music synchronization license indicating the scope and nature of rights granted (master use for sound recording, synchronization for composition, blanket for multiple works, per-title for single work, mechanical for reproduction, performance for public performance). | Column license_type (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedPlatforms rdf:type rdf:Property ;
    rdfs:label 'Licensed Platforms' ;
    rdfs:comment 'Comma-separated list of distribution platforms and channels where the licensed music may be used (e.g., linear broadcast, SVOD, AVOD, TVOD, theatrical, home video, social media). | Column licensed_platforms (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proAffiliation rdf:type rdf:Property ;
    rdfs:label 'Pro Affiliation' ;
    rdfs:comment 'Name of the Performance Rights Organization (e.g., ASCAP, BMI, SESAC, PRS, SOCAN) with which the composer or publisher is affiliated for performance royalty collection. | Column pro_affiliation (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictions rdf:type rdf:Property ;
    rdfs:label 'Restrictions' ;
    rdfs:comment 'Free-text description of any restrictions, limitations, or special conditions attached to this music synchronization license (e.g., no use in advertising, no use with controversial content, limited to specific episodes). | Column restrictions (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyBasis rdf:type rdf:Property ;
    rdfs:label 'Royalty Basis' ;
    rdfs:comment 'The metric or revenue base upon which ongoing royalties are calculated (gross revenue, net revenue, per-stream count, per-download, per-unit sold, or flat fee with no ongoing royalties). | Column royalty_basis (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sublicensePermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Sublicense Permitted Flag' ;
    rdfs:comment 'Indicates whether the licensee is permitted to sublicense the music synchronization rights to third parties (e.g., for syndication or international distribution partners). | Column sublicense_permitted_flag (BOOLEAN) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageType rdf:type rdf:Property ;
    rdfs:label 'Usage Type' ;
    rdfs:comment 'Classification of how the music is used within the content asset (background music, theme song, featured performance, promotional use, trailer, opening/closing credits). | Column usage_type (STRING) in rights.music_sync_license' ;
    rdfs:domain ind:MusicSyncLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advertisingCampaignId rdf:type rdf:Property ;
    rdfs:label 'Advertising Campaign Id' ;
    rdfs:comment 'Foreign key linking to advertising.campaign. Business justification: Advertising campaigns booking licensed content trigger clearance requests for talent, music, and holdback compliance. Rights clearance teams need to know which campaign initiated the request to priori' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdvertisingCampaign .

ind:reachFrequencyReportId rdf:type rdf:Property ;
    rdfs:label 'Reach Frequency Report Id' ;
    rdfs:comment 'Foreign key linking to audience.reach_frequency_report. Business justification: Clearance analysts validate content placement against audience delivery thresholds before approving air. Linking clearance_request to reach_frequency_report allows the clearance workflow to reference ' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReachFrequencyReport .

ind:analystNotes rdf:type rdf:Property ;
    rdfs:label 'Analyst Notes' ;
    rdfs:comment 'Free-text notes and observations recorded by the clearance analyst during review. May include references to specific contract clauses, communications with rights holders, or special handling instructions. | Column analyst_notes (STRING) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingCategory rdf:type rdf:Property ;
    rdfs:label 'Blocking Category' ;
    rdfs:comment 'Classification of the primary reason for clearance denial. Enables reporting on common rights obstacles and process improvement. [ENUM-REF-CANDIDATE: holdback_period|territory_restriction|window_unavailable|rights_expired|music_sync_missing|talent_approval_required|residuals_unpaid|clearance_incomplete — promote to reference product] | Column blocking_category (STRING) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'Detailed explanation of why a clearance request was blocked or denied. May reference specific contract clauses, holdback periods, territorial restrictions, or missing rights. Null if request is cleared. | Column blocking_reason (STRING) in rights.clearance_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceDecision rdf:type rdf:Property ;
    rdfs:label 'Clearance Decision' ;
    rdfs:comment 'Final determination made by the clearance analyst regarding whether the content may be exploited as requested. Approved with conditions may require specific usage restrictions or additional payments. | Column clearance_decision (STRING) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalRequirements rdf:type rdf:Property ;
    rdfs:label 'Conditional Requirements' ;
    rdfs:comment 'Specific conditions or restrictions that must be met for conditional clearance approval. May include required credits, usage limitations, geographic blackouts, or additional royalty payments. | Column conditional_requirements (STRING) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Explanation of why the clearance request required escalation beyond standard analyst review. May reference contract ambiguity, conflicting rights claims, or high-value strategic decisions. | Column escalation_reason (STRING) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the clearance request was escalated to senior rights management or legal counsel due to complexity, ambiguity, or high business impact. Null if no escalation occurred. | Column escalation_timestamp (TIMESTAMP) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedAudienceReach rdf:type rdf:Property ;
    rdfs:label 'Estimated Audience Reach' ;
    rdfs:comment 'Projected number of unique viewers or households expected to access the content in the requested exploitation. Used for royalty calculations and rights holder reporting. | Column estimated_audience_reach (BIGINT) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedGrp rdf:type rdf:Property ;
    rdfs:label 'Estimated Grp' ;
    rdfs:comment 'Projected Gross Rating Point value for the scheduled broadcast or streaming event. GRP represents the sum of ratings achieved by the content and may trigger tiered royalty obligations. | Column estimated_grp (DECIMAL(10,2)) in rights.clearance_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedResidualsAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Residuals Amount' ;
    rdfs:comment 'Projected total residual payments owed to talent if the clearance is approved and content is distributed. Used for financial planning and budget approval workflows. | Column estimated_residuals_amount (DECIMAL(15,2)) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:integrationStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Status' ;
    rdfs:comment 'Status of data synchronization between Rightsline clearance system and downstream scheduling and playout systems (Ericsson MediaFirst). Ensures cleared content is automatically released to scheduling workflows. | Column integration_status (STRING) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:musicClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Music Clearance Required' ;
    rdfs:comment 'Indicates whether separate music synchronization licenses must be verified before content can be cleared for distribution. True if content contains licensed music requiring additional clearance. | Column music_clearance_required (BOOLEAN) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Human-readable business identifier for the clearance request, typically formatted as CLR-YYYYMMDD sequence for tracking and reference in scheduling and distribution workflows. | Column request_number (STRING) in rights.clearance_request' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Submitted Timestamp' ;
    rdfs:comment 'Date and time when the clearance request was initially submitted into the workflow system. Marks the start of the clearance review lifecycle and SLA clock. | Column request_submitted_timestamp (TIMESTAMP) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedAirDate rdf:type rdf:Property ;
    rdfs:label 'Requested Air Date' ;
    rdfs:comment 'The target date when the content is scheduled to be broadcast, streamed, or published. Critical for verifying that rights are available within the requested window and that no holdback periods are violated. | Column requested_air_date (DATE) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedAirTime rdf:type rdf:Property ;
    rdfs:label 'Requested Air Time' ;
    rdfs:comment 'Precise timestamp for the intended broadcast or streaming start time, including time zone. Used for daypart-specific rights verification and scheduling coordination. | Column requested_air_time (TIMESTAMP) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestingDepartment rdf:type rdf:Property ;
    rdfs:label 'Requesting Department' ;
    rdfs:comment 'Business unit or department initiating the clearance request. Identifies which operational area needs rights verification before proceeding with content exploitation. | Column requesting_department (STRING) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualsTriggered rdf:type rdf:Property ;
    rdfs:label 'Residuals Triggered' ;
    rdfs:comment 'Indicates whether the requested exploitation will trigger residual payments to talent per guild agreements. True if reuse payments are required for this distribution window. | Column residuals_triggered (BOOLEAN) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the clearance request was finalized with a cleared, blocked, or conditionally cleared decision. Marks the end of the clearance workflow and enables SLA compliance measurement. | Column resolution_timestamp (TIMESTAMP) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Started Timestamp' ;
    rdfs:comment 'Date and time when a clearance analyst began active review of the request. Used to measure queue time and analyst response performance. | Column review_started_timestamp (TIMESTAMP) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaMet rdf:type rdf:Property ;
    rdfs:label 'Sla Met' ;
    rdfs:comment 'Indicates whether the clearance request was resolved within the defined SLA target hours. Used for operational performance reporting and process improvement. | Column sla_met (BOOLEAN) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Number of business hours within which the clearance request must be resolved per service level agreement. Varies by priority level (urgent requests have shorter SLA targets). | Column sla_target_hours (INT) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:talentApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Talent Approval Required' ;
    rdfs:comment 'Indicates whether talent (actors, directors, producers) approval or notification is contractually required before the requested exploitation. True if talent has approval rights per guild agreements or individual contracts. | Column talent_approval_required (BOOLEAN) in rights.clearance_request' ;
    rdfs:domain ind:ClearanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bankAccountName rdf:type rdf:Property ;
    rdfs:label 'Bank Account Name' ;
    rdfs:comment 'Name on the bank account designated for royalty payments. Must match legal entity name for payment processing compliance. | Column bank_account_name (STRING) in rights.holder' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Bank account number for royalty payment remittance. Encrypted at rest and in transit per PCI DSS requirements. | Column bank_account_number (STRING) in rights.holder' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'Bank routing number or SWIFT/BIC code for international wire transfers. Used for automated royalty payment processing. | Column bank_routing_number (STRING) in rights.holder' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearancePriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Clearance Priority Level' ;
    rdfs:comment 'Priority level assigned to clearance requests for content from this rights holder. VIP and critical levels receive accelerated processing. | Column clearance_priority_level (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum credit exposure allowed for advance payments or minimum guarantees to this rights holder. Used for financial risk management. | Column credit_limit_amount (DECIMAL(15,2)) in rights.holder' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultRoyaltyRate rdf:type rdf:Property ;
    rdfs:label 'Default Royalty Rate' ;
    rdfs:comment 'Default royalty rate percentage applied to new agreements with this rights holder. Can be overridden at the contract level. | Column default_royalty_rate (DECIMAL(5,2)) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the rights holder by organizational type. Determines applicable contract templates, royalty calculation methods, and clearance workflows. [ENUM-REF-CANDIDATE: film_studio|production_company|music_publisher|performing_rights_organization|talent_guild|record_label|news_agency|individual_creator — 8 candidates stripped; promote to reference product] | Column entity_type (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityPreference rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Preference' ;
    rdfs:comment 'Rights holder\'s stated preference for exclusivity terms in licensing agreements. Influences windowing strategy and holdback negotiations. | Column exclusivity_preference (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guildAffiliation rdf:type rdf:Property ;
    rdfs:label 'Guild Affiliation' ;
    rdfs:comment 'Name of talent guild or performing rights organization (PRO) that this rights holder is affiliated with. Determines residual payment rules and reporting requirements. [ENUM-REF-CANDIDATE: sag_aftra|wga|dga|afm|ascap|bmi|sesac|gema|prs|socan — promote to reference product] | Column guild_affiliation (STRING) in rights.holder' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGuaranteeThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Threshold' ;
    rdfs:comment 'Minimum guarantee amount threshold below which this rights holder will not enter licensing agreements. Used for deal structuring and negotiation. | Column minimum_guarantee_threshold (DECIMAL(15,2)) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mostFavoredNationsFlag rdf:type rdf:Property ;
    rdfs:label 'Most Favored Nations Flag' ;
    rdfs:comment 'Indicates whether this rights holder has most favored nations clause requiring rate parity with other similar rights holders. True triggers rate comparison workflows. | Column most_favored_nations_flag (BOOLEAN) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'Three-letter ISO currency code representing the rights holder\'s preferred currency for royalty payments and contract valuations. | Column preferred_currency (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrantIdentifier rdf:type rdf:Property ;
    rdfs:label 'Registrant Identifier' ;
    rdfs:comment 'The ISAN or ISRC registrant identifier assigned to the rights holder by the respective international registration authority. Used for global rights tracking and content identification. | Column registrant_identifier (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipEndDate rdf:type rdf:Property ;
    rdfs:label 'Relationship End Date' ;
    rdfs:comment 'Date when the business relationship with this rights holder was terminated or suspended. Null for active relationships. | Column relationship_end_date (DATE) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date when the business relationship with this rights holder was established. Used for historical reporting and relationship tenure analysis. | Column relationship_start_date (DATE) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsHolderCode rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Code' ;
    rdfs:comment 'Internal business identifier code assigned to the rights holder for operational reference and system integration across Rightsline and billing systems. | Column rights_holder_code (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsHolderStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Status' ;
    rdfs:comment 'Current lifecycle status of the rights holder relationship. Active status is required for new license agreements and royalty payments. | Column rights_holder_status (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Tax identification number for the rights holder in their jurisdiction of incorporation. Required for tax reporting and withholding compliance. | Column tax_identification_number (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithholdingClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Classification' ;
    rdfs:comment 'Tax withholding classification for royalty payments. Determines applicable withholding rates based on tax treaties and domestic regulations. | Column tax_withholding_classification (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithholdingRate rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Rate' ;
    rdfs:comment 'Applicable tax withholding rate percentage for royalty payments to this rights holder. Derived from tax treaties and domestic law based on withholding classification. | Column tax_withholding_rate (DECIMAL(5,2)) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:territoryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Territory Of Incorporation' ;
    rdfs:comment 'Three-letter ISO country code representing the legal jurisdiction where the rights holder entity is incorporated or registered. Determines applicable tax treaties and withholding requirements. | Column territory_of_incorporation (STRING) in rights.holder' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useCaseFitnessGaps rdf:type rdf:Property ;
    rdfs:label 'Use Case Fitness Gaps' ;
    rdfs:comment 'Documents analytics use-case fitness gaps requiring A1 (news), A2 (sports), A3 (music) entity additions: Sports right-holder analytics (2-star): A2 sports entities (sports_league, sports_event, sports_team, athlete, event_blackout_rule); Newsroom analytics (2-star): A1 news entities (news_story, wire_ingest, byline_credit, breaking_news_event, editorial_workflow_state); Music label catalog & royalties (2-star): A3 composition/master split (composition, master_recording, release, publisher, pro_affiliation)' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adInventoryId rdf:type rdf:Property ;
    rdfs:label 'Ad Inventory Id' ;
    rdfs:comment 'Unique identifier for the advertising inventory record. Primary key. | Column ad_inventory_id (BIGINT) in advertising.ad_inventory' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdInventory .

ind:adTitleId rdf:type rdf:Property ;
    rdfs:label 'Ad Title Id' ;
    rdfs:comment 'Foreign key linking to content.title. Business justification: Inventory is generated from title airings. Business process: inventory forecasting by title, avails management, sell-through reporting, title-level CPM pricing, program-based inventory allocation. | Column title_id (BIGINT) in content.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Title .

ind:nielsenRatingId rdf:type rdf:Property ;
    rdfs:label 'Nielsen Rating Id' ;
    rdfs:comment 'Foreign key linking to audience.nielsen_rating. Business justification: Ad inventory pricing and GRP/TRP estimates are directly derived from Nielsen rating records. Linking ad_inventory to the specific Nielsen rating record enables rate card validation, inventory audit tr' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NielsenRating .

ind:rateCardId rdf:type rdf:Property ;
    rdfs:label 'Rate Card Id' ;
    rdfs:comment 'Foreign key linking to advertising.rate_card. Business justification: ad_inventory carries denormalized rate card pricing fields (rate_card_cpm, rate_card_cprp) that reference a specific rate card definition. Adding rate_card_id FK normalizes this reference, allowing th' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCard .

ind:advertiserRestrictions rdf:type rdf:Property ;
    rdfs:label 'Advertiser Restrictions' ;
    rdfs:comment 'Comma-separated list of advertiser categories or specific advertisers that are restricted from purchasing this inventory due to content, competitive, or regulatory reasons. | Column advertiser_restrictions (STRING) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSegmentTargeting rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Targeting' ;
    rdfs:comment 'JSON-encoded audience segment targeting criteria for addressable/programmatic inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutMarkets rdf:type rdf:Property ;
    rdfs:label 'Blackout Markets' ;
    rdfs:comment 'Comma-separated list of designated market areas (DMA) or geographic regions where this inventory cannot be sold due to blackout restrictions. | Column blackout_markets (STRING) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandSafetyTier rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Tier' ;
    rdfs:comment 'Brand safety classification tier' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contextualCategory rdf:type rdf:Property ;
    rdfs:label 'Contextual Category' ;
    rdfs:comment 'IAB contextual category for targeting' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domainExpansionMarker rdf:type rdf:Property ;
    rdfs:label 'Domain Expansion Marker' ;
    rdfs:comment 'Marker attribute indicating advertising domain expansion' ;
    rdfs:domain ind:Advertising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedImpressions rdf:type rdf:Property ;
    rdfs:label 'Estimated Impressions' ;
    rdfs:comment 'The projected number of advertising impressions (individual ad views) this inventory will deliver, based on historical audience data. | Column estimated_impressions (BIGINT) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedReach rdf:type rdf:Property ;
    rdfs:label 'Estimated Reach' ;
    rdfs:comment 'The projected unique audience count (reach) that will be exposed to advertising in this inventory slot at least once. | Column estimated_reach (BIGINT) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedTrp rdf:type rdf:Property ;
    rdfs:label 'Estimated Trp' ;
    rdfs:comment 'The estimated target rating point (TRP) delivery for this inventory, representing the rating within a specific demographic target audience. TRP is used for targeted advertising campaigns. | Column estimated_trp (DECIMAL(8,2)) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstPartyDataEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'First Party Data Eligible Flag' ;
    rdfs:comment 'Indicates if inventory is eligible for first-party data targeting' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heldUnits rdf:type rdf:Property ;
    rdfs:label 'Held Units' ;
    rdfs:comment 'The number of advertising units currently held or reserved pending final commitment, typically during proposal negotiation. | Column held_units (INT) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryCode rdf:type rdf:Property ;
    rdfs:label 'Inventory Code' ;
    rdfs:comment 'Unique business identifier for this inventory slot, used in sales proposals and trafficking systems. | Column inventory_code (STRING) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryDate rdf:type rdf:Property ;
    rdfs:label 'Inventory Date' ;
    rdfs:comment 'The specific broadcast date for which this inventory is available. | Column inventory_date (DATE) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventoryEndTime rdf:type rdf:Property ;
    rdfs:label 'Inventory End Time' ;
    rdfs:comment 'The precise end time of the inventory window, including time zone information. | Column inventory_end_time (TIMESTAMP) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryStartTime rdf:type rdf:Property ;
    rdfs:label 'Inventory Start Time' ;
    rdfs:comment 'The precise start time of the inventory window, including time zone information. | Column inventory_start_time (TIMESTAMP) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current lifecycle status of the advertising inventory: available for sale, held pending commitment, sold and committed, preempted for higher-priority content, or blocked due to restrictions. | Column inventory_status (STRING) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryType rdf:type rdf:Property ;
    rdfs:label 'Inventory Type' ;
    rdfs:comment 'Classification of the advertising inventory format: linear broadcast spot, video-on-demand (VOD) ad position, dynamic ad insertion (DAI) slot, free ad-supported streaming television (FAST) pod, or over-the-top (OTT) impression. | Column inventory_type (STRING) in advertising.ad_inventory' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preemptible rdf:type rdf:Property ;
    rdfs:label 'Preemptible' ;
    rdfs:comment 'Indicates whether this inventory can be preempted (bumped) for higher-priority programming or advertising. Preemptible inventory is typically sold at lower rates. | Column preemptible (BOOLEAN) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'The pricing tier classification for this inventory based on audience quality and demand: premium (highest value), standard, value, or remnant (lowest value, unsold inventory). | Column pricing_tier (STRING) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Programmatic Eligible Flag' ;
    rdfs:comment 'Indicates if inventory is available for programmatic buying' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateCardCprp rdf:type rdf:Property ;
    rdfs:label 'Rate Card Cprp' ;
    rdfs:comment 'The published rate card cost per rating point (CPRP) for this inventory. CPRP is used in broadcast television pricing based on audience ratings. | Column rate_card_cprp (DECIMAL(12,2)) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingAvails rdf:type rdf:Property ;
    rdfs:label 'Remaining Avails' ;
    rdfs:comment 'The number of advertising units still available for sale, calculated as total available minus sold and held units. | Column remaining_avails (INT) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesCategory rdf:type rdf:Property ;
    rdfs:label 'Sales Category' ;
    rdfs:comment 'The sales market category for this inventory: upfront (advance sales event), scatter (last-minute sales), local, national, digital, or programmatic. | Column sales_category (STRING) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soldUnits rdf:type rdf:Property ;
    rdfs:label 'Sold Units' ;
    rdfs:comment 'The number of advertising units that have been sold and committed to advertisers. | Column sold_units (INT) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAvailableUnits rdf:type rdf:Property ;
    rdfs:label 'Total Available Units' ;
    rdfs:comment 'The total number of advertising units (spots or impressions) available for sale in this inventory record. | Column total_available_units (INT) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Unit Duration Seconds' ;
    rdfs:comment 'The standard duration in seconds for each advertising unit in this inventory (e.g., 15, 30, 60 seconds). | Column unit_duration_seconds (INT) in advertising.ad_inventory' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:viewabilityThreshold rdf:type rdf:Property ;
    rdfs:label 'Viewability Threshold' ;
    rdfs:comment 'Minimum viewability percentage required' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:panelId rdf:type rdf:Property ;
    rdfs:label 'Panel Id' ;
    rdfs:comment 'Foreign key linking to audience.panel. Business justification: Rate cards specify which measurement panel (e.g., Nielsen national people meter vs. local market panel) underpins GRP/TRP guarantees and minimum audience guarantees. This link is required for MRC-accr' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Panel .

ind:addressablePremiumPct rdf:type rdf:Property ;
    rdfs:label 'Addressable Premium Pct' ;
    rdfs:comment 'Premium percentage for addressable inventory' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpmBasis rdf:type rdf:Property ;
    rdfs:label 'Cpm Basis' ;
    rdfs:comment 'Cost per thousand impressions or viewers that the rate is based on. CPM is a standard metric in advertising pricing used to normalize rates across different audience sizes. | Column cpm_basis (DECIMAL(12,2)) in advertising.rate_card' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctvRatePremium rdf:type rdf:Property ;
    rdfs:label 'Ctv Rate Premium' ;
    rdfs:comment 'Premium rate for connected TV inventory' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountEligibility rdf:type rdf:Property ;
    rdfs:label 'Discount Eligibility' ;
    rdfs:comment 'Description of volume discounts, frequency discounts, or package deals that can be applied to this rate card for qualifying advertisers. | Column discount_eligibility (STRING) in advertising.rate_card' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyCapDiscount rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Discount' ;
    rdfs:comment 'Discount applied when frequency caps are accepted' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'Geographic market or Designated Market Area (DMA) to which the rate card applies. Can be national, regional, or local market identifier. | Column geographic_market (STRING) in advertising.rate_card' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossRate rdf:type rdf:Property ;
    rdfs:label 'Gross Rate' ;
    rdfs:comment 'Published rate for the ad spot before any discounts, commissions, or agency fees are applied. This is the list price used as the baseline for negotiations. | Column gross_rate (DECIMAL(15,2)) in advertising.rate_card' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodPolicy rdf:type rdf:Property ;
    rdfs:label 'Makegood Policy' ;
    rdfs:comment 'Policy describing conditions under which makegoods (compensatory ad spots) will be provided if audience guarantees are not met or technical issues occur. | Column makegood_policy (STRING) in advertising.rate_card' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAudienceGuarantee rdf:type rdf:Property ;
    rdfs:label 'Minimum Audience Guarantee' ;
    rdfs:comment 'Minimum guaranteed audience size (in thousands) for the daypart and demographic. If actual audience falls below this threshold, makegoods may be required. | Column minimum_audience_guarantee (INT) in advertising.rate_card' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobileRateModifier rdf:type rdf:Property ;
    rdfs:label 'Mobile Rate Modifier' ;
    rdfs:comment 'Rate modifier for mobile device inventory' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRate rdf:type rdf:Property ;
    rdfs:label 'Net Rate' ;
    rdfs:comment 'Rate after standard agency commission (typically 15%) and other standard deductions are applied. This is the effective rate paid by the advertiser. | Column net_rate (DECIMAL(15,2)) in advertising.rate_card' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pmpDealRate rdf:type rdf:Property ;
    rdfs:label 'Pmp Deal Rate' ;
    rdfs:comment 'Negotiated rate for private marketplace deals' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preemptionPriority rdf:type rdf:Property ;
    rdfs:label 'Preemption Priority' ;
    rdfs:comment 'Indicates whether spots purchased at this rate can be preempted (bumped) for higher-paying advertisers. Non-preemptible rates are premium, while preemptible rates offer discounts but risk being moved or cancelled. | Column preemption_priority (STRING) in advertising.rate_card' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticFloorCpm rdf:type rdf:Property ;
    rdfs:label 'Programmatic Floor Cpm' ;
    rdfs:comment 'Minimum CPM floor price for programmatic/RTB transactions' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programmaticRateModifier rdf:type rdf:Property ;
    rdfs:label 'Programmatic Rate Modifier' ;
    rdfs:comment 'Rate modifier for programmatic vs direct sales' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCardNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Card Number' ;
    rdfs:comment 'Business identifier for the rate card, used for external reference and communication with sales teams and advertisers. Typically follows format RC-YYYYNNNN. | Column rate_card_number (STRING) in advertising.rate_card' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Card Status' ;
    rdfs:comment 'Current lifecycle status of the rate card indicating its operational state and usability for ad order entry. | Column rate_card_status (STRING) in advertising.rate_card' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the rate amounts (e.g., USD, GBP, EUR). | Column rate_currency_code (STRING) in advertising.rate_card' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the rate card by sales market type. Upfront rates are negotiated in advance for the broadcast year, scatter rates are for last-minute inventory, package rates bundle multiple spots, digital rates apply to OTT/streaming, sponsorship rates for integrated content, and remnant rates for unsold inventory. | Column rate_type (STRING) in advertising.rate_card' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalityFactor rdf:type rdf:Property ;
    rdfs:label 'Seasonality Factor' ;
    rdfs:comment 'Multiplier applied to base rates to account for seasonal demand variations (e.g., 1.25 for high-demand periods like holidays, 0.85 for low-demand summer months). | Column seasonality_factor (DECIMAL(5,2)) in advertising.rate_card' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spotLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Spot Length Seconds' ;
    rdfs:comment 'Duration of the advertising spot in seconds for which the rate applies. Common lengths are 15, 30, 60, and 120 seconds. | Column spot_length_seconds (INT) in advertising.rate_card' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:viewabilityGuaranteePremium rdf:type rdf:Property ;
    rdfs:label 'Viewability Guarantee Premium' ;
    rdfs:comment 'Premium for guaranteed viewability' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advertiserId rdf:type rdf:Property ;
