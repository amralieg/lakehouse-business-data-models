    rdfs:comment 'Current lifecycle status of the sponsorship deal. [ENUM-REF-CANDIDATE: draft|proposed|negotiating|approved|active|fulfilled|cancelled|expired — 8 candidates stripped; promote to reference product] | Column sponsorship_status (STRING) in sales.sponsorship' ;
    rdfs:domain ind:Sponsorship ;
