ind:foundedDate rdf:type rdf:Property ;
    rdfs:label 'Founded Date' ;
    rdfs:comment 'Date team was founded' ;
    rdfs:domain ind:TalentSportsTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teamAbbreviation rdf:type rdf:Property ;
    rdfs:label 'Team Abbreviation' ;
    rdfs:comment 'Short abbreviation code for the team (e.g., NYY, LAL).' ;
    rdfs:domain ind:TalentSportsTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamColors rdf:type rdf:Property ;
    rdfs:label 'Team Colors' ;
    rdfs:comment 'Official team colors.' ;
    rdfs:domain ind:TalentSportsTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamLogoUrl rdf:type rdf:Property ;
    rdfs:label 'Team Logo Url' ;
    rdfs:comment 'URL to the official team logo asset.' ;
    rdfs:domain ind:TalentSportsTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamMarket rdf:type rdf:Property ;
    rdfs:label 'Team Market' ;
    rdfs:comment 'Designated market area (DMA) for the team.' ;
    rdfs:domain ind:TalentSportsTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentAthleteId rdf:type rdf:Property ;
    rdfs:label 'Talent Athlete Id' ;
    rdfs:comment 'Primary key for the athlete entity.' ;
    rdfs:domain ind:TalentAthlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statsFeedId rdf:type rdf:Property ;
    rdfs:label 'Stats Feed Id' ;
    rdfs:comment 'External ID for stats data feed integration' ;
    rdfs:domain ind:TalentAthlete ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BettingDataFeed .

ind:bioText rdf:type rdf:Property ;
    rdfs:label 'Bio Text' ;
    rdfs:comment 'Short biographical text for broadcast graphics.' ;
    rdfs:domain ind:TalentAthlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collegeUniversity rdf:type rdf:Property ;
    rdfs:label 'College University' ;
    rdfs:comment 'College or university attended before professional career.' ;
    rdfs:domain ind:TalentAthlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftPick rdf:type rdf:Property ;
    rdfs:label 'Draft Pick' ;
    rdfs:comment 'Overall pick number in the draft.' ;
    rdfs:domain ind:TalentAthlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:draftRound rdf:type rdf:Property ;
    rdfs:label 'Draft Round' ;
    rdfs:comment 'Round in which the athlete was drafted.' ;
    rdfs:domain ind:TalentAthlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:draftYear rdf:type rdf:Property ;
    rdfs:label 'Draft Year' ;
    rdfs:comment 'Year the athlete was drafted (if applicable).' ;
    rdfs:domain ind:TalentAthlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headshotUrl rdf:type rdf:Property ;
    rdfs:label 'Headshot Url' ;
    rdfs:comment 'URL to the athlete\'s official headshot image.' ;
    rdfs:domain ind:TalentAthlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Athlete\'s height in centimeters.' ;
    rdfs:domain ind:TalentAthlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:likenessRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Likeness Rights Flag' ;
    rdfs:comment 'Indicates if likeness rights are cleared for promotional use.' ;
    rdfs:domain ind:TalentAthlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yearsPro rdf:type rdf:Property ;
    rdfs:label 'Years Pro' ;
    rdfs:comment 'Number of years in professional leagues.' ;
    rdfs:domain ind:TalentAthlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAdEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ad Employee Id' ;
    rdfs:comment 'Reference to the sales representative responsible for this advertising order. Links to employee/user master record. | Column primary_ad_employee_id (BIGINT) in workforce.ad_order' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:salesAgencyId rdf:type rdf:Property ;
    rdfs:label 'Sales Agency Id' ;
    rdfs:comment 'Reference to the advertising agency representing the advertiser. Nullable if direct advertiser purchase. Links to agency master record. | Column sales_agency_id (BIGINT) in sales.ad_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesAgency .

ind:salesforceOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Id' ;
    rdfs:comment 'External reference to the originating sales opportunity in Salesforce Media Cloud CRM. 15 or 18 character Salesforce record ID. | Column salesforce_opportunity_id (BIGINT) in sales.ad_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:affidavitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Affidavit Required Flag' ;
    rdfs:comment 'Indicates whether proof of broadcast affidavits must be provided to the advertiser. True = affidavits required; False = not required. Affidavits document actual air times and are often required for political advertising. | Column affidavit_required_flag (BOOLEAN) in sales.ad_order' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the advertising order was confirmed by the advertiser or agency. Marks transition from pending to confirmed status. | Column confirmed_timestamp (TIMESTAMP) in sales.ad_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contractedCpm rdf:type rdf:Property ;
    rdfs:label 'Contracted Cpm' ;
    rdfs:comment 'Contracted Cost Per Mille (cost per thousand impressions) for this advertising order. Key pricing metric for media buying. | Column contracted_cpm (DECIMAL(10,2)) in sales.ad_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedCprp rdf:type rdf:Property ;
    rdfs:label 'Contracted Cprp' ;
    rdfs:comment 'Contracted Cost Per Rating Point. Pricing metric calculated as total cost divided by GRP. Used for market efficiency comparison. | Column contracted_cprp (DECIMAL(10,2)) in sales.ad_order' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mmmAdstockDecayRate rdf:type rdf:Property ;
    rdfs:label 'Mmm Adstock Decay Rate' ;
    rdfs:comment 'Rate at which advertising effect decays over time for MMM calculations' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mmmChannelContribution rdf:type rdf:Property ;
    rdfs:label 'Mmm Channel Contribution' ;
    rdfs:comment 'Marketing Mix Model estimated contribution of this channel to conversions' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mmmSaturationPoint rdf:type rdf:Property ;
    rdfs:label 'Mmm Saturation Point' ;
    rdfs:comment 'Estimated spend level at which diminishing returns begin for this channel' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Net revenue value after agency commissions, discounts, and adjustments. Amount recognized for revenue reporting. | Column net_order_value (DECIMAL(18,2)) in sales.ad_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Free-text notes and special instructions for this advertising order. May include trafficking instructions, creative specifications, or client preferences. | Column order_notes (STRING) in sales.ad_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:politicalAdFlag rdf:type rdf:Property ;
    rdfs:label 'Political Ad Flag' ;
    rdfs:comment 'Indicates whether this order contains political advertising content. True = political advertising; False = commercial advertising. Political ads have special FCC disclosure and equal-time requirements. | Column political_ad_flag (BOOLEAN) in sales.ad_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'Industry classification of the advertised product or service (e.g., automotive, pharmaceutical, retail, financial services). Used for content clearance and regulatory compliance. | Column product_category (STRING) in sales.ad_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTrp rdf:type rdf:Property ;
    rdfs:label 'Target Trp' ;
    rdfs:comment 'Target Rating Points for specific demographic audience. TRP measures delivery against a defined target audience segment rather than total audience. | Column target_trp (DECIMAL(10,2)) in sales.ad_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalContractedValue rdf:type rdf:Property ;
    rdfs:label 'Total Contracted Value' ;
    rdfs:comment 'Total monetary value of the advertising order across all spots and placements. Gross revenue before agency commissions and discounts. | Column total_contracted_value (DECIMAL(18,2)) in sales.ad_order' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSpotCount rdf:type rdf:Property ;
    rdfs:label 'Total Spot Count' ;
    rdfs:comment 'Total number of advertising spots (commercial airings) contracted in this order across all placements and dayparts. | Column total_spot_count (INT) in sales.ad_order' ;
    rdfs:domain ind:AdOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wideOrbitOrderReference rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Order Reference' ;
    rdfs:comment 'External reference to the corresponding order record in Wide Orbit traffic and billing system. Used for cross-system reconciliation and affidavit generation. | Column wide_orbit_order_reference (STRING) in sales.ad_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makegoodForLineId rdf:type rdf:Property ;
    rdfs:label 'Makegood For Line Id' ;
    rdfs:comment 'Reference to the original ad order line that this line is compensating for (if this is a makegood spot). Null if not a makegood. | Column makegood_for_line_id (BIGINT) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdOrderLine .

ind:actualImpressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Actual Impressions Delivered' ;
    rdfs:comment 'Actual number of impressions delivered for this line. Sourced from DAI (Dynamic Ad Insertion) systems or CDN (Content Delivery Network) logs for digital campaigns. | Column actual_impressions_delivered (BIGINT) in sales.ad_order_line' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionModelType rdf:type rdf:Property ;
    rdfs:label 'Attribution Model Type' ;
    rdfs:comment 'Type of attribution model applied (first-touch, last-touch, linear, time-decay, position-based, data-driven)' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionWeight rdf:type rdf:Property ;
    rdfs:label 'Attribution Weight' ;
    rdfs:comment 'Fractional credit assigned to this touchpoint in multi-touch attribution' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveSeparationCategory rdf:type rdf:Property ;
    rdfs:label 'Competitive Separation Category' ;
    rdfs:comment 'Product or industry category for competitive adjacency restrictions. Prevents competing advertisers from airing in the same pod. | Column competitive_separation_category (STRING) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedGrp rdf:type rdf:Property ;
    rdfs:label 'Contracted Grp' ;
    rdfs:comment 'Target Gross Rating Points (GRP) contracted for this line. GRP measures total audience reach multiplied by frequency. | Column contracted_grp (DECIMAL(10,2)) in sales.ad_order_line' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedImpressions rdf:type rdf:Property ;
    rdfs:label 'Contracted Impressions' ;
    rdfs:comment 'Total number of impressions (individual ad views) contracted for this line item. Used for digital and OTT (Over-The-Top) campaigns. | Column contracted_impressions (BIGINT) in sales.ad_order_line' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedSpots rdf:type rdf:Property ;
    rdfs:label 'Contracted Spots' ;
    rdfs:comment 'Total number of ad spots contracted for this line item. Represents the quantity commitment. | Column contracted_spots (INT) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedTrp rdf:type rdf:Property ;
    rdfs:label 'Contracted Trp' ;
    rdfs:comment 'Target Rating Points (TRP) contracted for this line. TRP measures reach within a specific demographic target. | Column contracted_trp (DECIMAL(10,2)) in sales.ad_order_line' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionPathPosition rdf:type rdf:Property ;
    rdfs:label 'Conversion Path Position' ;
    rdfs:comment 'Position of this touchpoint in the customer conversion path' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:copySplitRule rdf:type rdf:Property ;
    rdfs:label 'Copy Split Rule' ;
    rdfs:comment 'Rules defining how multiple creative versions should be split across the contracted spots (e.g., 50/50, 70/30). Used for A/B testing or creative variation. | Column copy_split_rule (STRING) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Total revenue amount for this line item (unit rate × contracted spots). Base amount before discounts or adjustments. | Column line_total_amount (DECIMAL(15,2)) in sales.ad_order_line' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionPreference rdf:type rdf:Property ;
    rdfs:label 'Position Preference' ;
    rdfs:comment 'Preferred position within the ad pod (group of ads in a break). Premium positions command higher rates. | Column position_preference (STRING) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue for this line is recognized for financial reporting. Typically aligned with air date or campaign completion. | Column revenue_recognition_date (DATE) in sales.ad_order_line' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rotationInstructions rdf:type rdf:Property ;
    rdfs:label 'Rotation Instructions' ;
    rdfs:comment 'Instructions for rotating multiple creatives within this line (e.g., even rotation, weighted rotation, sequential). Guides playout system behavior. | Column rotation_instructions (STRING) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingNotes rdf:type rdf:Property ;
    rdfs:label 'Special Handling Notes' ;
    rdfs:comment 'Free-text instructions for special handling requirements (e.g., live read, sponsorship billboard, product integration). Communicated to playout operators. | Column special_handling_notes (STRING) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchpointSequenceCode rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Sequence Code' ;
    rdfs:comment 'Identifier linking touchpoints in a conversion path for attribution analysis' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traffickingNotes rdf:type rdf:Property ;
    rdfs:label 'Trafficking Notes' ;
    rdfs:comment 'Internal notes for trafficking team regarding execution details, creative delivery status, or special coordination requirements. | Column trafficking_notes (STRING) in sales.ad_order_line' ;
    rdfs:domain ind:AdOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCampaignApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Campaign Approved By User Employee Id' ;
    rdfs:comment 'Reference to the user who approved the campaign for activation. | Column campaign_approved_by_user_employee_id (BIGINT) in workforce.campaign' ;
    rdfs:domain ind:SalesCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:makegoodEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Makegood Eligible Flag' ;
    rdfs:comment 'Indicates whether this campaign is eligible for makegood compensatory ad spots if contracted delivery targets are not met. | Column makegood_eligible_flag (BOOLEAN) in sales.campaign' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productBrand rdf:type rdf:Property ;
    rdfs:label 'Product Brand' ;
    rdfs:comment 'The product, service, or brand being advertised in this campaign. | Column product_brand (STRING) in sales.campaign' ;
    rdfs:domain ind:SalesCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmaticEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Programmatic Enabled Flag' ;
    rdfs:comment 'Flag indicating programmatic campaign' ;
    rdfs:domain ind:SalesCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'The sales channel through which the campaign was sold (upfront advance sales, scatter last-minute, programmatic automated, direct negotiated, or sponsorship). | Column sales_channel (STRING) in sales.campaign' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceCampaignReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Campaign Reference' ;
    rdfs:comment 'External reference identifier linking to the campaign record in Salesforce Media Cloud CRM system. | Column salesforce_campaign_reference (STRING) in sales.campaign' ;
    rdfs:domain ind:SalesCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCprp rdf:type rdf:Property ;
    rdfs:label 'Target Cprp' ;
    rdfs:comment 'Contracted target Cost Per Rating Point representing the cost to achieve one rating point. | Column target_cprp (DECIMAL(10,2)) in sales.campaign' ;
    rdfs:domain ind:SalesCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetFrequency rdf:type rdf:Property ;
    rdfs:label 'Target Frequency' ;
    rdfs:comment 'Contracted average number of times each unique audience member should be exposed to the campaign. | Column target_frequency (DECIMAL(5,2)) in sales.campaign' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetReachPercent rdf:type rdf:Property ;
    rdfs:label 'Target Reach Percent' ;
    rdfs:comment 'Contracted percentage of unique audience members to be reached by the campaign. | Column target_reach_percent (DECIMAL(5,2)) in sales.campaign' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSovPercent rdf:type rdf:Property ;
    rdfs:label 'Target Sov Percent' ;
    rdfs:comment 'Contracted target Share of Voice representing the percentage of total advertising impressions in the category or daypart. | Column target_sov_percent (DECIMAL(5,2)) in sales.campaign' ;
    rdfs:domain ind:SalesCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryAdvertiserCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Advertiser Created By User Employee Id' ;
    rdfs:comment 'The user identifier of the person who created this advertiser record. | Column advertiser_created_by_user_employee_id (BIGINT) in workforce.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryAdvertiserUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Advertiser Updated By User Employee Id' ;
    rdfs:comment 'The user identifier of the person who last modified this advertiser record. | Column advertiser_updated_by_user_employee_id (BIGINT) in workforce.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualSpendTier rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Tier' ;
    rdfs:comment 'The classification tier based on annual advertising spend volume, used for pricing, service level, and upfront negotiation priority. | Column annual_spend_tier (STRING) in sales.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'The credit approval status indicating whether the advertiser is authorized to purchase advertising on credit terms. | Column credit_status (STRING) in sales.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryCategory rdf:type rdf:Property ;
    rdfs:label 'Industry Category' ;
    rdfs:comment 'The Interactive Advertising Bureau (IAB) taxonomy category classifying the advertiser\'s primary business vertical (e.g., Automotive, Financial Services, Consumer Packaged Goods). | Column industry_category (STRING) in sales.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPoliticalAdvertiser rdf:type rdf:Property ;
    rdfs:label 'Is Political Advertiser' ;
    rdfs:comment 'Boolean flag indicating whether this advertiser is a political candidate, party, or issue advocacy group subject to FCC political advertising disclosure requirements. | Column is_political_advertiser (BOOLEAN) in sales.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentCompanyName rdf:type rdf:Property ;
    rdfs:label 'Parent Company Name' ;
    rdfs:comment 'The name of the parent or holding company if the advertiser is a subsidiary or brand within a larger corporate structure. | Column parent_company_name (STRING) in sales.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAdClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Ad Clearance' ;
    rdfs:comment 'Boolean flag indicating whether this advertiser\'s creative content requires pre-broadcast clearance review due to industry category (e.g., pharmaceuticals, alcohol, financial services). | Column requires_ad_clearance (BOOLEAN) in sales.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'The doing-business-as (DBA) or brand name used in advertising campaigns and public-facing materials. | Column trade_name (STRING) in sales.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideOrbitAdvertiserCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Advertiser Code' ;
    rdfs:comment 'The unique advertiser identifier in the Wide Orbit traffic and billing system, used for ad scheduling, sales orders, and invoicing. | Column wide_orbit_advertiser_code (STRING) in sales.advertiser' ;
    rdfs:domain ind:Advertiser ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTalentAgencyId rdf:type rdf:Property ;
    rdfs:label 'Sales Talent Agency Id' ;
    rdfs:comment 'Foreign key to SSOT talent.talent_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentAgency .

ind:accreditationDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Date' ;
    rdfs:comment 'Date when the agency was granted accreditation status by the broadcaster or industry body. | Column accreditation_date (DATE) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiry Date' ;
    rdfs:comment 'Date when the current accreditation status expires and requires renewal. Nullable for indefinite accreditation. | Column accreditation_expiry_date (DATE) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Current accreditation status of the agency with industry bodies or the broadcaster, indicating creditworthiness and eligibility for commission-based billing. | Column accreditation_status (STRING) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingModel rdf:type rdf:Property ;
    rdfs:label 'Billing Model' ;
    rdfs:comment 'Billing methodology used for this agency. Gross: agency bills advertiser full amount and remits net to broadcaster. Net: broadcaster bills agency net amount. Hybrid: mixed approach. | Column billing_model (STRING) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum credit amount (in base currency) extended to the agency for outstanding ad orders before payment is required. Used for credit risk management. | Column credit_limit (DECIMAL(15,2)) in sales.sales_agency' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingCompanyGroup rdf:type rdf:Property ;
    rdfs:label 'Holding Company Group' ;
    rdfs:comment 'Name of the parent holding company or agency network to which this agency belongs (e.g., WPP, Omnicom, Publicis, IPG, Dentsu). Null if independent. | Column holding_company_group (STRING) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesAgencyName rdf:type rdf:Property ;
    rdfs:label 'Sales Agency Name' ;
    rdfs:comment 'Full legal or trade name of the advertising agency or media buying firm. | Column sales_agency_name (STRING) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date when the agency was first onboarded and approved to place advertising orders with the broadcaster. | Column onboarding_date (DATE) in sales.sales_agency' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesAgencyStatus rdf:type rdf:Property ;
    rdfs:label 'Sales Agency Status' ;
    rdfs:comment 'Current operational status of the agency relationship. Active agencies can place orders; inactive/suspended/terminated agencies cannot. | Column sales_agency_status (STRING) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusReason rdf:type rdf:Property ;
    rdfs:label 'Status Reason' ;
    rdfs:comment 'Explanation or business reason for the current status, particularly for inactive, suspended, or terminated statuses (e.g., credit issues, contract expiration, voluntary closure). | Column status_reason (STRING) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideOrbitAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Agency Code' ;
    rdfs:comment 'Unique agency identifier code used in the Wide Orbit traffic and billing system for ad scheduling, sales orders, and invoicing. | Column wide_orbit_agency_code (STRING) in sales.sales_agency' ;
    rdfs:domain ind:SalesAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adSpotId rdf:type rdf:Property ;
    rdfs:label 'Ad Spot Id' ;
    rdfs:comment 'Unique identifier for the individual advertisement spot placement. Primary key for the ad spot entity. | Column ad_spot_id (BIGINT) in sales.ad_spot' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdSpot .

ind:originalSpotAdSpotId rdf:type rdf:Property ;
    rdfs:label 'Original Spot Ad Spot Id' ;
    rdfs:comment 'Reference to the original ad spot that this makegood spot is compensating for. Populated only when makegood_flag is true. | Column original_spot_ad_spot_id (BIGINT) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdSpot .

ind:actualAirTime rdf:type rdf:Property ;
    rdfs:label 'Actual Air Time' ;
    rdfs:comment 'The actual date and time when this ad spot aired, as recorded in the broadcast affidavit. Used for proof of performance and billing reconciliation. | Column actual_air_time (TIMESTAMP) in sales.ad_spot' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current billing status of this spot. Tracks the spot through the billing lifecycle from unbilled through payment or dispute resolution. | Column billing_status (STRING) in sales.ad_spot' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusSpotFlag rdf:type rdf:Property ;
    rdfs:label 'Bonus Spot Flag' ;
    rdfs:comment 'Indicates whether this spot was provided as a bonus (added value) to the advertiser at no additional charge. Used for revenue recognition and campaign value calculation. | Column bonus_spot_flag (BOOLEAN) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Code identifying the broadcast channel or network where the spot aired (e.g., ABC, NBC, ESPN). Links to channel master data. | Column channel_code (STRING) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpmAmount rdf:type rdf:Property ;
    rdfs:label 'Cpm Amount' ;
    rdfs:comment 'Cost per thousand impressions for this spot. Key pricing metric in advertising sales used to compare efficiency across different placements. | Column cpm_amount (DECIMAL(10,2)) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daiFlag rdf:type rdf:Property ;
    rdfs:label 'Dai Flag' ;
    rdfs:comment 'Indicates whether this spot was delivered via Dynamic Ad Insertion technology, allowing personalized ad delivery to different viewers or platforms. | Column dai_flag (BOOLEAN) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Impressions Delivered' ;
    rdfs:comment 'Total number of impressions (views) delivered by this spot. Used for performance measurement and billing reconciliation. | Column impressions_delivered (BIGINT) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:makegoodFlag rdf:type rdf:Property ;
    rdfs:label 'Makegood Flag' ;
    rdfs:comment 'Indicates whether this spot is a makegood (compensatory ad spot provided to an advertiser due to a previous preemption or underdelivery). | Column makegood_flag (BOOLEAN) in sales.ad_spot' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rotationPattern rdf:type rdf:Property ;
    rdfs:label 'Rotation Pattern' ;
    rdfs:comment 'Describes the rotation or sequencing pattern for this spot within the campaign (e.g., ROS - Run of Schedule, fixed position, alternating). Used for inventory management and fulfillment. | Column rotation_pattern (STRING) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:separationRequirement rdf:type rdf:Property ;
    rdfs:label 'Separation Requirement' ;
    rdfs:comment 'Specifies any separation rules for this spot (e.g., competitive separation, minimum time between airings). Ensures advertiser requirements are met. | Column separation_requirement (STRING) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotRateAmount rdf:type rdf:Property ;
    rdfs:label 'Spot Rate Amount' ;
    rdfs:comment 'The rate charged for this individual spot placement. May differ from the order line rate due to daypart, program, or inventory adjustments. | Column spot_rate_amount (DECIMAL(15,2)) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spotRateCurrency rdf:type rdf:Property ;
    rdfs:label 'Spot Rate Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the spot rate amount (e.g., USD, GBP, EUR). | Column spot_rate_currency (STRING) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotStatus rdf:type rdf:Property ;
    rdfs:label 'Spot Status' ;
    rdfs:comment 'Current lifecycle status of the ad spot. Tracks whether the spot was scheduled, successfully aired, preempted, cancelled, or requires makegood processing. | Column spot_status (STRING) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficLogReference rdf:type rdf:Property ;
    rdfs:label 'Traffic Log Reference' ;
    rdfs:comment 'Reference identifier to the Wide Orbit traffic log entry that scheduled and tracked this spot. Used for audit trail and reconciliation. | Column traffic_log_reference (STRING) in sales.ad_spot' ;
    rdfs:domain ind:AdSpot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandId rdf:type rdf:Property ;
    rdfs:label 'Brand Id' ;
    rdfs:comment 'Reference to the specific brand or product line being promoted in this creative. Links to the brand master record. | Column brand_id (BIGINT) in sales.isci_creative' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:previousVersionIsciCreativeId rdf:type rdf:Property ;
    rdfs:label 'Previous Version Isci Creative Id' ;
    rdfs:comment 'Reference to the immediately preceding version of this creative, if this is a revision. Null for the original version. Enables version lineage tracking. | Column previous_version_isci_creative_id (BIGINT) in sales.isci_creative' ;
    rdfs:domain ind:IsciCreative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IsciCreative .

ind:primaryIsciEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Isci Employee Id' ;
    rdfs:comment 'Reference to the user who created this creative record in the system. Used for audit trail and accountability. | Column primary_isci_employee_id (BIGINT) in workforce.isci_creative' ;
    rdfs:domain ind:IsciCreative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adStandardsClearanceId rdf:type rdf:Property ;
    rdfs:label 'Ad Standards Clearance Id' ;
    rdfs:comment 'Foreign key linking to compliance.ad_standards_clearance. Business justification: Creative assets must pass ad standards clearance before airing. Broadcasters track clearance approval status, rejection reasons, and certificate numbers for each ISCI code to ensure only approved cont | Column ad_standards_clearance_id (BIGINT) in sales.isci_creative' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audioStandard rdf:type rdf:Property ;
    rdfs:label 'Audio Standard' ;
    rdfs:comment 'The audio encoding and channel configuration standard used in the creative. Includes stereo, surround sound formats (Dolby Digital, Dolby Atmos, DTS), and codec specifications (AAC). | Column audio_standard (STRING) in sales.isci_creative' ;
    rdfs:domain ind:IsciCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeDescription rdf:type rdf:Property ;
    rdfs:label 'Creative Description' ;
    rdfs:comment 'Detailed narrative description of the creative content, messaging, and visual elements. Used for trafficking, clearance review, and internal reference. | Column creative_description (STRING) in sales.isci_creative' ;
    rdfs:domain ind:IsciCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeFormat rdf:type rdf:Property ;
    rdfs:label 'Creative Format' ;
    rdfs:comment 'The media format and delivery channel for which this creative is designed. Determines playout system routing and technical specifications. [ENUM-REF-CANDIDATE: linear_tv|digital_pre_roll|digital_mid_roll|digital_post_roll|audio_radio|audio_podcast|ott_streaming|social_media|display_banner — 9 candidates stripped; promote to reference product] | Column creative_format (STRING) in sales.isci_creative' ;
    rdfs:domain ind:IsciCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeTitle rdf:type rdf:Property ;
    rdfs:label 'Creative Title' ;
    rdfs:comment 'The human-readable name or title of the advertising creative, typically describing the campaign theme or message (e.g., \'Summer Sale 2024\', \'New Product Launch\'). | Column creative_title (STRING) in sales.isci_creative' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletAssetReference rdf:type rdf:Property ;
    rdfs:label 'Dalet Asset Reference' ;
    rdfs:comment 'Reference identifier linking this ISCI creative record to the corresponding digital asset file stored in the Dalet Galaxy Media Asset Management system. Used for asset retrieval and playout automation. | Column dalet_asset_reference (STRING) in sales.isci_creative' ;
    rdfs:domain ind:IsciCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:politicalAdIndicator rdf:type rdf:Property ;
    rdfs:label 'Political Ad Indicator' ;
    rdfs:comment 'Indicates whether this creative is a political advertisement subject to FCC political advertising disclosure and equal time requirements. Triggers mandatory public inspection file documentation. | Column political_ad_indicator (BOOLEAN) in sales.isci_creative' ;
    rdfs:domain ind:IsciCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedContentFlags rdf:type rdf:Property ;
    rdfs:label 'Restricted Content Flags' ;
    rdfs:comment 'Comma-separated list of content restriction flags indicating special handling requirements (e.g., \'alcohol\', \'gambling\', \'political\', \'pharmaceutical\', \'tobacco\'). Triggers daypart restrictions and disclosure requirements. | Column restricted_content_flags (STRING) in sales.isci_creative' ;
    rdfs:domain ind:IsciCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alcoholAdAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Alcohol Ad Allowed Flag' ;
    rdfs:comment 'Indicates whether alcohol advertising is permitted within this ad pod, based on daypart restrictions and content adjacency policies. | Column alcohol_ad_allowed_flag (BOOLEAN) in sales.ad_pod' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audienceTargetDemo rdf:type rdf:Property ;
    rdfs:label 'Audience Target Demo' ;
    rdfs:comment 'Primary demographic audience segment targeted by this ad pod, typically expressed in age-gender format (e.g., A18-49, W25-54, M18-34) per Nielsen measurement standards. | Column audience_target_demo (STRING) in sales.ad_pod' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicMarketCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Market Code' ;
    rdfs:comment 'Nielsen Designated Market Area (DMA) code or equivalent geographic market identifier where this ad pod airs, used for regional targeting and blackout enforcement. | Column geographic_market_code (STRING) in sales.ad_pod' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryClass rdf:type rdf:Property ;
    rdfs:label 'Inventory Class' ;
    rdfs:comment 'Classification of the ad pod inventory by pricing tier and sales priority. Premium for high-demand slots, standard for regular inventory, remnant for unsold last-minute inventory, bonus for value-added makegoods. | Column inventory_class (STRING) in sales.ad_pod' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSpotCount rdf:type rdf:Property ;
    rdfs:label 'Max Spot Count' ;
    rdfs:comment 'Maximum number of individual ad spots that can be scheduled within this pod, governing inventory capacity. | Column max_spot_count (INT) in sales.ad_pod' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:podCode rdf:type rdf:Property ;
    rdfs:label 'Pod Code' ;
    rdfs:comment 'Unique business identifier or code for the ad pod used in trafficking and billing systems. | Column pod_code (STRING) in sales.ad_pod' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Pod Duration Seconds' ;
    rdfs:comment 'Total duration of the ad pod in seconds, representing the maximum time allocated for all ad spots within this break. | Column pod_duration_seconds (INT) in sales.ad_pod' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:podName rdf:type rdf:Property ;
    rdfs:label 'Pod Name' ;
    rdfs:comment 'Human-readable name or label for the ad pod, often used for internal identification and trafficking purposes. | Column pod_name (STRING) in sales.ad_pod' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podRateCardCpm rdf:type rdf:Property ;
    rdfs:label 'Pod Rate Card Cpm' ;
    rdfs:comment 'Standard rate card Cost Per Mille (cost per thousand impressions) for this ad pod, used as the baseline pricing for inventory sales negotiations. | Column pod_rate_card_cpm (DECIMAL(12,2)) in sales.ad_pod' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podStatus rdf:type rdf:Property ;
    rdfs:label 'Pod Status' ;
    rdfs:comment 'Current lifecycle status of the ad pod. Scheduled indicates planned but not locked, confirmed indicates inventory committed, aired indicates successfully broadcast, preempted indicates replaced by higher-priority content, cancelled indicates removed from schedule, makegoods_required indicates compensatory spots needed due to delivery issues. | Column pod_status (STRING) in sales.ad_pod' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podType rdf:type rdf:Property ;
    rdfs:label 'Pod Type' ;
    rdfs:comment 'Classification of the ad pod by content purpose. Commercial for paid advertising, promotional for network self-promotion, PSA (Public Service Announcement) for non-profit messaging, network for national inventory, affiliate for station-level inventory, local for regional inventory. | Column pod_type (STRING) in sales.ad_pod' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:politicalAdAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Political Ad Allowed Flag' ;
    rdfs:comment 'Indicates whether political advertising is permitted within this ad pod, subject to FCC equal time and disclosure requirements. | Column political_ad_allowed_flag (BOOLEAN) in sales.ad_pod' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesMarket rdf:type rdf:Property ;
    rdfs:label 'Sales Market' ;
    rdfs:comment 'Market channel through which the ad pod inventory was sold. Upfront for advance commitment sales, scatter for last-minute inventory sales, programmatic for automated bidding platforms, direct for one-on-one advertiser deals. | Column sales_market (STRING) in sales.ad_pod' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scte35CuePointReference rdf:type rdf:Property ;
    rdfs:label 'Scte35 Cue Point Reference' ;
    rdfs:comment 'Reference identifier for the SCTE-35 (Society of Cable Telecommunications Engineers) cue point that triggers this ad pod insertion in the broadcast stream. | Column scte35_cue_point_reference (STRING) in sales.ad_pod' ;
    rdfs:domain ind:AdPod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advertisingMakegoodId rdf:type rdf:Property ;
    rdfs:label 'Advertising Makegood Id' ;
    rdfs:comment 'Reference to the makegood order created to compensate for this discrepancy, if applicable. | Column advertising_makegood_id (BIGINT) in sales.affidavit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Makegood .

ind:publicInspectionFileId rdf:type rdf:Property ;
    rdfs:label 'Public Inspection File Id' ;
    rdfs:comment 'Foreign key linking to compliance.public_inspection_file. Business justification: Political advertising affidavits must be maintained in the public inspection file per FCC rules. Broadcasters link affidavits to public file entries documenting actual air dates, times, and rates char | Column public_inspection_file_id (BIGINT) in compliance.affidavit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PublicInspectionFile .

ind:actualAirDate rdf:type rdf:Property ;
    rdfs:label 'Actual Air Date' ;
    rdfs:comment 'The date the ad spot actually aired as confirmed by playout system logs. | Column actual_air_date (DATE) in sales.affidavit' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSpotLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Actual Spot Length Seconds' ;
    rdfs:comment 'The actual duration in seconds that the ad spot aired as measured by playout system. | Column actual_spot_length_seconds (INT) in sales.affidavit' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affidavitNumber rdf:type rdf:Property ;
    rdfs:label 'Affidavit Number' ;
    rdfs:comment 'Business identifier for the affidavit document. Externally-known unique reference number used for billing finalization and compliance documentation. | Column affidavit_number (STRING) in sales.affidavit' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAmount rdf:type rdf:Property ;
    rdfs:label 'Billing Amount' ;
    rdfs:comment 'The amount billed for this ad spot as documented in this affidavit. Used for revenue recognition and reconciliation. | Column billing_amount (DECIMAL(15,2)) in sales.affidavit' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedSpotLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Contracted Spot Length Seconds' ;
    rdfs:comment 'The duration in seconds that was contracted and paid for in the sales order. | Column contracted_spot_length_seconds (INT) in sales.affidavit' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Date and time when the affidavit was delivered to the advertiser or agency. | Column delivery_timestamp (TIMESTAMP) in sales.affidavit' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discrepancyDescription rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Description' ;
    rdfs:comment 'Detailed explanation of the discrepancy, including root cause and impact. Used for makegood processing and client communication. | Column discrepancy_description (STRING) in sales.affidavit' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicates whether there was any discrepancy between the contracted spot parameters and what actually aired. True if discrepancy exists, False if spot aired as contracted. | Column discrepancy_flag (BOOLEAN) in sales.affidavit' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Classification of the type of discrepancy if one occurred. None indicates spot aired exactly as contracted. [ENUM-REF-CANDIDATE: wrong_time|wrong_length|preempted|wrong_creative|wrong_channel|missed|none — 7 candidates stripped; promote to reference product] | Column discrepancy_type (STRING) in sales.affidavit' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Generation Timestamp' ;
    rdfs:comment 'Date and time when this affidavit record was first generated by the traffic system. This is the record audit created timestamp. | Column generation_timestamp (TIMESTAMP) in sales.affidavit' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:playoutSystemLogReference rdf:type rdf:Property ;
    rdfs:label 'Playout System Log Reference' ;
    rdfs:comment 'Reference to the playout automation system log entry that provides technical proof of broadcast. | Column playout_system_log_reference (STRING) in sales.affidavit' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wideOrbitAffidavitReference rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Affidavit Reference' ;
    rdfs:comment 'External reference identifier from the Wide Orbit traffic and billing system for cross-system reconciliation. | Column wide_orbit_affidavit_reference (STRING) in sales.affidavit' ;
    rdfs:domain ind:Affidavit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makegoodId rdf:type rdf:Property ;
    rdfs:label 'Makegood Id' ;
    rdfs:comment 'Primary key for makegood | Column makegood_id (BIGINT) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_allocation. Business justification: Makegoods represent cost of service delivery failures. Cost of quality reporting and operational cost allocation require linking makegoods to cost allocation records for accurate cost center accountab | Column cost_allocation_id (BIGINT) in finance.makegood' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostAllocation .

ind:originalAdSpotId rdf:type rdf:Property ;
    rdfs:label 'Original Ad Spot Id' ;
    rdfs:comment 'Reference to the original ad spot that failed to air as scheduled and triggered this makegood. | Column original_ad_spot_id (BIGINT) in sales.makegood' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdSpot .

ind:originalIsciCreativeId rdf:type rdf:Property ;
    rdfs:label 'Original Isci Creative Id' ;
    rdfs:comment 'Foreign key linking to sales.isci_creative. Business justification: Normalize creative reference for the original spot being made good. Makegood record needs to reference which creative was supposed to air originally. Currently denormalized as original_isci_code STRIN | Column original_isci_creative_id (BIGINT) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IsciCreative .

ind:primaryMakegoodOriginalChannelId rdf:type rdf:Property ;
    rdfs:label 'Primary Makegood Original Channel Id' ;
    rdfs:comment 'Reference to the channel on which the original ad spot was scheduled to air. | Column makegood_original_channel_id (BIGINT) in scheduling.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:affidavitDate rdf:type rdf:Property ;
    rdfs:label 'Affidavit Date' ;
    rdfs:comment 'The date on which the affidavit for the makegood spot was generated and issued. | Column affidavit_date (DATE) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affidavitGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Affidavit Generated Flag' ;
    rdfs:comment 'Indicates whether a proof-of-broadcast affidavit has been generated for the aired makegood spot. | Column affidavit_generated_flag (BOOLEAN) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:makegoodNumber rdf:type rdf:Property ;
    rdfs:label 'Makegood Number' ;
    rdfs:comment 'Business identifier for the makegood record, used in external communications and affidavits. | Column makegood_number (STRING) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalActualGrp rdf:type rdf:Property ;
    rdfs:label 'Original Actual Grp' ;
    rdfs:comment 'The actual GRP delivered by the original spot if it aired but underperformed, triggering a ratings shortfall makegood. | Column original_actual_grp (DECIMAL(10,2)) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalContractedGrp rdf:type rdf:Property ;
    rdfs:label 'Original Contracted Grp' ;
    rdfs:comment 'The GRP value that was contracted for the original ad spot, used to assess audience underdelivery. | Column original_contracted_grp (DECIMAL(10,2)) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalDaypart rdf:type rdf:Property ;
    rdfs:label 'Original Daypart' ;
    rdfs:comment 'The broadcast daypart (time segment) in which the original spot was scheduled, such as Prime, Early Fringe, Late Night. | Column original_daypart (STRING) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalProgramName rdf:type rdf:Property ;
    rdfs:label 'Original Program Name' ;
    rdfs:comment 'The name of the program during which the original ad spot was scheduled to air. | Column original_program_name (STRING) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Original Scheduled Date' ;
    rdfs:comment 'The date on which the original ad spot was scheduled to air before the failure occurred. | Column original_scheduled_date (DATE) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalScheduledTime rdf:type rdf:Property ;
    rdfs:label 'Original Scheduled Time' ;
    rdfs:comment 'The precise timestamp at which the original ad spot was scheduled to air. | Column original_scheduled_time (TIMESTAMP) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalSpotLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Original Spot Length Seconds' ;
    rdfs:comment 'The duration in seconds of the original ad spot that failed to air. | Column original_spot_length_seconds (INT) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalSpotRate rdf:type rdf:Property ;
    rdfs:label 'Original Spot Rate' ;
    rdfs:comment 'The contracted rate (in USD) for the original ad spot that failed to air. | Column original_spot_rate (DECIMAL(15,2)) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedDaypart rdf:type rdf:Property ;
    rdfs:label 'Proposed Daypart' ;
    rdfs:comment 'The broadcast daypart proposed for the makegood replacement spot. | Column proposed_daypart (STRING) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedEstimatedGrp rdf:type rdf:Property ;
    rdfs:label 'Proposed Estimated Grp' ;
    rdfs:comment 'The estimated GRP that the proposed makegood replacement spot is expected to deliver. | Column proposed_estimated_grp (DECIMAL(10,2)) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedProgramName rdf:type rdf:Property ;
    rdfs:label 'Proposed Program Name' ;
    rdfs:comment 'The name of the program during which the makegood replacement spot is proposed to air. | Column proposed_program_name (STRING) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedReplacementDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Replacement Date' ;
    rdfs:comment 'The date proposed by the broadcaster for airing the makegood replacement spot. | Column proposed_replacement_date (DATE) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedReplacementTime rdf:type rdf:Property ;
    rdfs:label 'Proposed Replacement Time' ;
    rdfs:comment 'The precise timestamp proposed for airing the makegood replacement spot. | Column proposed_replacement_time (TIMESTAMP) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proposedSpotLengthSeconds rdf:type rdf:Property ;
    rdfs:label 'Proposed Spot Length Seconds' ;
    rdfs:comment 'The duration in seconds of the proposed makegood replacement spot. | Column proposed_spot_length_seconds (INT) in sales.makegood' ;
    rdfs:domain ind:Makegood ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySalesRepId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Rep Id' ;
    rdfs:comment 'Reference to the sales account executive responsible for this proposal and the advertiser relationship. | Column primary_sales_rep_id (BIGINT) in sales.sales_proposal' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:rfpId rdf:type rdf:Property ;
    rdfs:label 'Rfp Id' ;
    rdfs:comment 'Foreign key linking to sales.rfp. Business justification: Proposals are often created in response to RFPs. This FK enables tracing proposals back to the RFP they respond to. N:1 relationship (one proposal per RFP in the context of a single seller responding) | Column rfp_id (BIGINT) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfp .

ind:acceptedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Accepted Timestamp' ;
    rdfs:comment 'Timestamp when the proposal was accepted by the advertiser or agency. Null if not yet accepted or if rejected. | Column accepted_timestamp (TIMESTAMP) in sales.sales_proposal' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:agencyCommissionPercentage rdf:type rdf:Property ;
    rdfs:label 'Agency Commission Percentage' ;
    rdfs:comment 'Agency commission percentage to be paid to the agency from the gross proposal value. Typically 15% in the industry. Null if direct advertiser buy. | Column agency_commission_percentage (DECIMAL(5,2)) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audienceGuaranteeFlag rdf:type rdf:Property ;
    rdfs:label 'Audience Guarantee Flag' ;
    rdfs:comment 'Indicates whether the proposal includes an audience delivery guarantee with makegood provisions if targets are not met. | Column audience_guarantee_flag (BOOLEAN) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:campaignEndDate rdf:type rdf:Property ;
    rdfs:label 'Campaign End Date' ;
    rdfs:comment 'Proposed end date for the advertising campaign covered by this proposal. | Column campaign_end_date (DATE) in sales.sales_proposal' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:campaignStartDate rdf:type rdf:Property ;
    rdfs:label 'Campaign Start Date' ;
    rdfs:comment 'Proposed start date for the advertising campaign covered by this proposal. | Column campaign_start_date (DATE) in sales.sales_proposal' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationTerms rdf:type rdf:Property ;
    rdfs:label 'Cancellation Terms' ;
    rdfs:comment 'Terms and conditions for cancellation of the proposal or resulting order, including notice periods and penalties. | Column cancellation_terms (STRING) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelMixSummary rdf:type rdf:Property ;
    rdfs:label 'Channel Mix Summary' ;
    rdfs:comment 'High-level summary of the proposed channel distribution (e.g., 60% Linear TV, 30% OTT, 10% Digital). Detailed channel breakdown is in proposal line items. | Column channel_mix_summary (STRING) in sales.sales_proposal' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveSituation rdf:type rdf:Property ;
    rdfs:label 'Competitive Situation' ;
    rdfs:comment 'Internal notes on competitive dynamics, other bidders, and strategic positioning for this proposal. | Column competitive_situation (STRING) in sales.sales_proposal' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentAdjacencyPreferences rdf:type rdf:Property ;
    rdfs:label 'Content Adjacency Preferences' ;
    rdfs:comment 'Client-specified preferences or restrictions for content types adjacent to ad placements (e.g., sports, news, drama, avoid violent content). | Column content_adjacency_preferences (STRING) in sales.sales_proposal' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartMixSummary rdf:type rdf:Property ;
    rdfs:label 'Daypart Mix Summary' ;
    rdfs:comment 'High-level summary of the proposed daypart distribution (e.g., 40% Prime, 30% Early Fringe, 20% Late Night, 10% Weekend). Detailed daypart breakdown is in proposal line items. | Column daypart_mix_summary (STRING) in sales.sales_proposal' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demographicTarget rdf:type rdf:Property ;
    rdfs:label 'Demographic Target' ;
    rdfs:comment 'Primary audience demographic segment targeted by this proposal, expressed in standard Nielsen notation (e.g., Adults 25-54, Women 18-49). | Column demographic_target (STRING) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteedImpressions rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Impressions' ;
    rdfs:comment 'Minimum number of impressions contractually guaranteed to be delivered, triggering makegood obligations if underdelivered. | Column guaranteed_impressions (BIGINT) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netProposedValue rdf:type rdf:Property ;
    rdfs:label 'Net Proposed Value' ;
    rdfs:comment 'Net revenue value of the proposal after discounts and agency commissions. This is the expected revenue to the broadcaster. | Column net_proposed_value (DECIMAL(18,2)) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformMix rdf:type rdf:Property ;
    rdfs:label 'Platform Mix' ;
    rdfs:comment 'Distribution of proposed inventory across delivery platforms: linear (traditional broadcast), OTT (over-the-top streaming), FAST (free ad-supported streaming TV), AVOD (advertising video on demand), SVOD (subscription video on demand). | Column platform_mix (STRING) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalDate rdf:type rdf:Property ;
    rdfs:label 'Proposal Date' ;
    rdfs:comment 'Date when the proposal was created and issued to the advertiser or agency. | Column proposal_date (DATE) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposalDescription rdf:type rdf:Property ;
    rdfs:label 'Proposal Description' ;
    rdfs:comment 'Detailed narrative description of the proposal, including campaign objectives, creative strategy, and value proposition. | Column proposal_description (STRING) in sales.sales_proposal' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalName rdf:type rdf:Property ;
    rdfs:label 'Proposal Name' ;
    rdfs:comment 'Descriptive name or title of the proposal, typically reflecting the campaign or client name. | Column proposal_name (STRING) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalNumber rdf:type rdf:Property ;
    rdfs:label 'Proposal Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the proposal, used in client communications and internal tracking. | Column proposal_number (STRING) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalSource rdf:type rdf:Property ;
    rdfs:label 'Proposal Source' ;
    rdfs:comment 'Origin or trigger for this proposal: response to RFP (request for proposal), proactive sales pitch, contract renewal, upsell to existing client, or cross-sell of additional services. | Column proposal_source (STRING) in sales.sales_proposal' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalStatus rdf:type rdf:Property ;
    rdfs:label 'Proposal Status' ;
    rdfs:comment 'Current lifecycle status of the advertising proposal in the sales workflow. | Column proposal_status (STRING) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalType rdf:type rdf:Property ;
    rdfs:label 'Proposal Type' ;
    rdfs:comment 'Category of commercial offer: advertising (spot sales), content licensing (rights acquisition), syndication (content resale), distribution (carriage agreements), sponsorship (branded integration), or upfront (advance commitment). | Column proposal_type (STRING) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedFrequency rdf:type rdf:Property ;
    rdfs:label 'Proposed Frequency' ;
    rdfs:comment 'Proposed average frequency (number of times) that each reached individual in the target audience will be exposed to the campaign. Frequency = GRP / Reach. | Column proposed_frequency (DECIMAL(10,2)) in sales.sales_proposal' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedGrp rdf:type rdf:Property ;
    rdfs:label 'Proposed Grp' ;
    rdfs:comment 'Total Gross Rating Points (GRP) proposed to be delivered across all dayparts and channels. GRP measures the total exposure weight of the campaign. | Column proposed_grp (DECIMAL(10,2)) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedImpressions rdf:type rdf:Property ;
    rdfs:label 'Proposed Impressions' ;
    rdfs:comment 'Total number of impressions (ad views) proposed to be delivered across all channels and platforms in this campaign. | Column proposed_impressions (BIGINT) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposedReach rdf:type rdf:Property ;
    rdfs:label 'Proposed Reach' ;
    rdfs:comment 'Proposed reach as a percentage of the target audience that will be exposed to the campaign at least once. Reach measures unique audience coverage. | Column proposed_reach (DECIMAL(10,2)) in sales.sales_proposal' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedTrp rdf:type rdf:Property ;
    rdfs:label 'Proposed Trp' ;
    rdfs:comment 'Total Target Rating Points (TRP) proposed to be delivered to the specific demographic target audience. TRP measures exposure within the target demo only. | Column proposed_trp (DECIMAL(10,2)) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejected Timestamp' ;
    rdfs:comment 'Timestamp when the proposal was rejected by the advertiser or agency. Null if not rejected. | Column rejected_timestamp (TIMESTAMP) in sales.sales_proposal' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Requested or required date by which the client should provide a decision or response to the proposal. | Column response_due_date (DATE) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spotLengthMixSummary rdf:type rdf:Property ;
    rdfs:label 'Spot Length Mix Summary' ;
    rdfs:comment 'High-level summary of the proposed spot length distribution (e.g., 80% :30s, 15% :15s, 5% :60s). Detailed spot length breakdown is in proposal line items. | Column spot_length_mix_summary (STRING) in sales.sales_proposal' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'Date when the proposal was formally submitted to the client or agency for review. | Column submitted_date (DATE) in sales.sales_proposal' ;
    rdfs:domain ind:SalesProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Timestamp when the proposal was formally submitted to the advertiser or agency. Null if still in draft status. | Column submitted_timestamp (TIMESTAMP) in sales.sales_proposal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Legal and commercial terms governing the proposal, including payment terms, cancellation policies, makegood provisions, and liability clauses. | Column terms_and_conditions (STRING) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalProposedValue rdf:type rdf:Property ;
    rdfs:label 'Total Proposed Value' ;
    rdfs:comment 'Total gross revenue value of the proposal in the base currency, before any discounts or agency commissions. Sum of all proposed line items. | Column total_proposed_value (DECIMAL(18,2)) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:winProbabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Win Probability Percent' ;
    rdfs:comment 'Sales team estimated probability of winning this proposal, expressed as a percentage (0-100). | Column win_probability_percent (DECIMAL(5,2)) in sales.sales_proposal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upfrontDealId rdf:type rdf:Property ;
    rdfs:label 'Upfront Deal Id' ;
    rdfs:comment 'Unique identifier for the upfront advertising deal negotiation record. Primary key. Role: MASTER_AGREEMENT. | Column upfront_deal_id (BIGINT) in sales.upfront_deal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UpfrontDeal .

ind:primaryUpfrontEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Upfront Employee Id' ;
    rdfs:comment 'Reference to the sales account executive responsible for negotiating and managing this upfront deal. Links to the employee/user master record. | Column primary_upfront_employee_id (BIGINT) in workforce.upfront_deal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:privateMarketplaceDealId rdf:type rdf:Property ;
    rdfs:label 'Private Marketplace Deal Id' ;
    rdfs:comment 'FK to private marketplace deal for programmatic-direct' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivateMarketplaceDeal .

ind:tertiaryUpfrontModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Upfront Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this deal record. Links to the employee/user master record for audit and accountability. | Column tertiary_upfront_modified_by_user_employee_id (BIGINT) in workforce.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:audienceGuaranteeGrp rdf:type rdf:Property ;
    rdfs:label 'Audience Guarantee Grp' ;
    rdfs:comment 'Total Gross Rating Points (GRP) guaranteed to the advertiser across all flights and dayparts in this deal. GRP = Reach × Frequency, representing the total audience delivery commitment. | Column audience_guarantee_grp (DECIMAL(10,2)) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audienceGuaranteeImpressions rdf:type rdf:Property ;
    rdfs:label 'Audience Guarantee Impressions' ;
    rdfs:comment 'Total number of ad impressions guaranteed to the advertiser. Alternative or complementary metric to GRP, especially for digital and cross-platform deals. | Column audience_guarantee_impressions (BIGINT) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationOptionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Cancellation Option Window Days' ;
    rdfs:comment 'Number of days before flight start date within which the advertiser may cancel or reduce the commitment without penalty. Common in upfront deals to provide flexibility. | Column cancellation_option_window_days (INT) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelMix rdf:type rdf:Property ;
    rdfs:label 'Channel Mix' ;
    rdfs:comment 'Comma-separated list or description of broadcast channels, networks, or platforms included in this deal (e.g., Network Prime, Cable Bundle, OTT Streaming). Defines the inventory scope. | Column channel_mix (STRING) in sales.upfront_deal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Date' ;
    rdfs:comment 'Date when the advertiser or agency verbally or formally committed to the deal terms. Nullable until commitment is secured. | Column commitment_date (DATE) in sales.upfront_deal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cpmRate rdf:type rdf:Property ;
    rdfs:label 'Cpm Rate' ;
    rdfs:comment 'Cost per thousand impressions for CPM-based deals. Nullable if pricing basis is not CPM. Represents the unit price for audience delivery. | Column cpm_rate (DECIMAL(10,2)) in sales.upfront_deal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cprpRate rdf:type rdf:Property ;
    rdfs:label 'Cprp Rate' ;
    rdfs:comment 'Cost per rating point for CPRP-based deals. Nullable if pricing basis is not CPRP. Represents the unit price per GRP delivered. | Column cprp_rate (DECIMAL(10,2)) in sales.upfront_deal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealYear rdf:type rdf:Property ;
    rdfs:label 'Deal Year' ;
    rdfs:comment 'Broadcast year for which this upfront deal applies, typically representing the September-to-August broadcast season (e.g., 2024 for 2024-2025 season). Critical for upfront planning and inventory allocation. | Column deal_year (INT) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:makegoodProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Makegood Provision Flag' ;
    rdfs:comment 'Indicates whether the deal includes makegood provisions for audience delivery shortfalls. True = makegoods required if guaranteed audience is not delivered; False = no makegood obligation. | Column makegood_provision_flag (BOOLEAN) in sales.upfront_deal' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiationRoundCount rdf:type rdf:Property ;
    rdfs:label 'Negotiation Round Count' ;
    rdfs:comment 'Number of formal negotiation rounds or proposal revisions submitted during the deal lifecycle. Tracks negotiation complexity and sales effort. | Column negotiation_round_count (INT) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingBasis rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis' ;
    rdfs:comment 'Pricing model used for this deal. CPM (Cost Per Mille) = cost per thousand impressions; CPRP (Cost Per Rating Point) = cost per GRP point; Flat Rate = fixed fee regardless of delivery; Performance = outcome-based pricing. | Column pricing_basis (STRING) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceOpportunityReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Reference' ;
    rdfs:comment 'External reference to the corresponding Salesforce Media Cloud Opportunity record. Enables cross-system traceability between the deal negotiation (Salesforce) and trafficking/billing (Wide Orbit). | Column salesforce_opportunity_reference (STRING) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scatterConversionRights rdf:type rdf:Property ;
    rdfs:label 'Scatter Conversion Rights' ;
    rdfs:comment 'Indicates whether the advertiser has the right to convert unused upfront commitment into scatter market inventory at preferential rates. True = conversion allowed; False = no conversion rights. | Column scatter_conversion_rights (BOOLEAN) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCommittedSpend rdf:type rdf:Property ;
    rdfs:label 'Total Committed Spend' ;
    rdfs:comment 'Total dollar value of advertising spend committed by the advertiser after negotiation. Nullable until commitment is secured. This is the final agreed revenue amount. | Column total_committed_spend (DECIMAL(18,2)) in sales.upfront_deal' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProposedSpend rdf:type rdf:Property ;
    rdfs:label 'Total Proposed Spend' ;
    rdfs:comment 'Total dollar value of advertising spend proposed in the initial deal submission. Represents the gross revenue opportunity before negotiation adjustments. | Column total_proposed_spend (DECIMAL(18,2)) in sales.upfront_deal' ;
    rdfs:domain ind:UpfrontDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advertisingAudienceGuaranteeId rdf:type rdf:Property ;
    rdfs:label 'Advertising Audience Guarantee Id' ;
    rdfs:comment 'Unique identifier for the audience delivery guarantee record. | Column advertising_audience_guarantee_id (BIGINT) in sales.advertising_audience_guarantee' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'The monetary credit amount owed to the advertiser if makegoods are not provided for underdelivery. | Column credit_amount (DECIMAL(15,2)) in sales.advertising_audience_guarantee' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveredGrp rdf:type rdf:Property ;
    rdfs:label 'Delivered Grp' ;
    rdfs:comment 'The actual Gross Rating Point (GRP) delivered to date as measured by Nielsen or other audience measurement provider. | Column delivered_grp (DECIMAL(12,2)) in sales.advertising_audience_guarantee' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveredImpressions rdf:type rdf:Property ;
    rdfs:label 'Delivered Impressions' ;
    rdfs:comment 'The actual number of impressions delivered to date as measured by the audience measurement system. | Column delivered_impressions (BIGINT) in sales.advertising_audience_guarantee' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveredTrp rdf:type rdf:Property ;
    rdfs:label 'Delivered Trp' ;
    rdfs:comment 'The actual Target Rating Point (TRP) delivered to date for the specified demographic segment. | Column delivered_trp (DECIMAL(12,2)) in sales.advertising_audience_guarantee' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryPercentage rdf:type rdf:Property ;
    rdfs:label 'Delivery Percentage' ;
    rdfs:comment 'The percentage of the contracted guarantee that has been delivered, calculated as (delivered / contracted) * 100. | Column delivery_percentage (DECIMAL(5,2)) in sales.advertising_audience_guarantee' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryVarianceGrp rdf:type rdf:Property ;
    rdfs:label 'Delivery Variance Grp' ;
    rdfs:comment 'The difference between contracted and delivered GRP, calculated as delivered minus contracted (negative indicates underdelivery). | Column delivery_variance_grp (DECIMAL(12,2)) in sales.advertising_audience_guarantee' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteeNumber rdf:type rdf:Property ;
    rdfs:label 'Guarantee Number' ;
    rdfs:comment 'Business identifier for the audience guarantee, used for tracking and reporting purposes. | Column guarantee_number (STRING) in sales.advertising_audience_guarantee' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Guarantee Period End Date' ;
    rdfs:comment 'The end date of the period during which the audience guarantee applies. | Column guarantee_period_end_date (DATE) in sales.advertising_audience_guarantee' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guaranteePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Guarantee Period Start Date' ;
    rdfs:comment 'The start date of the period during which the audience guarantee applies. | Column guarantee_period_start_date (DATE) in sales.advertising_audience_guarantee' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guaranteeStatus rdf:type rdf:Property ;
    rdfs:label 'Guarantee Status' ;
    rdfs:comment 'Current status of the audience guarantee: on_track (meeting targets), at_risk (trending toward underdelivery), underdelivered (below threshold), fulfilled (completed successfully), cancelled (guarantee voided). | Column guarantee_status (STRING) in sales.advertising_audience_guarantee' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMeasurementDate rdf:type rdf:Property ;
    rdfs:label 'Last Measurement Date' ;
    rdfs:comment 'The date of the most recent audience measurement update used to calculate delivery performance. | Column last_measurement_date (DATE) in sales.advertising_audience_guarantee' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:makegoodGrpOwed rdf:type rdf:Property ;
    rdfs:label 'Makegood Grp Owed' ;
    rdfs:comment 'The amount of GRP that must be delivered through makegood spots to fulfill the guarantee obligation. | Column makegood_grp_owed (DECIMAL(12,2)) in sales.advertising_audience_guarantee' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkStationCode rdf:type rdf:Property ;
    rdfs:label 'Network Station Code' ;
    rdfs:comment 'The broadcast network or station identifier where the guaranteed audience delivery is measured. | Column network_station_code (STRING) in sales.advertising_audience_guarantee' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextEvaluationDate rdf:type rdf:Property ;
    rdfs:label 'Next Evaluation Date' ;
    rdfs:comment 'The scheduled date for the next evaluation of guarantee delivery performance. | Column next_evaluation_date (DATE) in sales.advertising_audience_guarantee' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:underdeliveryThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Underdelivery Threshold Percentage' ;
    rdfs:comment 'The contractual threshold percentage below which underdelivery triggers makegood or credit obligations (e.g., 95% means delivery below 95% triggers makegoods). | Column underdelivery_threshold_percentage (DECIMAL(5,2)) in sales.advertising_audience_guarantee' ;
    rdfs:domain ind:AdvertisingAudienceGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daiEventId rdf:type rdf:Property ;
    rdfs:label 'Dai Event Id' ;
    rdfs:comment 'Unique identifier for the dynamic ad insertion event record. Primary key. | Column dai_event_id (BIGINT) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daiMediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Dai Media Asset Id' ;
    rdfs:comment 'Foreign key linking to mediaasset.media_asset. Business justification: Dynamic ad insertion events must track which specific media asset file was served to the viewer for billing reconciliation, QC audits, and content delivery verification. Essential for programmatic ad  | Column media_asset_id (BIGINT) in mediaasset.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:adDecisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ad Decision Timestamp' ;
    rdfs:comment 'Precise timestamp when the DAI platform made the ad selection decision for this insertion opportunity. | Column ad_decision_timestamp (TIMESTAMP) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Ad Duration Seconds' ;
    rdfs:comment 'Duration of the inserted ad creative in seconds (e.g., 15, 30, 60 seconds). | Column ad_duration_seconds (INT) in sales.dai_event' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adServerTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Ad Server Transaction Reference' ;
    rdfs:comment 'Transaction identifier from the upstream ad server (e.g., Wide Orbit, FreeWheel) that authorized this ad insertion. | Column ad_server_transaction_reference (STRING) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidPriceCpm rdf:type rdf:Property ;
    rdfs:label 'Bid Price Cpm' ;
    rdfs:comment 'Winning bid price in CPM (cost per thousand impressions) for this ad insertion in programmatic auction scenarios. | Column bid_price_cpm (DECIMAL(10,4)) in sales.dai_event' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdnNodeReference rdf:type rdf:Property ;
    rdfs:label 'Cdn Node Reference' ;
    rdfs:comment 'Identifier of the CDN edge node that delivered the ad content to the viewer. Used for delivery performance tracking. | Column cdn_node_reference (STRING) in sales.dai_event' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Completion Rate Percent' ;
    rdfs:comment 'Percentage of the ad duration that was actually viewed by the user before skipping or abandoning (0.00 to 100.00). | Column completion_rate_percent (DECIMAL(5,2)) in sales.dai_event' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daiPlatformName rdf:type rdf:Property ;
    rdfs:label 'Dai Platform Name' ;
    rdfs:comment 'Name of the DAI platform that executed this ad insertion (e.g., Google DAI, FreeWheel, Adobe Primetime). | Column dai_platform_name (STRING) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daiPlatformVersion rdf:type rdf:Property ;
    rdfs:label 'Dai Platform Version' ;
    rdfs:comment 'Version identifier of the DAI platform software used for this insertion event. | Column dai_platform_version (STRING) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmed Flag' ;
    rdfs:comment 'Boolean flag indicating whether the CDN confirmed successful delivery of the ad content to the viewer\'s device. | Column delivery_confirmed_flag (BOOLEAN) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fallbackReason rdf:type rdf:Property ;
    rdfs:label 'Fallback Reason' ;
    rdfs:comment 'Reason code or description explaining why a fallback ad was used instead of the primary targeted ad (e.g., targeting mismatch, inventory unavailable, technical constraint). | Column fallback_reason (STRING) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoLocationCode rdf:type rdf:Property ;
    rdfs:label 'Geo Location Code' ;
    rdfs:comment 'Geographic location code (DMA, postal code, or country code) of the viewer at the time of ad insertion, used for geo-targeting. | Column geo_location_code (STRING) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionFiredFlag rdf:type rdf:Property ;
    rdfs:label 'Impression Fired Flag' ;
    rdfs:comment 'Boolean flag indicating whether the impression tracking URL was successfully fired and acknowledged. | Column impression_fired_flag (BOOLEAN) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impressionFiredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Impression Fired Timestamp' ;
    rdfs:comment 'Timestamp when the impression tracking beacon was fired, marking the billable impression event. | Column impression_fired_timestamp (TIMESTAMP) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:impressionTrackingUrl rdf:type rdf:Property ;
    rdfs:label 'Impression Tracking Url' ;
    rdfs:comment 'URL fired to record the ad impression event. Used for third-party verification and billing reconciliation. | Column impression_tracking_url (STRING) in sales.dai_event' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insertionPointTimecode rdf:type rdf:Property ;
    rdfs:label 'Insertion Point Timecode' ;
    rdfs:comment 'Timecode within the content stream where the ad insertion was triggered, typically corresponding to an SCTE-35 cue marker. | Column insertion_point_timecode (STRING) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insertionStatus rdf:type rdf:Property ;
    rdfs:label 'Insertion Status' ;
    rdfs:comment 'Status outcome of the ad insertion attempt: inserted (successful), fallback (backup ad used), no-fill (no ad available), error (technical failure), or skipped (viewer action). | Column insertion_status (STRING) in sales.dai_event' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacySignal rdf:type rdf:Property ;
    rdfs:label 'Privacy Signal' ;
    rdfs:comment 'Privacy signal or consent string passed from the viewer\'s device (e.g., IAB TCF consent string, US Privacy string). | Column privacy_signal (STRING) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quartileReached rdf:type rdf:Property ;
    rdfs:label 'Quartile Reached' ;
    rdfs:comment 'Highest quartile milestone reached during ad playback: start, first quartile (25%), midpoint (50%), third quartile (75%), complete (100%), or none. | Column quartile_reached (STRING) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemName rdf:type rdf:Property ;
    rdfs:label 'Source System Name' ;
    rdfs:comment 'Name of the source system that generated this DAI event record (e.g., Google DAI API, FreeWheel event stream). | Column source_system_name (STRING) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userConsentStatus rdf:type rdf:Property ;
    rdfs:label 'User Consent Status' ;
    rdfs:comment 'Privacy consent status of the viewer for personalized ad targeting: granted, denied, not required (non-EU), or unknown. | Column user_consent_status (STRING) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userInteractionType rdf:type rdf:Property ;
    rdfs:label 'User Interaction Type' ;
    rdfs:comment 'Type of user interaction with the ad during playback: none, click-through, skip, pause, mute, or expand. | Column user_interaction_type (STRING) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Viewability Status' ;
    rdfs:comment 'Viewability measurement status indicating whether the ad met viewability criteria (e.g., 50% of pixels visible for 2+ seconds per IAB standards). | Column viewability_status (STRING) in sales.dai_event' ;
    rdfs:domain ind:DaiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Impression Delivery Id' ;
    rdfs:comment 'Unique identifier for the digital or streaming advertising impression delivery record. | Column impression_delivery_id (BIGINT) in sales.impression_delivery' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:browserType rdf:type rdf:Property ;
    rdfs:label 'Browser Type' ;
    rdfs:comment 'Web browser used to view the impression, if applicable. | Column browser_type (STRING) in sales.impression_delivery' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnDeliveryConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Cdn Delivery Confirmed Flag' ;
    rdfs:comment 'Boolean flag indicating whether the CDN confirmed successful delivery of the impression. | Column cdn_delivery_confirmed_flag (BOOLEAN) in sales.impression_delivery' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clickThroughRatePercent rdf:type rdf:Property ;
    rdfs:label 'Click Through Rate Percent' ;
    rdfs:comment 'Percentage of impressions that resulted in a click-through, calculated as click-throughs divided by total impressions served. | Column click_through_rate_percent (DECIMAL(5,2)) in sales.impression_delivery' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clickThroughs rdf:type rdf:Property ;
    rdfs:label 'Click Throughs' ;
    rdfs:comment 'Number of times viewers clicked on the ad to visit the advertiser\'s destination. | Column click_throughs (BIGINT) in sales.impression_delivery' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completedViews rdf:type rdf:Property ;
    rdfs:label 'Completed Views' ;
    rdfs:comment 'Number of impressions where the viewer watched the ad to completion. | Column completed_views (BIGINT) in sales.impression_delivery' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpmRealized rdf:type rdf:Property ;
    rdfs:label 'Cpm Realized' ;
    rdfs:comment 'Actual cost per thousand impressions realized for this delivery event. | Column cpm_realized (DECIMAL(15,4)) in sales.impression_delivery' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoTargetCode rdf:type rdf:Property ;
    rdfs:label 'Geo Target Code' ;
    rdfs:comment 'ISO country or region code representing the geographic targeting applied to this impression. | Column geo_target_code (STRING) in sales.impression_delivery' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'Operating system of the device that received the impression. | Column operating_system (STRING) in sales.impression_delivery' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyVerificationSource rdf:type rdf:Property ;
    rdfs:label 'Third Party Verification Source' ;
    rdfs:comment 'Name of the third-party verification service that validated this impression delivery. | Column third_party_verification_source (STRING) in sales.impression_delivery' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalImpressionsServed rdf:type rdf:Property ;
    rdfs:label 'Total Impressions Served' ;
    rdfs:comment 'Total number of impressions delivered in this event. | Column total_impressions_served (BIGINT) in sales.impression_delivery' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:viewabilityRatePercent rdf:type rdf:Property ;
    rdfs:label 'Viewability Rate Percent' ;
    rdfs:comment 'Percentage of impressions that met viewability standards, calculated as viewable impressions divided by total impressions served. | Column viewability_rate_percent (DECIMAL(5,2)) in sales.impression_delivery' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewableImpressions rdf:type rdf:Property ;
    rdfs:label 'Viewable Impressions' ;
    rdfs:comment 'Number of impressions that met the IAB viewability standard (50% of pixels in view for 2+ seconds for display, 50% for 2+ seconds for video). | Column viewable_impressions (BIGINT) in sales.impression_delivery' ;
    rdfs:domain ind:ImpressionDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesScatterOrderId rdf:type rdf:Property ;
    rdfs:label 'Sales Scatter Order Id' ;
    rdfs:comment 'Unique identifier for the scatter market advertising order. Primary key for the sales scatter order entity. | Column sales_scatter_order_id (BIGINT) in sales.sales_scatter_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesScatterOrder .

ind:primarySalesEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Employee Id' ;
    rdfs:comment 'Reference to the sales account executive responsible for this scatter order. Used for commission calculation and performance tracking. | Column primary_sales_employee_id (BIGINT) in workforce.sales_scatter_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primarySalesforceOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Primary Salesforce Opportunity Id' ;
    rdfs:comment 'External identifier linking this scatter order to the originating sales opportunity in Salesforce Media Cloud. Enables CRM integration and sales pipeline tracking. | Column primary_salesforce_opportunity_id (BIGINT) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:salesRepId rdf:type rdf:Property ;
    rdfs:label 'Sales Rep Id' ;
    rdfs:comment 'Reference to the sales representative who negotiated and closed this scatter order. | Column sales_rep_id (BIGINT) in sales.sales_scatter_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:scatterOrderId rdf:type rdf:Property ;
    rdfs:label 'Scatter Order Id' ;
    rdfs:comment 'Foreign key linking to sales.scatter_order. Business justification: sales_scatter_order and scatter_order appear to represent the same business entity at different lifecycle stages (proposal vs. confirmed). Linking them tracks the progression from scatter order reques | Column scatter_order_id (BIGINT) in sales.sales_scatter_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScatterOrder .

ind:agencyCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Agency Commission Rate' ;
    rdfs:comment 'Agency commission rate percentage deducted from the gross order value. Standard agency commission is typically 15% in the advertising industry. | Column agency_commission_rate (DECIMAL(5,2)) in sales.sales_scatter_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Deadline Date' ;
    rdfs:comment 'Last date by which the advertiser may cancel this scatter order without penalty. After this date, cancellation fees may apply. | Column cancellation_deadline_date (DATE) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractTerms rdf:type rdf:Property ;
    rdfs:label 'Contract Terms' ;
    rdfs:comment 'Free-text field capturing special contractual terms, conditions, or notes specific to this scatter order. May include payment terms, delivery guarantees, or custom provisions. | Column contract_terms (STRING) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredGrps rdf:type rdf:Property ;
    rdfs:label 'Delivered Grps' ;
    rdfs:comment 'Actual Gross Rating Points (GRPs) delivered for linear broadcast inventory. Compared against requested GRPs to assess fulfillment. | Column delivered_grps (DECIMAL(10,2)) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercent rdf:type rdf:Property ;
    rdfs:label 'Discount Percent' ;
    rdfs:comment 'Percentage discount applied to the scatter order total. May reflect volume discounts, promotional pricing, or negotiated rate adjustments. | Column discount_percent (DECIMAL(5,2)) in sales.sales_scatter_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatedCpm rdf:type rdf:Property ;
    rdfs:label 'Negotiated Cpm' ;
    rdfs:comment 'Negotiated Cost Per Mille (CPM) rate for this scatter order. Represents the cost per thousand impressions. Scatter market CPM is typically at a premium to upfront rates. | Column negotiated_cpm (DECIMAL(12,2)) in sales.sales_scatter_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatedCprp rdf:type rdf:Property ;
    rdfs:label 'Negotiated Cprp' ;
    rdfs:comment 'Negotiated Cost Per Rating Point (CPRP) for linear broadcast inventory. Represents the cost per single rating point. | Column negotiated_cprp (DECIMAL(12,2)) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Net Order Amount' ;
    rdfs:comment 'Final order amount after discounts and adjustments. Represents the actual revenue expected from this scatter order. | Column net_order_amount (DECIMAL(15,2)) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preemptibilityClass rdf:type rdf:Property ;
    rdfs:label 'Preemptibility Class' ;
    rdfs:comment 'Classification of whether and how scatter spots can be preempted by higher-value inventory. Non-preemptible spots are guaranteed to air; preemptible spots may be bumped for higher-paying advertisers. Critical distinction from upfront deals. | Column preemptibility_class (STRING) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preemptionProtectionLevel rdf:type rdf:Property ;
    rdfs:label 'Preemption Protection Level' ;
    rdfs:comment 'Numeric priority level for preemption protection (1-10, where 10 is highest protection). Determines which orders are preempted first when inventory conflicts arise. | Column preemption_protection_level (INT) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preemptionRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Preemption Risk Flag' ;
    rdfs:comment 'Boolean flag indicating whether this scatter order is subject to preemption by higher-rated inventory. True indicates the order may be bumped if higher-priority demand emerges. | Column preemption_risk_flag (BOOLEAN) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedAirEndDate rdf:type rdf:Property ;
    rdfs:label 'Requested Air End Date' ;
    rdfs:comment 'Last date of the requested air window for scatter market spots. Defines the flight period for the scatter campaign. | Column requested_air_end_date (DATE) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedAirStartDate rdf:type rdf:Property ;
    rdfs:label 'Requested Air Start Date' ;
    rdfs:comment 'First date of the requested air window for scatter market spots. Typically 4-12 weeks from order date, distinguishing scatter from upfront buys. | Column requested_air_start_date (DATE) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedGrps rdf:type rdf:Property ;
    rdfs:label 'Requested Grps' ;
    rdfs:comment 'Total Gross Rating Points (GRPs) requested for linear broadcast inventory. Represents reach multiplied by frequency. | Column requested_grps (DECIMAL(10,2)) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedImpressions rdf:type rdf:Property ;
    rdfs:label 'Requested Impressions' ;
    rdfs:comment 'Total number of advertising impressions requested by the advertiser for this scatter order. Used for digital and streaming inventory. | Column requested_impressions (BIGINT) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestedSpots rdf:type rdf:Property ;
    rdfs:label 'Requested Spots' ;
    rdfs:comment 'Number of individual advertising spots or units requested in this scatter order. | Column requested_spots (INT) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresClearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Clearance Flag' ;
    rdfs:comment 'Indicates whether advertising creative requires legal or standards clearance before airing. Common for political ads, pharmaceutical products, and sensitive content. | Column requires_clearance_flag (BOOLEAN) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scatterCpmAmount rdf:type rdf:Property ;
    rdfs:label 'Scatter Cpm Amount' ;
    rdfs:comment 'Cost per thousand impressions for this scatter order. Typically at a premium to upfront CPM due to short lead time and market conditions. CPM is the standard pricing metric in broadcast advertising. | Column scatter_cpm_amount (DECIMAL(12,2)) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Total Order Amount' ;
    rdfs:comment 'Total monetary value of the scatter order before discounts or adjustments. Calculated from spot count, CPM, and estimated impressions. | Column total_order_amount (DECIMAL(15,2)) in sales.sales_scatter_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Total monetary value of the scatter order before any adjustments. Calculated based on negotiated rates and requested volume. | Column total_order_value (DECIMAL(15,2)) in sales.sales_scatter_order' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSpotsOrdered rdf:type rdf:Property ;
    rdfs:label 'Total Spots Ordered' ;
    rdfs:comment 'Total number of advertising spots purchased in this scatter order. Represents the quantity of impressions the advertiser is buying. | Column total_spots_ordered (INT) in sales.sales_scatter_order' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wideOrbitOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Wide Orbit Order Number' ;
    rdfs:comment 'External order number assigned by Wide Orbit traffic and billing system for scatter market buys. Used for cross-system reconciliation and affidavit tracking. | Column wide_orbit_order_number (STRING) in sales.sales_scatter_order' ;
    rdfs:domain ind:SalesScatterOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentPartnerPartnerPartnerId rdf:type rdf:Property ;
    rdfs:label 'Content Partner Partner Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_partner. Business justification: Sponsorships require tracking the content partner (network, producer, syndicator) delivering the sponsored property, distinct from the agency. Real business process: sponsorship fulfillment verificati | Column content_partner_partner_partner_id (BIGINT) in partner.sponsorship' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partner .

ind:primarySponsorshipApprovedByUserEmployeeId rdf:type rdf:Property ;
