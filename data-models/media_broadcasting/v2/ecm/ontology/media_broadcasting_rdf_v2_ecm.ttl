    rdfs:comment 'The scheduled date for the next depreciation calculation. Used for planning period-end close and financial reporting cycles. | Column next_depreciation_run_date (DATE) in finance.depreciation_schedule' ;
    rdfs:domain ind:DepreciationSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalCost rdf:type rdf:Property ;
    rdfs:label 'Original Cost' ;
