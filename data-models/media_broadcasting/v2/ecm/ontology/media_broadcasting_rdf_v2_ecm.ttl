ind:mailingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the contact\'s mailing address. | Column mailing_postal_code (STRING) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Mailing State Province' ;
    rdfs:comment 'State, province, or region for the contact\'s mailing address. | Column mailing_state_province (STRING) in sales.sales_contact' ;
    rdfs:domain ind:SalesContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile or cellular phone number for urgent or time-sensitive communication during upfront or scatter market negotiations. | Column mobile_number (STRING) in sales.sales_contact' ;
    rdfs:domain ind:MediaBroadcasting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Next Follow Up Date' ;
