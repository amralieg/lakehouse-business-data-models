    rdfs:comment 'The name of the microservice or backend service that implements and owns this endpoint (e.g., content-service, playback-service, subscriber-service). Used for operational ownership and incident routing. | Column owning_service (STRING) in distribution.api_endpoint' ;
    rdfs:domain ind:ApiEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningTeam rdf:type rdf:Property ;
