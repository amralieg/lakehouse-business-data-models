    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Required' ;
    rdfs:comment 'Indicates whether compliance information or related documents must be made publicly available (e.g., in FCC Online Public Inspection File). | Column public_disclosure_required (BOOLEAN) in compliance.regulatory_obligation' ;
